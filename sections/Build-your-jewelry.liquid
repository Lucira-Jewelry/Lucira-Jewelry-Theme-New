{{ 'build-your-jewelery.css' | asset_url | stylesheet_tag }}

{% if page.handle == 'build-your-jewelry' %}
  <style>
    @media screen and (max-width: 768px) {
      predictive-search.search-modal__form {
        display: none !important;
      }
    }
  </style>
{% endif %}

<section id="Section--{{ section.id }}" class="brad">
  <div class="sefllove-header-div">
    <div class="selflove-container">
      <div class="selflove-left">
        <img
          src="{{ section.settings.main_image | img_url: 'master' }}"
          alt="{{ section.settings.heading | escape }}"
          loading="lazy"
          width="auto"
          height="auto"
        >
      </div>
      <div class="selflove-right">
        <p class="selflove-subheading">{{ section.settings.subheading }}</p>
        <h2 class="selflove-heading">{{ section.settings.heading }}</h2>
        <p class="selflove-description">{{ section.settings.description }}</p>

        <div class="selflove-options">
          {% for block in section.blocks %}
            {% if section.settings.option_url != blank %}
              <div class="option" {{ block.shopify_attributes }}>
                <a
                  href="{{ section.settings.option_url }}?collection={{ block.settings.collection_url.handle }}"
                  onclick="
                    try{
                       localStorage.setItem('selected_chain_type','{{ block.settings.collection_url.handle }}');
                       console.log('Selected chain type saved:', '{{ block.settings.collection_url.handle }}');
                    }catch(e){console.log(e);}
                  "
                >
                  <img
                    src="{{ block.settings.option_image | img_url: 'medium' }}"
                    alt="{{ block.settings.option_text | escape }}"
                    loading="lazy"
                    width="auto"
                    height="auto"
                  >
                  <p>{{ block.settings.option_text }}</p>
                </a>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  async function storeLocalData(collectionHandle) {
    if (!collectionHandle) return;
    try {
      localStorage.setItem('selected_chain_type', collectionHandle);
    } catch (error) {
      console.error('Failed to store collection handle:', error);
    }
  }
</script>

{% schema %}
{
  "name": "SelfLove Chain Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Left Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "YOUR STORY, YOUR SPARKLE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE SELFLOVE CHAIN"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Design your own personalized lab-grown diamond chain — whether it's a necklace, bracelet, or anklet — with our online builder, and celebrate every chapter of your journey with timeless brilliance and meaningful charms."
    },
    {
      "type": "url",
      "id": "option_url",
      "label": "Option URL"
    }
  ],
  "blocks": [
    {
      "type": "chain_option",
      "name": "Chain Option",
      "settings": [
        {
          "type": "image_picker",
          "id": "option_image",
          "label": "Option Image"
        },
        {
          "type": "text",
          "id": "option_text",
          "label": "Option Text",
          "default": "BRACELET"
        },
        {
          "type": "collection",
          "id": "collection_url",
          "label": "Choose Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SelfLove Chain Section"
    }
  ]
}
{% endschema %}
