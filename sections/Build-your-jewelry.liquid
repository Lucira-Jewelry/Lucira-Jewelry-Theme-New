<style>
.selflove-options a {
  color: #000;
}


.selflove-right {
  padding: 0 60px;
}
.sefllove-header-div {
  margin-bottom: 1%;
}

/* Main Section */
.selflove-section {
  margin-bottom: 5%;
  width: 100%;
  height: 100%;
}

/* Container */
.selflove-container {
  display: flex;
  align-items: center;
  gap: 20px;
}

/* Left & Right Columns */
.selflove-left,
.selflove-right {
  width: 50%;
  text-align: center;
}

/* Left Image Section */
.selflove-left {
  height: 800px;
  overflow: hidden;
}

.selflove-left img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top;
  display: block;
}

/* Text Section */
.selflove-subheading {
  font-size: 20px;
  letter-spacing: 1px;
  text-transform: uppercase;
  font-weight: 400;
}

.selflove-heading {
  font-size: 50px;
  font-weight: 500;
  margin: -15px 0 0;
}

.selflove-description {
  font-size: 14px;
  margin-bottom: 25px;
  line-height: 22px;
}

/* Options Section */
.selflove-options {
  display: flex;
  gap: 15px;
  justify-content: center;
}

.sefllove-header-div .option img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.sefllove-header-div .option p {
  margin-top: -20px;
  font-size: 17px;
  font-weight: 500;
}

/* ---------------------------
      Responsive Styles
----------------------------*/

/* Tablet */
@media (max-width: 768px) {

  .selflove-container {
    flex-wrap: wrap;
  }

  .selflove-left,
  .selflove-right {
    width: 100%;
  }

  .sefllove-header-div,
  .sefllove-header-div .option,
  .sefllove-header-div .option img {
    height: auto;
    max-height: 100%;
  }

  .selflove-right {
    padding: 0 10px;
  }

  .sefllove-header-div .option p {
    margin-top: 0;
    font-size: 12px;
    font-weight: 400;
  }

  .selflove-description {
    font-size: 13px;
    margin-bottom: 25px;
    line-height: 19px;
  }

  .selflove-heading {
    margin: -9px 0 0;
    font-size: 27px;
  }

  .selflove-subheading {
    font-size: 13px;
  }

  .selflove-left {
    height: 40vh;
  }

  .selflove-options {
    gap: 6px;
  }
}

/* Mobile */
 @media screen and (min-width:900px) and (max-width:1600px) {
 .selflove-left{
  height:500px;
 } 
}
</style>
{% if page.handle == 'build-your-jewelry' %}
  <style>
    @media screen and (max-width: 768px) {
      predictive-search.search-modal__form {
        display: none !important;
      }
    }
  </style>
{% endif %}


<section id="Section--{{ section.id }}" class="brad">
  <div class="sefllove-header-div">
    <div class="selflove-container">
      <div class="selflove-left">
        <img 
          src="{{ section.settings.main_image | img_url: 'master' }}" 
          alt="{{ section.settings.heading | escape }}" 
          loading="lazy"
          width="auto"
          height="auto"
        >
      </div>
      <div class="selflove-right">
        <p class="selflove-subheading">{{ section.settings.subheading }}</p>
        <h2 class="selflove-heading">{{ section.settings.heading }}</h2>
        <p class="selflove-description">{{ section.settings.description }}</p>

        <div class="selflove-options">
          {% for block in section.blocks %}
            {% if section.settings.option_url != blank %}
              <div class="option" {{ block.shopify_attributes }}>
               <a href="{{ section.settings.option_url }}?collection={{ block.settings.collection_url.handle }}"
                 onclick="try{ localStorage.setItem('selected_chain_type','{{ block.settings.collection_url.handle }}'); }catch(e){}">

                  <img
                    src="{{ block.settings.option_image | img_url: 'medium' }}"
                    alt="{{ block.settings.option_text | escape }}"
                    loading="lazy"
                     width="auto"
                      height="auto"
                  >
                  <p>{{ block.settings.option_text }}</p>
                </a>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  async function storeLocalData(collectionHandle) {
    if (!collectionHandle) return;
    try {
      localStorage.setItem('selected_chain_type', collectionHandle);
    } catch (error) {
      console.error('Failed to store collection handle:', error);
    }
  }
 

</script>


{% schema %}
{
  "name": "SelfLove Chain Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Left Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "YOUR STORY, YOUR SPARKLE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE SELFLOVE CHAIN"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Design your own personalized lab-grown diamond chain — whether it's a necklace, bracelet, or anklet — with our online builder, and celebrate every chapter of your journey with timeless brilliance and meaningful charms."
    },
    {
      "type": "url",
      "id": "option_url",
      "label": "Option URL"
    }
  ],
  "blocks": [
    {
      "type": "chain_option",
      "name": "Chain Option",
      "settings": [
        {
          "type": "image_picker",
          "id": "option_image",
          "label": "Option Image"
        },
        {
          "type": "text",
          "id": "option_text",
          "label": "Option Text",
          "default": "BRACELET"
        },
        {
          "type": "collection",
          "id": "collection_url",
          "label": "Choose Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SelfLove Chain Section",
      
    }
  ]
}
{% endschema %}
