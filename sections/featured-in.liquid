<style>



  .featured-in-web{padding:30px 0px 30px;background:#fff}
  .featured-in-parent{text-align:center;margin-bottom:40px}
  .featured-in{margin-bottom:10px;font-family:Futura,sans-serif;font-weight:500;line-height:150%;vertical-align:middle;text-transform:uppercase;color:#1a1a1a;text-align:center;margin:0;font-size:24px;letter-spacing:1px}
  .into-the-web{font-size:18px;color:#666}
  .logos-container{display:flex;flex-wrap:nowrap;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;-ms-overflow-style:none;gap:20px;padding:10px 0;justify-content:flex-start}
  .logos-container::-webkit-scrollbar{display:none}
  .logo-item{scroll-snap-align:center;flex:0 0 auto;padding:10px;text-align:center;min-width:120px;max-width:160px;margin:0}
  .logo-image{height:60px;width:auto;max-width:100%;object-fit:contain;display:inline-block}
  .featured-in-web .logos-container{padding:0}
  @media (min-width:1024px){
    .logos-container{overflow-x:hidden;justify-content:space-between}
    .logo-item{flex:1 1 auto;max-width:none;min-width:0}
    .logo-image{max-height:80px}
  }
  @media only screen and (min-width:0px) and (max-width:767px){
    h2.featured-in{font-size:18px!important}
    .featured-in-web{padding-top:20px;padding-bottom:20px}
    .product-template-page .featured-in-web{padding-top:0}
    .featured-in-parent{text-align:center;margin-bottom:20px}
    .featured-in-web .logos-container{padding:0}
     .into-the-web{font-size:12px;color:#666}
  @media (min-width:1024px){
    .logos-container{overflow-x:hidden;justify-content:space-between}
    .logo-item{flex:1 1 auto;max-width:none;min-width:0}
    .logo-image{max-height:80px}
  }
  @media only screen and (min-width:0px) and (max-width:767px){
    h2.featured-in{font-size:18px!important}
    .featured-in-web{padding-top:20px;padding-bottom:20px}
    .product-template-page .featured-in-web{padding-top:0}
    .featured-in-parent{text-align:center;margin-bottom:20px}
  }
  @media only screen and (min-width:0px) and (max-width:767px;){
  .into-the-web{font-size:12px!important;color:#666}
  }
</style>

<div class="featured-in-web">
  <div class="page-width">
    <div class="component-103">
      <div class="featured-in-parent">
        <h2 class="featured-in">{{ section.settings.heading | escape }}</h2>
        <div class="into-the-web">{{ section.settings.subheading | escape }}</div>
      </div>

      <div class="logos-container no-js-carousel">
        {% for block in section.blocks %}
          <div class="logo-item">
            {% if block.settings.logo_url %}
              <a href="{{ block.settings.logo_url }}" target="_blank" rel="noopener noreferrer">
                {% if block.settings.logo_image %}
                  <img
                    class="logo-image"
                    src="{{ block.settings.logo_image | image_url: width: 300 }}"
                    alt="{{ block.settings.logo_alt | default: block.settings.company_name | escape }}"
                    title="{{ block.settings.logo_alt | default: block.settings.company_name | escape }}"
                    loading="lazy"
                    width="300"
                    height="169"
                  >
                {% endif %}
              </a>
            {% elsif block.settings.logo_image %}
              <img
                class="logo-image"
                src="{{ block.settings.logo_image | img_url: '300x' }}"
                alt="{{ block.settings.logo_alt | default: block.settings.company_name | escape }}"
                title="{{ block.settings.logo_alt | default: block.settings.company_name | escape }}"
                loading="lazy"
                width="auto"
                height="auto"
              >
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Featured In",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured In"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "As seen on your favorite platforms"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo Image"
        },
        {
          "type": "url",
          "id": "logo_url",
          "label": "Logo Link (optional)"
        },
        {
          "type": "text",
          "id": "logo_alt",
          "label": "Image Alt Text"
        },
        {
          "type": "text",
          "id": "company_name",
          "label": "Company Name (for fallback alt)",
          "default": "Brand"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Featured In",
      "category": "Image",
      "blocks": []
    }
  ]
}
{% endschema %}
{% comment %} <script>
document.addEventListener("DOMContentLoaded", function() {
  const featuredSection = document.querySelector('.featured-in-web');
  if (!featuredSection) return;

  const observer = new IntersectionObserver((entries, obs) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible'); // Add a class when section is visible
        obs.unobserve(entry.target); // Stop observing after it appears
      }
    });
  }, { threshold: 0.2 }); // Trigger when 20% visible

  observer.observe(featuredSection);
});
</script> {% endcomment %}
