{% schema %}
{
  "name": "Lucira Trendy Categories",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "TRENDY CATEGORIES"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog Source"
    },
    {
      "type": "range",
      "id": "max_categories",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 6,
      "label": "Maximum Categories to Show"
    }
  ],
  "presets": [
    {
      "name": "Lucira Trendy Categories",
      "category": "Blog"
    }
  ]
}
{% endschema %}

<style>
.categories-section{padding:40px 100px;font-family:"Futura Std"}
.section-title{font-size:18px;margin-bottom:30px;letter-spacing:1px}
.categories-container{display:flex;flex-wrap:wrap;gap:20px}
.category-card{display:flex;flex-direction:column;align-items:center;max-width:120px}
.category-card img{width:120px;height:120px;border-radius:50%;object-fit:cover;box-shadow:0 4px 8px rgba(0,0,0,.1)}
.category-card h3{font-size:14px;margin:10px 0 5px;font-weight:600;text-transform:uppercase}
.category-card p{font-size:12px;color:#555;margin:0}
@media (max-width:768px){
.categories-section{padding:40px 20px;font-family:'Futura Std'}
.categories-container{flex-wrap:nowrap;overflow-x:auto;justify-content:flex-start;padding-bottom:10px;gap:10px}
.category-card{margin-right:20px;flex:0 0 auto}
.categories-container::-webkit-scrollbar{display:none}
.categories-container{-ms-overflow-style:none;scrollbar-width:none}
}
</style>

  <section class="categories-section" >
    <h2 class="section-title">TRENDY CATEGORIES</h2>
    <div class="categories-container" style="display:flex;"> 
      <div class="category-card">
        <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/CCed_Proposal.jpg?v=1747462981"title="category-card"  >
        <h3>PROPOSAL</h3>
        {% comment %} <p>(12 posts)</p> {% endcomment %}
      </div>
      <div class="category-card">
        <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/CCed_Promise.jpg?v=1747463839"title="category-card"  >
        <h3>PROMISE</h3>
        {% comment %} <p>(12 posts)</p> {% endcomment %}
      </div>
      <div class="category-card">
        <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/CCed_Engagement_Updated.jpg?v=1747465961"title="category-card"  >
        <h3>ENGAGEMENT</h3>
        {% comment %} <p>(12 posts)</p> {% endcomment %}
      </div>
      <div class="category-card">
        <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/CCed_Wedding.jpg?v=1747466549" title="category-card" >
        <h3>WEDDING</h3>
        {% comment %} <p>(12 posts)</p> {% endcomment %}
      </div>
      <div class="category-card">
        <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/CCed_Anni.jpg?v=1747468062" title="category-card" >
        <h3>ANNIVERSARY</h3>
        {% comment %} <p>(12 posts)</p> {% endcomment %}
      </div>
      <div class="category-card">
        <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/CCed_Gifting.jpg?v=1747476455" title="category-card" >
        <h3>GIFTS</h3>
        {% comment %} <p>(12 posts)</p> {% endcomment %}
      </div>
    </div>
  </section>
