          "label": "Sunshine (Zodiac)",
          "default": "Capricorn & Aquarius"
        },
        {
          "type": "text",
          "id": "mohs_hardness",
          "label": "Mohs Hardness",
          "default": "6.5 - 7.5"
        },
        {
          "type": "textarea",
          "id": "properties",
          "label": "Properties",
          "default": "Garnet belongs to a group of silicate minerals and comes in a wide variety of colors, though the deep red variety is most recognized. These gems are prized for their brilliance and durability."
        },
        {
          "type": "textarea",
