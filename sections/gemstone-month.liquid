<section class="know-your-birthstone sumit_birthstone_{{ section.id }}">
  <div class="page-width">
    <div class="text-center">
      <h2>{{ section.settings.heading }}</h2>
      <div class="section-subtext">{{ section.settings.subtext }}</div>
    </div>

    <!-- Month Selector Row -->
    <div class="month-selector" role="tablist" aria-label="Select birth month">
      {% assign months = "JAN,FEB,MAR,APR,MAY,JUN,JUL,AUG,SEP,OCT,NOV,DEC" | split: "," %}
      {% for block in section.blocks %}
        {% assign month_index = forloop.index0 %}
        <button
          class="month-btn {% if forloop.first %}active{% endif %}"
          data-index="{{ month_index }}"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          aria-controls="birthstone-panel-{{ month_index }}"
          {{ block.shopify_attributes }}
        >
          <span class="month-gem-wrap">
            {% if block.settings.gem_image != blank %}
              <img
                src="{{ block.settings.gem_image | img_url: '120x120', crop: 'center' }}"
                alt="{{ block.settings.month_name }} birthstone"
                loading="lazy"
                width="60"
                height="60"
                class="month-gem-img"
              >
            {% else %}
              <span class="month-gem-placeholder"></span>
            {% endif %}
          </span>
          <span class="month-label">{{ block.settings.month_name | default: months[month_index] }}</span>
        </button>
      {% endfor %}
    </div>

    <!-- Content Panels -->
    <div class="birthstone-panels-wrapper" aria-live="polite">
      {% for block in section.blocks %}
        {% assign month_index = forloop.index0 %}
        <div
          class="birthstone-panel {% if forloop.first %}active{% endif %}"
          id="birthstone-panel-{{ month_index }}"
          data-index="{{ month_index }}"
          role="tabpanel"
          aria-labelledby="month-btn-{{ month_index }}"
        >
          <div class="panel-inner">
            <!-- Left: Gemstone Image -->
            <div class="panel-image-col">
              {% if block.settings.panel_image != blank %}
                <img
                  src="{{ block.settings.panel_image | img_url: '600x600', crop: 'center' }}"
                  alt="{{ block.settings.gemstone_name }} gemstone"
                  loading="lazy"
                  width="600"
                  height="600"
                  class="panel-gem-img"
                >
              {% else %}
                <div class="panel-image-placeholder"></div>
              {% endif %}
            </div>

            <!-- Right: Details -->
            <div class="panel-details-col">
              <dl class="gem-details">
                {% if block.settings.gemstone_name != blank %}
                  <div class="gem-row">
                    <dt>GEMSTONE</dt>
                    <dd>{{ block.settings.gemstone_name }}</dd>
                  </div>
                {% endif %}
                {% if block.settings.also_known_as != blank %}
                  <div class="gem-row">
                    <dt>ALSO KNOWN AS</dt>
                    <dd>{{ block.settings.also_known_as }}</dd>
                  </div>
                {% endif %}
                {% if block.settings.sunshine != blank %}
                  <div class="gem-row">
                    <dt>SUNSHINE</dt>
                    <dd>{{ block.settings.sunshine }}</dd>
                  </div>
                {% endif %}
                {% if block.settings.mohs_hardness != blank %}
                  <div class="gem-row">
                    <dt>MOHS HARDNESS</dt>
                    <dd>{{ block.settings.mohs_hardness }}</dd>
                  </div>
                {% endif %}
                {% if block.settings.properties != blank %}
                  <div class="gem-row gem-row--multiline">
                    <dt>PROPERTIES</dt>
                    <dd>{{ block.settings.properties }}</dd>
                  </div>
                {% endif %}
                {% if block.settings.facts != blank %}
                  <div class="gem-row gem-row--multiline">
                    <dt>FACTS</dt>
                    <dd>{{ block.settings.facts }}</dd>
                  </div>
                {% endif %}
              </dl>

              {% if block.settings.cta_link != blank %}
                <div class="gemstone-cta-2">
                <a href="{{ block.settings.cta_link }}" class="gem-cta-btn">
                  {{ block.settings.cta_label | default: "KNOW MORE" }}
                </a>
                </div>
              {% endif %}
            </div>

          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
/* ── Scope all styles ── */
.sumit_birthstone_{{ section.id }} {
  padding: 50px 0 70px;
}

/* Heading */
.sumit_birthstone_{{ section.id }} h2 {
  font-size: 24px;
  text-transform: uppercase;
  margin: 0 0 10px;
  letter-spacing: 1px;
  display:flex;
  align-items:center;
  justify-content:center;
}

.sumit_birthstone_{{ section.id }} .section-subtext {
  display:flex;
  margin: 0 auto 40px;
  font-size: 15px;
  color: #666;
  line-height: 1.6;
  justify-content:center;
}

/* ── Month Selector ── */
.sumit_birthstone_{{ section.id }} .month-selector {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 20px;
  flex-wrap: nowrap;
  overflow-x: auto;
  padding-bottom: 6px;
  margin-bottom: 40px;
  scrollbar-width: none;
}
.sumit_birthstone_{{ section.id }} .month-selector::-webkit-scrollbar {
  display: none;
}
.gemstone-cta-2{
display:flex;

}
.sumit_birthstone_{{ section.id }} .month-btn {
  background: none;
  border: none;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 0 8px 10px;
  position: relative;
  flex: 1;
  min-width: 60px;
  max-width: 90px;
  transition: transform 0.25s ease;
}

.sumit_birthstone_{{ section.id }} .month-gem-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54px;
  height: 54px;
  transition: width 0.3s ease, height 0.3s ease;
}

.sumit_birthstone_{{ section.id }} .month-gem-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  border-radius: 50%;
  display: block;
  transition: transform 0.3s ease;
}

.sumit_birthstone_{{ section.id }} .month-gem-placeholder {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #e0e0e0;
  display: block;
}

.sumit_birthstone_{{ section.id }} .month-label {
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 0.5px;
  color: #555;
  text-transform: uppercase;
  transition: font-weight 0.2s, color 0.2s, font-size 0.2s;
  white-space: nowrap;
}

/* Active state */
.sumit_birthstone_{{ section.id }} .month-btn.active .month-gem-wrap {
  width: 72px;
  height: 72px;
}

.sumit_birthstone_{{ section.id }} .month-btn.active .month-label {
  font-weight: 600;
  color: #1a1a1a;
  font-size: 14px;
}

.sumit_birthstone_{{ section.id }} .month-btn.active::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 36px;
  height: 2px;
  background: #222;
  border-radius: 2px;
}

/* ── Panels Wrapper ── */
.sumit_birthstone_{{ section.id }} .birthstone-panels-wrapper {
  position: relative;
  overflow: hidden;
  min-height: 320px;
}

.sumit_birthstone_{{ section.id }} .birthstone-panel {
  display: none;
  opacity: 0;
}

.sumit_birthstone_{{ section.id }} .birthstone-panel.active {
  display: block;
  opacity: 1;
}

/* Slide-in animations */
@keyframes bstone_slide_from_right {
  from { transform: translateX(60px); opacity: 0; }
  to   { transform: translateX(0);    opacity: 1; }
}

@keyframes bstone_slide_from_left {
  from { transform: translateX(-60px); opacity: 0; }
  to   { transform: translateX(0);     opacity: 1; }
}

.sumit_birthstone_{{ section.id }} .birthstone-panel.slide-from-right {
  animation: bstone_slide_from_right 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

.sumit_birthstone_{{ section.id }} .birthstone-panel.slide-from-left {
  animation: bstone_slide_from_left 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

/* ── Panel Inner Layout ── */
.sumit_birthstone_{{ section.id }} .panel-inner {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 50px;
  align-items: start;
  padding: 10px 0;
}

/* Left image col */
.sumit_birthstone_{{ section.id }} .panel-image-col {
  width: 100%;
}

.sumit_birthstone_{{ section.id }} .panel-gem-img {
  width: 100%;

  object-fit: cover;
  display: block;
  border-radius: 4px;
}

.sumit_birthstone_{{ section.id }} .panel-image-placeholder {
  width: 100%;
 
  background: #f0ede8;
  border-radius: 4px;
}

/* Right details col */
.sumit_birthstone_{{ section.id }} .panel-details-col {
  padding: 10px 0;
}

.sumit_birthstone_{{ section.id }} .gem-details {
  margin: 0 0 30px;
}

.sumit_birthstone_{{ section.id }} .gem-row {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 10px 20px;
  padding: 12px 0;
  border-bottom: 1px solid #f0ede8;
  align-items: start;
}

.sumit_birthstone_{{ section.id }} .gem-row:first-child {
  border-top: 1px solid #f0ede8;
}

.sumit_birthstone_{{ section.id }} .gem-row dt {
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 1px;
  color: #1a1a1a;
  text-transform: uppercase;
  padding-top: 2px;
  font-family:'Futura Std';
}

.sumit_birthstone_{{ section.id }} .gem-row dd {
  font-size: 13px;
  color: #555;
  line-height: 1.65;
  margin: 0;
}

.sumit_birthstone_{{ section.id }} .gem-row--multiline dd {
  line-height: 1.7;
}

/* CTA Button */
.sumit_birthstone_{{ section.id }} .gem-cta-btn {
  display: inline-block;
  background: #a68380;
  color: #fff;
  text-decoration: none;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 14px 110px;
  border-radius: 12px;
  transition: background 0.25s ease;
}

.sumit_birthstone_{{ section.id }} .gem-cta-btn:hover {
  background: #9a6e6e;
}

/* ── Extra Large Screens ── */
@media (min-width: 1600px) {
  .sumit_birthstone_{{ section.id }} h2 {
    font-size: 28px;
  }
  .sumit_birthstone_{{ section.id }} .panel-inner {
    max-width: 1200px;
    margin: 0 auto;
    gap: 70px;
  }
}

/* ── Tablet ── */
@media (max-width: 1024px) {
  {% comment %} .sumit_birthstone_{{ section.id }} .gem-row {
    grid-template-columns: 130px 1fr;
  } {% endcomment %}
  .sumit_birthstone_{{ section.id }} .panel-inner {
    gap: 30px;
  }
}

/* ── Mobile ── */
@media (max-width: 767px) {
  .gemstone-cta-2{
display:flex;
justify-content:center;
}
  .sumit_birthstone_{{ section.id }} {
    padding: 30px 0 20px;
  }

  .sumit_birthstone_{{ section.id }} h2 {
    font-size: 18px;
  }

  .sumit_birthstone_{{ section.id }} .section-subtext {
    font-size: 13px;
    margin-bottom: 24px;
  }

  .sumit_birthstone_{{ section.id }} .month-selector {
    justify-content: flex-start;
    gap: 15px;
    padding: 0 2px 8px;
    margin-bottom: 24px;
  }

  .sumit_birthstone_{{ section.id }} .month-btn {
    min-width: 52px;
    padding: 0 4px 10px;
  }

  .sumit_birthstone_{{ section.id }} .month-gem-wrap {
    width: 40px;
    height: 40px;
  }

  .sumit_birthstone_{{ section.id }} .month-btn.active .month-gem-wrap {
    width: 54px;
    height: 54px;
  }

  .sumit_birthstone_{{ section.id }} .month-label {
    font-size: 9px;
  }

  .sumit_birthstone_{{ section.id }} .panel-inner {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .sumit_birthstone_{{ section.id }} .panel-gem-img,
  .sumit_birthstone_{{ section.id }} .panel-image-placeholder {
    height: 220px;
  }

  .sumit_birthstone_{{ section.id }} .gem-row {
    {% comment %} grid-template-columns: 1fr; {% endcomment %}
    gap: 14px;
    padding: 10px 0;
  }

  .sumit_birthstone_{{ section.id }} .gem-cta-btn {
    width: 50%;
    text-align: center;
    padding: 14px 20px;
  }
}
</style>

<script>
(function () {
  const SECTION_ID = "{{ section.id }}";
  const PARENT_CLASS = ".sumit_birthstone_" + SECTION_ID;

  document.addEventListener("DOMContentLoaded", function () {
    const parent = document.querySelector(PARENT_CLASS);
    if (!parent) return;

    const buttons  = parent.querySelectorAll(".month-btn");
    const panels   = parent.querySelectorAll(".birthstone-panel");
    let currentIndex = 0;
    let isAnimating  = false;

    // Helper: strip animation classes after they finish
    function clearAnimClasses(panel) {
      panel.classList.remove("slide-from-right", "slide-from-left");
    }

    function activateMonth(newIndex) {
      if (newIndex === currentIndex || isAnimating) return;
      isAnimating = true;

      const direction = newIndex > currentIndex ? "slide-from-right" : "slide-from-left";

      // Deactivate current button
      buttons[currentIndex].classList.remove("active");
      buttons[currentIndex].setAttribute("aria-selected", "false");

      // Hide current panel (instant)
      const oldPanel = panels[currentIndex];
      oldPanel.classList.remove("active", "slide-from-right", "slide-from-left");
      oldPanel.style.display = "none";

      // Activate new button
      buttons[newIndex].classList.add("active");
      buttons[newIndex].setAttribute("aria-selected", "true");

      // Show + animate new panel
      const newPanel = panels[newIndex];
      newPanel.style.display = "block";

      // Force reflow so the animation triggers
      void newPanel.offsetWidth;

      newPanel.classList.add("active", direction);

      // GA4 tracking
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: "birthstoneMonthClick",
        birthstoneMonth: {
          month_index: newIndex,
          month_label: buttons[newIndex].querySelector(".month-label")?.textContent.trim() || ""
        }
      });

      // Clean up after animation ends
      function onAnimEnd(e) {
        if (e.target !== newPanel) return;
        clearAnimClasses(newPanel);
        isAnimating = false;
        newPanel.removeEventListener("animationend", onAnimEnd);
      }
      newPanel.addEventListener("animationend", onAnimEnd);

      // Fallback release if animationend never fires
      setTimeout(function () {
        isAnimating = false;
        clearAnimClasses(newPanel);
      }, 600);

      currentIndex = newIndex;
    }

    // Bind click events
    buttons.forEach(function (btn) {
      btn.addEventListener("click", function () {
        const idx = parseInt(this.getAttribute("data-index"), 10);
        activateMonth(idx);
      });
    });

    // Keyboard nav (arrow keys)
    parent.querySelector(".month-selector").addEventListener("keydown", function (e) {
      if (e.key === "ArrowRight") {
        const next = Math.min(currentIndex + 1, buttons.length - 1);
        buttons[next].focus();
        activateMonth(next);
      } else if (e.key === "ArrowLeft") {
        const prev = Math.max(currentIndex - 1, 0);
        buttons[prev].focus();
        activateMonth(prev);
      }
    });

    // Intersection Observer for lazy reveal
    const observer = new IntersectionObserver(function (entries, obs) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add("section-visible");
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    observer.observe(parent);
  });
})();
</script>

{% schema %}
{
  "name": "Know Your Birthstone",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "KNOW YOUR BIRTHSTONE"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Section Subtext",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut alconsequat."
    }
  ],
  "blocks": [
    {
      "type": "month",
      "name": "Month",
      "settings": [
        {
          "type": "text",
