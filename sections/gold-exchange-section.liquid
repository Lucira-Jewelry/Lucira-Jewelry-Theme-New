<section class="gold-exchange">
  <div class="ge-headers">
    <h2>Calculate by purity or karatage</h2>
    <h3>Find the best gold exchange value</h3>
  </div>
  <div class="ge-content">
    <div class="ge-content-left">
      <div class="ge-content-tabs">
        <span class="ge-tab active-tag" data-type="karatage">Karatage</span>
        <span class="ge-tab" data-type="purity">Purity</span>
      </div>
      <form class="ge-content-form" onsubmit="geHandleFormSubmit(event)">
        <select name="karatage" id="karatage-select">
          <option value="">Select Karatage</option>
          <option value="14K">14 Karat</option>
          <option value="18K">18 Karat</option>
          <option value="22K">22 Karat</option>
          <option value="24K">24 Karat</option>
        </select>
        <input
          id="purity-input"
          placeholder="Enter Purity (%)"
          type="number"
          min="1"
          max="100"
          name="purity"
          style="display: none;"
        >
        <input id="weight-input" placeholder="Enter Grams" type="number" step="0.0001" name="weight">
        <button id="calculate-btn" disabled>CALCULATE EXCHANGE VALUE</button>
      </form>
      <div class="ge-exchange-result"></div>
    </div>
    <div class="ge-content-right">
      <div class="ge-content-gold-rates">
        <h4>Standard gold rates for the day</h4>
        <div class="ge-content-gold-rate-item">
          <div class="ge-content-gold-rate-weight">
            <div>14 Karatage Gold</div>
            <small>(1 gram)</small>
          </div>
          <span class="ge-content-gold-rate-price">₹ 4845</span>
        </div>

        <div class="ge-content-gold-rate-item">
          <div>
            <div>18 Karatage Gold</div>
            <small>(1 gram)</small>
          </div>
          <span class="ge-content-gold-rate-price">₹ 6233</span>
        </div>

        <div class="ge-content-gold-rate-item">
          <div>
            <div>22 Karatage Gold</div>
            <small>(1 gram)</small>
          </div>
          <span class="ge-content-gold-rate-price">₹ 7621</span>
        </div>

        <div class="ge-content-gold-rate-item">
          <div>
            <div>24 Karatage Gold</div>
            <small>(1 gram)</small>
          </div>
          <span class="ge-content-gold-rate-price">₹ 8269</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .gold-exchange {
  }
  .ge-headers h2 {
    text-align: center;
    font-weight: bold;
    color: #333;
  }
  .ge-headers h3 {
    text-align: center;
    margin-bottom: 2rem;
    color: gray;
  }
  .ge-content {
    display: flex;
    justify-content: center;
    gap: 5rem;
  }
  .ge-content-tabs {
    display: flex;
    background: #f2efff;
    border-radius: 20px;
    padding: 0.5rem;
  }
  .ge-content-tabs span {
    flex: 1;
    text-align: center;
    padding: 0.5rem 1rem;
    cursor: pointer;
    border-radius: 20px;
    transition: 0.3s;
  }
  .ge-content-tabs .active-tag {
    background: #9f7aea;
    color: white;
  }
  .ge-content-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    align-items: center;
  }
  .ge-content-form select,
  .ge-content-form input {
    width: 100%;
    padding: 2rem 4rem;
    border: 2px solid #9f7aea;
    border-radius: 12px;
    background: #f6f3ff;
    color: #333;
    outline: none;
    transition: all 0.3s ease-in-out;
  }
  .ge-content-form select:focus,
  .ge-content-form input:focus {
    border-color: #7a5eb2;
    box-shadow: 0 0 8px rgba(159, 122, 234, 0.4);
  }
  .ge-content-form button {
    width: 100%;
    max-width: 400px;
    padding: 1.2rem;
    font-size: 1.1rem;
    font-weight: bold;
    border-radius: 12px;
  }
  .ge-content-form button.active {
    background: linear-gradient(135deg, #9f7aea, #6b46c1);
  }
  .ge-content-form button {
    width: 100%;
    padding: 2rem 4rem;
    font-size: 1rem;
    border: none;
    border-radius: 8px;
    background: #ccc;
    color: white;
    cursor: not-allowed;
    transition: 0.3s;
  }
  .ge-content-form button.active {
    background: #9f7aea;
    cursor: pointer;
  }
  .ge-content-gold-rates {
    padding: 5rem;
    border: 2px solid #9f7aea;
    border-radius: 20px;
  }
  .ge-content-gold-rate-item {
    display: flex;
    gap: 2rem;
    justify-content: space-between;
    padding: 1rem 0;
    border-bottom: 1px solid #ddd;
  }
  .ge-content-gold-rate-item:last-child {
    border-bottom: none;
  }
  .ge-content-gold-rate-weight {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .ge-content-gold-rate-weight {
    display: flex;
  }
  .ge-content-gold-rate-price {
    color: #9f7aea;
    font-weight: bold;
  }
</style>


<script src="{{ 'gold-exchange.js' | asset_url }}" async></script>
{% schema %}
{
  "name": "Gold Exchange Section",
  "settings": [],

  "presets": [
    {
      "name": "Gold Exchange Section"
    }
  ],
  "enabled_on": {
    "templates": ["page"],
  }
}
{% endschema %}
