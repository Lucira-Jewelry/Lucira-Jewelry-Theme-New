<div class="talk-to-us-expert-section">
  <div class="page-width">
    <div class="talk-to-us-expert-wrapper">
      {% if section.settings.talk_to_us_expert_banner_title != blank %}
        <h2 class="talk-to-us-expert-title">
          {{ section.settings.talk_to_us_expert_banner_title }}
        </h2>
      {% endif %}

      <form id="talkToExpertForm" class="talk-to-us-expert-input-wrapper">
        <!-- Visible input: phone number -->
        <input
          type="number"
          name="phone"
          id="talkToExpertPhone"
          placeholder="Mobile Number"
          required
          class="talk-to-us-expert-input"
          oninput="if(this.value.length > 10) this.value = this.value.slice(0, 10);"
        />

        <!-- Hidden fields to capture calculator values -->
        <input type="hidden" id="expert_premium_amount" name="premium_amount" />
        <input type="hidden" id="expert_total_investment" name="total_investment" />
        <input type="hidden" id="expert_free_premium" name="free_premium" />
        <input type="hidden" id="expert_total_redeemable" name="total_redeemable" />

        <button type="submit" class="talk-to-us-expert-button">
          <svg width="24" height="24">
            <use href="#icon-bell"></use>
          </svg>
          Talk to an Expert
        </button>
      </form>

      <div id="formFeedback" class="form-feedback" style="display: none;"></div>
    </div>
  </div>
</div>

<script>
  // Function to get calculator values from the scheme calculator section
 function getCalculatorValues() {
    // Get visible amounts
    const premiumAmountEl = document.getElementById('premium_amount');
    const totalInvestmentEl = document.getElementById('pay_amount');
    const freeAmountEl = document.getElementById('free_amount');
    const totalAmountEl = document.getElementById('total_amount');
    
    // Default values
    let premiumAmount = '₹10,000';
    let totalInvestment = '₹90,000';
    let freePremium = '₹10,000';
    let totalRedeemable = '₹1,00,000';
    
    // Get premium and total investment (these are always visible)
    if (premiumAmountEl && premiumAmountEl.textContent) {
      premiumAmount = premiumAmountEl.textContent.trim();
    }
    
    if (totalInvestmentEl && totalInvestmentEl.textContent) {
      totalInvestment = totalInvestmentEl.textContent.trim();
    }
    
    // Get free premium from data attribute (even if hidden)
    if (freeAmountEl) {
      const freeValue = freeAmountEl.getAttribute('data-real-value');
      if (freeValue) {
        freePremium = '₹' + parseInt(freeValue).toLocaleString('en-IN');
      } else if (freeAmountEl.textContent && !freeAmountEl.classList.contains('hidden-value')) {
        freePremium = freeAmountEl.textContent.trim();
      }
    }
    
    // Get total redeemable from data attribute (even if hidden)
    if (totalAmountEl) {
      const totalValue = totalAmountEl.getAttribute('data-real-value');
      if (totalValue) {
        totalRedeemable = '₹' + parseInt(totalValue).toLocaleString('en-IN');
      } else if (totalAmountEl.textContent && !totalAmountEl.classList.contains('hidden-value')) {
        totalRedeemable = totalAmountEl.textContent.trim();
      }
    }
    
    console.log('Fetched Calculator Values:', {
      premiumAmount,
      totalInvestment,
      freePremium,
      totalRedeemable
    });
    
    return {
      premiumAmount: premiumAmount,
      totalInvestment: totalInvestment,
      freePremium: freePremium,
      totalRedeemable: totalRedeemable
    };
  }

  // Main form submission handler
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('talkToExpertForm');
    
    if (!form) {
      console.error('Talk to Expert form not found');
      return;
    }
    
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const submitButton = form.querySelector('.talk-to-us-expert-button');
      const feedbackDiv = document.getElementById('formFeedback');
      const phoneInput = document.getElementById('talkToExpertPhone');
      
      // Validate phone number
      const phoneValue = phoneInput.value.trim();
      if (!/^\d{10}$/.test(phoneValue)) {
        feedbackDiv.className = 'form-feedback error';
        feedbackDiv.innerHTML = '<ul><li>Please enter a valid 10-digit phone number</li></ul>';
        feedbackDiv.style.display = 'block';
        return;
      }
      
      // Get calculator values and populate hidden fields
      const calcValues = getCalculatorValues();
      
      // Populate hidden fields
      document.getElementById('expert_premium_amount').value = calcValues.premiumAmount;
      document.getElementById('expert_total_investment').value = calcValues.totalInvestment;
      document.getElementById('expert_free_premium').value = calcValues.freePremium;
      document.getElementById('expert_total_redeemable').value = calcValues.totalRedeemable;
      
      console.log('Submitting with Calculator Values:', calcValues);
      
      // Disable button and show processing state
      submitButton.disabled = true;
      submitButton.style.opacity = '0.6';
      const originalButtonHTML = submitButton.innerHTML;
      submitButton.innerHTML = '<svg width="24" height="24"><use href="#icon-bell"></use></svg> Processing...';
      
      // Hide previous feedback
      feedbackDiv.style.display = 'none';
      
      // Prepare data to send
      const webhookData = {
        phone: phoneValue,
        email: 'support@lucirajewelry.com',
        subject: 'Talk to Expert Request - Lucira Jewelry',
        tags: 'Talk to Expert',
        premiumAmount: calcValues.premiumAmount,
        totalInvestment: calcValues.totalInvestment,
        freePremium: calcValues.freePremium,
        totalRedeemable: calcValues.totalRedeemable,
        timestamp: new Date().toISOString(),
        source: 'Lucira Jewelry Website - Talk to Expert Form',
        pageUrl: window.location.href
      };
      
      console.log('Webhook Data:', webhookData);
      
      try {
        const webhookURL = 'https://schemes-api-385594025448.europe-west1.run.app/';
        
        const response = await fetch(webhookURL, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(webhookData)
        });
        
        if (response.ok) {
          // Show success message
          feedbackDiv.className = 'form-feedback success';
          feedbackDiv.textContent = 'Thank you! Our expert will contact you shortly.';
          feedbackDiv.style.display = 'block';
          
          // Push to dataLayer for analytics
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: "talkToExpertSubmit",
            expertData: webhookData,
          });
          
          // Reset form
          form.reset();
          
          // Hide success message after 5 seconds
          setTimeout(() => {
            feedbackDiv.style.display = 'none';
          }, 5000);
        } else {
          throw new Error('Failed to send');
        }
      } catch (error) {
        // Show error message
        feedbackDiv.className = 'form-feedback error';
        feedbackDiv.innerHTML = '<ul><li>Something went wrong. Please try again.</li></ul>';
        feedbackDiv.style.display = 'block';
        console.error('Webhook error:', error);
      } finally {
        // Re-enable button
        submitButton.disabled = false;
        submitButton.style.opacity = '1';
        submitButton.innerHTML = originalButtonHTML;
      }
    });
  });
</script>

<style>
  .talk-to-us-expert-input{flex:1;min-width:200px}
  .form-feedback{margin-top:12px;padding:8px 12px;border-radius:4px;font-size:14px}
  .form-feedback.error{background-color:#ffe6e6;color:#d8000c;border:1px solid #d8000c}
  .form-feedback.success{background-color:#e6ffe6;color:#2d8515;border:1px solid #e6ffe6;width:max-content;margin:0 auto;margin-top:20px}
  .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
  @media (max-width:768px){
  .talk-to-us-expert-input{width:100%}
  .talk-to-us-expert-button{width:100%}
  }
</style>

<style>
  .talk-to-us-expert-section {padding: 30px 0;}
  .talk-to-us-expert-title {margin-bottom: 28px; margin-top: 0; font-weight: 500; font-size: 24px; line-height: 150%; letter-spacing: .7px; text-align: center; vertical-align: middle; text-transform: uppercase;}
  .talk-to-us-expert-button { background: #b77766; color: #fff; border: 0; padding: 12px 28px; font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; display: inline-flex ; align-items: center; gap: 10px; cursor: pointer;}
  input.talk-to-us-expert-input { padding: 14px 28px 14px 20px; font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; border: 1px solid #666666; max-width: 300px; width: 100%;}
  .talk-to-us-expert-input-wrapper { text-align: center; display: flex ; align-items: center; justify-content: center; gap: 8px; }
  input[type=number]::-webkit-inner-spin-button, input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; -moz-appearance: none; appearance: none; margin: 0; }
  h2.talk-to-us-expert-title { margin-top: 0; font-size: 24px; width: 90%; margin-left: auto; margin-right: auto; letter-spacing: 1.4px; }
  .tab-link {letter-spacing: 1.4px;}
  @media only screen and (min-width:0) and (max-width:767px){
    .talk-to-us-expert-button { background: #b67665; color: #fff; border: 0; padding: 14px 12px; font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; display: inline-flex ; align-items: center; justify-content: center; gap: 10px; width: 100%; }
    input.talk-to-us-expert-input { padding: 16px 28px 16px 20px; font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; border: 1px solid #666666; width: 100%; display: block; max-width: 100%;}
    .talk-to-us-expert-input-wrapper { text-align: center; flex-direction: column;}
    .featured-collections-tabs h2 { margin-bottom: 28px; max-width: 300px; margin-left: auto; margin-right: auto; }
    .tab-link { padding: 1rem 2rem; font-size: 12px;letter-spacing: 1.4px;}
    h2.talk-to-us-expert-title {font-size: 18px;}
    .talk-to-us-expert-section {padding: 20px 0;}
  }
</style>

{% schema %}
{
  "name": "Schemes Talk to Expert",
  "tag": "section",
  "class": "schemes-talk-to-expert",
  "settings": [
    {
      "type": "text",
      "label": "heading",
      "id": "talk_to_us_expert_banner_title"
    }
  ],
  "presets": [
    {
      "name": "Schemes Talk to Expert"
    }
  ]
}
{% endschema %}