{% if section.settings.talk_to_us_expert_banner_title != blank %}
  {{ section.settings.talk_to_us_expert_banner_title }}
{% endif %}

<div class="talk-to-us-expert-input-wrapper">
  <form id="talkToExpertForm">
    <input type="text" name="name" placeholder="Your Name" required>
    <input type="email" name="email" placeholder="Your Email" required>
    <input type="tel" name="phone" placeholder="Your Phone" required>
    <textarea name="message" placeholder="Your Message"></textarea>
    <button type="submit">Talk to an Expert</button>
  </form>
</div>

<div id="responseMessage" style="display: none;"></div>

<script>
document.getElementById('talkToExpertForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  
  const form = e.target;
  const submitButton = form.querySelector('button[type="submit"]');
  const responseDiv = document.getElementById('responseMessage');
  
  // Disable button during submission
  submitButton.disabled = true;
  submitButton.textContent = 'Sending...';
  
  // Collect form data
  const formData = {
    name: form.name.value,
    email: form.email.value,
    phone: form.phone.value,
    message: form.message.value,
    timestamp: new Date().toISOString()
  };
  
  try {
    // Replace with your actual webhook URL
    const webhookURL = 'YOUR_WEBHOOK_URL_HERE';
    
    const response = await fetch(webhookURL, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(formData)
    });
    
    if (response.ok) {
      // Show success message
      responseDiv.style.display = 'block';
      responseDiv.style.color = 'green';
      responseDiv.textContent = 'Thank you! Our expert will contact you shortly.';
      
      // Reset form
      form.reset();
    } else {
      throw new Error('Failed to send');
    }
  } catch (error) {
    // Show error message
    responseDiv.style.display = 'block';
    responseDiv.style.color = 'red';
    responseDiv.textContent = 'Something went wrong. Please try again.';
  } finally {
    // Re-enable button
    submitButton.disabled = false;
    submitButton.textContent = 'Talk to an Expert';
  }
});
</script>


<style>
.talk-to-us-expert-button[disabled] {
  cursor: not-allowed;
  transition: opacity 0.3s ease;
  padding: 17px 40px;
}


</style>



<style>
  .input-group { display: flex ; gap: 12px; align-items: center; justify-content: center; flex-wrap: wrap; width: 100%; }
  .talk-to-us-expert-input { flex: 1; min-width: 200px; } .form-feedback {
  margin-top: 12px; padding: 8px 12px; border-radius: 4px; font-size: 14px; }
  .form-feedback.error { background-color: #ffe6e6; color: #d8000c; border: 1px
  solid #d8000c; } .form-feedback.success { background-color: #e6ffe6; color:
  #2d8515; border: 1px solid #2d8515; } .sr-only { position: absolute; width: 1px;
  height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0);
  white-space: nowrap; border: 0; }


/* Responsive design */
@media (max-width: 768px) {
  .talk-to-us-expert-input { width: 100%; }
  .talk-to-us-expert-button { width: 100%; }
}
</style>


<style>
  .talk-to-us-expert-section {padding: 30px 0;}
  .talk-to-us-expert-title {margin-bottom: 28px; margin-top: 0; font-weight: 500; font-size: 24px; line-height: 150%; letter-spacing: .7px; text-align: center; vertical-align: middle; text-transform: uppercase;}
  .talk-to-us-expert-button { background: #b77766; color: #fff; border: 0; padding: 12px 28px; font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; display: inline-flex ; align-items: center; gap: 10px; cursor: pointer;}
  input.talk-to-us-expert-input { padding: 14px 28px 14px 20px; font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; border: 1px solid #666666; max-width: 300px; width: 100%;}
  .talk-to-us-expert-input-wrapper { text-align: center; display: flex ; align-items: center; justify-content: center; gap: 8px; }
  input[type=number]::-webkit-inner-spin-button, input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; -moz-appearance: none; appearance: none; margin: 0; }
  h2.talk-to-us-expert-title { margin-top: 0; font-size: 24px; width: 90%; margin-left: auto; margin-right: auto;     letter-spacing: 1.4px; }
  .tab-link {letter-spacing: 1.4px;}
  @media only screen and (min-width:0) and (max-width:767px){
    .talk-to-us-expert-button { background: #b67665; color: #fff; border: 0; padding: 14px 12px; font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; display: inline-flex ; align-items: center; justify-content: center; gap: 10px; width: 100%; }
    input.talk-to-us-expert-input { padding: 16px 28px 16px 20px; font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; border: 1px solid #666666; width: 100%; display: block; max-width: 100%;}
    .talk-to-us-expert-input-wrapper { text-align: center; flex-direction: column;}
    .featured-collections-tabs h2 { margin-bottom: 28px; max-width: 300px; margin-left: auto; margin-right: auto; }
    .tab-link { padding: 1rem 2rem; font-size: 12px;letter-spacing: 1.4px;}
    h2.talk-to-us-expert-title {font-size: 18px;}
    .talk-to-us-expert-section {padding: 20px 0;}
  }
</style>

{% schema %}
{
  "name": "Schemes Talk to Expert",
  "tag": "section",
  "class": "schemes-talk-to-expert",
  "settings": [
    {
      "type": "text",
      "label": "heading",
      "id": "talk_to_us_expert_banner_title"
    },
  ],
  "presets": [
    {
      "name": "Schemes Talk to Expert"
    }
  ]
}
{% endschema %}