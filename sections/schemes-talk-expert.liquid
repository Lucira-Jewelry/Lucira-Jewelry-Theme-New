<div class="talk-to-us-expert-section">
  <div class="page-width">
    <div class="talk-to-us-expert-wrapper">
      {% if section.settings.talk_to_us_expert_banner_title != blank %}
        <h2 class="talk-to-us-expert-title">
          {{ section.settings.talk_to_us_expert_banner_title }}
        </h2>
      {% endif %}

      <form method="post" action="/contact" id="talkToExpertForm" accept-charset="UTF-8" class="talk-to-us-expert-input-wrapper">
        <input type="hidden" name="form_type" value="contact" />
        <input type="hidden" name="utf8" value="✓" />
        <input type="hidden" name="contact[subject]" value="Talk to Expert Request - Lucira Jewelry" />
        <input type="hidden" name="contact[tags]" value="Talk to Expert" />
        
        <input 
          type="tel" 
          name="contact[phone]" 
          id="talkToExpertPhone"
          placeholder="Mobile Number" 
          required 
          class="talk-to-us-expert-input"
        />
        
        <textarea 
          name="contact[body]" 
          id="talkToExpertBody"
          style="display: none;"
        ></textarea>
        
        <button type="submit" class="talk-to-us-expert-button">
          <svg width="24" height="24">
            <use href="#icon-bell"></use>
          </svg>
          Talk to an Expert
        </button>
      </form>
      
      <div id="formFeedback" class="form-feedback" style="display: none;"></div>

    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('talkToExpertForm');
  
  if (form) {
    form.addEventListener('submit', handleExpertForm);
  }
  
  // Enhanced phone input formatting
  const phoneInput = document.getElementById('talkToExpertPhone');
  if (phoneInput) {
    phoneInput.addEventListener('input', function(e) {
      let value = e.target.value.replace(/\D/g, '');
      if (value.length > 0) {
        value = value.match(new RegExp('.{1,4}', 'g')).join(' ');
      }
      e.target.value = value;
    });
  }
  
  // Check for success message in URL
  if (window.location.hash === '#contact_form' && window.location.search.includes('contact_posted=true')) {
    showFeedback('Thank you! An expert will contact you shortly.', 'success');
  }
});

function handleExpertForm(event) {
  event.preventDefault();
  
  const form = event.target;
  const phoneInput = document.getElementById('talkToExpertPhone');
  const bodyInput = document.getElementById('talkToExpertBody');
  const phoneNumber = phoneInput.value.trim();
  const feedbackEl = document.getElementById('formFeedback');
  const submitButton = form.querySelector('button[type="submit"]');
  
  // Clear previous feedback
  feedbackEl.style.display = 'none';
  feedbackEl.className = 'form-feedback';
  
  // Validation
  if (!phoneNumber) {
    showFeedback('Please enter your mobile number.', 'error');
    phoneInput.focus();
    return false;
  }
  
  // Basic phone validation
  const phoneRegex = /^[\d\+\-\(\)\s]{10,}$/;
  if (!phoneRegex.test(phoneNumber)) {
    showFeedback('Please enter a valid phone number.', 'error');
    phoneInput.focus();
    return false;
  }
  
  // Disable button and show loading state
  submitButton.disabled = true;
  const originalHTML = submitButton.innerHTML;
  submitButton.innerHTML = 'Sending...';
  
  // Add formatted message to body field
  const timestamp = new Date().toLocaleString();
  bodyInput.value = `New Expert Consultation Request

Phone Number: ${phoneNumber}
Date: ${timestamp}
Source: Website Form

Please contact this customer as soon as possible.`;
  
  // Submit the form using fetch to handle it properly
  const formData = new FormData(form);
  
  fetch(form.action, {
    method: 'POST',
    body: formData,
    headers: {
      'Accept': 'application/json'
    }
  })
  .then(response => {
    if (response.ok || response.redirected) {
      showFeedback('Thank you! An expert will contact you shortly.', 'success');
      phoneInput.value = '';
      
      // Send email notification
      sendEmailNotification(phoneNumber, timestamp);
    } else {
      throw new Error('Form submission failed');
    }
  })
  .catch(error => {
    console.error('Error:', error);
    // Try standard form submission as fallback
    showFeedback('Submitting your request...', 'success');
    setTimeout(() => {
      form.submit();
    }, 500);
  })
  .finally(() => {
    submitButton.disabled = false;
    submitButton.innerHTML = originalHTML;
  });
  
  return false;
}

function sendEmailNotification(phoneNumber, timestamp) {
  // Method 1: mailto link (opens email client)
  const email = 'support@lucirajewelry.com';
  const subject = encodeURIComponent('Talk to an Expert Request - Lucira Jewelry');
  const body = encodeURIComponent(
`New Expert Consultation Request:

Phone Number: ${phoneNumber}
Date: ${timestamp}
Source: Website Form

Please contact this customer as soon as possible.`
  );

  // Create mailto link but don't navigate to it (just log it)
  const mailtoLink = `mailto:${email}?subject=${subject}&body=${body}`;
  console.log('Email notification:', mailtoLink);
  
  // Method 2: Try to send via third-party email service
  // Using Formspree free tier (replace with your endpoint)
  fetch('https://formspree.io/f/xanyddzp', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      email: email,
      subject: 'Talk to an Expert Request - Lucira Jewelry',
      phone: phoneNumber,
      timestamp: timestamp,
      message: `New expert consultation request from ${phoneNumber}`
    })
  }).catch(err => console.log('Email service error:', err));
}

function showFeedback(message, type) {
  const feedbackEl = document.getElementById('formFeedback');
  feedbackEl.textContent = message;
  feedbackEl.className = `form-feedback ${type}`;
  feedbackEl.style.display = 'block';
  
  // Auto-hide success messages after 5 seconds
  if (type === 'success') {
    setTimeout(() => {
      feedbackEl.style.display = 'none';
    }, 5000);
  }
}
</script>

<style>
  .input-group { display: flex ; gap: 12px; align-items: center; justify-content: center; flex-wrap: wrap; width: 100%; }
  .talk-to-us-expert-input { flex: 1; min-width: 200px; } .form-feedback {
  margin-top: 12px; padding: 8px 12px; border-radius: 4px; font-size: 14px; }
  .form-feedback.error { background-color: #ffe6e6; color: #d8000c; border: 1px
  solid #d8000c; } .form-feedback.success { background-color: #e6ffe6; color:
  #2d8515; border: 1px solid #2d8515; } .sr-only { position: absolute; width: 1px;
  height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0);
  white-space: nowrap; border: 0; }


/* Responsive design */
@media (max-width: 768px) {
  .input-group { flex-direction: column; }
  .talk-to-us-expert-input { width: 100%; }
  .talk-to-us-expert-button { width: 100%; }
}
</style>


<style>
  .talk-to-us-expert-section {padding: 30px 0;}
  .talk-to-us-expert-title {margin-bottom: 28px; margin-top: 0; font-weight: 500; font-size: 24px; line-height: 150%; letter-spacing: .7px; text-align: center; vertical-align: middle; text-transform: uppercase;}
  .talk-to-us-expert-button { background: #B76F79; color: #fff; border: 0; padding: 12px 28px; font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; display: inline-flex ; align-items: center; gap: 10px; }
  input.talk-to-us-expert-input { padding: 14px 28px 14px 20px; font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; border: 1px solid #666666; max-width: 300px; width: 100%;}
  .talk-to-us-expert-input-wrapper { text-align: center; display: flex ; align-items: center; justify-content: center; gap: 8px; }
  input[type=number]::-webkit-inner-spin-button, input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; -moz-appearance: none; appearance: none; margin: 0; }
  h2.talk-to-us-expert-title { margin-top: 0; font-size: 18px; width: 90%; margin-left: auto; margin-right: auto; }
  @media only screen and (min-width:0) and (max-width:767px){
    .talk-to-us-expert-button { background: #B76F79; color: #fff; border: 0; padding: 12px 12px; font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; display: inline-flex ; align-items: center; justify-content: center; gap: 10px; width: 100%; max-width: 300px; }
    input.talk-to-us-expert-input { padding: 14px 28px 14px 20px; font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; border: 1px solid #666666; max-width: 300px; width: 100%; }
    .talk-to-us-expert-input-wrapper { text-align: center; flex-direction: column;}
    .featured-collections-tabs h2 { margin-bottom: 28px; max-width: 300px; margin-left: auto; margin-right: auto; }
    .tab-link { padding: 1rem 2rem; font-size: 12px;letter-spacing: 1.4px;}
  }
</style>

{% schema %}
{
  "name": "Schemes Talk to Expert",
  "tag": "section",
  "class": "schemes-talk-to-expert",
  "settings": [
    {
      "type": "text",
      "label": "heading",
      "id": "talk_to_us_expert_banner_title"
    },
  ],
  "presets": [
    {
      "name": "Schemes Talk to Expert"
    }
  ]
}
{% endschema %}