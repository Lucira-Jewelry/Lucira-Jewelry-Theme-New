{{ 'marque-style.css' | asset_url | stylesheet_tag: preload: true }}

<section class="featured-in-section featured-lazy" data-featured>
  <div class="featured-skeleton">
    {% for i in (1..8) %}
      <div class="featured-skeleton-logo"></div>
    {% endfor %}
  </div>
  <div class="featured-content" style="display:none">
    <div class="featured-in-wrapper">

      {% if section.settings.section_heading != blank %}
        <h2 class="featured-in-heading">{{ section.settings.section_heading }}</h2>
      {% endif %}

      {% if section.settings.section_subtitle != blank %}
        <p class="featured-in-subtitle">{{ section.settings.section_subtitle }}</p>
      {% endif %}

      <div class="marquee marquee--horizontal">
        <div class="marquee__group">
          {% for block in section.blocks %}
            {% if block.settings.logo_link != blank %}
              <a href="{{ block.settings.logo_link }}" target="_blank" rel="noopener">
            {% endif %}
              <img
                src="{{ block.settings.logo_image | img_url: '250x' }}"
                alt="{{ block.settings.logo_alt }}"
                title="{{ block.settings.logo_alt }}"
                loading="lazy"
              >
            {% if block.settings.logo_link != blank %}
              </a>
            {% endif %}
          {% endfor %}
        </div>

        <div class="marquee__group" aria-hidden="true">
          {% for block in section.blocks %}
            {% if block.settings.logo_link != blank %}
              <a href="{{ block.settings.logo_link }}" target="_blank" rel="noopener">
            {% endif %}
              <img
                src="{{ block.settings.logo_image | img_url: '250x' }}"
                alt="{{ block.settings.logo_alt }}"
                title="{{ block.settings.logo_alt }}"
                loading="lazy"
              >
            {% if block.settings.logo_link != blank %}
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .featured-skeleton{display:flex;justify-content:center;gap:24px;padding:40px 0}
  .featured-skeleton-logo{width:160px;height:80px;border-radius:10px;background:linear-gradient(90deg,#eee 25%,#f5f5f5 37%,#eee 63%);background-size:400% 100%;animation:shimmer 1.4s infinite}
  @keyframes shimmer{
  0%{background-position:100% 0}
  100%{background-position:-100% 0}
  }
  @media (max-width:750px){
  .featured-skeleton{gap:16px}
  .featured-skeleton-logo{width:120px;height:60px}
  }
  .featured-in-section .marquee.marquee--horizontal { background: #fff; }
  .featured-in-wrapper {background: #fff; padding: 8px 0;}
  .featured-in-section .marquee img { border-radius: 10px; pointer-events: none; max-width: 160px; height: 80px; padding: 13px; object-fit: contain; }
  .featured-in-section .marquee.marquee--horizontal:after { background: linear-gradient(to right, #fff, #fff0); content: ""; height: 100px; position: absolute; width: 200px; z-index: 1; }
   h2.featured-in-heading { text-align: center; font-size: 24px; text-transform: uppercase; font-weight: 400; margin-top: 0; margin-bottom: 0px !important; display: block; }
   .featured-in-wrapper {padding: 40px 0;}
   .featured-in-section .marquee.marquee--horizontal {position: relative;}
   .featured-in-section .marquee.marquee--horizontal:after {background: linear-gradient(to left, #fff, #fff0); content: ""; right: 0; top: 50%; transform: translateY(-50%); height: 100px; position: absolute; width: 200px; z-index: 1;}
   .featured-in-section .marquee.marquee--horizontal:before {background: linear-gradient(to right, #fff, #fff0); content: ""; left: 0; top: 50%; transform: translateY(-50%); height: 100px; position: absolute; width: 200px; z-index: 1;}
   h2.featured-in-heading { text-align: center; font-size: 24px; text-transform: capitalize; font-weight: 500; letter-spacing: 0.9px; margin-top: 0; margin-bottom: 2px !important; display: block; }
   .featured-in-section p.featured-in-subtitle { color: #535361; font-size: 18px; line-height: 2; text-align: center; margin: 0 auto 30px; display: block; }
   .featured-in-section h2.featured-in-heading { font-size: 20px; text-transform: uppercase; letter-spacing: 1px; font-weight: 400; }
   .featured-in-section .button-center {text-align: center; margin-top: 16px; font-size: 14px; text-decoration: underline; text-underline-offset: 3px; color: #a68380;}
   .featured-in-section a {color: #a3807f;}
   .featured-in-section h2.featured-in-heading {font-size: 24px;}
   @media only screen and (max-width: 750px) {
    .featured-in-section .marquee.marquee--horizontal:after {background: linear-gradient(to left, #fff 0%, #fff0 40%); content: none; right: 0; top: 50%; transform: translateY(-50%); height: 100px; position: absolute; width: 200px; z-index: 1;}
    .featured-in-section .marquee.marquee--horizontal:before {background: linear-gradient(to right, #fff, #fff0 40%); content: none; left: 0; top: 50%; transform: translateY(-50%); height: 100px; position: absolute; width: 200px; z-index: 1;}
    .featured-in-section h2.featured-in-heading { text-transform: uppercase; font-size: 18px !important; font-weight: 500;}
    .featured-in-section h2.featured-in-heading {font-size: 20px;}
    .featured-in-section .marquee img {max-width: 120px;}
    .featured-in-section p.featured-in-subtitle { text-align: center; margin: 0 auto 20px !important; font-size: 14px; color: #535361; }
    .featured-in-section .marquee__group {gap: 20px; margin-right: 30px;}
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {

  const featured = document.querySelector('[data-featured]');
  if (!featured) return;

  const io = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const skeleton = featured.querySelector('.featured-skeleton');
        const content  = featured.querySelector('.featured-content');

        content.style.display = 'block';
        content.style.opacity = '0';
        content.style.transition = 'opacity .4s ease';

        requestAnimationFrame(() => content.style.opacity = '1');
        skeleton.remove();

        io.disconnect();
      }
    });
  }, { rootMargin: '200px' });

  io.observe(featured);
});
</script>


{% schema %}
{
  "name": "Featured In Logos Marquee",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Featured In"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "Trusted by leading brands and media"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Marquee Speed",
      "min": 5,
      "max": 50,
      "step": 1,
      "default": 20
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    }
  ],

  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo Image"
        },
        {
          "type": "text",
          "id": "logo_alt",
          "label": "Alt Text",
          "default": "Logo"
        },
        {
          "type": "url",
          "id": "logo_link",
          "label": "Logo Link"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Featured In Logos Marquee",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}