<section class="featured-in-section" id="featured-in-{{ section.id }}">
  <div class="featured-in-wrapper">
    {% if section.settings.section_heading != blank %}
      <h2 class="featured-in-heading">{{ section.settings.section_heading }}</h2>
    {% endif %}

    {% if section.settings.section_subtitle != blank %}
      <p class="featured-in-subtitle">{{ section.settings.section_subtitle }}</p>
    {% endif %}

    <div class="marquee-container">
      <div class="marquee-content" style="--speed: {{ section.settings.speed }}s;">
        {%- comment -%} Triple duplication ensures seamless loop on all screen widths {%- endcomment -%}
        {% for i in (1..3) %}
          <div class="marquee-group">
            {% for block in section.blocks %}
              <div class="marquee-item" {{ block.shopify_attributes }}>
                {% if block.settings.logo_link != blank %}
                  <a href="{{ block.settings.logo_link }}" target="_blank" rel="noopener" class="marquee-link">
                {% endif %}
                  <img
                    src="{{ block.settings.logo_image | img_url: '250x' }}"
                    alt="{{ block.settings.logo_alt | escape }}"
                    loading="lazy"
                    width="160"
                    height="80"
                    class="marquee-img"
                  >
                {% if block.settings.logo_link != blank %}
                  </a>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  .featured-in-section { background: #fff; padding: 30px 0; overflow: hidden; contain: content; }
  .featured-in-heading { text-align: center; font-size: 24px; text-transform: uppercase; font-weight: 500; margin: 0 0 5px; color: #1a1a1a; margin-top: 0px; font-size: 24px; font-weight: 500; line-height: normal; text-align: center; text-transform: uppercase !important; color: #1a1a1a; letter-spacing: 1px; }
  .featured-in-subtitle { color: #535361; font-size: 16px; text-align: center; margin: 0 auto 30px; max-width: 600px; }

  .marquee-container { position: relative; width: 100%; overflow: hidden; padding: 10px 0; }
  .marquee-container::before, .marquee-container::after { 
    content: ""; position: absolute; top: 0; width: 150px; height: 100%; z-index: 2; pointer-events: none; 
  }
  .marquee-container::before { left: 0; background: linear-gradient(to right, #fff, transparent); }
  .marquee-container::after { right: 0; background: linear-gradient(to left, #fff, transparent); }

  .marquee-content { display: flex; width: max-content; animation: marquee-scroll var(--speed) linear infinite; will-change: transform; }
  .marquee-group { display: flex; align-items: center; gap: 40px; padding-right: 40px; }
  .marquee-item { flex-shrink: 0; }
  .marquee-img { max-width: 160px; height: 80px; object-fit: contain; filter: grayscale(1); transition: filter 0.3s ease; }
  .marquee-img:hover { filter: grayscale(0); }

  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.33%); }
  }

  @media (max-width: 750px) {
    .featured-in-heading { font-size: 18px; }
    .featured-in-subtitle { font-size: 14px; margin-bottom: 20px; }
    .marquee-container::before, .marquee-container::after { width: 50px; }
    .marquee-group { gap: 20px; padding-right: 20px; }
    .marquee-img { max-width: 110px; height: 55px; }
    @keyframes marquee-scroll {
      100% { transform: translateX(-33.33%); }
    }
  }
</style>

{% schema %}
{
  "name": "Featured In Logos Marquee",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Featured In"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "Trusted by leading brands and media"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Marquee Speed",
      "min": 5,
      "max": 50,
      "step": 1,
      "default": 20
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    }
  ],

  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo Image"
        },
        {
          "type": "text",
          "id": "logo_alt",
          "label": "Alt Text",
          "default": "Logo"
        },
        {
          "type": "url",
          "id": "logo_link",
          "label": "Logo Link"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Featured In Logos Marquee",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}