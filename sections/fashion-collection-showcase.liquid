{% schema %}
{
  "name": "Fashion Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FASHIONIST"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit..."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "View Fashion Collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Side Image"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    }
  ],
  "presets": [
    {
      "name": "Fashion Collection Showcase"
    }
  ]
}
{% endschema %}

<section class="page-width fashionist-section">
  <div class="fashionist-top">
    
    <div class="fashionist-left">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subtext }}</p>
      <a href="{{ section.settings.cta_link }}" class="fashionist-link">
        {{ section.settings.cta_text }}
      </a>
    </div>

    <div class="fashionist-right">
      {% if section.settings.right_image %}
        <img src="{{ section.settings.right_image }}" alt="Fashion Image" width= "800px"  height= "525px">
      {% endif %}
    </div>

  </div>

  {% if section.settings.collection != blank %}
    <div class="fashionist-products">
      {% for product in section.settings.collection.products limit: 4 %}
        
        <div class="fashionist-card">
          <a href="{{ product.url }}">
            <div class="fashionist-img">
              <img 
                src="{{ product.featured_image | image_url: width: 500 }}" 
                alt="{{ product.title }}">
            </div>
            <div class="fashionist-info">
              <p class="fashionist-title">{{ product.title }}</p>
              <p class="fashionist-price">
                {{ product.price | money }}
                {% if product.compare_at_price > product.price %}
                  <span class="compare">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </p>
            </div>
          </a>
        </div>

      {% endfor %}
    </div>
  {% endif %}

  <div class="fashionist-bottom">
    <a href="{{ section.settings.cta_link }}" class="fashionist-btn">
      EXPLORE MORE
    </a>
  </div>
</section>

<style>
.fashionist-section {
  padding: 60px 40px;
  background: #f5f5f5;
}

.fashionist-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 40px;
  margin-bottom: 40px;
}

.fashionist-left {
  max-width: 500px;
}

.fashionist-left h2 {
  font-size: 28px;
  letter-spacing: 2px;
  margin-bottom: 15px;
}

.fashionist-left p {
  font-size: 14px;
  color: #555;
  margin-bottom: 20px;
}

.fashionist-link {
  font-size: 14px;
  text-decoration: underline;
  color: #000;
}

.fashionist-right img {
  width: 100%;
  max-width: 500px;
  border-radius: 12px;
}

.fashionist-products {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-bottom: 40px;
}

.fashionist-card {
  background: #fff;
  padding: 20px;
  border-radius: 12px;
  transition: 0.3s ease;
}

.fashionist-card:hover {
  transform: translateY(-5px);
}

.fashionist-img img {
  width: 100%;
  height: auto;
}

.fashionist-title {
  font-size: 14px;
  margin-top: 10px;
  color: black;
}

.fashionist-price {
  font-size: 14px;
  font-weight: 500;
  color: #000;
}

.fashionist-price .compare {
  text-decoration: line-through;
  color: #888;
  margin-left: 8px;
  font-weight: 400;
}

.fashionist-bottom {
  text-align: center;
}

.fashionist-btn {
  background: #b58b7a;
  color: #fff;
  padding: 12px 30px;
  border-radius: 6px;
  text-decoration: none;
  font-size: 14px;
  letter-spacing: 1px;
}

/* Responsive */
@media (max-width: 1024px) {
  .fashionist-products {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .fashionist-top {
    flex-direction: column;
  }

  .fashionist-products {
    grid-template-columns: 1fr;
  }
}
</style>