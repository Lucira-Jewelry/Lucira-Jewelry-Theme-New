<section class="store-collection-banner">
  <div class="grid-row">
    <div class="grid-column">
      <div class="grid-banner-collection-wrapper">
        <div class="swiper grid-banner-collection-carousel">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              {% if block.type == 'banner_slide' %}
                <div class="swiper-slide">
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | img_url: 'master' }}"
                      alt="{{ block.settings.alt_text | escape }}"
                      loading="lazy"
                      width="100%"
                      height="auto"
                    >
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
          <div class="swiper-button-next"></div>
          <div class="swiper-button-prev"></div>
          <div class="swiper-pagination"></div>
        </div>
      </div>
    </div>

    <div class="grid-column">
      <div class="store-collection-details-wrapper">
        <div class="mobile-show">
          <div class="store-details-wrapper">
            <div class="store-details-title-wrapper">
              <h1>{{ section.settings.store_name }}</h1>
              {% if section.settings.show_rating %}
                <a href="{{ section.settings.rating_link }}" target="_blank" class="rating-text">
                  {{ section.settings.rating_value }}
                  {% if section.settings.rating_icon != blank %}
                    <img src="{{ section.settings.rating_icon | img_url: '24x' }}" alt="rating">
                  {% else %}
                    {{- 'five-star-rating.svg' | inline_asset_content -}}
                  {% endif %}
                </a>
              {% endif %}
            </div>
            <p>{{ section.settings.store_address }}</p>
          </div>
        </div>

        <div class="store-status-wrapper">
          {% if section.settings.store_status == 'regular' %}
            <div class="store-status" id="store-status">
              <div class="status-info">
                <span class="status-dot"></span>
                <span class="status-text"></span>
              </div>
              <span class="today-hours"></span>
              <span class="dropdown-arrow">{{- 'icon-angle-arrow.svg' | inline_asset_content -}}</span>

              <div class="store-hours-dropdown">
                <ul id="hours-list"></ul>
              </div>
            </div>
          {% elsif section.settings.store_status == 'opening_soon' %}
            <div class="store-status-static">
              <div class="status-info opening-soon">
                <span class="status-dot opening-soon"></span>
                <span class="status-text opening-soon">OPENING SOON</span>
              </div>
            </div>
          {% elsif section.settings.store_status == 'temporarily_closed' %}
            <div class="store-status-static">
              <div class="status-info temporarily-closed">
                <span class="status-dot temporarily-closed"></span>
                <span class="status-text temporarily-closed">TEMPORARILY CLOSED</span>
              </div>
            </div>
          {% endif %}
        </div>

        <div class="store-facilities-wrapper">
          <div class="store-facilities-icon-wrapper">
            <span class="store-facilities-icon">
              {{- 'icon-facilities.svg' | inline_asset_content -}}
            </span>
            Facilities At store
          </div>
          {% assign facility_blocks = section.blocks | where: 'type', 'facility' %}
          {% if facility_blocks.size > 0 %}
            <ul class="store-facilities-list">
              {% for block in facility_blocks %}
                <li>{{ block.settings.facility_name }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>

        <div class="store-services-wrapper">
          <div class="store-services-icon-wrapper">
            <span class="store-services-icon">
              {{- 'icon-facilities.svg' | inline_asset_content -}}
            </span>
            Services At Store
          </div>
          {% assign services_blocks = section.blocks | where: 'type', 'services' %}
          {% if services_blocks.size > 0 %}
            <ul class="store-services-list">
              {% for block in services_blocks %}
                <li class="store-service-item">
                  {% if block.settings.service_image != blank %}
                    <span class="service-icon">
                      <img
                        src="{{ block.settings.service_image | img_url: 'master' }}"
                        title="{{ block.settings.service_name | escape }}"
                        alt="{{ block.settings.service_name | escape }}"
                      >
                    </span>
                  {% endif %}
                  <span class="service-text">{{ block.settings.service_name }}</span>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
  <div class="page-width">
    <div class="store-collection-book-appoinment-block">
      <div class="grid-row">
        <div class="grid-column">
          <div class="store-details-wrapper">
            <div class="store-details-title-wrapper">
              <div>{{ section.settings.store_name }}</div>
              {% if section.settings.show_rating %}
                <a
                  href="{{ section.settings.rating_link }}"
                  target="_blank"
                  class="rating-text"
                >
                  {{- section.settings.rating_value }}
                  {{- 'five-star-rating.svg' | inline_asset_content -}}
                </a>
              {% endif %}
            </div>
            <p>{{ section.settings.store_address }}</p>
          </div>
        </div>
        <div class="grid-column">
          <div class="store-btn-wrapper">
            <a href="{{ section.settings.direct_me_link }}" class="direct-me-btn secondary-btn" target="_blank">
              {{- 'direction-icon.svg' | inline_asset_content -}}
              <span>{{ section.settings.direct_me_text }}</span>
            </a>
            <a href="{{ section.settings.call_us_link }}" class="call-us-btn secondary-btn" target="_blank">
              {{- 'call-us-icon.svg' | inline_asset_content -}}
              <span>{{ section.settings.call_us_text }}</span>
            </a>
            <a href="#"
              class="book-appointment-btn primary-btn"
              target="_blank"
              onclick="openVisitStoreOverlay()"
            >
              {{- 'icon-calender.svg' | inline_asset_content -}}
              <span>{{ section.settings.book_appointment_text }}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="visitStoreOverlay" class="form-popup-overlay">
    <div class="popup-form-container">
      <span class="popup-close-btn" onclick="closeVisitStoreOverlay()">&times;</span>

      <div id="visitStoreFormSection">
        <h3 class="popup-topic">Visit Our Store</h3>
        <form id="visitStoreContactForm" class="popup-form">
          <div class="input-icon-wrapper">
            {{- 'scheme-user.svg' | inline_asset_content -}}
            <input type="text" id="visit_store_name" placeholder="Full Name" required>
          </div>

          <div class="input-icon-wrapper">
            {{- 'scheme-phone.svg' | inline_asset_content -}}
            <input
              type="number"
              id="visit_store_phone"
              placeholder="Phone Number"
              required
              oninput="if(this.value.length > 10) this.value = this.value.slice(0, 10);"
            >
          </div>

          <p id="visit_store_phoneError" class="error-message" style="display: none;">
            Please enter a valid 10-digit phone number
          </p>

          <!-- Store Location Dropdown -->
          {% assign selected_store = '' %}

          {% if collection.handle == 'chembur-store' %}
            {% assign selected_store = 'Chembur - Mumbai' %}
          {% elsif collection.handle == 'pune-store' %}
            {% assign selected_store = 'JM Road - Pune' %}
             {% elsif collection.handle == 'sky-city-borivali-store' %}
            {% assign selected_store = 'Sky City Mall - Borivali - Mumbai' %}
          {% endif %}

          <div class="input-icon-wrapper">
            {{- 'scheme-location.svg' | inline_asset_content -}}
            <select id="visit_store_location" required>
              <option
                value=""
                disabled
                {% if selected_store == '' %}
                  selected
                {% endif %}
              >
                Select Store Location
              </option>

              <option
                value="Chembur - Mumbai"
                {% if selected_store == 'Chembur - Mumbai' %}
                  selected
                {% endif %}
              >
                Chembur - Mumbai
              </option>

              <option
                value="JM Road - Pune"
                {% if selected_store == 'JM Road - Pune' %}
                  selected
                {% endif %}
              >
                JM Road - Pune
              </option>
              <option
                value="Sky City Mall - Borivali - Mumbai"
                {% if selected_store == 'Sky City Mall - Borivali - Mumbai' %}
                  selected
                {% endif %}
              >
                Sky City Mall - Borivali - Mumbai
              </option>
            </select>
          </div>

          <button type="submit" id="visitStoreSubmitBtn" class="popup-submit-btn btn-submit-try-at-store" disabled>
            Submit
          </button>
        </form>
      </div>

      <div id="visitStoreSuccessMessage" class="popup-success-message" style="display: none;">
        <div class="success-icon">
          <svg width="60" height="60" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="30" cy="30" r="28" fill="#A398DE" stroke="#A398DE" stroke-width="2"/>
            <path d="M20 30L26 36L40 22" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3>Request Submitted!</h3>
        <p>We'll send you store details and directions shortly.</p>
        <div class="progress-bar-container">
          <div class="progress-bar"><span style="display: none;"></span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .store-collection-banner {margin-bottom: 70px;}
  .store-collection-banner .grid-row {display: grid ; grid-template-columns: calc(55% - 0px) calc(45% - 0px);}
  .store-collection-banner .grid-banner-collection-carousel img {width: 100%; height: 100%; object-fit: cover; display: block;}
  .store-collection-banner .swiper-pagination-bullets {display: none;}
  .store-status-wrapper{position:relative;display:inline-block;font-family:inherit}
  .store-status{display:inline-flex;align-items:center;gap:6px;position:relative;cursor:pointer;font-size:14px}
  .status-info { display: inline-flex ; align-items: center; gap: 6px; border: 1px solid #008000; padding: 4px 8px; border-radius: 8px; }
  .status-dot{width:8px;height:8px;border-radius:50%}
  .status-dot.open{background-color:#008000}
  .status-dot.closed{background-color:#dc3545}
  .status-text{font-weight: 500; font-size: 14px; line-height: 24px; letter-spacing: 1px; vertical-align: middle; text-transform: uppercase; color: #008000;}
  .today-hours{color: #1A1A1A; display: inline-flex ; align-items: center; gap: 8px; font-weight: 400; font-size: 16px; line-height: 24px; letter-spacing: 1px; margin-left: 12px; margin-right: 12px;}
  .today-hours svg { width:28px; height:28px; vertical-align:middle; }
  .dropdown-arrow{font-size:12px;color:#777}
  .store-hours-dropdown{display:none;position: absolute; top: 130%; left: 0; background: #fff; border: 1px solid #eaeaea; border-radius: 6px; box-shadow: 0 4px 8px rgb(56 56 56 / 10%); padding: 8px 4px; min-width: 100%; z-index: 2;}
  .store-hours-dropdown ul{list-style:none;margin:0;padding:0}
  .store-hours-dropdown li{padding: 6px 14px; display: flex ; justify-content: space-between; white-space: nowrap; font-size: 16px; color: #1A1A1A; letter-spacing: 0.6px; font-weight: 500;}
  .store-hours-dropdown li.today{font-weight:500;color:#008000}
  .store-status:hover .store-hours-dropdown{display:block}
  .store-collection-details-wrapper {height: 100%; padding: 20px 26px;}
  .store-facilities-icon svg {display: block; margin-right: 6px; width: 28px; height: 28px;}
  .store-facilities-wrapper .store-facilities-icon-wrapper {display: flex ; align-items: center; font-family: Futura Std; font-weight: 400; font-size: 16px; line-height: 24px; letter-spacing: 1px; text-transform: uppercase; color: #1A1A1A; margin-top: 20px;}
  .store-facilities-list { list-style: none; margin: 0; padding: 0; display: flex ; align-items: center; flex-wrap: wrap; gap: 12px; color: #B76F79; margin-top: 20px; font-family: Futura Std; font-weight: 400; font-size: 14px; line-height: 24px; vertical-align: middle; text-transform: capitalize; max-width: 500px;}
  .store-facilities-list li { margin-bottom: 0; border: 1px solid #B76F79; padding: 4px 16px; border-radius: 3rem; font-weight: 500; }
  .store-services-icon-wrapper {display: flex ; align-items: center; font-family: Futura Std; font-weight: 400; font-size: 16px; line-height: 24px; letter-spacing: 1px; text-transform: uppercase; color: #1A1A1A; margin-top: 20px;}
  .store-services-icon svg { display: block; margin-right: 6px; width: 28px; height: 28px; }
  .store-services-wrapper .store-service-item img { width: 100%; display: block;}
  ul.store-services-list { padding: 0; list-style: none; display: grid ; grid-template-columns: repeat(4, 1fr); gap: 12px;     max-width: 85%; margin-bottom: 0;}
  li.store-service-item { position: relative; }
  .store-service-item {position: relative; height: 100%;}
  .service-text {font-weight: 500; font-size: 12px; line-height: 150%; letter-spacing: 0.7px; vertical-align: middle; text-transform: uppercase;}
  .service-icon {display: block;}
  .store-details-title-wrapper h1 {margin: 0;}
  .store-collection-book-appoinment-block .grid-row { display: grid ; grid-template-columns: calc(45% - 0px) calc(55% - 0px); align-items: center; }
  .store-collection-banner {position: relative;}
  .store-collection-book-appoinment-block { box-shadow: 0px 4px 20px 0px #00000040; position: absolute; bottom: -60px; left: 50%; transform: translate(-50%); max-width: 1200px; width: 100%; padding: 20px; z-index: 1; background: #fff; border-radius: 12px;}
  .store-details-title-wrapper h1, .store-details-title-wrapper div { margin: 0; font-weight: 500; font-size: 22px; line-height: 24px; letter-spacing: 1px; vertical-align: middle; text-transform: uppercase; }
  .store-details-wrapper p { font-family: Futura Std; font-weight: 400; font-size: 14px; letter-spacing: 0.7px; line-height: 1.7; max-width: 420px; margin-bottom: 0; color: #666666;}
  .store-collection-book-appoinment-block .grid-row { display: grid ; grid-template-columns: calc(40% - 0px) calc(60% - 0px) !important; }
  .store-collection-book-appoinment-block a.secondary-btn { font-weight: 500; font-size: 16px; line-height: 100%; letter-spacing: 1.2px; text-transform: uppercase; padding: 16px 26px; border: 1px solid #B76F79; border-radius: 8px; color: #B76F79; display: inline-flex ; align-items: center; gap: 12px; transition: 0.3s;}
  .store-btn-wrapper {display: flex ; gap: 12px; align-items: center; justify-content: flex-end;}
  .store-collection-book-appoinment-block a.primary-btn { font-weight: 500; font-size: 16px; line-height: 100%; letter-spacing: 1.2px; text-transform: uppercase; padding: 16px 26px; border: 1px solid #B76F79; border-radius: 8px; color: #fff; display: inline-flex ; align-items: center; gap: 12px; background: #B76F79;}
