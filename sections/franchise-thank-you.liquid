<style>
.thank-you-wrapper{margin:0;padding:0;font-family:"Futura Std",Inter,Arial,sans-serif;background:#f6f9fc;display:flex;justify-content:center;align-items:center;min-height:100vh;text-align:center}
.thank-you-container{background:#fff;padding:50px 40px;width:90%;max-width:520px;border-radius:20px;box-shadow:0 10px 40px rgba(0,0,0,.1);animation:fadeIn .7s ease-out}
.thank-you-checkmark{width:100px;height:100px;border-radius:50%;border:5px solid #4caf50;display:flex;justify-content:center;align-items:center;margin:0 auto 30px;animation:pop .4s ease-out forwards}
.thank-you-checkmark svg{width:55px;height:55px;stroke:#4caf50;stroke-width:6;fill:none;stroke-linecap:round;stroke-linejoin:round;stroke-dasharray:100;stroke-dashoffset:100;animation:draw .8s ease forwards .3s}
.thank-you-title{font-size:32px;font-weight:600;margin-bottom:15px;color:#222;letter-spacing:1px}
.thank-you-message{font-size:17px;line-height:1.7;color:#555;margin-bottom:30px}
.thank-you-download-btn{display:inline-block;padding:16px 40px;background:#a68380;color:#fff;border-radius:50px;text-decoration:none;font-size:16px;font-weight:500;letter-spacing:1px;text-transform:uppercase;transition:all .3s ease;box-shadow:0 4px 15px rgba(166,131,128,.3);cursor:pointer;border:none}
.thank-you-download-btn:hover{background:#956e6b;transform:translateY(-2px);box-shadow:0 6px 20px rgba(166,131,128,.4)}
.thank-you-back-link{display:inline-block;margin-top:25px;color:#a68380;text-decoration:none;font-size:15px;transition:color .3s}
.thank-you-back-link:hover{color:#956e6b;text-decoration:underline}
@keyframes draw{
to{stroke-dashoffset:0}
}
@keyframes pop{
0%{transform:scale(.5);opacity:0}
100%{transform:scale(1);opacity:1}
}
@keyframes fadeIn{
from{opacity:0;transform:translateY(20px)}
to{opacity:1;transform:translateY(0)}
}
@media (max-width:576px){
.thank-you-container{padding:40px 30px}
.thank-you-title{font-size:26px}
.thank-you-message{font-size:15px}
.thank-you-download-btn{padding:14px 35px;font-size:14px}
.thank-you-checkmark{width:85px;height:85px}
.thank-you-checkmark svg{width:45px;height:45px}
}
</style>

<div class="thank-you-wrapper">
  <div class="thank-you-container">
    <!-- Animated Checkmark -->
    <div class="thank-you-checkmark">
      <svg viewBox="0 0 52 52">
        <path d="M14 27l7 7 17-17"/>
      </svg>
    </div>

    <h1 class="thank-you-title">{{ section.settings.title }}</h1>
    <p class="thank-you-message">
      {{ section.settings.message }}
    </p>

    {% if section.settings.show_download_button %}
      <a class="thank-you-download-btn" 
         href="{{ section.settings.download_url }}"
         {% if section.settings.open_in_new_tab %}target="_blank"{% endif %}
         {% if section.settings.force_download %}download{% endif %}>
        {{ section.settings.button_text }}
      </a>
    {% endif %}

    <br>
    <a class="thank-you-back-link" href="{{ section.settings.back_link_url }}">
      ← {{ section.settings.back_link_text }}
    </a>
  </div>
</div>

<script>
  window.onload = function () {
    // Track thank you page view
    if (window.dataLayer) {
      window.dataLayer.push({
        event: 'thankYouPage',
        pageType: 'franchise_registration_success',
        timestamp: new Date().toISOString()
      });
    }

    {% if section.settings.auto_open_pdf %}
      // Auto-open PDF in new tab after delay
      setTimeout(function() {
        window.open("{{ section.settings.pdf_view_url }}", "_blank");
      }, {{ section.settings.auto_open_delay }});
    {% endif %}
  };
</script>

{% schema %}
{
  "name": "Franchise Thank You",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Thank You!"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "Message",
      "default": "Your submission has been received.\nOur executive will contact you shortly."
    },
    {
      "type": "header",
      "content": "Download Button Settings"
    },
    {
      "type": "checkbox",
      "id": "show_download_button",
      "label": "Show Download Button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Download Brochure"
    },
    {
      "type": "url",
      "id": "download_url",
      "label": "Download URL",
      "info": "Use format: https://drive.google.com/uc?export=download&id=YOUR_FILE_ID"
    },
    {
      "type": "checkbox",
      "id": "force_download",
      "label": "Force Download (instead of opening)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open in New Tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Auto-Open PDF Settings"
    },
    {
      "type": "checkbox",
      "id": "auto_open_pdf",
      "label": "Auto-Open PDF in New Tab",
      "default": true,
      "info": "Automatically opens PDF viewer in new tab on page load"
    },
    {
      "type": "url",
      "id": "pdf_view_url",
      "label": "PDF View URL",
      "info": "Use format: https://drive.google.com/file/d/YOUR_FILE_ID/view"
    },
    {
      "type": "range",
      "id": "auto_open_delay",
      "label": "Auto-Open Delay (milliseconds)",
      "min": 0,
      "max": 3000,
      "step": 100,
      "default": 500,
      "info": "Delay before auto-opening PDF (recommended: 500-1000ms)"
    },
    {
      "type": "header",
      "content": "Back Link Settings"
    },
    {
      "type": "text",
      "id": "back_link_text",
      "label": "Back Link Text",
      "default": "Back to Home"
    },
    {
      "type": "url",
      "id": "back_link_url",
      "label": "Back Link URL",
      "default": "/"
    }
  ],
  "presets": [
    {
      "name": "Franchise Thank You"
    }
  ]
}
{% endschema %}