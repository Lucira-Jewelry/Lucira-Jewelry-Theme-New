<script>
  $(document).ready(function () {
    let selectedKarat = 14;

    function getRateByKarat(baseRate, karat) {
      const perGramRate = baseRate / 10; // baseRate is for 10 gm → convert to 1 gm
      return (perGramRate * (karat / 24)).toFixed(2);
    }

    const baseRate = parseFloat($('#goldRate').data('base'));

    function updateRateDisplay(karat) {
      const calculatedRate = karat === 24
        ? (baseRate / 10).toFixed(2)
        : getRateByKarat(baseRate, karat);

      $('.gold-calc__label--desktop').text(`Today's Standard Rate of ${karat}kt Gold`);
      $('.gold-calc__label--mobile').text(`Today's ${karat}kt Gold Rate`);
      $('#goldRate').text('₹ ' + parseFloat(calculatedRate).toLocaleString('en-IN'));
    }

    updateRateDisplay(selectedKarat);

    $('.gold-calc__karat').on('click', function () {
      $('.gold-calc__karat').removeClass('gold-calc__karat--active');
      $(this).addClass('gold-calc__karat--active');

      selectedKarat = parseInt($(this).text().replace('kt', ''));
      updateRateDisplay(selectedKarat);
      $('#goldCalcResult').hide();
    });

    $('.gold-calc__button').on('click', function () {
      const weight = parseFloat($('#weightInput').val());

      if (isNaN(weight) || weight <= 0) {
        alert('Please enter a valid weight.');
        return;
      }

      const currentRate = selectedKarat === 24
        ? baseRate / 10
        : getRateByKarat(baseRate, selectedKarat);

      const total = (weight * currentRate).toFixed(2);

      $('#goldValueOutput').text(`₹${parseFloat(total).toLocaleString('en-IN')}`);
      $('#goldCalcResult').show();
    });
  });
</script>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    function updateDateTime() {
      const today = new Date();

      // Format date
      const formattedDate = today.toLocaleDateString('en-IN', {
        day: 'numeric',
        month: 'short',
        year: 'numeric'
      });

      // Format time (12-hour format with seconds + AM/PM)
      const formattedTime = today.toLocaleTimeString('en-IN', {
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        hour12: true
      });

      // Combine date + time
      const dateTime = `${formattedDate}, ${formattedTime}`;

      // Update DOM safely
      const el1 = document.getElementById('rate-today-date');
      const el2 = document.getElementById('rate-today-date-2');

      if (el1) el1.textContent = dateTime;
      if (el2) el2.textContent = dateTime;
    }

    // Run immediately
    updateDateTime();

    // Update every second
    setInterval(updateDateTime, 1000);
  });
</script>
<script>
  function replaceGoldShortcodes() {
    const baseEl = document.querySelector('[data-base]');
    if (!baseEl) return;

    const baseRate = parseFloat(baseEl.getAttribute('data-base'));
    if (isNaN(baseRate)) return;

    const ratePerGram = baseRate / 10;

    const rates = {
      "[gold_rate_24kt]": Math.round(ratePerGram),
      "[gold_rate_22kt]": Math.round(ratePerGram * (22 / 24)),
      "[gold_rate_18kt]": Math.round(ratePerGram * (18 / 24)),
      "[gold_rate_14kt]": Math.round(ratePerGram * (14 / 24)),
    };

    const containers = document.querySelectorAll("p, li, span, div, h1, h2, h3, h4, h5, h6");

    containers.forEach((el) => {
      let html = el.innerHTML;
      let changed = false;

      Object.entries(rates).forEach(([shortcode, price]) => {
        if (html.includes(shortcode)) {
          html = html.replaceAll(shortcode, `₹${price.toLocaleString("en-IN")}`);
          changed = true;
        }
      });

      if (changed) el.innerHTML = html;
    });
  }

  document.addEventListener("DOMContentLoaded", function () {
    // Only replace shortcodes
    replaceGoldShortcodes();
  });
</script>
<script>
  $(document).ready(function () {
    $('.gold-table-v2 td').each(function () {
      let text = $(this).text().trim();
      if (text.startsWith('₹')) {
        let number = parseInt(text.replace(/[₹,]/g, ''));
        if (!isNaN(number)) {
          let formatted = number.toLocaleString('en-IN');
          $(this).text('₹' + formatted);
        }
      }
    });
  });
</script>
