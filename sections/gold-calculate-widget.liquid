<script>
  document.addEventListener('DOMContentLoaded', function () {
    const goldPriceElement = document.getElementById('gold-price');
    const karatSelector = document.getElementById('karatSelector');
    const gstToggle = document.getElementById('gstToggle');
    const locationSelector = document.getElementById('locationSelector');

    // Base gold price (default 22K Chennai if nothing selected)
    let baseGoldPrice = parseFloat(goldPriceElement.textContent) || 0;
    let selectedKarat = 22;
    let gstEnabled = false;

    // Location-based prices
    const locationPrices = {
      chennai: { price: 6000, name: 'Chennai' },
      coimbatore: { price: 5900, name: 'Coimbatore' },
      madurai: { price: 5800, name: 'Madurai' },
    };

    // Main calculation function
    function updatePrice() {
      if (!baseGoldPrice) return;

      let finalPrice = baseGoldPrice;

      // Karat adjustment
      if (selectedKarat === 18) {
        finalPrice = (finalPrice * 18) / 22;
      } else if (selectedKarat === 24) {
        finalPrice = (finalPrice * 24) / 22;
      }

      // GST adjustment
      if (gstEnabled) {
        finalPrice *= 1.03; // 3% GST
      }

      goldPriceElement.textContent = finalPrice.toFixed(2);
    }

    // GST toggle event
    if (gstToggle) {
      gstToggle.addEventListener('change', function () {
        gstEnabled = this.checked;
        updatePrice();
      });
    }

    // Karat selector event
    if (karatSelector) {
      karatSelector.addEventListener('change', function () {
        selectedKarat = parseInt(this.value, 10) || 22;
        updatePrice();
      });
    }

    // Location selector event
    if (locationSelector) {
      locationSelector.addEventListener('change', function () {
        const selectedLocation = this.value;
        if (locationPrices[selectedLocation]) {
          baseGoldPrice = locationPrices[selectedLocation].price;
        }
        updatePrice();
      });
    }

    // Initial price calculation
    updatePrice();
  });
</script>

<script>
  $(document).ready(function () {
    // Define the main calculation function
    function calculateAndDisplayGST() {
      const weight = parseFloat($('#weightInput').val());
      const gstResultsContainer = $('#gstResults');

      // Check if the weight input is a valid positive number
      if (isNaN(weight) || weight <= 0) {
        gstResultsContainer
          .html(
            `
        <p style="text-align:center; font-size:16px; color:#A68380; margin-top:20px;">
          Please enter a valid weight in grams.
        </p>
      `
          )
          .slideDown();
        return;
      }

      // Get the base rate and active karat
      const baseRate = parseFloat($('#goldRate').data('base'));
      const activeKarat = $('.gold-calc__karat.gold-calc__karat--active').text().replace('kt', '');

      let currentRate;
      if (activeKarat === '24') {
        currentRate = baseRate / 10;
      } else {
        currentRate = (baseRate / 10) * (parseInt(activeKarat) / 24);
      }

      const goldPrice = weight * currentRate;
      const gstRate = 0.03; // 3% GST on gold
      const totalGST = goldPrice * gstRate;
      const finalAmountGST = goldPrice + totalGST;

      const cgstValue = totalGST / 2; // 1.5%
      const sgstValue = totalGST / 2; // 1.5%

      // Recreate the HTML table dynamically with the new values
      gstResultsContainer
        .html(
          `
      <div class="gst-result-item">
        <span class="gst-label">Gold Price</span>
        <span class="gst-value" id="goldPriceGST">₹${goldPrice.toLocaleString('en-IN', {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        })}</span>
      </div>
      <div class="gst-result-item">
        <span class="gst-label">CGST (Central GST)</span>
        <span class="gst-value" id="cgstValue">₹${cgstValue.toLocaleString('en-IN', {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        })}</span>
      </div>
      <div class="gst-result-item">
        <span class="gst-label">SGST/UTGST (State GST)</span>
        <span class="gst-value" id="sgstValue">₹${sgstValue.toLocaleString('en-IN', {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        })}</span>
      </div>
      <div class="gst-result-item total-gst">
        <span class="gst-label">Total GST Amount</span>
        <span class="gst-value" id="totalGST">₹${totalGST.toLocaleString('en-IN', {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        })}</span>
      </div>
      <div class="gst-result-item final-amount">
        <p class="gst-label-son">Final Amount <span class="includesmall"> ( Including GST)</span></p>
        <p class="gst-value-son" id="finalAmountGST">₹${finalAmountGST.toLocaleString('en-IN', {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        })}</p>
      </div>
      <p class="gold-calc__note">*This value is not the final value as Gold Rate might change*</p>
    `
        )
        .slideDown();
    }

    // Set the default weight to 1 gram and perform initial calculation on page load
    $('#weightInput').val(1);
    calculateAndDisplayGST();

    // Attach the calculation function to the click events
    $('.gold-calc__button').on('click', calculateAndDisplayGST);
    $('.gst-button.including-gst').on('click', calculateAndDisplayGST);
  });
</script>
<script>
  $(document).ready(function () {
    const gstResultsContainer = $('#gstResults');

    function calculateGoldPrice() {
      const weight = parseFloat($('#weightInput').val());

      if (isNaN(weight) || weight <= 0) {
        gstResultsContainer
          .html(
            `
          <p style="text-align:center; font-size:16px; color:#A68380; margin-top:20px;">
            Please enter a valid weight in grams.
          </p>
        `
          )
          .slideDown();
        return null;
      }

      const baseRate = parseFloat($('#goldRate').data('base'));
      const activeKarat = $('.gold-calc__karat.gold-calc__karat--active').text().replace('kt', '');
      let currentRate;
      if (activeKarat === '24') {
        currentRate = baseRate / 10;
      } else {
        currentRate = (baseRate / 10) * (parseInt(activeKarat) / 24);
      }

      return weight * currentRate;
    }

    // 🔹 Exclude GST button
    $('.gst-button.excluding-gst').on('click', function () {
      $('.gst-button').removeClass('active');
      $(this).addClass('active');

      const goldPrice = calculateGoldPrice();
      if (goldPrice === null) return;

      gstResultsContainer
        .html(
          `
        <div class="gst-result-item">
          <span class="gst-label">Gold Price</span>
          <span class="gst-value" id="goldPriceGST">₹${goldPrice.toLocaleString('en-IN', {
