<div class="gold-calc-section">
  <div class="page-width">
    <h1 class="gold-calc__heading">Gold Rate Today in {{ page.metafields.custom.city_name }}</h1>
  </div>
  <div class="gst-main page-width">
    <div class="gold-calc__container">
      <p class="gold-calc__label">Choose Karatage</p>

      <div class="gold-calc__karat-options">
        <button class="gold-calc__karat gold-calc__karat--active">9kt</button>
        <button class="gold-calc__karat">14kt</button>
        <button class="gold-calc__karat">18kt</button>
        <button class="gold-calc__karat">22kt</button>
        <button class="gold-calc__karat">24kt</button>
      </div>

      <div class="gold-calc__inputs">
        <div class="gold-calc__input-group">
          <label for="weightInput" class="gold-calc__input-label">In Grams</label>
          <input type="number" id="weightInput" placeholder="Enter Weight" value="1" class="gold-calc__input">
        </div>

        <div class="gold-calc__input-group">
          <label for="goldRate" class="gold-calc__input-label">
            <span class="gold-calc__label--desktop">Today's Standard Rate of 14kt Gold</span>
            <span class="gold-calc__label--mobile">Today's 14kt Gold Rate</span>
          </label>
          <div
            id="goldRate"
            class="gold-calc__rate-display"
            data-base="{{ section.settings.rate_today | remove: '₹' | remove: ',' | strip }}"
          ></div>
        </div>
      </div>

      <button class="gold-calc__button">CALCULATE</button>
      {% if page.handle == 'gst-calculator' %}
        <div class="gst-toggle-container">
          <button class="gst-button excluding-gst">Excluding GST</button>
          <button class="gst-button including-gst active">Including GST</button>
        </div>
      {% endif %}
      <div id="goldCalcResult" class="gold-calc__rate-display" style="margin-top: 15px; display:none;">
        <span>Estimated Value: </span><span id="goldValueOutput"></span>
      </div>

      <p class="gold-calc__note">*This value is not the final value as Gold Rate might change*</p>
    </div>

    {% if page.handle == 'gst-calculator' %}
      <div class="gst-calculate">
        <div class="gold-calc__container gst-results-container">
          <div id="gstResults">
            <div class="gst-result-item">
              <span class="gst-label">Gold Price</span>
              <span class="gst-value" id="goldPriceGST">₹ 1,19,850.00</span>
            </div>
            <div class="gst-result-item">
              <span class="gst-label">CGST (Central GST)</span>
              <span class="gst-value" id="cgstValue">₹ 1,797.75</span>
            </div>
            <div class="gst-result-item">
              <span class="gst-label">SGST/UTGST (State GST)</span>
              <span class="gst-value" id="sgstValue">₹ 1,797.75</span>
            </div>
            <div class="gst-result-item total-gst">
              <span class="gst-label">Total GST Amount</span>
              <span class="gst-value" id="totalGST">₹ 3,595.50</span>
            </div>
            <div class="gst-result-item final-amount">
              <p class="gst-label vv">Final Amount <span class="includesmall"> ( Including GST)</span></p>
              <p class="gst-value nn" id="finalAmountGST">₹ 1,23,445.50</p>
            </div>
            <p class="gold-calc__note">*This value is not the final value as Gold Rate might change*</p>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>

<div class="investment-section">
  <div class="">
    <div class="investment-section__container">
      <!-- Left Column -->
      <div class="investment-section__container">
        <div class="investment-section__column investment-section__left" style="width:fit-content">
          <h2 class="investment-section__heading">{{ section.settings.investment_heading }}</h2>
          <div class="investment-section__description">
            {{ section.settings.investment_description }}
          </div>
        </div>

        <div class="investment-section__column investment-section__right">
          <h3 class="investment-section__toc-heading">Table of Contents</h3>
          {{ section.settings.investment_quick_links }}
        </div>
      </div>
    </div>
  </div>
</div>
<div class="gold-table-v2-section">
  <div class="page-width">
    <h2 class="gold-table-v2-title" id="gold-price-breakdown-weight">GST PRICE BREAKDOWN BY GOLD WEIGHT</h2>
    <div class="gold-table-v2-wrapper">
      <table class="gold-table-v2">
        <thead>
          <tr>
            <th>CARAT</th>
            <th>1GM</th>
            <th>5GM</th>
            <th>10GM</th>
            <th>100GM</th>
          </tr>
        </thead>
        <tbody>
          {%- assign base_24kt = section.settings.rate_today | remove: '₹' | remove: ',' | strip | plus: 0 -%}
          {%- assign rate_per_gram = base_24kt | divided_by: 10.0 -%}
          {%- assign karats = '24,22,18,14,9' | split: ',' -%}
          {%- assign weights = '1,5,10,100' | split: ',' -%}

          {%- for karat in karats -%}
            {%- assign karat_factor = karat | plus: 0 | divided_by: 24.0 -%}
            <tr>
              <td>{{ karat }} KT</td>
              {%- for w in weights -%}
                {%- assign price = rate_per_gram | times: w | times: karat_factor -%}
                <td>₹{{ price | round }}</td>
              {%- endfor -%}
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="gold-rate-rise-and-fall">
  <div class="page-width">
    <div class="information-content-wrapper">
      <h2>Gold Rate Today in {{ page.metafields.custom.city_name }} – [current_date]</h2>
      <div id="gold-rise" style="display:none">
        <h3>Gold Rate Rises</h3>
        <p>
          In {{ page.metafields.custom.city_name }} on [current_date], 24-carat gold is priced at [gold_rate_24kt_10gm]
          per 10 grams, while 22-carat gold stands at [gold_rate_22kt_10gm] per 10 grams.
        </p>
      </div>

      <div id="gold-fall" style="display:none">
        <h3>Gold Rate Falls</h3>
        <p>
          In {{ page.metafields.custom.city_name }} on [current_date], 24-carat gold is available at
          [gold_rate_24kt_10gm] per 10 grams, with 22-carat gold priced at [gold_rate_22kt_10gm] per 10 grams.
        </p>
      </div>

      <div id="gold-stable" style="display:none">
        <h3>Gold Rate Remains Stable</h3>
        <p>
          In {{ page.metafields.custom.city_name }} on [current_date], gold prices remain steady with 24-carat gold at
          [gold_rate_24kt_10gm] per 10 grams and 22-carat gold at [gold_rate_22kt_10gm] per 10 grams.
        </p>
      </div>
    </div>
  </div>
</div>

