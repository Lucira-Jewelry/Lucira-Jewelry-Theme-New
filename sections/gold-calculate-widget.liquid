      'Muzaffarnagar',
      'Pilibhit',
      'Saharanpur',
      'Saidapur',
      'Shahbazpur',
      'Tharati Etawah',
      'Varanasi',
    ],
    uttarakhand: ['DehraDun'],
    'west-bengal': [
      'Alipurduar',
      'Asansol',
      'Barddhaman',
      'Bhatpara',
      'Haldia',
      'Haora',
      'Kolkata',
      'Krishnanagar',
      'Shiliguri',
    ],
  };

  const stateDropdown = document.getElementById('state');
  const cityDropdown = document.getElementById('city');

  // Get pre-selected values from Liquid
  const preselectedCity = "{{ page.metafields.custom.city_name | default: '' }}";

  function populateCities(state) {
    cityDropdown.innerHTML = '';
    if (stateCityMap[state]) {
      stateCityMap[state].forEach((city) => {
        const option = document.createElement('option');
        option.value = city.toLowerCase().replace(/\s+/g, '-');
        option.textContent = city;

        // Check if this city should be pre-selected
        if (
          preselectedCity &&
          (preselectedCity === city || preselectedCity === city.toLowerCase().replace(/\s+/g, '-'))
        ) {
          option.selected = true;
        }

        cityDropdown.appendChild(option);
      });
    }
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', function () {
    // Populate cities for the initially selected state
    populateCities(stateDropdown.value);
  });

  stateDropdown.addEventListener('change', function () {
    populateCities(this.value);
  });

  document.querySelector('.location-submit').addEventListener('click', function () {
    const state = stateDropdown.value;
    const city = cityDropdown.value;
    window.location.href = `/pages/${city}-gold-rate-today`;
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const baseEl = document.querySelector('[data-base]');
    if (!baseEl) return;

    const todayRate = parseFloat(baseEl.getAttribute('data-base'));

    const yesterdayRate = parseFloat("{{ section.settings.rate_yesterday | remove: '₹' | remove: ',' | strip }}");

    if (!todayRate || !yesterdayRate) return;

    const THRESHOLD = 500; // ₹500 range

    const riseEl = document.getElementById('gold-rise');
    const fallEl = document.getElementById('gold-fall');
    const stableEl = document.getElementById('gold-stable');

    // Hide all by default
    [riseEl, fallEl, stableEl].forEach((el) => el && (el.style.display = 'none'));

    const diff = todayRate - yesterdayRate;

    if (diff > THRESHOLD && riseEl) {
      riseEl.style.display = 'block';
    } else if (diff < -THRESHOLD && fallEl) {
      fallEl.style.display = 'block';
    } else if (stableEl) {
      stableEl.style.display = 'block';
    }
  });
</script>

