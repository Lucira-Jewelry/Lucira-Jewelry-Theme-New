<script>
  function getDaySuffix(day) {
    if (day > 3 && day < 21) return 'th';
    switch (day % 10) {
      case 1: return 'st';
      case 2: return 'nd';
      case 3: return 'rd';
      default: return 'th';
    }
  }

  function replaceDateShortcode() {
    const today = new Date();

    const day = today.getDate();
    const suffix = getDaySuffix(day);

    const formattedDate = `${day}${suffix} ${today.toLocaleString('en-IN', {
      month: 'short'
    })}, ${today.getFullYear()}`;

    const elements = document.querySelectorAll(
      'p, li, span, div, h1, h2, h3, h4, h5, h6'
    );

    elements.forEach(el => {
      if (el.innerHTML.includes('[current_date]')) {
        el.innerHTML = el.innerHTML.replaceAll(
          '[current_date]',
          formattedDate
        );
      }
    });
  }

  document.addEventListener('DOMContentLoaded', replaceDateShortcode);
</script>
