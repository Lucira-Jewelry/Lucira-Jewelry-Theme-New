<div class="gold-widget-section">
  <div class="page-width">
    <div class="wrapper-gold">
      <div class="gold-widget__box">
        <!-- Today's Rate -->
        
        <div class="gold-widget__block gold-widget__block--today">
          <p class="gold-widget__label">Gold Rate in {{ page.metafields.custom.city_name }}: 24 KT</p>
          <p class="gold-widget__price"><span class="gold-unit">₹</span>{{ section.settings.rate_today -}}<span class="gold-widget__unit">/10 gm</span>
          </p>
          <p class="gold-widget__date" id="rate-today-date"></p>
        </div>

        <div class="gold-widget__divider"></div>

        <!-- Weekly Average -->
        <div class="gold-widget__block gold-widget__block--week">
          <p class="gold-widget__label">Gold Rate in {{ page.metafields.custom.city_name }}: 22 KT</p>
          <p class="gold-widget__price"><span class="gold-unit">₹</span>{{ section.settings.rate_avg -}}<span class="gold-widget__unit">/10 gm</span>
          </p>
          <p class="gold-widget__date" id="rate-today-date-2"></p>
        </div>
      </div>
      <div class="location-selector">
        <div class="location-dropdown">
          <label for="state">State</label>
          <select id="state" name="state">
            {% assign states = "Andaman and Nicobar Islands,Andhra Pradesh,Arunachal Pradesh,Assam,Bihar,Chandigarh,Chhattisgarh,Dadra and Nagar Haveli,Daman and Diu,Delhi,Goa,Gujarat,Haryana,Himachal Pradesh,Jammu and Kashmir,Jharkhand,Karnataka,Kerala,Lakshadweep,Madhya Pradesh,Maharashtra,Manipur,Meghalaya,Mizoram,Nagaland,Odisha,Puducherry,Punjab,Rajasthan,Sikkim,Tamil Nadu,Telangana,Tripura,Uttar Pradesh,Uttarakhand,West Bengal" | split: "," %}
            {% assign current_state = page.metafields.custom.state_name %}
            {% for state in states %}
              {% assign state_value = state | downcase | replace: ' ', '-' %}
              {% assign state_selected = false %}
              
              {% comment %} Check if current state matches either the display name or the value {% endcomment %}
              {% if current_state == state or current_state == state_value %}
                {% assign state_selected = true %}
              {% endif %}
              
              <option value="{{ state_value }}" {% if state_selected %}selected{% endif %}>{{ state }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="location-dropdown city-dropdown">
          <label for="city">City</label>
          <select id="city" name="city">
            {% assign current_city = page.metafields.custom.city_name %}
            {% comment %} Cities will be populated by JavaScript, but we need to set the selected value {% endcomment %}
          </select>
        </div>

        <button type="button" class="location-submit">→</button>
      </div>
    </div>
  </div>
</div>


<div class="gold-calc-section">
  <div class="page-width">
    <h1 class="gold-calc__heading">CALCULATE YOUR GOLD</h1>
  </div>
  <div class="gold-calc__container">
    <p class="gold-calc__label">Choose Karatage</p>

    <div class="gold-calc__karat-options">
      <button class="gold-calc__karat gold-calc__karat--active">14kt</button>
      <button class="gold-calc__karat">18kt</button>
      <button class="gold-calc__karat">22kt</button>
      <button class="gold-calc__karat">24kt</button>
    </div>

    <div class="gold-calc__inputs">
      <div class="gold-calc__input-group">
        <label for="weightInput" class="gold-calc__input-label">In Grams</label>
        <input type="text" id="weightInput" placeholder="Enter Weight" class="gold-calc__input">
      </div>

      <div class="gold-calc__input-group">
        <label for="goldRate" class="gold-calc__input-label">
          <span class="gold-calc__label--desktop">Today's Standard Rate of 14kt Gold</span>
          <span class="gold-calc__label--mobile">Today's 14kt Gold Rate</span>
        </label>
        <div
            id="goldRate"
            class="gold-calc__rate-display"
            data-base="{{ section.settings.rate_today | remove: '₹' | remove: ',' | strip }}"
          >
        </div>
      </div>
    </div>

    <button class="gold-calc__button">CALCULATE</button>

    <div id="goldCalcResult" class="gold-calc__rate-display" style="margin-top: 15px; display:none;">
      <span>Estimated Value: </span><span id="goldValueOutput"></span>
    </div>

    <p class="gold-calc__note">*This value is not the final value as Gold Rate might change*</p>
  </div>
</div>
<div class="investment-section">
  <div class="page-width">
    <div class="investment-section__container">
    <!-- Left Column -->
        <div class="investment-section__container">
          <div class="investment-section__column investment-section__left" style="width:fit-content">
            <h2 class="investment-section__heading">{{ section.settings.investment_heading }}</h2>
            <div class="investment-section__description">
              {{ section.settings.investment_description }}
            </div>
          </div>

          <div class="investment-section__column investment-section__right">
            <h3 class="investment-section__toc-heading">Table of Contents</h3>
            {{ section.settings.investment_quick_links }}
          </div>
        </div>
  </div>
  </div>
</div>
<div class="gold-table-v2-section">
  <div class="page-width">
    <h2 class="gold-table-v2-title" id="gold-price-breakdown-weight">GOLD PRICE BREAKDOWN BY WEIGHT</h2>
    <div class="gold-table-v2-wrapper">
      <table class="gold-table-v2">
        <thead>
          <tr>
            <th>CARAT</th>
            <th>1GM</th>
            <th>6GM</th>
            <th>12GM</th>
            <th>100GM</th>
          </tr>
        </thead>
        <tbody>
          {%- assign base_24kt = section.settings.rate_today | remove: '₹' | remove: ',' | strip | plus: 0 -%}
          {%- assign rate_per_gram = base_24kt | divided_by: 10.0 -%}
          {%- assign karats = "24,22,18,14" | split: "," -%}
          {%- assign weights = "1,6,12,100" | split: "," -%}
      
          {%- for karat in karats -%}
            {%- assign karat_factor = karat | plus: 0 | divided_by: 24.0 -%}
            <tr>
              <td>{{ karat }} KT</td>
              {%- for w in weights -%}
                {%- assign price = rate_per_gram | times: w | times: karat_factor -%}
                <td>₹{{ price | round }}</td>
              {%- endfor -%}
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</div>



