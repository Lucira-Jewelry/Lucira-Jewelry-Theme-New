<script>
  function replaceGoldShortcodes() {
    const baseEl = document.querySelector('[data-base]');
    if (!baseEl) return;

    const baseRate = parseFloat(baseEl.getAttribute('data-base'));
    if (isNaN(baseRate)) return;

    const ratePerGram = baseRate / 10;

    const rates = {
      // Per 1 gram
      '[gold_rate_24kt]': Math.round(ratePerGram),
      '[gold_rate_22kt]': Math.round(ratePerGram * (22 / 24)),
      '[gold_rate_18kt]': Math.round(ratePerGram * (18 / 24)),
      '[gold_rate_14kt]': Math.round(ratePerGram * (14 / 24)),
      '[gold_rate_9kt]': Math.round(ratePerGram * (9 / 24)),

      // ✅ Per 10 gram
      '[gold_rate_24kt_10gm]': Math.round(ratePerGram * 10),
      '[gold_rate_22kt_10gm]': Math.round(ratePerGram * 10 * (22 / 24)),
      '[gold_rate_18kt_10gm]': Math.round(ratePerGram * 10 * (18 / 24)),
      '[gold_rate_14kt_10gm]': Math.round(ratePerGram * 10 * (14 / 24)),
      '[gold_rate_9kt_10gm]': Math.round(ratePerGram * 10 * (9 / 24)),
    };

    const containers = document.querySelectorAll(
      'p, li, span, div, h1, h2, h3, h4, h5, h6'
    );

    containers.forEach((el) => {
      let html = el.innerHTML;
      let changed = false;

      Object.entries(rates).forEach(([shortcode, price]) => {
        if (html.includes(shortcode)) {
          html = html.replaceAll(
            shortcode,
            `₹${price.toLocaleString('en-IN')}`
          );
          changed = true;
        }
      });

      if (changed) el.innerHTML = html;
    });
  }

  document.addEventListener('DOMContentLoaded', replaceGoldShortcodes);
</script>
