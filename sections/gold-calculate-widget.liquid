            maximumFractionDigits: 2,
          })}</p>
        </div>
        <p class="gold-calc__note">*This value is not the final value as Gold Rate might change*</p>
      `
        )
        .slideDown();
    });

    // 🔹 Include GST button
    $('.gst-button.including-gst').on('click', function () {
      $('.gst-button').removeClass('active');
      $(this).addClass('active');

      const goldPrice = calculateGoldPrice();
      if (goldPrice === null) return;

      const cgstValue = goldPrice * 0.015;
      const sgstValue = goldPrice * 0.015;
      const totalGST = cgstValue + sgstValue;
      const finalAmountGST = goldPrice + totalGST;

      gstResultsContainer
        .html(
          `
