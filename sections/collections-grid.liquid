{% schema %}
{
  "name": "Collections Grid",
  "settings": [
    {
      "type": "text",
      "id": "Cateogory_heading",
      "label": "Section Heading"
    },
    {
      "type": "text",
      "id": "category_subheading",
      "label": "category Subheading"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "category_image_desktop",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "category_image_mobile",
          "label": "Mobile Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Collections Grid"
    }
  ]
}
{% endschema %}

<div class="categories-section">
  <div class="page-width">
    <h1 class="h1-tag-homepage" style="display:none;">
      Lucira Jewelry - Lab Grown Diamond Rings, Earrings, Necklace, Bracelet & Mangalsutra
    </h1>
    <h2>{{ section.settings.Cateogory_heading }}</h2>
    <p>{{ section.settings.category_subheading }}</p>
    <div class="categories-grid">
      {% for block in section.blocks %}
        <div class="category-card">
          {% if block.settings.link != blank %}
            <a
              href="{{ block.settings.link }}" aria-label="Browse {{ block.settings.title }} collection"
              onclick="
                window.dataLayer = window.dataLayer || []; dataLayer.push({
                    event: 'promoClick',
                    promoClick: {
                    creative_name: 'Below Banner Collection Grid',
                    promo_name: '{{ block.settings.title | escape }}',
                    promo_position: '{{ block.settings.link }}',
                    location_id: 'homepage'
                    }
                });
              "
            >
          {% endif %}

          {% comment %} <picture>
            {% if block.settings.category_image_mobile %}
              <source
                media="(max-width: 767px)"
                srcset="
                  {{ block.settings.category_image_mobile | img_url: '210x360', crop: 'center', format: 'webp' }} 210w,
                  {{ block.settings.category_image_mobile | img_url: '420x720', crop: 'center', format: 'webp' }} 420w
                "
                sizes="(max-width: 767px) 210px"
                type="image/webp"
              >
              <source
                media="(max-width: 767px)"
                srcset="
                  {{ block.settings.category_image_mobile | img_url: '210x360', crop: 'center' }} 210w,
                  {{ block.settings.category_image_mobile | img_url: '420x720', crop: 'center' }} 420w
                "
                sizes="(max-width: 767px) 210px"
              >
            {% endif %}
            {% if block.settings.category_image_desktop %}
              <source
                media="(min-width: 768px)"
                srcset="
                  {{ block.settings.category_image_desktop | img_url: '200x346', crop: 'center', format: 'webp' }} 200w,
                  {{ block.settings.category_image_desktop | img_url: '270x468', crop: 'center', format: 'webp' }} 270w,
                  {{ block.settings.category_image_desktop | img_url: '400x692', crop: 'center', format: 'webp' }} 400w
                "
                sizes="(min-width: 768px) 270px"
                type="image/webp"
              >
              <source
                media="(min-width: 768px)"
                srcset="
                  {{ block.settings.category_image_desktop | img_url: '200x346', crop: 'center' }} 200w,
                  {{ block.settings.category_image_desktop | img_url: '270x468', crop: 'center' }} 270w,
                  {{ block.settings.category_image_desktop | img_url: '400x692', crop: 'center' }} 400w
                "
                sizes="(min-width: 768px) 270px"
              >
            {% endif %}
            <img
              src="{% if block.settings.category_image_desktop %}{{ block.settings.category_image_desktop | img_url: '270x468', crop: 'center' }}{% elsif block.settings.category_image_mobile %}{{ block.settings.category_image_mobile | img_url: '420x720', crop: 'center' }}{% else %}{{ 'placeholder-image.png' | asset_url }}{% endif %}"
              srcset="{% if block.settings.category_image_desktop %}{{ block.settings.category_image_desktop | img_url: '200x346', crop: 'center' }} 200w, {{ block.settings.category_image_desktop | img_url: '270x468', crop: 'center' }} 270w, {{ block.settings.category_image_desktop | img_url: '400x692', crop: 'center' }} 400w{% elsif block.settings.category_image_mobile %}{{ block.settings.category_image_mobile | img_url: '210x360', crop: 'center' }} 210w, {{ block.settings.category_image_mobile | img_url: '420x720', crop: 'center' }} 420w{% endif %}"
              sizes="(max-width: 767px) 210px, 270px"
              width="400" height="692"
              alt="Explore our {{ block.settings.title }} Collection"
              title="{{ block.settings.title }}"
              loading="lazy"
              decoding="async"
              class="category-card-img"
            >
          </picture> {% endcomment %}

          <picture>
            {%- comment -%} Define images for cleaner logic {%- endcomment -%}
            {%- assign desktop_img = block.settings.category_image_desktop | default: block.settings.category_image_mobile -%}
            {%- assign mobile_img = block.settings.category_image_mobile | default: block.settings.category_image_desktop -%}

            {%- comment -%} Mobile Sources (50vw width) {%- endcomment -%}
            {%- if mobile_img -%}
              <source
                media="(max-width: 767px)"
                srcset="
                  {{ mobile_img | image_url: width: 210, height: 360, crop: 'center' }} 210w,
                  {{ mobile_img | image_url: width: 420, height: 720, crop: 'center' }} 420w
                "
                sizes="50vw"
              >
            {%- endif -%}

            {%- comment -%} Desktop Sources (Approx 16.5% width) {%- endcomment -%}
            {%- if desktop_img -%}
              <source
                media="(min-width: 768px)"
                srcset="
                  {{ desktop_img | image_url: width: 200, height: 346, crop: 'center' }} 200w,
                  {{ desktop_img | image_url: width: 270, height: 468, crop: 'center' }} 270w,
                  {{ desktop_img | image_url: width: 400, height: 692, crop: 'center' }} 400w
                "
                sizes="(min-width: 1400px) 16vw, 20vw"
              >
            {%- endif -%}

            {%- comment -%} Main Image Tag {%- endcomment -%}
            <img
              src="{{ desktop_img | image_url: width: 270, height: 468, crop: 'center' }}"
              alt="Explore our {{ block.settings.title | escape }} Collection"
              width="270"
              height="468"
              class="category-card-img"
              {%- comment -%} 
                PERFORMANCE FIX: Load the first 6 images (1st row) eagerly. 
                Load the rest lazily to save data.
              {%- endcomment -%}
              {% if forloop.index <= 6 %}
                loading="eager"
                fetchpriority="high"
              {% else %}
                loading="lazy"
              {% endif %}
              decoding="async"
              style="object-fit: cover; width: 100%; height: auto; aspect-ratio: 270/468;"
            >
          </picture>

          
          <span class="category-title">{{ block.settings.title }}</span>
          <span class="shop-now-text desktop-only">Shop Now</span>

          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .categories-section h2{color:#000;}
  .mobilecategory-img{display:none;}
  @media(max-width:767px){
    .desktopcategory-img{display:none!important;}
    .mobilecategory-img{display:block!important;}
  }

  .categories-section .page-width{
    max-width: 1920px !important;
    width: 96% !important;
    margin: 0 auto !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }
  .categories-section{text-align:center;margin:0;padding-top:0px;padding-bottom:0;}
  .categories-section h2{margin:0;font-weight:500;font-size:24px;line-height:150%;text-align:center;vertical-align:middle;text-transform:uppercase;color:#1a1a1a;}
  .categories-section p{margin-top:0;font-size:18px;color:#666;margin-bottom:0;line-height:34px;}
  .categories-grid{display:flex;justify-content:center;gap:20px;margin-top:40px;}
  .category-card{width:16.5%;position:relative;}
  .category-card a{display:block;position:relative;}
  .category-card img{width:100%;height:auto;transition:transform .5s ease,border-radius .5s ease;display:block;border-radius: 0; }
  .category-title,.shop-now-text{position:absolute;left:50%;transform:translateX(-50%);color:black ;font-weight:500;z-index:2;letter-spacing:.9px;text-transform:uppercase;}
  .category-title{bottom:6%;font-size:16px;transition:bottom .4s ease,font-size .4s ease; color:#1a1a1a;}
  .shop-now-text{position:absolute;bottom:3%;left:50%;transform:translateX(-50%);font-size:10px;color:black;opacity:0;transition:bottom .4s ease,opacity .4s ease;text-transform:uppercase;}
  .category-card:hover .shop-now-text{opacity:1;bottom:8%;}
  .home-shop-the-look{margin-top:0!important;}
  .page-video_call_pdp-template-page .categories-section {padding-top: 30px !important;}
  @media(min-width:768px){
  .category-card:hover img{border-radius:100%/60%;}
  .category-card:hover .shop-now-text{opacity:1;}
  .category-card:hover .category-title{bottom:14%;font-size:16px;color:#1a1a1a;}
  }
  @media(max-width:999px) and (min-width:768px){
  .categories-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
  .category-card{width:100%;}
  }
   {% comment %} @media(max-width:410px) and (min-width:0px){
  .categories-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:6px;p}
  .category-card{width:100%;}
  } {% endcomment %}
  @media(max-width:767px){
  .categories-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:6px;}
  .category-card{width:100%;}
  .category-card img{ height: auto;width: 100%;object-fit:cover;aspect-ratio: 1 / 1.4;}
  .category-title { bottom: 15%; font-size: 14px; transform: translate(-50%, 50%); text-align: center; color: #1a1a1a; }
  .shop-now-text{display:none;}
  .categories-section h2{font-size:18px;}
  .categories-section p{font-size:12px; line-height:2;}
  .categories-grid{margin-top:24px;}
  .categories-section{text-align:center;margin:0;padding-top:40px;padding-bottom:0;}
  }
  @media only screen and (min-width:1024px) and (max-width:1600px){
    .categories-section {padding-top: 60px; padding-bottom: 30px;}
  }
  @media only screen and (min-width:1600px) and (max-width:2700px){
  .categories-section{padding-bottom:0;margin:0 auto;}
  .categories-section h2{font-size:28px;}
  .categories-section p{font-size:18px;}
  .categories-section {padding-top: 60px; padding-bottom: 30px;}
  }
</style>
