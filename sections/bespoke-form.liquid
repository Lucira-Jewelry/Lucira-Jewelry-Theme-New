

<style>
.bespoke-form-section-{{ section.id }} { background-color: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; } .bespoke-form-container { max-width: {{ section.settings.container_width }}px; margin: 0 auto; padding: 0 20px; } .bespoke-form-header { text-align: center; margin-bottom: 40px; } .bespoke-form-header h2 { font-size: {{ section.settings.heading_size }}px; color: {{ section.settings.heading_color }}; font-weight: {{ section.settings.heading_weight }}; line-height:1.8; margin: 0; text-transform: {{ section.settings.heading_transform }}; letter-spacing: {{ section.settings.heading_letter_spacing }}px; } .bespoke-form-header p { font-size: {{ section.settings.subheading_size }}px; color: {{ section.settings.subheading_color }}; margin: 0; line-height: 1.5; } .bespoke-successful-message { background-color: #d4edda; border: 1px solid #c3e6cb; color: #155724; padding: 15px 20px; border-radius: 6px; margin-bottom: 20px; font-size: 14px; } .bespoke-form .errors { background-color: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; padding: 15px 20px; border-radius: 6px; margin-bottom: 20px; font-size: 14px; } .bespoke-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; } .bespoke-form-group { margin-bottom: 20px; } .bespoke-form-group label { display: block; font-size: {{ section.settings.label_size }}px; color: {{ section.settings.label_color }}; font-weight: {{ section.settings.label_weight }}; margin-bottom: 8px; } .bespoke-form-group input[type="text"], .bespoke-form-group input[type="tel"], .bespoke-form-group textarea { width: 100%; padding: {{ section.settings.input_padding_v }}px {{ section.settings.input_padding_h }}px; font-size: {{ section.settings.input_size }}px; color: {{ section.settings.input_color }}; background: {{ section.settings.input_background }}; border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }}; border-radius: {{ section.settings.input_border_radius }}px; outline: none; transition: border-color 0.3s ease; font-family: inherit; } .bespoke-form-group input::placeholder, .bespoke-form-group textarea::placeholder { color: {{ section.settings.placeholder_color }}; } .bespoke-form-group input:focus, .bespoke-form-group textarea:focus { border-color: {{ section.settings.input_focus_border_color }}; } .bespoke-form-group textarea { min-height: 200px; resize: vertical; } .bespoke-submit-button { text-align: center; margin-top: 30px; } .bespoke-submit-button button { padding: {{ section.settings.button_padding_v }}px {{ section.settings.button_padding_h }}px; font-size: {{ section.settings.button_size }}px; font-weight: {{ section.settings.button_weight }}; color: {{ section.settings.button_text_color }}; background: {{ section.settings.button_background }}; border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }}; border-radius: {{ section.settings.button_border_radius }}px; cursor: pointer; transition: all 0.3s ease; text-transform: {{ section.settings.button_transform }}; letter-spacing: {{ section.settings.button_letter_spacing }}px; min-width: 200px; font-family: inherit; } .bespoke-submit-button button:hover { color: {{ section.settings.button_hover_text_color }}; background: {{ section.settings.button_hover_background }}; border-color: {{ section.settings.button_hover_border_color }}; transform: translateY(-2px); }

@media (max-width: 768px) { .bespoke-form-section-{{ section.id }} { padding: {{ section.settings.padding_top_mobile }}px 0 {{ section.settings.padding_bottom_mobile }}px; } .bespoke-form-header h2 { font-size: {{ section.settings.heading_size_mobile }}px; margin-bottom:6px; } .bespoke-form-header p { font-size: {{ section.settings.subheading_size_mobile }}px; } .bespoke-form-row { grid-template-columns: 1fr; gap: 0; } .bespoke-form-group label { font-size: {{ section.settings.label_size_mobile }}px; } .bespoke-form-group input[type="text"], .bespoke-form-group input[type="tel"], .bespoke-form-group textarea { font-size: {{ section.settings.input_size_mobile }}px; } .bespoke-submit-button button { font-size: {{ section.settings.button_size_mobile }}px; padding: {{ section.settings.button_padding_v_mobile }}px {{ section.settings.button_padding_h_mobile }}px;min-width:150px; } }
</style>

<section class="bespoke-form-section-{{ section.id }}">
  <div class="bespoke-form-container">
    {% if section.settings.show_header %}
      <div class="bespoke-form-header">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="bespoke-form-wrapper">
      {% form 'contact', class: 'bespoke-form' %}
        {%- if form.posted_successfully? -%}
          <div class="bespoke-successful-message">
            {{ section.settings.success_message }}
          </div>  
        {% endif %}
        
        {% comment %} Custom error handling without email validation {% endcomment %}
        {%- if form.errors -%}
          <div class="bespoke-form-errors errors">
            <ul>
              {%- for field in form.errors -%}
                {%- if field == 'form' -%}
                  <li>{{ form.errors.messages[field] }}</li>
                {%- else -%}
                  {% comment %} Skip email validation errors {% endcomment %}
                  {%- unless field == 'email' -%}
                    <li>
                      {%- capture field_label -%}
                        {%- case field -%}
                          {%- when 'full_name' -%}
                            {{ section.settings.name_label }}
                          {%- when 'phone_number' -%}
                            {{ section.settings.phone_label }}
                          {%- when 'comments' -%}
                            {{ section.settings.comments_label }}
                          {%- else -%}
                            {{ field | capitalize }}
                        {%- endcase -%}
                      {%- endcapture -%}
                      <strong>{{ field_label }}:</strong> {{ form.errors.messages[field] }}
                    </li>
                  {%- endunless -%}
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        <div class="bespoke-form-row">
          <div class="bespoke-form-col">
            <div class="bespoke-form-group">
              <label for="bespoke-full_name">
                {{ section.settings.name_label }}
                {% if section.settings.name_required %}*{% endif %}
              </label>
              <input 
                id="bespoke-full_name" 
                type="text" 
                name="contact[full_name]" 
                placeholder="{{ section.settings.name_placeholder }}"
                {% if section.settings.name_required %}required{% endif %}
                oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '');"
                pattern="[A-Za-z\s]+"
                maxlength="50"
                {% if form.errors contains 'full_name' %}aria-invalid="true"{% endif %}
              >
            </div>
          </div>

          <div class="bespoke-form-col">
            <div class="bespoke-form-group">
              <label for="bespoke-phone_number">
                {{ section.settings.phone_label }}
                {% if section.settings.phone_required %}*{% endif %}
              </label>
              <input 
                id="bespoke-phone_number" 
                type="tel" 
                name="contact[phone_number]" 
                placeholder="{{ section.settings.phone_placeholder }}"
                {% if section.settings.phone_required %}required{% endif %}
                maxlength="10"
                inputmode="numeric"
                pattern="[0-9]{0,13}"
                oninput="this.value = this.value.replace(/[^0-9]/g, '');"
                {% if form.errors contains 'phone_number' %}aria-invalid="true"{% endif %}
              >
            </div>
          </div>
        </div>

        <div class="bespoke-form-group">
          <label for="bespoke-comments">
            {{ section.settings.comments_label }}
            {% if section.settings.comments_required %}*{% endif %}
          </label>
          <textarea 
            id="bespoke-comments" 
            name="contact[comments]"
            placeholder="{{ section.settings.comments_placeholder }}"
            {% if section.settings.comments_required %}required{% endif %}
            {% if form.errors contains 'comments' %}aria-invalid="true"{% endif %}
          ></textarea>
        </div>

        {% comment %} Hidden email field with dummy value to bypass validation {% endcomment %}
        <input type="hidden" name="contact[email]" value="no-email@example.com">

        <div class="bespoke-submit-button">
          <button type="submit">{{ section.settings.button_text }}</button>
        </div>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bespoke Design Form",
  "settings": [
    {
      "type": "header",
      "content": "Form Header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show header",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We'd love to hear from you. Send us a message and we'll respond as soon as possible."
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size (desktop)",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading size (mobile)",
      "default": 28
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Heading letter spacing",
      "default": 0
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading size (desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "subheading_size_mobile",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Subheading size (mobile)",
      "default": 14
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Form Fields"
    },
    {
      "type": "text",
      "id": "name_label",
      "label": "Name field label",
      "default": "Name"
    },
    {
      "type": "text",
      "id": "name_placeholder",
      "label": "Name field placeholder",
      "default": "Enter Full Name"
    },
    {
      "type": "checkbox",
      "id": "name_required",
      "label": "Name required",
      "default": true
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone field label",
      "default": "Contact"
    },
    {
      "type": "text",
      "id": "phone_placeholder",
      "label": "Phone field placeholder",
      "default": "Enter Mobile Number"
    },
    {
      "type": "checkbox",
      "id": "phone_required",
      "label": "Phone required",
      "default": true
    },
    {
      "type": "text",
      "id": "comments_label",
      "label": "Comments field label",
      "default": "Comment"
    },
    {
      "type": "text",
      "id": "comments_placeholder",
      "label": "Comments field placeholder",
      "default": "Comment"
    },
    {
      "type": "checkbox",
      "id": "comments_required",
      "label": "Comments required",
      "default": false
    },
    {
      "type": "header",
      "content": "Form Styling"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Container max width",
      "default": 800
    },
    {
      "type": "header",
      "content": "Label Styling"
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Label size (desktop)",
      "default": 14
    },
    {
      "type": "range",
      "id": "label_size_mobile",
      "min": 12,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Label size (mobile)",
      "default": 13
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#333333"
    },
    {
      "type": "select",
      "id": "label_weight",
      "label": "Label weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" }
      ],
      "default": "500"
    },
    {
      "type": "header",
      "content": "Input Styling"
    },
    {
      "type": "range",
      "id": "input_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Input size (desktop)",
      "default": 14
    },
    {
      "type": "range",
      "id": "input_size_mobile",
