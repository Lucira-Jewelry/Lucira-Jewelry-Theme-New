{% schema %}
{
  "name": "Timeline Section",
  "tag": "section",
  "class": "timeline-section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Our Journey"
    }
  ],
  "blocks": [
    {
      "type": "timeline_item",
      "name": "Timeline Item",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "2024"
        },
        {
          "type": "image_picker",
          "id": "timeline_image",
          "label": "Timeline Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "LOREM IPSUM"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad m"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline",
      "blocks": [
        {
          "type": "timeline_item"
        },
        {
          "type": "timeline_item"
        },
        {
          "type": "timeline_item"
        },
        {
          "type": "timeline_item"
        }
      ]
    }
  ]
}
{% endschema %}

<section class="timeline-section">
  <div class="container">
    {% if section.settings.section_title != blank %}
      <h2 class="timeline-heading">{{ section.settings.section_title }}</h2>
    {% endif %}

    <div class="timeline-wrapper">
      <!-- Horizontal Timeline Line -->
      <div class="timeline-line"></div>

      <!-- Timeline items -->
      <div class="timeline-items">
        {% for block in section.blocks %}
          <div class="timeline-item" {{ block.shopify_attributes }}>
            <!-- Year above the marker -->
            <div class="timeline-year">{{ block.settings.year }}</div>

            <!-- Diamond marker with image -->
            <div class="timeline-marker">
              {% if block.settings.timeline_image != blank %}
                <img
                  src="{{ block.settings.timeline_image | image_url: width: 80, height: 80 }}"
                  alt="{{ block.settings.title }}"
                  title="{{ block.settings.title }}"
                  class="timeline-image"
                >
              {% else %}
                <div class="timeline-placeholder">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2L2 12L12 22L22 12L12 2Z" fill="#B8957A" stroke="#B8957A" stroke-width="2"/>
                  </svg>
                </div>
              {% endif %}
            </div>

            <!-- Content below the marker -->
            <div class="timeline-content">
              <h3 class="timeline-title">{{ block.settings.title }}</h3>
              <p class="timeline-description">{{ block.settings.description }}</p>
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Navigation arrows for mobile -->
      <div class="timeline-nav-prev">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M15 18L9 12L15 6" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="timeline-nav-next">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M9 18L15 12L9 6" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    let timelineSwiper = null;

    function initSwiper() {
      // Only initialize on mobile (768px or less)
      if (window.innerWidth <= 768) {
        if (!timelineSwiper) {
          const wrapper = document.querySelector('.timeline-wrapper');
          const items = document.querySelector('.timeline-items');
          const slides = document.querySelectorAll('.timeline-item');

          // Add Swiper classes for mobile
          items.classList.add('swiper-wrapper');
          slides.forEach((slide) => slide.classList.add('swiper-slide'));

          timelineSwiper = new Swiper(wrapper, {
            slidesPerView: 1,
            spaceBetween: 0,
            centeredSlides: true,
            navigation: {
              nextEl: '.timeline-nav-next',
              prevEl: '.timeline-nav-prev',
            },
          });
        }
      } else {
        // Destroy slider on desktop
        if (timelineSwiper) {
          const items = document.querySelector('.timeline-items');
          const slides = document.querySelectorAll('.timeline-item');

          timelineSwiper.destroy(true, true);
          timelineSwiper = null;

          // Remove Swiper classes on desktop
          items.classList.remove('swiper-wrapper');
          slides.forEach((slide) => slide.classList.remove('swiper-slide'));
        }
      }
    }

    initSwiper();

    window.addEventListener('resize', function () {
      initSwiper();
    });
  });
</script>

<style>
 .timeline-section{background:#fff;padding:20px 0;font-family:'Futura Std',Arial,sans-serif;overflow:hidden}
.timeline-nav-next,.timeline-nav-prev{display:none;position:absolute;top:100%;transform:translateY(-50%);width:40px;height:40px;background:#fff;border:1px solid #ddd;border-radius:50%;cursor:pointer;z-index:1;align-items:center;justify-content:center;transition:all .3s ease}
.timeline-nav-prev{left:110px}
.timeline-nav-next{right:110px}
.container{max-width:100%;margin:0 auto;position:relative}
.timeline-heading{font-family:'Futura Std',sans-serif;font-size:36px;font-weight:300;text-align:center;margin-bottom:80px;color:#000;text-transform:uppercase;letter-spacing:.1em}
.timeline-wrapper{position:relative;width:100%;padding:15px 0;overflow-x:auto;overflow-y:visible;min-height:300px}
.timeline-line{position:absolute;top:50%;left:0;right:0;height:2px;width:100%;background:#b8957a;transform:translateY(-50%);z-index:1;pointer-events:none}
.timeline-wrapper::before{content:'';position:absolute;top:32.5%;left:0;right:0;height:2px;width:100%;background:#b8957a;transform:translateY(-50%);z-index:1}
.timeline-items{display:flex;justify-content:space-between;align-items:center;gap:40px;position:relative;z-index:2;min-width:fit-content;padding:0 20px}
.timeline-item{display:flex;flex-direction:column;align-items:center;flex:1;min-width:280px;max-width:320px;position:relative}
.timeline-year{font-family:'Futura Std',sans-serif;font-size:20px;font-weight:400;color:#000;margin-bottom:24px;text-align:center;letter-spacing:.04em;position:relative;z-index:3}
.timeline-marker{position:relative;z-index:3;display:flex;align-items:center;justify-content:center;width:80px;height:80px;margin-bottom:24px}
.timeline-image{width:80px;height:80px;object-fit:cover;border-radius:50%;background:#fff;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.1)}
.timeline-placeholder{width:80px;height:80px;background:#f5f5f5;border-radius:50%;display:flex;align-items:center;justify-content:center;border:2px solid #b8957a}
.timeline-content{text-align:center;max-width:280px;position:relative;z-index:3}
.timeline-title{font-family:'Futura Std',sans-serif;font-weight:500;font-size:18px;line-height:150%;letter-spacing:.04em;text-transform:uppercase;color:#000;margin:0 0 12px 0}
.timeline-description{font-family:'Futura Std',sans-serif;font-size:16px;font-weight:300;color:#666;line-height:1.6;margin:0;letter-spacing:.02em}
@media (max-width:1200px){
.timeline-items{gap:30px}
.timeline-item{min-width:240px;max-width:280px}
.timeline-nav-next,.timeline-nav-prev{z-index:1}
}
@media (max-width:968px){
.timeline-section{padding:60px 15px}
.timeline-wrapper{overflow-x:scroll;padding:40px 0}
.timeline-items{gap:20px;padding:0 10px}
.timeline-item{min-width:200px;max-width:240px}
.timeline-content{max-width:200px}
.timeline-nav-next,.timeline-nav-prev{z-index:1}
}
@media (max-width:768px){
.timeline-section{padding:50px 15px}
.timeline-nav-next,.timeline-nav-prev{z-index:1}
.timeline-heading{font-size:28px;margin-bottom:60px}
.timeline-wrapper{overflow:visible;padding:60px 0 80px 0!important}
.timeline-line{left:50%;right:auto;width:80%;height:2px;top:50%;transform:translate(-50%,-50%)}
.timeline-items{gap:0;justify-content:flex-start;min-width:auto;padding:0}
.timeline-nav-next,.timeline-nav-prev{display:flex;z-index:10}
.timeline-item{min-width:100%;max-width:100%;width:100%;padding:0 20px;box-sizing:border-box;flex:none}
.timeline-year{font-size:18px;margin-bottom:30px}
.timeline-marker{width:70px;height:70px;margin-bottom:25px}
.timeline-image,.timeline-placeholder{width:70px;height:70px}
.timeline-title{font-size:16px}
.timeline-description{font-size:13px;max-width:90%;margin:0 auto}
.timeline-content{max-width:100%;padding:0 10px}
}
@media (max-width:480px){
.timeline-section{padding:20px 0;height:auto}
.timeline-nav-next,.timeline-nav-prev{z-index:1}
.vision-block .text-card{right:0!important}
.mission-block .text-card{left:0!important}
.timeline-heading{font-size:24px;margin-bottom:40px}
.timeline-wrapper{padding:40px 0 80px 0}
.timeline-year{font-size:16px;margin-bottom:16px}
.timeline-marker{width:60px;height:60px;margin-bottom:16px}
.timeline-image,.timeline-placeholder{width:60px;height:60px}
.timeline-title{font-size:14px;margin-bottom:8px}
.timeline-description{font-size:14px;max-width:85%;margin:0 auto}
.timeline-item{padding:0 15px}
.timeline-content{padding:0 5px}
}
@media (max-width:480px){
.timeline-wrapper::before{content:'';position:absolute;top:40.5%;left:0;right:0;height:2px;width:100%;background:#b8957a;transform:translateY(-50%);z-index:1}
}
</style>
