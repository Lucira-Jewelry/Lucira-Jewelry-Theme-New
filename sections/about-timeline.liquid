{% schema %}
{
  "name": "Timeline Section",
  "tag": "section",
  "class": "timeline-section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Our Journey"
    }
  ],
  "blocks": [
    {
      "type": "timeline_item",
      "name": "Timeline Item",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "2024"
        },
        {
          "type": "image_picker",
          "id": "timeline_image",
          "label": "Timeline Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "LOREM IPSUM"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad m"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline",
      "blocks": [
        {
          "type": "timeline_item"
        },
        {
          "type": "timeline_item"
        },
        {
          "type": "timeline_item"
        },
        {
          "type": "timeline_item"
        }
      ]
    }
  ]
}
{% endschema %}

<section class="timeline-section">
  <div class="container">
    {% if section.settings.section_title != blank %}
      <h2 class="timeline-heading">{{ section.settings.section_title }}</h2>
    {% endif %}

    <slider-component class="timeline-wrapper">
      <!-- Horizontal Timeline Line -->
      <div class="timeline-line"></div>

      <!-- Timeline items -->
      <ul id="Slider-{{ section.id }}" class="timeline-items slider slider--everywhere">
        {% for block in section.blocks %}
          <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="timeline-item slider__slide" {{ block.shopify_attributes }}>
            <!-- Year above the marker -->
            <div class="timeline-year">{{ block.settings.year }}</div>

            <!-- Diamond marker with image -->
            <div class="timeline-marker">
              {% if block.settings.timeline_image != blank %}
                <img src="{{ block.settings.timeline_image | image_url: width: 80, height: 80 }}"
                    alt="{{ block.settings.title }}"
                     title="{{ block.settings.title }}"
                    class="timeline-image"
                    loading="lazy">
              {% else %}
                <div class="timeline-placeholder">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2L2 12L12 22L22 12L12 2Z" fill="#B8957A" stroke="#B8957A" stroke-width="2"/>
                  </svg>
                </div>
              {% endif %}
            </div>

            <!-- Content below the marker -->
            <div class="timeline-content">
              <h3 class="timeline-title">{{ block.settings.title }}</h3>
              <p class="timeline-description">{{ block.settings.description }}</p>
            </div>
          </li>
        {% endfor %}
      </ul>

      <div class="slider-buttons no-js-hidden small-hide">
        <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
          <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
        </button>
        <div class="slider-counter caption">
          <span class="slider-counter--current">1</span>
          <span aria-hidden="true"> / </span>
          <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
          <span class="slider-counter--total">{{ section.blocks.size }}</span>
        </div>
        <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
          <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
        </button>
      </div>
    </slider-component>
  </div>
</section>

<style>
.timeline-section {
  background: #ffffff;
  padding: 20px 0px;
  font-family: 'Futura Std', 'Arial', sans-serif;
  overflow: hidden;
}

.timeline-nav-prev,
.timeline-nav-next {
  display: none;
}

.container {
  max-width: 100%;
  margin: 0 auto;
  position: relative;
}

.timeline-heading {
  font-family: 'Futura Std', sans-serif;
  font-size: 36px;
  font-weight: 300;
  text-align: center;
  margin-bottom: 80px;
  color: #000;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.timeline-wrapper {
  position: relative;
  width: 100%;
  padding: 15px 0;
  min-height: 300px;
}

.timeline-line {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 2px;
  width: 100%;
  background: #B8957A;
  transform: translateY(-50%);
  z-index: 1;
  pointer-events: none;
}

.timeline-wrapper::before {
  content: '';
  position: absolute;
  top: 32.5%;
  left: 0;
  right: 0;
  height: 2px;
  width: 100%;
  background: #B8957A;
  transform: translateY(-50%);
  z-index: 1;
}

.timeline-items {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 40px;
  position: relative;
  z-index: 2;
  min-width: fit-content;
  padding: 0 20px;
  list-style: none;
  margin: 0;
}

.timeline-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  min-width: 280px;
  max-width: 320px;
  position: relative;
}

.timeline-year {
  font-family: 'Futura Std', sans-serif;
  font-size: 20px;
  font-weight: 400;
  color: #000;
  margin-bottom: 24px;
  text-align: center;
  letter-spacing: 0.04em;
  position: relative;
  z-index: 3;
}

.timeline-marker {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80px;
  height: 80px;
  margin-bottom: 24px;
}

.timeline-image {
  width: 80px;
  height: 80px;
  object-fit: cover;
  border-radius: 50%;
  background: #fff;
  border: 3px solid #fff;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.timeline-placeholder {
  width: 80px;
  height: 80px;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid #B8957A;
}

.timeline-content {
  text-align: center;
  max-width: 280px;
  position: relative;
  z-index: 3;
}

.timeline-title {
  font-family: 'Futura Std', sans-serif;
  font-weight: 500;
  font-size: 18px;
  line-height: 150%;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #000;
  margin: 0 0 12px 0;
}

.timeline-description {
  font-family: 'Futura Std', sans-serif;
  font-size: 16px;
  font-weight: 300;
  color: #666;
  line-height: 1.6;
  margin: 0;
  letter-spacing: 0.02em;
}

@media (max-width: 768px) {
  .timeline-items {
    justify-content: flex-start;
    min-width: auto;
    padding: 0;
    gap: 0;
  }

  .timeline-item {
    min-width: 100%;
    max-width: 100%;
    width: 100%;
    padding: 0 20px;
    box-sizing: border-box;
    flex: none;
  }

  .timeline-line {
    left: 50%;
    right: auto;
    width: 80%;
    height: 2px;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .timeline-wrapper::before {
    top: 40.5%;
  }
}
</style>