{% if section.settings.show_on_homepage == false or template == 'index' %}
  <section class="information-content-section">
    <div class="{% if section.settings.full_width %}page-width-full{% else %}page-width{% endif %}"      {% if section.settings.section_id != blank %}id="{{ section.settings.section_id | handleize }}"{% endif %}>
      <div class="address-locations-footer">
        <h3>{{ block.settings.stores_heading }}</h3>
        <div class="grid-row">
          {% for block in section.blocks %}
            {% if block.type == 'store_location' %}
              <div class="grid-column">
                <div class="store-location-item">
                  <h4 class="store-heading">{{ block.settings.store_name }}</h4>
                  <ul>
                    <li>{{ 'icon-phone.svg' | inline_asset_content }} <a href="tel:{{ block.settings.phone }}"><span>{{ block.settings.phone }}</span></a></li>
                    <li>{{ 'icon-email.svg' | inline_asset_content }} <a href="mailto:{{ block.settings.email }}"><span>{{ block.settings.email }}</span></a></li>
                    <li>{{ 'icon-address.svg' | inline_asset_content }} <a href="{{ block.settings.map_url }}" target="_blank"><span>{{ block.settings.address }}</span></a></li>
                  </ul>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div class="information-content-wrapper">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'heading' %}
              {% assign tag = block.settings.heading_level | default: 'h2' %}
              {% if block.settings.text %}
                <{{ tag }}
                  class="information-content-heading text-{{ block.settings.alignment }}"
                  {% if block.settings.heading_id != blank %}
                    id="{{ block.settings.heading_id | escape }}"
                  {% endif %}
                >
                  {{ block.settings.text }}
                </{{ tag }}>
              {% endif %}
  
            {% when 'richtext' %}
              {% if block.settings.content %}
                <div class="information-content-richtext">
                  {{ block.settings.content }}
                </div>
              {% endif %}
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}
  
{% schema %}
  {
    "name": "Information Content",
    "tag": "section",
    "class": "gold-rate-section",
    "settings": [
      {
        "type": "checkbox",
        "id": "full_width",
        "label": "Enable Full Width",
        "default": false,
        "info": "Make the section span the full width of the screen"
      },
      {
        "type": "text",
        "id": "section_id",
        "label": "Section ID (optional)",
        "info": "Add a custom ID for anchor links (e.g., about-us)"
      },
      {
        "type": "checkbox",
        "id": "show_on_homepage",
        "label": "Show on homepage only",
        "default": false,
        "info": "When enabled, this section will only appear on the homepage"
      },
      {
        "type": "text",
        "id": "stores_heading",
        "label": "Stores Section Heading",
        "default": "Lucira's Experience Stores"
      }
    ],
    "blocks": [
      {
        "type": "heading",
        "name": "Heading Block",
        "limit": 10,
        "settings": [
          {
            "type": "text",
            "id": "text",
            "label": "Heading Text",
            "default": "Sample Heading"
          },
          {
            "type": "select",
            "id": "heading_level",
            "label": "Heading Level",
            "default": "h2",
            "options": [
              { "value": "h1", "label": "H1" },
              { "value": "h2", "label": "H2" },
              { "value": "h3", "label": "H3" },
              { "value": "h4", "label": "H4" },
              { "value": "h5", "label": "H5" },
              { "value": "h6", "label": "H6" }
            ]
          },
          {
            "type": "text",
            "id": "heading_id",
            "label": "Heading ID (for anchor links)"
          },
          {
            "type": "select",
            "id": "alignment",
            "label": "Text Alignment",
            "default": "left",
            "options": [
              { "value": "left", "label": "Left" },
              { "value": "center", "label": "Center" },
              { "value": "right", "label": "Right" }
            ]
          }
        ]
      },
      {
        "type": "richtext",
        "name": "Rich Text Block",
        "limit": 20,
        "settings": [
          {
            "type": "richtext",
            "id": "content",
            "label": "Content"
          }
        ]
      },
      {
        "type": "store_location",
        "name": "Store Location",
        "settings": [
          {
            "type": "text",
            "id": "store_name",
            "label": "Store Name",
            "default": "Chembur Store"
          },
          {
            "type": "text",
            "id": "phone",
            "label": "Phone Number",
            "default": "+91 8433667236"
          },
          {
            "type": "text",
            "id": "email",
            "label": "Email Address",
            "default": "lcspnqjmr@lucirajewelry.com"
          },
          {
            "type": "textarea",
            "id": "address",
            "label": "Store Address",
            "default": "Shop no. 3,4, Balgandharv Chowk, Sai Square, 5 & 6, Jangali Maharaj Rd, Pune, Maharashtra - 411005"
          },
          {
            "type": "url",
            "id": "map_url",
            "label": "Google Maps URL",
            "info": "Paste the full Google Maps link for this store"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Information Content",
        "category": "Custom",
        "blocks": [
          { "type": "heading" },
          { "type": "richtext" }
        ]
      }
    ]
  }
{% endschema %}