{% if customer %}
  <script>
    window.location.href = "/account";
  </script>
{% endif %}
<style>
  .otp-login-form-wrapper .close-button {
    display: none;
  }
</style>
<script>
  document.addEventListener('DOMContentLoaded', function () {

    if (window.location.pathname === '/account/register') {

      const shopifyRegister = document.querySelector('.template-customers-register');
      if (shopifyRegister) {
        shopifyRegister.style.display = 'none';
      }

      const popup = document.getElementById('login-popup');
      if (!popup) return;

      popup.style.display = 'flex';
      document.body.classList.add('overflow-hidden');

      resetToLoginView();

      const wheelWrapper = document.querySelector('.spin-wheel-wrapper');
      if (wheelWrapper) {
        wheelWrapper.style.display = 'flex';
        wheelWrapper.style.visibility = 'visible';
      }

      const wrapper = document.querySelector('.otp-login-form-wrapper');
      if (wrapper) {
        wrapper.classList.add('signup-active');
      }

      const heading = popup.querySelector('.otp-number-wrapper p.heading');
      const subtext = popup.querySelector('.otp-number-wrapper p:not(.heading)');

      if (heading) heading.innerText = 'Spin & Register to Win';
      if (subtext) subtext.innerText = 'Try Your Luck! Win a Diamond Pendant';

    }
  });
</script>




{% schema %}
{
  "name": "t:sections.main-register.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
