{% comment %} <div class="custom-collection-grid-section">
  <div class="custom-collection-scroll-container">
    <div class="custom-collection-grid-wrapper">
      {% for block in section.blocks %}
        <div class="custom-slider-item" {{ block.shopify_attributes }}>
          {% if block.settings.collection_link != blank %}
            <a href="{{ block.settings.collection_link }}" class="custom-collection-link">
          {% endif %}

          <div class="custom-collection-image-wrapper">
            {% if block.settings.collection_image != blank %}
              <img
                src="{{ block.settings.collection_image | img_url: '300x300', crop: 'center' }}"
                alt="{{ block.settings.collection_name | escape }}"
                loading="lazy"
                class="custom-collection-image"
                width="150"
                height="150"
              >
            {% else %}
              <div class="custom-collection-placeholder">
                {{ 'image' | placeholder_svg_tag: 'custom-placeholder-svg' }}
              </div>
            {% endif %}
          </div>

          <p class="custom-collection-name">{{ block.settings.collection_name }}</p>

          {% if block.settings.collection_link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <!-- Navigation buttons -->
    <button class="scroll-button scroll-button-prev" aria-label="Scroll left">
      <span>←</span>
    </button>
    <button class="scroll-button scroll-button-next" aria-label="Scroll right">
      <span>→</span>
    </button>
  </div>
</div>

<style>
  .custom-collection-grid-section {
    display: none;
  }

  @media (max-width: 768px) {
    .custom-collection-grid-section {
      display: block;
      padding: 0px 1px 8px 10px;
      margin: 0 auto;
      position: relative;
    }

    .custom-collection-scroll-container {
      width: 100%;
      position: relative;
      overflow: hidden;
    }

    .custom-slider-item:last-child {
      margin-right:12px;
    }
    .custom-collection-grid-wrapper {
      display: flex;
      overflow-x: scroll;
      overflow-y: hidden;
      scroll-behavior: smooth;
      gap: 14px;
      align-items: center;
      padding: 10px 5px;

      /* Hide scrollbar */
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none; /* IE/Edge */

      /* Momentum scrolling for iOS */
      -webkit-overflow-scrolling: touch;
    }

    /* Hide scrollbar for Chrome/Safari */
    .custom-collection-grid-wrapper::-webkit-scrollbar {
      display: none;
    }

    .custom-slider-item {
      text-align: center;
      width: 100px;
      min-width: 100px;
      flex-shrink: 0;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      -webkit-tap-highlight-color: transparent;
    }

    .custom-collection-link {
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      gap: 2px;
      transition: opacity 0.3s ease;
      -webkit-tap-highlight-color: transparent;
      -webkit-touch-callout: none;
      -webkit-user-select: none;
      -moz-user-select: none;
      -ms-user-select: none;
      user-select: none;
    }

    .custom-collection-link:hover {
      opacity: 0.8;
    }

    .custom-collection-link:focus {
      outline: none;
    }

    .custom-collection-link:active {
      opacity: 0.8;
    }

    .custom-collection-image-wrapper {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      overflow: hidden;
      margin: 0 auto 8px;
      background-color: #f5f5f5;
    }

    .custom-collection-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .custom-collection-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #e0e0e0;
    }

    .custom-placeholder-svg {
      width: 50%;
      height: 50%;
      fill: #999;
    }

    .custom-collection-name {
      font-size: 12px;
      font-weight: 400;
      text-transform: uppercase;
      color: #333333;
      margin: 0;
      letter-spacing: 0.5px;
      line-height: 1.2;
    }

    /* Navigation Buttons */
    .scroll-button {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 30px;
      height: 30px;
      background: #ffffff;
      border: none;
      border-radius: 50%;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
      cursor: pointer;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.3s ease, background-color 0.3s ease;
      -webkit-tap-highlight-color: transparent;
      outline: none;
    }

    .scroll-button:hover {
      background-color: #f5f5f5;
    }

    .scroll-button:focus {
      outline: none;
    }

    .scroll-button:active {
      transform: translateY(-50%) scale(0.95);
    }

    .scroll-button.hidden {
      opacity: 0;
      pointer-events: none;
    }

    .scroll-button span {
      font-size: 14px;
      font-weight: bold;
      color: #333333;
      line-height: 1;
    }

    .scroll-button-prev {
      left: 5px;
    }

    .scroll-button-next {
      right: 5px;
    }

    /* Optimize for smaller screens */
    @media (max-width: 480px) {
      .custom-slider-item {
        width: 100px;
        min-width: 100px;
      }

      {% comment %} .custom-collection-image-wrapper {
        width: 80px;
        height: 80px;
      }
       {% endcomment %}
      .custom-collection-name {
        font-size: 10px;
      }

      .scroll-button {
        display: none;
      }
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {

    // GTM Tracking - Fire promoClick event
    function firePromoClick(collectionItem) {
      const link = collectionItem.querySelector('.custom-collection-link');
      if (!link) return;

      const collectionName = collectionItem.querySelector('.custom-collection-name')?.innerText?.trim() || '';
      const collectionUrl = link.getAttribute('href') || '';

      if (!collectionName) return;

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'promoClick',
        promoClick: {
          creative_name: 'Homepage Mobile Collection Grid',
          promo_name: collectionName,
          location_id: collectionUrl,
        },
      });

      console.log('GTM promoClick fired for collection:', collectionName, collectionUrl);
    }

    
    // Bind click tracking with event delegation
    function bindCollectionClickTracking() {
      const container = document.querySelector('.custom-collection-grid-section');

      if (!container) {
        console.log('Collection grid container not found for tracking');
        return;
      }

      console.log('Binding collection click tracking to:', container);

      container.addEventListener(
        'click',
        function (e) {
          const collectionItem = e.target.closest('.custom-slider-item');
          if (!collectionItem) return;

          console.log('Collection item clicked, firing promo click');
          firePromoClick(collectionItem);
        },
        { capture: true }
      );
    }

    // Initialize tracking
    bindCollectionClickTracking();
  });
</script>


{% schema %}
{
  "name": "Collection Grid Carousel",
  "settings": [
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Grid gap",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "collection_image",
          "label": "Collection Image"
        },
        {
          "type": "text",
          "id": "collection_name",
          "label": "Collection Name",
          "default": "Collection"
        },
        {
          "type": "url",
          "id": "collection_link",
          "label": "Collection Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Grid Carousel",
      "blocks": [
        {
          "type": "collection_item",
          "settings": {
            "collection_name": "RINGS"
          }
        },
        {
          "type": "collection_item",
          "settings": {
            "collection_name": "EARRINGS"
          }
        },
        {
          "type": "collection_item",
          "settings": {
            "collection_name": "BRACELET"
          }
        },
        {
          "type": "collection_item",
          "settings": {
            "collection_name": "NECKLACE"
          }
        }
      ]
    }
  ]
}
{% endschema %} {% endcomment %}


{% comment %} Preload first 2 collection images for mobile LCP {% endcomment %}
{% if section.blocks.size > 0 %}
  {% for block in section.blocks limit: 2 %}
    {% if block.settings.collection_image != blank %}
      <link rel="preload" 
            as="image" 
            href="{{ block.settings.collection_image | img_url: '200x200', crop: 'center' }}"
            media="(max-width: 768px)"
            {% if forloop.first %}fetchpriority="high"{% endif %}>
    {% endif %}
  {% endfor %}
{% endif %}

<div class="custom-collection-grid-section">
  <div class="custom-collection-scroll-container">
    <div class="custom-collection-grid-wrapper" role="list">
      {% for block in section.blocks %}
        {% liquid
          assign is_priority = false
          if forloop.index <= 4
            assign is_priority = true
          endif
        %}
        
        <div class="custom-slider-item" 
             role="listitem"
             data-collection-name="{{ block.settings.collection_name | escape }}"
             data-collection-url="{{ block.settings.collection_link }}"
             {{ block.shopify_attributes }}>
          {% if block.settings.collection_link != blank %}
            <a href="{{ block.settings.collection_link }}" 
               class="custom-collection-link"
               aria-label="Shop {{ block.settings.collection_name }}">
          {% endif %}

          <div class="custom-collection-image-wrapper">
            {% if block.settings.collection_image != blank %}
              <img
                srcset="{{ block.settings.collection_image | img_url: '200x200', crop: 'center' }} 200w,
                        {{ block.settings.collection_image | img_url: '100x100', crop: 'center' }} 100w"
                sizes="100px"
                src="{{ block.settings.collection_image | img_url: '200x200', crop: 'center' }}"
                alt="{{ block.settings.collection_name | escape }}"
                loading="{% if is_priority %}eager{% else %}lazy{% endif %}"
                decoding="async"
                class="custom-collection-image"
                width="100"
                height="100"
                {% if is_priority %}fetchpriority="high"{% endif %}
              >
            {% else %}
              <div class="custom-collection-placeholder" role="img" aria-label="Collection placeholder">
                {{ 'image' | placeholder_svg_tag: 'custom-placeholder-svg' }}
              </div>
            {% endif %}
          </div>

          <p class="custom-collection-name">{{ block.settings.collection_name }}</p>

          {% if block.settings.collection_link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>

  </div>
</div>

<style>
  .custom-collection-grid-section {
    display: none;
  }

  @media (max-width: 768px) {
    .custom-collection-grid-section {
      display: block;
      padding: 0px 1px 8px 10px;
      margin: 0 auto;
