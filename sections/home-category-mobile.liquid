      font-size: 12px;
      font-weight: 400;
      text-transform: uppercase;
      color: #333333;
      margin: 0;
      letter-spacing: 0.5px;
      line-height: 1.2;
      word-break: break-word;
    }

    /* Navigation Buttons */
   

    /* Optimize for smaller screens */
    @media (max-width: 480px) {
      .custom-collection-name {
        font-size: 10px;
      }
    }
  }
</style>

<script>
  (function() {
    // Initialize on DOM ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCollectionCarousel);
    } else {
      initCollectionCarousel();
    }
    
    function initCollectionCarousel() {
      const section = document.querySelector('.custom-collection-grid-section');
      if (!section) return;
      
      const wrapper = section.querySelector('.custom-collection-grid-wrapper');
      
      // GTM Click Tracking
      section.addEventListener('click', function(e) {
        const item = e.target.closest('.custom-slider-item');
        if (!item) return;
        
        const collectionName = item.dataset.collectionName;
        const collectionUrl = item.dataset.collectionUrl;
        
        if (!collectionName) return;
        
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'promoClick',
          promoClick: {
            creative_name: 'Homepage Mobile Collection Grid',
            promo_name: collectionName,
            location_id: collectionUrl || '',
          }
        });
      }, { capture: true });
      

    }
  })();
</script>

