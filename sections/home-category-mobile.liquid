      overflow: hidden;
      margin: 0 auto;
      background-color: #f5f5f5;
      position: relative;
      aspect-ratio: 1 / 1;
    }

    .custom-collection-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .custom-collection-placeholder {
