{% schema %}
{
  "name": "Founder Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "founder_image",
      "label": "Founder Image (Transparent PNG Recommended)"
    },
    {
      "type": "image_picker",
      "id": "founder_signature",
      "label": "Founder Signature"
    },
    {
      "type": "text",
      "id": "founder_quote",
      "label": "Founder Quote",
      "default": "\"Jewelry runs in my blood—it's who I am. After building brands in India, I created Lucira to go beyond tradition and craft pieces that reflect elegance and meaning. For me, jewelry isn’t just adornment—it’s a celebration of moments, love, and legacy. Every piece we make is a promise.\""
    },
    {
      "type": "text",
      "id": "founder_name",
      "label": "Founder Name",
      "default": "Rupesh Jain"
    },
    {
      "type": "text",
      "id": "founder_designation",
      "label": "Founder Designation",
      "default": "Founder & CEO"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Know More"
    },
    {
      "type": "select",
      "id": "image_alignment",
      "label": "Image Alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Image on Left"
        },
        {
          "value": "right",
          "label": "Image on Right"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Founder Section",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
<h2 class="founder-title-meet">MEET OUR FOUNDER</h2>
<section class="founder-section page-width">
  <div class="founder-container {{ section.settings.image_alignment }}">
    <div class="founder-image">
      {% if section.settings.founder_image %}
        <img src="{{ section.settings.founder_image | image_url: width: 600 }}" width="400" height="525" alt="{{ section.settings.founder_name }}" loading="lazy">
      {% endif %}
    </div>
    <div class="founder-content">
      <p class="founder-quote">{{ section.settings.founder_quote }}</p>
      <span class="content-wrapper-founder">
        <p class="founder-name">{{ section.settings.founder_name | upcase }}</p>
        <p class="founder-designation">{{ section.settings.founder_designation }}</p>
      </span>

      {% if section.settings.button_link %}
        <a href="{{ section.settings.button_link }}" class="founder-button">{{ section.settings.button_text }}</a>
      {% endif %}
          <div class="founder-signature">
            <img src="{{ section.settings.founder_signature| image_url: width: 600 }}" title="{{ section.settings.founder_name }}"alt="{{ section.settings.founder_name }}" width="120px" height="150" loading="lazy">
          </div>

    </div>
  </div>
</section>

<style>
  .founder-title-meet{
    text-align: center;
    padding-top: 70px;
    padding-bottom: 30px;
    font-weight:500;
  }
  .founder-section {
    background: transparent;
    padding: 60px 5%;
    padding-top: 0px;
  }

  
  .founder-container {
    display: flex;
    align-items: center;
    border: 1px solid #1a1a1a;
    justify-content: center;
    margin: 0 auto;
    width: 100%;
    gap: 40px;
    position: relative;
    flex-wrap: wrap;
    border-radius: 12px;
  }

  .founder-container.right {
    flex-direction: row-reverse;
  }

  .founder-image{
    position: absolute;
    left: -42px;
    bottom: -98px;
    z-index: 1;
}

.founder-signature {
    position: absolute;
    bottom: -50px;
    right: 60px;
}
  
  .founder-image img {
    max-width: 320px;
    object-fit: contain;
    background: transparent;
    position: relative;
    max-width: 400px;
  }

  .founder-content {
    flex: 1;
    padding: 20px 30px;
    border-radius: 12px;
    padding-left:380px;
    position: relative;
    background: #fff; /* keep text readable even on colored background */
  }

  .founder-quote {
    font-size: 18px;
    font-weight: 300;
    line-height: 1.6;
    margin-bottom: 20px;
    font-style: italic;
  }

  .founder-name {
    font-weight: 400;
    font-size: 24px;
    margin-bottom: -8px;
  }

  .founder-designation {
    font-size: 12px;
    font-weight: 400;
    color: #666;
    margin-bottom: 20px;
    margin-top: 0px;
  }

  .founder-button {
    display: inline-block;
    padding: 8px 24px;
    border: 1px solid #b19797;
    border-radius: 20px;
    text-decoration: none;
    color: #b19797;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .founder-button:hover {
    background-color: #b19797;
    color: #fff;
  }

  @media (max-width: 768px) {
    .founder-signature{
    right: 0;
    }

    .founder-title-meet{
    padding-bottom: 10px;
    margin-top:0px;
    padding-top:0px;
    font-size:18px;
  }

        .founder-signature {
        position: absolute;
        right: 0;
        bottom: -45px;
    }
    .founder-name{
      font-size:18px;
      right: 0;
      bottom: -250px;
    }
    .founder-quote{
      font-size: 14px;
    }
    .founder-container {
      flex-direction: column !important;
      text-align: center;
      height: 520px;
    }

    .founder-image img {
      max-width: 250px;
      bottom: -254px;
    }
    .founder-image{
          bottom: 92px;
    }
    .founder-content {
      max-width: 100%;
      padding-left:20px;
      position: relative;
      text-align: left;
    }
    .content-wrapper-founder{
      position: absolute;
      right: 20px;
      
    }
    .founder-image img{
      z-index:1;
    }
  }
</style>
