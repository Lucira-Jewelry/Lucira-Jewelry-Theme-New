<div
  class="lazy-section"
  data-section-id="gifting-content"
>
  <!-- Skeleton / placeholder -->
  <div class="section-skeleton">
    Loading...
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const lazySections = document.querySelectorAll('.lazy-section');

  if (!('IntersectionObserver' in window)) {
    lazySections.forEach(loadSection);
    return;
  }

  const observer = new IntersectionObserver((entries, obs) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;

      const container = entry.target;
      loadSection(container);
      obs.unobserve(container);
    });
  }, {
    rootMargin: '200px'
  });

  lazySections.forEach(section => observer.observe(section));

  function loadSection(container) {
    const sectionId = container.dataset.sectionId;
    if (!sectionId || container.dataset.loaded) return;

    fetch(`/?section_id=${sectionId}`)
      .then(res => res.text())
      .then(html => {
        container.innerHTML = html;
        container.dataset.loaded = 'true';
      })
      .catch(err => {
        console.error('Section load failed:', sectionId, err);
      });
  }
});
</script>

