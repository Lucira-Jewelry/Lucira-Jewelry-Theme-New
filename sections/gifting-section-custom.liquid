{% schema %}
{
  "name": "Gifting Section Custom",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sliders that are Worth Sliding"
    },
    {
      "type": "image_picker",
      "id": "gift_image-1",
      "label": "Gift Image One (Desktop)"
    },
    {
      "type": "url",
      "id": "gift_link-1",
      "label": "Gift Link One"
    },
    {
      "type": "image_picker",
      "id": "gift_image-2",
      "label": "Gift Image Two (Desktop)"
    },
    {
      "type": "url",
      "id": "gift_link-2",
      "label": "Gift Link Two"
    },
    {
      "type": "image_picker",
      "id": "gift_image-3",
      "label": "Gift Image Three (Desktop)"
    },
    {
      "type": "url",
      "id": "gift_link-3",
      "label": "Gift Link Three"
    }
  ],
  "blocks": [
    {
      "type": "slider_block",
      "name": "Slider Block",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "slider_image",
          "label": "Slider Image (Desktop)"
        },
        {
          "type": "image_picker",
          "id": "slider_image_mobile",
          "label": "Slider Image (Mobile)"
        },
        {
          "type": "text",
          "id": "msg-forher",
          "label": "Title"
        },
        {
          "type": "url",
          "id": "url-img",
          "label": "URL Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gifting Section Custom",
      "blocks": [
        { "type": "slider_block" },
        { "type": "slider_block" },
        { "type": "slider_block" }
      ]
    }
  ]
}
{% endschema %}

<style>


h2.slidering-heading{font-family:Tangerine,cursive!important;font-size:60px;margin-top:50px;text-align:center}
@media (min-width:1600px){
h2.slidering-heading{font-size:80px}
}
@media (max-width:768px){
h2.slidering-heading{font-size: 34px; margin-top: 0;}
}
@media (min-width:400px) and (max-width:450px){
h2.slidering-heading{font-size:32px}
}
.slidering-section{padding:30px 0}
.slidering-section.page-width{margin-bottom:0!important}
.main-section-gift{display:flex;justify-content:space-between;gap:40px;width:100%}
@media(max-width:768px){
.main-section-gift{flex-direction:column;gap:20px}
}
.gift-section-both{width:50%;text-align:center;display:flex;flex-direction:column;justify-content:space-between;gap:10px}
.gift-box{display:flex;justify-content:space-around;gap:10px}
.gift-box img{width:175px;height:175px;object-fit:cover;display:block}
@media(min-width:768px){
.gift-box{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.gift-box img{width:100%;height:auto}
}
@media(max-width:768px){
  .gift-box{justify-content:center!important}
  .gift-box img{max-width:90%;height:auto}
  .gift-section-both{width:100%!important}
}
.custom-slider-container{width:50%;position:relative}
.custom-slider-wrapper{display:flex;transition:transform .5s ease-in-out;min-height:400px}
.custom-slider-item,.slider__slide{position:relative;border-radius:12px; list-style: none;}
.slider-image{width:100%;height:100%;aspect-ratio:3/2;object-fit:cover;border-radius:12px;display:block}
.slider-overlay{position:absolute;bottom:20px;left:30px;text-align:left;color:#fff;z-index:2}
.slider-overlay h3{font-size:16px;margin:0;text-transform:uppercase;color:#fff;letter-spacing:.5px}
.slider-btn{display:inline-block;padding:8px 18px;background:#fff;color:#000;border-radius:30px;text-decoration:none;font-weight:700;transition:all .3s ease}
.slider-btn:hover{background:#000;color:#fff}
.slider-arrow{position:absolute;top:93%;width:30px;height:30px;transform:translateY(-50%);background:#00000038;color:#fff;border:1px solid #fff;padding:0;cursor:pointer;font-size:12px;z-index:10;border-radius:100%; display: flex; align-items: center; justify-content: center;}
.slidering-section .prev-arrow{right:11.5%}
.slidering-section .next-arrow{right:5%}


@media(max-width:768px){
  .custom-slider-container,.custom-slider-wrapper{width:100%!important}
  .slidering-section .prev-arrow{left: 80%;padding:0; width:25px; height: 25px;}
  .slidering-section .next-arrow{right:5%;padding:0; width:25px; height: 25px;}
  .slider-overlay{bottom:13px!important}
  .slider-overlay h3{font-size:14px}
  .slidering-section {padding: 20px 0;}
  .slider-overlay {left: 16px;}
}
@media(max-width:370px){
  .slidering-section .prev-arrow {width: 22px; height: 22px;}
  .slidering-section .next-arrow {width: 22px; height: 22px;}
  .slidering-section .prev-arrow {left: 79%;}
  .slidering-section .next-arrow {right: 5%;}
  .slider-arrow {top: 89%;}
}
@media(min-width:1500px){
  .slider-overlay h3{font-size:24px}
  h2.slidering-heading { font-family: Tangerine, cursive !important; margin-top: 100px; margin-bottom: 0; text-align: center; }
}

.custom-slider-wrapper.slider--everywhere {
  display: flex;
  flex-wrap: inherit;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
}
</style>

<div class="slidering-section page-width">
  <div class="main-section-gift">
    <!-- Left: Gift Images -->
    <div class="gift-section-both">
      <h2 class="slidering-heading">{{ section.settings.heading }}</h2>
      <div class="gift-box">
        {% for i in (1..3) %}
        {% assign img_key = "gift_image-" | append: i %}
        {% assign link_key = "gift_link-" | append: i %}
        {% assign img = section.settings[img_key] %}
        {% assign link = section.settings[link_key] %}

        {% if img %}
            {% assign img_url = img | image_url: width: 270, height: 282 %}
            {% if link != blank %}
            <a href="{{ link }}" class="gift-link" data-gift="Gift {{ i }}">
                <img src="{{ img_url }}" width="270" height="282" alt="Gift Image {{ i }}" title="Gift Image {{ i }}" loading="lazy">
            </a>
            {% else %}
            <img src="{{ img_url }}" width="270" height="282" alt="Gift Image {{ i }}" title="Gift Image {{ i }}" loading="lazy">
            {% endif %}
        {% endif %}
        {% endfor %}
      </div>
    </div>

    <slider-component class="custom-slider-container">
      <ul id="Slider-{{ section.id }}" class="custom-slider-wrapper slider slider--everywhere">
        {% for block in section.blocks %}
          {% if block.type == 'slider_block' and block.settings.slider_image %}
            {% assign slider_img = block.settings.slider_image | image_url: width:600, height:400 %}
            <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="custom-slider-item slider__slide">
              <a href="{{ block.settings.url-img }}">
                <img src="{{ slider_img }}" width="600" height="400" alt="{{ block.settings.msg-forher }}" title="{{ block.settings.msg-forher }}" class="slider-image" loading="lazy">
                <div class="slider-overlay">
                  {% if block.settings.msg-forher %}<h3>{{ block.settings.msg-forher }}</h3>{% endif %}
                </div>
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      <button type="button" name="previous" class="slider-arrow prev-arrow slider-button">{{ 'icon-left-arrow-banner.svg' | inline_asset_content }}</button>
      <button type="button" name="next" class="slider-arrow next-arrow slider-button">{{ 'icon-right-arrow-banner.svg' | inline_asset_content }}</button>
    </slider-component>
  </div>
</div>

<script>
  window.addEventListener('DOMContentLoaded', () => {
    if (window.initGiftingTracking) window.initGiftingTracking();
  });
</script>