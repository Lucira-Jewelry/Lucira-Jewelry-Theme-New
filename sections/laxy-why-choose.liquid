<div
  class="lazy-section"
  data-section-handle="why-choose"
  data-section-id="{{ section.id }}"
>
  <!-- Skeleton -->
  <div class="wc-skeleton">
    {% for i in (1..4) %}
      <div class="wc-skeleton-card"></div>
    {% endfor %}
  </div>
</div>


<script>
document.addEventListener('DOMContentLoaded', () => {
  const lazySections = document.querySelectorAll('.lazy-section');

  const observer = new IntersectionObserver((entries, obs) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;

      const el = entry.target;
      const handle = el.dataset.sectionHandle;

      fetch(`/?sections=${handle}`)
        .then(res => res.json())
        .then(data => {
          el.innerHTML = data[handle];
          obs.unobserve(el);
        })
        .catch(err => console.error('Lazy section error:', err));
    });
  }, { rootMargin: '200px' });

  lazySections.forEach(sec => observer.observe(sec));
});
</script>
