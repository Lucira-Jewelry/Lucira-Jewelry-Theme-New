<div class="pdp-rec-lazy" data-pdp-rec>
  {% if template.name == 'product' %}

    {% assign current_product = product %}
    {% assign limit = section.settings.products_limit %}
    {% assign product_type = product.type %}
    {% assign product_type_norm = product.type | downcase | remove: 's' %}

    {% assign current_gender = '' %}
    {% assign gender_metafield = product.metafields.shopify.target-gender %}
    {% if gender_metafield and gender_metafield.value != blank %}
      {% assign gender_entry = gender_metafield.value | first %}
      {% assign current_gender = gender_entry.handle | default: gender_entry.base_target_gender | default: gender_entry.label | downcase %}
    {% endif %}

    {% assign shape_mappings = "EM:emerald,RD:round,PR:princess,CU:cushion,OV:oval,PE:pear,MQ:marquise,HS:heart,AS:asscher,RA:radiant" | split: "," %}

    {% assign current_shapes = '' %}
    {% assign display_shape = '' %}

    {% assign components_json = product.selected_or_first_available_variant.metafields.custom.components.value %}
    {% if components_json %}
      {% assign components_data = components_json | parse_json %}
      {% if components_data.components %}
        {% for component in components_data.components %}
          {% if component.shape_code and component.shape_code != blank %}
            {% assign shape_code = component.shape_code | strip | upcase %}
            {% assign shape_clean = component.shape_code | strip | downcase %}

            {% assign mapped_shape = shape_clean %}
            {% for mapping in shape_mappings %}
              {% assign map_parts = mapping | split: ":" %}
              {% if map_parts[0] == shape_code %}
                {% assign mapped_shape = map_parts[1] %}
                {% break %}
              {% endif %}
            {% endfor %}

            {% assign current_shapes = current_shapes | append: ',' | append: mapped_shape | append: ',' %}
            {% if display_shape == blank %}
              {% assign display_shape = mapped_shape %}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endif %}
    {% endif %}

    {% if current_shapes == blank %}
      {% for i in (1..4) %}
        {% capture field_name %}diamond_{{ i }}_shape{% endcapture %}
        {% assign shape_value = product.selected_or_first_available_variant.metafields.custom[field_name].value %}
        {% if shape_value and shape_value != blank %}
          {% assign shape_clean = shape_value | strip | downcase %}
          {% assign current_shapes = current_shapes | append: ',' | append: shape_clean | append: ',' %}
          {% if display_shape == blank %}
            {% assign display_shape = shape_value | strip %}
          {% endif %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% assign priority_collection = nil %}
    {% for c in product.collections %}
      {% assign title = c.title | downcase %}

      {% if title contains 'engagement ring' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'solitaire ring' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'eternity ring' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'stackable ring' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'casual ring' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains "men's ring" or title contains 'mens ring' %}
        {% assign priority_collection = c %}
        {% break %}

      {% elsif title contains 'stud' and title contains 'earring' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'hoop' and title contains 'earring' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'sui dhaga' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'dangle' and title contains 'earring' %}
        {% assign priority_collection = c %}
        {% break %}

      {% elsif title contains 'chain bracelet' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'tennis bracelet' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'cuff bracelet' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'mangalsutra bracelet' %}
        {% assign priority_collection = c %}
        {% break %}

      {% elsif title contains 'chain necklace' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'pendant necklace' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'mangalsutra necklace' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'tennis necklace' %}
        {% assign priority_collection = c %}
        {% break %}

      {% elsif title contains 'nosepin' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains "men's stud" or title contains 'mens stud' %}
        {% assign priority_collection = c %}
        {% break %}

      {% elsif title contains 'wedding' %}
        {% assign priority_collection = c %}
        {% break %}
      {% elsif title contains 'engagement' %}
        {% assign priority_collection = c %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% assign base_collection = nil %}
    {% assign broader_collection = nil %}

    {% if priority_collection %}
      {% assign base_collection = priority_collection %}
    {% else %}
      {% for c in product.collections %}
        {% assign c_title_norm = c.title | downcase | remove: 's' %}
        {% if c_title_norm contains product_type_norm %}
          {% assign base_collection = c %}
          {% break %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% for c in product.collections %}
      {% assign c_title_norm = c.title | downcase | remove: 's' %}
      {% if c_title_norm == product_type_norm and c.id != base_collection.id %}
        {% assign broader_collection = c %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% if base_collection == nil and product.collections.size > 0 %}
      {% for c in product.collections %}
        {% if c.handle != 'frontpage' %}
          {% assign base_collection = c %}
          {% break %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% assign normalized_product_type = product_type %}
    {% assign normalized_product_type_handle = product_type | downcase | replace: ' ', '-' %}

    {% if product_type == 'Charms & Pendants' %}
      {% assign normalized_product_type = 'Necklaces' %}
      {% assign normalized_product_type_handle = 'necklaces' %}
    {% endif %}

    {% assign product_type_handle = product_type | downcase | replace: ' ', '-' %}

    {% assign is_charms_or_pendants = false %}
    {% if product_type_handle == 'charms-&-pendants' or product_type_handle == 'charms-and-pendants' or product_type_handle == 'pendants' or product_type_handle == 'charms' %}
      {% assign is_charms_or_pendants = true %}
    {% endif %}

    {% if is_charms_or_pendants %}
      {% assign all_type_collection_url = '/collections/necklace' %}
    {% else %}
      {% assign all_type_collection_url = '/collections/all-' | append: product_type_handle %}
    {% endif %}

    {% if is_charms_or_pendants %}
      {% assign bestseller_collection_url = '/collections/bestsellers-1?sort_by=best-selling&filter.v.price.gte=&filter.v.price.lte=&filter.p.product_type=Necklaces' %}
    {% else %}
      {% assign bestseller_collection_url = '/collections/all/bestsellers?sort_by=title-ascending' %}
      {% assign bestseller_collection_url = bestseller_collection_url
        | append: '&filter.p.product_type='
        | append: product_type
      %}
    {% endif %}

    {% assign shape_collection_url = all_type_collection_url
      | append: '?sort_by=manual'
      | append: '&filter.v.price.gte='
      | append: '&filter.v.price.lte='
    %}

    {% if display_shape != blank %}
      {% assign shape_value = display_shape | capitalize %}
      {% assign shape_collection_url = shape_collection_url
        | append: '&filter.v.m.custom.diamond_1_shape='
        | append: shape_value
      %}
    {% endif %}
    
    {% assign global_shown_ids = '' %}

    {% if base_collection and current_gender != 'men' and current_gender != 'male' %}
    <div class="page-width">
      <div class="pdp-dynamic-recommendations">

        {% if section.settings.enable_bestseller %}
          {% assign count = 0 %}
          {% capture bestseller_content %}
            {% for p in base_collection.products %}
              {% assign p_type_norm = p.type | downcase | remove: 's' %}

              {% assign in_same_collection = false %}
              {% for p_col in p.collections %}
                {% if p_col.id == base_collection.id %}
                  {% assign in_same_collection = true %}
                  {% break %}
                {% endif %}
              {% endfor %}

              {% if p.id != current_product.id
              and in_same_collection
              and p_type_norm == product_type_norm
              and p.tags contains section.settings.bestseller_tag
              and p.featured_image != blank
              and count < limit
              %}
                {% assign check_id = ',' | append: p.id | append: ',' %}
                {% unless global_shown_ids contains check_id %}
                  <a 
                    href="{{ bestseller_collection_url }}" 
                    class="recommendation-item bestseller-promo-item"
                    data-promo-sku="{{ p.selected_or_first_available_variant.sku | default: p.id }}"
                    data-product-title="{{ p.title | escape }}"
                    data-product-id="{{ p.id }}"
                    data-redirect-url="{{ bestseller_collection_url }}"
                    data-section-type="bestseller"
                    data-section-name="Explore Bestseller {{ product_type }}"
                    onclick="trackPromoClick(event, this)"
                  >
                    <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.title | escape }}" loading="lazy">
                  </a>
                  {% assign global_shown_ids = global_shown_ids | append: check_id %}
                  {% assign count = count | plus: 1 %}
                {% endunless %}
              {% endif %}
            {% endfor %}

            {% if count < limit and broader_collection %}
              {% for p in broader_collection.products %}
                {% assign p_type_norm = p.type | downcase | remove: 's' %}
                
                {% if p.id != current_product.id
                and p_type_norm == product_type_norm
                and p.tags contains section.settings.bestseller_tag
                and p.featured_image != blank
                and count < limit
                %}
                  {% assign check_id = ',' | append: p.id | append: ',' %}
                  {% unless global_shown_ids contains check_id %}
                    <a 
                      href="{{ bestseller_collection_url }}" 
                      class="recommendation-item bestseller-promo-item"
                      data-promo-sku="{{ p.selected_or_first_available_variant.sku | default: p.id }}"
                      data-product-title="{{ p.title | escape }}"
                      data-product-id="{{ p.id }}"
                      data-redirect-url="{{ bestseller_collection_url }}"
                      data-section-type="bestseller"
                      data-section-name="Explore Bestseller {{ product_type }}"
                      onclick="trackPromoClick(event, this)"
                    >
                      <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.title | escape }}" loading="lazy">
                    </a>
                    {% assign global_shown_ids = global_shown_ids | append: check_id %}
                    {% assign count = count | plus: 1 %}
                  {% endunless %}
                {% endif %}
              {% endfor %}
            {% endif %}

            {% if count < limit %}
              {% for p in base_collection.products %}
                {% assign p_type_norm = p.type | downcase | remove: 's' %}
                
                {% if p.id != current_product.id
                and p_type_norm == product_type_norm
                and p.featured_image != blank
                and count < limit
                %}
                  {% assign check_id = ',' | append: p.id | append: ',' %}
                  {% unless global_shown_ids contains check_id %}
                    <a 
                      href="{{ bestseller_collection_url }}" 
                      class="recommendation-item bestseller-promo-item"
                      data-promo-sku="{{ p.selected_or_first_available_variant.sku | default: p.id }}"
                      data-product-title="{{ p.title | escape }}"
                      data-product-id="{{ p.id }}"
                      data-redirect-url="{{ bestseller_collection_url }}"
                      data-section-type="bestseller"
                      data-section-name="Explore Bestseller {{ product_type }}"
                      onclick="trackPromoClick(event, this)"
                    >
                      <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.title | escape }}" loading="lazy">
                    </a>
                    {% assign global_shown_ids = global_shown_ids | append: check_id %}
                    {% assign count = count | plus: 1 %}
                  {% endunless %}
                {% endif %}
              {% endfor %}
            {% endif %}
          {% endcapture %}

          {% assign bestseller_content = bestseller_content | strip %}
          {% if bestseller_content != blank %}
            <div class="recommendation-block">
              <h3>Explore Bestseller {{ product_type }}</h3>
              <div class="recommendation-grid">
                {{ bestseller_content }}
              </div>
            </div>
          {% endif %}
        {% endif %}

        {% if section.settings.enable_collection %}
          {% assign count = 0 %}
          {% capture collection_content %}
            {% for p in base_collection.products %}
              {% assign p_type_norm = p.type | downcase | remove: 's' %}

              {% if p.id != current_product.id
              and p_type_norm == product_type_norm
              and p.featured_image != blank
              and count < limit
              %}
                {% assign check_id = ',' | append: p.id | append: ',' %}
                {% unless global_shown_ids contains check_id %}
                  <a 
                    href="{{ all_type_collection_url }}" 
                    class="recommendation-item"
                    data-promo-sku="{{ p.selected_or_first_available_variant.sku | default: p.id }}"
                    data-product-title="{{ p.title | escape }}"
                    data-product-id="{{ p.id }}"
                    data-redirect-url="{{ all_type_collection_url }}"
                    data-section-type="all"
                    data-section-name="Explore All {{ product_type }}"
                    onclick="trackPromoClick(event, this)"
                  >
                    <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.title | escape }}" loading="lazy">
                  </a>
                  {% assign global_shown_ids = global_shown_ids | append: check_id %}
                  {% assign count = count | plus: 1 %}
                {% endunless %}
              {% endif %}
            {% endfor %}

            {% if count < limit and broader_collection %}
              {% for p in broader_collection.products %}
                {% assign p_type_norm = p.type | downcase | remove: 's' %}
                
                {% if p.id != current_product.id
                and p_type_norm == product_type_norm
                and p.featured_image != blank
                and count < limit
                %}
                  {% assign check_id = ',' | append: p.id | append: ',' %}
                  {% unless global_shown_ids contains check_id %}
                    <a 
                      href="{{ all_type_collection_url }}" 
                      class="recommendation-item"
                      data-promo-sku="{{ p.selected_or_first_available_variant.sku | default: p.id }}"
                      data-product-title="{{ p.title | escape }}"
                      data-product-id="{{ p.id }}"
                      data-redirect-url="{{ all_type_collection_url }}"
                      data-section-type="all"
                      data-section-name="Explore All {{ product_type }}"
                      onclick="trackPromoClick(event, this)"
                    >
                      <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.title | escape }}" loading="lazy">
                    </a>
                    {% assign global_shown_ids = global_shown_ids | append: check_id %}
                    {% assign count = count | plus: 1 %}
                  {% endunless %}
                {% endif %}
              {% endfor %}
            {% endif %}

            {% if count < limit %}
              {% for c in product.collections %}
                {% if count >= limit %}{% break %}{% endif %}
                {% for p in c.products %}
                  {% assign p_type_norm = p.type | downcase | remove: 's' %}
                  
                  {% if p.id != current_product.id
                  and p_type_norm == product_type_norm
                  and p.featured_image != blank
                  and count < limit
                  %}
                    {% assign check_id = ',' | append: p.id | append: ',' %}
                    {% unless global_shown_ids contains check_id %}
                      <a 
                        href="{{ all_type_collection_url }}" 
                        class="recommendation-item"
                        data-promo-sku="{{ p.selected_or_first_available_variant.sku | default: p.id }}"
                        data-product-title="{{ p.title | escape }}"
                        data-product-id="{{ p.id }}"
                        data-redirect-url="{{ all_type_collection_url }}"
                        data-section-type="all"
                        data-section-name="Explore All {{ product_type }}"
                        onclick="trackPromoClick(event, this)"
                      >
                        <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.title | escape }}" loading="lazy">
                      </a>
                      {% assign global_shown_ids = global_shown_ids | append: check_id %}
                      {% assign count = count | plus: 1 %}
                    {% endunless %}
                  {% endif %}
                {% endfor %}
              {% endfor %}
            {% endif %}
          {% endcapture %}

          {% assign collection_content = collection_content | strip %}
          {% if collection_content != blank %}
            <div class="recommendation-block">
              <h3>Explore All {{ product_type }}</h3>
              <div class="recommendation-grid">
                {{ collection_content }}
              </div>
            </div>
          {% endif %}
        {% endif %}

        {% if section.settings.enable_shape and current_shapes != blank %}
          {% assign count = 0 %}
          {% capture shape_content %}
            {% for p in base_collection.products %}
              {% assign p_type_norm = p.type | downcase | remove: 's' %}

              {% assign in_same_collection = false %}
              {% for p_col in p.collections %}
                {% if p_col.id == base_collection.id %}
                  {% assign in_same_collection = true %}
                  {% break %}
                {% endif %}
              {% endfor %}

              {% assign shape_match = false %}
              
              {% assign p_components_json = p.selected_or_first_available_variant.metafields.custom.components.value %}
              {% if p_components_json %}
                {% assign p_components_data = p_components_json | parse_json %}
                {% if p_components_data.components %}
                  {% for p_component in p_components_data.components %}
                    {% if p_component.shape_code and p_component.shape_code != blank %}
                      {% assign p_shape_code = p_component.shape_code | strip | upcase %}
                      {% assign p_shape_clean = p_component.shape_code | strip | downcase %}
                      
                      {% assign p_mapped_shape = p_shape_clean %}
                      {% for mapping in shape_mappings %}
                        {% assign map_parts = mapping | split: ":" %}
                        {% if map_parts[0] == p_shape_code %}
                          {% assign p_mapped_shape = map_parts[1] %}
                          {% break %}
                        {% endif %}
                      {% endfor %}
                      
                      {% assign check_shape = ',' | append: p_mapped_shape | append: ',' %}
                      {% if current_shapes contains check_shape %}
                        {% assign shape_match = true %}
                        {% break %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}
                {% endif %}
              {% endif %}

              {% if shape_match == false %}
                {% for i in (1..4) %}
                  {% capture field_name %}diamond_{{ i }}_shape{% endcapture %}
                  {% assign p_shape = p.selected_or_first_available_variant.metafields.custom[field_name].value %}
                  {% if p_shape and p_shape != blank %}
                    {% assign p_shape_clean = p_shape | strip | downcase %}
                    {% assign check_shape = ',' | append: p_shape_clean | append: ',' %}
                    {% if current_shapes contains check_shape %}
                      {% assign shape_match = true %}
                      {% break %}
                    {% endif %}
                  {% endif %}
                {% endfor %}
              {% endif %}

              {% if shape_match == false %}
                {% for tag in p.tags %}
                  {% assign tag_clean = tag | downcase %}
                  {% assign tag_check = ',' | append: tag_clean | append: ',' %}
                  {% if current_shapes contains tag_check %}
                    {% assign shape_match = true %}
                    {% break %}
                  {% endif %}
                {% endfor %}
              {% endif %}

              {% if p.id != current_product.id
              and in_same_collection
              and p_type_norm == product_type_norm
              and shape_match
              and p.featured_image != blank
              and count < limit
              %}
                {% assign check_id = ',' | append: p.id | append: ',' %}
                {% unless global_shown_ids contains check_id %}
                  <a 
                    href="{{ shape_collection_url }}" 
                    class="recommendation-item"
                    data-promo-sku="{{ p.selected_or_first_available_variant.sku | default: p.id }}"
                    data-product-title="{{ p.title | escape }}"
                    data-product-id="{{ p.id }}"
                    data-redirect-url="{{ shape_collection_url }}"
                    data-section-type="shape"
                    data-section-name="Explore {{ display_shape | capitalize }} {{ product_type }}"
                    onclick="trackPromoClick(event, this)"
                  >
                    <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.title | escape }}" loading="lazy">
                  </a>
                  {% assign global_shown_ids = global_shown_ids | append: check_id %}
                  {% assign count = count | plus: 1 %}
                {% endunless %}
              {% endif %}
            {% endfor %}

            {% if count < limit %}
              {% for p in base_collection.products %}
                {% assign p_type_norm = p.type | downcase | remove: 's' %}
                
                {% if p.id != current_product.id
                and p_type_norm == product_type_norm
                and p.featured_image != blank
                and count < limit
                %}
                  {% assign check_id = ',' | append: p.id | append: ',' %}
                  {% unless global_shown_ids contains check_id %}
                    <a 
                      href="{{ shape_collection_url }}" 
                      class="recommendation-item"
                      data-promo-sku="{{ p.selected_or_first_available_variant.sku | default: p.id }}"
                      data-product-title="{{ p.title | escape }}"
                      data-product-id="{{ p.id }}"
                      data-redirect-url="{{ shape_collection_url }}"
                      data-section-type="shape"
                      data-section-name="Explore {{ display_shape | capitalize }} {{ product_type }}"
                      onclick="trackPromoClick(event, this)"
                    >
                      <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.title | escape }}" loading="lazy">
                    </a>
                    {% assign global_shown_ids = global_shown_ids | append: check_id %}
                    {% assign count = count | plus: 1 %}
                  {% endunless %}
                {% endif %}
              {% endfor %}
            {% endif %}

            {% if count < limit and broader_collection %}
              {% for p in broader_collection.products %}
                {% assign p_type_norm = p.type | downcase | remove: 's' %}
                
                {% if p.id != current_product.id
                and p_type_norm == product_type_norm
                and p.featured_image != blank
                and count < limit
                %}
                  {% assign check_id = ',' | append: p.id | append: ',' %}
                  {% unless global_shown_ids contains check_id %}
                    <a 
                      href="{{ shape_collection_url }}" 
                      class="recommendation-item"
                      data-promo-sku="{{ p.selected_or_first_available_variant.sku | default: p.id }}"
                      data-product-title="{{ p.title | escape }}"
                      data-product-id="{{ p.id }}"
                      data-redirect-url="{{ shape_collection_url }}"
                      data-section-type="shape"
                      data-section-name="Explore {{ display_shape | capitalize }} {{ product_type }}"
                      onclick="trackPromoClick(event, this)"
                    >
                      <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.title | escape }}" loading="lazy">
                    </a>
                    {% assign global_shown_ids = global_shown_ids | append: check_id %}
                    {% assign count = count | plus: 1 %}
                  {% endunless %}
                {% endif %}
              {% endfor %}
            {% endif %}
          {% endcapture %}

          {% assign shape_content = shape_content | strip %}
          {% if shape_content != blank %}
            <div class="recommendation-block">
              <h3>Explore {{ display_shape | capitalize }} {{ product_type }}</h3>
              <div class="recommendation-grid">
                {{ shape_content }}
              </div>
            </div>
          {% endif %}
        {% endif %}

      </div>
    </div>
    {% endif %}

  {% endif %}
</div>

<script>
  function trackPromoClick(event, element) {
    const promoSku = element.getAttribute('data-promo-sku');
    const productId = element.getAttribute('data-product-id');
    const redirectUrl = element.getAttribute('data-redirect-url');
    const sectionType = element.getAttribute('data-section-type');
    const sectionName = element.getAttribute('data-section-name');
    
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'promoClick',
      promoClick: {
        promo_id: productId,
        creative_name: "Bestseller Section",
        promo_name: sectionName,
        location_id: 'bottom of pdp',
        promo_position: redirectUrl
      },
    });
  }
</script>


<style>
  .pdp-rec-lazy.loading{min-height:360px;position:relative}
  .pdp-rec-lazy.loading::before{content:"";display:block;height:300px;margin:40px auto;max-width:1200px;background:linear-gradient(90deg,#eee 25%,#f5f5f5 37%,#eee 63%);background-size:400% 100%;animation:shimmer 1.4s infinite}
  @keyframes shimmer{
    0%{background-position:100% 0}
    100%{background-position:-100% 0}
  }
</style>

<script>
(function () {
  function initPdpRecLazy() {
    const wrapper = document.querySelector('[data-pdp-rec]');
    if (!wrapper) return;

    // Always visible in Shopify editor
    if (window.Shopify && Shopify.designMode) {
      wrapper.classList.remove('loading');
      return;
    }

    wrapper.classList.add('loading');

    const io = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) {
        wrapper.classList.remove('loading');
        io.disconnect();
      }
    }, {
      rootMargin: '300px'
    });

    io.observe(wrapper);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPdpRecLazy);
  } else {
    initPdpRecLazy();
  }
})();
</script>

