<style>
.trust-partners-section{margin-top:var(--mt-desktop);margin-bottom:var(--mb-desktop)}
.tp-container{margin:auto;padding-left:40px;text-align:center;margin-right:0}
.tp-heading{margin:0 auto;margin-bottom:12px;font-weight:500;font-size:32px;line-height:150%;text-align:center;vertical-align:middle;text-transform:uppercase;color:#1a1a1a;max-width:850px}
.tp-subheading{margin:0 auto;max-width:850px;margin-bottom:60px;font-weight:400;font-size:18px;line-height:24px;text-align:center;vertical-align:middle}
.tp-blocks{display:flex;gap:20px;padding-right:40px;overflow-x:auto;padding-bottom:5px;scrollbar-width:none}
.tp-blocks::-webkit-scrollbar{display:none}
.tp-block{min-width:40%}
.tp-image-wrapper{width:100%;height:auto;overflow:hidden;border-radius:6px}
.tp-image-wrapper img{width:100%;display:block;object-fit:cover}
.tp-text{margin:0;font-weight:300;font-size:18px;line-height:150%;vertical-align:middle;text-align:left;margin-top:24px}
@media (max-width:768px){
.tp-container{padding-left:20px}
.trust-partners-section{margin-top:var(--mt-mobile);margin-bottom:var(--mb-mobile)}
.tp-heading{margin-bottom:6px;font-size:18px}
.tp-subheading{margin-bottom:24px;font-size:12px}
.tp-block{min-width:70%;padding-right:20px}
.tp-text{margin-top:12px;font-size:10px}
.tp-blocks{font-size:12px}
}
</style>

<section
  class="trust-partners-section"
  style="
    --mt-desktop: {{ section.settings.margin_top_desktop }}px;
    --mb-desktop: {{ section.settings.margin_bottom_desktop }}px;
    --mt-mobile: {{ section.settings.margin_top_mobile }}px;
    --mb-mobile: {{ section.settings.margin_bottom_mobile }}px;
  "
>
  <div class="tp-container ">
    <h2 class="tp-heading">{{ section.settings.heading }}</h2>
    <p class="tp-subheading">{{ section.settings.subheading }}</p>

    <div class="tp-blocks">
      {% for block in section.blocks %}
        <div class="tp-block">
          <div class="tp-image-wrapper">
            {% if block.settings.image %}
              <img src="{{ block.settings.image | img_url: '800x' }}" alt="">
            {% endif %}
          </div>

          <p class="tp-text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trustworthy Partners",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "TRUSTWORTHY PARTNERS"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit..."
    },

    {
      "type": "range",
      "id": "margin_top_desktop",
      "label": "Margin Top (Desktop)",
      "min": 0,
      "max": 100,
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "label": "Margin Bottom (Desktop)",
      "min": 0,
      "max": 100,
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Margin Top (Mobile)",
      "min": 0,
      "max": 100,
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Margin Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "default": 20
    }
  ],

  "blocks": [
    {
      "type": "item",
      "name": "Partner Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Content",
          "default": "Lorem ipsum dolor sit amet, consectetur..."
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Trustworthy Partners"
    }
  ]
}
{% endschema %}
