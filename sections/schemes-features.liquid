<div class="schemes-features-section">
    <div class="page-width">
        <div class="section-header text-center">
            <h2 class="section-header__title">Why Choose Lucira’s Scheme</h2>
            {% comment %} <p class="section-header__subtitle">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut alconsequat. </p> {% endcomment %}
        </div>
        <div class="features-grid">
            <div class="feature-item">
                {{- 'flexible-payment.svg' | inline_asset_content -}}
                <h3 class="feature-title">Flexible Payments</h3>
                <p class="feature-description">Start with just ₹1000/month and save big!</p>
            </div>
            <div class="feature-item">
                {{- 'smart-calender.svg' | inline_asset_content -}}
                <h3 class="feature-title">Smart Planning</h3>
                <p class="feature-description">Perfect for gifts, weddings, and special milestones.</p>
            </div>
            <div class="feature-item">
                {{- 'extra-savings.svg' | inline_asset_content -}}
                <h3 class="feature-title">Extra Savings</h3>
                <p class="feature-description">Enjoy a 100% discount on your 10th installment.</p>
            </div>
            <div class="feature-item">
                {{- 'safe-secure.svg' | inline_asset_content -}}
                <h3 class="feature-title">Safe & Secure</h3>
                <p class="feature-description">Guaranteed savings with no hidden charges.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .schemes-features-section .section-header { margin-bottom: 40px; }
    .schemes-features-section {padding: 30px 0;}
    .schemes-features-section h2.section-header__title {font-weight: 500; font-size: 24px; line-height: 150%; letter-spacing: 1.4px; text-align: center; vertical-align: middle; text-transform: uppercase; margin-top: 0; margin-bottom: 8px;}
    .schemes-features-section p.section-header__subtitle { font-weight: 400; font-size: 16px; letter-spacing: 1px; text-align: center; vertical-align: middle; max-width: 900px; margin: 0 auto; color: #1a1a1a; line-height: 1.7; }
    .schemes-features-section .features-grid {display: grid ; grid-template-columns: repeat(4, 1fr); gap: 20px;}
    .schemes-features-section .features-grid .feature-item:nth-child(1) {background: #F3E0CF;}
    .schemes-features-section .features-grid .feature-item:nth-child(2) {background: #F3DCE0;}
    .schemes-features-section .features-grid .feature-item:nth-child(3) {background: #CCE6CC;}
    .schemes-features-section .features-grid .feature-item:nth-child(4) {background: #D6EEF4;}
    .schemes-features-section .features-grid .feature-item {padding: 20px 20px 20px; border-radius: 8px;}
    .schemes-features-section h3.feature-title {font-weight: 500; font-size: 16px; line-height: 150%; letter-spacing: 1.1px; text-align: center; vertical-align: middle; text-transform: uppercase; margin-top: 0 !important; margin-bottom: 0;}
    .schemes-features-section .feature-description { margin-top: 14px; font-weight: 400; font-size: 14px; line-height: 22px; letter-spacing: 1px; text-align: center; vertical-align: middle; text-transform: capitalize; max-width: 220px; margin-left: auto; margin-right: auto; margin-bottom: 0px; }
    .schemes-features-section p.section-header__subtitle {margin-bottom: 40px;}
    .schemes-features-section .features-grid .feature-item {display: flex ; flex-direction: column; justify-content: center; align-items: center; }
    .schemes-features-section .features-grid .feature-item svg { display: block; width: 40px; height: 40px; margin-bottom: 20px; }
    @media only screen and (min-width:0) and (max-width:767px){
      .schemes-features-section .features-grid { display: grid ; grid-template-columns: repeat(2, 1fr); gap: 20px; }
      .process-text {font-size: 10px;}
      .process-number {font-size: 14px;}
      .schemes-features-section h2.section-header__title {font-size: 18px;}
      .schemes-features-section .features-grid {display: grid ; grid-template-columns: repeat(2, 1fr); gap: 12px;}
      .schemes-features-section p.section-header__subtitle {margin: 0 auto; letter-spacing: 1px; vertical-align: middle; font-weight: 400; font-size: 12px; line-height: 150%; text-align: center; margin-bottom: 28px;}
      .schemes-features-section .feature-description {font-size: 10px; line-height: 1.7;}
    }

    @media only screen and (min-width:0) and (max-width:430px){
      input.talk-to-us-expert-input { padding: 14px 22px 14px 20px; font-family: Futura Std; font-weight: 500; font-size: 12px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; border: 1px solid #666666; width: 100%; display: block; max-width: 100%; }
      .talk-to-us-expert-button  {background: #b67665; color: #fff; border: 0; padding: 14px 12px; font-family: Futura Std; font-weight: 500; font-size: 12px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; border-radius: 8px; display: inline-flex ; align-items: center; justify-content: center; gap: 10px; width: 100%;}
      .talk-to-us-expert-button svg {width: 20px; height: 20px;}
      .schemes-offer-banner h2 {font-size: 16px;}
      .schemes-features-section h3.feature-title {font-size: 12px;}

    }
</style>

{% schema %}
{
  "name": "Schemes Features Banner",
  "tag": "section",
  "class": "schemes-features-banner",
  "settings": [
    {
      "type": "text",
      "label": "heading",
      "id": "schemes_features_title"
    },
  ],
  "presets": [
    {
      "name": "Schemes Features Banner"
    }
  ]
}
{% endschema %}