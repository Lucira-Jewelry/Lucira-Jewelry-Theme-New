<div class="schemes-features-section">
    <div class="page-width">
        <div class="section-header text-center">
            <h2 class="section-header__title">why scheme from lucira</h2>
            <p class="section-header__subtitle">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut alconsequat. </p>
        </div>
        <div class="features-grid">
            <div class="feature-item">
                <img src="images/drag-drop-builder.png" alt="Flexible Payments" class="feature-icon">
                <h3 class="feature-title">Flexible Payments</h3>
                <p class="feature-description">Start with just ₹1000/month and save big!</p>
            </div>
            <div class="feature-item">
                <img src="images/automation.png" alt="Smart Planning" class="feature-icon">
                <h3 class="feature-title">Smart Planning</h3>
                <p class="feature-description">Perfect for gifts, weddings, and special milestones.</p>
            </div>
            <div class="feature-item">
                <img src="images/analytics.png" alt="Extra Savings" class="feature-icon">
                <h3 class="feature-title">Extra Savings</h3>
                <p class="feature-description">Enjoy a 100% discount on your 11th installment.</p>
            </div>
            <div class="feature-item">
                <img src="images/segmentation.png" alt="Safe & Secure" class="feature-icon">
                <h3 class="feature-title">Safe & Secure</h3>
                <p class="feature-description">Guaranteed savings with no hidden charges.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .schemes-features-section h2.section-header__title { font-weight: 500; font-size: 24px; line-height: 150%; letter-spacing: 1.4px; text-align: center; vertical-align: middle; text-transform: uppercase; }
    .schemes-features-section p.section-header__subtitle { font-weight: 400; font-size: 16px; letter-spacing: 1px; text-align: center; vertical-align: middle; max-width: 900px; margin: 0 auto; color: #1a1a1a; line-height: 1.7; }
    .schemes-features-section .features-grid {display: grid ; grid-template-columns: repeat(4, 1fr); gap: 30px;}
    .schemes-features-section .features-grid .feature-item::nth-child(1) {background: #F3E0CF;}
    .schemes-features-section .features-grid .feature-item::nth-child(2) {background: #F3DCE0;}
    .schemes-features-section .features-grid .feature-item::nth-child(3) {background: #CCE6CC;}
    .schemes-features-section .features-grid .feature-item::nth-child(4) {background: #D6EEF4;}
</style>

{% schema %}
{
  "name": "Schemes Features Banner",
  "tag": "section",
  "class": "schemes-features-banner",
  "settings": [
    {
      "type": "text",
      "label": "heading",
      "id": "schemes_features_title"
    },
  ],
  "presets": [
    {
      "name": "Schemes Features Banner"
    }
  ]
}
{% endschema %}