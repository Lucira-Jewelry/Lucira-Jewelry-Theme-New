{% assign engraving_tags = product.tags | join: ',' | downcase %}
{% if engraving_tags contains 'engraving available' %}
  <section
    id="lucira-engraving-section"
    class="lucira-engraving-section"
    style="background-color: {{ section.settings.background }}"
  >
    <div class="engraving-drawer-overlay" id="engraving-drawer-overlay"></div>
    <div class="engraving-drawer" id="engraving-drawer">
      <div class="engraving-drawer-wrapper">
        <div class="engraving-drawer-title-wrap">
          {% if section.settings.lucira_engraving_title != blank %}
            <div class="title-wrapper">{{ section.settings.lucira_engraving_title }}</div>
          {% endif %}
          <div class="close-button" id="close-engraving-button">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <mask id="mask0_10852_4801" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24">
              <rect width="24" height="24" fill="#D9D9D9"/>
              </mask>
              <g mask="url(#mask0_10852_4801)">
              <path d="M12 13.0538L6.92701 18.127C6.78851 18.2653 6.61443 18.3362 6.40476 18.3395C6.19526 18.3427 6.01801 18.2718 5.87301 18.127C5.72818 17.982 5.65576 17.8063 5.65576 17.6C5.65576 17.3937 5.72818 17.218 5.87301 17.073L10.9463 12L5.87301 6.92701C5.73468 6.78851 5.66385 6.61443 5.66051 6.40476C5.65735 6.19526 5.72818 6.01801 5.87301 5.87301C6.01801 5.72818 6.19368 5.65576 6.40001 5.65576C6.60635 5.65576 6.78201 5.72818 6.92701 5.87301L12 10.9463L17.073 5.87301C17.2115 5.73468 17.3856 5.66385 17.5953 5.66051C17.8048 5.65735 17.982 5.72818 18.127 5.87301C18.2718 6.01801 18.3443 6.19368 18.3443 6.40001C18.3443 6.60635 18.2718 6.78201 18.127 6.92701L13.0538 12L18.127 17.073C18.2653 17.2115 18.3362 17.3856 18.3395 17.5953C18.3427 17.8048 18.2718 17.982 18.127 18.127C17.982 18.2718 17.8063 18.3443 17.6 18.3443C17.3937 18.3443 17.218 18.2718 17.073 18.127L12 13.0538Z" fill="#666666"/>
              </g>
            </svg>
          </div>
        </div>
      </div>

      <div class="lucira-engraving-details-wrapper">
        <div class="grid-row">
          <div class="product_engraving_container">
            <div class="image-and-text-div">
              <img
                class="image_on_text"
                src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/upscalemedia-transformed.png?v=1745999646"
                width="450"
                height="112"
                alt="Engraving Preview"
                title="Engraving"
              >
              <div id="engraving-preview-text" class="overlay-text"></div>
            </div>
            <p class="product_engraving_note">
              <strong>Note:</strong> Text can only contain up to 8 English/alphanumeric characters (A-Z, a-z, 0-9) and
              special characters (heart and infinity).
            </p>

            <div class="engraving-font-selection-wrapper">
              <h3>Choose a Font <span style="color: #d32f2f;">*</span></h3>
              <div class="lucira_engraving_font_options">
                <div class="lucira_engraving_font_option" data-font="Lobster">Aa - Lobster</div>
                <div class="lucira_engraving_font_option" data-font="Yellowtail">Aa - Yellowtail</div>
                <div class="lucira_engraving_font_option" data-font="Satisfy">Aa - Satisfy</div>
                <div class="lucira_engraving_font_option" data-font="ABeeZee">Aa - ABeeZee</div>
              </div>
            </div>

            <div class="engraving-font-selection-wrapper">
              <h3>Inner Engraving <span style="color: #d32f2f;">*</span></h3>
              <div class="lucira-engraving-input">
                <input
                  type="text"
                  id="lucira_engraving_text"
                  maxlength="8"
                  placeholder="Type your text here"
                >
                <div class="lucira-engraving-icons">
                  <span class="lucira-engraving-icon" onclick="EngravingAddSymbol('❤')">❤️</span>
                  <span class="lucira-engraving-icon" onclick="ProductEngravAddSymbol('∞')">♾</span>
                </div>
              </div>
            </div>

            <div class="engraving-font-selection-wrapper">
              <button
                id="product_engraving_confirm_submit"
                class="engraving-save-btn lucira-engraving-save-btn"
                type="button"
                disabled
              >
                SAVE
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Engraving Drawer",
  "settings": [
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "lucira_engraving_title",
      "label": "Title",
      "default": "Engraving"
    }
  ],
  "blocks": [
    {
      "type": "engraving_item",
      "name": "Engraving Item",
      "settings": []
    }
  ],
  "presets": [
    {
      "name": "Engraving Drawer",
      "blocks": [
        {
          "type": "engraving_item"
        }
      ]
    }
  ]
}
{% endschema %}
