{% assign engraving_tags = product.tags | join: ',' | downcase %}
{% if engraving_tags contains 'engraving available' %}

<section
  id="lucira-engraving-section"
  class="lucira-engraving-section"
  style="background-color: {{ section.settings.background }}"
>
  <div class="engraving-drawer-overlay" id="engraving-drawer-overlay"></div>
  <div class="engraving-drawer" id="engraving-drawer">
    <div class="engraving-drawer-wrapper">
      <div class="engraving-drawer-title-wrap">
        {% if section.settings.lucira_engraving_title != blank %}
          <div class="title-wrapper">{{ section.settings.lucira_engraving_title }}</div>
        {% endif %}
        <div class="close-button" id="close-engraving-button">
          <i class="fa-solid fa-xmark"></i>
        </div>
      </div>
    </div>

    <div class="lucira-engraving-details-wrapper">
      <div class="grid-row">
        <div class="product_engraving_container">
          <div class="image-and-text-div">
            <img
              class="image_on_text"
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/upscalemedia-transformed.png?v=1745999646"
              alt="Engraving Preview"
            >
            <div id="engraving-preview-text" class="overlay-text"></div>
          </div>
          <p class="product_engraving_note">
            <strong>Note:</strong> Text can only contain up to 8 English/alphanumeric characters (A-Z, a-z, 0-9) and special characters (heart and infinity).
          </p>

          <div class="engraving-font-selection-wrapper">
            <h3>Choose a Font</h3>
            <div class="lucira_engraving_font_options">
              <div class="lucira_engraving_font_option active" data-font="Lobster">Aa - Lobster</div>
              <div class="lucira_engraving_font_option" data-font="Yellowtail">Aa - Yellowtail</div>
              <div class="lucira_engraving_font_option" data-font="Satisfy">Aa - Satisfy</div>
              <div class="lucira_engraving_font_option" data-font="ABeeZee">Aa - ABeeZee</div>
            </div>
          </div>

          <div class="engraving-font-selection-wrapper">
            <h3>Inner Engraving</h3>
            <div class="lucira-engraving-input">
              <input
                type="text"
                id="lucira_engraving_text"
                name="properties[EngravingText]"
                maxlength="8"
                placeholder="Type your text here"
              >
              <div class="lucira-engraving-icons">
                <span class="lucira-engraving-icon" onclick="EngravingAddSymbol('❤')">❤️</span>
                <span class="lucira-engraving-icon" onclick="bradProdEngravAddSymbol('∞')">♾</span>
              </div>
            </div>
          </div>

          <div class="engraving-font-selection-wrapper">
            <button id="product_engraving_confirm_submit" class="lucira-engraving-save-btn">SAVE</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const engravingInput = document.getElementById("lucira_engraving_text");
  const previewText = document.getElementById("engraving-preview-text");
  const fontOptions = document.querySelectorAll(".lucira_engraving_font_option");
  const saveButton = document.getElementById("product_engraving_confirm_submit");
  const savedWrapper = document.getElementById("engraving-saved-wrapper");

  // Hidden inputs to pass engraving data into Shopify cart
  let fontInput = document.createElement("input");
  fontInput.type = "hidden";
  fontInput.name = "properties[EngravingFont]";
  engravingInput.closest("form")?.appendChild(fontInput);

  // --- Live Preview Update ---
  engravingInput.addEventListener("input", function () {
    previewText.textContent = this.value;
  });

  // --- Symbol Insertion ---
  window.EngravingAddSymbol = function (symbol) {
    insertAtCursor(engravingInput, symbol);
    engravingInput.dispatchEvent(new Event("input")); // refresh preview
  };

  window.bradProdEngravAddSymbol = function (symbol) {
    insertAtCursor(engravingInput, symbol);
    engravingInput.dispatchEvent(new Event("input")); // refresh preview
  };

  function insertAtCursor(input, text) {
    const start = input.selectionStart;
    const end = input.selectionEnd;
    input.value = input.value.slice(0, start) + text + input.value.slice(end);
    input.setSelectionRange(start + text.length, start + text.length);
    input.focus();
  }

  // --- Font Selection ---
  fontOptions.forEach(option => {
    option.addEventListener("click", () => {
      fontOptions.forEach(opt => opt.classList.remove("active"));
      option.classList.add("active");
      const font = option.dataset.font;

      // Update preview font
      previewText.style.fontFamily = font;

      // Save into hidden input
      fontInput.value = font;
    });
  });

  // --- Save Button (finalize selection) ---
  saveButton.addEventListener("click", (e) => {
    e.preventDefault();

    // Finalize engraving data
    const engravingValue = engravingInput.value.trim();
    const selectedFont = document.querySelector(".lucira_engraving_font_option.active")?.dataset.font || "";

    // Update hidden inputs
    engravingInput.value = engravingValue;
    fontInput.value = selectedFont;

    // --- Show Saved Engraving ---
    if (engravingValue) {
      savedWrapper.innerHTML = `
        <p><strong>Saved Engraving:</strong></p>
        <div style="font-family:${selectedFont}; font-size:18px; margin-top:5px;">
          ${engravingValue}
        </div>
      `;
    } else {
      savedWrapper.innerHTML = `<p style="color:red;">No engraving text entered</p>`;
    }

    // Button feedback
    saveButton.textContent = "Saved ✓";
    setTimeout(() => (saveButton.textContent = "SAVE"), 2000);
  });
});
</script>




{% endif %}

{% schema %}
{
  "name": "Engraving Drawer",
  "settings": [
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "lucira_engraving_title",
      "label": "Title",
      "default": "Engraving"
    }
  ],
  "blocks": [
    {
      "type": "engraving_item",
      "name": "Engraving Item",
      "settings": []
    }
  ],
  "presets": [
    {
      "name": "Engraving Drawer",
      "blocks": [
        {
          "type": "engraving_item"
        }
      ]
    }
  ]
}
{% endschema %}