{% assign engraving_tags = product.tags | join: ',' | downcase %}
{% if engraving_tags contains 'engraving available' %}
  
  <!-- Engraving Button -->
  <!-- Engraving Drawer Section -->
  <section
    id="lucira-engraving-section"
    class="lucira-engraving-section"
    style="background-color: {{ section.settings.background }}"
  >
    <div class="engraving-drawer-overlay" id="engraving-drawer-overlay"></div>
    <div class="engraving-drawer" id="engraving-drawer">
      <div class="engraving-drawer-wrapper">
        <div class="engraving-drawer-title-wrap">
          {% if section.settings.lucira_engraving_title != blank %}
            <div class="title-wrapper">{{ section.settings.lucira_engraving_title }}</div>
          {% endif %}
          <div class="close-button" id="close-engraving-button">
            <i class="fa-solid fa-xmark"></i>
          </div>
        </div>
      </div>

      <div class="lucira-engraving-details-wrapper">
        <div class="grid-row">
          <div class="product_engraving_container">
            <div class="image-and-text-div">
              <img
                class="image_on_text"
                src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/upscalemedia-transformed.png?v=1745999646"
                alt="Engraving Preview"
              >
              <div id="engraving-preview-text" class="overlay-text"></div>
            </div>
            <p class="product_engraving_note">
              <strong>Note:</strong> Text can only contain up to 8 English/alphanumeric characters (A-Z, a-z, 0-9) and special characters (heart and infinity).
            </p>

            <div style="display: flex; justify-content: center; display: none">
              <button class="brad-prodEngrav-info-btn">HOW IS ENGRAVING DONE? ▶</button>
            </div>

            <div>
              <h3>Choose a font</h3>
              <div class="lucira_engraving_font_options">
                <div class="lucira_engraving_font_option brad-prodEngrav-selected" data-font="Lobster">Aa - Lobster</div>
                <div class="lucira_engraving_font_option" data-font="Yellowtail">Aa - Yellowtail</div>
                <div class="lucira_engraving_font_option" data-font="Satisfy">Aa - Satisfy</div>
                <div class="lucira_engraving_font_option" data-font="ABeeZee">Aa - ABeeZee</div>
              </div>
            </div>

            <div>
              <h3>Inner Engraving</h3>
              <div class="lucira-engraving-input">
                <input
                  type="text"
                  id="lucira_engraving_text"
                  name="properties[EngravingText]"
                  maxlength="8"
                  placeholder="Type your text here"
                >
                <div class="lucira-engraving-icons">
                  <span class="lucira-engraving-icon" onclick="bradProdEngravAddSymbol('❤')">❤️</span>
                  <span class="lucira-engraving-icon" onclick="bradProdEngravAddSymbol('∞')">♾</span>
                </div>
              </div>
            </div>

            <div>
              <button id="product_engraving_confirm_submit" class="lucira-engraving-save-btn">SAVE</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .lucira-engraving-trigger {
      margin: 20px 0;
      text-align: left;
    }
    .free-engraving-text {
      font-weight: 400;
      font-size:14px;
      margin-bottom: 10px;
    }
    .engraving-guide-button {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: 1px solid #d1d1d1;
      border-radius: 8px;
      background: #fff;
      padding: 14px 20px;
      font-size: 16px;
      font-weight: 400;
      cursor: pointer;
      width: 100%;
      max-width: 500px;
      margin: auto;
      transition: all 0.2s ease-in-out;
    }
    .engraving-guide-button i {
      font-size: 20px;
    }
    .engraving-guide-button:hover {
      border-color: #333;
    }

    /* Drawer open/close animations */
    .engraving-drawer {
      position: fixed;
      top: 0;
      right: -100%;
      max-width: 90%;
      height: 100%;
      background: #fff;
      transition: right 0.3s ease;
      z-index: 1001;
      overflow-y: auto;
      box-shadow: -2px 0 8px rgba(0,0,0,0.2);
    }
    .engraving-drawer.open {
      right: 0;
    }
    .engraving-drawer-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.5);
      z-index: 1000;
    }
    .product_engraving_container{
      padding:20px;
    }
    .engraving-drawer-overlay.active {
      display: block;
    }
    .close-button {
      cursor: pointer;
    }
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const trigger = document.getElementById("engraving_drawer");
      const drawer = document.getElementById("engraving-drawer");
      const overlay = document.getElementById("engraving-drawer-overlay");
      const closeBtn = document.getElementById("close-engraving-button");

      if (trigger && drawer) {
        trigger.addEventListener("click", function() {
          drawer.classList.add("open");
          overlay.classList.add("active");
        });
      }

      if (overlay) {
        overlay.addEventListener("click", function() {
          drawer.classList.remove("open");
          overlay.classList.remove("active");
        });
      }

      if (closeBtn) {
        closeBtn.addEventListener("click", function() {
          drawer.classList.remove("open");
          overlay.classList.remove("active");
        });
      }
    });
  </script>

{% endif %}

{% schema %}
{
  "name": "Engraving Drawer",
  "settings": [
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "lucira_engraving_title",
      "label": "Title",
      "default": "Engraving"
    }
  ],
  "blocks": [
    {
      "type": "engraving_item",
      "name": "Engraving Item",
      "settings": []
    }
  ],
  "presets": [
    {
      "name": "Engraving Drawer",
      "blocks": [
        {
          "type": "engraving_item"
        }
      ]
    }
  ]
}
{% endschema %}