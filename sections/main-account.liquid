  {% comment %} script for schemes tab  {% endcomment %}

  <script>
    (function () {
      'use strict';

      var ORN_TOKEN_URL = 'https://lucira.live.ornaverse.in/connect/token';
      var ORN_LIST_URL  = 'https://lucira.live.ornaverse.in/Services/POS/SchemeEnrollment/List';
      var ORN_USERNAME  = {{ settings.orn_username | json }};
      var ORN_PASSWORD  = {{ settings.orn_password | json }};
      {% comment %} var ENROLL_URL    = 'https://schemes.lucirajewelry.com/enroll'; {% endcomment %}
{% comment %} customer.phone {% endcomment %}
      var rawPhone = '{{ 8857957580 | remove: "+" | remove: "-" | remove: " " | remove: "(" | remove: ")" | strip }}';
      var customerPhone = (rawPhone.length === 12 && rawPhone.slice(0, 2) === '91')
        ? rawPhone.slice(2)
        : rawPhone;

      var ENROLL_URL = 'https://schemes.lucirajewelry.com/enroll?p=' + customerPhone;

      var allSchemes  = [];
      var cachedToken = null;
      var tokenExpiry = 0;
      var inner       = document.getElementById('schemes-inner');

      if (!customerPhone || customerPhone.length < 10) {
        renderError('Phone number not associated with your account.<br>Please contact support.');
        return;
      }

      init();

      async function init() {
        try {
          var token = await getToken();
          await fetchSchemes(token);
        } catch (err) {
          renderError('Something went wrong: ' + (err.message || err));
        }
      }

      async function getToken() {
        if (cachedToken && Date.now() < tokenExpiry) return cachedToken;

        var body = [
          'grant_type=password',
          'client_id=api_access',
          'scope=openid%20offline_access',
          'username=' + encodeURIComponent(ORN_USERNAME),
          'password=' + encodeURIComponent(ORN_PASSWORD)
        ].join('&');

        var res = await fetch(ORN_TOKEN_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body
        });

        if (!res.ok) {
          var errText = await res.text();
          throw new Error('Token fetch failed (' + res.status + '): ' + errText);
        }

        var data    = await res.json();
        cachedToken = data.access_token;
        tokenExpiry = Date.now() + (data.expires_in - 60) * 1000;
        return cachedToken;
      }

      async function fetchSchemes(token) {
        var res = await fetch(ORN_LIST_URL, {
          method: 'POST',
          headers: {
            'Content-Type':  'application/json',
            'Authorization': 'Bearer ' + token
          },
          body: JSON.stringify({ mobile: customerPhone })
        });

        if (!res.ok) {
          var errText = await res.text();
          throw new Error('Enrollment fetch failed (' + res.status + '): ' + errText);
        }

        var data   = await res.json();
        allSchemes = (data.Entities || []);

        if (allSchemes.length === 0) {
          renderEmpty();
        } else {
          renderList();
        }
      }

      function renderEmpty() {
        inner.innerHTML = [
          '<div class="sch-empty">',
            '<h3>No Enrolled Scheme</h3>',
            '<p>You have not enrolled in any scheme yet.</p>',
            '<a class="sch-enroll-btn" href="' + ENROLL_URL + '">Enroll Now</a>',
          '</div>'
        ].join('');
      }

      function renderList() {
        /* ── Mobile card view ── */
        var cards = allSchemes.map(function (s, i) {
          return [
            '<div class="sch-card" data-idx="' + i + '">',
              '<div class="sch-card-row">',
                '<span class="sch-card-label">Scheme</span>',
                '<span class="sch-card-value sch-card-scheme">' + esc(s.scheme_code || s.scheme_unique_code) + '</span>',
              '</div>',
              '<div class="sch-card-row">',
                '<span class="sch-card-label">Customer</span>',
                '<span class="sch-card-value">' + esc(s.party_name || '-') + '</span>',
              '</div>',
              '<div class="sch-card-row">',
                '<span class="sch-card-label">Code</span>',
                '<span class="sch-card-value">' + esc(s.scheme_unique_code || '-') + '</span>',
              '</div>',
              '<div class="sch-card-row">',
                '<span class="sch-card-label">Amount</span>',
                '<span class="sch-card-value">&#8377;' + fmtAmount(s.scheme_amount) + '</span>',
              '</div>',
              '<div class="sch-card-row">',
                '<span class="sch-card-label">Status</span>',
                '<span class="sch-card-value">' + statusBadge(s.scheme_status) + '</span>',
              '</div>',
              '<div class="sch-card-chevron">&#8250;</div>',
            '</div>'
          ].join('');
        }).join('');

        /* ── Desktop table view ── */
        var rows = allSchemes.map(function (s, i) {
          return [
            '<tr class="sch-clickable-row" data-idx="' + i + '">',
              '<td class="sch-scheme-cell">' + esc(s.scheme_code || s.scheme_unique_code) + '</td>',
              '<td>' + esc(s.party_name || '-') + '</td>',
              '<td>' + esc(s.scheme_unique_code || '-') + '</td>',
              '<td>&#8377;' + fmtAmount(s.scheme_amount) + '</td>',
              '<td>' + statusBadge(s.scheme_status) + '</td>',
            '</tr>'
          ].join('');
        }).join('');

        inner.innerHTML = [
          '<p class="sch-section-title">Enrolled Schemes</p>',

          /* Desktop table */
          '<div class="sch-table-wrap">',
            '<table class="sch-table">',
              '<thead><tr>',
                '<th>Scheme</th>',
                '<th>Customer Name</th>',
                '<th>Code</th>',
                '<th>Scheme Amount</th>',
                '<th>Status</th>',
              '</tr></thead>',
              '<tbody>' + rows + '</tbody>',
            '</table>',
          '</div>',

          /* Mobile cards */
          '<div class="sch-cards">' + cards + '</div>',

          '<div class="sch-enroll-bar">',
            '<a href="' + ENROLL_URL + '">Enroll New Scheme</a>',
          '</div>'
        ].join('');

        /* Row click — desktop table */
        inner.querySelectorAll('.sch-clickable-row').forEach(function (tr) {
          tr.addEventListener('click', function () {
            renderDetail(allSchemes[parseInt(this.dataset.idx, 10)]);
          });
        });

        /* Row click — mobile cards */
        inner.querySelectorAll('.sch-card').forEach(function (card) {
          card.addEventListener('click', function () {
            renderDetail(allSchemes[parseInt(this.dataset.idx, 10)]);
          });
        });
      }

      function renderDetail(scheme) {
        var details = scheme.scheme_monthly_details || [];

        /* ── Mobile cards for detail ── */
        var detailCards = details.map(function (d) {
          return [
            '<div class="sch-card sch-card--detail">',
              '<div class="sch-card-row">',
                '<span class="sch-card-label">Status</span>',
                '<span class="sch-card-value">' + paymentBadge(d.payment_made) + '</span>',
              '</div>',
              '<div class="sch-card-row">',
                '<span class="sch-card-label">Due Date</span>',
                '<span class="sch-card-value">' + fmtDate(d.due_date) + '</span>',
              '</div>',
              '<div class="sch-card-row">',
                '<span class="sch-card-label">Month Amount</span>',
                '<span class="sch-card-value">&#8377;' + fmtAmount(d.month_amount) + '</span>',
              '</div>',
              '<div class="sch-card-row">',
                '<span class="sch-card-label">Paid On</span>',
                '<span class="sch-card-value">' + fmtDate(d.paid_on_date) + '</span>',
              '</div>',
              '<div class="sch-card-row">',
                '<span class="sch-card-label">Delay</span>',
                '<span class="sch-card-value">' + (d.delay_days !== null && d.delay_days !== undefined ? d.delay_days : 0) + '</span>',
              '</div>',
              '<div class="sch-card-row">',
                '<span class="sch-card-label">Days Held</span>',
                '<span class="sch-card-value">' + (d.days_held !== null && d.days_held !== undefined ? d.days_held : '-') + '</span>',
              '</div>',
              '<div class="sch-card-row">',
                '<span class="sch-card-label">Applied Rate</span>',
                '<span class="sch-card-value">' + (d.applied_rate !== null && d.applied_rate !== undefined ? d.applied_rate : '-') + '</span>',
              '</div>',
            '</div>'
          ].join('');
        }).join('');

        /* ── Desktop table rows for detail ── */
        var rows = details.map(function (d) {
          return [
            '<tr>',
              '<td>' + paymentBadge(d.payment_made) + '</td>',
              '<td>' + fmtDate(d.due_date) + '</td>',
              '<td>&#8377;' + fmtAmount(d.month_amount) + '</td>',
              '<td>' + fmtDate(d.paid_on_date) + '</td>',
              '<td>' + (d.delay_days !== null && d.delay_days !== undefined ? d.delay_days : 0) + '</td>',
              '<td>' + (d.days_held !== null && d.days_held !== undefined ? d.days_held : '-') + '</td>',
              '<td>' + (d.applied_rate !== null && d.applied_rate !== undefined ? d.applied_rate : '-') + '</td>',
            '</tr>'
          ].join('');
        }).join('');

        var displayName = scheme.scheme_display_name ||
          (esc(scheme.scheme_unique_code) + ' | ' + esc(scheme.scheme_code));

        inner.innerHTML = [
          '<div class="myaccount-scheme-buttons">',
          '<button class="sch-back-btn" id="sch-back">&#8592;</button>',
          '<p class="sch-section-title">' + esc(displayName) + '</p>',
          '</div>',

          /* Desktop table */
          '<div class="sch-table-wrap">',
            '<table class="sch-table">',
              '<thead><tr>',
                '<th>Status</th>',
                '<th>Due Date</th>',
                '<th>Month Amount</th>',
                '<th>Paid On</th>',
                '<th>Delay</th>',
                '<th>Days Held</th>',
                '<th>Applied Rate</th>',
              '</tr></thead>',
              '<tbody>' + rows + '</tbody>',
            '</table>',
          '</div>',

          /* Mobile cards */
          '<div class="sch-cards">' + detailCards + '</div>',

          '<div class="sch-enroll-bar">',
            '<a href="' + ENROLL_URL + '">Enroll New Scheme</a>',
          '</div>'
        ].join('');

        document.getElementById('sch-back').addEventListener('click', renderList);
      }

      function renderError(msg) {
        inner.innerHTML = '<div class="sch-error">' + msg + '</div>';
      }

      function statusBadge(status) {
        return status === 1
          ? '<span class="sch-badge sch-badge--active">Active</span>'
          : '<span class="sch-badge sch-badge--inactive">Inactive</span>';
      }

      function paymentBadge(made) {
        return made
          ? '<span class="sch-badge sch-badge--paid">Paid</span>'
          : '<span class="sch-badge sch-badge--pending">Pending</span>';
      }

      function fmtAmount(val) {
        if (val === null || val === undefined) return '0';
        return Number(val).toLocaleString('en-IN');
      }

      function fmtDate(str) {
        if (!str) return '-';
        var d = new Date(str);
        if (isNaN(d.getTime())) return '-';
        return (d.getMonth() + 1) + '/' + d.getDate() + '/' + d.getFullYear();
      }

      function esc(str) {
        if (!str) return '';
        return String(str)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

    })();
  </script>

  <script>
    window.WISHLIST_CUSTOMER_ID = '{{ customer.id }}';
    const WISHLIST_PROXY_URL = 'https://wishlist-list-items-385594025448.asia-south1.run.app';

    document.addEventListener('DOMContentLoaded', function () {
      const root = document.getElementById('wishlist-root');
      if (!root) return;

      const customerId = root.dataset.customerId;
      fetch(`${WISHLIST_PROXY_URL}?customer_id=${customerId}`)
        .then((res) => res.json())
        .then((data) => {
          if (!data || !data.result || data.result.length === 0) {
            root.innerHTML =
              "<div class='empty-wishlist'><img src='https://s3.amazonaws.com/cdn.myshopapps.com/iwish/drawer/empty-heart.png' alt='wishlist-empty'><p>No items in your wishlist</p><div class='subtitle'>Your dream jewelry awaits — start curating your wishlist!</div><a href='/collections/jewelry' class='primary-button'>Explore Now</a></div>";
            return;
          }
          renderWishlist(data.result);
        })
        .catch((err) => {
          console.error('Wishlist error:', err);
          root.innerHTML = '<p>Unable to load wishlist.</p>';
        });
    });

    function renderWishlist(items) {
      const root = document.getElementById('wishlist-root');
      let html = `<div class="wishlist-grid">`;

      items.forEach((item) => {
        const productUrl = `/products/${item.handle}`;
        const image = item.variant?.image || item.featuredImage;
        const price = item.variant?.price;
        const compare = item.variant?.compareAtPrice;

        html += `
        <div class="wishlist-card" data-variant-id="${item.variant.id}">
          <button
            type="button"
            class="wishlist-remove"
            onclick="removeWishlistItem('${item.variant.id}')"
          >
            <svg width="15" height="17" viewBox="0 0 15 17" fill="none">
              <path d="M2.80775 16.8845C2.30908 16.8845 1.88441 16.7115 1.53375 16.3655C1.18308 16.0195 1.00775 15.5978 1.00775 15.1005V2.3845H0.123242V0.884521H4.62324V0.0577698H10.3925V0.884521H14.8925V2.3845H14.008V15.1005C14.008 15.5992 13.8327 16.0212 13.482 16.3665C13.1313 16.7118 12.7064 16.8845 12.2072 16.8845H2.80775ZM12.508 2.3845H2.50775V15.1005C2.50775 15.1965 2.53675 15.2735 2.59475 15.3315C2.65275 15.3895 2.72375 15.4185 2.80775 15.4185H12.2072C12.2906 15.4185 12.3614 15.3895 12.4197 15.3315C12.4781 15.2735 12.5072 15.1965 12.5072 15.1005V2.3845H12.508ZM4.69225 13.4185H6.19225V4.38452H4.69225V13.4185ZM8.82324 13.4185H10.3232V4.38452H8.82324V13.4185Z" fill="#666666"/>
            </svg>
          </button>

          <div class="wishlist-img">
            <a href="${productUrl}">
              <img src="${image}" alt="${item.title}">
            </a>
          </div>

          <div class="wishlist-info">
            <div class="wishlist-title">
              <a href="${productUrl}" class="product-title">${item.title}</a>
            </div>
            <div class="wishlist-price">
              ₹${Number(price).toLocaleString('en-IN')}
              ${compare ? `<span class="compare">₹${Number(compare).toLocaleString('en-IN')}</span>` : ''}
            </div>
          </div>
        </div>
      `;
      });

      html += `</div>`;
      root.innerHTML = html;
    }

    function removeWishlistItem(variantId) {
      const card = document.querySelector(`.wishlist-card[data-variant-id="${variantId}"]`);
      if (card) {
        card.remove();
      }

      const remaining = document.querySelectorAll('.wishlist-card');
      if (remaining.length === 0) {
        document.getElementById('wishlist-root').innerHTML =
          "<div class='empty-wishlist'><img src='https://s3.amazonaws.com/cdn.myshopapps.com/iwish/drawer/empty-heart.png' alt='wishlist-empty'><p>No items in your wishlist</p><div class='subtitle'>Your dream jewelry awaits — start curating your wishlist!</div><a href='/collections/jewelry' class='primary-button'>Explore Now</a></div>";
      }

      const counters = document.querySelectorAll('.iwish-counter');
      counters.forEach((counter) => {
        let currentCount = parseInt(counter.innerText) || 0;
        if (currentCount > 0) {
          currentCount = currentCount - 1;
          counter.innerText = currentCount;
        }
        if (currentCount === 0) {
          const parentWrapper = counter.closest('.iw-count-show') || document.querySelectorAll('.iw-count-show');
          if (parentWrapper instanceof NodeList) {
            parentWrapper.forEach((wrap) => (wrap.style.display = 'none'));
          } else if (parentWrapper) {
            parentWrapper.style.display = 'none';
          }
        }
      });

      updateAppStorage(variantId);
      const formData = new FormData();
      formData.append('customer_id', window.WISHLIST_CUSTOMER_ID);
      formData.append('variant_id', variantId);

      fetch(WISHLIST_PROXY_URL, {
        method: 'POST',
        body: formData,
      })
        .then((res) => res.json())
        .then((data) => {
          console.log('Wishlist delete response:', data);
        })
        .catch((err) => {
          console.error('Wishlist delete failed:', err);
        });
    }

    function updateAppStorage(variantId) {
      const vId = parseInt(variantId);
      const storageKeys = ['iwish_list', 'iWishList', '__iwish', 'my_wishlist'];

      storageKeys.forEach((key) => {
        const storedData = localStorage.getItem(key);
        if (storedData) {
          try {
            let items = JSON.parse(storedData);
            if (Array.isArray(items)) {
              const newItems = items.filter((id) => parseInt(id) !== vId);
              localStorage.setItem(key, JSON.stringify(newItems));
            } else if (typeof items === 'object') {
              delete items[vId];
              localStorage.setItem(key, JSON.stringify(items));
            }
          } catch (e) {}
        }
      });

      if (typeof iWish !== 'undefined' && iWish.products) {
        if (Array.isArray(iWish.products)) {
          iWish.products = iWish.products.filter((id) => parseInt(id) !== vId);
        }
      }
    }
  </script>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const mobileBreadcrumb = document.getElementById('mobileBreadcrumbLink');
    const breadcrumbText = document.getElementById('mobileBreadcrumbText');
    const drawerOverlay = document.getElementById('drawerOverlay');
    const accountDrawer = document.getElementById('accountDrawer');
    const drawerClose = document.getElementById('drawerClose');
    const tabLabels = document.querySelectorAll('.customer_tab');

    let currentActiveTab = 'My Orders';

    function openDrawer() {
      accountDrawer.classList.add('drawer-open');
      drawerOverlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      accountDrawer.classList.remove('drawer-open');
      drawerOverlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    if (mobileBreadcrumb) {
      mobileBreadcrumb.addEventListener('click', function (e) {
        e.preventDefault();
        openDrawer();
      });
    }

    if (drawerClose) {
      drawerClose.addEventListener('click', closeDrawer);
    }

    if (drawerOverlay) {
      drawerOverlay.addEventListener('click', closeDrawer);
    }

    tabLabels.forEach((label) => {
      label.addEventListener('click', function () {
        const tabText = label.querySelector('.customer_tab_option span');
        if (tabText) {
          currentActiveTab = tabText.textContent.trim();
          if (breadcrumbText) {
            breadcrumbText.textContent = currentActiveTab;
          }
        }

        if (window.innerWidth < 750) {
          setTimeout(closeDrawer, 300);
        }
      });
    });

    const contents = {
      tab_my_orders: document.getElementById('tab_my_orders_content'),
      tab_personal_info: document.getElementById('tab_personal_info_content'),
      tab_my_wishlists: document.getElementById('tab_wishlist_content'),
      tab_refer_earn: document.getElementById('tab_refer_earn_content'),
      tab_offers: document.getElementById('tab_offers_content'),
      tab_earn_rewards: document.getElementById('tab_earn_rewards_content'),
      tab_education: document.getElementById('tab_education_content'),
      tab_schemes: document.getElementById('tab_schemes_content'),
    };

    function activateTabById(tabId) {
      const radio = document.getElementById(tabId);
      if (radio) radio.checked = true;

      tabLabels.forEach((l) => {
        const target = l.getAttribute('for');
        if (target === tabId) l.classList.add('active');
        else l.classList.remove('active');
      });

      Object.values(contents).forEach((c) => c && c.classList.remove('active'));
      const contentId = tabId + '_content';
      const matched = document.getElementById(contentId);
      if (matched) matched.classList.add('active');
    }

    (function init() {
      const checked = document.querySelector('.customer_tab_input:checked');
      if (checked) activateTabById(checked.id);
      else activateTabById('tab_my_orders');
    })();

    tabLabels.forEach((label) => {
      label.addEventListener('click', function (e) {
        const target = label.getAttribute('for');
        if (!target) return;
        setTimeout(() => activateTabById(target), 0);
      });
    });

    const radios = document.querySelectorAll('.customer_tab_input');
    radios.forEach((r) => r.addEventListener('change', () => activateTabById(r.id)));

    document.body.addEventListener('click', function (e) {
      const el = e.target.closest('[data-open-tab]');
      if (!el) return;
      e.preventDefault();
      const tabToOpen = el.getAttribute('data-open-tab');
      if (!tabToOpen) return;
      activateTabById(tabToOpen);
      const targetContent = document.getElementById(tabToOpen + '_content');
      if (targetContent) {
        const firstFocusable = targetContent.querySelector('input, button, a, [tabindex]:not([tabindex="-1"])');
        if (firstFocusable) firstFocusable.focus();
      }
    });
  });
</script>

<script>
  (function () {
    const root = document.getElementById('tab_my_orders_content');
    if (!root) return;

    const searchInput = root.querySelector('#order-search');
    const statusSelect = root.querySelector('#order-status');
    const cards = Array.from(root.querySelectorAll('.order-card'));

    if (!statusSelect || !cards.length) return;

    const rawStatuses = new Set();

    cards.forEach((card) => {
      const s = (card.dataset.status || '').trim();
      if (s) rawStatuses.add(s.toLowerCase());
    });

    const preferredOrder = ['unfulfilled', 'fulfilled', 'cancelled'];

    const sortedStatuses = Array.from(rawStatuses).sort((a, b) => {
      const ia = preferredOrder.indexOf(a);
      const ib = preferredOrder.indexOf(b);
      const rankA = ia === -1 ? 999 : ia;
      const rankB = ib === -1 ? 999 : ib;
      if (rankA !== rankB) return rankA - rankB;
      return a.localeCompare(b);
    });

    sortedStatuses.forEach((status) => {
      const option = document.createElement('option');
      option.value = status;
      option.textContent = status.replace(/[_-]+/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
      statusSelect.appendChild(option);
    });

    function applyFilters() {
      const q = ((searchInput && searchInput.value) || '').trim().toLowerCase();
      const s = statusSelect.value;

      cards.forEach((card) => {
        const txt = (card.dataset.search || '').toLowerCase();
        const cardStatus = (card.dataset.status || '').toLowerCase();

        const matchText = q ? txt.includes(q) : true;
        const matchStatus = s ? cardStatus === s : true;

        card.hidden = !(matchText && matchStatus);
      });
    }

    let t;
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        clearTimeout(t);
        t = setTimeout(applyFilters, 120);
      });
    }

    statusSelect.addEventListener('change', applyFilters);

    applyFilters();
  })();
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const root = document.getElementById('tab_my_orders_content');
    if (!root) return;

    const cards = Array.from(root.querySelectorAll('.order-card'));

    const STATUS_STYLES = {
      1: { label: 'Order Confirmed', className: 'status-chip--confirmed' },
      2: { label: 'Processing', className: 'status-chip--processing' },
      3: { label: 'Manufacturing', className: 'status-chip--manufacturing' },
      13: { label: 'Quality Control', className: 'status-chip--qc' },
      4: { label: 'Certification', className: 'status-chip--certification' },
      5: { label: 'Dispatch', className: 'status-chip--dispatch' },
      6: { label: 'In Transit', className: 'status-chip--in-transit' },
    };

    cards.forEach(function (card) {
      const marketplaceOrderId = card.dataset.marketplaceOrderId;
      const marketplaceItemId = card.dataset.marketplaceItemId;
      const statusSpan = card.querySelector('.ornaverse-status');

      if (!statusSpan || !marketplaceOrderId || !marketplaceItemId) return;

      const shopifyStatus = (card.dataset.status || '').toLowerCase();

      if (shopifyStatus === 'fulfilled' || shopifyStatus === 'cancelled') {
        return;
      }

      statusSpan.textContent = 'Fetching live status…';
      const chip = statusSpan.closest('.order-status-chip') || statusSpan;
      chip.classList.add('order-status-chip');

      fetch('https://lucira-orders-api-385594025448.asia-south1.run.app', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          marketplace_order_id: Number(marketplaceOrderId),
          marketplace_item_id: Number(marketplaceItemId),
        }),
      })
        .then(function (r) {
          return r.json();
        })
        .then(function (data) {
          console.log('Ornaverse Live Status Response:', data);

          if (!data || !data.success || !data.data || data.data.Error) {
            statusSpan.textContent = 'Status unavailable';
            chip.classList.remove(
              'status-chip--confirmed',
              'status-chip--processing',
              'status-chip--manufacturing',
              'status-chip--qc',
              'status-chip--certification',
              'status-chip--dispatch',
              'status-chip--in-transit'
            );
            return;
          }

          const statusId = Number(data.data.order_status_id);
          const info = STATUS_STYLES[statusId];

          if (!info) {
            statusSpan.textContent = 'Unknown Status';
            chip.classList.remove(
              'status-chip--confirmed',
              'status-chip--processing',
              'status-chip--manufacturing',
              'status-chip--qc',
              'status-chip--certification',
              'status-chip--dispatch',
              'status-chip--in-transit'
            );
            return;
          }

          statusSpan.textContent = info.label;
          chip.classList.remove(
            'status-chip--confirmed',
            'status-chip--processing',
            'status-chip--manufacturing',
            'status-chip--qc',
            'status-chip--certification',
            'status-chip--dispatch',
            'status-chip--in-transit'
          );
          chip.classList.add(info.className);
        })
        .catch(function (err) {
          console.error('Ornaverse error', err);
          statusSpan.textContent = 'Status unavailable';
        });
    });
  });
</script>

