    </div>
    <div class="acc-content acc-content-offers-info">
      {% render 'account-offers' %}
    </div>
  </div>
</div>

<script>
  function accMobileClearTabSelection() {
    const radios = document.querySelectorAll('input[name="acc-tab"]');
    radios.forEach((radio) => (radio.checked = false));

    // Remove "open-acc" class from all tabs when going back
    document.querySelectorAll('.acc-tab').forEach((tab) => {
      tab.classList.remove('open-acc');
    });
  }

  function handleGTMLogout(event) {
    event.preventDefault();
    console.log(event.target.dataset);
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'logout',
      logout: {
        mobile: event.target.dataset.mobile,
        email: event.target.dataset.email,
      },
    });
    window.location.assign(event.target.href);
  }

  // Add click event listeners to tabs
  document.addEventListener('DOMContentLoaded', function () {
    const tabs = document.querySelectorAll('.acc-tab');

    tabs.forEach((tab) => {
      tab.addEventListener('click', function () {
        // Remove "open-acc" class from all tabs
        tabs.forEach((t) => t.classList.remove('open-acc'));

        // Add "open-acc" class to clicked tab
        this.classList.add('open-acc');
      });
    });

    // Set initial "open-acc" class if a tab is already checked
    const checkedRadio = document.querySelector('input[name="acc-tab"]:checked');
    if (checkedRadio) {
      const tabId = checkedRadio.id;
      const activeTab = document.querySelector(`label[for="${tabId}"]`);
      if (activeTab) {
        activeTab.classList.add('open-acc');
      }
    }
  });
</script>

<style>
    .faq-terms-section { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; }

    @media screen and (max-width: 767px) {
        .faq-terms-section {
            padding-top: {{ section.settings.padding_top_mobile }}px;
            padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
        }
    }

    .faq-terms-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    .faq-terms-tabs { display: flex; overflow: hidden; background: #F2F2F2; width: 100%; justify-content: center; border-radius: 50px; margin: 4px; }
    .account .tab-button { width: 50%; border: none; padding: 15px 20px; cursor: pointer; text-align: center; font-family: 'Futura Std', sans-serif; font-weight: 400; font-size: 16px; line-height: 20px; letter-spacing: 1px; }
    .tab-button.active { background-color: {{ section.settings.tab_active_bg_color }}; color: {{ section.settings.tab_active_text_color }}; font-weight: 500; border-radius: 44px; }
    .tab-content { display: none; padding: 20px; padding-bottom: 0; border-radius: 0 0 4px 4px; }
    .tab-content.active { display: block; }
    .faq-item { border-radius: 8px; background: #f4f0f0; margin-bottom: 25px; padding: 20px; padding-bottom: 15px; }
    .faq-item:last-child { border-bottom: none; margin-bottom: 0; }
    .faq-question { font-family: 'Futura Std', sans-serif; font-weight: 500; font-size: 16px; line-height: 150%; letter-spacing: 1%; text-transform: capitalize; color: {{ section.settings.faq_question_color }}; cursor: pointer; position: relative; padding-right: 30px; transition: all 0.3s ease; }
    .faq-question:after { content: '+'; position: absolute; right: 5px; font-size: 20px; transition: transform 0.3s ease; }
    .faq-question.active:after { content: '−'; }
    .faq-answer { display: none; padding-top: 10px; font-family: 'Futura Std', sans-serif; font-weight: 400; font-size: 16px; line-height: 150%; letter-spacing: 2%; text-transform: capitalize; color: {{ section.settings.faq_answer_color }}; }
    .terms-content { background: {{ section.settings.terms_bg_color }}; padding: 20px; color: {{ section.settings.terms_text_color }}; }
    .acc-personal-tab-buttons label {flex: 1; cursor: pointer; padding: 1.4rem 1rem !important; text-align: center; border-radius: 3rem; font-family: 'Futura Std', sans-serif; font-weight: 500; font-size: 16px !important; line-height: 20px; letter-spacing: 0.7px !important; vertical-align: middle;}
    #tab-info:checked ~ .acc-personal-tab-buttons label[for="tab-info"] {color: #3C2C2A;}
    .acc-personal-tab-buttons {padding: 4px !important;}
    .acc-personal-tab-buttons label {color: #666666;}
    .acc-form-group input[type="text"], .acc-form-group input[type="email"], .acc-form-group input[type="date"] {border: 0; border-radius: 8px; width: 100%; font-size: 14px !important; padding: 13px 16px !important; color: #666666 !important; font-family: 'Futura Std', sans-serif; letter-spacing: 0.7px;}
    .acc-form-group {margin-bottom: 4px;}
    strong { font-weight: 600; }
    @media(max-width:768px) {
        .account .faq-btn{margin:0}
        .account .tab-button{display:block;padding:8px 12px;font-size:12px;line-height:normal}
        .faq-terms-container{padding:0 16px}
        .acc-account { display: grid ; grid-template-columns: 1fr; gap: 0; padding: 0; width: 100%; }
        .tab-content.active {padding: 0 0px;}
    }
</style>

