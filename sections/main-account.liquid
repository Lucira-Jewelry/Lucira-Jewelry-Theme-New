{{ 'customer.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'main-account-custom.css' | asset_url | stylesheet_tag: preload: true }}

{%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    #tab_my_orders_content,#tab_personal_info_content{display:none}
    #tab_my_orders_content.active,#tab_personal_info_content.active{display:block}
    .customer_tab.active{background:#f5f5f5}
    @media screen and (max-width:749px){
    .mobile-breadcrumb{width:100%;background:#f5f5f5;padding:16px 20px;z-index:100;border-bottom:1px solid #e0e0e0;display:flex;align-items:center;gap:12px}
    .mobile-breadcrumb-link{display:flex;align-items:center;gap:8px;text-decoration:none;color:#333;font-size:16px;font-weight:500}
    .mobile-breadcrumb-link svg{width:20px;height:20px}
    .drawer-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.5);z-index:998;opacity:0;visibility:hidden;transition:opacity .3s ease,visibility .3s ease}
    .drawer-overlay.active{opacity:1;visibility:visible}
    .customer__tabs{position:absolute;top:0;left:-100%;width:100%;height:100vh;background:#fff;z-index:9999999;overflow-y:auto;transition:left .3s ease;box-shadow:2px 0 12px rgba(0,0,0,.15)}
    .customer__tabs.drawer-open{left:0}
    .drawer-close{position:absolute;top:16px;right:16px;background:0 0;border:none;padding:8px;cursor:pointer;z-index:10; display: flex !important;}
    .drawer-close svg{width:24px;height:24px}
    .customer__tabs .customer__title{padding-top:60px}
    .customer__details{padding-top:80px}
    div#tab_my_orders_content { padding: 0; margin-top: 0; }
    .customer__details h2 {display: none;}
    }
    @media screen and (min-width:750px){
    .drawer-close,.drawer-overlay,.mobile-breadcrumb{display:none}
    .customer__tabs{position:relative;left:0;width:auto;height:auto;box-shadow:none}
    .drawer-close{position:absolute;top:16px;right:16px;background:0 0;border:none;padding:8px;cursor:pointer;z-index:10; display: none !important;}
    .drawer-close svg{width:24px;height:24px}
    }
    .order-status-chip{display:inline-flex;align-items:center;gap:4px;border-radius:999px;font-size:12px;line-height:1.2;font-weight:500;text-transform:none;background:#f0f0f0;color:#333}
    .order-status-label{font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.04em}
    .status-chip--delivered span{color:#1c7c3c}
    .status-chip--cancelled span{color:#b22626}
    .status-chip--confirmed span{color:#204a9c}
    .status-chip--processing span{color:#b46911}
    .status-chip--manufacturing span{color:#5c2ca0}
    .status-chip--qc span{color:#0b5c95}
    .status-chip--certification span{color:#0b6776}
    .status-chip--dispatch span{color:#aa4b0b}
    .status-chip--in-transit span{color:#214f9d}


    /* style for scheme tab */
   /* ─── Layout ─────────────────────────────────────────── */
.customer_details_schemes #schemes-wrapper {
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 1px 8px rgba(0,0,0,0.07);
  padding: 28px 32px;
  min-height: 200px;
}

/* ─── Loader ─────────────────────────────────────────── */
.customer_details_schemes .sch-loader {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 60px 0;
  color: #888;
  font-size: 15px;
}

.customer_details_schemes .sch-spinner {
  width: 22px;
  height: 22px;
  border: 3px solid #e8d8d2;
  border-top-color: #b87a6a;
  border-radius: 50%;
  animation: sch-spin 0.8s linear infinite;
  flex-shrink: 0;
}

@keyframes sch-spin { to { transform: rotate(360deg); } }

/* ─── Empty State ────────────────────────────────────── */
.customer_details_schemes .sch-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  text-align: center;
}

.customer_details_schemes .sch-empty h3 {
  font-size: 18px;
  font-weight: 500;
  color: #1a1a1a;
  margin: 0 0 8px;
}

.customer_details_schemes .sch-empty p {
  color: #888;
  font-size: 14px;
  margin: 0 0 20px;
}

/* ─── Section Title ──────────────────────────────────── */
.customer_details_schemes .sch-section-title {
  font-size: 16px;
  font-weight: 500;
  color: #1a1a1a;
  text-transform: uppercase;
  margin: 0 0 20px;
  letter-spacing: 1px;
}

/* ─── Table wrapper ──────────────────────────────────── */
.customer_details_schemes .sch-table-wrap {
  width: 100%;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

/* ─── Table ──────────────────────────────────────────── */
.customer_details_schemes .sch-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 480px;
}

.customer_details_schemes .sch-table th {
  text-align: left;
  font-size: 13px;
  font-weight: 600;
  color: #b87a6a;
  padding: 0 12px 12px 0;
  border-bottom: 2px solid #f0e8e5;
  white-space: nowrap;
}

.customer_details_schemes .sch-table td:first-child {
  color: #b87a6a;
  font-weight: 600;
  padding-left: 12px;
}

.customer_details_schemes .sch-table td {
  padding: 14px 12px 14px 0;
  font-size: 14px;
  color: #1a1a1a;
  border-bottom: 1px solid #f7f2f0;
  vertical-align: middle;
}

.customer_details_schemes .sch-table tr:last-child td { border-bottom: none; }

/* ─── Clickable row ──────────────────────────────────── */
.customer_details_schemes .sch-clickable-row {
  cursor: pointer;
  transition: background 0.15s;
}

.customer_details_schemes .sch-clickable-row:hover { background: #fdf6f4; }

.customer_details_schemes .sch-scheme-cell {
  color: #b87a6a;
  font-weight: 600;
}

/* ─── Mobile card list ───────────────────────────────── */
.customer_details_schemes .sch-cards { display: none; }

.customer_details_schemes .sch-card {
  border: 1px solid #f0e8e5;
  border-radius: 10px;
  padding: 14px 16px;
  margin-bottom: 12px;
  cursor: pointer;
  position: relative;
  transition: background 0.15s, box-shadow 0.15s;
}

.customer_details_schemes .sch-card:hover {
  background: #fdf6f4;
  box-shadow: 0 2px 8px rgba(184,122,106,0.1);
}

.customer_details_schemes .sch-card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 5px 0;
  border-bottom: 1px solid #f7f2f0;
  gap: 8px;
}

.customer_details_schemes .sch-card-row:last-of-type { border-bottom: none; }

.customer_details_schemes .sch-card-label {
  font-size: 12px;
  font-weight: 600;
  color: #b87a6a;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  flex-shrink: 0;
  min-width: 100px;
}

.customer_details_schemes .sch-card-value {
  font-size: 13px;
  color: #333;
  text-align: right;
  word-break: break-word;
}

.customer_details_schemes .sch-card-scheme {
  color: #b87a6a;
  font-weight: 600;
}

.customer_details_schemes .sch-card-chevron {
  position: absolute;
  top: 50%;
  right: 14px;
  transform: translateY(-50%);
  font-size: 22px;
  color: #ccc;
  pointer-events: none;
}

.customer_details_schemes .sch-card--detail { cursor: default; }
.customer_details_schemes .sch-card--detail:hover { background: #fff; box-shadow: none; }

/* ─── Badges ─────────────────────────────────────────── */
.customer_details_schemes .sch-badge {
  display: inline-block;
  border-radius: 20px;
  padding: 4px 12px;
  font-size: 12px;
  font-weight: 600;
  white-space: nowrap;
}

.customer_details_schemes .sch-badge--active   { background: #22c55e; color: #fff; }
.customer_details_schemes .sch-badge--inactive { background: #ef4444; color: #fff; }
.customer_details_schemes .sch-badge--paid     { background: #22c55e; color: #fff; }
.customer_details_schemes .sch-badge--pending  { background: #f59e0b; color: #fff; }

/* ─── Back button ────────────────────────────────────── */
.customer_details_schemes .sch-back-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 14px;
  color: white;
  cursor: pointer;
  margin-bottom: 18px;
  background: #b87a6a;
  border: none;
  padding: 0;
  font-weight: 500;
  font-family: inherit;
  border-radius:50px;
  min-width:40px;
  min-height:40px;
}
.customer_details_schemes .myaccount-scheme-buttons
  {
    display: flex;
    align-items: center;
    gap: 20px;
}

.customer_details_schemes .schemes-wrapper .customer button {
  background-color: #8a5548;
}

/* ─── Bottom enroll bar ──────────────────────────────── */
.customer_details_schemes .sch-enroll-bar { margin-top: 24px; display: flex; justify-content: center; }

.customer_details_schemes .sch-enroll-bar a,
.customer_details_schemes .sch-enroll-btn {
  display: block;
  width: 50%;
  text-align: center;
  background: #b87a6a;
  color: #fff;
  padding: 14px;
  border-radius: 12px;
  font-size: 15px;
  text-decoration: none;
  cursor: pointer;
  border: none;
  font-family: inherit;
  transition: background 0.2s;
  box-sizing: border-box;
}

.customer_details_schemes .sch-enroll-bar a { color: white; }

.customer_details_schemes .sch-enroll-bar a:hover,
.customer_details_schemes .sch-enroll-btn:hover { background: #a0685a; color: #fff; }

/* ─── Error ──────────────────────────────────────────── */
.customer_details_schemes .sch-error {
  text-align: center;
  padding: 40px 20px;
  color: #ef4444;
  font-size: 14px;
  line-height: 1.6;
}

/* ═══════════════════════════════════════════════════════
   RESPONSIVE BREAKPOINTS
═══════════════════════════════════════════════════════ */

@media (max-width: 768px) {
  .customer_details_schemes #schemes-wrapper {
    padding: 20px 18px;
    border-radius: 8px;
  }

  .customer_details_schemes .sch-section-title { font-size: 14px; }

  .customer_details_schemes .sch-table th,
  .customer_details_schemes .sch-table td {
    font-size: 13px;
    padding-right: 10px;
  }
}

@media (max-width: 600px) {
  .customer_details_schemes #schemes-wrapper {
    padding: 16px 12px;
    border-radius: 0;
    box-shadow: none;
    border-top: 1px solid #f0e8e5;
    border-bottom: 1px solid #f0e8e5;
  }

  .customer_details_schemes .sch-table-wrap { display: none; }
  .customer_details_schemes .sch-cards      { display: block; }

  .customer_details_schemes .sch-section-title { font-size: 13px; margin-bottom: 14px; }

  .customer_details_schemes .sch-enroll-bar a,
  .customer_details_schemes .sch-enroll-btn { font-size: 14px; padding: 13px; }

  .customer_details_schemes .sch-back-btn { font-size: 13px; margin-bottom: 14px;border-radius:50px; }

  .customer_details_schemes .sch-badge { font-size: 11px; padding: 3px 10px; }

  .customer_details_schemes .sch-loader { padding: 40px 0; font-size: 14px; }
}

@media (max-width: 380px) {
  .customer_details_schemes #schemes-wrapper { padding: 12px 10px; }

  .customer_details_schemes .sch-card { padding: 12px 14px; }

  .customer_details_schemes .sch-card-label { min-width: 85px; font-size: 11px; }
  .customer_details_schemes .sch-card-value { font-size: 12px; }

  .customer_details_schemes .sch-card-chevron { font-size: 18px; right: 10px; }

  .customer_details_schemes .sch-section-title { font-size: 12px; }

  .customer_details_schemes .sch-enroll-bar a,
  .customer_details_schemes .sch-enroll-btn { font-size: 13px; padding: 12px; }
}
{%- endstyle -%}

<div class="mobile-breadcrumb">
  <a href="#" class="mobile-breadcrumb-link" id="mobileBreadcrumbLink">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M15 18l-6-6 6-6"/>
    </svg>
    <span id="mobileBreadcrumbText">My Orders</span>
  </a>
</div>

<div class="drawer-overlay" id="drawerOverlay"></div>

<div class="customer account section-{{ section.id }}-padding">
  <input type="radio" name="customer_tabs" id="tab_my_orders" class="customer_tab_input" hidden checked>
  <input type="radio" name="customer_tabs" id="tab_personal_info" class="customer_tab_input" hidden>
  <input type="radio" name="customer_tabs" id="tab_wishlist" class="customer_tab_input" hidden>
  <input type="radio" name="customer_tabs" id="tab_refer_earn" class="customer_tab_input" hidden>
  <div class="customer__tabs" id="accountDrawer">
    <button class="drawer-close" id="drawerClose" aria-label="Close menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>

    <h1 class="customer__title">{{ 'customer.account.title' | t }}</h1>
    <div class="customer__name">
      <svg class="icon">
        <use xlink:href="#icon-custom"></use>
      </svg>
      <div class="customer_name_wrapper">
        <span>HELLO,</span>
        <span
          ><strong>{{ customer.name | upcase }}</strong></span
        >
      </div>
    </div>

    <div class="customer_tabs_container">
      <label class="customer_tab" for="tab_my_orders">
        <span class="customer_tab_logo">
          {{- 'icon-orders.svg' | inline_asset_content -}}
        </span>
        <span class="customer_tab_option">
          <span>My Orders</span>
          <span class="angle-arrow">{{- 'icon-angle-right.svg' | inline_asset_content -}}</span>
        </span>
      </label>
      <label class="customer_tab" for="tab_personal_info">
        <span class="customer_tab_logo">
          {{- 'icon-account-details.svg' | inline_asset_content -}}
        </span>
        <span class="customer_tab_option"><span>Personal Information</span></span>
      </label>
      <label class="customer_tab" for="tab_wishlist">
        <span class="customer_tab_logo">
          {{- 'icon-wishlist.svg' | inline_asset_content -}}
        </span>
        <span class="customer_tab_option"><span>Wishlist</span></span>
      </label>
      <label class="customer_tab" for="tab_refer_earn">
        <span class="customer_tab_logo">
          {{- 'icon-refer-earn.svg' | inline_asset_content -}}
        </span>
        <span class="customer_tab_option"><span>Refer and Earn</span></span>
      </label>
      <label class="customer_tab" for="tab_offers">
        <span class="customer_tab_logo">
          {{- 'icon-offers.svg' | inline_asset_content -}}
        </span>
        <span class="customer_tab_option"><span>Offers</span></span>
      </label>
      {% comment %}
        <label class="customer_tab" for="tab_earn_rewards">
          <span class="customer_tab_logo">
            {{- 'icon-earn-rewards.svg' | inline_asset_content -}}
          </span>
          <span class="customer_tab_option"><span>Earn Rewards</span></span>
        </label>
      {% endcomment %}
      <label class="customer_tab" for="tab_education">
        <span class="customer_tab_logo">
          {{- 'icon-education.svg' | inline_asset_content -}}
        </span>
        <span class="customer_tab_option"><span>Education</span></span>
      </label>

      <label class="customer_tab" for="tab_schemes">
        <span class="customer_tab_logo">
          {{- 'icon-scheme.svg' | inline_asset_content -}}
        </span>
        <span class="customer_tab_option"><span>Schemes</span></span>
      </label>
    </div>

    <div class="logout-button-wrapper">
      <a href="{{ routes.account_logout_url }}" class="customer_account_logout">
        <span class="svg-wrapper">{{- 'icon-logout.svg' | inline_asset_content -}}</span>
        {{ 'customer.log_out' | t }}
      </a>
    </div>
  </div>

  <div class="customer__details" id="tab_my_orders_content">
    <div>
      <h2>{{ 'customer.orders.title' | t }}</h2>

      <!-- Toolbar -->
      <div class="orders-toolbar">
        <div class="orders-toolbar__search">
          <svg width="20" height="20" viewBox="0 0 25 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <mask id="mask0_5402_9029" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="25" height="24">
            <rect x="0.5" width="24" height="24" fill="#1a1a1a"></rect>
            </mask>
            <g mask="url(#mask0_5402_9029)">
            <path d="M10.0192 15.6152C8.31157 15.6152 6.86541 15.023 5.68074 13.8385C4.49624 12.6538 3.90399 11.2077 3.90399 9.5C3.90399 7.79233 4.49624 6.34617 5.68074 5.1615C6.86541 3.977 8.31157 3.38475 10.0192 3.38475C11.7269 3.38475 13.1731 3.977 14.3577 5.1615C15.5422 6.34617 16.1345 7.79233 16.1345 9.5C16.1345 10.2142 16.0147 10.8963 15.775 11.5463C15.5352 12.1962 15.2152 12.7616 14.8152 13.2423L20.5692 18.9962C20.7077 19.1346 20.7786 19.3086 20.7817 19.5182C20.7849 19.7279 20.7141 19.9052 20.5692 20.05C20.4244 20.1948 20.2487 20.2673 20.0422 20.2673C19.8359 20.2673 19.6603 20.1948 19.5155 20.05L13.7615 14.296C13.2615 14.7088 12.6865 15.0319 12.0365 15.2653C11.3865 15.4986 10.7141 15.6152 10.0192 15.6152ZM10.0192 14.1155C11.3077 14.1155 12.3991 13.6683 13.2932 12.774C14.1876 11.8798 14.6347 10.7885 14.6347 9.5C14.6347 8.2115 14.1876 7.12017 13.2932 6.226C12.3991 5.33167 11.3077 4.8845 10.0192 4.8845C8.73074 4.8845 7.63941 5.33167 6.74524 6.226C5.85091 7.12017 5.40374 8.2115 5.40374 9.5C5.40374 10.7885 5.85091 11.8798 6.74524 12.774C7.63941 13.6683 8.73074 14.1155 10.0192 14.1155Z" fill="#666666"></path>
            </g>
          </svg>
          <input id="order-search" type="search" placeholder="Search here" aria-label="Search orders or products">
        </div>
        <div class="orders-toolbar__status">
          <label for="order-status">Status:</label>
          <select id="order-status">
            <option value="">All</option>
          </select>
        </div>
      </div>

      {% paginate customer.orders by 20 %}
        {% if customer.orders.size > 0 %}
          {%- for order in customer.orders -%}
            {% assign _fulfillment_key = order.fulfillment_status | default: 'unfulfilled' | downcase %}
            {% if order.cancelled %}
              {% assign _status_key = 'cancelled' %}
            {% else %}
              {% assign _status_key = _fulfillment_key %}
            {% endif %}

            {% for line_item in order.line_items %}
              {%- assign _search_blob = line_item.title | append: ' ' | append: order.order_number | downcase -%}

              <div
                class="order-card"
                data-status="{{ _status_key }}"
                data-search="{{ _search_blob | escape }}"
                data-order="{{ order.order_number }}"
                data-marketplace-order-id="{{ order.id }}"
                data-marketplace-item-id="{{ line_item.id }}"
              >
                <div class="order-card__header">
                  <div class="order-info">
                    <div>
                      Order No: <strong>#{{ order.order_number }}</strong>
                    </div>
                    <div>
                      Expected On: <strong>{{ order.created_at | date: '%d %b, %Y' }}</strong>
                    </div>

                    <div>
                      Status:
                      <span
                        class="
                          order-status-chip
                          {% if order.cancelled %}
                            status-chip--cancelled
                          {% elsif order.fulfillment_status == 'fulfilled' %}
                            status-chip--delivered
                          {% endif %}
                        "
                      >
                        <span class="order-status-label">
                          {% if order.cancelled %}
                            Cancelled
                          {% elsif order.fulfillment_status == 'fulfilled' %}
                            Delivered
                          {% else %}
                            <span class="ornaverse-status" aria-live="polite">Fetching live status…</span>
                          {% endif %}
                        </span>
                      </span>
                    </div>
                  </div>
                </div>

                <div class="order-card__items">
                  <img
                    class="order-item__image"
                    src="{{ line_item.image | image_url }}"
                    title="{{ line_item.title }}"
                    alt="{{ line_item.title }}"
                    width="120"
                    height="120"
                  >
                  <div class="order-item__details">
                    <div class="order-item__title">{{ line_item.title }}</div>
                    <div class="order-item__quantity">
                      Quantity: <strong>{{ line_item.quantity }}</strong>
                    </div>
                    <div class="order-item__price">{{ line_item.price | money_without_trailing_zeros }}</div>
                  </div>
                  <div class="order-status-wrapper">
                    <a href="{{ order.customer_url }}" class="order-details-toggle">
                      View Details
                      <svg class="icon" width="8" height="8">
                        <use href="#icon-chevron-right"></use>
                      </svg>
                    </a>
                  </div>
                </div>

                <div class="order-card__actions">
                  <div class="order-actions">
                    <a href="https://luciraonline.myshopify.com/apps/return_prime" class="btn btn-return">
                      <svg class="icon" width="18" height="18">
                        <use href="#icon-undo"></use>
                      </svg>
                      RETURN
                    </a>
                    <a href="{{ line_item.url }}" class="btn btn-reorder">
                      <svg class="icon" width="18" height="18">
                        <use href="#icon-order-again"></use>
                      </svg>
                      ORDER AGAIN
                    </a>
                  </div>
                  <a href="{{ line_item.url }}" class="btn btn-review">
                    <svg class="icon" width="18" height="18">
                      <use href="#icon-rate-review"></use>
                    </svg>
                    REVIEW
                  </a>
                </div>
              </div>
            {% endfor %}
          {%- endfor -%}
        {% else %}
          <div class="no-orders">
            {{- 'no-orders-icon.svg' | inline_asset_content -}}
            <h3>No Orders Yet</h3>
            <p>{{ 'customer.orders.none' | t }}</p>
          </div>
        {% endif %}

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
            <ul role="list">
              {%- if paginate.previous -%}
                <li>
                  <a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">‹</a>
                </li>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                <li>
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}">{{ part.title }}</a>
                  {%- elsif part.title == paginate.current_page -%}
                    <span aria-current="page">{{ part.title }}</span>
                  {%- else -%}
                    <span>{{ part.title }}</span>
                  {%- endif -%}
                </li>
              {%- endfor -%}
              {%- if paginate.next -%}
                <li><a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">›</a></li>
              {%- endif -%}
            </ul>
          </nav>
        {%- endif -%}
      {% endpaginate %}
