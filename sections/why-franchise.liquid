{% comment %}
  Section: Why Lucira Franchise
  File: sections/franchise-why.liquid
{% endcomment %}

<style>
  .franchise-why {
    padding: 80px 50px;
    background-color: #fff;
    max-width: 1400px;
    margin: 0 auto;
  }

  .franchise-why__header {
    text-align: center;
    margin-bottom: 60px;
  }

  .franchise-why__title {
    font-size: 32px;
    font-weight: 400;
    letter-spacing: 2px;
    margin-bottom: 20px;
    text-transform: uppercase;
    color: #333;
  }

  .franchise-why__subtitle {
    font-size: 14px;
    line-height: 1.8;
    color: #666;
    max-width: 800px;
    margin: 0 auto;
  }

  .franchise-why__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    margin-bottom: 50px;
  }

  .franchise-why__card {
    background-color: #f8f5f2;
    padding: 40px 30px;
    border-radius: 8px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .franchise-why__card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .franchise-why__icon {
    width: 80px;
    height: 80px;
    background-color: #9d8b7f;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 25px;
  }

  .franchise-why__icon img {
    width: 40px;
    height: 40px;
    filter: brightness(0) invert(1);
  }

  .franchise-why__card-title {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 15px;
    color: #333;
  }

  .franchise-why__card-text {
    font-size: 13px;
    line-height: 1.6;
    color: #666;
  }

  .franchise-why__button-wrapper {
    text-align: center;
  }

  .franchise-why__button {
    display: inline-block;
    padding: 14px 40px;
    background-color: #9d8b7f;
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 12px;
    border-radius: 4px;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .franchise-why__button:hover {
    background-color: #8a7869;
  }

  @media (max-width: 1024px) {
    .franchise-why__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .franchise-why {
      padding: 60px 30px;
    }

    .franchise-why__title {
      font-size: 26px;
    }

    .franchise-why__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  @media (max-width: 576px) {
    .franchise-why {
      padding: 40px 20px;
    }

    .franchise-why__title {
      font-size: 22px;
    }

    .franchise-why__card {
      padding: 30px 20px;
    }
  }
</style>

<section class="franchise-why">
  <div class="franchise-why__header">
    <h2 class="franchise-why__title">{{ section.settings.title }}</h2>
    <p class="franchise-why__subtitle">{{ section.settings.subtitle }}</p>
  </div>

  <div class="franchise-why__grid">
    {% for block in section.blocks %}
      {% if block.type == 'feature' %}
        <div class="franchise-why__card" {{ block.shopify_attributes }}>
          <div class="franchise-why__icon">
            {% if block.settings.icon != blank %}
              {{ block.settings.icon | image_url: width: 80 | image_tag: alt: block.settings.title }}
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
              </svg>
            {% endif %}
          </div>
          <h3 class="franchise-why__card-title">{{ block.settings.title }}</h3>
          <p class="franchise-why__card-text">{{ block.settings.description }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="franchise-why__button-wrapper">
    {% if section.settings.brochure_file != blank %}
      <a href="{{ section.settings.brochure_file }}" class="franchise-why__button" download>
        {{ section.settings.button_text }}
      </a>
    {% elsif section.settings.brochure_url != blank %}
      <a href="{{ section.settings.brochure_url }}" class="franchise-why__button" target="_blank">
        {{ section.settings.button_text }}
      </a>
    {% else %}
      <button class="franchise-why__button" onclick="alert('Please upload brochure file in theme settings')">
        {{ section.settings.button_text }}
      </button>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Why Franchise",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "WHY LUCIRA FRANCHISE?"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut alconsequat."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "DOWNLOAD BROCHURE"
    },
    {
      "type": "url",
      "id": "brochure_file",
      "label": "Brochure File URL",
      "info": "Upload brochure to Files section and paste the URL here"
    },
    {
      "type": "url",
      "id": "brochure_url",
      "label": "Brochure External URL (Optional)",
      "info": "Alternative: link to external brochure URL"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image",
          "info": "Upload a 100x100px icon (will be displayed in white)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Store Location Research"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "We'll guide you to the right strategic location and set up every key process you need."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Franchise",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Store Location Research",
            "description": "We'll guide you to the right strategic location and set up every key process you need."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Store Location Research",
            "description": "We'll guide you to the right strategic location and set up every key process you need."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Store Location Research",
            "description": "We'll guide you to the right strategic location and set up every key process you need."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Store Location Research",
            "description": "We'll guide you to the right strategic location and set up every key process you need."
          }
        }
      ]
    }
  ]
}
{% endschema %}