<div id="virtual-tryon-section">
  <h2>Virtual Try-On</h2>
  <button id="start-tryon-btn">Try-On Now</button>

  <div id="tryon-area" style="display:none; margin-top:20px;">
    <video id="user-video" autoplay playsinline></video>
    <canvas id="overlay-canvas"></canvas>
  </div>
</div>

<!-- Mediapipe -->
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/face_mesh/face_mesh.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands/hands.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/pose/pose.js"></script>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const btn = document.getElementById("start-tryon-btn");
  const video = document.getElementById("user-video");
  const canvas = document.getElementById("overlay-canvas");
  const ctx = canvas.getContext("2d");
  const tryonArea = document.getElementById("tryon-area");

  // Ornament image
  const ornament = new Image();
  ornament.src = "{{ section.settings.ornament_image | img_url: 'master' }}";

  // Schema values
  const ornamentType = "{{ section.settings.ornament_type }}";
  const placement = "{{ section.settings.placement }}";
  const size = parseInt("{{ section.settings.ornament_size }}", 10);

  let camera, detector;

  btn.addEventListener("click", async () => {
    tryonArea.style.display = "block";

    // Start webcam
    const stream = await navigator.mediaDevices.getUserMedia({ video: true });
    video.srcObject = stream;

    video.addEventListener("loadeddata", () => {
      canvas.width = video.videoWidth;
      canvas.height = video.videoHeight;
    });

    // Wait until ornament is loaded
    ornament.onload = () => {
      if (ornamentType === "face") setupFaceMesh();
      else if (ornamentType === "hand") setupHands();
      else if (ornamentType === "foot") setupPose();
    };
  });

  // ---------------- FACE ORNAMENTS ----------------
  function setupFaceMesh() {
    detector = new FaceMesh({ locateFile: (file) =>
      `https://cdn.jsdelivr.net/npm/@mediapipe/face_mesh/${file}` 
    });
    detector.setOptions({ maxNumFaces: 1, refineLandmarks: true });
    detector.onResults(onFaceResults);

    camera = new Camera(video, {
      onFrame: async () => { await detector.send({ image: video }); },
      width: 640,
      height: 480
    });
    camera.start();
  }

  function onFaceResults(results) {
    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

    if (results.multiFaceLandmarks.length > 0) {
      const lm = results.multiFaceLandmarks[0];
      let landmark;

      if (placement === "ear_left") landmark = lm[234];
      else if (placement === "ear_right") landmark = lm[454];
      else if (placement === "nose") landmark = lm[1];
      else if (placement === "neck") landmark = lm[152];

      if (landmark) {
        const x = landmark.x * canvas.width;
        const y = landmark.y * canvas.height;
        ctx.drawImage(ornament, x - size/2, y - size/2, size, size);
      }
    }
  }

  // ---------------- HAND ORNAMENTS ----------------
  function setupHands() {
    detector = new Hands({ locateFile: (file) =>
      `https://cdn.jsdelivr.net/npm/@mediapipe/hands/${file}` 
    });
    detector.setOptions({ maxNumHands: 1 });
    detector.onResults(onHandResults);

    camera = new Camera(video, {
      onFrame: async () => { await detector.send({ image: video }); },
      width: 640,
      height: 480
    });
    camera.start();
  }

  function onHandResults(results) {
    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

    if (results.multiHandLandmarks.length > 0) {
      const lm = results.multiHandLandmarks[0];
      let landmark;

      switch (placement) {
        case "finger": 
          landmark = lm[5]; // Index finger MCP (base joint)
          break;
        case "middle_finger":
          landmark = lm[9]; // Middle finger MCP
          break;
        case "ring_finger":
          landmark = lm[13]; // Ring finger MCP
          break;
        case "pinky_finger":
          landmark = lm[17]; // Pinky finger MCP
          break;
        case "wrist":
          landmark = lm[0]; // Wrist → bangle
          break;
      }

      if (landmark) {
        const x = landmark.x * canvas.width;
        const y = landmark.y * canvas.height;
        ctx.drawImage(ornament, x - size/2, y - size/2 + (placement === "wrist" ? 5 : 0), size, size);
      }
    }
  }

  // ---------------- FOOT ORNAMENTS ----------------
  function setupPose() {
    detector = new Pose({ locateFile: (file) =>
      `https://cdn.jsdelivr.net/npm/@mediapipe/pose/${file}` 
    });
    detector.setOptions({ modelComplexity: 1 });
    detector.onResults(onPoseResults);

    camera = new Camera(video, {
      onFrame: async () => { await detector.send({ image: video }); },
      width: 640,
      height: 480
    });
    camera.start();
  }

  function onPoseResults(results) {
    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

    if (results.poseLandmarks) {
      let landmark;

      if (placement === "ankle_left") landmark = results.poseLandmarks[27];
      if (placement === "ankle_right") landmark = results.poseLandmarks[28];

      if (landmark) {
        const x = landmark.x * canvas.width;
        const y = landmark.y * canvas.height;
        ctx.drawImage(ornament, x - size/2, y - size/2, size, size);
      }
    }
  }
});
</script>

{% schema %}
{
  "name": "Virtual Try-On",
  "settings": [
    {
      "type": "image_picker",
      "id": "ornament_image",
      "label": "Overlay Ornament Image",
      "info": "Upload a transparent PNG (earring, ring, bangle, payal, etc.)"
    },
    {
      "type": "select",
      "id": "ornament_type",
      "label": "Ornament Type",
      "options": [
        { "value": "face", "label": "Face (ear, nose, neck)" },
        { "value": "hand", "label": "Hand (ring, bangle)" },
        { "value": "foot", "label": "Foot (payal, toe ring)" }
      ],
      "default": "face"
    },
    {
      "type": "select",
      "id": "placement",
      "label": "Placement",
      "options": [
        { "value": "ear_left", "label": "Left Ear" },
        { "value": "ear_right", "label": "Right Ear" },
        { "value": "nose", "label": "Nose" },
        { "value": "neck", "label": "Neck" },
        { "value": "finger", "label": "Finger" },
        { "value": "wrist", "label": "Wrist" },
        { "value": "ankle_left", "label": "Left Ankle" },
        { "value": "ankle_right", "label": "Right Ankle" }
      ],
      "default": "ear_left"
    },
    {
      "type": "range",
      "id": "ornament_size",
      "min": 20,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Ornament Size",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Virtual Try-On",
      "category": "Product",
      "settings": {
        "ornament_image": "shopify:\/\/shop_images\/example-ornament.png",
        "ornament_type": "face",
        "placement": "ear_left",
        "ornament_size": 60
      }
    }
  ]
}
{% endschema %}
