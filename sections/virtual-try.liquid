<div id="virtual-tryon-section">
  <h2>Virtual Try-On</h2>
  <button id="start-tryon-btn">Try-On Now</button>

  <div id="tryon-area" style="display:none; margin-top:20px; position:relative;">
    <video id="user-video" autoplay playsinline style="width:100%; max-width:640px;"></video>
    <canvas id="overlay-canvas" style="position:absolute; top:0; left:0; width:100%; max-width:640px;"></canvas>
  </div>
  
  <!-- Debug info -->
  <div id="debug-info" style="margin-top:10px; color:red; font-size:12px;"></div>
</div>

<!-- Simplified approach without MediaPipe -->
<script>
document.addEventListener("DOMContentLoaded", () => {
  const btn = document.getElementById("start-tryon-btn");
  const video = document.getElementById("user-video");
  const canvas = document.getElementById("overlay-canvas");
  const ctx = canvas.getContext("2d");
  const tryonArea = document.getElementById("tryon-area");
  const debugInfo = document.getElementById("debug-info");

  // Debug logging
  function debugLog(message) {
    debugInfo.innerHTML += message + '<br>';
    console.log(message);
  }

  // Ornament image
  const ornament = new Image();
  ornament.crossOrigin = "anonymous";
  const ornamentImageUrl = "{{ section.settings.ornament_image | img_url: 'master' }}";
  ornament.src = ornamentImageUrl;

  // Schema values
  const ornamentType = "{{ section.settings.ornament_type }}";
  const placement = "{{ section.settings.placement }}";
  const size = parseInt("{{ section.settings.ornament_size }}", 10);

  let isRunning = false;

  btn.addEventListener("click", async () => {
    if (isRunning) {
      // Stop if already running
      isRunning = false;
      if (video.srcObject) {
        video.srcObject.getTracks().forEach(track => track.stop());
      }
      btn.textContent = "Try-On Now";
      tryonArea.style.display = "none";
      return;
    }

    debugLog("Starting virtual try-on...");
    tryonArea.style.display = "block";
    isRunning = true;
    btn.textContent = "Stop Try-On";

    try {
      // Start webcam
      const stream = await navigator.mediaDevices.getUserMedia({ 
        video: { width: 640, height: 480 } 
      });
      video.srcObject = stream;
      debugLog("Webcam started successfully");

      // Set canvas size when video metadata loads
      video.addEventListener("loadedmetadata", () => {
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        debugLog(`Video dimensions: ${video.videoWidth}x${video.videoHeight}`);
        
        // Start the drawing loop
        startDrawingLoop();
      });

    } catch (error) {
      debugLog("ERROR accessing webcam: " + error.message);
      isRunning = false;
      btn.textContent = "Try-On Now";
    }
  });

  function startDrawingLoop() {
    if (!isRunning) return;

    // Clear canvas
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // Draw video frame
    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
    
    // Draw ornament at estimated positions (simplified approach)
    drawOrnament();
    
    // Continue the loop
    requestAnimationFrame(startDrawingLoop);
  }

  function drawOrnament() {
    if (!ornament.complete) return;

    let x, y;

    // Simplified positioning based on ornament type and placement
    switch(ornamentType) {
      case "hand":
        if (placement === "finger") {
          // Position for finger - approximate based on screen coordinates
          x = canvas.width * 0.5; // Center of screen
          y = canvas.height * 0.7; // Lower part for hands
        } else if (placement === "wrist") {
          x = canvas.width * 0.5;
          y = canvas.height * 0.8; // Even lower for wrist
        }
        break;
        
      case "face":
        if (placement === "ear_left") {
          x = canvas.width * 0.3;
          y = canvas.height * 0.4;
        } else if (placement === "ear_right") {
          x = canvas.width * 0.7;
          y = canvas.height * 0.4;
        } else if (placement === "nose") {
          x = canvas.width * 0.5;
          y = canvas.height * 0.5;
        } else if (placement === "neck") {
          x = canvas.width * 0.5;
          y = canvas.height * 0.7;
        }
        break;
        
      case "foot":
        if (placement === "ankle_left") {
          x = canvas.width * 0.3;
          y = canvas.height * 0.9;
        } else if (placement === "ankle_right") {
          x = canvas.width * 0.7;
          y = canvas.height * 0.9;
        }
        break;
    }

    if (x && y) {
      // Draw the ornament
      ctx.drawImage(ornament, x - size/2, y - size/2, size, size);
      
      // Draw a debug circle to show position
      ctx.beginPath();
      ctx.arc(x, y, 5, 0, 2 * Math.PI);
      ctx.fillStyle = 'red';
      ctx.fill();
    }
  }

  // Manual positioning controls for testing
  createManualControls();
});

// Create manual positioning controls for testing
function createManualControls() {
  const controls = document.createElement('div');
  controls.innerHTML = `
    <div style="margin-top: 10px; padding: 10px; background: #f0f0f0; border-radius: 5px;">
      <h4>Manual Position Adjustment</h4>
      <label>X Position: <input type="range" id="pos-x" min="0" max="100" value="50"></label>
      <label>Y Position: <input type="range" id="pos-y" min="0" max="100" value="50"></label>
      <button id="reset-pos">Reset Position</button>
    </div>
  `;
  document.getElementById('virtual-tryon-section').appendChild(controls);
}
</script>

{% schema %}
{
  "name": "Virtual Try-On",
  "settings": [
    {
      "type": "image_picker",
      "id": "ornament_image",
      "label": "Overlay Ornament Image",
      "info": "Upload a transparent PNG (earring, ring, bangle, payal, etc.)"
    },
    {
      "type": "select",
      "id": "ornament_type",
      "label": "Ornament Type",
      "options": [
        { "value": "face", "label": "Face (ear, nose, neck)" },
        { "value": "hand", "label": "Hand (ring, bangle)" },
        { "value": "foot", "label": "Foot (payal, toe ring)" }
      ],
      "default": "face"
    },
    {
      "type": "select",
      "id": "placement",
      "label": "Placement",
      "options": [
        { "value": "ear_left", "label": "Left Ear" },
        { "value": "ear_right", "label": "Right Ear" },
        { "value": "nose", "label": "Nose" },
        { "value": "neck", "label": "Neck" },
        { "value": "finger", "label": "Finger" },
        { "value": "wrist", "label": "Wrist" },
        { "value": "ankle_left", "label": "Left Ankle" },
        { "value": "ankle_right", "label": "Right Ankle" }
      ],
      "default": "ear_left"
    },
    {
      "type": "range",
      "id": "ornament_size",
      "min": 20,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Ornament Size",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Virtual Try-On",
      "category": "Product"
    }
  ]
}
{% endschema %}