</div>

<style>
.store-location-section{width:95%;margin:0 auto;padding-bottom:40px;padding-top:80px;font-family:Futura,sans-serif;text-align:center}
.store-header{margin-bottom:80px}
.store-city{text-transform:uppercase;font-size:14px;letter-spacing:2px;color:#777;margin-top:0}
.store-title{font-size:28px;margin-bottom:12px;margin-top:0}
.store-description{max-width:700px;margin:0 auto;font-size:18px;color:#555}
.store-location-wrapper{display:flex;align-items:flex-start;justify-content:space-between}
.store-map{flex:1}
.store-map iframe{width:100%;height:500px}
.lucistore-address svg,.store-phone svg,.store-time svg{vertical-align:middle;margin-right:8px}
.lucistore-address{display:flex;gap:8px;align-items:start}
.store-phone,.store-time{display:flex;align-items:center;gap:8px}
.store-info{background:#f9f6f6;padding:80px;text-align:left;flex:1;height:500px}
.lucistore-name{font-size:24px;margin:5px 0 15px}
.lucistore-address,.store-phone,.store-time{font-size:16px;margin-bottom:8px}
.store-actions{display:flex;align-items:center;gap:10px;margin-top:20px;width:100%}
.store-distance-btn{border:1px solid #7a4a43;color:#7a4a43;padding:12px 20px;text-decoration:none;font-size:14px;width:50%;gap:15px;justify-content:center;transition:.3s;display:flex;align-items:center;border-radius:12px}
.store-distance-btn:hover{background:#f1e8e7}
.store-btn{background:#7a4a43;color:#fff;width:50%;text-transform:uppercase;justify-content:center;padding:12px 20px;border-radius:12px;text-decoration:none;font-size:14px;transition:.3s;display:flex;align-items:center;gap:15px}
.store-btn:hover{background:#5c322e}
@media(max-width:768px){
.store-location-wrapper{flex-direction:column;gap:0}
.store-location-section{padding-bottom:20px;padding-top:40px;width:92%}
.store-header{margin-bottom:40px}
.store-map iframe{display:block;margin:0;padding:0;line-height:0}
.store-map{margin-bottom:0;width:100%}
.lucistore-address svg{width:28px;height:30px}
.store-info{margin-top:0;padding:12px;border-top:none}
.store-distance-btn{padding:12px 9px;text-decoration:none;font-size:11px;background:#fff;border-radius:9px}
.store-title{font-size:18px;margin:10px 0}
.store-description{font-size:12px}
.lucistore-name{font-size:18px}
.store-btn{padding:13px;font-size:10px}
.lucistore-address,.store-phone,.store-time{font-size:12px;margin-bottom:8px}
}
</style>
