{% schema %}
{
  "name": "Store Location Section",
  "settings": [
    {
      "type": "text",
      "id": "store_city",
      "label": "Store City",
      "default": "Mumbai"
    },
    {
      "type": "text",
      "id": "store_title",
      "label": "Store Title",
      "default": "Our Chembur Store"
    },
    {
      "type": "textarea",
      "id": "store_description",
      "label": "Store Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit..."
    },
    {
      "type": "text",
      "id": "store_name",
      "label": "Store Name",
      "default": "Chembur Lucira Store"
    },
    {
      "type": "textarea",
      "id": "store_address",
      "label": "Store Address",
      "default": "Unit No. 305, B2B Centre Cabin A, Malad Industrial Estate, Orlem, Kanchpada, Malad West, Mumbai - 400064"
    },
    {
      "type": "text",
      "id": "store_phone",
      "label": "Store Phone",
      "default": "+91 0000000001"
    },
    {
      "type": "text",
      "id": "store_timing",
      "label": "Store Timing",
      "default": "10:00 AM - 10:00 PM"
    },
    {
      "type": "text",
      "id": "store_distance",
      "label": "Store Distance",
      "default": "1.2 KM AWAY"
    },
    {
      "type": "url",
      "id": "appointment_link",
      "label": "Appointment Button Link"
    },
    {
      "type": "textarea",
      "id": "map_iframe",
      "label": "Google Map Embed (iframe)"
    }
  ],
  "presets": [
    {
      "name": "Store Location"
    }
  ]
}
{% endschema %}

<div class="store-location-section">
  <div class="store-header">
    <p class="store-city">{{ section.settings.store_city }}</p>
    <h2 class="store-title">{{ section.settings.store_title }}</h2>
    <p class="store-description">{{ section.settings.store_description }}</p>
  </div>

  <div class="store-location-wrapper">
    <div class="store-map">
      {{ section.settings.map_iframe }}
    </div>
    <div class="store-info">
      <p class="store-city">{{ section.settings.store_city }}</p>
      <h3 class="lucistore-name">{{ section.settings.store_name }}</h3>
