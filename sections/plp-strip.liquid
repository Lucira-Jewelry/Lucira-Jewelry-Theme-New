<style>
  .dual-banner-section {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .dual-banner-wrapper {
    display: block;
    width: 100%;
    height: auto;
    text-decoration: none;
    cursor: {% if section.settings.banner_url == blank %}default{% else %}pointer{% endif %};
  }

  .dual-banner-wrapper.no-link {
    cursor: default;
  }

  .dual-banner-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
</style>

<div class="dual-banner-section">
  {% if section.settings.banner_url != blank %}
    <a href="{{ section.settings.banner_url }}" 
       class="dual-banner-wrapper"
       {% if section.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
  {% else %}
    <div class="dual-banner-wrapper no-link">
  {% endif %}

    <picture>
      {%- comment -%} 1. Mobile Source: Loads only on screens 768px and smaller {%- endcomment -%}
      {% if section.settings.mobile_banner != blank %}
        <source media="(max-width: 768px)" srcset="{{ section.settings.mobile_banner | image_url: width: 800 }}">
      {% endif %}
      
      {%- comment -%} 2. Desktop Source: Loads only on screens 769px and larger {%- endcomment -%}
      {% if section.settings.desktop_banner != blank %}
        <source media="(min-width: 769px)" srcset="{{ section.settings.desktop_banner | image_url: width: 1920 }}">
        
        {%- comment -%} 3. Fallback Image Tag (Required for <picture> to work) {%- endcomment -%}
        <img 
          src="{{ section.settings.desktop_banner | image_url: width: 1920 }}"
          alt="{{ section.settings.banner_alt_text | default: 'Banner' | escape }}"
          class="dual-banner-image"
          fetchpriority="high"
          width="1920"
          height="200"
        >
      {% elsif section.settings.mobile_banner != blank %}
        {%- comment -%} If they forgot a desktop banner, fallback to mobile {%- endcomment -%}
        <img 
          src="{{ section.settings.mobile_banner | image_url: width: 800 }}"
          alt="{{ section.settings.banner_alt_text | default: 'Banner' | escape }}"
          class="dual-banner-image"
          fetchpriority="high"
          width="428"
          height="160"
        >
      {% else %}
        {%- comment -%} Placeholder if no images are selected {%- endcomment -%}
        <div style="background: #f0f0f0; display: flex; align-items: center; justify-content: center; color: #999; height: 200px; width: 100%;">
          Please select a banner image in the theme editor.
        </div>
      {% endif %}
    </picture>

  {% if section.settings.banner_url != blank %}
    </a>
  {% else %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Plp Banner Strip",
  "tag": "section",
  "class": "section-dual-banner",
  "settings": [
    {
      "type": "header",
      "content": "Desktop Banner"
    },
    {
      "type": "image_picker",
      "id": "desktop_banner",
      "label": "Desktop Banner Image",
      "info": "Recommended size: 1920px x 200px"
    },
    {
      "type": "header",
      "content": "Mobile Banner"
    },
    {
      "type": "image_picker",
      "id": "mobile_banner",
      "label": "Mobile Banner Image",
      "info": "Recommended size: 428px x 160px"
    },
    {
      "type": "header",
      "content": "Banner Settings"
    },
    {
      "type": "url",
      "id": "banner_url",
      "label": "Banner Link URL",
      "info": "Leave empty if banner should not be clickable"
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "label": "Open link in new tab",
      "default": false
    },
    {
      "type": "text",
      "id": "banner_alt_text",
      "label": "Image Alt Text",
      "default": "Banner",
      "info": "Describe the image for accessibility"
    }
  ],
  "presets": [
    {
      "name": "Dual Banner Strip"
    }
  ]
}
{% endschema %}