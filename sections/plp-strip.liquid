
<style>
  .dual-banner-section {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .dual-banner-wrapper {
    display: block;
    width: 100%;
    height: auto;
    text-decoration: none;
    cursor: {{ section.settings.banner_url | default: '' | blank | if: 'default', 'pointer' }};
  }

  .dual-banner-wrapper.no-link {
    cursor: default;
  }

  .dual-banner-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .desktop-banner {
    display: block;
    {% comment %} height: 200px; {% endcomment %}
  }

  .mobile-banner {
    display: none;
    {% comment %} height: 160px; %} {% endcomment %}
  }

  @media screen and (max-width: 768px) {
    .desktop-banner {
      display: none;
    }
    
    .mobile-banner {
      display: block;
    }
  }

  /* Optional: Add loading animation */
  .dual-banner-image {
    opacity: 0;
    animation: fadeIn 0.5s ease-in forwards;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }
</style>

<div class="dual-banner-section">
  {% if section.settings.banner_url != blank %}
    <a href="{{ section.settings.banner_url }}" 
       class="dual-banner-wrapper"
       {% if section.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
  {% else %}
    <div class="dual-banner-wrapper no-link">
  {% endif %}

    {% if section.settings.desktop_banner != blank %}
      <img 
        src="{{ section.settings.desktop_banner | img_url: '1920x200', crop: 'center' }}"
        alt="{{ section.settings.banner_alt_text | default: 'Banner' }}"
        class="dual-banner-image desktop-banner"
        loading="lazy"
        width="1920"
        height="200">
    {% else %}
      <div class="desktop-banner" style="background: #f0f0f0; display: flex; align-items: center; justify-content: center; color: #999;">
        Desktop Banner (1920x200)
      </div>
    {% endif %}

    {% if section.settings.mobile_banner != blank %}
      <img 
        src="{{ section.settings.mobile_banner | img_url: '428x160', crop: 'center' }}"
        alt="{{ section.settings.banner_alt_text | default: 'Banner' }}"
        class="dual-banner-image mobile-banner"
        loading="lazy"
        width="428"
        height="160">
    {% else %}
      <div class="mobile-banner" style="background: #f0f0f0; display: flex; align-items: center; justify-content: center; color: #999;">
        Mobile Banner (428x160)
      </div>
    {% endif %}

  {% if section.settings.banner_url != blank %}
    </a>
  {% else %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Plp Banner Strip",
  "tag": "section",
  "class": "section-dual-banner",
  "settings": [
    {
      "type": "header",
      "content": "Desktop Banner"
    },
    {
      "type": "image_picker",
      "id": "desktop_banner",
      "label": "Desktop Banner Image",
      "info": "Recommended size: 1920px x 200px"
    },
    {
      "type": "header",
      "content": "Mobile Banner"
    },
    {
      "type": "image_picker",
      "id": "mobile_banner",
      "label": "Mobile Banner Image",
      "info": "Recommended size: 428px x 160px"
    },
    {
      "type": "header",
      "content": "Banner Settings"
    },
    {
      "type": "url",
      "id": "banner_url",
      "label": "Banner Link URL",
      "info": "Leave empty if banner should not be clickable"
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "label": "Open link in new tab",
      "default": false
    },
    {
      "type": "text",
      "id": "banner_alt_text",
      "label": "Image Alt Text",
      "default": "Banner",
      "info": "Describe the image for accessibility"
    }
  ],
  "presets": [
    {
      "name": "Dual Banner Strip"
    }
  ]
}
{% endschema %}