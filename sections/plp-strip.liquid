{% assign show_banner = true %}



{% if collection %}
  {% if collection.handle == 'gold-coins' %}
    {% assign show_banner = false %}
  {% endif %}
{% endif %}

{% if collection %}
  {% assign all_plain_gold = true %}
  {% for product in collection.products %}
    {% unless product.tags contains 'plain gold' %}
      {% assign all_plain_gold = false %}
      {% break %}
    {% endunless %}
  {% endfor %}
  {% if collection.products_count > 0 and all_plain_gold %}
    {% assign show_banner = false %}
  {% endif %}
{% endif %}

{% assign desktop_banner = collection.metafields.custom.desktop_banner.value %}
{% assign mobile_banner = collection.metafields.custom.mobile_banner.value %}

{% if show_banner %}
<style>
  .dual-banner-section { width: 100%; overflow: hidden; position: relative; }
  .dual-banner-wrapper { display: block; width: 100%; height: auto; text-decoration: none; cursor: {% if section.settings.banner_url == blank %}default{% else %}pointer{% endif %}; }
  .dual-banner-wrapper.no-link { cursor: default; }
  .dual-banner-image { width: 100%; height: auto; display: block; object-fit: cover; }
</style>

<div class="dual-banner-section">
  {% if section.settings.banner_url != blank %}
    <a href="{{ section.settings.banner_url }}" 
       class="dual-banner-wrapper"
       {% if section.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
  {% else %}
    <div class="dual-banner-wrapper no-link">
  {% endif %}

    <picture>

      {% comment %} Mobile priority: metafield → fallback {% endcomment %}
      {% if mobile_banner != blank %}
        <source media="(max-width: 768px)" srcset="{{ mobile_banner | image_url: width: 800 }}">
      {% elsif section.settings.mobile_banner != blank %}
        <source media="(max-width: 768px)" srcset="{{ section.settings.mobile_banner | image_url: width: 800 }}">
      {% endif %}

      {% comment %} Desktop priority: metafield → fallback {% endcomment %}
      {% if desktop_banner != blank %}
        <source media="(min-width: 769px)" srcset="{{ desktop_banner | image_url: width: 1920 }}">
        <img 
          src="{{ desktop_banner | image_url: width: 1920 }}"
          alt="{{ section.settings.banner_alt_text | default: 'Banner' | escape }}"
          class="dual-banner-image"
          fetchpriority="high"
          width="1920"
          height="200"
        >

      {% elsif section.settings.desktop_banner != blank %}
        <source media="(min-width: 769px)" srcset="{{ section.settings.desktop_banner | image_url: width: 1920 }}">
        <img 
          src="{{ section.settings.desktop_banner | image_url: width: 1920 }}"
          alt="{{ section.settings.banner_alt_text | default: 'Banner' | escape }}"
          class="dual-banner-image"
          fetchpriority="high"
          width="1920"
          height="200"
        >

      {% elsif mobile_banner != blank %}
        <img 
          src="{{ mobile_banner | image_url: width: 800 }}"
          alt="{{ section.settings.banner_alt_text | default: 'Banner' | escape }}"
          class="dual-banner-image"
          fetchpriority="high"
          width="428"
          height="160"
        >

      {% elsif section.settings.mobile_banner != blank %}
        <img 
          src="{{ section.settings.mobile_banner | image_url: width: 800 }}"
          alt="{{ section.settings.banner_alt_text | default: 'Banner' | escape }}"
          class="dual-banner-image"
          fetchpriority="high"
          width="428"
          height="160"
        >
      {% endif %}

    </picture>

  {% if section.settings.banner_url != blank %}
    </a>
  {% else %}
    </div>
  {% endif %}
</div>
{% endif %}

{% schema %}
{
  "name": "Plp Banner Strip",
  "tag": "section",
  "class": "section-dual-banner",
  "settings": [
    {
      "type": "header",
      "content": "Desktop Banner"
    },
    {
      "type": "image_picker",
      "id": "desktop_banner",
      "label": "Desktop Banner Image",
      "info": "Recommended size: 1920px x 200px"
    },
    {
      "type": "header",
      "content": "Mobile Banner"
    },
    {
      "type": "image_picker",
      "id": "mobile_banner",
      "label": "Mobile Banner Image",
      "info": "Recommended size: 428px x 160px"
    },
    {
      "type": "header",
      "content": "Banner Settings"
    },
    {
      "type": "url",
      "id": "banner_url",
      "label": "Banner Link URL",
      "info": "Leave empty if banner should not be clickable"
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "label": "Open link in new tab",
      "default": false
    },
    {
      "type": "text",
      "id": "banner_alt_text",
      "label": "Image Alt Text",
      "default": "Banner",
      "info": "Describe the image for accessibility"
    }
  ],
  "presets": [
    {
      "name": "Dual Banner Strip"
    }
  ]
}
{% endschema %}