<section class="shop-by-shape brad_diamond_shapes{{ section.id }}">
  <div class="page-width">
    <div class="text-center">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subtext }}</p>

      <div class="shape-grid">
        {% for block in section.blocks %}
        <div class="shape-item">
          <a
            href="{% if block.settings.scroll_to_id != blank %}#{{ block.settings.scroll_to_id }}{% else %}{{ block.settings.shape_link }}{% endif %}"
            class="shape-link"
            data-shape-title="{{ block.settings.shape_title | downcase }}"
            data-scroll-target="{{ block.settings.scroll_to_id }}"
          >
            {% if block.settings.shape_image != blank %}
            <picture>
              <source media="(max-width: 767px)" srcset="{{ block.settings.shape_image | img_url: '200x200' }}">
              <source media="(min-width: 768px)" srcset="{{ block.settings.shape_image | img_url: '200x200' }}">
              <img src="{{ block.settings.shape_image | img_url: '120x120' }}" 
                   alt="{{ block.settings.shape_title }} cut diamond" 
                   title="{{ block.settings.shape_title }}" 
                   loading="lazy" 
                   width="60" 
                   height="60" 
                   class="shape-img">
            </picture>
            {% endif %}
            <p>{{ block.settings.shape_title }}</p>
          </a>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
/* PARENT SCOPED */
.brad_diamond_shapes{{ section.id }} .shop-by-shape {
  padding:30px 0 60px;
}
.brad_diamond_shapes{{ section.id }} h2 {
  font-size:24px;
  text-align:center;
  margin-bottom:0;
  text-transform:uppercase;
  margin:0;
}
.brad_diamond_shapes{{ section.id }} .shape-item a { 
  text-decoration:none;
}
.brad_diamond_shapes{{ section.id }} p {
  max-width:700px;
  margin:0 auto 30px;
  font-size:18px;
  text-align:center;
  color:#555;
}
.brad_diamond_shapes{{ section.id }} .shape-grid {
  display:flex;
  flex-wrap:wrap;
  justify-content:space-around;
  gap:0;
}
.brad_diamond_shapes{{ section.id }} .shape-item img {
  transition:.3s;
}
.brad_diamond_shapes{{ section.id }} .shape-item img:hover {
  transform:scale(1.1);
}
.brad_diamond_shapes{{ section.id }} .shape-item img {
  height:120px;
  object-fit:contain;
  display:block;
  margin:0 auto 10px;
}
.brad_diamond_shapes{{ section.id }} .shape-item p {
  font-size:14px;
  font-weight:500;
  text-transform:uppercase;
  margin:0;
}
.brad_diamond_shapes{{ section.id }} .shape-item img {
  width: max-content !important;
}

/* Lazy Reveal */
.brad_diamond_shapes{{ section.id }} .shop-by-shape,
.brad_diamond_shapes{{ section.id }} .shape-link {
  content-visibility: auto;
  contain-intrinsic-size: 300px auto;
}

/* Desktop Wide */
@media (min-width:1600px) {
  .brad_diamond_shapes{{ section.id }} .shape-grid {
    max-width:1400px;
    margin:0 auto;
  }
}

/* Mobile */
@media (max-width:767px) {
  .brad_diamond_shapes{{ section.id }} .shop-by-shape {
    padding:0 0 40px;
  }
  .brad_diamond_shapes{{ section.id }} .shape-item p {
    font-size:12px!important;
  }
  .brad_diamond_shapes{{ section.id }} p {
    font-size:14px;
  }
  .brad_diamond_shapes{{ section.id }} h2 {
    font-size:18px;
  }
  .brad_diamond_shapes{{ section.id }} .shape-item {
    width:100%;
  }
  .brad_diamond_shapes{{ section.id }} .shape-item img {
    width:100%;
    height:60px;
  }
  .brad_diamond_shapes{{ section.id }} .shape-grid {
    display:grid;
    grid-template-columns:repeat(4,1fr);
    grid-template-rows:repeat(2,100px);
    gap:10px;
  }
}

/* Extra Large Screens */
@media only screen and (min-width:1600px) and (max-width:2100px) {
  .brad_diamond_shapes{{ section.id }} h2 {
    font-size:28px;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const parent = document.querySelector(".brad_diamond_shapes{{ section.id }}");
  if (!parent) return;

  /* GA4 promoClick tracking */
  parent.querySelectorAll(".shape-link").forEach((link) => {
    link.addEventListener("click", function () {
      var shapeTitle = this.getAttribute("data-shape-title") || "Unknown Shape";
      var shapeHref = this.getAttribute("href") || "N/A";

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: "promoClick",
        promoClick: {
          promo_id: shapeTitle,
          promo_name: "Shop by Shape - " + shapeTitle,
          creative_name: "Shape Grid Click",
          location_id: shapeHref
        }
      });
    });
  });

  /* Smooth scroll to target section */
  parent.querySelectorAll(".shape-link").forEach(link => {
    link.addEventListener("click", function (e) {
      const scrollTarget = this.dataset.scrollTarget;
      
      // If there's a scroll target ID, handle smooth scrolling
      if (scrollTarget) {
        e.preventDefault();
        
        const targetSection = document.getElementById(scrollTarget);
        
        if (targetSection) {
          const yOffset = -100; // Adjust for sticky header
          const y = targetSection.getBoundingClientRect().top + window.pageYOffset + yOffset;

          window.scrollTo({
            top: y,
            behavior: "smooth"
          });
        }
      }
      // Otherwise, let the default href behavior work (external link)
    });
  });
});

/* Lazy load + reveal animation */
document.addEventListener("DOMContentLoaded", function () {
  const parent = document.querySelector(".brad_diamond_shapes{{ section.id }}");
  if (!parent) return;

  const shapeLinks = parent.querySelectorAll(".shape-link");
  if (!shapeLinks.length) return;

  const observer = new IntersectionObserver((entries, obs) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add("visible");
        obs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });

  shapeLinks.forEach(link => observer.observe(link));
});
</script>

{% schema %}
{
  "name": "Diamond Shape",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP BY SHAPE"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    }
  ],
  "blocks": [
    {
      "type": "shape",
      "name": "Shape",
      "settings": [
        {
          "type": "image_picker",
          "id": "shape_image",
          "label": "Shape Image"
        },
        {
          "type": "text",
          "id": "shape_title",
          "label": "Shape Title",
          "default": "ROUND"
        },
        {
          "type": "text",
          "id": "scroll_to_id",
          "label": "Scroll to Section ID",
          "info": "Enter the Section ID from the Banner with Collection section (e.g., 'marquise-diamond'). Leave empty to use Link URL instead.",
          "placeholder": "e.g., marquise-diamond"
        },
        {
          "type": "url",
          "id": "shape_link",
          "label": "Link URL (Fallback)",
          "info": "Used only if Scroll to Section ID is empty"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Diamond Shape",
      "category": "Custom"
    }
  ]
}
{% endschema %}