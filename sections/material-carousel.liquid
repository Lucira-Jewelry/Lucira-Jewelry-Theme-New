{%- liquid
  assign s_id    = 'ms-' | append: section.id
  assign s_total = section.blocks.size
-%}

<section
  class="ms-root"
  id="{{ s_id }}"
  data-ms-section
  data-ms-id="{{ s_id }}"
  data-ms-total="{{ s_total }}"
  tabindex="-1"
>
  <div class="ms-inner">

    {%- comment -%}── HEADER ──{%- endcomment -%}
    <div class="ms-head">
      {%- if section.settings.title != blank -%}
        <h2 class="ms-head__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ms-head__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%}
      ── CYLINDRICAL CAROUSEL ──
      5 images visible at once with 3D cylinder effect
    {%- endcomment -%}
    <div class="ms-stage-wrap">
      <div class="ms-cylinder-bg"></div>
      <div class="ms-stage" data-ms-stage>
        
        {%- comment -%}Create a continuous loop of slides for cylinder effect{%- endcomment -%}
        {%- assign extended_blocks = section.blocks | concat: section.blocks | concat: section.blocks -%}
        {%- assign start_index = s_total -%}
        
        <div class="ms-cylinder" data-ms-cylinder>
          {%- for block in extended_blocks limit: 15 -%}
            {%- assign original_index = forloop.index0 | modulo: s_total -%}
            {%- assign block_data = section.blocks[original_index] -%}
            
            <div
              class="ms-cylinder-face{% if forloop.index == start_index %} is-active{% endif %}"
              data-ms-face="{{ original_index }}"
              data-ms-position="{{ forloop.index0 }}"
              {{ block_data.shopify_attributes }}
            >
              <div class="ms-face-inner">
                {%- if block_data.settings.desktop_image != blank -%}
                  {{- block_data.settings.desktop_image
                      | image_url: width: 600
                      | image_tag:
                          class: 'ms-face__img',
                          loading: 'lazy',
                          alt: block_data.settings.name,
                          widths: '300,450,600' -}}
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- comment -%}Mobile fallback (standard carousel){%- endcomment -%}
        <div class="ms-mobile-carousel">
          {%- for block in section.blocks -%}
            <div class="ms-mobile-slide{% if forloop.first %} is-active{% endif %}" data-ms-mobile-slide="{{ forloop.index0 }}">
              {%- if block.settings.mobile_image != blank -%}
                {{- block.settings.mobile_image
                    | image_url: width: 600
                    | image_tag:
                        class: 'ms-mobile__img',
                        loading: 'lazy',
                        alt: block.settings.name,
                        widths: '300,450,600' -}}
              {%- elsif block.settings.desktop_image != blank -%}
                {{- block.settings.desktop_image
                    | image_url: width: 600
                    | image_tag:
                        class: 'ms-mobile__img',
                        loading: 'lazy',
                        alt: block.settings.name,
                        widths: '300,450,600' -}}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>

    {%- comment -%}── CONTROLS ──{%- endcomment -%}
    <div class="ms-controls">
      <button class="ms-arrow ms-arrow--prev" type="button" data-ms-prev aria-label="Previous material">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="ms-dots" data-ms-dots>
        {%- for block in section.blocks -%}
          <button
            class="ms-dot{% if forloop.first %} is-active{% endif %}"
            data-ms-dot="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {%- endfor -%}
      </div>

      <button class="ms-arrow ms-arrow--next" type="button" data-ms-next aria-label="Next material">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    {%- comment -%}── INFO PANEL ──{%- endcomment -%}
    <div class="ms-info-wrap" data-ms-info-wrap>
      {%- for block in section.blocks -%}
        <div
          class="ms-info-item{% if forloop.first %} is-active{% endif %}"
          data-ms-info="{{ forloop.index0 }}"
        >
          <h3 class="ms-info-item__name">{{ block.settings.name | upcase | escape }}</h3>
          {%- if block.settings.description != blank -%}
            <p class="ms-info-item__desc">{{ block.settings.description }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a
              href="{{ block.settings.button_url | default: '#' }}"
              class="ms-info-item__btn"
            >{{ block.settings.button_label | upcase | escape }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
/* ============================================================
   CYLINDRICAL MATERIALS CAROUSEL
   Features: 5 images visible, 3D cylinder effect with squeeze
   ============================================================ */
[data-ms-section] {
  --ms-bg: #f0eeea;
  --ms-cylinder-bg: #e8e6e1;
  --ms-panel-bg: #ffffff;
  --ms-border: #e2e0db;
  --ms-title-clr: #1a1a1a;
  --ms-text-clr: #6b6b6b;
  --ms-btn-bg: {{ section.settings.button_color | default: '#8c6464' }};
  --ms-btn-hov: {{ section.settings.button_hover_color | default: '#7a5555' }};
  --ms-dot-color: #c8c8c8;
  --ms-dot-active: #1a1a1a;
  --ms-cylinder-width: min(1200px, 90vw);
  --ms-face-width: min(220px, 18vw);
  --ms-face-height: min(320px, 45vh);
  --ms-ease: cubic-bezier(0.23, 1, 0.32, 1);
  --ms-dur: 600ms;

  background: var(--ms-bg);
  padding: 60px 0 56px;
  overflow: hidden;
  font-family: inherit;
  isolation: isolate;
  position: relative;
}

[data-ms-section] *,
[data-ms-section] *::before,
[data-ms-section] *::after { 
  box-sizing: border-box; 
  margin: 0; 
  padding: 0; 
}

[data-ms-section] button { 
  appearance: none; 
  -webkit-appearance: none; 
  border: none; 
  background: none; 
  cursor: pointer; 
  font-family: inherit; 
}

/* ── Layout ─────────────────────────────────── */
[data-ms-section] .ms-inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 24px;
  text-align: center;
}

/* ── Header ─────────────────────────────────── */
[data-ms-section] .ms-head { 
  margin-bottom: 44px; 
  position: relative;
  z-index: 2;
}

[data-ms-section] .ms-head__title {
  font-size: clamp(18px, 2vw, 26px);
  font-weight: 400;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
  margin-bottom: 18px;
}

[data-ms-section] .ms-head__subtitle {
  font-size: 15px;
  color: var(--ms-text-clr);
  line-height: 1.8;
  max-width: 560px;
  margin: 0 auto;
}

/* ── Cylinder Stage ─────────────────────────── */
[data-ms-section] .ms-stage-wrap {
  position: relative;
  min-height: 400px;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 40px 0 20px;
}

[data-ms-section] .ms-cylinder-bg {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 100%;
  background: var(--ms-cylinder-bg);
  border-radius: 50% / 20% 20% 20% 20%;
  box-shadow: 0 20px 40px rgba(0,0,0,0.08);
  z-index: 0;
}

[data-ms-section] .ms-stage {
  position: relative;
  width: 100%;
  height: 400px;
  display: flex;
  justify-content: center;
  align-items: center;
  perspective: 2000px;
  transform-style: preserve-3d;
  z-index: 1;
}

/* ── Cylinder Container ──────────────────────── */
[data-ms-section] .ms-cylinder {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  transform-style: preserve-3d;
  transition: transform var(--ms-dur) var(--ms-ease);
}

/* ── Cylinder Faces (5 visible) ─────────────── */
[data-ms-section] .ms-cylinder-face {
  position: absolute;
  width: var(--ms-face-width);
  height: var(--ms-face-height);
  left: 50%;
  top: 50%;
  margin-left: calc(var(--ms-face-width) / -2);
  margin-top: calc(var(--ms-face-height) / -2);
  background: var(--ms-panel-bg);
  border: 1px solid var(--ms-border);
  border-radius: 40px 40px 20px 20px; /* Squeezed top/bottom radius */
  overflow: hidden;
  box-shadow: 0 15px 30px rgba(0,0,0,0.15);
  transform-style: preserve-3d;
  backface-visibility: visible;
  transition: all var(--ms-dur) var(--ms-ease);
  
  /* 3D Cylinder positioning */
  transform: 
    rotateY(calc(var(--face-index) * 60deg))
    translateZ(calc(var(--ms-face-width) * 1.2))
    scaleY(0.92); /* Squeeze effect from top/bottom */
}

/* Inner circle effect - additional radius on front */
[data-ms-section] .ms-cylinder-face::before {
  content: '';
  position: absolute;
  inset: 10px;
  border-radius: 30px 30px 15px 15px;
  background: rgba(255,255,255,0.1);
  pointer-events: none;
  z-index: 1;
}

[data-ms-section] .ms-face-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

[data-ms-section] .ms-face__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  filter: drop-shadow(0 5px 10px rgba(0,0,0,0.1));
  transition: transform 0.3s ease;
}

[data-ms-section] .ms-cylinder-face.is-active .ms-face__img {
  transform: scale(1.05);
}

/* Dynamic face positioning via JS */
[data-ms-section] .ms-cylinder-face {
  --face-index: 0;
}

/* ── Mobile Carousel (hidden on desktop) ─────── */
[data-ms-section] .ms-mobile-carousel {
  display: none;
  width: 100%;
  position: relative;
}

[data-ms-section] .ms-mobile-slide {
  display: none;
  width: 100%;
  max-width: 400px;
  margin: 0 auto;
  background: var(--ms-panel-bg);
  border: 1px solid var(--ms-border);
  border-radius: 40px 40px 20px 20px;
  overflow: hidden;
  box-shadow: 0 15px 30px rgba(0,0,0,0.15);
  padding: 20px;
}

[data-ms-section] .ms-mobile-slide.is-active {
  display: block;
}

[data-ms-section] .ms-mobile__img {
  width: 100%;
  height: auto;
  object-fit: contain;
}

/* ── Controls ────────────────────────────────── */
[data-ms-section] .ms-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30px;
  margin: 40px 0 20px;
  position: relative;
  z-index: 4;
}

[data-ms-section] .ms-arrow {
  flex-shrink: 0;
  width: 44px;
  height: 44px;
  border: 1.5px solid var(--ms-dot-color) !important;
  border-radius: 50%;
  background: white !important;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #444;
  transition: all 0.2s ease;
  box-shadow: 0 4px 8px rgba(0,0,0,0.05);
}

[data-ms-section] .ms-arrow:hover {
  border-color: var(--ms-dot-active) !important;
  background: #f8f8f8 !important;
  transform: scale(1.05);
  box-shadow: 0 6px 12px rgba(0,0,0,0.1);
}

[data-ms-section] .ms-arrow:active { 
  transform: scale(0.95); 
}

/* ── Dots ────────────────────────────────────── */
[data-ms-section] .ms-dots {
  display: flex;
  gap: 12px;
}

[data-ms-section] .ms-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--ms-dot-color);
  transition: all 0.3s var(--ms-ease);
  padding: 0;
}

[data-ms-section] .ms-dot.is-active {
  background: var(--ms-dot-active);
  transform: scale(1.3);
  width: 24px;
  border-radius: 12px;
}

/* ── Info block ──────────────────────────────── */
[data-ms-section] .ms-info-wrap {
  position: relative;
  min-height: 152px;
  margin-top: 24px;
}

[data-ms-section] .ms-info-item {
  position: absolute;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateY(10px);
  transition: all 0.35s var(--ms-ease);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

[data-ms-section] .ms-info-item.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateY(0);
}

[data-ms-section] .ms-info-item__name {
  font-size: clamp(15px, 1.6vw, 20px);
  font-weight: 400;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
}

[data-ms-section] .ms-info-item__desc {
  font-size: 14px;
  color: var(--ms-text-clr);
  line-height: 1.8;
  max-width: 480px;
}

[data-ms-section] .ms-info-item__btn {
  display: inline-block;
  padding: 13px 38px;
  background: var(--ms-btn-bg);
  color: #fff;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  transition: all 0.22s var(--ms-ease);
  margin-top: 4px;
  border-radius: 2px;
}
[data-ms-section] .ms-info-item__btn:hover {
  background: var(--ms-btn-hov);
}
[data-ms-section] .ms-info-item__btn:active { 
  transform: scale(0.97); 
}

/* ── Desktop only ────────────────────────────── */
@media screen and (min-width: 768px) {
  [data-ms-section] .ms-cylinder {
    display: flex !important;
  }
  [data-ms-section] .ms-mobile-carousel {
    display: none !important;
  }
}

/* ── Mobile Responsive ───────────────────────── */
@media screen and (max-width: 767px) {
  [data-ms-section] {
    padding: 40px 0 44px;
  }
  
  [data-ms-section] .ms-inner { 
    padding: 0 16px; 
  }
  
  [data-ms-section] .ms-head { 
    margin-bottom: 28px; 
  }
  
  [data-ms-section] .ms-head__title { 
    font-size: 17px; 
    letter-spacing: 4px; 
  }

  [data-ms-section] .ms-cylinder,
  [data-ms-section] .ms-cylinder-bg {
    display: none !important;
  }

  [data-ms-section] .ms-mobile-carousel {
    display: block !important;
  }

  [data-ms-section] .ms-stage {
    height: auto;
    min-height: 300px;
    perspective: none;
  }

  [data-ms-section] .ms-stage-wrap {
    min-height: auto;
    margin: 20px 0;
  }

  [data-ms-section] .ms-controls {
    margin: 20px 0;
    gap: 20px;
  }

  [data-ms-section] .ms-info-wrap { 
    min-height: 164px; 
  }
  
  [data-ms-section] .ms-info-item__desc { 
    max-width: 300px; 
  }
}

[data-ms-section][data-ms-total="1"] .ms-controls { 
  display: none; 
}

/* Animation keyframes for smooth rotation */
@keyframes cylinderGlow {
  0%, 100% { filter: brightness(1); }
  50% { filter: brightness(1.05); }
}

.ms-cylinder-face.is-active {
  animation: cylinderGlow 3s infinite;
}
</style>

<script>
(function () {
  'use strict';

  const ROOT = document.getElementById('{{ s_id }}');
  if (!ROOT) return;

  const STAGE = ROOT.querySelector('[data-ms-stage]');
  const CYLINDER = ROOT.querySelector('[data-ms-cylinder]');
  const FACES = Array.from(ROOT.querySelectorAll('[data-ms-face]'));
  const MOBILE_SLIDES = Array.from(ROOT.querySelectorAll('[data-ms-mobile-slide]'));
  const DOTS = Array.from(ROOT.querySelectorAll('[data-ms-dot]'));
  const INFO_ITEMS = Array.from(ROOT.querySelectorAll('[data-ms-info]'));
  const PREV_BTN = ROOT.querySelector('[data-ms-prev]');
  const NEXT_BTN = ROOT.querySelector('[data-ms-next]');

  const total = {{ s_total }};
  let currentIndex = 0;
  let isAnimating = false;
  const DURATION = 600; // match CSS var

  if (total <= 1) return;

  // Initialize cylinder face positions
  function updateCylinderRotation(index) {
    if (!CYLINDER || window.innerWidth < 768) return;

    // Calculate rotation based on current index
    // Each face is 60deg apart (360/6 = 60deg for 6 faces, but we show 5)
    const rotation = -(index * 60); // Rotate opposite direction of navigation
    
    CYLINDER.style.transform = `rotateY(${rotation}deg)`;
    
    // Update active states
    FACES.forEach(face => {
      const faceIndex = parseInt(face.dataset.msFace);
      const position = parseInt(face.dataset.msPosition);
      
      // Calculate if this face should be active based on proximity to center
      const normalizedPos = ((position - index + total * 2) % total);
      if (normalizedPos === 0) {
        face.classList.add('is-active');
      } else {
        face.classList.remove('is-active');
      }
      
      // Set custom property for face index (used in CSS)
      face.style.setProperty('--face-index', normalizedPos);
    });
  }

  // Update all UI elements
  function updateUI(newIndex, direction = 'next') {
    if (isAnimating) return;
    isAnimating = true;

    // Update current index
    currentIndex = newIndex;

    // Update cylinder rotation (desktop)
    if (window.innerWidth >= 768) {
      updateCylinderRotation(currentIndex);
    }

    // Update mobile slides
    MOBILE_SLIDES.forEach((slide, idx) => {
      if (idx === currentIndex) {
        slide.classList.add('is-active');
      } else {
        slide.classList.remove('is-active');
      }
    });

    // Update dots
    DOTS.forEach((dot, idx) => {
      if (idx === currentIndex) {
        dot.classList.add('is-active');
      } else {
        dot.classList.remove('is-active');
      }
    });

    // Update info panels
    INFO_ITEMS.forEach((item, idx) => {
      if (idx === currentIndex) {
        item.classList.add('is-active');
        item.setAttribute('aria-hidden', 'false');
      } else {
        item.classList.remove('is-active');
        item.setAttribute('aria-hidden', 'true');
      }
    });

    // Reset animation lock after duration
    setTimeout(() => {
      isAnimating = false;
    }, DURATION);
  }

  // Navigation functions
  function goToNext() {
    if (isAnimating) return;
    const nextIndex = (currentIndex + 1) % total;
    updateUI(nextIndex, 'next');
  }

  function goToPrev() {
    if (isAnimating) return;
    const prevIndex = (currentIndex - 1 + total) % total;
    updateUI(prevIndex, 'prev');
  }

  function goToIndex(index) {
    if (isAnimating || index === currentIndex) return;
    const direction = index > currentIndex ? 'next' : 'prev';
    updateUI(index, direction);
  }

  // Event listeners
  PREV_BTN && PREV_BTN.addEventListener('click', goToPrev);
  NEXT_BTN && NEXT_BTN.addEventListener('click', goToNext);

  // Dot clicks
  DOTS.forEach((dot, index) => {
    dot.addEventListener('click', () => goToIndex(index));
  });

  // Touch swipe
  let touchStartX = 0;
  let touchEndX = 0;

  STAGE.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });

  STAGE.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    
    if (Math.abs(diff) > 50) {
      if (diff > 0) {
        goToNext();
      } else {
        goToPrev();
      }
    }
  }, { passive: true });

  // Keyboard navigation
  ROOT.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') {
      e.preventDefault();
      goToPrev();
    } else if (e.key === 'ArrowRight') {
      e.preventDefault();
      goToNext();
    }
  });

  // Handle window resize
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      if (window.innerWidth >= 768) {
        updateCylinderRotation(currentIndex);
      }
    }, 150);
  });

  // Initialize
  updateUI(0);

  // Preload images for smoother animation
  const preloadImages = () => {
    const images = document.querySelectorAll('[data-ms-face] img, [data-ms-mobile-slide] img');
    images.forEach(img => {
      const src = img.src;
      if (src) {
        const preloadLink = document.createElement('link');
        preloadLink.rel = 'preload';
        preloadLink.as = 'image';
        preloadLink.href = src;
        document.head.appendChild(preloadLink);
      }
    });
  };

  if (document.readyState === 'complete') {
    preloadImages();
  } else {
    window.addEventListener('load', preloadImages);
  }

})();
</script>

{% schema %}
{
  "name": "Cylinder Materials",
  "tag": "section",
  "class": "section-cylinder-materials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "MATERIALS"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle / Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Background",
      "default": "#8c6464"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button Hover",
      "default": "#7a5555"
    }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Material Name",
          "default": "Black Beads"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt."
        },
        {
          "type": "header",
          "content": "Images"
        },
        {
