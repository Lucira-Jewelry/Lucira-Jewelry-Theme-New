{% comment %} {%- liquid
  assign s_id    = 'ms-' | append: section.id
  assign s_total = section.blocks.size
-%}

<section
  class="ms-root"
  id="{{ s_id }}"
  data-ms-section
  data-ms-id="{{ s_id }}"
  data-ms-total="{{ s_total }}"
  tabindex="-1"
>
  <div class="ms-inner">

    {%- comment -%}── HEADER ──{%- endcomment -%}
    <div class="ms-head">
      {%- if section.settings.title != blank -%}
        <h2 class="ms-head__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ms-head__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%}
      CAROUSEL STAGE - Modified for 5 visible panels with cylindrical effect
      Slides are stacked absolutely, only the active one is visible
      The panels inside each slide show the active block and its neighbors
    {%- endcomment -%}
    <div class="ms-stage-wrap">
      <div class="ms-stage" data-ms-stage>

        {%- for block in section.blocks -%}
          {%- liquid
            assign bi = forloop.index0

            assign prev2_i = bi | minus: 2
            if prev2_i < 0
              assign prev2_i = prev2_i | plus: s_total
            endif
            assign prev1_i = bi | minus: 1
            if prev1_i < 0
              assign prev1_i = prev1_i | plus: s_total
            endif
            assign next1_i = bi | plus: 1
            if next1_i >= s_total
              assign next1_i = next1_i | minus: s_total
            endif
            assign next2_i = bi | plus: 2
            if next2_i >= s_total
              assign next2_i = next2_i | minus: s_total
            endif

            assign prev2_b = section.blocks[prev2_i]
            assign prev1_b = section.blocks[prev1_i]
            assign next1_b = section.blocks[next1_i]
            assign next2_b = section.blocks[next2_i]
          -%}

          <div
            class="ms-slide{% if forloop.first %} is-active{% endif %}"
            data-ms-slide="{{ bi }}"
            aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
            {{ block.shopify_attributes }}
          >
            {%- comment -%}DESKTOP 5-panel with cylindrical distortion{%- endcomment -%}
            <div class="ms-panels ms-panels--5">

              {%- comment -%}Panel for slide two steps back (far left){%- endcomment -%}
              <div class="ms-panel ms-panel--far-left">
                {%- if prev2_b.settings.desktop_image != blank -%}
                  {{- prev2_b.settings.desktop_image
                      | image_url: width: 300
                      | image_tag:
                          class: 'ms-panel__img',
                          loading: 'lazy',
                          alt: prev2_b.settings.name,
                          widths: '150,240,300' -}}
                {%- endif -%}
              </div>

              {%- comment -%}Panel for previous slide (center-left){%- endcomment -%}
              <div class="ms-panel ms-panel--left">
                {%- if prev1_b.settings.desktop_image != blank -%}
                  {{- prev1_b.settings.desktop_image
                      | image_url: width: 400
                      | image_tag:
                          class: 'ms-panel__img',
                          loading: 'lazy',
                          alt: prev1_b.settings.name,
                          widths: '200,300,400' -}}
                {%- endif -%}
              </div>

              {%- comment -%}Center panel for the current active block{%- endcomment -%}
              <div class="ms-panel ms-panel--center">
                {%- if block.settings.desktop_image != blank -%}
                  {{- block.settings.desktop_image
                      | image_url: width: 700
                      | image_tag:
                          class: 'ms-panel__img',
                          loading: 'lazy',
                          alt: block.settings.name,
                          widths: '400,560,700' -}}
                {%- elsif block.settings.mobile_image != blank -%}
                  {{- block.settings.mobile_image
                      | image_url: width: 700
                      | image_tag:
                          class: 'ms-panel__img',
                          loading: 'lazy',
                          alt: block.settings.name -}}
                {%- endif -%}
              </div>

              {%- comment -%}Panel for next slide (center-right){%- endcomment -%}
              <div class="ms-panel ms-panel--right">
                {%- if next1_b.settings.desktop_image != blank -%}
                  {{- next1_b.settings.desktop_image
                      | image_url: width: 400
                      | image_tag:
                          class: 'ms-panel__img',
                          loading: 'lazy',
                          alt: next1_b.settings.name,
                          widths: '200,300,400' -}}
                {%- endif -%}
              </div>

              {%- comment -%}Panel for slide two steps ahead (far right){%- endcomment -%}
              <div class="ms-panel ms-panel--far-right">
                {%- if next2_b.settings.desktop_image != blank -%}
                  {{- next2_b.settings.desktop_image
                      | image_url: width: 300
                      | image_tag:
                          class: 'ms-panel__img',
                          loading: 'lazy',
                          alt: next2_b.settings.name,
                          widths: '150,240,300' -}}
                {%- endif -%}
              </div>

            </div>

            {%- comment -%}MOBILE single panel{%- endcomment -%}
            <div class="ms-mobile-panel">
              {%- if block.settings.mobile_image != blank -%}
                {{- block.settings.mobile_image
                    | image_url: width: 600
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: block.settings.name,
                        widths: '300,450,600' -}}
              {%- elsif block.settings.desktop_image != blank -%}
                {{- block.settings.desktop_image
                    | image_url: width: 600
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: block.settings.name,
                        widths: '300,450,600' -}}
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}

      </div>
    </div>

    {%- comment -%}── CONTROLS ──{%- endcomment -%}
    <div class="ms-controls">
      <button class="ms-arrow ms-arrow--prev" type="button" data-ms-prev aria-label="Previous material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M6 1.5 1 6.5l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="ms-dot-display" data-ms-dot-display aria-hidden="true">
        {%- for block in section.blocks -%}
          <div class="ms-dot-icon{% if forloop.first %} is-visible{% endif %}" data-ms-dot-icon="{{ forloop.index0 }}">
            {%- if block.settings.icon != blank -%}
              {{- block.settings.icon | image_url: width: 80 | image_tag: class: 'ms-dot-icon__img', loading: 'lazy', alt: block.settings.name -}}
            {%- else -%}
              <span class="ms-dot-icon__swatch" style="background:{{ block.settings.icon_color | default: '#1a1a1a' }};"></span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      <button class="ms-arrow ms-arrow--next" type="button" data-ms-next aria-label="Next material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M1 1.5l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    {%- comment -%}── INFO PANEL ──{%- endcomment -%}
    <div class="ms-info-wrap" data-ms-info-wrap>
      {%- for block in section.blocks -%}
        <div class="ms-info-item{% if forloop.first %} is-active{% endif %}" data-ms-info="{{ forloop.index0 }}" role="region" aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}">
          <h3 class="ms-info-item__name">{{ block.settings.name | upcase | escape }}</h3>
          {%- if block.settings.description != blank -%}
            <p class="ms-info-item__desc">{{ block.settings.description }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_url | default: '#' }}" class="ms-info-item__btn">{{ block.settings.button_label | upcase | escape }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
/* ============================================================
   MATERIALS CAROUSEL  ·  prefix: ms-
   UPDATED FOR 5-PANEL CYLINDRICAL EFFECT
   ============================================================ */
[data-ms-section] {
  --ms-bg:        #f0eeea;
  --ms-arch-bg:   #e8e6e1;
  --ms-panel-bg:  #ffffff;
  --ms-border:    #e2e0db;
  --ms-shad-c:    0 4px 32px rgba(0,0,0,0.10);
  --ms-shad-s:    0 2px 12px rgba(0,0,0,0.05);
  --ms-title-clr: #1a1a1a;
  --ms-text-clr:  #6b6b6b;
  --ms-btn-bg:    {{ section.settings.button_color | default: '#8c6464' }};
  --ms-btn-hov:   {{ section.settings.button_hover_color | default: '#7a5555' }};
  --ms-dot-sz:    56px;
  --ms-arrow-sz:  36px;
  --ms-ease:      cubic-bezier(0.4,0,0.2,1);
  --ms-dur:       500ms;
  --ms-stage-h:   380px;

  background: var(--ms-bg);
  padding: 60px 0 56px;
  overflow: hidden;
  font-family: inherit;
  isolation: isolate;
}

[data-ms-section] *,
[data-ms-section] *::before,
[data-ms-section] *::after { box-sizing: border-box; margin: 0; padding: 0; }

[data-ms-section] a          { text-decoration: none; }
[data-ms-section] img        { display: block; }
[data-ms-section] button     { appearance: none; -webkit-appearance: none; border: none; background: none; cursor: pointer; font-family: inherit; }

/* ── Layout ─────────────────────────────────── */
[data-ms-section] .ms-inner {
  margin: 0 auto;
  padding: 0 24px;
  text-align: center;
}

/* ── Header ─────────────────────────────────── */
[data-ms-section] .ms-head { margin-bottom: 44px; }
[data-ms-section] .ms-head__title {
  font-size: clamp(18px, 2vw, 26px);
  font-weight: 400;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
  margin-bottom: 18px;
}
[data-ms-section] .ms-head__subtitle {
  font-size: 15px;
  color: var(--ms-text-clr);
  line-height: 1.8;
  max-width: 560px;
  margin: 0 auto;
}

/* ── Stage wrap + arch ───────────────────────── */
[data-ms-section] .ms-stage-wrap { position: relative; }
[data-ms-section] .ms-stage-wrap::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  height: 88%;
  background: var(--ms-arch-bg);
  border-radius: 50% 50% 0 0 / 18% 18% 0 0;
  z-index: 0;
  pointer-events: none;
}
[data-ms-section] .ms-stage {
  position: relative;
  height: var(--ms-stage-h);
  z-index: 1;
}

/* ── Slides: ALL stacked ─────────────────────── */
[data-ms-section] .ms-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateX(32px);
  transition:
    opacity var(--ms-dur) var(--ms-ease),
    transform var(--ms-dur) var(--ms-ease),
    visibility 0s linear var(--ms-dur);
  will-change: opacity, transform;
}
[data-ms-section] .ms-slide.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateX(0);
  z-index: 2;
  transition:
    opacity var(--ms-dur) var(--ms-ease),
    transform var(--ms-dur) var(--ms-ease),
    visibility 0s linear 0s;
}
[data-ms-section] .ms-slide.is-out-left {
  opacity: 0;
  transform: translateX(-32px);
  transition:
    opacity var(--ms-dur) var(--ms-ease),
    transform var(--ms-dur) var(--ms-ease);
  z-index: 1;
}
[data-ms-section] .ms-slide.is-out-right {
  opacity: 0;
  transform: translateX(32px);
  transition:
    opacity var(--ms-dur) var(--ms-ease),
    transform var(--ms-dur) var(--ms-ease);
  z-index: 1;
}

/* ============================================================
   5-panel desktop with cylindrical transformations
   ============================================================ */
[data-ms-section] .ms-panels--5 {
  display: flex;
  align-items: stretch;
  height: 100%;
  gap: 6px;
}

/* Base panel styles */
[data-ms-section] .ms-panel {
  flex: 1;
  background: var(--ms-panel-bg);
  border: 1px solid var(--ms-border);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  height: 100%;
  transition: all var(--ms-dur) var(--ms-ease);
}

/* ---- CYLINDRICAL TRANSFORMATIONS ---- */
/* Far Left (two steps back) */
[data-ms-section] .ms-panel--far-left {
  border-radius: 10px 0 0 10px;
  transform: perspective(1200px) rotateY(40deg) scaleY(1.10);
  transform-origin: right center;
  box-shadow: var(--ms-shad-s);
  opacity: 0.7;
  z-index: 1;
  flex:1.3;
}

/* Left (one step back) */
[data-ms-section] .ms-panel--left {
  border-right: none;
  transform: perspective(1200px) rotateY(30deg) scaleY(0.96);
  transform-origin: right center;
  box-shadow: var(--ms-shad-s);
  opacity: 0.85;
  z-index: 2;
}

/* Center (active slide) */
[data-ms-section] .ms-panel--center {
  z-index: 5;
  border-radius: 4px;
  box-shadow: var(--ms-shad-c);
  flex: 1.60;
  transform: scale(0.95);
}

/* Right (one step ahead) */
[data-ms-section] .ms-panel--right {
  border-left: none;
  transform: perspective(1200px) rotateY(-30deg) scaleY(0.96);
  transform-origin: left center;
  box-shadow: var(--ms-shad-s);
  opacity: 0.85;
  z-index: 2;
}

/* Far Right (two steps ahead) */
[data-ms-section] .ms-panel--far-right {
  border-radius: 0 10px 10px 0;
  transform: perspective(1200px) rotateY(-40deg) scaleY(1.10);
  transform-origin: left center;
  box-shadow: var(--ms-shad-s);
  opacity: 0.7;
  z-index: 1;
  flex:1.3;
}

/* Images fill panels */
[data-ms-section] .ms-panel__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 20px 12px;
}

/* Mobile panel */
[data-ms-section] .ms-mobile-panel {
  display: none;
  height: 100%;
  align-items: center;
  justify-content: center;
  background: var(--ms-panel-bg);
  border: 1px solid var(--ms-border);
  border-radius: 6px;
  box-shadow: var(--ms-shad-c);
  overflow: hidden;
}

/* Controls (unchanged) */
[data-ms-section] .ms-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin: 28px 0 4px;
  position: relative;
  z-index: 4;
}
[data-ms-section] .ms-arrow {
  flex-shrink: 0;
  width: var(--ms-arrow-sz);
  height: var(--ms-arrow-sz);
  border: 1.5px solid #c8c8c8 !important;
  border-radius: 50%;
  background: transparent !important;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #444;
  transition: border-color 0.2s, background 0.2s, transform 0.15s;
}
[data-ms-section] .ms-arrow:hover {
  border-color: #888 !important;
  background: rgba(0,0,0,0.04) !important;
}
[data-ms-section] .ms-arrow:active { transform: scale(0.90); }

/* Dot display */
[data-ms-section] .ms-dot-display {
  position: relative;
  width: var(--ms-dot-sz);
  height: var(--ms-dot-sz);
  flex-shrink: 0;
  border-radius: 50%;
  box-shadow: 0 0 0 2.5px #1a1a1a;
}
[data-ms-section] .ms-dot-icon {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  overflow: hidden;
  opacity: 0;
  transform: scale(0.65) rotate(-20deg);
  pointer-events: none;
  transition:
    opacity 0.32s var(--ms-ease),
    transform 0.32s var(--ms-ease);
}
[data-ms-section] .ms-dot-icon.is-visible {
  opacity: 1;
  transform: scale(1) rotate(0deg);
}
[data-ms-section] .ms-dot-icon__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}
[data-ms-section] .ms-dot-icon__swatch {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* Info block */
[data-ms-section] .ms-info-wrap {
  position: relative;
  min-height: 152px;
  margin-top: 24px;
}
[data-ms-section] .ms-info-item {
  position: absolute;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateY(10px);
  transition:
    opacity 0.35s var(--ms-ease),
    transform 0.35s var(--ms-ease),
    visibility 0s linear 0.35s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}
[data-ms-section] .ms-info-item.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateY(0);
  transition:
    opacity 0.35s var(--ms-ease) 0.12s,
    transform 0.35s var(--ms-ease) 0.12s,
    visibility 0s linear 0s;
}
[data-ms-section] .ms-info-item__name {
  font-size: clamp(15px, 1.6vw, 20px);
  font-weight: 400;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
}
[data-ms-section] .ms-info-item__desc {
  font-size: 14px;
  color: var(--ms-text-clr);
  line-height: 1.8;
  max-width: 480px;
}
[data-ms-section] .ms-info-item__btn {
  display: inline-block;
  padding: 13px 38px;
  background: var(--ms-btn-bg);
  color: #fff;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  transition: background 0.22s var(--ms-ease), transform 0.15s;
  margin-top: 4px;
}
[data-ms-section] .ms-info-item__btn:hover {
  background: var(--ms-btn-hov);
  color: #fff;
}
[data-ms-section] .ms-info-item__btn:active { transform: scale(0.97); }

/* Responsive for mobile */
@media screen and (max-width: 767px) {
  [data-ms-section] {
    padding: 40px 0 44px;
    --ms-stage-h: 300px;
  }
  [data-ms-section] .ms-inner    { padding: 0 16px; }
  [data-ms-section] .ms-head     { margin-bottom: 28px; }
  [data-ms-section] .ms-head__title { font-size: 17px; letter-spacing: 4px; }

  [data-ms-section] .ms-panels--5 { display: none !important; }
  [data-ms-section] .ms-mobile-panel { display: flex; }

  [data-ms-section] .ms-stage-wrap::before {
    border-radius: 50% 50% 0 0 / 12% 12% 0 0;
    height: 84%;
  }
  [data-ms-section] .ms-info-wrap { min-height: 164px; }
  [data-ms-section] .ms-info-item__desc { max-width: 300px; }
}

[data-ms-section][data-ms-total="1"] .ms-controls { display: none; }
</style>

<script>
(function () {
  'use strict';

  var ROOT = document.getElementById('{{ s_id }}');
  if (!ROOT) return;

  var STAGE      = ROOT.querySelector('[data-ms-stage]');
  var SLIDES     = Array.from(ROOT.querySelectorAll('[data-ms-slide]'));
  var DOT_ICONS  = Array.from(ROOT.querySelectorAll('[data-ms-dot-icon]'));
  var INFO_ITEMS = Array.from(ROOT.querySelectorAll('[data-ms-info]'));
  var PREV_BTN   = ROOT.querySelector('[data-ms-prev]');
  var NEXT_BTN   = ROOT.querySelector('[data-ms-next]');

  var total    = SLIDES.length;
  var current  = 0;
  var locked   = false;
  var DURATION = 500;

  if (total <= 1) return;

  function go(next, dir) {
    if (locked) return;
    next = ((next % total) + total) % total;
    if (next === current) return;

    locked = true;
    var from = current;
    current  = next;

    var oldSlide = SLIDES[from];
    var newSlide = SLIDES[next];

    /* Set incoming slide starting position */
    var startX = dir === 'next' ? '32px' : '-32px';
    newSlide.style.cssText =
      'position:absolute;inset:0;opacity:0;visibility:visible;pointer-events:none;' +
      'transform:translateX(' + startX + ');transition:none;z-index:2;';

    /* Force reflow */
    void newSlide.offsetWidth;

    /* Animate old slide out */
    oldSlide.classList.remove('is-active');
    oldSlide.classList.add(dir === 'next' ? 'is-out-left' : 'is-out-right');

    /* Animate new slide in */
    newSlide.style.cssText = '';
    newSlide.classList.add('is-active');
    newSlide.setAttribute('aria-hidden', 'false');
    oldSlide.setAttribute('aria-hidden', 'true');

    /* Clean up after animation */
    setTimeout(function () {
      oldSlide.classList.remove('is-out-left', 'is-out-right');
      oldSlide.style.cssText = '';
      locked = false;
    }, DURATION + 60);

    /* Update dot icon */
    var oldDot = DOT_ICONS[from];
    var newDot = DOT_ICONS[next];
    if (oldDot) oldDot.classList.remove('is-visible');
    setTimeout(function () {
      if (newDot) newDot.classList.add('is-visible');
    }, 80);

    /* Update info panel */
    var oldInfo = INFO_ITEMS[from];
    var newInfo = INFO_ITEMS[next];
    if (oldInfo) {
      oldInfo.classList.remove('is-active');
      oldInfo.setAttribute('aria-hidden', 'true');
    }
    if (newInfo) {
      newInfo.classList.add('is-active');
      newInfo.setAttribute('aria-hidden', 'false');
    }
  }

  /* Event Listeners */
  PREV_BTN && PREV_BTN.addEventListener('click', function () { go(current - 1, 'prev'); });
  NEXT_BTN && NEXT_BTN.addEventListener('click', function () { go(current + 1, 'next'); });

  /* Touch swipe */
  var tx = 0, ty = 0;
  STAGE.addEventListener('touchstart', function (e) {
    tx = e.changedTouches[0].clientX;
    ty = e.changedTouches[0].clientY;
  }, { passive: true });
  STAGE.addEventListener('touchend', function (e) {
    var dx = e.changedTouches[0].clientX - tx;
    var dy = e.changedTouches[0].clientY - ty;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
      go(dx < 0 ? current + 1 : current - 1, dx < 0 ? 'next' : 'prev');
    }
  }, { passive: true });

  /* Keyboard */
  ROOT.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  go(current - 1, 'prev');
    if (e.key === 'ArrowRight') go(current + 1, 'next');
  });

  /* Dynamic height lock */
  function lockHeight() {
    if (!STAGE) return;
    var max = 0;
    SLIDES.forEach(function (s) {
      var prev = s.style.cssText;
      s.style.cssText = 'position:relative!important;opacity:0!important;visibility:visible!important;transform:none!important;pointer-events:none!important;transition:none!important;';
      var h = s.offsetHeight;
      s.style.cssText = prev;
      if (h > max) max = h;
    });
    if (max > 10) STAGE.style.height = max + 'px';
  }

  if (document.readyState === 'complete') {
    lockHeight();
  } else {
    window.addEventListener('load', lockHeight);
  }

  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(lockHeight, 120);
  });

})();
</script>

