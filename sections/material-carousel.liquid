{%- liquid
  assign s_id     = 'ms-' | append: section.id
  assign s_total  = section.blocks.size
-%}

<section
  class="ms-root"
  id="{{ s_id }}"
  data-ms-section
  data-ms-id="{{ s_id }}"
  data-ms-total="{{ s_total }}"
>
  <div class="ms-inner">

    {%- comment -%} ── Header ── {%- endcomment -%}
    <div class="ms-head">
      {%- if section.settings.title != blank -%}
        <h2 class="ms-head__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ms-head__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ── Cylinder Carousel ── {%- endcomment -%}
    <div class="ms-carousel" data-ms-carousel>
      {%- for block in section.blocks -%}
        {%- liquid
          assign bi = forloop.index0

          assign pi = bi | minus: 1
          if pi < 0
            assign pi = s_total | minus: 1
          endif

          assign ni = bi | plus: 1
          if ni >= s_total
            assign ni = 0
          endif

          assign pb = section.blocks[pi]
          assign nb = section.blocks[ni]
        -%}

        <div
          class="ms-slide{% if forloop.first %} ms-slide--active{% endif %}"
          data-ms-slide="{{ bi }}"
          aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
          {{ block.shopify_attributes }}
        >

          {%- comment -%} Desktop: 3-panel cylinder view {%- endcomment -%}
          <div class="ms-panels">

            <div class="ms-panel ms-panel--l">
              {%- if pb.settings.desktop_image != blank -%}
                {{- pb.settings.desktop_image
                    | image_url: width: 400
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: pb.settings.name,
                        widths: '200, 300, 400' -}}
              {%- endif -%}
            </div>

            <div class="ms-panel ms-panel--c">
              {%- if block.settings.desktop_image != blank -%}
                {{- block.settings.desktop_image
                    | image_url: width: 580
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: block.settings.name,
                        widths: '300, 450, 580' -}}
              {%- elsif block.settings.mobile_image != blank -%}
                {{- block.settings.mobile_image
                    | image_url: width: 580
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: block.settings.name -}}
              {%- endif -%}
            </div>

            <div class="ms-panel ms-panel--r">
              {%- if nb.settings.desktop_image != blank -%}
                {{- nb.settings.desktop_image
                    | image_url: width: 400
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: nb.settings.name,
                        widths: '200, 300, 400' -}}
              {%- endif -%}
            </div>

          </div>

          {%- comment -%}
            Mobile: single centered panel.
            Falls back to desktop_image if mobile_image is not set.
          {%- endcomment -%}
          <div class="ms-mobile">
            {%- if block.settings.mobile_image != blank -%}
              {{- block.settings.mobile_image
                  | image_url: width: 500
                  | image_tag:
                      class: 'ms-panel__img',
                      loading: 'lazy',
                      alt: block.settings.name,
                      widths: '280, 380, 500' -}}
            {%- elsif block.settings.desktop_image != blank -%}
              {{- block.settings.desktop_image
                  | image_url: width: 500
                  | image_tag:
                      class: 'ms-panel__img',
                      loading: 'lazy',
                      alt: block.settings.name,
                      widths: '280, 380, 500' -}}
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} ── Selector row: arrow · dots · arrow ── {%- endcomment -%}
    <div class="ms-controls">
      <button class="ms-arrow ms-arrow--prev" type="button" data-ms-prev aria-label="Previous material">
        <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true">
          <path d="M6 1L1 6l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="ms-dots" role="tablist" aria-label="{{ section.settings.title | escape }} materials">
        {%- for block in section.blocks -%}
          <button
            class="ms-dot{% if forloop.first %} ms-dot--active{% endif %}"
            type="button"
            data-ms-dot="{{ forloop.index0 }}"
            role="tab"
            aria-selected="{{ forloop.first | json }}"
            aria-label="View {{ block.settings.name | escape }}"
          >
            {%- if block.settings.icon != blank -%}
              {{- block.settings.icon
                  | image_url: width: 60
                  | image_tag:
                      class: 'ms-dot__img',
                      loading: 'lazy',
                      alt: block.settings.name -}}
            {%- else -%}
              <span
                class="ms-dot__swatch"
                style="background: {{ block.settings.icon_color | default: '#1a1a1a' }};"
                aria-hidden="true"
              ></span>
            {%- endif -%}
          </button>
        {%- endfor -%}
      </div>

      <button class="ms-arrow ms-arrow--next" type="button" data-ms-next aria-label="Next material">
        <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true">
          <path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    {%- comment -%} ── Material info ── {%- endcomment -%}
    <div class="ms-info" data-ms-info-wrap>
      {%- for block in section.blocks -%}
        <div
          class="ms-info__item{% if forloop.first %} ms-info__item--active{% endif %}"
          data-ms-info="{{ forloop.index0 }}"
          role="tabpanel"
          {%- unless forloop.first %} aria-hidden="true"{% endunless %}
        >
          <h3 class="ms-info__name">{{ block.settings.name | upcase | escape }}</h3>
          {%- if block.settings.description != blank -%}
            <p class="ms-info__desc">{{ block.settings.description }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a
              href="{{ block.settings.button_url | default: '#' }}"
              class="ms-info__btn"
            >
              {{- block.settings.button_label | upcase | escape -}}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{%- comment -%} ────────────────────────────────────────────────
  STYLES
  All rules are scoped under [data-ms-section] and prefixed ms-
  so they cannot bleed into other sections.
──────────────────────────────────────────────── {%- endcomment -%}
<style>
/* ============================================================
   MATERIALS CAROUSEL  |  prefix: ms-
   Scoped to: [data-ms-section]
   ============================================================ */

/* CSS custom properties — override in Shopify theme settings if needed */
[data-ms-section] {
  --ms-bg:           #f4f4f2;
  --ms-arch-bg:      #e9e9e7;
  --ms-panel-bg:     #ffffff;
  --ms-border:       #e3e3e3;
  --ms-shadow:       0 2px 18px rgba(0,0,0,0.07);
  --ms-title-color:  #1a1a1a;
  --ms-text-color:   #5a5a5a;
  --ms-btn-bg:       {{ section.settings.button_color | default: '#8c6464' }};
  --ms-btn-hover:    {{ section.settings.button_hover_color | default: '#7a5555' }};
  --ms-dot-ring:     #1a1a1a;
  --ms-arrow-border: #c0c0c0;
  --ms-font-family:  inherit;
  --ms-ease:         cubic-bezier(0.4, 0, 0.2, 1);

  background: var(--ms-bg);
  padding: 64px 0 52px;
  overflow: hidden;
  font-family: var(--ms-font-family);
}

/* Hard reset only inside our section to avoid collisions */
[data-ms-section] *,
[data-ms-section] *::before,
[data-ms-section] *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

[data-ms-section] button {
  appearance: none;
  -webkit-appearance: none;
}

/* ── Layout ─────────────────────────────────────── */
.ms-inner {
  max-width: 980px;
  margin: 0 auto;
  padding: 0 24px;
  text-align: center;
}

/* ── Header ─────────────────────────────────────── */
.ms-head {
  margin-bottom: 40px;
}

.ms-head__title {
  font-size: clamp(18px, 2.2vw, 24px);
  font-weight: 500;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--ms-title-color);
  line-height: 1.3;
  margin-bottom: 14px;
}

.ms-head__subtitle {
  font-size: 14px;
  color: var(--ms-text-color);
  line-height: 1.75;
  max-width: 540px;
  margin: 0 auto;
}

/* ── Carousel wrapper + arch background ─────────── */
.ms-carousel {
  position: relative;
  margin: 0 -24px;   /* bleed to edges */
  padding: 0 24px;
}

/* The arch / cylinder-mouth pseudo-element */
.ms-carousel::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 105%;
  height: 92%;
  background: var(--ms-arch-bg);
  border-radius: 50% 50% 0 0 / 22% 22% 0 0;
  z-index: 0;
  pointer-events: none;
}

/* ── Slide show/hide ─────────────────────────────── */
.ms-slide {
  display: none;
  position: relative;
  z-index: 1;
}

.ms-slide--active {
  display: block;
}

/* Entering animation classes added by JS */
.ms-slide--enter-next {
  display: block;
  animation: ms-enter-from-right 0.38s var(--ms-ease) both;
}

.ms-slide--enter-prev {
  display: block;
  animation: ms-enter-from-left 0.38s var(--ms-ease) both;
}

@keyframes ms-enter-from-right {
  from { opacity: 0; transform: translateX(28px); }
  to   { opacity: 1; transform: translateX(0); }
}

@keyframes ms-enter-from-left {
  from { opacity: 0; transform: translateX(-28px); }
  to   { opacity: 1; transform: translateX(0); }
}

/* ── Desktop: 3-panel cylinder ───────────────────── */
.ms-panels {
  display: flex;
  align-items: stretch;
  gap: 0;
  padding-top: 28px;
}

.ms-panel {
  flex: 1;
  background: var(--ms-panel-bg);
  border: 1px solid var(--ms-border);
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 250px;
  padding: 28px 18px;
  overflow: hidden;
  will-change: transform;
}

/* Left panel — angled like cylinder left face */
.ms-panel--l {
  transform: perspective(900px) rotateY(22deg) scaleY(0.97);
  transform-origin: right center;
  border-right: none;
  border-radius: 6px 0 0 6px;
  opacity: 0.88;
}

/* Center panel — straight front face */
.ms-panel--c {
  transform: perspective(900px) rotateY(0deg);
  z-index: 2;
  box-shadow: var(--ms-shadow);
  min-height: 270px;
}

/* Right panel — angled like cylinder right face */
.ms-panel--r {
  transform: perspective(900px) rotateY(-22deg) scaleY(0.97);
  transform-origin: left center;
  border-left: none;
  border-radius: 0 6px 6px 0;
  opacity: 0.88;
}

.ms-panel__img {
  max-width: 100%;
  max-height: 190px;
  width: auto;
  height: auto;
  object-fit: contain;
  display: block;
  margin: 0 auto;
}

.ms-panel--c .ms-panel__img {
  max-height: 210px;
}

/* ── Mobile: single center panel ────────────────── */
.ms-mobile {
  display: none;
  align-items: center;
  justify-content: center;
  min-height: 270px;
  padding: 28px 20px 16px;
  background: var(--ms-panel-bg);
  border: 1px solid var(--ms-border);
  box-shadow: var(--ms-shadow);
}

.ms-mobile .ms-panel__img {
  max-height: 230px;
  max-width: 90%;
}

/* ── Controls row ────────────────────────────────── */
.ms-controls {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  margin: 24px 0 6px;
}

/* Prev / Next arrow buttons */
.ms-arrow {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  border: 1px solid var(--ms-arrow-border);
  border-radius: 50%;
  background: transparent;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  transition: background 0.2s, border-color 0.2s, transform 0.15s;
}

.ms-arrow:hover {
  background: rgba(0,0,0,0.05);
  border-color: #888;
}

.ms-arrow:active {
  transform: scale(0.92);
}

/* Dot selector strip */
.ms-dots {
  display: flex;
  gap: 8px;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
}

.ms-dot {
  width: 48px;
  height: 48px;
  border: 2.5px solid transparent;
  border-radius: 50%;
  background: transparent;
  cursor: pointer;
  padding: 2px;
  overflow: hidden;
  transition: border-color 0.25s var(--ms-ease), transform 0.25s var(--ms-ease);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ms-dot--active {
  border-color: var(--ms-dot-ring);
  transform: scale(1.12);
}

.ms-dot__img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
  display: block;
}

/* Fallback color swatch when no icon image */
.ms-dot__swatch {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #1a1a1a;
}

/* ── Info / content block ────────────────────────── */
.ms-info {
  position: relative;
  z-index: 2;
  margin-top: 18px;
  min-height: 130px;
}

.ms-info__item {
  display: none;
  opacity: 0;
  transition: opacity 0.3s var(--ms-ease);
}

.ms-info__item--active {
  display: block;
  opacity: 1;
}

.ms-info__name {
  font-size: clamp(16px, 1.8vw, 20px);
  font-weight: 500;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--ms-title-color);
  margin-bottom: 12px;
}

.ms-info__desc {
  font-size: 14px;
  color: var(--ms-text-color);
  line-height: 1.75;
  max-width: 480px;
  margin: 0 auto 22px;
}

.ms-info__btn {
  display: inline-block;
  padding: 12px 34px;
  background: var(--ms-btn-bg);
  color: #fff;
  text-decoration: none;
  font-size: 11px;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  border: none;
  cursor: pointer;
  transition: background 0.2s var(--ms-ease), transform 0.15s;
}

.ms-info__btn:hover {
  background: var(--ms-btn-hover);
  color: #fff;
  text-decoration: none;
}

.ms-info__btn:active {
  transform: scale(0.97);
}

/* ── Responsive: mobile ──────────────────────────── */
@media screen and (max-width: 767px) {
  [data-ms-section] {
    padding: 44px 0 40px;
  }

  .ms-inner {
    padding: 0 16px;
  }

  /* Hide 3-panel layout, show single panel */
  .ms-panels {
    display: none !important;
  }

  .ms-mobile {
    display: flex;
  }

  /* Narrower arch on mobile */
  .ms-carousel::before {
    border-radius: 50% 50% 0 0 / 14% 14% 0 0;
    width: 110%;
    height: 88%;
  }

  .ms-head__title {
    font-size: 18px;
    letter-spacing: 3px;
  }

  .ms-dot {
    width: 42px;
    height: 42px;
  }

  .ms-info__desc {
    max-width: 300px;
  }
}

/* ── Hide controls when only 1 block ─────────────── */
[data-ms-section][data-ms-total="1"] .ms-controls {
  display: none;
}
</style>

{%- comment -%} ────────────────────────────────────────────────
  JAVASCRIPT — IIFE scoped, no globals polluted
──────────────────────────────────────────────── {%- endcomment -%}
<script>
(function () {
  'use strict';

  var ROOT = document.getElementById('{{ s_id }}');
  if (!ROOT) return;

  var SLIDES     = Array.from(ROOT.querySelectorAll('[data-ms-slide]'));
  var DOTS       = Array.from(ROOT.querySelectorAll('[data-ms-dot]'));
  var INFO_ITEMS = Array.from(ROOT.querySelectorAll('[data-ms-info]'));
  var PREV_BTN   = ROOT.querySelector('[data-ms-prev]');
  var NEXT_BTN   = ROOT.querySelector('[data-ms-next]');
  var CAROUSEL   = ROOT.querySelector('[data-ms-carousel]');

  var total      = SLIDES.length;
  var current    = 0;
  var busy       = false;

  if (total <= 1) return; // nothing to navigate

  /* ── Core navigation ── */
  function goTo(nextIdx, dir) {
    if (busy) return;
    nextIdx = ((nextIdx % total) + total) % total;
    if (nextIdx === current) return;

    busy = true;

    var prevIdx   = current;
    current       = nextIdx;

    var prevSlide = SLIDES[prevIdx];
    var nextSlide = SLIDES[current];
    var enterCls  = dir === 'prev' ? 'ms-slide--enter-prev' : 'ms-slide--enter-next';

    /* Fade / slide out old */
    prevSlide.style.transition = 'opacity 0.28s ease';
    prevSlide.style.opacity    = '0';

    /* Trigger enter animation on new slide */
    nextSlide.classList.add(enterCls);

    setTimeout(function () {
      /* Hide old slide */
      prevSlide.style.transition = '';
      prevSlide.style.opacity    = '';
      prevSlide.classList.remove('ms-slide--active');

      /* Finalise new slide */
      nextSlide.classList.remove(enterCls);
      nextSlide.classList.add('ms-slide--active');
      nextSlide.setAttribute('aria-hidden', 'false');
      prevSlide.setAttribute('aria-hidden', 'true');

      busy = false;
    }, 380);

    /* Dots */
    DOTS.forEach(function (dot, i) {
      var active = i === current;
      dot.classList.toggle('ms-dot--active', active);
      dot.setAttribute('aria-selected', String(active));
    });

    /* Info items */
    var prevInfo = INFO_ITEMS[prevIdx];
    var nextInfo = INFO_ITEMS[current];

    if (prevInfo) {
      prevInfo.style.transition = 'opacity 0.22s ease';
      prevInfo.style.opacity    = '0';
      setTimeout(function () {
        prevInfo.classList.remove('ms-info__item--active');
        prevInfo.setAttribute('aria-hidden', 'true');
        prevInfo.style.transition = '';
        prevInfo.style.opacity    = '';
      }, 220);
    }

    if (nextInfo) {
      setTimeout(function () {
        nextInfo.classList.add('ms-info__item--active');
        nextInfo.setAttribute('aria-hidden', 'false');
        nextInfo.style.opacity    = '0';
        nextInfo.style.transition = 'opacity 0.3s ease';
        /* rAF double-tap to trigger transition */
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            nextInfo.style.opacity = '1';
            setTimeout(function () {
              nextInfo.style.transition = '';
              nextInfo.style.opacity    = '';
            }, 300);
          });
        });
      }, 120);
    }
  }

  /* ── Buttons ── */
  PREV_BTN && PREV_BTN.addEventListener('click', function () {
    goTo(current - 1, 'prev');
  });

  NEXT_BTN && NEXT_BTN.addEventListener('click', function () {
    goTo(current + 1, 'next');
  });

  /* ── Dot clicks ── */
  DOTS.forEach(function (dot) {
    dot.addEventListener('click', function () {
      var idx = parseInt(dot.getAttribute('data-ms-dot'), 10);
      goTo(idx, idx > current ? 'next' : 'prev');
    });
  });

  /* ── Touch / swipe on carousel ── */
  var touchX = 0;
  var touchY = 0;

  CAROUSEL && CAROUSEL.addEventListener('touchstart', function (e) {
    touchX = e.changedTouches[0].clientX;
    touchY = e.changedTouches[0].clientY;
  }, { passive: true });

  CAROUSEL && CAROUSEL.addEventListener('touchend', function (e) {
    var dx = e.changedTouches[0].clientX - touchX;
    var dy = e.changedTouches[0].clientY - touchY;
    /* Only horizontal swipes with enough distance */
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 44) {
      if (dx < 0) goTo(current + 1, 'next');
      else         goTo(current - 1, 'prev');
    }
  }, { passive: true });

  /* ── Keyboard support (left/right arrows) ── */
  ROOT.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  goTo(current - 1, 'prev');
    if (e.key === 'ArrowRight') goTo(current + 1, 'next');
  });

})();
</script>

{% schema %}
{
  "name": "Materials Carousel",
  "tag": "section",
  "class": "section-materials-carousel",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "MATERIALS"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Section Subtitle / Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Background",
      "default": "#8c6464"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button Hover Background",
      "default": "#7a5555"
    }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Material Name",
          "default": "Black Beads",
          "info": "Displayed in ALL CAPS below the carousel."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
        },
        {
          "type": "header",
          "content": "Selector Icon"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image",
          "info": "Circular image shown in the selector row. Recommended: 120×120 px PNG."
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "Fallback Icon Colour",
          "default": "#1a1a1a",
          "info": "Used when no Icon Image is set."
        },
        {
          "type": "header",
          "content": "Images"
        },
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop / Main Image",
          "info": "Used as the centre panel on desktop and as the mobile fallback if no Mobile Image is set. Recommended: 600×500 px."
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image (optional)",
          "info": "If left blank, the Desktop Image is used on mobile. Recommended: 500×500 px."
        },
