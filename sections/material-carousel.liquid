{%- liquid
  assign s_id    = 'mc-' | append: section.id
  assign s_total = section.blocks.size
-%}

<section
  class="mc-root"
  id="{{ s_id }}"
  data-mc-section
  data-mc-id="{{ s_id }}"
  data-mc-total="{{ s_total }}"
>
  <div class="mc-inner">

    {%- comment -%}── MAIN TITLE SECTION (MATERIALS) ──{%- endcomment -%}
    <div class="mc-header">
      <h2 class="mc-header__title">{{ section.settings.title | default: 'MATERIALS' | escape }}</h2>
      <p class="mc-header__desc">{{ section.settings.header_description | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.' }}</p>
    </div>

    {%- comment -%}── CYLINDRICAL CAROUSEL WITH 5 VISIBLE IMAGES ──{%- endcomment -%}
    <div class="mc-carousel-wrapper">
      <!-- Curved background cylinder -->
      <div class="mc-cylinder-bg"></div>
      
      <div class="mc-carousel" data-mc-carousel>
        <button class="mc-arrow mc-arrow--left" data-mc-prev aria-label="Previous">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="mc-track-container">
          <div class="mc-track" data-mc-track>
            {%- comment -%}Create enough slides for infinite loop effect with 5 visible{%- endcomment -%}
            {%- for i in (1..15) -%}
              {%- assign block_index = forloop.index0 | modulo: s_total -%}
              {%- assign block = section.blocks[block_index] -%}
              
              <div class="mc-slide" data-mc-slide="{{ block_index }}" data-mc-pos="{{ forloop.index0 }}">
                <div class="mc-slide-inner">
                  {%- if block.settings.image != blank -%}
                    {{- block.settings.image
                        | image_url: width: 400
                        | image_tag:
                            class: 'mc-slide__img',
                            loading: 'lazy',
                            alt: block.settings.name,
                            widths: '200,300,400' -}}
                  {%- else -%}
                    <div class="mc-slide__placeholder"></div>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>

        <button class="mc-arrow mc-arrow--right" data-mc-next aria-label="Next">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <!-- Material indicators (dots) -->
      <div class="mc-indicators" data-mc-indicators>
        {%- for block in section.blocks -%}
          <button class="mc-indicator{% if forloop.first %} is-active{% endif %}" data-mc-indicator="{{ forloop.index0 }}" aria-label="Go to {{ block.settings.name }}">
            <span class="mc-indicator-dot"></span>
          </button>
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%}── MATERIAL INFO SECTION (BLACK BEADS + description + button) ──{%- endcomment -%}
    <div class="mc-info-panel" data-mc-info-panel>
      {%- for block in section.blocks -%}
        <div class="mc-info{% if forloop.first %} is-active{% endif %}" data-mc-info="{{ forloop.index0 }}">
          <h3 class="mc-info__title">{{ block.settings.name | default: 'BLACK BEADS' | upcase }}</h3>
          <p class="mc-info__desc">{{ block.settings.description | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.' }}</p>
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_url | default: '#' }}" class="mc-info__btn">{{ block.settings.button_label | upcase }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
/* ============================================================
   MATERIALS CYLINDER CAROUSEL
   Exact match to provided design
   ============================================================ */
[data-mc-section] {
  --mc-bg: #f5f3f0;
  --mc-cylinder-bg: #e8e4df;
  --mc-slide-bg: #ffffff;
  --mc-border: #d4d0cb;
  --mc-text-dark: #1a1a1a;
  --mc-text-light: #6b6b6b;
  --mc-accent: #8c7a6b;
  --mc-ease: cubic-bezier(0.4, 0, 0.2, 1);
  --mc-dur: 500ms;

  background: var(--mc-bg);
  padding: 80px 0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

[data-mc-section] * {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

[data-mc-section] .mc-inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 40px;
}

/* ── HEADER SECTION (MATERIALS) ───────────────── */
[data-mc-section] .mc-header {
  text-align: center;
  margin-bottom: 60px;
}

[data-mc-section] .mc-header__title {
  font-size: 32px;
  font-weight: 400;
  letter-spacing: 8px;
  text-transform: uppercase;
  color: var(--mc-text-dark);
  margin-bottom: 20px;
}

[data-mc-section] .mc-header__desc {
  font-size: 16px;
  line-height: 1.8;
  color: var(--mc-text-light);
  max-width: 700px;
  margin: 0 auto;
}

/* ── CYLINDRICAL CAROUSEL ─────────────────────── */
[data-mc-section] .mc-carousel-wrapper {
  position: relative;
  margin: 40px 0 30px;
  padding: 30px 0;
}

/* Cylinder background (the curved shape) */
[data-mc-section] .mc-cylinder-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--mc-cylinder-bg);
  border-radius: 50% / 60px 60px 60px 60px;
  transform: scaleY(0.85);
  box-shadow: 0 20px 30px rgba(0,0,0,0.05);
  z-index: 0;
}

[data-mc-section] .mc-carousel {
  position: relative;
  display: flex;
  align-items: center;
  gap: 20px;
  z-index: 2;
}

[data-mc-section] .mc-track-container {
  flex: 1;
  overflow: hidden;
  padding: 20px 0;
}

[data-mc-section] .mc-track {
  display: flex;
  gap: 20px;
  transition: transform var(--mc-dur) var(--mc-ease);
  will-change: transform;
}

/* Individual slides */
[data-mc-section] .mc-slide {
  flex: 0 0 calc(20% - 16px); /* 5 slides visible with gap */
  min-width: 180px;
  aspect-ratio: 3/4;
  background: var(--mc-slide-bg);
  border: 1px solid var(--mc-border);
  border-radius: 40px 40px 20px 20px; /* Squeezed top/bottom radius */
  overflow: hidden;
  box-shadow: 0 15px 25px rgba(0,0,0,0.1);
  transition: all 0.3s ease;
  position: relative;
}

/* Inner circle effect */
[data-mc-section] .mc-slide::before {
  content: '';
  position: absolute;
  inset: 8px;
  border-radius: 32px 32px 16px 16px;
  background: rgba(255,255,255,0.15);
  pointer-events: none;
  z-index: 1;
}

/* Active slide highlight */
[data-mc-section] .mc-slide.is-active {
  transform: scale(1.02);
  box-shadow: 0 20px 30px rgba(0,0,0,0.15);
  border-color: var(--mc-accent);
}

[data-mc-section] .mc-slide-inner {
  width: 100%;
  height: 100%;
  padding: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

[data-mc-section] .mc-slide__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  filter: drop-shadow(0 5px 10px rgba(0,0,0,0.1));
}

[data-mc-section] .mc-slide__placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 200%;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* Navigation arrows */
[data-mc-section] .mc-arrow {
  width: 44px;
  height: 44px;
  border: 1px solid var(--mc-border);
  border-radius: 50%;
  background: white;
  color: var(--mc-text-dark);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  flex-shrink: 0;
  z-index: 3;
}

[data-mc-section] .mc-arrow:hover {
  background: var(--mc-accent);
  color: white;
  border-color: var(--mc-accent);
  transform: scale(1.05);
}

[data-mc-section] .mc-arrow:active {
  transform: scale(0.95);
}

/* Indicators (dots) */
[data-mc-section] .mc-indicators {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-top: 20px;
  position: relative;
  z-index: 2;
}

[data-mc-section] .mc-indicator {
  background: none;
  border: none;
  cursor: pointer;
  padding: 5px;
}

[data-mc-section] .mc-indicator-dot {
  display: block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--mc-border);
  transition: all 0.3s var(--mc-ease);
}

[data-mc-section] .mc-indicator.is-active .mc-indicator-dot {
  width: 24px;
  border-radius: 12px;
  background: var(--mc-accent);
}

/* ── INFO PANEL (BLACK BEADS section) ──────────── */
[data-mc-section] .mc-info-panel {
  position: relative;
  min-height: 200px;
  margin-top: 40px;
  text-align: center;
}

[data-mc-section] .mc-info {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  opacity: 0;
  visibility: hidden;
  transform: translateY(20px);
  transition: all 0.4s var(--mc-ease);
  pointer-events: none;
}

[data-mc-section] .mc-info.is-active {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
  pointer-events: auto;
}

[data-mc-section] .mc-info__title {
  font-size: 24px;
  font-weight: 400;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--mc-text-dark);
  margin-bottom: 16px;
}

[data-mc-section] .mc-info__desc {
  font-size: 16px;
  line-height: 1.8;
  color: var(--mc-text-light);
  max-width: 600px;
  margin: 0 auto 24px;
}

[data-mc-section] .mc-info__btn {
  display: inline-block;
  padding: 14px 42px;
  background: transparent;
  color: var(--mc-text-dark);
  border: 1px solid var(--mc-accent);
  font-size: 12px;
  letter-spacing: 3px;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.3s ease;
}

[data-mc-section] .mc-info__btn:hover {
  background: var(--mc-accent);
  color: white;
}

/* ── RESPONSIVE ───────────────────────────────── */
@media screen and (max-width: 1024px) {
  [data-mc-section] .mc-slide {
    flex: 0 0 calc(25% - 15px); /* 4 slides visible */
  }
}

@media screen and (max-width: 768px) {
  [data-mc-section] {
    padding: 40px 0;
  }

  [data-mc-section] .mc-inner {
    padding: 0 20px;
  }

  [data-mc-section] .mc-header__title {
    font-size: 24px;
    letter-spacing: 4px;
  }

  [data-mc-section] .mc-header__desc {
    font-size: 14px;
  }

  [data-mc-section] .mc-slide {
    flex: 0 0 calc(33.33% - 14px); /* 3 slides visible on tablet */
    min-width: 140px;
  }

  [data-mc-section] .mc-arrow {
    width: 36px;
    height: 36px;
  }
}

@media screen and (max-width: 480px) {
  [data-mc-section] .mc-slide {
    flex: 0 0 calc(50% - 10px); /* 2 slides visible on mobile */
  }

  [data-mc-section] .mc-info__title {
    font-size: 20px;
    letter-spacing: 3px;
  }

  [data-mc-section] .mc-info__desc {
    font-size: 14px;
  }

  [data-mc-section] .mc-info__btn {
    padding: 12px 32px;
    font-size: 11px;
  }
}
</style>

<script>
(function() {
  const section = document.querySelector('[data-mc-section]');
  if (!section) return;

  const track = section.querySelector('[data-mc-track]');
  const slides = Array.from(section.querySelectorAll('[data-mc-slide]'));
  const indicators = Array.from(section.querySelectorAll('[data-mc-indicator]'));
  const infoItems = Array.from(section.querySelectorAll('[data-mc-info]'));
  const prevBtn = section.querySelector('[data-mc-prev]');
  const nextBtn = section.querySelector('[data-mc-next]');

  const totalSlides = {{ s_total }};
  let currentIndex = 0;
  let isAnimating = false;

  // Calculate how many slides to show based on screen width
  function getSlidesPerView() {
    if (window.innerWidth <= 480) return 2;
    if (window.innerWidth <= 768) return 3;
    if (window.innerWidth <= 1024) return 4;
    return 5;
  }

  // Update track position
  function updateCarousel(index, animate = true) {
    if (isAnimating) return;
    isAnimating = true;

    const slidesPerView = getSlidesPerView();
    const slideWidth = slides[0]?.offsetWidth || 200;
    const gap = 20; // matches gap in CSS
    const moveAmount = (slideWidth + gap) * index;
    
    track.style.transition = animate ? `transform var(--mc-dur) var(--mc-ease)` : 'none';
    track.style.transform = `translateX(-${moveAmount}px)`;

    // Update active states
    slides.forEach(slide => {
      const slideIndex = parseInt(slide.dataset.mcSlide);
      if (slideIndex === index) {
        slide.classList.add('is-active');
      } else {
        slide.classList.remove('is-active');
      }
    });

    // Update indicators
    indicators.forEach((indicator, i) => {
      if (i === index) {
        indicator.classList.add('is-active');
      } else {
        indicator.classList.remove('is-active');
      }
    });

    // Update info panels
    infoItems.forEach((item, i) => {
      if (i === index) {
        item.classList.add('is-active');
      } else {
        item.classList.remove('is-active');
      }
    });

    setTimeout(() => {
      isAnimating = false;
    }, 500);
  }

  // Navigation
  function nextSlide() {
    const next = (currentIndex + 1) % totalSlides;
    currentIndex = next;
    updateCarousel(currentIndex);
  }

  function prevSlide() {
    const prev = (currentIndex - 1 + totalSlides) % totalSlides;
    currentIndex = prev;
    updateCarousel(currentIndex);
  }

  // Event listeners
  prevBtn?.addEventListener('click', prevSlide);
  nextBtn?.addEventListener('click', nextSlide);

  indicators.forEach((indicator, index) => {
    indicator.addEventListener('click', () => {
      currentIndex = index;
      updateCarousel(currentIndex);
    });
  });

  // Touch events
  let touchStartX = 0;
  track.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });

  track.addEventListener('touchend', (e) => {
    const touchEndX = e.changedTouches[0].clientX;
    const diff = touchStartX - touchEndX;
    
    if (Math.abs(diff) > 50) {
      if (diff > 0) {
        nextSlide();
      } else {
        prevSlide();
      }
    }
  }, { passive: true });

  // Keyboard navigation
  section.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') {
      e.preventDefault();
      prevSlide();
    } else if (e.key === 'ArrowRight') {
      e.preventDefault();
      nextSlide();
    }
  });

  // Resize handler
  let resizeTimeout;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      updateCarousel(currentIndex, false);
    }, 150);
  });

  // Initialize
  updateCarousel(0, false);
})();
</script>

{% schema %}
{
  "name": "Materials Cylinder",
  "tag": "section",
  "class": "section-materials-cylinder",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Main Title",
      "default": "MATERIALS"
    },
    {
      "type": "textarea",
      "id": "header_description",
      "label": "Header Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Material Name",
          "default": "BLACK BEADS"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Material Image",
          "info": "Recommended: Square image with transparent background"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "VIEW COLLECTION"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Materials Cylinder",
      "blocks": [
        { "type": "material" },
        { "type": "material" },
        { "type": "material" },
        { "type": "material" },
        { "type": "material" }
      ]
    }
  ]
}
{% endschema %}