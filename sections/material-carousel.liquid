{%- liquid
  assign s_id    = 'ms-' | append: section.id
  assign s_total = section.blocks.size
-%}

{{- 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css' | stylesheet_tag -}}

<section
  class="ms-root"
  id="{{ s_id }}"
  data-ms-section
  data-ms-id="{{ s_id }}"
  data-ms-total="{{ s_total }}"
  tabindex="-1"
>
  <div class="ms-inner">

    {%- comment -%}── HEADER ──{%- endcomment -%}
    <div class="ms-head">
      {%- if section.settings.title != blank -%}
        <h2 class="ms-head__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ms-head__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%}── SWIPER STAGE ──{%- endcomment -%}
    <div class="ms-stage-wrap">
      <div class="swiper ms-swiper" id="{{ s_id }}-swiper">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            <div
              class="swiper-slide"
              data-ms-swiper-slide="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.desktop_image != blank -%}
                {{- block.settings.desktop_image
                    | image_url: width: 800
                    | image_tag:
                        loading: 'lazy',
                        alt: block.settings.name,
                        widths: '400,600,800' -}}
              {%- elsif block.settings.mobile_image != blank -%}
                {{- block.settings.mobile_image
                    | image_url: width: 800
                    | image_tag:
                        loading: 'lazy',
                        alt: block.settings.name -}}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>

    {%- comment -%}── CONTROLS ──{%- endcomment -%}
    <div class="ms-controls">
      <button class="ms-arrow ms-arrow--prev" type="button" data-ms-prev aria-label="Previous material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M6 1.5 1 6.5l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="ms-dot-display" data-ms-dot-display aria-hidden="true">
        {%- for block in section.blocks -%}
          <div class="ms-dot-icon{% if forloop.first %} is-visible{% endif %}" data-ms-dot-icon="{{ forloop.index0 }}">
            {%- if block.settings.icon != blank -%}
              {{- block.settings.icon | image_url: width: 80 | image_tag: class: 'ms-dot-icon__img', loading: 'lazy', alt: block.settings.name -}}
            {%- else -%}
              <span class="ms-dot-icon__swatch" style="background:{{ block.settings.icon_color | default: '#1a1a1a' }};"></span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      <button class="ms-arrow ms-arrow--next" type="button" data-ms-next aria-label="Next material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M1 1.5l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    {%- comment -%}── INFO PANEL ──{%- endcomment -%}
    <div class="ms-info-wrap" data-ms-info-wrap>
      {%- for block in section.blocks -%}
        <div
          class="ms-info-item{% if forloop.first %} is-active{% endif %}"
          data-ms-info="{{ forloop.index0 }}"
          role="region"
          aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
        >
          <h3 class="ms-info-item__name">{{ block.settings.name | upcase | escape }}</h3>
          {%- if block.settings.description != blank -%}
            <p class="ms-info-item__desc">{{ block.settings.description }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_url | default: '#' }}" class="ms-info-item__btn">
              {{ block.settings.button_label | upcase | escape }}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
/* ============================================================
   MATERIALS CAROUSEL  ·  prefix: ms-
   Stage replaced with Swiper.js — all other styles unchanged
   ============================================================ */
[data-ms-section] {
  --ms-bg:        #f0eeea;
  --ms-panel-bg:  #ffffff;
  --ms-border:    #e2e0db;
  --ms-shad-c:    0 4px 32px rgba(0,0,0,0.10);
  --ms-shad-s:    0 2px 12px rgba(0,0,0,0.05);
  --ms-title-clr: #1a1a1a;
  --ms-text-clr:  #6b6b6b;
  --ms-btn-bg:    {{ section.settings.button_color | default: '#8c6464' }};
  --ms-btn-hov:   {{ section.settings.button_hover_color | default: '#7a5555' }};
  --ms-dot-sz:    56px;
  --ms-arrow-sz:  36px;
  --ms-ease:      cubic-bezier(0.4,0,0.2,1);
  --ms-dur:       500ms;
  --ms-slide-h:   380px;   /* height of each swiper slide */

  background: var(--ms-bg);
  padding: 60px 0 56px;
  overflow: hidden;
  font-family: inherit;
  isolation: isolate;
}

[data-ms-section] *,
[data-ms-section] *::before,
[data-ms-section] *::after { box-sizing: border-box; margin: 0; padding: 0; }

[data-ms-section] a      { text-decoration: none; }
[data-ms-section] img    { display: block; }
[data-ms-section] button { appearance: none; -webkit-appearance: none; border: none; background: none; cursor: pointer; font-family: inherit; }

/* ── Layout ─────────────────────────────────── */
[data-ms-section] .ms-inner {
  margin: 0 auto;
  padding: 0 24px;
  text-align: center;
}

/* ── Header ─────────────────────────────────── */
[data-ms-section] .ms-head { margin-bottom: 44px; }
[data-ms-section] .ms-head__title {
  font-size: clamp(18px, 2vw, 26px);
  font-weight: 400;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
  margin-bottom: 18px;
}
[data-ms-section] .ms-head__subtitle {
  font-size: 15px;
  color: var(--ms-text-clr);
  line-height: 1.8;
  max-width: 560px;
  margin: 0 auto;
}

/* ── Stage Wrap ──────────────────────────────── */
[data-ms-section] .ms-stage-wrap {
  position: relative;
  /* allow swiper slides to bleed out past section edges */
  overflow: visible;
}

/* ── Swiper container ────────────────────────── */
[data-ms-section] .ms-swiper {
  position: relative;
  width: 800px;
  margin-inline: auto;
  overflow: visible; /* side slides visible outside the 800px box */
}

/*
 * Oval top & bottom masks — same technique as the reference code.
 * Uses --ms-bg so they blend seamlessly with the section background,
 * creating the "barrel / cylindrical peephole" crop effect.
 */
/* REPLACE these two blocks in your existing file */

[data-ms-section] .ms-swiper::before {
  content: '';
  position: absolute;
  top: -70px;
  left: 50%;
  transform: translateX(-50%);
  width: 100vw;          /* full viewport width */
  height: 100px;
  background: var(--ms-bg);
  border-radius: 100%;
  z-index: 10;
  pointer-events: none;
}

[data-ms-section] .ms-swiper::after {
  content: '';
  position: absolute;
  bottom: -60px;
  left: 50%;
  transform: translateX(-50%);
  width: 100vw;          /* full viewport width */
  height: 100px;
  background: var(--ms-bg);
  border-radius: 100%;
  z-index: 10;
  pointer-events: none;
}
/* ── Swiper slide ────────────────────────────── */
[data-ms-section] .ms-swiper .swiper-slide {
  height: var(--ms-slide-h);
  background: var(--ms-panel-bg);
  border: 1px solid var(--ms-border);
  border-radius: 6px;
  overflow: hidden;
  box-shadow: var(--ms-shad-s);
  transition: box-shadow var(--ms-dur) var(--ms-ease);
}

[data-ms-section] .ms-swiper .swiper-slide-active {
  box-shadow: var(--ms-shad-c);
}

[data-ms-section] .ms-swiper .swiper-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ── Controls ────────────────────────────────── */
[data-ms-section] .ms-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin: 28px 0 4px;
  position: relative;
  z-index: 4;
}
[data-ms-section] .ms-arrow {
  flex-shrink: 0;
  width: var(--ms-arrow-sz);
  height: var(--ms-arrow-sz);
  border: 1.5px solid #c8c8c8 !important;
  border-radius: 50%;
  background: transparent !important;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #444;
  transition: border-color 0.2s, background 0.2s, transform 0.15s;
}
[data-ms-section] .ms-arrow:hover {
  border-color: #888 !important;
  background: rgba(0,0,0,0.04) !important;
}
[data-ms-section] .ms-arrow:active { transform: scale(0.90); }

/* ── Dot display ─────────────────────────────── */
[data-ms-section] .ms-dot-display {
  position: relative;
  width: var(--ms-dot-sz);
  height: var(--ms-dot-sz);
  flex-shrink: 0;
  border-radius: 50%;
  box-shadow: 0 0 0 2.5px #1a1a1a;
}
[data-ms-section] .ms-dot-icon {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  overflow: hidden;
  opacity: 0;
  transform: scale(0.65) rotate(-20deg);
  pointer-events: none;
  transition:
    opacity 0.32s var(--ms-ease),
    transform 0.32s var(--ms-ease);
}
[data-ms-section] .ms-dot-icon.is-visible {
  opacity: 1;
  transform: scale(1) rotate(0deg);
}
[data-ms-section] .ms-dot-icon__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}
[data-ms-section] .ms-dot-icon__swatch {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* ── Info block ──────────────────────────────── */
[data-ms-section] .ms-info-wrap {
  position: relative;
  min-height: 152px;
  margin-top: 24px;
}
[data-ms-section] .ms-info-item {
  position: absolute;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateY(10px);
  transition:
    opacity 0.35s var(--ms-ease),
    transform 0.35s var(--ms-ease),
    visibility 0s linear 0.35s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}
[data-ms-section] .ms-info-item.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateY(0);
  transition:
    opacity 0.35s var(--ms-ease) 0.12s,
    transform 0.35s var(--ms-ease) 0.12s,
    visibility 0s linear 0s;
}
[data-ms-section] .ms-info-item__name {
  font-size: clamp(15px, 1.6vw, 20px);
  font-weight: 400;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
}
[data-ms-section] .ms-info-item__desc {
  font-size: 14px;
  color: var(--ms-text-clr);
  line-height: 1.8;
  max-width: 480px;
}
[data-ms-section] .ms-info-item__btn {
  display: inline-block;
  padding: 13px 38px;
  background: var(--ms-btn-bg);
  color: #fff;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  transition: background 0.22s var(--ms-ease), transform 0.15s;
  margin-top: 4px;
}
[data-ms-section] .ms-info-item__btn:hover {
  background: var(--ms-btn-hov);
  color: #fff;
}
[data-ms-section] .ms-info-item__btn:active { transform: scale(0.97); }

/* ── Responsive ──────────────────────────────── */
@media screen and (max-width: 767px) {
  [data-ms-section] {
    padding: 40px 0 44px;
    --ms-slide-h: 300px;
  }
  [data-ms-section] .ms-inner    { padding: 0 16px; }
  [data-ms-section] .ms-head     { margin-bottom: 28px; }
  [data-ms-section] .ms-head__title { font-size: 17px; letter-spacing: 4px; }

  [data-ms-section] .ms-swiper {
    width: 100%;
    max-width: 400px;
  }
  /* Tighten the oval masks on mobile */
  [data-ms-section] .ms-swiper::before {
    top: -50px;
    height: 80px;
  }
  [data-ms-section] .ms-swiper::after {
    bottom: -45px;
    height: 80px;
  }

  [data-ms-section] .ms-info-wrap    { min-height: 164px; }
  [data-ms-section] .ms-info-item__desc { max-width: 300px; }
}

/* Hide controls when only one block */
[data-ms-section][data-ms-total="1"] .ms-controls { display: none; }
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script>
(function () {
  'use strict';

  /* Wait for Swiper library to be ready */
  function init() {
    var ROOT = document.getElementById('{{ s_id }}');
    if (!ROOT) return;

    var total      = parseInt(ROOT.getAttribute('data-ms-total'), 10) || 0;
    var DOT_ICONS  = Array.from(ROOT.querySelectorAll('[data-ms-dot-icon]'));
    var INFO_ITEMS = Array.from(ROOT.querySelectorAll('[data-ms-info]'));
    var PREV_BTN   = ROOT.querySelector('[data-ms-prev]');
    var NEXT_BTN   = ROOT.querySelector('[data-ms-next]');

    if (total <= 1) return;

    /* ── Swiper init ───────────────────────── */
    var swiper = new Swiper('#{{ s_id }}-swiper', {
      loop:            true,
      slidesPerView:   2,
      spaceBetween:    20,
      centeredSlides:  true,
      speed:           500,
      grabCursor:      true,

      /* Touch swipe already built into Swiper */
      touchRatio:      1,
      touchAngle:      45,

      /* Breakpoints */
      breakpoints: {
        0: {
          slidesPerView: 1,
          spaceBetween:  16
        },
        768: {
          slidesPerView: 2,
          spaceBetween:  20
        }
      },

      /* Slide-change callback: sync dots + info panel */
      on: {
        slideChange: function () {
          var idx = this.realIndex; /* always 0-based, loop-safe */

          /* Dot icons */
          DOT_ICONS.forEach(function (dot, i) {
            dot.classList.toggle('is-visible', i === idx);
          });

          /* Info items */
          INFO_ITEMS.forEach(function (item, i) {
            var active = (i === idx);
            item.classList.toggle('is-active', active);
            item.setAttribute('aria-hidden', active ? 'false' : 'true');
          });
        }
      }
    });

    /* Wire existing arrow buttons to Swiper API */
    PREV_BTN && PREV_BTN.addEventListener('click', function () { swiper.slidePrev(); });
    NEXT_BTN && NEXT_BTN.addEventListener('click', function () { swiper.slideNext(); });

    /* Keyboard support */
    ROOT.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft')  swiper.slidePrev();
      if (e.key === 'ArrowRight') swiper.slideNext();
    });
  }

  /* Swiper is loaded via defer — run after DOM + scripts are ready */
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    /* Tiny poll in case the deferred script hasn't executed yet */
    var attempts = 0;
    var poll = setInterval(function () {
      if (typeof Swiper !== 'undefined') {
        clearInterval(poll);
        init();
      }
      if (++attempts > 40) clearInterval(poll); /* give up after ~2s */
    }, 50);
  } else {
    document.addEventListener('DOMContentLoaded', function () {
      var attempts = 0;
      var poll = setInterval(function () {
        if (typeof Swiper !== 'undefined') {
          clearInterval(poll);
          init();
        }
        if (++attempts > 40) clearInterval(poll);
      }, 50);
    });
  }

})();
</script>

