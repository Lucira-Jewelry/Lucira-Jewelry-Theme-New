{%- liquid
  assign s_id    = 'ms-' | append: section.id
  assign s_total = section.blocks.size
-%}

<section
  class="ms-root"
  id="{{ s_id }}"
  data-ms-section
  data-ms-id="{{ s_id }}"
  data-ms-total="{{ s_total }}"
  tabindex="-1"
>
  <div class="ms-inner">

    {%- comment -%}── HEADER ──{%- endcomment -%}
    <div class="ms-head">
      {%- if section.settings.title != blank -%}
        <h2 class="ms-head__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ms-head__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%}
      ── CAROUSEL STAGE ──
      All slides stacked via position:absolute inside a fixed-height
      container — zero layout shift on every transition.
    {%- endcomment -%}
    <div class="ms-stage-wrap">
      <div class="ms-stage" data-ms-stage>

        {%- for block in section.blocks -%}
          {%- liquid
            assign bi = forloop.index0

            assign pi = bi | minus: 1
            if pi < 0
              assign pi = s_total | minus: 1
            endif

            assign ni = bi | plus: 1
            if ni >= s_total
              assign ni = 0
            endif

            assign fli = pi | minus: 1
            if fli < 0
              assign fli = s_total | minus: 1
            endif
            if fli == bi
              assign fli = pi
            endif

            assign fri = ni | plus: 1
            if fri >= s_total
              assign fri = 0
            endif
            if fri == bi
              assign fri = ni
            endif

            assign pb  = section.blocks[pi]
            assign nb  = section.blocks[ni]
            assign flb = section.blocks[fli]
            assign frb = section.blocks[fri]
          -%}

          <div
            class="ms-slide{% if forloop.first %} is-active{% endif %}"
            data-ms-slide="{{ bi }}"
            aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
            {{ block.shopify_attributes }}
          >
            {%- comment -%}── DESKTOP 5-panel ──{%- endcomment -%}
            <div class="ms-panels">

              {%- comment -%}Far-left panel (prev-prev){%- endcomment -%}
              <div class="ms-panel ms-panel--fl">
                {%- if flb.settings.desktop_image != blank -%}
                  {{- flb.settings.desktop_image
                      | image_url: width: 360
                      | image_tag:
                          class: 'ms-panel__img',
                          loading: 'lazy',
                          alt: flb.settings.name,
                          widths: '180,270,360' -}}
                {%- endif -%}
              </div>

              {%- comment -%}Left panel (prev){%- endcomment -%}
              <div class="ms-panel ms-panel--l">
                {%- if pb.settings.desktop_image != blank -%}
                  {{- pb.settings.desktop_image
                      | image_url: width: 480
                      | image_tag:
                          class: 'ms-panel__img',
                          loading: 'lazy',
                          alt: pb.settings.name,
                          widths: '240,360,480' -}}
                {%- endif -%}
              </div>

              {%- comment -%}Centre panel (active){%- endcomment -%}
              <div class="ms-panel ms-panel--c">
                {%- if block.settings.desktop_image != blank -%}
                  {{- block.settings.desktop_image
                      | image_url: width: 700
                      | image_tag:
                          class: 'ms-panel__img',
                          loading: 'lazy',
                          alt: block.settings.name,
                          widths: '400,560,700' -}}
                {%- elsif block.settings.mobile_image != blank -%}
                  {{- block.settings.mobile_image
                      | image_url: width: 700
                      | image_tag:
                          class: 'ms-panel__img',
                          loading: 'lazy',
                          alt: block.settings.name -}}
                {%- endif -%}
              </div>

              {%- comment -%}Right panel (next){%- endcomment -%}
              <div class="ms-panel ms-panel--r">
                {%- if nb.settings.desktop_image != blank -%}
                  {{- nb.settings.desktop_image
                      | image_url: width: 480
                      | image_tag:
                          class: 'ms-panel__img',
                          loading: 'lazy',
                          alt: nb.settings.name,
                          widths: '240,360,480' -}}
                {%- endif -%}
              </div>

              {%- comment -%}Far-right panel (next-next){%- endcomment -%}
              <div class="ms-panel ms-panel--fr">
                {%- if frb.settings.desktop_image != blank -%}
                  {{- frb.settings.desktop_image
                      | image_url: width: 360
                      | image_tag:
                          class: 'ms-panel__img',
                          loading: 'lazy',
                          alt: frb.settings.name,
                          widths: '180,270,360' -}}
                {%- endif -%}
              </div>

            </div>

            {%- comment -%}── MOBILE single panel ──{%- endcomment -%}
            <div class="ms-mobile-panel">
              {%- if block.settings.mobile_image != blank -%}
                {{- block.settings.mobile_image
                    | image_url: width: 600
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: block.settings.name,
                        widths: '300,450,600' -}}
              {%- elsif block.settings.desktop_image != blank -%}
                {{- block.settings.desktop_image
                    | image_url: width: 600
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: block.settings.name,
                        widths: '300,450,600' -}}
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}

      </div>
    </div>

    {%- comment -%}── CONTROLS: arrow · single active dot · arrow ──{%- endcomment -%}
    <div class="ms-controls">

      <button class="ms-arrow ms-arrow--prev" type="button" data-ms-prev aria-label="Previous material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M6 1.5 1 6.5l5 5" stroke="currentColor" stroke-width="1.6"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="ms-dot-display" data-ms-dot-display aria-hidden="true">
        {%- for block in section.blocks -%}
          <div
            class="ms-dot-icon{% if forloop.first %} is-visible{% endif %}"
            data-ms-dot-icon="{{ forloop.index0 }}"
          >
            {%- if block.settings.icon != blank -%}
              {{- block.settings.icon
                  | image_url: width: 80
                  | image_tag:
                      class: 'ms-dot-icon__img',
                      loading: 'lazy',
                      alt: block.settings.name -}}
            {%- else -%}
              <span
                class="ms-dot-icon__swatch"
                style="background:{{ block.settings.icon_color | default: '#1a1a1a' }};"
              ></span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <button class="ms-arrow ms-arrow--next" type="button" data-ms-next aria-label="Next material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M1 1.5l5 5-5 5" stroke="currentColor" stroke-width="1.6"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

    </div>

    {%- comment -%}── INFO PANEL ──{%- endcomment -%}
    <div class="ms-info-wrap" data-ms-info-wrap>
      {%- for block in section.blocks -%}
        <div
          class="ms-info-item{% if forloop.first %} is-active{% endif %}"
          data-ms-info="{{ forloop.index0 }}"
          role="region"
          aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
        >
          <h3 class="ms-info-item__name">{{ block.settings.name | upcase | escape }}</h3>
          {%- if block.settings.description != blank -%}
            <p class="ms-info-item__desc">{{ block.settings.description }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a
              href="{{ block.settings.button_url | default: '#' }}"
              class="ms-info-item__btn"
            >{{ block.settings.button_label | upcase | escape }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
/* ============================================================
   MATERIALS CAROUSEL  ·  prefix: ms-
   Double-scoped: [data-ms-section] .ms-*  — zero bleed
   5-panel layout with smooth transitions
   ============================================================ */
[data-ms-section] {
  --ms-bg:        #f0eeea;
  --ms-arch-bg:   #e8e6e1;
  --ms-panel-bg:  #ffffff;
  --ms-border:    #e2e0db;
  --ms-shad-c:    0 4px 32px rgba(0,0,0,0.10);
  --ms-shad-s:    0 2px 12px rgba(0,0,0,0.05);
  --ms-title-clr: #1a1a1a;
  --ms-text-clr:  #6b6b6b;
  --ms-btn-bg:    {{ section.settings.button_color | default: '#8c6464' }};
  --ms-btn-hov:   {{ section.settings.button_hover_color | default: '#7a5555' }};
  --ms-dot-sz:    56px;
  --ms-arrow-sz:  36px;
  --ms-ease:      cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --ms-dur:       500ms;
  --ms-stage-h:   380px;

  background: var(--ms-bg);
  padding: 60px 0 56px;
  overflow: hidden;
  font-family: inherit;
  isolation: isolate;
}

[data-ms-section] *,
[data-ms-section] *::before,
[data-ms-section] *::after { box-sizing: border-box; margin: 0; padding: 0; }

[data-ms-section] a          { text-decoration: none; }
[data-ms-section] img        { display: block; }
[data-ms-section] button     { appearance: none; -webkit-appearance: none; border: none; background: none; cursor: pointer; font-family: inherit; }

/* ── Layout ─────────────────────────────────── */
[data-ms-section] .ms-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 0px;
  text-align: center;
}

/* ── Header ─────────────────────────────────── */
[data-ms-section] .ms-head { margin-bottom: 44px; }

[data-ms-section] .ms-head__title {
  font-size: clamp(18px, 2vw, 26px);
  font-weight: 400;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
  margin-bottom: 18px;
}

[data-ms-section] .ms-head__subtitle {
  font-size: 15px;
  color: var(--ms-text-clr);
  line-height: 1.8;
  max-width: 560px;
  margin: 0 auto;
}

/* ── Stage wrap + arch ───────────────────────── */
[data-ms-section] .ms-stage-wrap {
  position: relative;
  /* clip the far panels so they partially bleed off-edge */
  overflow: hidden;
}

[data-ms-section] .ms-stage-wrap::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  height: 88%;
  background: var(--ms-arch-bg);
  border-radius: 50% 50% 0 0 / 18% 18% 0 0;
  z-index: 0;
  pointer-events: none;
}

/* Fixed-height stage prevents layout shift */
[data-ms-section] .ms-stage {
  position: relative;
  height: var(--ms-stage-h);
  z-index: 1;
}

/* ── Slides: ALL stacked, no display:none ────── */
[data-ms-section] .ms-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateX(48px);
  transition:
    opacity var(--ms-dur) var(--ms-ease),
    transform var(--ms-dur) var(--ms-ease),
    visibility 0s linear var(--ms-dur);
  will-change: opacity, transform;
}

[data-ms-section] .ms-slide.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateX(0);
  z-index: 2;
  transition:
    opacity var(--ms-dur) var(--ms-ease),
    transform var(--ms-dur) var(--ms-ease),
    visibility 0s linear 0s;
}

/* Direction-aware outgoing animations */
[data-ms-section] .ms-slide.is-out-left {
  opacity: 0;
  visibility: visible;
  transform: translateX(-48px);
  transition:
    opacity var(--ms-dur) var(--ms-ease),
    transform var(--ms-dur) var(--ms-ease),
    visibility 0s linear var(--ms-dur);
  z-index: 1;
}

[data-ms-section] .ms-slide.is-out-right {
  opacity: 0;
  visibility: visible;
  transform: translateX(48px);
  transition:
    opacity var(--ms-dur) var(--ms-ease),
    transform var(--ms-dur) var(--ms-ease),
    visibility 0s linear var(--ms-dur);
  z-index: 1;
}

/* ── 5-panel desktop ─────────────────────────── */
[data-ms-section] .ms-panels {
  display: flex;
  align-items: stretch;
  height: 100%;
  gap: 8px;
}

[data-ms-section] .ms-panel {
  background: var(--ms-panel-bg);
  border: 1px solid var(--ms-border);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  height: 100%;
  flex-shrink: 0;
}

/* Far-left: partially clipped, very receded */
[data-ms-section] .ms-panel--fl {
  flex: 0 0 7%;
  border-radius: 10px 0 0 10px;
  transform: perspective(900px) rotateY(48deg) scaleY(0.90) scaleX(0.85);
  transform-origin: right center;
  opacity: 0.42;
  box-shadow: var(--ms-shad-s);
  /* clip to show only partial image */
  clip-path: inset(0 0 0 20%);
}

/* Left panel (prev) */
[data-ms-section] .ms-panel--l {
  flex: 0 0 16%;
  border-right: none;
  border-radius: 10px 0 0 10px;
  transform: perspective(1000px) rotateY(30deg) scaleY(0.96);
  transform-origin: right center;
  box-shadow: var(--ms-shad-s);
  opacity: 0.82;
}

/* Centre panel */
[data-ms-section] .ms-panel--c {
  flex: 1 1 auto;
  z-index: 3;
  border-radius: 4px;
  box-shadow: var(--ms-shad-c);
}

/* Right panel (next) */
[data-ms-section] .ms-panel--r {
  flex: 0 0 16%;
  border-left: none;
  border-radius: 0 10px 10px 0;
  transform: perspective(1000px) rotateY(-30deg) scaleY(0.96);
  transform-origin: left center;
  box-shadow: var(--ms-shad-s);
  opacity: 0.82;
}

/* Far-right: partially clipped, very receded */
[data-ms-section] .ms-panel--fr {
  flex: 0 0 7%;
  border-radius: 0 10px 10px 0;
  transform: perspective(900px) rotateY(-48deg) scaleY(0.90) scaleX(0.85);
  transform-origin: left center;
  opacity: 0.42;
  box-shadow: var(--ms-shad-s);
  /* clip to show only partial image */
  clip-path: inset(0 20% 0 0);
}

/* Images fill panels while preserving aspect ratio */
[data-ms-section] .ms-panel__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 24px 18px;
}

/* Far panels get tighter padding since they're narrow */
[data-ms-section] .ms-panel--fl .ms-panel__img,
[data-ms-section] .ms-panel--fr .ms-panel__img {
  padding: 20px 8px;
  object-fit: cover;
}

/* ── Mobile single panel ─────────────────────── */
[data-ms-section] .ms-mobile-panel {
  display: none;
  height: 100%;
  align-items: center;
  justify-content: center;
  background: var(--ms-panel-bg);
  border: 1px solid var(--ms-border);
  border-radius: 6px;
  box-shadow: var(--ms-shad-c);
  overflow: hidden;
}

/* ── Controls ────────────────────────────────── */
[data-ms-section] .ms-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin: 28px 0 4px;
  position: relative;
  z-index: 4;
}

[data-ms-section] .ms-arrow {
  flex-shrink: 0;
  width: var(--ms-arrow-sz);
  height: var(--ms-arrow-sz);
  border: 1.5px solid #c8c8c8 !important;
  border-radius: 50%;
  background: transparent !important;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #444;
  transition: border-color 0.2s, background 0.2s, transform 0.15s;
}
[data-ms-section] .ms-arrow:hover {
  border-color: #888 !important;
  background: rgba(0,0,0,0.04) !important;
}
[data-ms-section] .ms-arrow:active { transform: scale(0.90); }

/* ── Single dot display ──────────────────────── */
[data-ms-section] .ms-dot-display {
  position: relative;
  width: var(--ms-dot-sz);
  height: var(--ms-dot-sz);
  flex-shrink: 0;
  border-radius: 50%;
  box-shadow: 0 0 0 2.5px #1a1a1a;
}

[data-ms-section] .ms-dot-icon {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  overflow: hidden;
  opacity: 0;
  transform: scale(0.65) rotate(-20deg);
  pointer-events: none;
  transition:
    opacity 0.32s var(--ms-ease),
    transform 0.32s var(--ms-ease);
}

[data-ms-section] .ms-dot-icon.is-visible {
  opacity: 1;
  transform: scale(1) rotate(0deg);
}

[data-ms-section] .ms-dot-icon__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}

[data-ms-section] .ms-dot-icon__swatch {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* ── Info block ──────────────────────────────── */
[data-ms-section] .ms-info-wrap {
  position: relative;
  min-height: 152px;
  margin-top: 24px;
}

[data-ms-section] .ms-info-item {
  position: absolute;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateY(10px);
  transition:
    opacity 0.35s var(--ms-ease),
    transform 0.35s var(--ms-ease),
    visibility 0s linear 0.35s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

[data-ms-section] .ms-info-item.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateY(0);
  transition:
    opacity 0.35s var(--ms-ease) 0.15s,
    transform 0.35s var(--ms-ease) 0.15s,
    visibility 0s linear 0s;
}

[data-ms-section] .ms-info-item__name {
  font-size: clamp(15px, 1.6vw, 20px);
  font-weight: 400;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
}

[data-ms-section] .ms-info-item__desc {
  font-size: 14px;
  color: var(--ms-text-clr);
  line-height: 1.8;
  max-width: 480px;
}

[data-ms-section] .ms-info-item__btn {
  display: inline-block;
  padding: 13px 38px;
  background: var(--ms-btn-bg);
  color: #fff;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  transition: background 0.22s var(--ms-ease), transform 0.15s;
  margin-top: 4px;
}
[data-ms-section] .ms-info-item__btn:hover {
  background: var(--ms-btn-hov);
  color: #fff;
}
[data-ms-section] .ms-info-item__btn:active { transform: scale(0.97); }

/* ── Responsive ──────────────────────────────── */
@media screen and (max-width: 767px) {
  [data-ms-section] {
    padding: 40px 0 44px;
    --ms-stage-h: 300px;
  }
  [data-ms-section] .ms-inner    { padding: 0 16px; }
  [data-ms-section] .ms-head     { margin-bottom: 28px; }
  [data-ms-section] .ms-head__title { font-size: 17px; letter-spacing: 4px; }

  [data-ms-section] .ms-panels         { display: none !important; }
  [data-ms-section] .ms-mobile-panel   { display: flex; }

  [data-ms-section] .ms-stage-wrap::before {
    border-radius: 50% 50% 0 0 / 12% 12% 0 0;
    height: 84%;
  }
  [data-ms-section] .ms-info-wrap     { min-height: 164px; }
  [data-ms-section] .ms-info-item__desc { max-width: 300px; }
}

[data-ms-section][data-ms-total="1"] .ms-controls { display: none; }
</style>

<script>
(function () {
  'use strict';

  var ROOT = document.getElementById('{{ s_id }}');
  if (!ROOT) return;

  var STAGE      = ROOT.querySelector('[data-ms-stage]');
  var SLIDES     = Array.from(ROOT.querySelectorAll('[data-ms-slide]'));
  var DOT_ICONS  = Array.from(ROOT.querySelectorAll('[data-ms-dot-icon]'));
  var INFO_ITEMS = Array.from(ROOT.querySelectorAll('[data-ms-info]'));
  var PREV_BTN   = ROOT.querySelector('[data-ms-prev]');
  var NEXT_BTN   = ROOT.querySelector('[data-ms-next]');

  var total    = SLIDES.length;
  var current  = 0;
  var locked   = false;
  var DURATION = 500; // keep in sync with --ms-dur

  if (total <= 1) return;

  /* ── Core go() ──────────────────────────── */
  function go(next, dir) {
    if (locked) return;
    next = ((next % total) + total) % total;
    if (next === current) return;

    locked = true;
    var from = current;
    current  = next;

    var oldSlide = SLIDES[from];
    var newSlide = SLIDES[next];

    /* ── Step 1: Place incoming slide off-screen with no transition ── */
    var startX = dir === 'next' ? '48px' : '-48px';
    newSlide.classList.remove('is-active', 'is-out-left', 'is-out-right');
    newSlide.style.transition = 'none';
    newSlide.style.opacity    = '0';
    newSlide.style.visibility = 'visible';
    newSlide.style.transform  = 'translateX(' + startX + ')';
    newSlide.style.zIndex     = '2';
    newSlide.setAttribute('aria-hidden', 'false');

    /* ── Step 2: Double rAF ensures browser paints the start state ── */
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        /* Clear inline overrides — CSS .is-active / .is-out-* now drive transitions */
        newSlide.style.transition = '';
        newSlide.style.opacity    = '';
        newSlide.style.visibility = '';
        newSlide.style.transform  = '';
        newSlide.style.zIndex     = '';

        /* Trigger outgoing on old slide */
        oldSlide.classList.remove('is-active');
        oldSlide.classList.add(dir === 'next' ? 'is-out-left' : 'is-out-right');
        oldSlide.setAttribute('aria-hidden', 'true');

        /* Trigger incoming on new slide */
        newSlide.classList.add('is-active');

        /* Clean up after animation completes */
        setTimeout(function () {
          oldSlide.classList.remove('is-out-left', 'is-out-right');
          oldSlide.style.cssText = '';
          locked = false;
        }, DURATION + 80);
      });
    });

    /* ── Dot icon ── */
    var oldDot = DOT_ICONS[from];
    var newDot = DOT_ICONS[next];
    if (oldDot) oldDot.classList.remove('is-visible');
    setTimeout(function () {
      if (newDot) newDot.classList.add('is-visible');
    }, 80);

    /* ── Info panel ── */
    var oldInfo = INFO_ITEMS[from];
    var newInfo = INFO_ITEMS[next];
    if (oldInfo) {
      oldInfo.classList.remove('is-active');
      oldInfo.setAttribute('aria-hidden', 'true');
    }
    if (newInfo) {
      newInfo.classList.add('is-active');
      newInfo.setAttribute('aria-hidden', 'false');
    }
  }

  /* ── Buttons ── */
  PREV_BTN && PREV_BTN.addEventListener('click', function () { go(current - 1, 'prev'); });
  NEXT_BTN && NEXT_BTN.addEventListener('click', function () { go(current + 1, 'next'); });

  /* ── Touch swipe ── */
  var tx = 0, ty = 0;
  STAGE.addEventListener('touchstart', function (e) {
    tx = e.changedTouches[0].clientX;
    ty = e.changedTouches[0].clientY;
  }, { passive: true });
  STAGE.addEventListener('touchend', function (e) {
    var dx = e.changedTouches[0].clientX - tx;
    var dy = e.changedTouches[0].clientY - ty;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
      go(dx < 0 ? current + 1 : current - 1, dx < 0 ? 'next' : 'prev');
    }
  }, { passive: true });

  /* ── Keyboard ── */
  ROOT.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  go(current - 1, 'prev');
    if (e.key === 'ArrowRight') go(current + 1, 'next');
  });

  /* ── Auto-height lock ── */
  function lockHeight() {
    if (!STAGE) return;
    var max = 0;
    SLIDES.forEach(function (s) {
      var prev = s.style.cssText;
      s.style.cssText = 'position:relative!important;opacity:0!important;visibility:visible!important;transform:none!important;pointer-events:none!important;transition:none!important;';
      var h = s.offsetHeight;
      s.style.cssText = prev;
      if (h > max) max = h;
    });
    if (max > 10) STAGE.style.height = max + 'px';
  }

  if (document.readyState === 'complete') {
    lockHeight();
  } else {
    window.addEventListener('load', lockHeight);
  }

  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(lockHeight, 120);
  });

})();
</script>

