{%- liquid
  assign s_id    = 'ms-' | append: section.id
  assign s_total = section.blocks.size
-%}

<section
  class="ms-root"
  id="{{ s_id }}"
  data-ms-section
  data-ms-id="{{ s_id }}"
  data-ms-total="{{ s_total }}"
  tabindex="-1"
>

  {%- comment -%}── HEADER ──{%- endcomment -%}
  <div class="ms-inner">
    <div class="ms-head">
      {%- if section.settings.title != blank -%}
        <h2 class="ms-head__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ms-head__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%}
    ── CAROUSEL STAGE (intentionally OUTSIDE ms-inner to be full-width) ──
    overflow:hidden on ms-stage clips the translateX scroll transitions.
  {%- endcomment -%}
  <div class="ms-stage-wrap">
    <div class="ms-arch" aria-hidden="true"></div>

    <div class="ms-stage" data-ms-stage>

      {%- for block in section.blocks -%}
        {%- liquid
          assign bi = forloop.index0
          assign pi = bi | minus: 1
          if pi < 0
            assign pi = s_total | minus: 1
          endif
          assign ni = bi | plus: 1
          if ni >= s_total
            assign ni = 0
          endif
          assign pb = section.blocks[pi]
          assign nb = section.blocks[ni]
        -%}

        <div
          class="ms-slide{% if forloop.first %} is-active{% endif %}"
          data-ms-slide="{{ bi }}"
          aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
          {{ block.shopify_attributes }}
        >

          {%- comment -%}── DESKTOP 3-panel cylindrical ──{%- endcomment -%}
          <div class="ms-panels">

            <div class="ms-panel ms-panel--l">
              {%- if pb.settings.desktop_image != blank -%}
                {{- pb.settings.desktop_image
                    | image_url: width: 480
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: pb.settings.name,
                        widths: '240,360,480' -}}
              {%- endif -%}
            </div>

            <div class="ms-panel ms-panel--c">
              {%- if block.settings.desktop_image != blank -%}
                {{- block.settings.desktop_image
                    | image_url: width: 800
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: block.settings.name,
                        widths: '400,600,800' -}}
              {%- elsif block.settings.mobile_image != blank -%}
                {{- block.settings.mobile_image
                    | image_url: width: 800
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: block.settings.name -}}
              {%- endif -%}
            </div>

            <div class="ms-panel ms-panel--r">
              {%- if nb.settings.desktop_image != blank -%}
                {{- nb.settings.desktop_image
                    | image_url: width: 480
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: nb.settings.name,
                        widths: '240,360,480' -}}
              {%- endif -%}
            </div>

          </div>

          {%- comment -%}── MOBILE single panel ──{%- endcomment -%}
          <div class="ms-mobile-panel">
            {%- if block.settings.mobile_image != blank -%}
              {{- block.settings.mobile_image
                  | image_url: width: 600
                  | image_tag:
                      class: 'ms-panel__img',
                      loading: 'lazy',
                      alt: block.settings.name,
                      widths: '300,450,600' -}}
            {%- elsif block.settings.desktop_image != blank -%}
              {{- block.settings.desktop_image
                  | image_url: width: 600
                  | image_tag:
                      class: 'ms-panel__img',
                      loading: 'lazy',
                      alt: block.settings.name,
                      widths: '300,450,600' -}}
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}

    </div>{%- comment -%}/.ms-stage{%- endcomment -%}
  </div>{%- comment -%}/.ms-stage-wrap{%- endcomment -%}

  {%- comment -%}── CONTROLS + INFO (back inside ms-inner) ──{%- endcomment -%}
  <div class="ms-inner">

    <div class="ms-controls">

      <button class="ms-arrow ms-arrow--prev" type="button" data-ms-prev aria-label="Previous material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M6 1.5 1 6.5l5 5" stroke="currentColor" stroke-width="1.6"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="ms-dot-display" data-ms-dot-display aria-hidden="true">
        {%- for block in section.blocks -%}
          <div
            class="ms-dot-icon{% if forloop.first %} is-visible{% endif %}"
            data-ms-dot-icon="{{ forloop.index0 }}"
          >
            {%- if block.settings.icon != blank -%}
              {{- block.settings.icon
                  | image_url: width: 80
                  | image_tag:
                      class: 'ms-dot-icon__img',
                      loading: 'lazy',
                      alt: block.settings.name -}}
            {%- else -%}
              <span
                class="ms-dot-icon__swatch"
                style="background:{{ block.settings.icon_color | default: '#1a1a1a' }};"
              ></span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <button class="ms-arrow ms-arrow--next" type="button" data-ms-next aria-label="Next material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M1 1.5l5 5-5 5" stroke="currentColor" stroke-width="1.6"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

    </div>

    <div class="ms-info-wrap" data-ms-info-wrap>
      {%- for block in section.blocks -%}
        <div
          class="ms-info-item{% if forloop.first %} is-active{% endif %}"
          data-ms-info="{{ forloop.index0 }}"
          role="region"
          aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
        >
          <h3 class="ms-info-item__name">{{ block.settings.name | upcase | escape }}</h3>
          {%- if block.settings.description != blank -%}
            <p class="ms-info-item__desc">{{ block.settings.description }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a
              href="{{ block.settings.button_url | default: '#' }}"
              class="ms-info-item__btn"
            >{{ block.settings.button_label | upcase | escape }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
/* ============================================================
   MATERIALS CAROUSEL  ·  prefix: ms-
   Cylindrical full-width layout + scroll-based transitions
   ============================================================ */
[data-ms-section] {
  --ms-bg:        #f0eeea;
  --ms-arch-bg:   #e8e6e1;
  --ms-panel-bg:  #ffffff;
  --ms-border:    rgba(0,0,0,0.06);
  --ms-shad-c:    0 8px 48px rgba(0,0,0,0.13);
  --ms-shad-s:    0 2px 20px rgba(0,0,0,0.07);
  --ms-title-clr: #1a1a1a;
  --ms-text-clr:  #6b6b6b;
  --ms-btn-bg:    {{ section.settings.button_color | default: '#8c6464' }};
  --ms-btn-hov:   {{ section.settings.button_hover_color | default: '#7a5555' }};
  --ms-dot-sz:    56px;
  --ms-arrow-sz:  36px;
  --ms-ease:      cubic-bezier(0.45, 0, 0.15, 1);
  --ms-dur:       480ms;
  --ms-stage-h:   400px;

  background: var(--ms-bg);
  padding: 60px 0 56px;
  font-family: inherit;
  isolation: isolate;
  overflow: hidden; /* prevent horizontal scroll from full-width stage */
}

[data-ms-section] *,
[data-ms-section] *::before,
[data-ms-section] *::after { box-sizing: border-box; margin: 0; padding: 0; }

[data-ms-section] a      { text-decoration: none; }
[data-ms-section] img    { display: block; }
[data-ms-section] button { appearance: none; -webkit-appearance: none; border: none; background: none; cursor: pointer; font-family: inherit; }

/* ── Inner wrapper (for header / controls / info) ─── */
[data-ms-section] .ms-inner {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 24px;
  text-align: center;
}

/* ── Header ──────────────────────────────────────── */
[data-ms-section] .ms-head { margin-bottom: 40px; }

[data-ms-section] .ms-head__title {
  font-size: clamp(18px, 2vw, 26px);
  font-weight: 400;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
  margin-bottom: 16px;
}

[data-ms-section] .ms-head__subtitle {
  font-size: 15px;
  color: var(--ms-text-clr);
  line-height: 1.8;
  max-width: 560px;
  margin: 0 auto;
}

/* ═══════════════════════════════════════════════════
   STAGE WRAP — Full viewport width, no max-width.
   The arch pseudo-element gives the cylindrical depth cue.
   ═══════════════════════════════════════════════════ */
[data-ms-section] .ms-stage-wrap {
  position: relative;
  width: 100%;
}

/* Arch background — large elliptical curve behind the panels */
[data-ms-section] .ms-arch {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 110%;
  height: 86%;
  background: var(--ms-arch-bg);
  border-radius: 50% 50% 0 0 / 22% 22% 0 0;
  z-index: 0;
  pointer-events: none;
}

/* ── Stage: fixed height, clips translateX slide scrolling ── */
[data-ms-section] .ms-stage {
  position: relative;
  height: var(--ms-stage-h);
  overflow: hidden; /* CRITICAL — clips the sliding slides */
  z-index: 1;
}

/* ═══════════════════════════════════════════════════
   SLIDE SCROLL ANIMATION
   Uses only translateX — no opacity fade/wipe.
   The container overflow:hidden creates the scroll illusion.
   ═══════════════════════════════════════════════════ */

/* Default: all slides off-screen right, invisible */
[data-ms-section] .ms-slide {
  position: absolute;
  inset: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateX(100%);
  /* visibility collapses after transition so it doesn't interfere */
  transition:
    transform var(--ms-dur) var(--ms-ease),
    visibility 0s linear var(--ms-dur);
  will-change: transform;
}

/* Active slide: centred, visible */
[data-ms-section] .ms-slide.is-active {
  visibility: visible;
  pointer-events: auto;
  transform: translateX(0);
  z-index: 2;
  transition:
    transform var(--ms-dur) var(--ms-ease),
    visibility 0s linear 0s;
}

/* Pre-position helpers — added with JS, trigger NONE (snap) */
[data-ms-section] .ms-slide.will-enter-from-right {
  transform: translateX(100%);
  visibility: visible;
  transition: none !important;
}

[data-ms-section] .ms-slide.will-enter-from-left {
  transform: translateX(-100%);
  visibility: visible;
  transition: none !important;
}

/* Exit left (slide goes off to the left on "next") */
[data-ms-section] .ms-slide.is-out-left {
  transform: translateX(-100%);
  visibility: visible;
  transition: transform var(--ms-dur) var(--ms-ease);
  z-index: 1;
}

/* Exit right (slide goes off to the right on "prev") */
[data-ms-section] .ms-slide.is-out-right {
  transform: translateX(100%);
  visibility: visible;
  transition: transform var(--ms-dur) var(--ms-ease);
  z-index: 1;
}

/* ═══════════════════════════════════════════════════
   3-PANEL CYLINDRICAL DESKTOP LAYOUT
   perspective() per-element gives the "wrapping around
   a cylinder" illusion — side panels tilt away from viewer.
   ═══════════════════════════════════════════════════ */
[data-ms-section] .ms-panels {
  display: flex;
  align-items: center;   /* vertical centre */
  height: 100%;
  padding: 0;            /* panels bleed to stage edges */
}

[data-ms-section] .ms-panel {
  flex: 1;
  background: var(--ms-panel-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 1px solid var(--ms-border);
}

/* ── Left panel: rotates away (right edge is shared edge) ── */
[data-ms-section] .ms-panel--l {
  height: 86%;
  border-radius: 12px 0 0 12px;
  border-right: none;
  transform:
    perspective(900px)
    rotateY(42deg)
    scaleY(0.94);
  transform-origin: right center;
  box-shadow: var(--ms-shad-s);
  z-index: 1;
}

/* ── Centre panel: flat, taller, prominent ── */
[data-ms-section] .ms-panel--c {
  flex: 1.5;             /* wider than side panels */
  height: 100%;
  border-radius: 4px;
  border-left: none;
  border-right: none;
  box-shadow: var(--ms-shad-c);
  z-index: 3;
}

/* ── Right panel: rotates away (left edge is shared edge) ── */
[data-ms-section] .ms-panel--r {
  height: 86%;
  border-radius: 0 12px 12px 0;
  border-left: none;
  transform:
    perspective(900px)
    rotateY(-42deg)
    scaleY(0.94);
  transform-origin: left center;
  box-shadow: var(--ms-shad-s);
  z-index: 1;
}

/* Images fill panels */
[data-ms-section] .ms-panel__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 20px 14px;
}

/* ── Mobile single panel ─────────────────────────── */
[data-ms-section] .ms-mobile-panel {
  display: none;
  height: 100%;
  align-items: center;
  justify-content: center;
  background: var(--ms-panel-bg);
  border: 1px solid var(--ms-border);
  border-radius: 8px;
  box-shadow: var(--ms-shad-c);
  overflow: hidden;
  margin: 0 16px;
}

/* ── Controls ─────────────────────────────────────── */
[data-ms-section] .ms-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18px;
  margin: 28px 0 4px;
  position: relative;
  z-index: 4;
}

[data-ms-section] .ms-arrow {
  flex-shrink: 0;
  width: var(--ms-arrow-sz);
  height: var(--ms-arrow-sz);
  border: 1.5px solid #c8c8c8 !important;
  border-radius: 50%;
  background: transparent !important;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #444;
  transition: border-color 0.2s, background 0.2s, transform 0.15s;
}
[data-ms-section] .ms-arrow:hover {
  border-color: #888 !important;
  background: rgba(0,0,0,0.04) !important;
}
[data-ms-section] .ms-arrow:active { transform: scale(0.90); }

/* ── Single dot display ──────────────────────────── */
[data-ms-section] .ms-dot-display {
  position: relative;
  width: var(--ms-dot-sz);
  height: var(--ms-dot-sz);
  flex-shrink: 0;
  border-radius: 50%;
  box-shadow: 0 0 0 2.5px #1a1a1a;
}

[data-ms-section] .ms-dot-icon {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  overflow: hidden;
  opacity: 0;
  transform: scale(0.65) rotate(-20deg);
  pointer-events: none;
  transition:
    opacity 0.32s var(--ms-ease),
    transform 0.32s var(--ms-ease);
}

[data-ms-section] .ms-dot-icon.is-visible {
  opacity: 1;
  transform: scale(1) rotate(0deg);
}

[data-ms-section] .ms-dot-icon__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}

[data-ms-section] .ms-dot-icon__swatch {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* ── Info block ──────────────────────────────────── */
[data-ms-section] .ms-info-wrap {
  position: relative;
  min-height: 152px;
  margin-top: 24px;
}

[data-ms-section] .ms-info-item {
  position: absolute;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateY(10px);
  transition:
    opacity 0.30s var(--ms-ease),
    transform 0.30s var(--ms-ease),
    visibility 0s linear 0.30s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

[data-ms-section] .ms-info-item.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateY(0);
  transition:
    opacity 0.30s var(--ms-ease) 0.10s,
    transform 0.30s var(--ms-ease) 0.10s,
    visibility 0s linear 0s;
}

[data-ms-section] .ms-info-item__name {
  font-size: clamp(15px, 1.6vw, 20px);
  font-weight: 400;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
}

[data-ms-section] .ms-info-item__desc {
  font-size: 14px;
  color: var(--ms-text-clr);
  line-height: 1.8;
  max-width: 480px;
}

[data-ms-section] .ms-info-item__btn {
  display: inline-block;
  padding: 13px 38px;
  background: var(--ms-btn-bg);
  color: #fff;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  transition: background 0.22s var(--ms-ease), transform 0.15s;
  margin-top: 4px;
}
[data-ms-section] .ms-info-item__btn:hover {
  background: var(--ms-btn-hov);
  color: #fff;
}
[data-ms-section] .ms-info-item__btn:active { transform: scale(0.97); }

/* ── Responsive ──────────────────────────────────── */
@media screen and (max-width: 767px) {
  [data-ms-section] {
    padding: 40px 0 44px;
    --ms-stage-h: 280px;
  }
  [data-ms-section] .ms-inner       { padding: 0 16px; }
  [data-ms-section] .ms-head        { margin-bottom: 28px; }
  [data-ms-section] .ms-head__title { font-size: 17px; letter-spacing: 4px; }

  [data-ms-section] .ms-panels      { display: none !important; }
  [data-ms-section] .ms-mobile-panel { display: flex; }

  [data-ms-section] .ms-arch {
    border-radius: 50% 50% 0 0 / 14% 14% 0 0;
    height: 82%;
  }
  [data-ms-section] .ms-info-wrap      { min-height: 164px; }
  [data-ms-section] .ms-info-item__desc { max-width: 300px; }
}

/* Hide controls when only one slide */
[data-ms-section][data-ms-total="1"] .ms-controls { display: none; }
</style>

<script>
(function () {
  'use strict';

  var ROOT = document.getElementById('{{ s_id }}');
  if (!ROOT) return;

  var STAGE      = ROOT.querySelector('[data-ms-stage]');
  var SLIDES     = Array.from(ROOT.querySelectorAll('[data-ms-slide]'));
  var DOT_ICONS  = Array.from(ROOT.querySelectorAll('[data-ms-dot-icon]'));
  var INFO_ITEMS = Array.from(ROOT.querySelectorAll('[data-ms-info]'));
  var PREV_BTN   = ROOT.querySelector('[data-ms-prev]');
  var NEXT_BTN   = ROOT.querySelector('[data-ms-next]');

  var total    = SLIDES.length;
  var current  = 0;
  var locked   = false;
  var DURATION = 480; // keep in sync with --ms-dur

  if (total <= 1) return;

  /* ──────────────────────────────────────────────────
     go(next, dir)
     Pure translateX scroll — no opacity/fade.
     1. Snap new slide to its starting off-screen position.
     2. Force reflow so the browser registers the snap.
     3. Remove the snap class — CSS transition takes over
        and slides both panels simultaneously.
  ────────────────────────────────────────────────── */
  function go(next, dir) {
    if (locked) return;
    next = ((next % total) + total) % total;
    if (next === current) return;

    locked = true;
    var from = current;
    current  = next;

    var oldSlide = SLIDES[from];
    var newSlide = SLIDES[next];

    // ── Step 1: Snap new slide off-screen (no transition) ──
    var enterClass = dir === 'next' ? 'will-enter-from-right' : 'will-enter-from-left';
    newSlide.classList.add(enterClass);

    // ── Step 2: Force reflow — must happen before any class removal ──
    void newSlide.offsetWidth;

    // ── Step 3: Remove snap class → is-active triggers CSS transition ──
    newSlide.classList.remove(enterClass);
    newSlide.classList.add('is-active');
    newSlide.setAttribute('aria-hidden', 'false');

    // ── Step 4: Exit old slide in opposite direction ──
    var exitClass = dir === 'next' ? 'is-out-left' : 'is-out-right';
    oldSlide.classList.remove('is-active');
    oldSlide.classList.add(exitClass);
    oldSlide.setAttribute('aria-hidden', 'true');

    // ── Step 5: Cleanup after animation completes ──
    setTimeout(function () {
      oldSlide.classList.remove('is-out-left', 'is-out-right');
      locked = false;
    }, DURATION + 80);

    // ── Dot icon: swap immediately (feels snappy) ──
    var oldDot = DOT_ICONS[from];
    var newDot = DOT_ICONS[next];
    if (oldDot) oldDot.classList.remove('is-visible');
    if (newDot) newDot.classList.add('is-visible');

    // ── Info panel: crossfade after a short delay ──
    var oldInfo = INFO_ITEMS[from];
    var newInfo = INFO_ITEMS[next];
    if (oldInfo) {
      oldInfo.classList.remove('is-active');
      oldInfo.setAttribute('aria-hidden', 'true');
    }
    if (newInfo) {
      newInfo.classList.add('is-active');
      newInfo.setAttribute('aria-hidden', 'false');
    }
  }

  /* ── Button clicks ── */
  if (PREV_BTN) PREV_BTN.addEventListener('click', function () { go(current - 1, 'prev'); });
  if (NEXT_BTN) NEXT_BTN.addEventListener('click', function () { go(current + 1, 'next'); });

  /* ── Touch swipe ── */
  var tx = 0, ty = 0;
  STAGE.addEventListener('touchstart', function (e) {
    tx = e.changedTouches[0].clientX;
    ty = e.changedTouches[0].clientY;
  }, { passive: true });

  STAGE.addEventListener('touchend', function (e) {
    var dx = e.changedTouches[0].clientX - tx;
    var dy = e.changedTouches[0].clientY - ty;
    // Only trigger if horizontal swipe is dominant and large enough
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
      go(dx < 0 ? current + 1 : current - 1, dx < 0 ? 'next' : 'prev');
    }
  }, { passive: true });

  /* ── Keyboard ── */
  ROOT.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  go(current - 1, 'prev');
    if (e.key === 'ArrowRight') go(current + 1, 'next');
  });

  /* ── Auto-height: measure tallest slide, pin stage height ──
     Prevents layout shift regardless of image aspect ratios.  */
  function lockHeight() {
    if (!STAGE) return;
    var max = 0;
    SLIDES.forEach(function (s) {
      var saved = s.style.cssText;
      s.style.cssText =
        'position:relative!important;' +
        'opacity:0!important;' +
        'visibility:visible!important;' +
        'transform:none!important;' +
        'pointer-events:none!important;' +
        'transition:none!important;';
      var h = s.offsetHeight;
      s.style.cssText = saved;
      if (h > max) max = h;
    });
    if (max > 10) STAGE.style.height = max + 'px';
  }

  if (document.readyState === 'complete') {
    lockHeight();
  } else {
    window.addEventListener('load', lockHeight);
  }

  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(lockHeight, 120);
  });

})();
</script>

