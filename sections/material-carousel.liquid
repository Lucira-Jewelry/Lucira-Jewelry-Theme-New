  <!-- javascript (exactly the same as original but adapted to this demo ID) -->
  <script>
    (function() {
      'use strict';
      var ROOT = document.getElementById('ms-demo');  // static ID for demo
      if (!ROOT) return;

      var STAGE      = ROOT.querySelector('[data-ms-stage]');
      var SLIDES     = Array.from(ROOT.querySelectorAll('[data-ms-slide]'));
      var DOT_ICONS  = Array.from(ROOT.querySelectorAll('[data-ms-dot-icon]'));
      var INFO_ITEMS = Array.from(ROOT.querySelectorAll('[data-ms-info]'));
      var PREV_BTN   = ROOT.querySelector('[data-ms-prev]');
      var NEXT_BTN   = ROOT.querySelector('[data-ms-next]');

      var total    = SLIDES.length;
      var current  = 0;
      var locked   = false;
      var DURATION = 500;

      if (total <= 1) return;

      function go(next, dir) {
        if (locked) return;
        next = ((next % total) + total) % total;
        if (next === current) return;

        locked = true;
        var from = current;
        current  = next;

        var oldSlide = SLIDES[from];
        var newSlide = SLIDES[next];

        var startX = dir === 'next' ? '32px' : '-32px';
        newSlide.style.cssText = 'position:absolute;inset:0;opacity:0;visibility:visible;pointer-events:none;transform:translateX(' + startX + ');transition:none;z-index:2;';

        void newSlide.offsetWidth; // reflow

        oldSlide.classList.remove('is-active');
        oldSlide.classList.add(dir === 'next' ? 'is-out-left' : 'is-out-right');

        newSlide.style.cssText = '';
        newSlide.classList.add('is-active');
        newSlide.setAttribute('aria-hidden', 'false');
        oldSlide.setAttribute('aria-hidden', 'true');

        setTimeout(function() {
          oldSlide.classList.remove('is-out-left', 'is-out-right');
          oldSlide.style.cssText = '';
          locked = false;
        }, DURATION + 60);

        // update dots
        var oldDot = DOT_ICONS[from];
        var newDot = DOT_ICONS[next];
        if (oldDot) oldDot.classList.remove('is-visible');
        setTimeout(function() {
          if (newDot) newDot.classList.add('is-visible');
        }, 80);

        // info panels
        var oldInfo = INFO_ITEMS[from];
        var newInfo = INFO_ITEMS[next];
        if (oldInfo) {
          oldInfo.classList.remove('is-active');
          oldInfo.setAttribute('aria-hidden', 'true');
        }
        if (newInfo) {
          newInfo.classList.add('is-active');
          newInfo.setAttribute('aria-hidden', 'false');
        }
      }

      PREV_BTN && PREV_BTN.addEventListener('click', function() { go(current - 1, 'prev'); });
      NEXT_BTN && NEXT_BTN.addEventListener('click', function() { go(current + 1, 'next'); });

      // touch
      var tx = 0, ty = 0;
      STAGE.addEventListener('touchstart', function(e) {
        tx = e.changedTouches[0].clientX;
        ty = e.changedTouches[0].clientY;
      }, { passive: true });
      STAGE.addEventListener('touchend', function(e) {
        var dx = e.changedTouches[0].clientX - tx;
        var dy = e.changedTouches[0].clientY - ty;
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
          go(dx < 0 ? current + 1 : current - 1, dx < 0 ? 'next' : 'prev');
        }
      }, { passive: true });

      ROOT.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowLeft') go(current - 1, 'prev');
        if (e.key === 'ArrowRight') go(current + 1, 'next');
      });

      function lockHeight() {
        if (!STAGE) return;
        var max = 0;
        SLIDES.forEach(function(s) {
          var prev = s.style.cssText;
          s.style.cssText = 'position:relative!important;opacity:0!important;visibility:visible!important;transform:none!important;pointer-events:none!important;transition:none!important;';
          var h = s.offsetHeight;
          s.style.cssText = prev;
          if (h > max) max = h;
        });
        if (max > 10) STAGE.style.height = max + 'px';
      }

      if (document.readyState === 'complete') lockHeight();
      else window.addEventListener('load', lockHeight);

      var resizeTimer;
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(lockHeight, 120);
      });

    })();
  </script>

  <!-- tiny spacer note: image reference perfectly matched -->
</body>
