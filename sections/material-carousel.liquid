{%- liquid
  assign s_id    = 'ms-' | append: section.id
  assign s_total = section.blocks.size
-%}

{{- 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css' | stylesheet_tag -}}

<section
  class="ms-root"
  id="{{ s_id }}"
  data-ms-section
  data-ms-id="{{ s_id }}"
  data-ms-total="{{ s_total }}"
  tabindex="-1"
>
  <div class="ms-inner">

    <div class="ms-head">
      {%- if section.settings.title != blank -%}
        <h2 class="ms-head__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ms-head__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="ms-stage-wrap">
      <div class="swiper ms-swiper" id="{{ s_id }}-swiper">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            <div
              class="swiper-slide"
              data-ms-swiper-slide="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.desktop_image != blank -%}
                {{- block.settings.desktop_image
                    | image_url: width: 800
                    | image_tag:
                        loading: 'lazy',
                        alt: block.settings.name,
                        widths: '400,600,800' -}}
              {%- elsif block.settings.mobile_image != blank -%}
                {{- block.settings.mobile_image
                    | image_url: width: 800
                    | image_tag:
                        loading: 'lazy',
                        alt: block.settings.name -}}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>

    <div class="ms-controls">
      <button class="ms-arrow ms-arrow--prev" type="button" data-ms-prev aria-label="Previous material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M6 1.5 1 6.5l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="ms-background-dot" style="background:white; padding:12px; border-radius:50%;">
      <div class="ms-dot-display" data-ms-dot-display aria-hidden="true">
        {%- for block in section.blocks -%}
          <div class="ms-dot-icon{% if forloop.first %} is-visible{% endif %}" data-ms-dot-icon="{{ forloop.index0 }}">
            {%- if block.settings.icon != blank -%}
              {{- block.settings.icon | image_url: width: 80 | image_tag: class: 'ms-dot-icon__img', loading: 'lazy', alt: block.settings.name -}}
            {%- else -%}
              <span class="ms-dot-icon__swatch" style="background:{{ block.settings.icon_color | default: '#1a1a1a' }};"></span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      </div>
      <button class="ms-arrow ms-arrow--next" type="button" data-ms-next aria-label="Next material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M1 1.5l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <div class="ms-info-wrap" data-ms-info-wrap>
      {%- for block in section.blocks -%}
        <div
          class="ms-info-item{% if forloop.first %} is-active{% endif %}"
          data-ms-info="{{ forloop.index0 }}"
          role="region"
          aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
        >
          <h3 class="ms-info-item__name">{{ block.settings.name | upcase | escape }}</h3>
          {%- if block.settings.description != blank -%}
            <p class="ms-info-item__desc">{{ block.settings.description }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_url | default: '#' }}" class="ms-info-item__btn">
              {{ block.settings.button_label | upcase | escape }}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>

[data-ms-section] {
  --ms-bg:        #f1F1F1;
  --ms-panel-bg:  #ffffff;
  --ms-border:    #e2e0db;
  --ms-shad-c:    0 4px 32px rgba(0,0,0,0.10);
  --ms-shad-s:    0 2px 12px rgba(0,0,0,0.05);
  --ms-title-clr: #1a1a1a;
  --ms-text-clr:  #6b6b6b;
  --ms-btn-bg:    {{ section.settings.button_color | default: '#A68380' }};
  --ms-btn-hov:   {{ section.settings.button_hover_color | default: '#7a5555' }};
  --ms-dot-sz:    80px;
  --ms-arrow-sz:  42px;
  --ms-ease:      cubic-bezier(0.4,0,0.2,1);
  --ms-dur:       500ms;
  --ms-slide-h:   380px;   
  background: var(--ms-bg);
  padding: 60px 0 56px;
  overflow: hidden;
  font-family: inherit;
  isolation: isolate;
}

[data-ms-section] *,
[data-ms-section] *::before,
[data-ms-section] *::after { box-sizing: border-box; margin: 0; padding: 0; }

[data-ms-section] a      { text-decoration: none; }
[data-ms-section] img    { display: block; }
[data-ms-section] button { appearance: none; -webkit-appearance: none; border: none; background: none; cursor: pointer; font-family: inherit; }

[data-ms-section] .ms-inner {
  margin: 0 auto;
  text-align: center;
}

[data-ms-section] .ms-head { margin-bottom: 0px; position:relative; z-index:10; }
[data-ms-section] .ms-head__title {
  font-size: clamp(18px, 2vw, 26px);
  font-weight: 400;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
  margin-bottom: 6px;
}
[data-ms-section] .ms-head__subtitle {
    font-size: 14px;
    color: var(--ms-text-clr);
    line-height: 1.4;
    max-width: 560px;
    margin: 0 auto;
    padding-top: 8px;
}

[data-ms-section] .ms-stage-wrap {
  position: relative;
  overflow: visible;
}

[data-ms-section] .ms-swiper {
  position: relative;
  width: 800px;
  margin-inline: auto;
  overflow: visible; 
}


[data-ms-section] .ms-swiper::before {
  content: '';
  position: absolute;
  top: -40px;
  left: 50%;
  transform: translateX(-50%);
  width: 100vw;         
  height: 100px;
  background: var(--ms-bg);
  border-radius: 100%;
  z-index: 10;
  pointer-events: none;
}

[data-ms-section] .ms-swiper::after {
  content: '';
  position: absolute;
  bottom: -50px;
  left: 50%;
  transform: translateX(-50%);
  width: 100vw;          
  height: 100px;
  background: var(--ms-bg);
  border-radius: 100%;
  z-index: 10;
  pointer-events: none;
}

[data-ms-section] .ms-swiper .swiper-slide {
  height: var(--ms-slide-h);
  background: var(--ms-panel-bg);
  border: 1px solid var(--ms-border);
  border-radius: 6px;
  overflow: hidden;
  box-shadow: var(--ms-shad-s);
  transition: box-shadow var(--ms-dur) var(--ms-ease);
}

[data-ms-section] .ms-swiper .swiper-slide-active {
  box-shadow: var(--ms-shad-c);
}

[data-ms-section] .ms-swiper .swiper-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

[data-ms-section] .ms-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin: 0 0 4px;
  position: relative;
  z-index: 4;
}
[data-ms-section] .ms-arrow {
  flex-shrink: 0;
  width: var(--ms-arrow-sz);
  height: var(--ms-arrow-sz);
  border-radius: 50%;
  background: white !important;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #444;
  transition: border-color 0.2s, background 0.2s, transform 0.15s;
}
[data-ms-section] .ms-arrow:hover {
  border-color: #888 !important;
  background: rgba(0,0,0,0.04) !important;
}
[data-ms-section] .ms-arrow:active { transform: scale(0.90); }

[data-ms-section] .ms-dot-display {
  position: relative;
  width: var(--ms-dot-sz);
  height: var(--ms-dot-sz);
  flex-shrink: 0;
  border-radius: 50%;
}
{% comment %} [data-ms-section] .ms-dot-icon {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  overflow: hidden;
  opacity: 0;
  transform: scale(0.65) rotate(-20deg);
  pointer-events: none;
  transition:
    opacity 0.32s var(--ms-ease),
    transform 0.32s var(--ms-ease);
}
[data-ms-section] .ms-dot-icon.is-visible {
  opacity: 1;
  transform: scale(1) rotate(0deg);
} {% endcomment %}
[data-ms-section] .ms-dot-display {
  position: relative;
  width: var(--ms-dot-sz);
  height: var(--ms-dot-sz);
  flex-shrink: 0;
  border-radius: 50%;
  overflow: hidden;           /* clip sliding dots inside the circle */
}

[data-ms-section] .ms-dot-icon {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  overflow: hidden;
  opacity: 0;
  transform: translateX(100%);   /* default: waiting off-screen right */
  pointer-events: none;
  transition:
    opacity var(--ms-dur) var(--ms-ease),
    transform var(--ms-dur) var(--ms-ease);
}

/* Active dot: centred, fully visible */
[data-ms-section] .ms-dot-icon.is-visible {
  opacity: 1;
  transform: translateX(0);
}

/* Exiting to the left (user went Next) */
[data-ms-section] .ms-dot-icon.is-exit-left {
  opacity: 0;
  transform: translateX(-100%);
  pointer-events: none;
}

/* Exiting to the right (user went Prev) */
[data-ms-section] .ms-dot-icon.is-exit-right {
  opacity: 0;
  transform: translateX(100%);
  pointer-events: none;
}

/* Entering from the left (user went Prev) */
[data-ms-section] .ms-dot-icon.is-enter-left {
  transform: translateX(-100%);
  opacity: 0;
}

/* Entering from the right (user went Next) */
[data-ms-section] .ms-dot-icon.is-enter-right {
  transform: translateX(100%);
  opacity: 0;
}

[data-ms-section] .ms-dot-icon__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}
[data-ms-section] .ms-dot-icon__swatch {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

[data-ms-section] .ms-info-wrap {
  position: relative;
  min-height: 152px;
  margin-top: 24px;
}
[data-ms-section] .ms-info-item {
  position: absolute;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateY(10px);
  transition:
    opacity 0.35s var(--ms-ease),
    transform 0.35s var(--ms-ease),
    visibility 0s linear 0.35s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}
[data-ms-section] .ms-info-item.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateY(0);
  transition:
    opacity 0.35s var(--ms-ease) 0.12s,
    transform 0.35s var(--ms-ease) 0.12s,
    visibility 0s linear 0s;
}
[data-ms-section] .ms-info-item__name {
  font-size: clamp(15px, 1.6vw, 20px);
  font-weight: 400;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
}
[data-ms-section] .ms-info-item__desc {
  font-size: 14px;
  color: var(--ms-text-clr);
  line-height: 1.4;
  max-width: 480px;
}
[data-ms-section] .ms-info-item__btn {
  display: inline-block;
  padding: 13px 38px;
  background: var(--ms-btn-bg);
  color: #fff;
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  transition: background 0.22s var(--ms-ease), transform 0.15s;
  margin-top: 30px;
  border-radius:12px;
}
[data-ms-section] .ms-info-item__btn:hover {
  background: var(--ms-btn-hov);
  color: #fff;
}
[data-ms-section] .ms-info-item__btn:active { transform: scale(0.97); }

@media screen and (max-width: 767px) {
  [data-ms-section] {
    padding: 40px 0 44px;
    --ms-slide-h: 300px;
  }
  [data-ms-section] .ms-inner    { padding: 0 16px; }
  [data-ms-section] .ms-head     { margin-bottom: 28px; }
  [data-ms-section] .ms-head__title { font-size: 17px; letter-spacing: 2px; }

  [data-ms-section] .ms-swiper {
    width: 100%;
    max-width: 100%;   
    overflow: visible;
  }
  [data-ms-section] .ms-stage-wrap {
    overflow: visible;
  }
  [data-ms-section] .ms-swiper::before {
    top: -50px;
    height: 80px;
  }
  [data-ms-section] .ms-swiper::after {
    bottom: -45px;
    height: 80px;
  }

  [data-ms-section] .ms-info-wrap    { min-height: 164px; }
}

[data-ms-section][data-ms-total="1"] .ms-controls { display: none; }
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>


<script>
(function () {
  'use strict';

  function init() {
    var ROOT = document.getElementById('{{ s_id }}');
    if (!ROOT) return;

    var total      = parseInt(ROOT.getAttribute('data-ms-total'), 10) || 0;
    var DOT_ICONS  = Array.from(ROOT.querySelectorAll('[data-ms-dot-icon]'));
    var INFO_ITEMS = Array.from(ROOT.querySelectorAll('[data-ms-info]'));
    var PREV_BTN   = ROOT.querySelector('[data-ms-prev]');
    var NEXT_BTN   = ROOT.querySelector('[data-ms-next]');

    if (total <= 1) return;

    // Track swipe direction: 1 = next (→), -1 = prev (←)
    var direction = 1;
    var prevRealIndex = 0;

    var swiper = new Swiper('#{{ s_id }}-swiper', {
      loop:            true,
      slidesPerView:   2,
      spaceBetween:    20,
      centeredSlides:  true,
      speed:           500,
      grabCursor:      true,
      touchRatio:      1,
      touchAngle:      45,

      breakpoints: {
        0: {
          slidesPerView: 1.3,
          spaceBetween:  16
        },
        768: {
          slidesPerView: 2,
          spaceBetween:  20
        }
      },

      on: {
        slideChange: function () {
          var idx = this.realIndex;

          // ── Dot slide animation ──────────────────────────────────
          var outgoing = DOT_ICONS[prevRealIndex];
          var incoming = DOT_ICONS[idx];

          var exitClass  = direction === 1 ? 'is-exit-left'  : 'is-exit-right';
          var enterClass = direction === 1 ? 'is-enter-right' : 'is-enter-left';

          // 1. Set incoming to its off-screen start position (no transition)
          incoming.style.transition = 'none';
          incoming.classList.remove('is-visible', 'is-exit-left', 'is-exit-right');
          incoming.classList.add(enterClass);

          // 2. Force reflow so the browser registers the start position
          incoming.getBoundingClientRect();

          // 3. Re-enable transitions and animate both dots
          incoming.style.transition = '';
          outgoing.classList.remove('is-visible');
          outgoing.classList.add(exitClass);
          incoming.classList.remove(enterClass);
          incoming.classList.add('is-visible');

          // 4. Clean up exit classes after transition ends
          outgoing.addEventListener('transitionend', function cleanup() {
            outgoing.classList.remove('is-exit-left', 'is-exit-right');
            outgoing.removeEventListener('transitionend', cleanup);
          });

          prevRealIndex = idx;

          // ── Info panel swap ──────────────────────────────────────
          INFO_ITEMS.forEach(function (item, i) {
            var active = (i === idx);
            item.classList.toggle('is-active', active);
            item.setAttribute('aria-hidden', active ? 'false' : 'true');
          });
        }
      }
    });

    // Set direction BEFORE slide changes so slideChange reads the correct value
    PREV_BTN && PREV_BTN.addEventListener('click', function () {
      direction = -1;
      swiper.slidePrev();
    });
    NEXT_BTN && NEXT_BTN.addEventListener('click', function () {
      direction = 1;
      swiper.slideNext();
    });

    // Keyboard nav
    ROOT.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft')  { direction = -1; swiper.slidePrev(); }
      if (e.key === 'ArrowRight') { direction =  1; swiper.slideNext(); }
    });

    // Touch/drag: detect direction from swiper's internal progress
    swiper.on('sliderFirstMove', function () {
      direction = swiper.swipeDirection === 'prev' ? -1 : 1;
    });
  }

  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    var attempts = 0;
    var poll = setInterval(function () {
      if (typeof Swiper !== 'undefined') { clearInterval(poll); init(); }
      if (++attempts > 40) clearInterval(poll);
    }, 50);
  } else {
    document.addEventListener('DOMContentLoaded', function () {
      var attempts = 0;
      var poll = setInterval(function () {
        if (typeof Swiper !== 'undefined') { clearInterval(poll); init(); }
        if (++attempts > 40) clearInterval(poll);
      }, 50);
    });
  }
})();
</script>

{% schema %}
{
  "name": "Materials Carousel",
  "tag": "section",
  "class": "section-materials-carousel",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "OTHER MATERIALS"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle / Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Background",
      "default": "#8c6464"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button Hover",
      "default": "#7a5555"
    }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Material Name",
          "default": "Black Beads"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt."
        },
        {
          "type": "header",
          "content": "Selector Icon"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image",
          "info": "Circular icon shown in the selector. Recommended: 120×120 px PNG."
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "Fallback Swatch Colour",
          "default": "#1a1a1a",
          "info": "Used when no Icon Image is set."
        },
        {
          "type": "header",
          "content": "Product Images"
        },
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop Image",
          "info": "Shown as the swiper slide image. Recommended: 800×500 px."
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image (optional)",
          "info": "If blank, Desktop Image is used. Recommended: 600×600 px."
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "VIEW COLLECTION"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Materials Carousel",
      "blocks": [
        { "type": "material" },
        { "type": "material" },
        { "type": "material" },
        { "type": "material" },
        { "type": "material" }
      ]
    }
  ],
  "max_blocks": 12
}
{% endschema %}
