{%- liquid
  assign s_id    = 'ms-' | append: section.id
  assign s_total = section.blocks.size
-%}

<section
  class="ms-root"
  id="{{ s_id }}"
  data-ms-section
  data-ms-id="{{ s_id }}"
  data-ms-total="{{ s_total }}"
  tabindex="-1"
>

  {%- comment -%}── HEADER ──{%- endcomment -%}
  <div class="ms-inner">
    <div class="ms-head">
      {%- if section.settings.title != blank -%}
        <h2 class="ms-head__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ms-head__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%}
    ── CAROUSEL STAGE ──
    Full-width so side slides bleed to screen edges.
    All slides stacked at center; JS drives cylindrical 3D transforms.
  {%- endcomment -%}
  <div class="ms-stage-wrap">
    <div class="ms-stage" data-ms-stage>

      {%- for block in section.blocks -%}
        <div
          class="ms-slide"
          data-ms-slide="{{ forloop.index0 }}"
          aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
          {{ block.shopify_attributes }}
        >
          <div class="ms-slide__card">
            {%- if block.settings.desktop_image != blank -%}
              {{- block.settings.desktop_image
                  | image_url: width: 700
                  | image_tag:
                      class: 'ms-slide__img',
                      loading: 'lazy',
                      alt: block.settings.name,
                      widths: '280,400,560,700' -}}
            {%- elsif block.settings.mobile_image != blank -%}
              {{- block.settings.mobile_image
                  | image_url: width: 600
                  | image_tag:
                      class: 'ms-slide__img',
                      loading: 'lazy',
                      alt: block.settings.name -}}
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}

    </div>
  </div>

  {%- comment -%}── CONTROLS + INFO ──{%- endcomment -%}
  <div class="ms-inner">

    <div class="ms-controls">

      <button class="ms-arrow ms-arrow--prev" type="button" data-ms-prev aria-label="Previous material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M6 1.5 1 6.5l5 5" stroke="currentColor" stroke-width="1.6"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="ms-dot-display" data-ms-dot-display aria-hidden="true">
        {%- for block in section.blocks -%}
          <div
            class="ms-dot-icon{% if forloop.first %} is-visible{% endif %}"
            data-ms-dot-icon="{{ forloop.index0 }}"
          >
            {%- if block.settings.icon != blank -%}
              {{- block.settings.icon
                  | image_url: width: 80
                  | image_tag:
                      class: 'ms-dot-icon__img',
                      loading: 'lazy',
                      alt: block.settings.name -}}
            {%- else -%}
              <span
                class="ms-dot-icon__swatch"
                style="background:{{ block.settings.icon_color | default: '#1a1a1a' }};"
              ></span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <button class="ms-arrow ms-arrow--next" type="button" data-ms-next aria-label="Next material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M1 1.5l5 5-5 5" stroke="currentColor" stroke-width="1.6"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

    </div>

    <div class="ms-info-wrap" data-ms-info-wrap>
      {%- for block in section.blocks -%}
        <div
          class="ms-info-item{% if forloop.first %} is-active{% endif %}"
          data-ms-info="{{ forloop.index0 }}"
          role="region"
          aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
        >
          <h3 class="ms-info-item__name">{{ block.settings.name | upcase | escape }}</h3>
          {%- if block.settings.description != blank -%}
            <p class="ms-info-item__desc">{{ block.settings.description }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a
              href="{{ block.settings.button_url | default: '#' }}"
              class="ms-info-item__btn"
            >{{ block.settings.button_label | upcase | escape }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
/* ============================================================
   MATERIALS CAROUSEL  ·  prefix: ms-
   Cylindrical multi-image carousel — auto-fills screen width.
   Double-scoped: [data-ms-section] .ms-*  — zero bleed.
   ============================================================ */
[data-ms-section] {
  /* ── Design tokens ── */
  --ms-bg:        #f0eeea;
  --ms-arch-bg:   #e8e6e1;
  --ms-panel-bg:  #ffffff;
  --ms-border:    #e2e0db;
  --ms-shad-c:    0 10px 48px rgba(0,0,0,0.13);
  --ms-shad-s:    0 2px 16px rgba(0,0,0,0.06);
  --ms-title-clr: #1a1a1a;
  --ms-text-clr:  #6b6b6b;
  --ms-btn-bg:    {{ section.settings.button_color | default: '#8c6464' }};
  --ms-btn-hov:   {{ section.settings.button_hover_color | default: '#7a5555' }};
  --ms-dot-sz:    56px;
  --ms-arrow-sz:  36px;
  --ms-ease:      cubic-bezier(0.4,0,0.2,1);
  --ms-dur:       420ms;

  /*
   * --ms-item-w: width of every slide card in px (with unit).
   * JS reads this via getComputedStyle + parseInt to strip 'px'.
   * Change in the @media block to auto-adapt per breakpoint.
   */
  --ms-item-w:    280px;
  --ms-stage-h:   400px;

  background: var(--ms-bg);
  padding: 60px 0 56px;
  overflow: hidden;
  font-family: inherit;
  isolation: isolate;
}

[data-ms-section] *,
[data-ms-section] *::before,
[data-ms-section] *::after { box-sizing: border-box; margin: 0; padding: 0; }

[data-ms-section] a      { text-decoration: none; }
[data-ms-section] img    { display: block; }
[data-ms-section] button {
  appearance: none; -webkit-appearance: none;
  border: none; background: none;
  cursor: pointer; font-family: inherit;
}

/* ── Centered content wrapper ─────────────────── */
[data-ms-section] .ms-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 24px;
  text-align: center;
}

/* ── Header ───────────────────────────────────── */
[data-ms-section] .ms-head { margin-bottom: 44px; }

[data-ms-section] .ms-head__title {
  font-size: clamp(18px, 2vw, 26px);
  font-weight: 400;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
  margin-bottom: 18px;
}

[data-ms-section] .ms-head__subtitle {
  font-size: 15px;
  color: var(--ms-text-clr);
  line-height: 1.8;
  max-width: 560px;
  margin: 0 auto;
}

/* ── Stage wrap — full section width ─────────── */
[data-ms-section] .ms-stage-wrap {
  position: relative;
  width: 100%;
  overflow: hidden; /* clips cards at screen edges */
}

/*
 * Cylindrical arch / dome background.
 * wider than container to give seamless dome edge,
 * clipped by .ms-stage-wrap overflow:hidden.
 */
[data-ms-section] .ms-stage-wrap::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 120%;
  height: 84%;
  background: var(--ms-arch-bg);
  border-radius: 50% 50% 0 0 / 22% 22% 0 0;
  z-index: 0;
  pointer-events: none;
}

/*
 * perspective on the stage gives all child transforms a shared
 * vanishing point, producing the cylindrical wrap illusion.
 */
[data-ms-section] .ms-stage {
  position: relative;
  height: var(--ms-stage-h);
  perspective: 1800px;
  z-index: 1;
}

/* ── Individual slide ─────────────────────────── */
[data-ms-section] .ms-slide {
  position: absolute;
  top: 0;
  /* Horizontally centred; transform drives X position */
  left: 50%;
  width: var(--ms-item-w);
  margin-left: calc(var(--ms-item-w) / -2);
  height: 100%;
  cursor: pointer;

  /* Default: invisible, parked at centre */
  opacity: 0;
  pointer-events: none;

  transition:
    transform var(--ms-dur) var(--ms-ease),
    opacity   var(--ms-dur) var(--ms-ease),
    box-shadow var(--ms-dur) var(--ms-ease);
  will-change: transform, opacity;
  transform-origin: center center;
}

/* Active centre slide — not pointer-interactive (already there) */
[data-ms-section] .ms-slide[data-ms-active] {
  cursor: default;
}

/* ── Slide card (white box) ───────────────────── */
[data-ms-section] .ms-slide__card {
  width: 100%;
  height: 100%;
  background: var(--ms-panel-bg);
  border: 1px solid var(--ms-border);
  border-radius: 8px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--ms-shad-s);
  transition: box-shadow var(--ms-dur) var(--ms-ease);
}

[data-ms-section] .ms-slide[data-ms-active] .ms-slide__card {
  box-shadow: var(--ms-shad-c);
}

[data-ms-section] .ms-slide__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 20px 16px;
}

/* ── Controls ────────────────────────────────── */
[data-ms-section] .ms-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin: 28px 0 4px;
  position: relative;
  z-index: 4;
}

[data-ms-section] .ms-arrow {
  flex-shrink: 0;
  width: var(--ms-arrow-sz);
  height: var(--ms-arrow-sz);
  border: 1.5px solid #c8c8c8 !important;
  border-radius: 50%;
  background: transparent !important;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #444;
  transition: border-color 0.2s, background 0.2s, transform 0.15s;
}
[data-ms-section] .ms-arrow:hover {
  border-color: #888 !important;
  background: rgba(0,0,0,0.04) !important;
}
[data-ms-section] .ms-arrow:active { transform: scale(0.90); }

/* ── Single active dot ───────────────────────── */
[data-ms-section] .ms-dot-display {
  position: relative;
  width: var(--ms-dot-sz);
  height: var(--ms-dot-sz);
  flex-shrink: 0;
  border-radius: 50%;
  box-shadow: 0 0 0 2.5px #1a1a1a;
}

[data-ms-section] .ms-dot-icon {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  overflow: hidden;
  opacity: 0;
  transform: scale(0.65) rotate(-20deg);
  pointer-events: none;
  transition:
    opacity   0.32s var(--ms-ease),
    transform 0.32s var(--ms-ease);
}

[data-ms-section] .ms-dot-icon.is-visible {
  opacity: 1;
  transform: scale(1) rotate(0deg);
}

[data-ms-section] .ms-dot-icon__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}

[data-ms-section] .ms-dot-icon__swatch {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* ── Info block ──────────────────────────────── */
[data-ms-section] .ms-info-wrap {
  position: relative;
  min-height: 152px;
  margin-top: 24px;
}

[data-ms-section] .ms-info-item {
  position: absolute;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateY(10px);
  transition:
    opacity   0.35s var(--ms-ease),
    transform 0.35s var(--ms-ease),
    visibility 0s linear 0.35s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

[data-ms-section] .ms-info-item.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateY(0);
  transition:
    opacity   0.35s var(--ms-ease) 0.12s,
    transform 0.35s var(--ms-ease) 0.12s,
    visibility 0s linear 0s;
}

[data-ms-section] .ms-info-item__name {
  font-size: clamp(15px, 1.6vw, 20px);
  font-weight: 400;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
}

[data-ms-section] .ms-info-item__desc {
  font-size: 14px;
  color: var(--ms-text-clr);
  line-height: 1.8;
  max-width: 480px;
}

[data-ms-section] .ms-info-item__btn {
  display: inline-block;
  padding: 13px 38px;
  background: var(--ms-btn-bg);
  color: #fff;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  transition: background 0.22s var(--ms-ease), transform 0.15s;
  margin-top: 4px;
}
[data-ms-section] .ms-info-item__btn:hover {
  background: var(--ms-btn-hov);
  color: #fff;
}
[data-ms-section] .ms-info-item__btn:active { transform: scale(0.97); }

/* ── Responsive overrides ─────────────────────── */
@media screen and (max-width: 1023px) {
  [data-ms-section] {
    --ms-item-w:   230px;
    --ms-stage-h:  340px;
  }
}

@media screen and (max-width: 767px) {
  [data-ms-section] {
    --ms-item-w:   190px;
    --ms-stage-h:  280px;
    padding: 40px 0 44px;
  }
  [data-ms-section] .ms-inner       { padding: 0 16px; }
  [data-ms-section] .ms-head        { margin-bottom: 28px; }
  [data-ms-section] .ms-head__title { font-size: 17px; letter-spacing: 4px; }
  [data-ms-section] .ms-info-wrap   { min-height: 164px; }
  [data-ms-section] .ms-info-item__desc { max-width: 300px; }
  [data-ms-section] .ms-stage-wrap::before {
    border-radius: 50% 50% 0 0 / 14% 14% 0 0;
  }
}

/* Hide controls when only one slide */
[data-ms-section][data-ms-total="1"] .ms-controls { display: none; }
</style>

<script>
(function () {
  'use strict';

  var ROOT = document.getElementById('{{ s_id }}');
  if (!ROOT) return;

  var STAGE      = ROOT.querySelector('[data-ms-stage]');
  var SLIDES     = Array.from(ROOT.querySelectorAll('[data-ms-slide]'));
  var DOT_ICONS  = Array.from(ROOT.querySelectorAll('[data-ms-dot-icon]'));
  var INFO_ITEMS = Array.from(ROOT.querySelectorAll('[data-ms-info]'));
  var PREV_BTN   = ROOT.querySelector('[data-ms-prev]');
  var NEXT_BTN   = ROOT.querySelector('[data-ms-next]');

  var total   = SLIDES.length;
  var current = 0;

  /* ── Cylindrical transform constants ──
   *
   *  STEP_RATIO   : fraction of item width between adjacent centres (overlap).
   *                 0.72 = 28% overlap → items slightly overlapping for depth.
   *  ROTATE_DEG   : Y-axis rotation per step (deg). Higher = more cylinder curve.
   *  SCALE_STEP   : scale reduction per step (0–1). 0.10 = 10% smaller per step.
   *  OPACITY_STEP : opacity reduction per step.
   *  MIN_OPACITY  : floor opacity for the farthest visible slides.
   */
  var STEP_RATIO    = 0.72;
  var ROTATE_DEG    = 20;
  var SCALE_STEP    = 0.09;
  var OPACITY_STEP  = 0.20;
  var MIN_OPACITY   = 0.12;

  /* ── Read --ms-item-w CSS variable (respects breakpoints) ── */
  function getItemW() {
    var raw = getComputedStyle(ROOT).getPropertyValue('--ms-item-w').trim();
    var val = parseInt(raw, 10);
    return isNaN(val) ? 280 : val;
  }

  /*
   * getMaxSide — how many slides to show on each side of centre.
   * Fills screen: keeps adding slides until the next one would
   * start beyond the section's half-width.
   */
  function getMaxSide() {
    var sectionHalf = ROOT.offsetWidth / 2;
    var itemW       = getItemW();
    var step        = itemW * STEP_RATIO;
    /* centre card occupies itemW/2 from centre to its right edge */
    var used        = itemW / 2;
    var side        = 0;

    while (used + step < sectionHalf + itemW * 0.5) {
      side++;
      used += step;
    }

    /* Never exceed what the slide pool can supply */
    side = Math.max(1, Math.min(side, Math.floor((total - 1) / 2) + 1));
    return side;
  }

  /* ── Apply 3D cylindrical transform to one slide ── */
  function setSlideTransform(slide, offset, maxSide, itemW) {
    var abs  = Math.abs(offset);
    var step = itemW * STEP_RATIO;

    if (abs > maxSide) {
      /*
       * Park hidden slides just off the visible edge so they
       * don't "pop" in from far away when navigating fast.
       */
      var parkSign = offset >= 0 ? 1 : -1;
      var parkAbs  = maxSide + 1;
      slide.style.transform =
        'translateX(' + (parkSign * parkAbs * step) + 'px)' +
        ' rotateY('   + (parkSign * parkAbs * ROTATE_DEG) + 'deg)' +
        ' scale('     + Math.max(0.25, 1 - parkAbs * SCALE_STEP) + ')';
      slide.style.opacity       = '0';
      slide.style.zIndex        = '0';
      slide.style.pointerEvents = 'none';
      slide.setAttribute('aria-hidden', 'true');
      slide.removeAttribute('data-ms-active');
      return;
    }

    var tx  = offset * step;
    var ry  = offset * ROTATE_DEG;
    var sc  = Math.max(0.35, 1 - abs * SCALE_STEP);
    var op  = Math.max(MIN_OPACITY, 1 - abs * OPACITY_STEP);
    var zi  = (maxSide + 2) - abs;

    slide.style.transform =
      'translateX(' + tx + 'px)' +
      ' rotateY('   + ry + 'deg)' +
      ' scale('     + sc + ')';
    slide.style.opacity       = String(op);
    slide.style.zIndex        = String(zi);
    /* All visible slides are pointer-interactive (click to jump) */
    slide.style.pointerEvents = 'auto';
    slide.setAttribute('aria-hidden', offset === 0 ? 'false' : 'true');

    if (offset === 0) {
      slide.setAttribute('data-ms-active', '');
    } else {
      slide.removeAttribute('data-ms-active');
    }
  }

  /* ── Reposition every slide around `current` ── */
  function updateSlides() {
    var maxSide = getMaxSide();
    var itemW   = getItemW();

    SLIDES.forEach(function (slide, i) {
      /* Shortest-path offset with circular wrap */
      var offset = i - current;
      if (offset >  total / 2) offset -= total;
      if (offset < -total / 2) offset += total;

      setSlideTransform(slide, offset, maxSide, itemW);
    });
  }

  /* ── Navigate to index `next` ── */
  function go(next) {
    next = ((next % total) + total) % total;
    if (next === current) return;

    var from = current;
    current  = next;

    updateSlides();

    /* Dot icon swap */
    DOT_ICONS[from] && DOT_ICONS[from].classList.remove('is-visible');
    var capturedNext = next;
    setTimeout(function () {
      DOT_ICONS[capturedNext] && DOT_ICONS[capturedNext].classList.add('is-visible');
    }, 80);

    /* Info panel swap */
    var oldInfo = INFO_ITEMS[from];
    var newInfo = INFO_ITEMS[next];
    if (oldInfo) {
      oldInfo.classList.remove('is-active');
      oldInfo.setAttribute('aria-hidden', 'true');
    }
    if (newInfo) {
      newInfo.classList.add('is-active');
      newInfo.setAttribute('aria-hidden', 'false');
    }
  }

  /* ── Click on side slide → jump to it ── */
  SLIDES.forEach(function (slide, i) {
    slide.addEventListener('click', function () {
      if (i !== current) go(i);
    });
  });

  /* ── Arrow buttons ── */
  PREV_BTN && PREV_BTN.addEventListener('click', function () { go(current - 1); });
  NEXT_BTN && NEXT_BTN.addEventListener('click', function () { go(current + 1); });

  /* ── Touch / swipe ── */
  var tx0 = 0, ty0 = 0;
  STAGE.addEventListener('touchstart', function (e) {
    tx0 = e.changedTouches[0].clientX;
    ty0 = e.changedTouches[0].clientY;
  }, { passive: true });
  STAGE.addEventListener('touchend', function (e) {
    var dx = e.changedTouches[0].clientX - tx0;
    var dy = e.changedTouches[0].clientY - ty0;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
      go(dx < 0 ? current + 1 : current - 1);
    }
  }, { passive: true });

  /* ── Keyboard ── */
  ROOT.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  go(current - 1);
    if (e.key === 'ArrowRight') go(current + 1);
  });

  /* ── Resize: recompute visible count & reposition ── */
  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(updateSlides, 100);
  });

  /* ── Init: run after fonts/images settle to get correct offsetWidth ── */
  if (document.readyState === 'complete') {
    updateSlides();
  } else {
    window.addEventListener('load', updateSlides);
    /* Eager first-pass so there's no flash of empty stage */
    updateSlides();
  }

})();
</script>

{% schema %}
{
  "name": "Materials Carousel",
  "tag": "section",
  "class": "section-materials-carousel",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "MATERIALS"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle / Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Background",
      "default": "#8c6464"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button Hover",
      "default": "#7a5555"
    }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Material Name",
          "default": "Black Beads"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt."
        },
        {
          "type": "header",
          "content": "Selector Icon"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image",
          "info": "Circular icon shown in the selector. Recommended: 120×120 px PNG."
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "Fallback Swatch Colour",
          "default": "#1a1a1a",
          "info": "Used when no Icon Image is set."
