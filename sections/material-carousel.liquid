{%- liquid
  assign s_id    = 'ms-' | append: section.id
  assign s_total = section.blocks.size
-%}

<section
  class="ms-root"
  id="{{ s_id }}"
  data-ms-section
  data-ms-id="{{ s_id }}"
  data-ms-total="{{ s_total }}"
  tabindex="-1"
>

  {%- comment -%}── HEADER (constrained width) ──{%- endcomment -%}
  <div class="ms-constrained">
    <div class="ms-head">
      {%- if section.settings.title != blank -%}
        <h2 class="ms-head__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ms-head__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%}
    ── STAGE WRAP — intentionally FULL WIDTH, bleeds to viewport edges.
    The arch pseudo-element sits behind. Each slide is position:absolute
    so the height never collapses (zero layout shift).
  {%- endcomment -%}
  <div class="ms-stage-wrap">
    <div class="ms-stage" data-ms-stage>

      {%- for block in section.blocks -%}
        {%- liquid
          assign bi = forloop.index0

          assign pi = bi | minus: 1
          if pi < 0
            assign pi = s_total | minus: 1
          endif
          assign ni = bi | plus: 1
          if ni >= s_total
            assign ni = 0
          endif

          assign pb = section.blocks[pi]
          assign nb = section.blocks[ni]
        -%}

        <div
          class="ms-slide{% if forloop.first %} is-active{% endif %}"
          data-ms-slide="{{ bi }}"
          aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
          {{ block.shopify_attributes }}
        >

          {%- comment -%}── DESKTOP: three panels that fill the full width ──{%- endcomment -%}
          <div class="ms-panels">

            {%- comment -%} LEFT panel — previous block's image, bleeds to left edge {%- endcomment -%}
            <div class="ms-panel ms-panel--l">
              {%- if pb.settings.desktop_image != blank -%}
                {{- pb.settings.desktop_image
                    | image_url: width: 520
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: pb.settings.name,
                        widths: '260,390,520' -}}
              {%- endif -%}
            </div>

            {%- comment -%} GAP between L and C {%- endcomment -%}
            <div class="ms-gap"></div>

            {%- comment -%} CENTER panel — current block's image {%- endcomment -%}
            <div class="ms-panel ms-panel--c">
              {%- if block.settings.desktop_image != blank -%}
                {{- block.settings.desktop_image
                    | image_url: width: 760
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: block.settings.name,
                        widths: '420,600,760' -}}
              {%- elsif block.settings.mobile_image != blank -%}
                {{- block.settings.mobile_image
                    | image_url: width: 760
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: block.settings.name -}}
              {%- endif -%}
            </div>

            {%- comment -%} GAP between C and R {%- endcomment -%}
            <div class="ms-gap"></div>

            {%- comment -%} RIGHT panel — next block's image, bleeds to right edge {%- endcomment -%}
            <div class="ms-panel ms-panel--r">
              {%- if nb.settings.desktop_image != blank -%}
                {{- nb.settings.desktop_image
                    | image_url: width: 520
                    | image_tag:
                        class: 'ms-panel__img',
                        loading: 'lazy',
                        alt: nb.settings.name,
                        widths: '260,390,520' -}}
              {%- endif -%}
            </div>

          </div>

          {%- comment -%}── MOBILE: single centered panel ──{%- endcomment -%}
          <div class="ms-mobile-panel">
            {%- if block.settings.mobile_image != blank -%}
              {{- block.settings.mobile_image
                  | image_url: width: 640
                  | image_tag:
                      class: 'ms-panel__img',
                      loading: 'lazy',
                      alt: block.settings.name,
                      widths: '320,480,640' -}}
            {%- elsif block.settings.desktop_image != blank -%}
              {{- block.settings.desktop_image
                  | image_url: width: 640
                  | image_tag:
                      class: 'ms-panel__img',
                      loading: 'lazy',
                      alt: block.settings.name,
                      widths: '320,480,640' -}}
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}

    </div>
  </div>

  {%- comment -%}── CONTROLS + INFO (constrained width) ──{%- endcomment -%}
  <div class="ms-constrained">

    <div class="ms-controls">
      <button class="ms-arrow ms-arrow--prev" type="button" data-ms-prev aria-label="Previous material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M6 1.5 1 6.5l5 5" stroke="currentColor" stroke-width="1.6"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      {%- comment -%}
        Single dot display: all icons stacked at position:absolute.
        Only the .is-visible one is shown — no multiple dots.
      {%- endcomment -%}
      <div class="ms-dot-display" data-ms-dot-display aria-hidden="true">
        {%- for block in section.blocks -%}
          <div
            class="ms-dot-icon{% if forloop.first %} is-visible{% endif %}"
            data-ms-dot-icon="{{ forloop.index0 }}"
          >
            {%- if block.settings.icon != blank -%}
              {{- block.settings.icon
                  | image_url: width: 80
                  | image_tag:
                      class: 'ms-dot-icon__img',
                      loading: 'lazy',
                      alt: block.settings.name -}}
            {%- else -%}
              <span
                class="ms-dot-icon__swatch"
                style="background:{{ block.settings.icon_color | default: '#1a1a1a' }};"
              ></span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <button class="ms-arrow ms-arrow--next" type="button" data-ms-next aria-label="Next material">
        <svg width="7" height="13" viewBox="0 0 7 13" fill="none" aria-hidden="true">
          <path d="M1 1.5l5 5-5 5" stroke="currentColor" stroke-width="1.6"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <div class="ms-info-wrap" data-ms-info-wrap>
      {%- for block in section.blocks -%}
        <div
          class="ms-info-item{% if forloop.first %} is-active{% endif %}"
          data-ms-info="{{ forloop.index0 }}"
          role="region"
          aria-hidden="{% unless forloop.first %}true{% else %}false{% endunless %}"
        >
          <h3 class="ms-info-item__name">{{ block.settings.name | upcase | escape }}</h3>
          {%- if block.settings.description != blank -%}
            <p class="ms-info-item__desc">{{ block.settings.description }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a
              href="{{ block.settings.button_url | default: '#' }}"
              class="ms-info-item__btn"
            >{{ block.settings.button_label | upcase | escape }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>

</section>

<style>
/* ============================================================
   MATERIALS CAROUSEL  ·  prefix: ms-
   Scoped: [data-ms-section] — zero bleed into other sections
   ============================================================ */

[data-ms-section] {
  --ms-bg:         #f0eeea;
  --ms-arch-bg:    #e5e3de;
  --ms-panel-bg:   #ffffff;
  --ms-border:     #e0ddd7;
  --ms-gap-bg:     #f0eeea;   /* gap strips match section bg */
  --ms-shad-c:     0 6px 40px rgba(0,0,0,0.11);
  --ms-shad-s:     0 2px 16px rgba(0,0,0,0.06);
  --ms-title-clr:  #1a1a1a;
  --ms-text-clr:   #6b6b6b;
  --ms-btn-bg:     {{ section.settings.button_color | default: '#8c6464' }};
  --ms-btn-hov:    {{ section.settings.button_hover_color | default: '#7a5555' }};
  --ms-dot-sz:     56px;
  --ms-arrow-sz:   36px;
  --ms-ease:       cubic-bezier(0.4,0,0.2,1);
  --ms-dur:        400ms;
  --ms-gap-w:      12px;      /* gap strip width between panels */
  --ms-stage-h:    420px;

  background: var(--ms-bg);
  padding: 56px 0 52px;
  /* overflow hidden clips the bleeding side panels cleanly */
  overflow: hidden;
  font-family: inherit;
  isolation: isolate;
}

[data-ms-section] *,
[data-ms-section] *::before,
[data-ms-section] *::after { box-sizing: border-box; margin: 0; padding: 0; }

[data-ms-section] a       { text-decoration: none; }
[data-ms-section] img     { display: block; }
[data-ms-section] button  {
  appearance: none; -webkit-appearance: none;
  border: none; background: none; cursor: pointer; font-family: inherit;
}

/* ── Constrained band (header / controls / info) ── */
[data-ms-section] .ms-constrained {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 24px;
  text-align: center;
}

/* ── Header ─────────────────────────────────────── */
[data-ms-section] .ms-head        { margin-bottom: 36px; }

[data-ms-section] .ms-head__title {
  font-size: clamp(17px, 1.9vw, 24px);
  font-weight: 400;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
  margin-bottom: 16px;
}

[data-ms-section] .ms-head__subtitle {
  font-size: 15px;
  color: var(--ms-text-clr);
  line-height: 1.85;
  max-width: 560px;
  margin: 0 auto;
}

/* ── Stage wrap — FULL viewport width, arch behind ── */
[data-ms-section] .ms-stage-wrap {
  position: relative;
  width: 100%;
  margin-bottom: 0;
}

/* Arch / cylinder-mouth shape */
[data-ms-section] .ms-stage-wrap::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  /* wider than 100% so arch extends behind clipped side panels */
  width: 110%;
  height: 86%;
  background: var(--ms-arch-bg);
  border-radius: 50% 50% 0 0 / 20% 20% 0 0;
  z-index: 0;
  pointer-events: none;
}

/* Fixed-height stage — prevents ALL layout shift */
[data-ms-section] .ms-stage {
  position: relative;
  height: var(--ms-stage-h);
  z-index: 1;
}

/* ── Slides: stacked absolute, no display:none ── */
[data-ms-section] .ms-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateX(40px);
  transition:
    opacity var(--ms-dur) var(--ms-ease),
    transform var(--ms-dur) var(--ms-ease),
    visibility 0s linear var(--ms-dur);
  will-change: opacity, transform;
}

[data-ms-section] .ms-slide.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateX(0);
  z-index: 2;
  transition:
    opacity var(--ms-dur) var(--ms-ease),
    transform var(--ms-dur) var(--ms-ease),
    visibility 0s linear 0s;
}

[data-ms-section] .ms-slide.is-out-left {
  opacity: 0;
  transform: translateX(-40px);
  transition:
    opacity var(--ms-dur) var(--ms-ease),
    transform var(--ms-dur) var(--ms-ease);
  z-index: 1;
  visibility: visible;
}

[data-ms-section] .ms-slide.is-out-right {
  opacity: 0;
  transform: translateX(40px);
  transition:
    opacity var(--ms-dur) var(--ms-ease),
    transform var(--ms-dur) var(--ms-ease);
  z-index: 1;
  visibility: visible;
}

/* ── Desktop 3-panel layout ─────────────────────── */
[data-ms-section] .ms-panels {
  display: flex;
  align-items: stretch;
  height: 100%;
  /* No padding — panels bleed to section edges */
}

/* The gap strips between panels */
[data-ms-section] .ms-gap {
  flex: 0 0 var(--ms-gap-w);
  background: var(--ms-gap-bg);
  height: 100%;
  z-index: 5;
  /* Slight arch-like curve on the gap edges */
  position: relative;
}

/* Visual divider shadow on gap edges */
[data-ms-section] .ms-gap::before,
[data-ms-section] .ms-gap::after {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  width: 1px;
}
[data-ms-section] .ms-gap::before {
  left: 0;
  box-shadow: -2px 0 6px rgba(0,0,0,0.06);
}
[data-ms-section] .ms-gap::after {
  right: 0;
  box-shadow: 2px 0 6px rgba(0,0,0,0.06);
}

[data-ms-section] .ms-panel {
  background: var(--ms-panel-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  height: 100%;
  position: relative;
}

/*
  Side panels: flex-basis ~22% each.
  The perspective tilt gives the cylinder face illusion.
  They intentionally bleed to viewport edges (no margin/padding on .ms-stage-wrap).
*/
[data-ms-section] .ms-panel--l {
  flex: 0 0 22%;
  /* Tilt away — left face of cylinder */
  transform: perspective(1100px) rotateY(16deg) scaleY(0.97);
  transform-origin: right center;
  box-shadow: var(--ms-shad-s);
  border-radius: 0 8px 8px 0;
  /* Fade slightly to hint it's a side face */
  opacity: 0.78;
}

[data-ms-section] .ms-panel--r {
  flex: 0 0 22%;
  /* Tilt away — right face of cylinder */
  transform: perspective(1100px) rotateY(-16deg) scaleY(0.97);
  transform-origin: left center;
  box-shadow: var(--ms-shad-s);
  border-radius: 8px 0 0 8px;
  opacity: 0.78;
}

[data-ms-section] .ms-panel--c {
  /* Center takes remaining space */
  flex: 1 1 auto;
  z-index: 3;
  box-shadow: var(--ms-shad-c);
  border-radius: 0;
}

/* Images: fill full panel, object-fit:contain keeps jewellery fully visible */
[data-ms-section] .ms-panel__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 28px 20px;
}

/* Side panel images get slightly more padding so they don't feel crammed */
[data-ms-section] .ms-panel--l .ms-panel__img,
[data-ms-section] .ms-panel--r .ms-panel__img {
  padding: 32px 16px;
}

/* ── Mobile single panel ─────────────────────────── */
[data-ms-section] .ms-mobile-panel {
  display: none;
  height: 100%;
  align-items: center;
  justify-content: center;
  background: var(--ms-panel-bg);
  box-shadow: var(--ms-shad-c);
  overflow: hidden;
  margin: 0 16px;
  border-radius: 6px;
}

/* ── Controls row ────────────────────────────────── */
[data-ms-section] .ms-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18px;
  margin: 26px 0 6px;
  position: relative;
  z-index: 4;
}

[data-ms-section] .ms-arrow {
  flex-shrink: 0;
  width: var(--ms-arrow-sz);
  height: var(--ms-arrow-sz);
  border: 1.5px solid #c4c4c4 !important;
  border-radius: 50%;
  background: transparent !important;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #444;
  transition: border-color 0.2s, background 0.2s, transform 0.14s;
}
[data-ms-section] .ms-arrow:hover {
  border-color: #888 !important;
  background: rgba(0,0,0,0.04) !important;
}
[data-ms-section] .ms-arrow:active { transform: scale(0.88); }

/* ── Single dot display ──────────────────────────── */
[data-ms-section] .ms-dot-display {
  position: relative;
  width: var(--ms-dot-sz);
  height: var(--ms-dot-sz);
  flex-shrink: 0;
  border-radius: 50%;
  /* Ring is a box-shadow — stays perfectly circular always */
  box-shadow: 0 0 0 2.5px #1a1a1a;
}

/* All icons stacked — only .is-visible one is shown */
[data-ms-section] .ms-dot-icon {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  overflow: hidden;
  opacity: 0;
  transform: scale(0.6) rotate(-18deg);
  pointer-events: none;
  transition:
    opacity 0.30s var(--ms-ease),
    transform 0.30s var(--ms-ease);
}

[data-ms-section] .ms-dot-icon.is-visible {
  opacity: 1;
  transform: scale(1) rotate(0deg);
}

[data-ms-section] .ms-dot-icon__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}

[data-ms-section] .ms-dot-icon__swatch {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* ── Info block ──────────────────────────────────── */
[data-ms-section] .ms-info-wrap {
  position: relative;
  min-height: 148px;
  margin-top: 20px;
}

[data-ms-section] .ms-info-item {
  position: absolute;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateY(8px);
  transition:
    opacity 0.32s var(--ms-ease),
    transform 0.32s var(--ms-ease),
    visibility 0s linear 0.32s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

[data-ms-section] .ms-info-item.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateY(0);
  transition:
    opacity 0.32s var(--ms-ease) 0.10s,
    transform 0.32s var(--ms-ease) 0.10s,
    visibility 0s linear 0s;
}

[data-ms-section] .ms-info-item__name {
  font-size: clamp(14px, 1.5vw, 19px);
  font-weight: 400;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--ms-title-clr);
}

[data-ms-section] .ms-info-item__desc {
  font-size: 14px;
  color: var(--ms-text-clr);
  line-height: 1.85;
  max-width: 480px;
}

[data-ms-section] .ms-info-item__btn {
  display: inline-block;
  padding: 12px 36px;
  background: var(--ms-btn-bg);
  color: #fff;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  transition: background 0.22s var(--ms-ease), transform 0.14s;
  margin-top: 4px;
}
[data-ms-section] .ms-info-item__btn:hover {
  background: var(--ms-btn-hov);
  color: #fff;
}
[data-ms-section] .ms-info-item__btn:active { transform: scale(0.97); }

/* ── Responsive ──────────────────────────────────── */
@media screen and (max-width: 767px) {
  [data-ms-section] {
    padding: 38px 0 42px;
    --ms-stage-h: 280px;
  }
  [data-ms-section] .ms-constrained { padding: 0 14px; }
  [data-ms-section] .ms-head        { margin-bottom: 24px; }
  [data-ms-section] .ms-head__title { font-size: 16px; letter-spacing: 4px; }

  /* Hide 3-panel, show single */
  [data-ms-section] .ms-panels       { display: none !important; }
  [data-ms-section] .ms-mobile-panel { display: flex; }

  /* Tighter arch on mobile */
  [data-ms-section] .ms-stage-wrap::before {
    border-radius: 50% 50% 0 0 / 11% 11% 0 0;
    height: 82%;
    width: 115%;
  }

  [data-ms-section] .ms-info-wrap          { min-height: 168px; }
  [data-ms-section] .ms-info-item__desc    { max-width: 290px; }
}

/* Single block → hide controls */
[data-ms-section][data-ms-total="1"] .ms-controls { display: none; }
</style>

<script>
(function () {
  'use strict';

  var ROOT       = document.getElementById('{{ s_id }}');
  if (!ROOT) return;

  var STAGE      = ROOT.querySelector('[data-ms-stage]');
  var SLIDES     = Array.from(ROOT.querySelectorAll('[data-ms-slide]'));
  var DOT_ICONS  = Array.from(ROOT.querySelectorAll('[data-ms-dot-icon]'));
  var INFO_ITEMS = Array.from(ROOT.querySelectorAll('[data-ms-info]'));
  var PREV_BTN   = ROOT.querySelector('[data-ms-prev]');
  var NEXT_BTN   = ROOT.querySelector('[data-ms-next]');

  var total    = SLIDES.length;
  var current  = 0;
  var locked   = false;
  var DUR      = 400; /* sync with --ms-dur */

  if (total <= 1) return;

  /* ── goTo ─────────────────────────────────────── */
  function go(next, dir) {
    if (locked) return;
    next = ((next % total) + total) % total;
    if (next === current) return;

    locked = true;
    var from     = current;
    current      = next;
    var oldSlide = SLIDES[from];
    var newSlide = SLIDES[next];

    /* 1. Position new slide off-screen without transition */
    var startX = dir === 'next' ? '40px' : '-40px';
    newSlide.style.cssText =
      'position:absolute;inset:0;opacity:0;visibility:visible;pointer-events:none;' +
      'transform:translateX(' + startX + ');transition:none;z-index:2;will-change:opacity,transform;';

    /* 2. Force reflow so the above takes effect before transitions fire */
    void newSlide.offsetWidth;

    /* 3. Kick outgoing slide into direction-aware exit */
    oldSlide.classList.remove('is-active');
    oldSlide.classList.add(dir === 'next' ? 'is-out-left' : 'is-out-right');
    oldSlide.setAttribute('aria-hidden', 'true');

    /* 4. Bring new slide in */
    newSlide.style.cssText = ''; /* clear inline → CSS .is-active takes over */
    newSlide.classList.add('is-active');
    newSlide.setAttribute('aria-hidden', 'false');

    /* 5. Clean up after animation finishes */
    setTimeout(function () {
      oldSlide.classList.remove('is-out-left', 'is-out-right');
      oldSlide.style.cssText = '';
      locked = false;
    }, DUR + 60);

    /* ── Dot icon cross-fade ── */
    var oldDot = DOT_ICONS[from];
    var newDot = DOT_ICONS[next];
    if (oldDot) oldDot.classList.remove('is-visible');
    /* Tiny delay so old icon fades before new pops in */
    setTimeout(function () {
      if (newDot) newDot.classList.add('is-visible');
    }, 70);

    /* ── Info cross-fade ── */
    var oldInfo = INFO_ITEMS[from];
    var newInfo = INFO_ITEMS[next];
    if (oldInfo) {
      oldInfo.classList.remove('is-active');
      oldInfo.setAttribute('aria-hidden', 'true');
    }
    if (newInfo) {
      newInfo.classList.add('is-active');
      newInfo.setAttribute('aria-hidden', 'false');
    }
  }

  /* ── Button handlers ── */
  PREV_BTN && PREV_BTN.addEventListener('click', function () { go(current - 1, 'prev'); });
  NEXT_BTN && NEXT_BTN.addEventListener('click', function () { go(current + 1, 'next'); });

  /* ── Touch / swipe ── */
  var tx = 0, ty = 0;
  STAGE.addEventListener('touchstart', function (e) {
    tx = e.changedTouches[0].clientX;
    ty = e.changedTouches[0].clientY;
  }, { passive: true });
  STAGE.addEventListener('touchend', function (e) {
    var dx = e.changedTouches[0].clientX - tx;
    var dy = e.changedTouches[0].clientY - ty;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 38) {
      go(dx < 0 ? current + 1 : current - 1, dx < 0 ? 'next' : 'prev');
    }
  }, { passive: true });

  /* ── Keyboard ── */
  ROOT.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  go(current - 1, 'prev');
    if (e.key === 'ArrowRight') go(current + 1, 'next');
  });

  /*
    ── Auto height lock ──────────────────────────────
    Measures the natural height of the tallest slide (by
    briefly making each one position:relative) and hard-sets
    the stage height. This eliminates ANY layout shift regardless
    of image load timing.
  */
  function lockHeight() {
    if (!STAGE) return;
    var max = 0;
    SLIDES.forEach(function (s) {
      var saved = s.style.cssText;
      s.style.cssText = [
        'position:relative',
        'opacity:0',
        'visibility:visible',
        'transform:none',
        'pointer-events:none',
        'transition:none',
        'z-index:-1'
      ].join('!important;') + '!important;';
      var h = s.offsetHeight;
      s.style.cssText = saved;
      if (h > max) max = h;
    });
    if (max > 20) STAGE.style.height = max + 'px';
  }

  if (document.readyState === 'complete') {
    lockHeight();
  } else {
    window.addEventListener('load', lockHeight);
  }

  var _resizeT;
  window.addEventListener('resize', function () {
    clearTimeout(_resizeT);
    _resizeT = setTimeout(lockHeight, 140);
  });

})();
</script>

