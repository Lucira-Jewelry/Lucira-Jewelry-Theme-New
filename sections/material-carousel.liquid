<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Materials Carousel – cylindrical 5‑panel · inspired by image</title>
  <style>
    /* === base reset / mini setup (only to demonstrate) === */
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #d9d2c5;  /* warm neutral to match image mood */
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 1rem;
    }
    /* === image reference preview – small hint (not part of carousel) === */
    .ref-note {
      position: fixed;
      top: 8px; left: 12px;
      background: rgba(0,0,0,0.5);
      color: white;
      padding: 6px 14px;
      border-radius: 40px;
      font-size: 13px;
      letter-spacing: 0.3px;
      backdrop-filter: blur(4px);
      z-index: 999;
    }
    /* ========== MATERIALS CAROUSEL (ms-) – UPDATED CYLINDRICAL 5-PANEL ========== */
    [data-ms-section] {
      --ms-bg:        #f0eeea;        /* soft linen */
      --ms-arch-bg:   #e3dfd8;        /* slightly deeper for arch */
      --ms-panel-bg:  #ffffff;
      --ms-border:    #d4d0c9;        /* warm border */
      --ms-shad-c:    0 12px 28px rgba(0,0,0,0.12);
      --ms-shad-s:    0 4px 14px rgba(0,0,0,0.08);
      --ms-title-clr: #2a241e;
      --ms-text-clr:  #5f5b55;
      --ms-btn-bg:    #8c6464;        /* theme from image – muted clay */
      --ms-btn-hov:   #7a5555;
      --ms-dot-sz:    56px;
      --ms-arrow-sz:  38px;
      --ms-ease:      cubic-bezier(0.25, 0.46, 0.45, 0.94);
      --ms-dur:       520ms;
      --ms-stage-h:   400px;           /* slightly taller for dramatic curve */

      background: var(--ms-bg);
      padding: 60px 0 56px;
      overflow: hidden;
      font-family: 'Inter', sans-serif;
      isolation: isolate;
      width: 100%;
      border-radius: 0;                /* clean, like reference */
      box-shadow: none;
    }

    [data-ms-section] *,
    [data-ms-section] *::before,
    [data-ms-section] *::after { box-sizing: border-box; }

    [data-ms-section] a          { text-decoration: none; }
    [data-ms-section] img        { display: block; width: 100%; height: 100%; object-fit: cover; }
    [data-ms-section] button     { appearance: none; border: none; background: none; cursor: pointer; font-family: inherit; }

    /* --- inner container --- */
    [data-ms-section] .ms-inner {
      max-width: 1440px;
      margin: 0 auto;
      padding: 0 24px;
      text-align: center;
    }

    /* --- header exactly as image: minimal, all caps, spaced --- */
    [data-ms-section] .ms-head { margin-bottom: 44px; }
    [data-ms-section] .ms-head__title {
      font-size: 26px;
      font-weight: 400;
      letter-spacing: 8px;
      text-transform: uppercase;
      color: #2a241e;
      margin-bottom: 22px;
      word-spacing: 2px;
    }
    [data-ms-section] .ms-head__subtitle {
      font-size: 15px;
      color: #6b625a;
      line-height: 1.7;
      max-width: 600px;
      margin: 0 auto;
      font-weight: 350;
    }

    /* --- stage background arch (soft, low) --- */
    [data-ms-section] .ms-stage-wrap { position: relative; }
    [data-ms-section] .ms-stage-wrap::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 100%;
      height: 82%;
      background: #e8e2da;   /* warm arch like image */
      border-radius: 50% 50% 0 0 / 22% 22% 0 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.9;
    }

    [data-ms-section] .ms-stage {
      position: relative;
      height: var(--ms-stage-h);
      z-index: 2;
    }

    /* slides stacked */
    [data-ms-section] .ms-slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateX(30px);
      transition: opacity var(--ms-dur) var(--ms-ease),
                  transform var(--ms-dur) var(--ms-ease),
                  visibility 0s linear var(--ms-dur);
      will-change: opacity, transform;
    }
    [data-ms-section] .ms-slide.is-active {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateX(0);
      z-index: 3;
      transition: opacity var(--ms-dur) var(--ms-ease),
                  transform var(--ms-dur) var(--ms-ease),
                  visibility 0s linear 0s;
    }
    [data-ms-section] .ms-slide.is-out-left {
      opacity: 0;
      transform: translateX(-30px);
      transition: opacity var(--ms-dur) var(--ms-ease),
                  transform var(--ms-dur) var(--ms-ease);
    }
    [data-ms-section] .ms-slide.is-out-right {
      opacity: 0;
      transform: translateX(30px);
      transition: opacity var(--ms-dur) var(--ms-ease),
                  transform var(--ms-dur) var(--ms-ease);
    }

    /* ===== 5-PANEL DESKTOP – CYLINDRICAL inspired by image ===== */
    [data-ms-section] .ms-panels--5 {
      display: flex;
      align-items: center;        /* vertical align */
      height: 100%;
      gap: 6px;
      padding: 0 2%;
    }

    /* base panel */
    [data-ms-section] .ms-panel {
      flex: 1;
      background: white;
      border: 1px solid #dbd5cd;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      height: 86%;                /* not full height – creates floating cylinders */
      transition: all var(--ms-dur) var(--ms-ease);
      box-shadow: 0 8px 20px -6px rgba(0,0,0,0.08);
    }

    /* CYLINDRICAL MAPPING – EXACT IMAGE MOOD */
    [data-ms-section] .ms-panel--far-left {
      border-radius: 32px 0 0 32px;
      transform: perspective(1400px) rotateY(42deg) scale(0.98) translateX(12px);
      transform-origin: right center;
      opacity: 0.7;
      z-index: 1;
      flex: 1.2;
      border-right: none;
      filter: brightness(0.98);
    }

    [data-ms-section] .ms-panel--left {
      border-radius: 20px 0 0 20px;
      transform: perspective(1400px) rotateY(28deg) scaleY(0.96) scaleX(0.98) translateX(4px);
      transform-origin: right center;
      opacity: 0.9;
      z-index: 2;
      border-right: none;
      box-shadow: 0 10px 18px -6px rgba(0,0,0,0.12);
    }

    [data-ms-section] .ms-panel--center {
      z-index: 5;
      border-radius: 24px;
      box-shadow: var(--ms-shad-c);
      flex: 1.7;
      transform: scale(1.0) translateY(-2px);
      border: 1px solid #cbc3ba;
      background: white;
      height: 94%;
    }

    [data-ms-section] .ms-panel--right {
      border-radius: 0 20px 20px 0;
      transform: perspective(1400px) rotateY(-28deg) scaleY(0.96) scaleX(0.98) translateX(-4px);
      transform-origin: left center;
      opacity: 0.9;
      z-index: 2;
      border-left: none;
    }

    [data-ms-section] .ms-panel--far-right {
      border-radius: 0 32px 32px 0;
      transform: perspective(1400px) rotateY(-42deg) scale(0.98) translateX(-12px);
      transform-origin: left center;
      opacity: 0.7;
      z-index: 1;
      flex: 1.2;
      border-left: none;
      filter: brightness(0.98);
    }

    /* images inside panels – contain to avoid cropping, like product shots */
    [data-ms-section] .ms-panel__img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 16px 8px;
      background: white;
    }

    /* mobile panel (hidden on desktop) */
    [data-ms-section] .ms-mobile-panel { display: none; }

    /* controls exactly as original but refined */
    [data-ms-section] .ms-controls {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 22px;
      margin: 36px 0 8px;
      position: relative;
      z-index: 10;
    }

    [data-ms-section] .ms-arrow {
      width: var(--ms-arrow-sz);
      height: var(--ms-arrow-sz);
      border: 1.5px solid #b9b2a9 !important;
      border-radius: 50%;
      background: transparent !important;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #4a423c;
      transition: all 0.2s ease;
    }
    [data-ms-section] .ms-arrow:hover {
      border-color: #6b5f56 !important;
      background: rgba(128, 115, 105, 0.06) !important;
      transform: scale(1.05);
    }
    [data-ms-section] .ms-arrow:active { transform: scale(0.92); }

    /* dot display – round selector */
    [data-ms-section] .ms-dot-display {
      position: relative;
      width: var(--ms-dot-sz);
      height: var(--ms-dot-sz);
      flex-shrink: 0;
      border-radius: 50%;
      box-shadow: 0 0 0 2.8px #342e28;
      background: #ece6df;
    }
    [data-ms-section] .ms-dot-icon {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      overflow: hidden;
      opacity: 0;
      transform: scale(0.5) rotate(-25deg);
      pointer-events: none;
      transition: opacity 0.32s var(--ms-ease), transform 0.32s var(--ms-ease);
    }
    [data-ms-section] .ms-dot-icon.is-visible {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
    [data-ms-section] .ms-dot-icon__img {
      width: 100%; height: 100%; object-fit: cover;
    }
    [data-ms-section] .ms-dot-icon__swatch {
      display: block; width: 100%; height: 100%; border-radius: 50%;
    }

    /* info panel – stacked exactly like original */
    [data-ms-section] .ms-info-wrap {
      position: relative;
      min-height: 170px;
      margin-top: 28px;
    }
    [data-ms-section] .ms-info-item {
      position: absolute;
      inset: 0;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(12px);
      transition: opacity 0.35s var(--ms-ease), transform 0.35s var(--ms-ease), visibility 0s linear 0.35s;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
    [data-ms-section] .ms-info-item.is-active {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateY(0);
      transition: opacity 0.35s var(--ms-ease) 0.1s, transform 0.35s var(--ms-ease) 0.1s, visibility 0s linear 0s;
    }
    [data-ms-section] .ms-info-item__name {
      font-size: 20px;
      font-weight: 400;
      letter-spacing: 4.5px;
      text-transform: uppercase;
      color: #302923;
    }
    [data-ms-section] .ms-info-item__desc {
      font-size: 14.5px;
      color: #5e554d;
      line-height: 1.7;
      max-width: 520px;
      margin: 0 auto;
    }
    [data-ms-section] .ms-info-item__btn {
      display: inline-block;
      padding: 14px 44px;
      background: var(--ms-btn-bg);
      color: white;
      font-size: 11px;
      letter-spacing: 3.4px;
      text-transform: uppercase;
      transition: background 0.2s, transform 0.15s;
      margin-top: 10px;
      border-radius: 0;   /* sharp edges like reference */
      font-weight: 500;
    }
    [data-ms-section] .ms-info-item__btn:hover {
      background: #735b5b;
    }

    /* responsive */
    @media screen and (max-width: 767px) {
      [data-ms-section] { --ms-stage-h: 300px; padding: 40px 0; }
      [data-ms-section] .ms-panels--5 { display: none !important; }
      [data-ms-section] .ms-mobile-panel {
        display: flex;
        height: 100%;
        background: white;
        border: 1px solid #ddd6cf;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 8px 18px rgba(0,0,0,0.1);
      }
      [data-ms-section] .ms-stage-wrap::before { height: 76%; border-radius: 50% 50% 0 0 / 14% 14% 0 0; }
      [data-ms-section] .ms-head__title { font-size: 19px; letter-spacing: 5px; }
    }

    [data-ms-section][data-ms-total="1"] .ms-controls { display: none; }
  </style>
</head>
