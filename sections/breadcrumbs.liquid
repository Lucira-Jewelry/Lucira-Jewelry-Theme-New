{% schema %}
{
  "name": "Breadcrumb",
  "settings": [
    {
      "type": "text",
      "id": "custom_class",
      "label": "Breadcrumb Section",
      "default": "breadcrumb-section"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide Breadcrumb on Mobile",
      "default": false
    }
  ],
  "presets": [
    { "name": "Breadcrumb" }
  ]
}
{% endschema %}


{%- unless template == 'index' or template == 'cart' or template == 'list-collections' or template == '404' -%}
{%- assign t = template | split: '.' | first -%}


<div class="breadcrum_style {% if section.settings.hide_on_mobile %}hide-mobile{% endif %}">
  <nav class="breadcrumbs page-width" role="navigation" aria-label="breadcrumbs" 
       itemscope itemtype="https://schema.org/BreadcrumbList">
    <ol class="breadcrumbs__list">

      <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <a class="breadcrumbs__link" href="/" itemprop="item">
          <span itemprop="name">Home</span>
        </a>
        <meta itemprop="position" content="1" />
      </li>

      {%- assign position = 2 -%}

      {%- case t -%}

        {%- when 'page' -%}
          <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a class="breadcrumbs__link" href="{{ page.url }}" itemprop="item" aria-current="page">
              <span itemprop="name">{{ page.title }}</span>
            </a>
            <meta itemprop="position" content="{{ position }}" />
          </li>

        {%- when 'product' -%}
          {%- if collection.url -%}
            <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a class="breadcrumbs__link" href="{{ collection.url }}" itemprop="item">
                <span itemprop="name">{{ collection.title }}</span>
              </a>
              <meta itemprop="position" content="{{ position }}" />
            </li>
            {%- assign position = position | plus: 1 -%}
          {%- endif -%}
          <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a class="breadcrumbs__link" href="{{ product.url }}" itemprop="item" aria-current="page">
              <span itemprop="name">{{ product.title }}</span>
            </a>
            <meta itemprop="position" content="{{ position }}" />
          </li>

        {%- when 'collection' and collection.handle -%}
          <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a class="breadcrumbs__link" href="{{ collection.url }}" itemprop="item">
              <span itemprop="name">{{ collection.title }}</span>
            </a>
            <meta itemprop="position" content="{{ position }}" />
          </li>
          {%- assign position = position | plus: 1 -%}
          {%- if current_tags -%}
            <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a class="breadcrumbs__link" href="{{ collection.url }}/{{ current_tags | join: '+' }}" itemprop="item" aria-current="page">
                <span itemprop="name">{{ current_tags | join: " + " }}</span>
              </a>
              <meta itemprop="position" content="{{ position }}" />
            </li>
          {%- endif -%}

        {%- when 'blog' -%}
          <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a class="breadcrumbs__link" href="{{ blog.url }}" itemprop="item">
              <span itemprop="name">{{ blog.title }}</span>
            </a>
            <meta itemprop="position" content="{{ position }}" />
          </li>
          {%- assign position = position | plus: 1 -%}
          {%- if current_tags -%}
            <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a class="breadcrumbs__link" href="{{ blog.url }}/tagged/{{ current_tags | join: '+' }}" itemprop="item" aria-current="page">
                <span itemprop="name">{{ current_tags | join: " + " }}</span>
              </a>
              <meta itemprop="position" content="{{ position }}" />
            </li>
          {%- endif -%}

        {%- when 'article' -%}
          <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a class="breadcrumbs__link" href="{{ blog.url }}" itemprop="item">
              <span itemprop="name">{{ blog.title }}</span>
            </a>
            <meta itemprop="position" content="{{ position }}" />
          </li>
          {%- assign position = position | plus: 1 -%}
          <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a class="breadcrumbs__link" href="{{ article.url }}" itemprop="item" aria-current="page">
              <span itemprop="name">{{ article.title }}</span>
            </a>
            <meta itemprop="position" content="{{ position }}" />
          </li>

        {%- else -%}
          <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a class="breadcrumbs__link" href="{{ request.path }}" itemprop="item" aria-current="page">
              <span itemprop="name">{{ page_title }}</span>
            </a>
            <meta itemprop="position" content="{{ position }}" />
          </li>
      {%- endcase -%}
    </ol>
  </nav>

</div>

{%- endunless -%}