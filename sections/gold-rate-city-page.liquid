  }

  .gold-rate-page__table-richtext thead,
  .gold-rate-page__table thead {
    background: #fcfbf7;
  }

  .gold-rate-page__table-richtext th,
  .gold-rate-page__table th {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: rgba(25, 25, 25, 0.7);
    padding: 0.9rem 1rem;
