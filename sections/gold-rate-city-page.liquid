{% liquid
  assign city = page.metafields.custom.gold_rate_city.value
  assign city_slug = ''

  if city != blank and city.slug != blank
    assign city_slug = city.slug
  elsif page.metafields.custom.city_name != blank
    assign city_slug = page.metafields.custom.city_name | handleize
  elsif page.handle contains '-gold-rate-today'
    assign city_slug = page.handle | remove: '-gold-rate-today'
  elsif page.handle contains '-gold-rate'
    assign city_slug = page.handle | remove: '-gold-rate'
  endif

  if city == blank and city_slug != blank
    assign city = shop.metaobjects.gold_rate_city.values | where: 'slug', city_slug | first
  endif

  if city == blank and page.metafields.custom.city.value and page.metafields.custom.city.value.hero_title != blank
    assign city = page.metafields.custom.city.value
  endif

  assign global_rates = shop.metaobjects.gold_rates_global.values | first
  if global_rates == blank
    assign global_rates = shop.metaobjects.gold_rates_global['gold-rates']
  endif
  if global_rates == blank
    assign global_rates = shop.metaobjects.gold_rates_global.values | where: 'handle', 'gold-rates' | first
  endif

  assign content_order = 'gold-purity,difference-22k-24k,investment-guide,buying-guide,historic-price-trends,factors-affecting-gold-prices,factors-affecting-gold-price,gold-forecast,gold-price-forecast,hallmark-guide' | split: ','
  assign table_order = 'todays-rate,weekly-trend,monthly-trend,historic-rate,forecast-table,city-comparison' | split: ','

  assign city_name = city.city_name | default: page.title | default: 'Gold Rate'
  assign city_state = city.state | default: ''
  assign hero_title = city.hero_title
  if hero_title == blank
    assign hero_title = "Today's Gold Rate in " | append: city_name
  endif
  assign hero_subtitle = city.hero_subtitle | default: 'Live gold prices'
  assign hero_description = city.hero_description
  assign city_intro = city.city_intro
  assign investment_text = city.investment_text
  assign hero_image = city.hero_image.value | default: city.hero_image
  assign seo_title = city.seo_title | strip
  assign seo_description = city.seo_description | strip

  assign rate_24k = global_rates.rate_24k | plus: 0
  assign rate_22k = global_rates.rate_22k | plus: 0
  assign rate_18k = global_rates.rate_18k | plus: 0
  assign rate_14k = global_rates.rate_14k | plus: 0
  assign updated_at = global_rates.updated_at

  assign rate_24k_display = rate_24k | round
  assign rate_22k_display = rate_22k | round
  assign rate_18k_display = rate_18k | round
  assign rate_14k_display = rate_14k | round

  assign rate_24k_8g = rate_24k | times: 8
  assign rate_24k_10g = rate_24k | times: 10
  assign rate_24k_100g = rate_24k | times: 100
  assign rate_22k_8g = rate_22k | times: 8
  assign rate_22k_10g = rate_22k | times: 10
  assign rate_22k_100g = rate_22k | times: 100
  assign rate_18k_8g = rate_18k | times: 8
  assign rate_18k_10g = rate_18k | times: 10
  assign rate_18k_100g = rate_18k | times: 100
  assign rate_14k_8g = rate_14k | times: 8
  assign rate_14k_10g = rate_14k | times: 10
  assign rate_14k_100g = rate_14k | times: 100

  assign rate_24k_8g = rate_24k_8g | round
  assign rate_24k_10g = rate_24k_10g | round
  assign rate_24k_100g = rate_24k_100g | round
  assign rate_22k_8g = rate_22k_8g | round
  assign rate_22k_10g = rate_22k_10g | round
  assign rate_22k_100g = rate_22k_100g | round
  assign rate_18k_8g = rate_18k_8g | round
  assign rate_18k_10g = rate_18k_10g | round
  assign rate_18k_100g = rate_18k_100g | round
  assign rate_14k_8g = rate_14k_8g | round
  assign rate_14k_10g = rate_14k_10g | round
  assign rate_14k_100g = rate_14k_100g | round

  assign faq_list = city.faq.value
  if faq_list == blank
    assign faq_list = city.faq_reference.value
  endif

  assign content_blocks = city.content_blocks.value
  if content_blocks == blank
    assign content_blocks = city.content_block_reference.value
  endif

  assign table_blocks = city.table_reference.value
  if table_blocks == blank
    assign table_blocks = city.tables.value
  endif
%}

<section class="gold-rate-page">
  {% if city == blank %}
    <div class="page-width gold-rate-page__empty">
      <h1>Gold Rate Page</h1>
      <p>Connect a `gold_rate_city` metaobject to this page with the `custom.gold_rate_city` metafield.</p>
    </div>
  {% else %}
    <div class="gold-rate-page__hero">
      <div class="page-width gold-rate-page__hero-grid">
        <div class="gold-rate-page__hero-copy">
          <p class="gold-rate-page__eyebrow">
            {{ hero_subtitle }}
            {% if city_state != blank %}
              <span class="gold-rate-page__eyebrow-sep">|</span>
              {{ city_state }}
            {% endif %}
          </p>
          <h1 class="gold-rate-page__title">{{ hero_title }}</h1>
          {% if hero_description != blank %}
            <div class="gold-rate-page__richtext">{{ hero_description | metafield_tag }}</div>
          {% endif %}
          {% if city_intro != blank %}
            <div class="gold-rate-page__intro">{{ city_intro | metafield_tag }}</div>
          {% endif %}

          <div class="gold-rate-page__hero-stats" aria-label="Global gold rates">
            <div class="gold-rate-page__stat">
              <span class="gold-rate-page__stat-label">24K</span>
              <span class="gold-rate-page__stat-value">&#8377;{{ rate_24k_display }}</span>
            </div>
            <div class="gold-rate-page__stat">
              <span class="gold-rate-page__stat-label">22K</span>
              <span class="gold-rate-page__stat-value">&#8377;{{ rate_22k_display }}</span>
            </div>
            <div class="gold-rate-page__stat">
              <span class="gold-rate-page__stat-label">18K</span>
              <span class="gold-rate-page__stat-value">&#8377;{{ rate_18k_display }}</span>
            </div>
            <div class="gold-rate-page__stat">
              <span class="gold-rate-page__stat-label">14K</span>
              <span class="gold-rate-page__stat-value">&#8377;{{ rate_14k_display }}</span>
            </div>
          </div>

          {% if updated_at != blank %}
            <p class="gold-rate-page__updated">Updated {{ updated_at | date: '%d %B %Y' }}</p>
          {% endif %}
        </div>

        <div class="gold-rate-page__hero-media">
          {% if hero_image != blank %}
            <img
              class="gold-rate-page__hero-image"
              src="{{ hero_image | image_url: width: 1400 }}"
              alt="{{ city_name | escape }}"
              loading="eager"
              width="1400"
              height="1050"
            >
          {% else %}
            <div class="gold-rate-page__hero-fallback">
              <span>{{ city_name }}</span>
            </div>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="gold-rate-page__band">
      <div class="page-width">
        <div class="gold-rate-page__section-head">
          <h2>Today's Gold Rate Table</h2>
          <p>Global rates are sourced from one shared `gold_rates_global` entry and reused on every city page.</p>
        </div>

        <div class="gold-rate-page__table-wrap">
          <table class="gold-rate-page__table">
            <thead>
              <tr>
                <th scope="col">Karat</th>
                <th scope="col">Per Gram</th>
                <th scope="col">8 Gram</th>
                <th scope="col">10 Gram</th>
                <th scope="col">100 Gram</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row">24K</th>
                <td>&#8377;{{ rate_24k_display }}</td>
                <td>&#8377;{{ rate_24k_8g }}</td>
                <td>&#8377;{{ rate_24k_10g }}</td>
                <td>&#8377;{{ rate_24k_100g }}</td>
              </tr>
              <tr>
                <th scope="row">22K</th>
                <td>&#8377;{{ rate_22k_display }}</td>
                <td>&#8377;{{ rate_22k_8g }}</td>
                <td>&#8377;{{ rate_22k_10g }}</td>
                <td>&#8377;{{ rate_22k_100g }}</td>
              </tr>
              <tr>
                <th scope="row">18K</th>
                <td>&#8377;{{ rate_18k_display }}</td>
                <td>&#8377;{{ rate_18k_8g }}</td>
                <td>&#8377;{{ rate_18k_10g }}</td>
                <td>&#8377;{{ rate_18k_100g }}</td>
              </tr>
              <tr>
                <th scope="row">14K</th>
                <td>&#8377;{{ rate_14k_display }}</td>
                <td>&#8377;{{ rate_14k_8g }}</td>
                <td>&#8377;{{ rate_14k_10g }}</td>
                <td>&#8377;{{ rate_14k_100g }}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    {% assign gold_purity_block = content_blocks | where: 'slug', 'gold-purity' | first %}
    {% assign difference_block = content_blocks | where: 'slug', 'difference-22k-24k' | first %}
    {% assign investment_block = content_blocks | where: 'slug', 'investment-guide' | first %}
    {% assign historic_content_block = content_blocks | where: 'slug', 'historic-price-trends' | first %}
    {% if historic_content_block == blank %}
      {% assign historic_content_block = content_blocks | where: 'slug', 'historic-price-trends' | first %}
    {% endif %}
    {% assign factors_block = content_blocks | where: 'slug', 'factors-affecting-gold-prices' | first %}
    {% if factors_block == blank %}
      {% assign factors_block = content_blocks | where: 'slug', 'factors-affecting-gold-price' | first %}
    {% endif %}
    {% assign forecast_block = content_blocks | where: 'slug', 'gold-forecast' | first %}
    {% if forecast_block == blank %}
      {% assign forecast_block = content_blocks | where: 'slug', 'gold-price-forecast' | first %}
    {% endif %}

    {% assign historic_rate_table = table_blocks | where: 'table_slug', 'historic-rate' | first %}
    {% assign forecast_table = table_blocks | where: 'table_slug', 'forecast-table' | first %}
    {% assign monthly_trend_table = table_blocks | where: 'table_slug', 'monthly-trend' | first %}
    {% assign weekly_trend_table = table_blocks | where: 'table_slug', 'weekly-trend' | first %}
    {% assign city_comparison_table = table_blocks | where: 'table_slug', 'city-comparison' | first %}

    {% assign faq_json = '' %}
    {% if faq_list != blank %}
      {% for faq in faq_list %}
        {% if faq != blank %}
          {% capture faq_entry %}
            {
              "@type": "Question",
              "name": {{ faq.question | strip_html | json }},
              "acceptedAnswer": {
                "@type": "Answer",
                "text": {{ faq.answer | strip_html | json }}
              }
            }
          {% endcapture %}
          {% if faq_json == blank %}
            {% assign faq_json = faq_entry | strip %}
          {% else %}
            {% assign faq_json = faq_json | append: ',' | append: faq_entry | strip %}
          {% endif %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% if gold_purity_block != blank %}
      <div class="gold-rate-page__band">
        <div class="page-width gold-rate-page__copy-block" id="gold-purity">
          <h2>{{ gold_purity_block.heading | default: gold_purity_block.title }}</h2>
          <div class="gold-rate-page__richtext">{{ gold_purity_block.content | metafield_tag }}</div>
        </div>
      </div>
    {% endif %}

    {% assign table_24k_title = '24 Carat Gold Rate in ' | append: city_name | append: ' Today' %}
    {% assign table_22k_title = '22 Carat Gold Rate in ' | append: city_name | append: ' Today' %}
    {% assign table_18k_title = '18 Carat Gold Rate in ' | append: city_name | append: ' Today' %}
    {% assign table_14k_title = '14 Carat Gold Rate in ' | append: city_name | append: ' Today' %}
    {% assign table_24k_column = '24K Gold Price in ' | append: city_name %}
    {% assign table_22k_column = '22K Gold Price in ' | append: city_name %}
    {% assign table_18k_column = '18K Gold Price in ' | append: city_name %}
    {% assign table_14k_column = '14K Gold Price in ' | append: city_name %}

    {% render 'gold-rate-weight-table',
      table_id: '24k-rate-table',
      table_title: table_24k_title,
      table_description: '24 Carat gold (99.9% purity) is the purest form of gold available and commands the highest price. It is commonly used in gold coins, bars, and digital gold investments.',
      rate_value: rate_24k,
      row_labels: '1 gram|2 grams|5 grams|8 grams (Tola)|10 grams|20 grams|50 grams|100 grams|1 kilogram',
      row_multipliers: '1|2|5|8|10|20|50|100|1000',
      row_suffixes: '| | | | | | | |',
      column_label: table_24k_column
    %}

    {% render 'gold-rate-weight-table',
      table_id: '22k-rate-table',
      table_title: table_22k_title,
      table_description: '22 Carat gold (91.6% purity) is the most widely used gold for jewellery in India and is popular for traditional pieces.',
      rate_value: rate_22k,
      row_labels: '1 gram|2 grams|5 grams|8 grams (Tola)|10 grams|20 grams|50 grams|100 grams|1 kilogram',
      row_multipliers: '1|2|5|8|10|20|50|100|1000',
      row_suffixes: '| | | | | | | |',
      column_label: table_22k_column
    %}

    {% render 'gold-rate-weight-table',
      table_id: '18k-rate-table',
      table_title: table_18k_title,
      table_description: '18 Carat gold (75% purity) is popular for diamond jewellery, modern designs, and lightweight daily-wear pieces.',
      rate_value: rate_18k,
      row_labels: '1 gram|5 grams|8 grams|10 grams|20 grams|100 grams',
      row_multipliers: '1|5|8|10|20|100',
      row_suffixes: '| | | | |',
      column_label: table_18k_column
    %}

    {% render 'gold-rate-weight-table',
      table_id: '14k-rate-table',
      table_title: table_14k_title,
      table_description: '14 Carat gold (58.5% purity) is a practical choice for lightweight and contemporary jewellery.',
      rate_value: rate_14k,
      row_labels: '1 gram|10 grams|100 grams',
      row_multipliers: '1|10|100',
      row_suffixes: '||',
      column_label: table_14k_column
    %}

    <div class="gold-rate-page__band">
      <div class="page-width gold-rate-page__copy-block" id="gold-purity-comparison">
        <h2>Gold Karat Purity Comparison - {{ city_name }} Buying Guide</h2>
        <div class="gold-rate-page__table-wrap">
          <table class="gold-rate-page__table">
            <thead>
              <tr>
                <th scope="col">Karat</th>
                <th scope="col">Purity</th>
                <th scope="col">Hallmark</th>
                <th scope="col">Best For</th>
                <th scope="col">Relative Price</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row">24K</th>
                <td>99.9%</td>
                <td>999</td>
                <td>Investment, coins, bars</td>
                <td>Highest</td>
              </tr>
              <tr>
                <th scope="row">22K</th>
                <td>91.6%</td>
                <td>916</td>
                <td>Traditional jewellery</td>
                <td>High</td>
              </tr>
              <tr>
                <th scope="row">18K</th>
                <td>75%</td>
                <td>750</td>
                <td>Diamond jewellery, modern designs</td>
                <td>Moderate</td>
              </tr>
              <tr>
                <th scope="row">14K</th>
                <td>58.5%</td>
                <td>585</td>
                <td>Lightweight, fashion jewellery</td>
                <td>Lower</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    {% if difference_block != blank %}
      <div class="gold-rate-page__band">
        <div class="page-width gold-rate-page__copy-block" id="difference-22k-24k">
          <h2>{{ difference_block.heading | default: difference_block.title }}</h2>
          <div class="gold-rate-page__richtext">{{ difference_block.content | metafield_tag }}</div>
        </div>
      </div>
    {% endif %}

    {% if investment_block != blank or investment_text != blank %}
      <div class="gold-rate-page__band gold-rate-page__band--subtle">
        <div class="page-width gold-rate-page__copy-block" id="investment-guide">
          <h2>{% if investment_block != blank %}{{ investment_block.heading | default: investment_block.title }}{% else %}Investment Guide{% endif %}</h2>
          {% if investment_block != blank %}
            <div class="gold-rate-page__richtext">{{ investment_block.content | metafield_tag }}</div>
          {% else %}
            <div class="gold-rate-page__richtext">{{ investment_text | metafield_tag }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if historic_content_block != blank %}
      <div class="gold-rate-page__band">
        <div class="page-width gold-rate-page__copy-block" id="historic-price-trends">
          <h2>{{ historic_content_block.heading | default: historic_content_block.title }}</h2>
          <div class="gold-rate-page__richtext">{{ historic_content_block.content | metafield_tag }}</div>
        </div>
      </div>
    {% endif %}

    {% if historic_rate_table != blank %}
      <div class="gold-rate-page__band gold-rate-page__band--table">
        <div class="page-width gold-rate-page__copy-block" id="historic-rate">
          <h2>{{ historic_rate_table.table_title }}</h2>
          {% if historic_rate_table.table_description != blank %}
            <p class="gold-rate-page__table-description">{{ historic_rate_table.table_description }}</p>
          {% endif %}
          {% assign historic_table_html = historic_rate_table.table_content %}
          {% if historic_table_html == blank %}
            {% assign historic_table_html = historic_rate_table.table_data %}
          {% endif %}
          {% if historic_table_html == blank %}
            {% assign historic_table_html = historic_rate_table.content %}
          {% endif %}
          {% if historic_table_html != blank and historic_table_html contains '<table' %}
            <div class="gold-rate-page__richtext gold-rate-page__table-richtext">{{ historic_table_html | metafield_tag }}</div>
          {% else %}
            <div class="gold-rate-page__table-wrap">
              <table class="gold-rate-page__table">
                <thead>
                  <tr>
                    <th scope="col">Month</th>
                    <th scope="col">22K</th>
                    <th scope="col">24K</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th scope="row">Current</th>
                    <td>&#8377;{{ rate_22k_display }}</td>
                    <td>&#8377;{{ rate_24k_display }}</td>
                  </tr>
                </tbody>
              </table>
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if factors_block != blank %}
      <div class="gold-rate-page__band">
        <div class="page-width gold-rate-page__copy-block" id="factors-affecting-gold-prices">
          <h2>{{ factors_block.heading | default: factors_block.title }}</h2>
          <div class="gold-rate-page__richtext">{{ factors_block.content | metafield_tag }}</div>
        </div>
      </div>
    {% endif %}

    {% if forecast_block != blank %}
      <div class="gold-rate-page__band">
        <div class="page-width gold-rate-page__copy-block" id="gold-forecast">
          <h2>{{ forecast_block.heading | default: forecast_block.title }}</h2>
          <div class="gold-rate-page__richtext">{{ forecast_block.content | metafield_tag }}</div>
        </div>
      </div>
    {% endif %}

    {% if forecast_table != blank %}
      <div class="gold-rate-page__band gold-rate-page__band--table">
        <div class="page-width gold-rate-page__copy-block" id="forecast-table">
          <h2>{{ forecast_table.table_title }}</h2>
          {% if forecast_table.table_description != blank %}
            <p class="gold-rate-page__table-description">{{ forecast_table.table_description }}</p>
          {% endif %}
          {% assign forecast_table_html = forecast_table.table_content %}
          {% if forecast_table_html == blank %}
            {% assign forecast_table_html = forecast_table.table_data %}
          {% endif %}
          {% if forecast_table_html == blank %}
            {% assign forecast_table_html = forecast_table.content %}
          {% endif %}
          {% if forecast_table_html != blank and forecast_table_html contains '<table' %}
            <div class="gold-rate-page__richtext gold-rate-page__table-richtext">{{ forecast_table_html | metafield_tag }}</div>
          {% else %}
            <div class="gold-rate-page__table-wrap">
              <table class="gold-rate-page__table">
                <thead>
                  <tr>
                    <th scope="col">Scenario</th>
                    <th scope="col">22K</th>
                    <th scope="col">24K</th>
                    <th scope="col">Note</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th scope="row">Today</th>
                    <td>&#8377;{{ rate_22k_display }}</td>
                    <td>&#8377;{{ rate_24k_display }}</td>
                    <td>Live rate</td>
                  </tr>
                  <tr>
                    <th scope="row">Near term</th>
                    <td>&#8212;</td>
                    <td>&#8212;</td>
                    <td>Populate via table metaobject</td>
                  </tr>
                </tbody>
              </table>
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if faq_json != blank %}
      <div class="gold-rate-page__band gold-rate-page__band--faq">
        <div class="page-width">
          <div class="gold-rate-page__section-head">
            <h2>FAQs</h2>
            <p>Reusable FAQ entries can be shared across all 1500+ city pages.</p>
          </div>

          <div class="gold-rate-page__faq-list" itemscope itemtype="https://schema.org/FAQPage">
            {% for faq in faq_list %}
              {% if faq != blank %}
                <details class="gold-rate-page__faq-item" itemprop="mainEntity" itemscope itemtype="https://schema.org/Question">
                  <summary class="gold-rate-page__faq-question" itemprop="name">{{ faq.question }}</summary>
                  <div class="gold-rate-page__faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                    <div itemprop="text">{{ faq.answer | metafield_tag }}</div>
                  </div>
                </details>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    {% endif %}

    {% if monthly_trend_table != blank %}
      <div class="gold-rate-page__band gold-rate-page__band--table">
        <div class="page-width gold-rate-page__copy-block" id="monthly-trend">
          <h2>{{ monthly_trend_table.table_title }}</h2>
          {% if monthly_trend_table.table_description != blank %}
            <p class="gold-rate-page__table-description">{{ monthly_trend_table.table_description }}</p>
          {% endif %}
          {% assign monthly_table_html = monthly_trend_table.table_content %}
          {% if monthly_table_html == blank %}
            {% assign monthly_table_html = monthly_trend_table.table_data %}
          {% endif %}
          {% if monthly_table_html == blank %}
            {% assign monthly_table_html = monthly_trend_table.content %}
          {% endif %}
          {% if monthly_table_html != blank and monthly_table_html contains '<table' %}
            <div class="gold-rate-page__richtext gold-rate-page__table-richtext">{{ monthly_table_html | metafield_tag }}</div>
          {% else %}
            <div class="gold-rate-page__table-wrap">
              <table class="gold-rate-page__table">
                <thead>
                  <tr>
                    <th scope="col">Month</th>
                    <th scope="col">22K Avg</th>
                    <th scope="col">24K Avg</th>
                    <th scope="col">Change</th>
                    <th scope="col">Trend</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th scope="row">Current month</th>
                    <td>&#8377;{{ rate_22k_display }}</td>
                    <td>&#8377;{{ rate_24k_display }}</td>
                    <td>&#8212;</td>
                    <td>Live</td>
                  </tr>
                </tbody>
              </table>
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if weekly_trend_table != blank %}
      <div class="gold-rate-page__band gold-rate-page__band--table">
        <div class="page-width gold-rate-page__copy-block" id="weekly-trend">
          <h2>{{ weekly_trend_table.table_title }}</h2>
          {% if weekly_trend_table.table_description != blank %}
            <p class="gold-rate-page__table-description">{{ weekly_trend_table.table_description }}</p>
          {% endif %}
          {% assign weekly_table_html = weekly_trend_table.table_content %}
          {% if weekly_table_html == blank %}
            {% assign weekly_table_html = weekly_trend_table.table_data %}
          {% endif %}
          {% if weekly_table_html == blank %}
            {% assign weekly_table_html = weekly_trend_table.content %}
          {% endif %}
          {% if weekly_table_html != blank and weekly_table_html contains '<table' %}
            <div class="gold-rate-page__richtext gold-rate-page__table-richtext">{{ weekly_table_html | metafield_tag }}</div>
          {% else %}
            <div class="gold-rate-page__table-wrap">
              <table class="gold-rate-page__table">
                <thead>
                  <tr>
                    <th scope="col">Date</th>
                    <th scope="col">22K</th>
                    <th scope="col">24K</th>
                    <th scope="col">Weekly change</th>
                    <th scope="col">Market note</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th scope="row">Today</th>
                    <td>&#8377;{{ rate_22k_display }}</td>
                    <td>&#8377;{{ rate_24k_display }}</td>
                    <td>&#8212;</td>
                    <td>Live</td>
                  </tr>
                </tbody>
              </table>
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if city_comparison_table != blank %}
      <div class="gold-rate-page__band gold-rate-page__band--table">
        <div class="page-width gold-rate-page__copy-block" id="city-comparison">
          <h2>{{ city_comparison_table.table_title }}</h2>
          {% if city_comparison_table.table_description != blank %}
            <p class="gold-rate-page__table-description">{{ city_comparison_table.table_description }}</p>
          {% endif %}
          {% assign city_table_html = city_comparison_table.table_content %}
          {% if city_table_html == blank %}
            {% assign city_table_html = city_comparison_table.table_data %}
          {% endif %}
          {% if city_table_html == blank %}
            {% assign city_table_html = city_comparison_table.content %}
          {% endif %}
          {% if city_table_html != blank and city_table_html contains '<table' %}
            <div class="gold-rate-page__richtext gold-rate-page__table-richtext">{{ city_table_html | metafield_tag }}</div>
          {% else %}
            <div class="gold-rate-page__table-wrap">
              <table class="gold-rate-page__table">
                <thead>
                  <tr>
                    <th scope="col">City</th>
                    <th scope="col">22K</th>
                    <th scope="col">24K</th>
                    <th scope="col">Note</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th scope="row">{{ city_name }}</th>
                    <td>&#8377;{{ rate_22k_display }}</td>
                    <td>&#8377;{{ rate_24k_display }}</td>
                    <td>Current market</td>
                  </tr>
                </tbody>
              </table>
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endif %}
</section>

{% if city != blank and faq_json != blank %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{{ faq_json }}]
    }
  </script>
{% endif %}

<style>
  .gold-rate-page {
    color: #191919;
    background: #fff;
  }

  .gold-rate-page__hero {
    padding: 3.5rem 0 2.25rem;
    background: linear-gradient(180deg, #faf7f0 0%, #fff 100%);
    border-bottom: 1px solid rgba(25, 25, 25, 0.08);
  }

  .gold-rate-page__hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: 2rem;
    align-items: center;
  }

  .gold-rate-page__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.82rem;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #6b5a2d;
  }

  .gold-rate-page__eyebrow-sep {
    margin: 0 0.5rem;
    color: rgba(25, 25, 25, 0.35);
  }

  .gold-rate-page__title {
    margin: 0;
    font-size: clamp(2rem, 3vw, 3.2rem);
    line-height: 1.05;
  }

  .gold-rate-page__richtext,
  .gold-rate-page__intro {
    margin-top: 1rem;
    font-size: 0.98rem;
    line-height: 1.7;
  }

  .gold-rate-page__intro {
    color: rgba(25, 25, 25, 0.8);
  }

  .gold-rate-page__hero-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .gold-rate-page__stat {
    padding: 0.9rem 1rem;
    border: 1px solid rgba(25, 25, 25, 0.12);
    border-radius: 8px;
    background: #fff;
  }

  .gold-rate-page__stat-label {
    display: block;
    font-size: 0.78rem;
    text-transform: uppercase;
    color: rgba(25, 25, 25, 0.58);
  }

  .gold-rate-page__stat-value {
    display: block;
    margin-top: 0.35rem;
    font-size: 1.15rem;
    font-weight: 700;
  }

  .gold-rate-page__updated {
    margin: 1rem 0 0;
    font-size: 0.9rem;
    color: rgba(25, 25, 25, 0.62);
  }

  .gold-rate-page__hero-media {
    min-height: 100%;
  }

  .gold-rate-page__hero-image,
  .gold-rate-page__hero-fallback {
    display: block;
    width: 100%;
    min-height: 420px;
    object-fit: cover;
    border-radius: 8px;
  }

  .gold-rate-page__hero-fallback {
    display: grid;
    place-items: center;
    background: #eee4cf;
    color: #5f4c20;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .gold-rate-page__band {
    padding: 2.4rem 0;
  }

  .gold-rate-page__band--subtle {
    background: #fcfbf7;
    border-top: 1px solid rgba(25, 25, 25, 0.06);
    border-bottom: 1px solid rgba(25, 25, 25, 0.06);
  }

  .gold-rate-page__band--faq {
    background: #fafafa;
    border-top: 1px solid rgba(25, 25, 25, 0.06);
    border-bottom: 1px solid rgba(25, 25, 25, 0.06);
  }

  .gold-rate-page__section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .gold-rate-page__section-head h2,
  .gold-rate-page__copy-block h2 {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.2;
  }

  .gold-rate-page__section-head p,
  .gold-rate-page__table-description {
    margin: 0;
    color: rgba(25, 25, 25, 0.72);
    max-width: 56ch;
  }

  .gold-rate-page__table-wrap {
    overflow-x: auto;
  }

  .gold-rate-page__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 680px;
  }

  .gold-rate-page__table th,
  .gold-rate-page__table td {
    padding: 0.95rem 1rem;
    border-bottom: 1px solid rgba(25, 25, 25, 0.1);
    text-align: left;
    white-space: nowrap;
  }

  .gold-rate-page__table thead th {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0;
    color: rgba(25, 25, 25, 0.58);
    background: #fcfbf7;
  }

  .gold-rate-page__table tbody th {
    font-weight: 600;
  }

  .gold-rate-page__copy-block {
    max-width: 78rem;
  }

  .gold-rate-page__faq-list {
    display: grid;
    gap: 0.75rem;
  }

  .gold-rate-page__faq-item {
    border: 1px solid rgba(25, 25, 25, 0.12);
    border-radius: 8px;
    background: #fff;
    overflow: hidden;
  }

  .gold-rate-page__faq-question {
    list-style: none;
    cursor: pointer;
    padding: 1rem 1.15rem;
    font-weight: 600;
  }

  .gold-rate-page__faq-question::-webkit-details-marker {
    display: none;
  }

  .gold-rate-page__faq-answer {
    padding: 0 1.15rem 1rem;
    color: rgba(25, 25, 25, 0.82);
  }

  .gold-rate-page__table-richtext table {
    width: 100%;
    border-collapse: collapse;
  }

  .gold-rate-page__table-richtext th,
  .gold-rate-page__table-richtext td {
    border: 1px solid rgba(25, 25, 25, 0.12);
    padding: 0.75rem 0.9rem;
    vertical-align: top;
  }

  .gold-rate-page__empty {
    padding: 3rem 0;
  }

  @media screen and (max-width: 990px) {
    .gold-rate-page__hero-grid {
      grid-template-columns: 1fr;
    }

    .gold-rate-page__hero-image,
    .gold-rate-page__hero-fallback {
      min-height: 320px;
    }

    .gold-rate-page__hero-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .gold-rate-page__section-head {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media screen and (max-width: 749px) {
    .gold-rate-page__hero {
      padding-top: 2rem;
    }

    .gold-rate-page__band {
      padding: 1.6rem 0;
    }

    .gold-rate-page__hero-stats {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

