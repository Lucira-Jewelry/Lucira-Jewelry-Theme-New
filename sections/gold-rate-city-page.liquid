    color: #191919;
  }

  .gold-rate-page__table tbody tr:hover {
    background: rgba(107, 90, 45, 0.03);
  }

  .gold-rate-page__copy-block {
    max-width: 78rem;
    margin: 0 auto;
  }

  .gold-rate-page__faq-list {
    display: grid;
    gap: 1rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .gold-rate-page__faq-item {
