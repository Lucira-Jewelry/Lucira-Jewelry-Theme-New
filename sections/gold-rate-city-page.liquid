    border-bottom: 2px solid rgba(25, 25, 25, 0.1);
  }

  .gold-rate-page__table-richtext td,
  .gold-rate-page__table td {
    padding: 0.85rem 1rem;
    border-bottom: 1px solid rgba(25, 25, 25, 0.08);
