  }

  .gold-rate-page__hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 3rem;
    align-items: center;
  }

  .gold-rate-page__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.82rem;
    letter-spacing: 0;
    text-transform: uppercase;
