  }

  .gold-rate-page__richtext ul li::before {
    content: "•";
    color: #6b5a2d;
    font-weight: bold;
    margin-right: 0.75rem;
  }

  .gold-rate-page__richtext ol li {
    counter-increment: list-item;
  }

  .gold-rate-page__richtext ol li::before {
    content: counter(list-item) ".";
    color: #6b5a2d;
    font-weight: bold;
    margin-right: 0.75rem;
  }

  .gold-rate-page__richtext a {
    color: #6b5a2d;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .gold-rate-page__richtext a:hover {
    color: #5f4c20;
  }

  .gold-rate-page__richtext strong,
  .gold-rate-page__richtext b {
    font-weight: 600;
    color: #191919;
  }

  .gold-rate-page__richtext em,
  .gold-rate-page__richtext i {
    font-style: italic;
  }

  .gold-rate-page__hero-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .gold-rate-page__stat {
    padding: 0.9rem 1rem;
    border: 1px solid rgba(25, 25, 25, 0.12);
    border-radius: 8px;
    background: #fff;
  }

  .gold-rate-page__stat-label {
    display: block;
    font-size: 0.78rem;
    text-transform: uppercase;
    color: rgba(25, 25, 25, 0.58);
  }

  .gold-rate-page__stat-value {
    display: block;
    margin-top: 0.35rem;
    font-size: 1.15rem;
    font-weight: 700;
  }

  .gold-rate-page__updated {
    margin: 1rem 0 0;
    font-size: 0.9rem;
    color: rgba(25, 25, 25, 0.62);
  }

  .gold-rate-page__hero-media {
    min-height: 100%;
  }

  .gold-rate-page__hero-image,
  .gold-rate-page__hero-fallback {
    display: block;
    width: 100%;
    min-height: 420px;
    object-fit: cover;
    border-radius: 8px;
  }

  .gold-rate-page__hero-fallback {
    display: grid;
    place-items: center;
    background: #eee4cf;
    color: #5f4c20;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .gold-rate-page__band {
    padding: 3.5rem 0;
  }

  .gold-rate-page__band--subtle {
    background: #fcfbf7;
    border-top: 1px solid rgba(25, 25, 25, 0.06);
    border-bottom: 1px solid rgba(25, 25, 25, 0.06);
  }

  .gold-rate-page__band--table {
    background: #fafafa;
    border-top: 1px solid rgba(25, 25, 25, 0.06);
    border-bottom: 1px solid rgba(25, 25, 25, 0.06);
  }

  .gold-rate-page__band--faq {
    background: #fafafa;
    border-top: 1px solid rgba(25, 25, 25, 0.06);
    border-bottom: 1px solid rgba(25, 25, 25, 0.06);
    padding: 4.5rem 0;
  }

  .gold-rate-page__section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .gold-rate-page__section-head h2,
  .gold-rate-page__copy-block h2 {
    margin: 0 0 1rem;
    font-size: 1.75rem;
    line-height: 1.2;
    font-weight: 600;
    color: #191919;
  }

  .gold-rate-page__section-head p,
  .gold-rate-page__table-description {
    margin: 0;
    color: rgba(25, 25, 25, 0.72);
    max-width: 56ch;
    font-size: 1rem;
    line-height: 1.5;
  }

  .gold-rate-page__table-wrap {
    overflow-x: auto;
  }

  .gold-rate-page__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 680px;
  }

  .gold-rate-page__table th,
  .gold-rate-page__table td {
    padding: 0.95rem 1rem;
    border-bottom: 1px solid rgba(25, 25, 25, 0.1);
    text-align: left;
    white-space: nowrap;
  }

  .gold-rate-page__table thead th {
    font-size: 0.85rem;
    text-transform: uppercase;
