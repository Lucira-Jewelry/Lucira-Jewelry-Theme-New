  .gold-rate-page__change--up { color: #2a7a2a; font-weight: 600; }
.gold-rate-page__change--down { color: #c0392b; font-weight: 600; }


  @media screen and (max-width: 990px) {
    .gold-rate-page__hero-grid {
      grid-template-columns: 1fr;
    }

    .gold-rate-page__hero-image,
    .gold-rate-page__hero-fallback {
      min-height: 320px;
    }

    .gold-rate-page__hero-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .gold-rate-page__section-head {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media screen and (max-width: 749px) {
    .gold-rate-page__hero {
      padding-top: 2rem;
    }

    .gold-rate-page__band {
      padding: 1.6rem 0;
    }

    .gold-rate-page__hero-stats {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
