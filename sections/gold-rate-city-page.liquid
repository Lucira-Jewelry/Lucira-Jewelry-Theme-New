    color: rgba(25, 25, 25, 0.8);
  }

  .gold-rate-page__richtext p {
    margin: 0 0 1.25rem;
    line-height: 1.75;
    color: rgba(25, 25, 25, 0.85);
  }

  .gold-rate-page__richtext p:last-child {
    margin-bottom: 0;
  }

  .gold-rate-page__richtext h3,
  .gold-rate-page__richtext h4 {
    margin: 2rem 0 1rem;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    color: #191919;
  }

  .gold-rate-page__richtext h3:first-child,
  .gold-rate-page__richtext h4:first-child {
    margin-top: 0;
  }

  .gold-rate-page__richtext ul,
  .gold-rate-page__richtext ol {
    margin: 1.5rem 0;
    padding-left: 0;
    list-style: none;
  }

  .gold-rate-page__richtext ol {
    counter-reset: list-item;
  }

  .gold-rate-page__richtext ul li,
  .gold-rate-page__richtext ol li {
