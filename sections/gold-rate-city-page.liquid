    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .gold-rate-page__faq-question::after {
    content: '+';
    font-size: 1.5rem;
    font-weight: 400;
    color: #6b5a2d;
    transition: transform 0.2s ease;
  }

  .gold-rate-page__faq-item[open] .gold-rate-page__faq-question::after {
    transform: rotate(45deg);
  }

  .gold-rate-page__faq-question::-webkit-details-marker {
    display: none;
  }

  .gold-rate-page__faq-answer {
    padding: 0 1.5rem 1.5rem;
    color: rgba(25, 25, 25, 0.82);
    font-size: 0.98rem;
    line-height: 1.6;
  }

  .gold-rate-page__faq-answer p {
    margin: 0 0 0.75rem;
  }

  .gold-rate-page__faq-answer p:last-child {
    margin-bottom: 0;
  }

  .gold-rate-page__table-richtext table,
  .gold-rate-page__table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    border-radius: 8px;
