<script>
document.addEventListener('DOMContentLoaded', function() {
  const storeMainContainer = document.querySelectorAll('.other-stores');
  const contactAfterForm = document.querySelectorAll('.contact-online-form-wrapper');
  const storeCards = document.querySelectorAll('.store-card');
  const input = document.querySelector('#pincode-input');
  const locateBtn = document.querySelector('#locate-btn');
  const submitBtn = document.querySelector('#submit-btn');
  storeCards.forEach(card => card.style.display = 'none');

  storeMainContainer.forEach(card => card.style.display = 'none');
  const parseRange = (rangeText) => {
    if (!rangeText) return null;
    const parts = rangeText.replace(/\s/g, '').split(/[-–—]/);
    if (parts.length === 1) return [parseInt(parts[0]), parseInt(parts[0])];
    return [parseInt(parts[0]), parseInt(parts[1])];
  };
  
  const filterStores = (enteredPincode) => {
    if (!enteredPincode) return;
    storeMainContainer.forEach(card => card.style.display = 'block');
     let count = 0;
    storeCards.forEach(card => {
      const rangeText = card.getAttribute('data-range');
      const range = parseRange(rangeText);
      if (!range) return;
      const [min, max] = range;
      console.log('173',enteredPincode, min, max )
      if (enteredPincode >= min && enteredPincode <= max) {
       count+=1;
        card.style.display = 'flex';
      } else {
        card.style.display = 'none';
      }
     
    });
     if (count > 0){
        document.querySelector('.contact-online-form-wrapper').style.display = 'none';
      }else {
        document.querySelector('.contact-online-form-wrapper').style.display = 'block';
      }

  };
  submitBtn?.addEventListener('click', () => {
    const pincode = parseInt(input.value.trim());
    if (pincode) filterStores(pincode);
  });
  document.addEventListener('pincodeDetected', (e) => {
    const pincode = parseInt(e.detail.pincode);
    if (pincode) filterStores(pincode);
  });
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const form = document.getElementById("contactForm");
  const formSection = document.getElementById("contact-form-section");
  const successSection = document.getElementById("success-section");
  const refillBtn = document.getElementById("refill-form");

  form.addEventListener("submit", function(e) {
    e.preventDefault();
    formSection.style.display = "none";
    successSection.style.display = "block";
  });

  refillBtn.addEventListener("click", function(e) {
    e.preventDefault();
    successSection.style.display = "none";
    formSection.style.display = "block";
    form.reset();
  });
});
</script>

