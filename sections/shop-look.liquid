{% schema %}
{
  "name": "Shop The Look",
  "settings": [
    { "type": "text", "id": "heading",    "label": "Heading" },
    { "type": "text", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "image_card",
      "limit": 3,
      "name": "Image Card",
      "settings": [
        { "type": "image_picker", "id": "card_image", "label": "Card Image" },
        { "type": "text",         "id": "parent_id",  "label": "Parent Id" }
      ]
    },
    {
      "type": "pin",
      "name": "Pin",
      "settings": [
        { "type": "range",   "id": "horizontal_position", "label": "Horizontal Position", "min": 0, "max": 100, "default": 50, "unit": "%" },
        { "type": "range",   "id": "vertical_position",   "label": "Vertical Position",   "min": 0, "max": 100, "default": 50, "unit": "%" },
        {
          "type": "select", "id": "product_position", "label": "Product Position",
          "options": [
            { "label": "Top",          "value": "top" },
            { "label": "Bottom",       "value": "bottom" },
            { "label": "Left",         "value": "left" },
            { "label": "Right",        "value": "right" },
            { "label": "Top Left",     "value": "top-left" },
            { "label": "Top Right",    "value": "top-right" },
            { "label": "Bottom Left",  "value": "bottom-left" },
            { "label": "Bottom Right", "value": "bottom-right" }
          ],
          "default": "top"
        },
        { "type": "product", "id": "pin_product", "label": "Product" },
        { "type": "text",    "id": "parent_id",   "label": "Parent Id" }
      ]
    }
  ],
  "presets": [{ "name": "Shop The Look" }]
}
{% endschema %}

<section class="home-shop-the-look">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <p class="home-stl-heading">{{ section.settings.heading }}</p>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="home-stl-subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="home-stl-container shop-look-carousel owl-carousel owl-theme" id="stl-carousel">
      {%- for block in section.blocks -%}
        {%- if block.type == 'image_card' -%}
          <div class="home-stl-item" data-parent-id="{{ block.settings.parent_id }}">

            {%- if block.settings.card_image != blank -%}
              <picture>
                <source
                  type="image/webp"
                  srcset="
                    {{ block.settings.card_image | image_url: width: 400, format: 'webp' }} 400w,
                    {{ block.settings.card_image | image_url: width: 800, format: 'webp' }} 800w,
                    {{ block.settings.card_image | image_url: width: 1200, format: 'webp' }} 1200w
                  "
                  sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)"
                >
                <img
                  srcset="
                    {%- if block.settings.card_image.width >= 165 -%}{{ block.settings.card_image | image_url: width: 165 }} 165w,{%- endif -%}
                    {%- if block.settings.card_image.width >= 360 -%}{{ block.settings.card_image | image_url: width: 360 }} 360w,{%- endif -%}
                    {%- if block.settings.card_image.width >= 535 -%}{{ block.settings.card_image | image_url: width: 535 }} 535w,{%- endif -%}
                    {%- if block.settings.card_image.width >= 750 -%}{{ block.settings.card_image | image_url: width: 750 }} 750w,{%- endif -%}
                    {%- if block.settings.card_image.width >= 1070 -%}{{ block.settings.card_image | image_url: width: 1070 }} 1070w,{%- endif -%}
                    {%- if block.settings.card_image.width >= 1500 -%}{{ block.settings.card_image | image_url: width: 1500 }} 1500w,{%- endif -%}
                    {{ block.settings.card_image | image_url }} {{ block.settings.card_image.width }}w
                  "
                  src="{{ block.settings.card_image | image_url: width: 1500 }}"
                  sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)"
                  alt="{{ block.settings.card_image.alt | escape }}"
                  width="564"
                  height="752"
                  loading="lazy"
                  decoding="async"
                  class="home-stl-image"
                  title="shop-the-look"
                >
              </picture>
            {%- endif -%}

            <div class="home-stl-pins-wrapper">
              {%- for pin in section.blocks -%}
                {%- if pin.type == 'pin' and pin.settings.parent_id == block.settings.parent_id -%}
                  {%- assign h = pin.settings.horizontal_position -%}
                  {%- assign v = pin.settings.vertical_position -%}
                  {%- assign pos = pin.settings.product_position -%}

                  <div class="home-stl-pin-group" style="left:{{ h }}%;top:{{ v }}%;position:absolute;">
                    <!-- Pin button — inline SVG fallback so it always renders -->
                    <button class="home-stl-pin-btn" aria-label="View product" type="button">
                      <svg width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="15" cy="15" r="14" fill="white" fill-opacity="0.85" stroke="#1a1a1a" stroke-width="1.5"/>
                        <path d="M15 8.5C12.5 8.5 10.5 10.4 10.5 12.8c0 3.5 4.5 8.7 4.5 8.7s4.5-5.2 4.5-8.7C19.5 10.4 17.5 8.5 15 8.5z" fill="#1a1a1a"/>
                      </svg>
                    </button>

                    {%- if pin.settings.pin_product.url -%}
                      <a
                        href="{{ pin.settings.pin_product.url }}"
                        class="home-stl-pin-product stl-shop-now stl-pos--{{ pos }}"
                      >
                        <span class="home-stl-pin-product-image">
                          <img
                            src="{{ pin.settings.pin_product.featured_image | image_url: width: 80 }}"
                            alt="{{ pin.settings.pin_product.title | escape }}"
                            width="72"
                            height="72"
                            loading="lazy"
                            decoding="async"
                          >
                        </span>
                        <span class="home-stl-pin-product-info">
                          <p class="home-stl-pin-title">{{ pin.settings.pin_product.title }}</p>
                          <p class="home-stl-pin-cta">Shop Now</p>
                        </span>
                      </a>
                    {%- endif -%}
                  </div>

                {%- endif -%}
              {%- endfor -%}
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
/* ── Section Layout ─────────────────────────────────────── */
.home-shop-the-look { padding: 30px 0; overflow: hidden; }

/* ── Typography ─────────────────────────────────────────── */
.home-stl-heading {
  margin: 0; font-size: 28px; font-weight: 500;
  line-height: normal; text-align: center;
  text-transform: uppercase; color: #1a1a1a;
}
.home-stl-subheading {
  margin: 0; font-size: 18px; text-align: center;
  color: #535361; font-family: Futura, sans-serif;
}

/* ── Carousel ───────────────────────────────────────────── */
.home-stl-container { margin-top: 40px; position: relative; }
.shop-look-carousel.owl-carousel .owl-stage-outer { overflow: visible; }
.shop-look-carousel.owl-carousel .owl-stage       { display: flex; align-items: stretch; }
.shop-look-carousel .owl-nav,
.shop-look-carousel .owl-dots                     { display: none; }

/* ── Card ───────────────────────────────────────────────── */
.home-stl-item { position: relative; border-radius: 12px; width: 100%; height: auto; }
.home-stl-image { display: block; width: 100%; height: auto; border-radius: 12px; }

/* ── Pins Wrapper ───────────────────────────────────────── */
.home-stl-pins-wrapper { position: absolute; inset: 0; pointer-events: none; }

/* ── Pin Group ──────────────────────────────────────────── */
.home-stl-pin-group { pointer-events: all; }

/* ── Pin Button ─────────────────────────────────────────── */
.home-stl-pin-btn {
  background: none; border: none; padding: 0;
  cursor: pointer; display: block;
  transform: translate(-50%, -50%);
  transition: transform 0.2s ease;
}
.home-stl-pin-btn:hover { transform: translate(-50%, -50%) scale(1.15); }

/* ── Pin Product Card ───────────────────────────────────── */
.home-stl-pin-product {
  position: absolute;
  display: flex; align-items: stretch; gap: 1rem;
  min-width: 250px; padding: 12px; border-radius: 12px;
  background: rgba(0,0,0,0.6); color: #fff;
  text-decoration: none; z-index: 10;
  pointer-events: all;
  visibility: hidden; opacity: 0;
  transition: visibility 0.2s ease, opacity 0.2s ease;
}
.home-stl-pin-group.is-active .home-stl-pin-product,
.home-stl-pin-product:hover { visibility: visible; opacity: 1; }

/* ── Position Transforms ────────────────────────────────── */
.stl-pos--top          { transform: translate(-33%, calc(-100% - 36px)); }
.stl-pos--bottom       { transform: translate(-33%, 8px); }
.stl-pos--left         { transform: translate(calc(-100% - 8px), -50%); }
.stl-pos--right        { transform: translate(8px, -50%); }
.stl-pos--top-left     { transform: translate(-100%, calc(-100% - 36px)); }
.stl-pos--top-right    { transform: translate(0%, calc(-100% - 36px)); }
.stl-pos--bottom-left  { transform: translate(-100%, 8px); }
.stl-pos--bottom-right { transform: translate(0%, 8px); }

/* ── Pin Product Internals ──────────────────────────────── */
.home-stl-pin-product-image { flex-shrink: 0; width: 72px; height: 72px; }
.home-stl-pin-product-image img { width: 100%; height: 100%; border-radius: 12px; object-fit: cover; }
.home-stl-pin-product-info { text-align: left; }
.home-stl-pin-title { margin: 0; font-size: 12px; line-height: initial; }
.home-stl-pin-cta   { margin: 8px 0 0; font-size: 10px; line-height: initial; text-decoration: underline; }

/* ── Responsive ─────────────────────────────────────────── */
@media screen and (max-width: 768px) {
  .home-shop-the-look  { margin: 24px 0; padding: 20px 1rem; }
  .home-stl-container  { margin-top: 24px; }
  .home-stl-heading    { font-size: 18px; }
  .home-stl-subheading { font-size: 12px; line-height: 2; }
  .home-stl-pin-btn svg { width: 26px; height: 26px; }
  .home-stl-pin-product { min-width: 200px; }
  .home-stl-pin-product-image { width: 48px; height: 48px; }
  .home-stl-pin-title  { font-size: 12px; }
}

@media only screen and (min-width: 1600px) and (max-width: 2100px) {
  .home-stl-heading { font-size: 28px; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const carousel = document.getElementById('stl-carousel');
  if (!carousel) return;

  // ── Owl Carousel ──────────────────────────────────────
  $(carousel).owlCarousel({
    loop: false, nav: false, dots: false, margin: 20,
    responsive: {
      0:   { items: 1, margin: 12, center: true, loop: true, mouseDrag: true, touchDrag: true, pullDrag: true, stagePadding: 50 },
      768: { items: 3, center: false, loop: false, mouseDrag: false, touchDrag: false, pullDrag: false, stagePadding: 0 }
    }
  });

  // ── Pin toggle (click to show/hide product card) ──────
  carousel.addEventListener('click', function (e) {
    const btn = e.target.closest('.home-stl-pin-btn');
    if (!btn) return;

    const group = btn.closest('.home-stl-pin-group');
    const isActive = group.classList.contains('is-active');

    // Close all open pins first
    carousel.querySelectorAll('.home-stl-pin-group.is-active')
      .forEach(g => g.classList.remove('is-active'));

    if (!isActive) group.classList.add('is-active');
  });

  // Close pins when clicking outside
  document.addEventListener('click', function (e) {
    if (!e.target.closest('.home-stl-pin-group')) {
      carousel.querySelectorAll('.home-stl-pin-group.is-active')
        .forEach(g => g.classList.remove('is-active'));
    }
  });

  // ── GTM promoClick ────────────────────────────────────
  carousel.addEventListener('click', function (e) {
    const link = e.target.closest('.stl-shop-now');
    if (!link) return;
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'promoClick',
      promoClick: {
        promo_id:       link.dataset.promoId       || '',
        creative_name:  link.dataset.creativeName  || 'Shop_the_look_banner_image',
        promo_position: link.dataset.promoPosition || 'homepage_shop_the_look'
      }
    });
  });
});
</script>
