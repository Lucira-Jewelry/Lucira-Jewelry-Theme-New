{% schema %}
{
  "name": "Shop The Look",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "image_card",
      "limit": 3,
      "name": "Image Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "parent_id",
          "label": "Parent Id"
        }
      ]
    },
    {
      "type": "pin",
      "name": "Pin",
      "settings": [
        {
          "type": "range",
          "id": "horizontal_position",
          "label": "Horizontal Position",
          "min": 0,
          "max": 100,
          "default": 50,
          "unit": "%"
        },
        {
          "type": "range",
          "id": "vertical_position",
          "label": "Vertical Position",
          "min": 0,
          "max": 100,
          "default": 50,
          "unit": "%"
        },
        {
          "type": "select",
          "id": "product_position",
          "label": "Product Position",
          "options": [
            { "label": "Top",          "value": "top" },
            { "label": "Bottom",       "value": "bottom" },
            { "label": "Left",         "value": "left" },
            { "label": "Right",        "value": "right" },
            { "label": "Top Left",     "value": "top-left" },
            { "label": "Top Right",    "value": "top-right" },
            { "label": "Bottom Left",  "value": "bottom-left" },
            { "label": "Bottom Right", "value": "bottom-right" }
          ],
          "default": "top"
        },
        {
          "type": "product",
          "id": "pin_product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "parent_id",
          "label": "Parent Id"
        }
      ]
    }
  ],
  "presets": [{ "name": "Shop The Look" }]
}
{% endschema %}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<section class="home-shop-the-look">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <p class="home-stl-heading">{{ section.settings.heading }}</p>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="home-stl-subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="home-stl-container">
      <!-- Desktop: plain grid wrapper -->
      <div class="home-stl-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'image_card' -%}
            <div class="home-stl-item" data-parent-id="{{ block.settings.parent_id }}">

              {%- if block.settings.card_image != blank -%}
                <picture>
                  <source
                    type="image/webp"
                    srcset="
                      {{ block.settings.card_image | image_url: width: 400, format: 'webp' }} 400w,
                      {{ block.settings.card_image | image_url: width: 800, format: 'webp' }} 800w,
                      {{ block.settings.card_image | image_url: width: 1200, format: 'webp' }} 1200w
                    "
                    sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)"
                  >
                  <img
                    srcset="
                      {%- if block.settings.card_image.width >= 165 -%}{{ block.settings.card_image | image_url: width: 165 }} 165w,{%- endif -%}
                      {%- if block.settings.card_image.width >= 360 -%}{{ block.settings.card_image | image_url: width: 360 }} 360w,{%- endif -%}
                      {%- if block.settings.card_image.width >= 535 -%}{{ block.settings.card_image | image_url: width: 535 }} 535w,{%- endif -%}
                      {%- if block.settings.card_image.width >= 750 -%}{{ block.settings.card_image | image_url: width: 750 }} 750w,{%- endif -%}
                      {%- if block.settings.card_image.width >= 1070 -%}{{ block.settings.card_image | image_url: width: 1070 }} 1070w,{%- endif -%}
                      {%- if block.settings.card_image.width >= 1500 -%}{{ block.settings.card_image | image_url: width: 1500 }} 1500w,{%- endif -%}
                      {{ block.settings.card_image | image_url }} {{ block.settings.card_image.width }}w
                    "
                    src="{{ block.settings.card_image | image_url: width: 1500 }}"
                    sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)"
                    alt="{{ block.settings.card_image.alt | escape }}"
                    width="564"
                    height="752"
                    loading="lazy"
                    decoding="async"
                    class="home-stl-image"
                    title="shop-the-look"
                  >
                </picture>
              {%- endif -%}

              <div class="home-stl-pins-wrapper">
                {%- for pin in section.blocks -%}
                  {%- if pin.type == 'pin' and pin.settings.parent_id == block.settings.parent_id -%}

                    {%- assign h = pin.settings.horizontal_position -%}
                    {%- assign v = pin.settings.vertical_position -%}

                    <svg
                      width="30"
                      height="30"
                      class="home-stl-pin"
                      style="left:{{ h }}%;top:{{ v }}%"
                      aria-hidden="true"
                    >
                      <use href="#icon-circle-heart"></use>
                    </svg>

                    {%- if pin.settings.pin_product.url -%}
                      {%- assign pos = pin.settings.product_position -%}
                      
                        href="{{ pin.settings.pin_product.url }}"
                        class="home-stl-pin-product stl-shop-now stl-pos--{{ pos }}"
                        style="left:{{ h }}%;top:{{ v }}%"
                      >
                        <span class="home-stl-pin-product-image">
                          <img
                            src="{{ pin.settings.pin_product.featured_image | image_url: width: 80 }}"
                            alt="{{ pin.settings.pin_product.title | escape }}"
                            width="72"
                            height="72"
                            loading="lazy"
                            decoding="async"
                          >
                        </span>
                        <span class="home-stl-pin-product-info">
                          <p class="home-stl-pin-title">{{ pin.settings.pin_product.title }}</p>
                          <p class="home-stl-pin-cta">Shop Now</p>
                        </span>
                      </a>
                    {%- endif -%}

                  {%- endif -%}
                {%- endfor -%}
              </div>

            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
/* ── Section Layout ─────────────────────────────────────── */
.home-shop-the-look {
  padding: 30px 0;
  overflow: hidden;
}

/* ── Typography ─────────────────────────────────────────── */
.home-stl-heading {
  margin: 0;
  font-size: 28px;
  font-weight: 500;
  line-height: normal;
  text-align: center;
  text-transform: uppercase;
  color: #1a1a1a;
}

.home-stl-subheading {
  margin: 0;
  font-size: 18px;
  text-align: center;
  color: #535361;
  font-family: Futura, sans-serif;
}

/* ── Container ──────────────────────────────────────────── */
.home-stl-container {
  margin-top: 40px;
}

/* ── Desktop Grid (768px+) ──────────────────────────────── */
.home-stl-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

/* ── Card ───────────────────────────────────────────────── */
.home-stl-item {
  position: relative;
  border-radius: 12px;
  width: 100%;
  height: auto;
}

.home-stl-image {
  display: block;
  width: 100%;
  height: auto;
  border-radius: 12px;
}

/* ── Pins Wrapper ───────────────────────────────────────── */
.home-stl-pins-wrapper {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

/* ── Pin Icon ───────────────────────────────────────────── */
.home-stl-pin {
  position: absolute;
  cursor: pointer;
  z-index: 1;
  pointer-events: all;
}

/* ── Pin Product Card ───────────────────────────────────── */
.home-stl-pin-product {
  position: absolute;
  display: flex;
  align-items: stretch;
  gap: 1rem;
  min-width: 250px;
  padding: 12px;
  border-radius: 12px;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  text-decoration: none;
  z-index: 2;
  pointer-events: all;
  visibility: hidden;
  opacity: 0;
  transition: visibility 0.2s ease, opacity 0.2s ease;
}

.home-stl-pin:hover + .home-stl-pin-product,
.home-stl-pin-product:hover {
  visibility: visible;
  opacity: 1;
}

.stl-pos--top          { transform: translate(-33%, -100%); }
.stl-pos--bottom       { transform: translate(-70%, -115px); }
.stl-pos--left         { transform: translate(-60%, -100%); }
.stl-pos--right        { transform: translate(32px, -50%); }
.stl-pos--top-left     { transform: translate(-100%, -100%); }
.stl-pos--top-right    { transform: translate(0%, -100%); }
.stl-pos--bottom-left  { transform: translate(-100%, 0%); }
.stl-pos--bottom-right { transform: translate(0%, 0%); }

/* ── Pin Product Internals ──────────────────────────────── */
.home-stl-pin-product-image {
  flex-shrink: 0;
  width: 72px;
  height: 72px;
}

.home-stl-pin-product-image img {
  width: 100%;
  height: 100%;
  border-radius: 12px;
  object-fit: cover;
}

.home-stl-pin-product-info { text-align: left; }

.home-stl-pin-title {
  margin: 0;
  font-size: 12px;
  line-height: initial;
}

.home-stl-pin-cta {
  margin: 8px 0 0;
  font-size: 10px;
  line-height: initial;
  text-decoration: underline;
}

/* ── Mobile Swiper (< 768px) ────────────────────────────── */
@media screen and (max-width: 767px) {
  .home-shop-the-look {
    margin: 24px 0;
    padding: 20px 0;
  }

  .home-stl-container {
    margin-top: 24px;
    /* allow Swiper overflow-visible peek */
    overflow: visible;
  }

  /* Reset grid → Swiper takes over */
  .home-stl-grid {
    display: block; /* Swiper JS wraps .home-stl-item inside .swiper-wrapper */
  }

  .home-stl-heading    { font-size: 18px; }
  .home-stl-subheading { font-size: 12px; line-height: 2; }
  .home-stl-pin        { width: 26px; height: 26px; }
  .home-stl-pin-product { min-width: 200px; }

  .home-stl-pin-product-image {
    width: 48px;
    height: 48px;
  }

  .home-stl-pin-title { font-size: 12px; }

  /* Swiper slide */
  .swiper-slide.home-stl-item {
    width: 80vw;  /* peek effect */
  }
}

@media only screen and (min-width: 1600px) and (max-width: 2100px) {
  .home-stl-heading { font-size: 28px; }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const isMobile = window.innerWidth < 768;

    if (isMobile) {
      initSwiper();
    }

    // ── Init Swiper on mobile ──────────────────────────────
    function initSwiper() {
      const grid = document.querySelector('.home-stl-grid');
      if (!grid) return;

      // Wrap in Swiper structure
      const items = Array.from(grid.querySelectorAll('.home-stl-item'));

      // Build swiper DOM
      const swiper = document.createElement('div');
      swiper.classList.add('swiper', 'home-stl-swiper');

      const wrapper = document.createElement('div');
      wrapper.classList.add('swiper-wrapper');

      items.forEach(item => {
        item.classList.add('swiper-slide');
        wrapper.appendChild(item);
      });

      swiper.appendChild(wrapper);
      grid.appendChild(swiper);

      new Swiper('.home-stl-swiper', {
        slidesPerView: 'auto',   // respects width: 80vw on slide
        spaceBetween: 12,
        centeredSlides: true,
        loop: true,
        grabCursor: true,
      });
    }

    // ── GTM promoClick ────────────────────────────────────
    const container = document.querySelector('.home-stl-container');
    if (!container) return;

    container.addEventListener('click', function (e) {
      const link = e.target.closest('.stl-shop-now');
      if (!link) return;

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'promoClick',
        promoClick: {
          promo_id:       link.dataset.promoId        || '',
          creative_name:  link.dataset.creativeName   || 'Shop_the_look_banner_image',
          promo_position: link.dataset.promoPosition  || 'homepage_shop_the_look'
        }
      });
    });
  });
</script>