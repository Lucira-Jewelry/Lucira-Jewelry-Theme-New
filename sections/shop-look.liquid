{% schema %}
{
  "name": "Shop The Look",
  "settings": [
    { "type": "text", "id": "heading",    "label": "Heading" },
    { "type": "text", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "image_card",
      "limit": 3,
      "name": "Image Card",
      "settings": [
        { "type": "image_picker", "id": "card_image", "label": "Card Image" },
        { "type": "text",         "id": "parent_id",  "label": "Parent Id" }
      ]
    },
    {
      "type": "pin",
      "name": "Pin",
      "settings": [
        {
          "type": "range", "id": "horizontal_position", "label": "Horizontal Position",
          "min": 0, "max": 100, "default": 50, "unit": "%"
        },
        {
          "type": "range", "id": "vertical_position", "label": "Vertical Position",
          "min": 0, "max": 100, "default": 50, "unit": "%"
        },
        {
          "type": "select", "id": "product_position", "label": "Product Position",
          "default": "top",
          "options": [
            { "label": "Top",          "value": "top" },
            { "label": "Bottom",       "value": "bottom" },
            { "label": "Left",         "value": "left" },
            { "label": "Right",        "value": "right" },
            { "label": "Top Left",     "value": "top-left" },
            { "label": "Top Right",    "value": "top-right" },
            { "label": "Bottom Left",  "value": "bottom-left" },
            { "label": "Bottom Right", "value": "bottom-right" }
          ]
        },
        { "type": "product", "id": "pin_product", "label": "Product" },
        { "type": "text",    "id": "parent_id",   "label": "Parent Id" }
      ]
    }
  ],
  "presets": [{ "name": "Shop The Look" }]
}
{% endschema %}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<section class="home-shop-the-look">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <p class="home-stl-heading">{{ section.settings.heading }}</p>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="home-stl-subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="home-stl-container">
      <div class="home-stl-grid" id="stl-grid">

        {%- for block in section.blocks -%}
          {%- if block.type == 'image_card' -%}
            <div class="home-stl-item" data-parent-id="{{ block.settings.parent_id }}">

              {%- if block.settings.card_image != blank -%}
                <picture>
                  <source
                    type="image/webp"
                    srcset="
                      {{ block.settings.card_image | image_url: width: 400,  format: 'webp' }} 400w,
                      {{ block.settings.card_image | image_url: width: 800,  format: 'webp' }} 800w,
                      {{ block.settings.card_image | image_url: width: 1200, format: 'webp' }} 1200w
                    "
                    sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                           (min-width: 750px) calc((100vw - 130px) / 2),
                           calc((100vw - 50px) / 2)"
                  >
                  <img
                    srcset="
                      {%- if block.settings.card_image.width >= 165  -%}{{ block.settings.card_image | image_url: width: 165  }} 165w,{%- endif -%}
                      {%- if block.settings.card_image.width >= 360  -%}{{ block.settings.card_image | image_url: width: 360  }} 360w,{%- endif -%}
                      {%- if block.settings.card_image.width >= 535  -%}{{ block.settings.card_image | image_url: width: 535  }} 535w,{%- endif -%}
                      {%- if block.settings.card_image.width >= 750  -%}{{ block.settings.card_image | image_url: width: 750  }} 750w,{%- endif -%}
                      {%- if block.settings.card_image.width >= 1070 -%}{{ block.settings.card_image | image_url: width: 1070 }} 1070w,{%- endif -%}
                      {%- if block.settings.card_image.width >= 1500 -%}{{ block.settings.card_image | image_url: width: 1500 }} 1500w,{%- endif -%}
                      {{ block.settings.card_image | image_url }} {{ block.settings.card_image.width }}w
                    "
                    src="{{ block.settings.card_image | image_url: width: 1500 }}"
                    sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                           (min-width: 750px) calc((100vw - 130px) / 2),
                           calc((100vw - 50px) / 2)"
                    alt="{{ block.settings.card_image.alt | escape }}"
                    width="564"
                    height="752"
                    loading="lazy"
                    decoding="async"
                    class="home-stl-image"
                    title="shop-the-look"
                  >
                </picture>
              {%- endif -%}

              <!-- Pins are rendered AFTER the image, inside the same relative parent -->
              <div class="home-stl-pins-wrapper">
                {%- for pin in section.blocks -%}
                  {%- if pin.type == 'pin' and pin.settings.parent_id == block.settings.parent_id -%}
                    {%- assign h   = pin.settings.horizontal_position -%}
                    {%- assign v   = pin.settings.vertical_position -%}
                    {%- assign pos = pin.settings.product_position -%}

                    <div
                      class="home-stl-pin-group"
                      style="left:{{ h }}%; top:{{ v }}%;"
                    >
                      <!-- Trigger button -->
                      <button
                        type="button"
                        class="home-stl-pin"
                        aria-label="View product"
                        aria-expanded="false"
                      >
                        <svg width="30" height="30" aria-hidden="true">
                          <use href="#icon-circle-heart"></use>
                        </svg>
                      </button>

                      <!-- Product card — hidden by default via display:none in CSS -->
                      {%- if pin.settings.pin_product.url -%}
                        <a
                          href="{{ pin.settings.pin_product.url }}"
                          class="home-stl-pin-product stl-shop-now stl-pos--{{ pos }}"
                        >
                          <span class="home-stl-pin-product-image">
                            <img
                              src="{{ pin.settings.pin_product.featured_image | image_url: width: 80 }}"
                              alt="{{ pin.settings.pin_product.title | escape }}"
                              width="72"
                              height="72"
                              loading="lazy"
                              decoding="async"
                            >
                          </span>
                          <span class="home-stl-pin-product-info">
                            <p class="home-stl-pin-title">{{ pin.settings.pin_product.title }}</p>
                            <p class="home-stl-pin-cta">Shop Now</p>
                          </span>
                        </a>
                      {%- endif -%}
                    </div>

                  {%- endif -%}
                {%- endfor -%}
              </div>

            </div>
          {%- endif -%}
        {%- endfor -%}

      </div><!-- /.home-stl-grid -->
    </div><!-- /.home-stl-container -->
  </div><!-- /.page-width -->
</section>

<style>
/* ── Section ────────────────────────────────────────────── */
.home-shop-the-look {
  padding: 30px 0;
  overflow: hidden;
}

/* ── Typography ─────────────────────────────────────────── */
.home-stl-heading {
  margin: 0;
  font-size: 28px;
  font-weight: 500;
  line-height: normal;
  text-align: center;
  text-transform: uppercase;
  color: #1a1a1a;
}

.home-stl-subheading {
  margin: 0;
  font-size: 18px;
  text-align: center;
  color: #535361;
  font-family: Futura, sans-serif;
}

/* ── Container ──────────────────────────────────────────── */
.home-stl-container { margin-top: 40px; }

/* ── Desktop Grid ───────────────────────────────────────── */
.home-stl-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

/* ── Card ───────────────────────────────────────────────── */
.home-stl-item {
  position: relative;    /* pins-wrapper anchor */
  border-radius: 12px;
  width: 100%;
  /* NO overflow:hidden here — pin popups must escape the card */
}

.home-stl-image {
  display: block;
  width: 100%;
  height: auto;
  border-radius: 12px;
}

/* ── Pins Wrapper ───────────────────────────────────────── */
.home-stl-pins-wrapper {
  position: absolute;
  inset: 0;
  pointer-events: none;   /* clicks pass through to image */
}

/* ── Pin Group (anchor for both button + popup) ─────────── */
.home-stl-pin-group {
  position: absolute;
  pointer-events: all;
  /* zero-size anchor; children are positioned relative to this */
  width: 0;
  height: 0;
}

/* ── Pin Button ─────────────────────────────────────────── */
.home-stl-pin {
  position: absolute;
  top: 0;
  left: 0;
  transform: translate(-50%, -50%);
  width: 30px;
  height: 30px;
  padding: 0;
  border: none;
  background: transparent;
  cursor: pointer;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ── Pin Product Card — HIDDEN BY DEFAULT ───────────────── */
.home-stl-pin-product {
  position: absolute;
  display: none;           /* JS adds .is-visible → display:flex */
  align-items: stretch;
  gap: 1rem;
  min-width: 250px;
  padding: 12px;
  border-radius: 12px;
  background: rgba(0, 0, 0, 0.65);
  color: #fff;
  text-decoration: none;
  z-index: 10;
  white-space: nowrap;
}

/* JS-toggled visible state */
.home-stl-pin-product.is-visible {
  display: flex;
}

/* ── Position Transforms ────────────────────────────────── */
.stl-pos--top          { bottom: calc(100% + 8px); left: 50%; transform: translateX(-50%); }
.stl-pos--bottom       { top:    calc(100% + 8px); left: 50%; transform: translateX(-50%); }
.stl-pos--left         { right:  calc(100% + 8px); top:  50%; transform: translateY(-50%); }
.stl-pos--right        { left:   calc(100% + 8px); top:  50%; transform: translateY(-50%); }
.stl-pos--top-left     { bottom: calc(100% + 8px); right: 0; }
.stl-pos--top-right    { bottom: calc(100% + 8px); left: 0; }
.stl-pos--bottom-left  { top:    calc(100% + 8px); right: 0; }
.stl-pos--bottom-right { top:    calc(100% + 8px); left: 0; }

/* ── Pin Product Internals ──────────────────────────────── */
.home-stl-pin-product-image {
  flex-shrink: 0;
  width: 72px;
  height: 72px;
}

.home-stl-pin-product-image img {
  width: 100%;
  height: 100%;
  border-radius: 8px;
  object-fit: cover;
}

.home-stl-pin-product-info { text-align: left; }

.home-stl-pin-title {
  margin: 0;
  font-size: 12px;
  line-height: 1.4;
  white-space: normal;
  max-width: 140px;
}

.home-stl-pin-cta {
  margin: 8px 0 0;
  font-size: 10px;
  line-height: initial;
  text-decoration: underline;
}

/* ── Mobile ─────────────────────────────────────────────── */
@media screen and (max-width: 767px) {
  .home-shop-the-look  { margin: 24px 0; padding: 20px 0; }
  .home-stl-container  { margin-top: 24px; overflow: visible; }
  .home-stl-grid       { display: block; }    /* Swiper takes over */
  .home-stl-heading    { font-size: 18px; }
  .home-stl-subheading { font-size: 12px; line-height: 2; }

  .home-stl-pin { width: 26px; height: 26px; }
  .home-stl-pin svg { width: 26px; height: 26px; }

  .home-stl-pin-product { min-width: 180px; white-space: normal; }

  .home-stl-pin-product-image { width: 48px; height: 48px; }
  .home-stl-pin-title  { font-size: 11px; max-width: 110px; }

  /* Swiper slide sizing for peek effect */
  .swiper-slide.home-stl-item { width: 80vw; }

   .home-shop-the-look { overflow: visible; }
  .home-stl-swiper    { overflow: visible; }
}

@media only screen and (min-width: 1600px) and (max-width: 2100px) {
  .home-stl-heading { font-size: 28px; }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {

  // ── 1. Mobile Swiper init ──────────────────────────────
  if (window.innerWidth < 768) {
    const grid = document.getElementById('stl-grid');
    if (grid) {
      const items = Array.from(grid.querySelectorAll('.home-stl-item'));

      const swiperEl  = document.createElement('div');
      swiperEl.classList.add('swiper', 'home-stl-swiper');

      const wrapperEl = document.createElement('div');
      wrapperEl.classList.add('swiper-wrapper');

      items.forEach(item => {
        item.classList.add('swiper-slide');
        wrapperEl.appendChild(item);
      });

      swiperEl.appendChild(wrapperEl);
      grid.appendChild(swiperEl);

      new Swiper('.home-stl-swiper', {
        slidesPerView   : 'auto',
        spaceBetween    : 12,
        centeredSlides  : true,
        centeredSlidesBounds: true,   // ← prevents first/last slide snapping to edge
        loop            : true,
        grabCursor      : true,
        initialSlide    : 0,
      });
    }
  }

  // ── 2. Pin toggle ──────────────────────────────────────
  const section = document.querySelector('.home-shop-the-look');
  if (!section) return;

  let activeProduct = null;

  function closeActive() {
    if (activeProduct) {
      activeProduct.classList.remove('is-visible');
      const btn = activeProduct.closest('.home-stl-pin-group')?.querySelector('.home-stl-pin');
      if (btn) btn.setAttribute('aria-expanded', 'false');
      activeProduct = null;
    }
  }

  function openProduct(product, btn) {
    if (activeProduct === product) { closeActive(); return; }
    closeActive();
    product.classList.add('is-visible');
    btn.setAttribute('aria-expanded', 'true');
    activeProduct = product;
  }

  // Detect touch-only devices (no hover capability)
  // On touch devices, mouseenter fires before click — causing double-toggle.
  // We skip hover listeners entirely for touch devices.
  const isHoverCapable = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

  section.querySelectorAll('.home-stl-pin-group').forEach(group => {
    const btn     = group.querySelector('.home-stl-pin');
    const product = group.querySelector('.home-stl-pin-product');
    if (!btn || !product) return;

    // Desktop only: hover to open/close
    if (isHoverCapable) {
      group.addEventListener('mouseenter', () => openProduct(product, btn));
      group.addEventListener('mouseleave', () => closeActive());
    }

    // Mobile + Desktop: click/tap to toggle
    // On desktop this is a fallback; on mobile this is the sole trigger
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      openProduct(product, btn);
    });

    // Prevent card click from bubbling up and closing the popup
    product.addEventListener('click', (e) => e.stopPropagation());
  });

  // Tap anywhere else → close
  document.addEventListener('click', closeActive);

  // ── 3. GTM promoClick ─────────────────────────────────
  section.addEventListener('click', function (e) {
    const link = e.target.closest('.stl-shop-now');
    if (!link) return;

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'promoClick',
      promoClick: {
        promo_id       : link.dataset.promoId       || '',
        creative_name  : link.dataset.creativeName  || 'Shop_the_look_banner_image',
        promo_position : link.dataset.promoPosition || 'homepage_shop_the_look'
      }
    });
  });

});
</script>