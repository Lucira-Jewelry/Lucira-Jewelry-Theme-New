{% comment %}
  Franchise Form Section - Uses Shopify Native Contact Form
  Sends email to tech@lucirajewelry.com AND confirmation to customer
{% endcomment %}

<section class="franchise-form-section">
  <div class="page-width">
    <div class="franchise-form-wrapper">

      <h2 class="ff-title">{{ section.settings.title }}</h2>
      <p class="ff-subtitle">{{ section.settings.subtitle }}</p>

      {% if form.posted_successfully? %}
        <div class="ff-success-message">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M10 0C4.48 0 0 4.48 0 10C0 15.52 4.48 20 10 20C15.52 20 20 15.52 20 10C20 4.48 15.52 0 10 0ZM8 15L3 10L4.41 8.59L8 12.17L15.59 4.58L17 6L8 15Z" fill="#155724"/>
          </svg>
          <p>Thank you! Our personnel will contact you shortly at <strong>{{ form.email }}</strong></p>
        </div>
      {% endif %}

      {% if form.errors %}
        <div class="ff-error-message">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M10 0C4.48 0 0 4.48 0 10C0 15.52 4.48 20 10 20C15.52 20 20 15.52 20 10C20 4.48 15.52 0 10 0ZM11 15H9V13H11V15ZM11 11H9V5H11V11Z" fill="#721c24"/>
          </svg>
          <p>{{ form.errors | default_errors }}</p>
        </div>
      {% endif %}

      <!-- SHOPIFY NATIVE CONTACT FORM -->
      {% form 'contact', class: 'franchise-form' %}
        
        {% comment %} Hidden field to identify form type {% endcomment %}
        <input type="hidden" name="contact[form_type]" value="franchise_inquiry">
        
        <div class="ff-row">
          <div class="ff-field">
            <label for="franchise_name">Enter your Full Name</label>
            <input 
              type="text" 
              name="contact[name]" 
              id="franchise_name" 
              placeholder="Sumit Chavda" 
              value="{% if form.name %}{{ form.name }}{% endif %}"
              required>
          </div>

          <div class="ff-field">
            <label for="franchise_phone">Enter your Phone Number</label>
            <input 
              type="tel" 
              name="contact[phone]" 
              id="franchise_phone" 
              placeholder="+91 9876543210"
              value="{% if form.phone %}{{ form.phone }}{% endif %}"
              required>
          </div>

          <div class="ff-field">
            <label for="franchise_email">Enter your Mail ID</label>
            <input 
              type="email" 
              name="contact[email]" 
              id="franchise_email" 
              placeholder="sumit@business.com"
              value="{% if form.email %}{{ form.email }}{% endif %}"
              required>
          </div>

          <div class="ff-field">
            <label for="franchise_city">Enter your City or Pincode</label>
            <input 
              type="text" 
              name="contact[city]" 
              id="franchise_city" 
              placeholder="400001"
              value="{% if form.city %}{{ form.city }}{% endif %}"
              required>
          </div>
        </div>

        {% comment %} Hidden body field with formatted message {% endcomment %}
        <input type="hidden" name="contact[body]" id="franchise_body" value="">

        <button type="submit" class="ff-submit">SUBMIT</button>

      {% endform %}

    </div>
  </div>
</section>

<style>
  .franchise-form-section {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 60px 20px;
  }

  .franchise-form-wrapper {
    width: 100%;
    max-width: 1100px;
    text-align: center;
    margin: 0 auto;
    font-family: inherit;
  }

  .franchise-form-section .ff-title {
    font-size: 24px;
    letter-spacing: 1px;
    font-weight: 500;
    margin-bottom: 10px;
    color: #1a1a1a;
  }

  .franchise-form-section .ff-subtitle {
    max-width: 600px;
    margin: 0 auto 40px;
    color: #555;
    font-size: 14px;
    line-height: 1.6;
  }

  .ff-success-message,
  .ff-error-message {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 30px;
    padding: 16px 20px;
    border-radius: 8px;
    font-size: 14px;
    animation: slideDown 0.3s ease-out;
  }

  .ff-success-message {
    background-color: #d4edda;
    border: 1px solid #c3e6cb;
    color: #155724;
  }

  .ff-error-message {
    background-color: #f8d7da;
    border: 1px solid #f5c6cb;
    color: #721c24;
  }

  .ff-success-message svg,
  .ff-error-message svg {
    flex-shrink: 0;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .franchise-form {
    width: 100%;
  }

  .franchise-form-section .ff-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-bottom: 30px;
  }

  .franchise-form-section .ff-field {
    text-align: left;
    width: 100%;
  }

  .franchise-form-section .ff-field label {
    display: block;
    font-size: 11px;
    margin-bottom: 6px;
    color: #888;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }

  .franchise-form-section .ff-field input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 14px;
    transition: border-color 0.2s;
  }

  .franchise-form-section .ff-field input:focus {
    outline: none;
    border-color: #A68380;
  }

  .franchise-form-section .ff-submit {
    background: #A68380;
    color: #fff;
    padding: 12px 50px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    letter-spacing: 0.5px;
    transition: all 0.2s;
    font-size: 14px;
    font-weight: 500;
  }

  .franchise-form-section .ff-submit:hover {
    background: #8f6e6b;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(166, 131, 128, 0.3);
  }

  .franchise-form-section .ff-submit:active {
    transform: translateY(0);
  }

  @media (max-width: 900px) {
    .franchise-form-section .ff-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .franchise-form-section {
      padding: 40px 15px;
    }

    .franchise-form-section .ff-row {
      grid-template-columns: 1fr;
      gap: 15px;
    }

    .franchise-form-section .ff-title {
      font-size: 20px;
    }

    .ff-success-message,
    .ff-error-message {
      font-size: 13px;
      padding: 14px 16px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('.franchise-form');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      // Build formatted message body before submission
      const name = document.getElementById('franchise_name').value;
      const phone = document.getElementById('franchise_phone').value;
      const email = document.getElementById('franchise_email').value;
      const city = document.getElementById('franchise_city').value;
      
      const messageBody = `
=== NEW FRANCHISE INQUIRY ===

Full Name: ${name}
Phone Number: ${phone}
Email: ${email}
City/Pincode: ${city}

Submitted: ${new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' })}

---
Please contact this lead within 24 hours.
      `.trim();
      
      document.getElementById('franchise_body').value = messageBody;
    });

    // Scroll to success/error message if present
    const successMsg = document.querySelector('.ff-success-message');
    const errorMsg = document.querySelector('.ff-error-message');
    
    if (successMsg || errorMsg) {
      setTimeout(function() {
        (successMsg || errorMsg).scrollIntoView({ 
          behavior: 'smooth', 
          block: 'center' 
        });
      }, 100);
    }
  });
</script>

{% schema %}
{
  "name": "Franchise Form",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Form Title",
      "default": "FRANCHISE INQUIRY FORM"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Form Subtitle",
      "default": "Join our growing network of franchise partners. Fill out the form below and our team will get back to you within 24 hours to discuss opportunities in your area."
    }
  ],
  "presets": [
    {
      "name": "Franchise Form"
    }
  ]
}
{% endschema %}