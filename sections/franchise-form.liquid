{% comment %}
  Franchise Form Section - Proper Shopify Contact Form
  This will work with Shopify's native system and send emails
{% endcomment %}
<section class="franchise-form-section">
  <div class="page-width">
    <div class="franchise-form-wrapper">

      <h2 class="ff-title">{{ section.settings.title }}</h2>
      <p class="ff-subtitle">{{ section.settings.subtitle }}</p>

      <!-- SHOPIFY NATIVE FORM (Properly Configured) -->
      <div class="franchise-form">
        {% form 'contact', id: 'franchise_contact_form' %}
          
          {% comment %} Success Message {% endcomment %}
          {% if form.posted_successfully? %}
            <div class="ff-success">
              Thank you! Our personnel will contact you shortly.
            </div>
          {% endif %}

          {% comment %} Error Messages {% endcomment %}
          {% if form.errors %}
            <div class="ff-error">
              {% for field in form.errors %}
                {{ form.errors.messages[field] }}
              {% endfor %}
            </div>
          {% endif %}

          {% comment %} Hidden Fields for Email Routing {% endcomment %}
          <input type="hidden" name="contact[subject]" value="New Franchise Lead - Lucira Jewelry">
          
          <div class="ff-row">
            <div class="ff-field">
              <label for="contact_name">Enter your Full Name</label>
              <input 
                type="text" 
                name="contact[name]" 
                id="contact_name" 
                placeholder="Sumit Chavda" 
                value="{% if form.name %}{{ form.name }}{% endif %}"
                required>
            </div>

            <div class="ff-field">
              <label for="contact_phone">Enter your Phone Number</label>
              <input 
                type="tel" 
                name="contact[phone]" 
                id="contact_phone" 
                placeholder="+91 9876543210" 
                value="{% if form.phone %}{{ form.phone }}{% endif %}"
                required>
            </div>

            <div class="ff-field">
              <label for="contact_email">Enter your Mail ID</label>
              <input 
                type="email" 
                name="contact[email]" 
                id="contact_email" 
                placeholder="sumit@business.com" 
                value="{% if form.email %}{{ form.email }}{% endif %}"
                required>
            </div>

            <div class="ff-field">
              <label for="contact_city">Enter your City or Pincode</label>
              <input 
                type="text" 
                name="contact[city]" 
                id="contact_city" 
                placeholder="400001" 
                value="{% if form.city %}{{ form.city }}{% endif %}"
                required>
            </div>
          </div>

          {% comment %} Hidden body field with all details {% endcomment %}
          <input type="hidden" name="contact[body]" id="contact_body" value="">

          <button type="submit" class="ff-submit">SUBMIT</button>

        {% endform %}
      </div>

    </div>
  </div>

  <style>
    .franchise-form-section {
      width: 100%;
      display: flex;
      justify-content: center;
      padding: 40px 20px;
    }

    .franchise-form-wrapper {
      width: 100%;
      max-width: 1100px;
      text-align: center;
      margin: 0 auto;
      font-family: inherit;
    }

    .franchise-form-section .ff-title {
      font-size: 24px;
      letter-spacing: 1px;
      font-weight: 500;
      margin-bottom: 10px;
      color: #1a1a1a;
    }

    .franchise-form-section .ff-subtitle {
      max-width: 600px;
      margin: 0 auto 40px;
      color: #555;
      font-size: 14px;
      line-height: 1.6;
    }

    .franchise-form-section .ff-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
      margin-bottom: 30px;
    }

    .franchise-form-section .ff-field {
      text-align: left;
      width: 100%;
    }

    .franchise-form-section .ff-field label {
      display: block;
      font-size: 11px;
      margin-bottom: 5px;
      color: #888;
      letter-spacing: 0.3px;
    }

    .franchise-form-section .ff-field input {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 14px;
      transition: border-color 0.2s;
    }

    .franchise-form-section .ff-field input:focus {
      outline: none;
      border-color: #A68380;
    }

    .franchise-form-section .ff-submit {
      background: #A68380;
      color: #fff;
      padding: 10px 40px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      letter-spacing: 0.5px;
      transition: 0.2s;
      font-size: 14px;
      font-weight: 500;
    }

    .franchise-form-section .ff-submit:hover {
      opacity: 0.85;
    }

    .ff-success {
      margin-top: 20px;
      padding: 15px 20px;
      background-color: #d4edda;
      border: 1px solid #c3e6cb;
      color: #155724;
      border-radius: 6px;
      font-size: 14px;
      text-align: center;
    }

    .ff-error {
      margin-top: 20px;
      padding: 15px 20px;
      background-color: #f8d7da;
      border: 1px solid #f5c6cb;
      color: #721c24;
      border-radius: 6px;
      font-size: 14px;
      text-align: center;
    }

    @media (max-width: 900px) {
      .franchise-form-section .ff-row {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 600px) {
      .franchise-form-section .ff-row {
        grid-template-columns: 1fr;
      }
      
      .franchise-form-section {
        padding: 30px 15px;
      }
    }
  </style>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var form = document.getElementById('franchise_contact_form');
  
  if (form) {
    // Build detailed message body before submission
    form.addEventListener('submit', function(e) {
      var name = document.getElementById('contact_name').value;
      var phone = document.getElementById('contact_phone').value;
      var email = document.getElementById('contact_email').value;
      var city = document.getElementById('contact_city').value;
      
      // Create formatted email body
      var emailBody = 
        "═══════════════════════════════\n" +
        "NEW FRANCHISE INQUIRY\n" +
        "═══════════════════════════════\n\n" +
        "📝 Full Name: " + name + "\n" +
        "📞 Phone: " + phone + "\n" +
        "📧 Email: " + email + "\n" +
        "📍 Location: " + city + "\n\n" +
        "═══════════════════════════════\n" +
        "Submitted: " + new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }) + " IST\n" +
        "═══════════════════════════════";
      
      document.getElementById('contact_body').value = emailBody;
    });
  }

  // Auto-scroll to success message if form was submitted
  {% if form.posted_successfully? %}
    var successMsg = document.querySelector('.ff-success');
    if (successMsg) {
      setTimeout(function() {
        successMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 100);
    }
  {% endif %}
});
</script>

{% schema %}
{
  "name": "Franchise Form",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Form Title",
      "default": "FRANCHISE INQUIRY"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Form Subtitle",
      "default": "Fill out the form below to express your interest in becoming a Lucira Jewelry franchise partner. Our team will review your application and contact you within 48 hours."
    }
  ],
  "presets": [
    {
      "name": "Franchise Form"
    }
  ]
}
{% endschema %}