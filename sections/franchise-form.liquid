{% comment %}
  Franchise Form Section
{% endcomment %}

<section class="franchise-form-section">
  <div class="franchise-form-wrapper">

    <h2 class="ff-title">{{ section.settings.title }}</h2>
    <p class="ff-subtitle">{{ section.settings.subtitle }}</p>

    <form class="ff-form" method="post" action="#">
      <div class="ff-row">
        <div class="ff-field">
          <label>Enter your Full Name</label>
          <input type="text" name="full_name" placeholder="Rohan Mehta" required>
        </div>

        <div class="ff-field">
          <label>Enter your Phone Number</label>
          <input type="text" name="phone" placeholder="+91 9876543210" required>
        </div>

        <div class="ff-field">
          <label>Enter your Mail ID</label>
          <input type="email" name="email" placeholder="rohanmehta@business.com" required>
        </div>

        <div class="ff-field">
          <label>Enter your City or Pincode</label>
          <input type="text" name="city" placeholder="400001" required>
        </div>
      </div>

      <button type="submit" class="ff-submit">SUBMIT</button>
    </form>

  </div>

  <style>
    .franchise-form-section {
      width: 100%;
      padding: 60px 0;
      display: flex;
      justify-content: center;
    }

    .franchise-form-wrapper {
      width: 100%;
      max-width: 1100px;
      text-align: center;
      margin: 0 auto;
      font-family: inherit;
    }

    .franchise-form-section .ff-title {
      font-size: 28px;
      letter-spacing: 1px;
      font-weight: 600;
      margin-bottom: 10px;
      color: #000;
    }

    .franchise-form-section .ff-subtitle {
      max-width: 600px;
      margin: 0 auto 40px;
      color: #555;
      font-size: 14px;
      line-height: 1.6;
    }

    .franchise-form-section .ff-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
      margin-bottom: 30px;
    }

    .franchise-form-section .ff-field {
      text-align: left;
      width: 100%;
    }

    .franchise-form-section .ff-field label {
      display: block;
      font-size: 11px;
      margin-bottom: 5px;
      color: #888;
      letter-spacing: 0.3px;
    }

    .franchise-form-section .ff-field input {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 14px;
    }

    .franchise-form-section .ff-submit {
      background: #b58a82;
      color: #fff;
      padding: 10px 40px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      letter-spacing: 0.5px;
      transition: 0.2s;
      font-size: 14px;
    }

    .franchise-form-section .ff-submit:hover {
      opacity: 0.85;
    }

    @media (max-width: 900px) {
      .franchise-form-section .ff-row {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 600px) {
      .franchise-form-section .ff-row {
        grid-template-columns: 1fr;
      }
    }
  </style>
</section>

{% schema %}
{
  "name": "Franchise Form",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Form Title",
      "default": "FORM"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Form Subtitle",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquip ex ea commodo consequat."
    }
  ],
  "presets": [
    {
      "name": "Franchise Form"
    }
  ]
}
{% endschema %}
