{% comment %}
  Franchise Form Section with Email Notifications
{% endcomment %}
<section class="franchise-form-section">
  <div class="page-width">
    <div class="franchise-form-wrapper">

      <h2 class="ff-title">{{ section.settings.title }}</h2>
      <p class="ff-subtitle">{{ section.settings.subtitle }}</p>

      <!-- FINAL WORKING FORM -->
      <div class="franchise-form">
        {% form 'contact' %}
          <!-- Force Shopify email routing to your email -->
          <input type="hidden" name="contact[form_type]" value="Franchise Form Submission">
          <input type="hidden" name="contact[subject]" value="New Franchise Lead - Lucira Jewelry">
          
          <!-- This ensures email goes to your specified address -->
          <input type="hidden" name="contact[recipient]" value="tech@lucirajewelry.com">

          <!-- HONEYPOT (invisible to real users; helps reduce bot submissions) -->
          <div style="position:absolute; left:-9999px; top:auto; width:1px; height:1px; overflow:hidden;" aria-hidden="true">
            <label for="contact_extra">Leave this field blank</label>
            <input id="contact_extra" name="contact[extra]" type="text" autocomplete="off" tabindex="-1" />
          </div>

          <div class="ff-row">
            <div class="ff-field">
              <label>Enter your Full Name</label>
              <input type="text" name="contact[name]" id="franchise_name" placeholder="Sumit Chavda" required>
            </div>

            <div class="ff-field">
              <label>Enter your Phone Number</label>
              <input type="tel" name="contact[phone]" id="franchise_phone" placeholder="+91 9876543210" required>
            </div>

            <div class="ff-field">
              <label>Enter your Mail ID</label>
              <input type="email" name="contact[email]" id="franchise_email" placeholder="sumit@business.com" required>
            </div>

            <div class="ff-field">
              <label>Enter your City or Pincode</label>
              <input type="text" name="contact[city]" id="franchise_city" placeholder="400001" required>
            </div>
          </div>

          <!-- Hidden field to include all details in email body -->
          <input type="hidden" name="contact[body]" id="franchise_body" value="">

          <button type="submit" class="ff-submit">SUBMIT</button>

          <!-- SUCCESS MESSAGE (Liquid) - rendered by Shopify after successful submit -->
          {% if form.posted_successfully? %}
            <div class="ff-success" id="franchise-success">
              Thank you! Our personnel will contact you shortly.
            </div>
          {% endif %}

        {% endform %}
      </div>

    </div>
  </div>

  <style>
    .franchise-form-section {
      width: 100%;
      display: flex;
      justify-content: center;
    }

    .franchise-form-wrapper {
      width: 100%;
      max-width: 1100px;
      text-align: center;
      margin: 0 auto;
      font-family: inherit;
    }

    .franchise-form-section .ff-title {
      font-size: 24px;
      letter-spacing: 1px;
      font-weight: 500;
      margin-bottom: 10px;
      color: #1a1a1a;
    }

    .franchise-form-section .ff-subtitle {
      max-width: 600px;
      margin: 0 auto 40px;
      color: #555;
      font-size: 14px;
      line-height: 1.6;
    }

    .franchise-form-section .ff-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
      margin-bottom: 30px;
    }

    .franchise-form-section .ff-field {
      text-align: left;
      width: 100%;
    }

    .franchise-form-section .ff-field label {
      display: block;
      font-size: 11px;
      margin-bottom: 5px;
      color: #888;
      letter-spacing: 0.3px;
    }

    .franchise-form-section .ff-field input {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 14px;
    }

    .franchise-form-section .ff-submit {
      background: #A68380;
      color: #fff;
      padding: 10px 40px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      letter-spacing: 0.5px;
      transition: 0.2s;
      font-size: 14px;
    }

    .franchise-form-section .ff-submit:hover {
      opacity: 0.85;
    }

    .ff-success {
      margin-top: 20px;
      padding: 15px;
      background-color: #d4edda;
      border: 1px solid #c3e6cb;
      color: #155724;
      border-radius: 6px;
      font-size: 14px;
    }

    @media (max-width: 900px) {
      .franchise-form-section .ff-row {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 600px) {
      .franchise-form-section .ff-row {
        grid-template-columns: 1fr;
      }
    }
  </style>
</section>

{% raw %}
<script>
document.addEventListener('DOMContentLoaded', function () {
  // Get the form element
  var form = document.querySelector('.franchise-form form');
  
  if (form) {
    form.addEventListener('submit', function(e) {
      // Collect form data and populate hidden body field
      var name = document.getElementById('franchise_name').value;
      var phone = document.getElementById('franchise_phone').value;
      var email = document.getElementById('franchise_email').value;
      var city = document.getElementById('franchise_city').value;
      
      // Create formatted message body
      var bodyContent = 
        "NEW FRANCHISE LEAD\n\n" +
        "Full Name: " + name + "\n" +
        "Phone Number: " + phone + "\n" +
        "Email: " + email + "\n" +
        "City/Pincode: " + city + "\n\n" +
        "Submitted on: " + new Date().toLocaleString();
      
      document.getElementById('franchise_body').value = bodyContent;
    });
  }

  // Show success message if form was posted
  try {
    var showSuccess = false;
    if (window.location.hash && window.location.hash.indexOf('franchise-success') !== -1) {
      showSuccess = true;
    }
    var params = new URLSearchParams(window.location.search);
    if (params.get('contact_posted') === 'true' || params.has('contact_posted')) {
      showSuccess = true;
    }
    if (showSuccess) {
      var el = document.getElementById('franchise-success');
      if (el) {
        el.style.display = 'block';
        try { el.scrollIntoView({behavior:'smooth', block:'center'}); } catch(e){}
      }
    }
  } catch (e) {
    console.warn('franchise-form helper script error', e);
  }
});
</script>
{% endraw %}

{% schema %}
{
  "name": "Franchise Form",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Form Title",
      "default": "FORM"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Form Subtitle",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquip ex ea commodo consequat."
    }
  ],
  "presets": [
    {
      "name": "Franchise Form"
    }
  ]
}
{% endschema %}