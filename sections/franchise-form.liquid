<!-- Create a new section file: franchise-form.liquid -->

{% schema %}
{
  "name": "Franchise Form",
  "class": "franchise-form-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Main Title",
      "default": "FORM"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut alconsequat."
    },
    {
      "type": "text",
      "id": "block_1_title",
      "label": "Block 1 Title",
      "default": "Follow your full Name"
    },
    {
      "type": "text",
      "id": "block_2_title",
      "label": "Block 2 Title", 
      "default": "Follow your Phone Number"
    },
    {
      "type": "text",
      "id": "block_2_content",
      "label": "Block 2 Content",
      "default": "491 9876543210"
    },
    {
      "type": "text",
      "id": "block_3_title",
      "label": "Block 3 Title",
      "default": "Follow your Mail ID"
    },
    {
      "type": "text",
      "id": "block_3_content",
      "label": "Block 3 Content",
      "default": "rabonmethx@business.com"
    },
    {
      "type": "text",
      "id": "block_4_title",
      "label": "Block 4 Title",
      "default": "ZIP Code"
    },
    {
      "type": "text",
      "id": "block_4_content",
      "label": "Block 4 Content",
      "default": "400001"
    },
    {
      "type": "text",
      "id": "submit_text",
      "label": "Submit Button Text",
      "default": "SUBMIT"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Color",
      "default": "#e5e5e5"
    },
    {
      "type": "color",
      "id": "block_bg_color",
      "label": "Block Background Color",
      "default": "#f8f9fa"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content Padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Franchise Form",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}

<style>
  /* Section Styles */
  .franchise-form-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.content_padding }}px 20px;
    font-family: Arial, sans-serif;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-title {
    font-size: 3rem;
    font-weight: bold;
    margin-bottom: 20px;
    color: {{ section.settings.accent_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-description {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 30px;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-divider {
    height: 2px;
    background-color: {{ section.settings.divider_color }};
    margin: 40px auto;
    border: none;
    max-width: 200px;
  }

  /* Grid Layout for Desktop */
  .franchise-form-section-{{ section.id }} .franchise-form-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    margin-bottom: 50px;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-block {
    background-color: {{ section.settings.block_bg_color }};
    padding: 30px 25px;
    border-radius: 8px;
    text-align: center;
    transition: all 0.3s ease;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-block:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
  }

  .franchise-form-section-{{ section.id }} .franchise-block-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 15px;
    color: {{ section.settings.accent_color }};
  }

  .franchise-form-section-{{ section.id }} .franchise-block-content {
    font-size: 1rem;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-input {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
    margin-top: 10px;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-input:focus {
    border-color: {{ section.settings.accent_color }};
    outline: none;
  }

  .franchise-form-section-{{ section.id }} .franchise-contact-link {
    color: {{ section.settings.accent_color }};
    text-decoration: none;
    font-weight: 500;
  }

  .franchise-form-section-{{ section.id }} .franchise-contact-link:hover {
    text-decoration: underline;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-submit {
    background-color: {{ section.settings.accent_color }};
    color: white;
    border: none;
    padding: 15px 50px;
    font-size: 1.1rem;
    font-weight: 600;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: block;
    margin: 0 auto;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-submit:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  /* Mobile Styles - 4 rows */
  @media (max-width: 768px) {
    .franchise-form-section-{{ section.id }} .franchise-form-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    
    .franchise-form-section-{{ section.id }} .franchise-form-block {
      padding: 25px 20px;
    }
    
    .franchise-form-section-{{ section.id }} .franchise-form-title {
      font-size: 2.2rem;
    }
    
    .franchise-form-section-{{ section.id }} .franchise-form-description {
      font-size: 1rem;
    }
  }

  /* Desktop-only styles */
  @media screen and (min-width: 769px) {
    .franchise-form-section-{{ section.id }} .franchise-form-grid {
      display: grid;
    }
  }
</style>

<div class="franchise-form-section-{{ section.id }}">
  <div class="franchise-form-container">
    <!-- Header Section -->
    <div class="franchise-form-header">
      <h1 class="franchise-form-title">{{ section.settings.title }}</h1>
      <p class="franchise-form-description">{{ section.settings.description }}</p>
      <hr class="franchise-form-divider">
    </div>

    <!-- 4-Grid Information Blocks -->
    <div class="franchise-form-grid">
      <!-- Block 1: Full Name Input -->
      <div class="franchise-form-block">
        <h3 class="franchise-block-title">{{ section.settings.block_1_title }}</h3>
        <div class="franchise-block-content">
          <input type="text" 
                 class="franchise-form-input" 
                 placeholder="Enter your full name"
                 id="franchise-full-name">
        </div>
      </div>

      <!-- Block 2: Phone Number -->
      <div class="franchise-form-block">
        <h3 class="franchise-block-title">{{ section.settings.block_2_title }}</h3>
        <div class="franchise-block-content">
          {{ section.settings.block_2_content }}
        </div>
      </div>

      <!-- Block 3: Email -->
      <div class="franchise-form-block">
        <h3 class="franchise-block-title">{{ section.settings.block_3_title }}</h3>
        <div class="franchise-block-content">
          <a href="mailto:{{ section.settings.block_3_content }}" class="franchise-contact-link">
            {{ section.settings.block_3_content }}
          </a>
        </div>
      </div>

      <!-- Block 4: ZIP Code -->
      <div class="franchise-form-block">
        <h3 class="franchise-block-title">{{ section.settings.block_4_title }}</h3>
        <div class="franchise-block-content">
          {{ section.settings.block_4_content }}
        </div>
      </div>
    </div>

    <!-- Bottom Divider -->
    <hr class="franchise-form-divider">

    <!-- Submit Button -->
    <button type="button" class="franchise-form-submit" id="franchise-submit-btn">
      {{ section.settings.submit_text }}
    </button>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const submitBtn = document.getElementById('franchise-submit-btn');
    const nameInput = document.getElementById('franchise-full-name');
    
    if (submitBtn) {
      submitBtn.addEventListener('click', function() {
        if (!nameInput.value.trim()) {
          alert('Please enter your full name before submitting.');
          nameInput.focus();
          return;
        }
        
        // Here you would typically send the data to your server
        // For now, we'll just show a success message
        submitBtn.textContent = 'Submitting...';
        submitBtn.disabled = true;
        
        setTimeout(function() {
          alert(`Thank you ${nameInput.value}! Your franchise inquiry has been received. We will contact you shortly.`);
          nameInput.value = '';
          submitBtn.textContent = '{{ section.settings.submit_text }}';
          submitBtn.disabled = false;
        }, 1500);
      });
    }
  });
</script>