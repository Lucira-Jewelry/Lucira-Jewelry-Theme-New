<!-- Create a new section file: franchise-form.liquid -->

{% schema %}
{
  "name": "Franchise Form",
  "class": "franchise-form-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Form Title",
      "default": "FORM"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut alconsequat."
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form Section Title",
      "default": "Franchise Inquiry"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "+491 9876543210"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email Address",
      "default": "rabonmethx@business.com"
    },
    {
      "type": "text",
      "id": "zip_code",
      "label": "ZIP Code",
      "default": "400001"
    },
    {
      "type": "text",
      "id": "submit_text",
      "label": "Submit Button Text",
      "default": "SUBMIT"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#1e3c72"
    },
    {
      "type": "color",
      "id": "secondary_color",
      "label": "Secondary Color",
      "default": "#2a5298"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f8f9fa"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content Padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "feature_text",
          "label": "Feature Text",
          "default": "Proven Business Model"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {
              "value": "check",
              "label": "Check"
            },
            {
              "value": "shield",
              "label": "Shield"
            },
            {
              "value": "support",
              "label": "Support"
            },
            {
              "value": "training",
              "label": "Training"
            },
            {
              "value": "marketing",
              "label": "Marketing"
            }
          ],
          "default": "check"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Franchise Form",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}

<style>
  /* Section Styles */
  .franchise-form-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.content_padding }}px 20px;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 40px;
    background-color: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }

  .franchise-form-section-{{ section.id }} .franchise-form-content {
    flex: 1;
    min-width: 300px;
    padding: 50px 40px;
    background: linear-gradient(135deg, {{ section.settings.primary_color }} 0%, {{ section.settings.secondary_color }} 100%);
    color: white;
    text-align: {{ section.settings.content_alignment }};
  }

  .franchise-form-section-{{ section.id }} .franchise-form-content h1 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    font-weight: 700;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-content p {
    font-size: 1.1rem;
    margin-bottom: 30px;
    opacity: 0.9;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-divider {
    height: 3px;
    width: 80px;
    background-color: #4CAF50;
    margin: 30px 0;
    {% if section.settings.content_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% elsif section.settings.content_alignment == 'right' %}
      margin-left: auto;
    {% endif %}
  }

  .franchise-form-section-{{ section.id }} .franchise-form {
    flex: 1;
    min-width: 300px;
    padding: 50px 40px;
  }

  .franchise-form-section-{{ section.id }} .franchise-form h2 {
    font-size: 1.8rem;
    margin-bottom: 30px;
    color: {{ section.settings.primary_color }};
    font-weight: 600;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-group {
    margin-bottom: 25px;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: #444;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-input {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-input:focus {
    border-color: {{ section.settings.secondary_color }};
    box-shadow: 0 0 0 2px {{ section.settings.secondary_color | color_modify: 'alpha', 0.2 }};
    outline: none;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-contact-info {
    background-color: #f8f9fa;
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 25px;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-contact-item {
    margin-bottom: 15px;
    display: flex;
    align-items: center;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-contact-item:last-child {
    margin-bottom: 0;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-contact-icon {
    width: 24px;
    height: 24px;
    margin-right: 10px;
    color: {{ section.settings.primary_color }};
  }

  .franchise-form-section-{{ section.id }} .franchise-form-contact-link {
    color: {{ section.settings.primary_color }};
    text-decoration: none;
    transition: color 0.3s;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-contact-link:hover {
    color: {{ section.settings.secondary_color }};
    text-decoration: underline;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-submit {
    background: linear-gradient(135deg, {{ section.settings.primary_color }} 0%, {{ section.settings.secondary_color }} 100%);
    color: white;
    border: none;
    padding: 14px 30px;
    font-size: 1.1rem;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.3s ease;
    width: 100%;
    margin-top: 10px;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px {{ section.settings.secondary_color | color_modify: 'alpha', 0.3 }};
  }

  .franchise-form-section-{{ section.id }} .franchise-form-features {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 40px;
    {% if section.settings.content_alignment == 'center' %}
      justify-content: center;
    {% elsif section.settings.content_alignment == 'right' %}
      justify-content: flex-end;
    {% endif %}
  }

  .franchise-form-section-{{ section.id }} .franchise-form-feature {
    flex: 1;
    min-width: 200px;
    display: flex;
    align-items: center;
    {% if section.settings.content_alignment == 'center' %}
      justify-content: center;
    {% elsif section.settings.content_alignment == 'right' %}
      justify-content: flex-end;
    {% endif %}
  }

  .franchise-form-section-{{ section.id }} .franchise-form-feature-icon {
    width: 40px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 15px;
  }

  /* Responsive styles */
  @media (max-width: 768px) {
    .franchise-form-section-{{ section.id }} .franchise-form-container {
      flex-direction: column;
    }
    
    .franchise-form-section-{{ section.id }} .franchise-form-content,
    .franchise-form-section-{{ section.id }} .franchise-form {
      padding: 30px 25px;
    }
    
    .franchise-form-section-{{ section.id }} .franchise-form-content h1 {
      font-size: 2rem;
    }
    
    .franchise-form-section-{{ section.id }} .franchise-form-features {
      flex-direction: column;
      gap: 15px;
    }
    
    .franchise-form-section-{{ section.id }} .franchise-form-feature {
      min-width: 100%;
      justify-content: flex-start;
    }
  }

  /* Desktop-only styles */
  @media screen and (min-width: 769px) {
    .franchise-form-section-{{ section.id }} .franchise-form-content {
      padding: {{ section.settings.content_padding }}px;
    }
  }
</style>

<div class="franchise-form-section-{{ section.id }}">
  <div class="franchise-form-container">
    <div class="franchise-form-content">
      <h1>{{ section.settings.title }}</h1>
      <p>{{ section.settings.description }}</p>
      
      <div class="franchise-form-divider"></div>
      
      <div class="franchise-form-features">
        {% for block in section.blocks %}
          <div class="franchise-form-feature" {{ block.shopify_attributes }}>
            <div class="franchise-form-feature-icon">
              {% case block.settings.icon %}
                {% when 'check' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                  </svg>
                {% when 'shield' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  </svg>
                {% when 'support' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <circle cx="12" cy="12" r="4"></circle>
                    <line x1="4.93" y1="4.93" x2="9.17" y2="9.17"></line>
                    <line x1="14.83" y1="14.83" x2="19.07" y2="19.07"></line>
                    <line x1="14.83" y1="9.17" x2="19.07" y2="4.93"></line>
                    <line x1="4.93" y1="19.07" x2="9.17" y2="14.83"></line>
                  </svg>
                {% when 'training' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                  </svg>
                {% when 'marketing' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
                  </svg>
              {% endcase %}
            </div>
            <span>{{ block.settings.feature_text }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
    
    <div class="franchise-form">
      <h2>{{ section.settings.form_title }}</h2>
      
      {% form 'contact', class: 'franchise-contact-form' %}
        {% if form.posted_successfully? %}
          <p class="form-success">Thank you for your inquiry! We'll be in touch soon.</p>
        {% endif %}
        
        {{ form.errors | default_errors }}
        
        <div class="franchise-form-group">
          <label class="franchise-form-label" for="ContactFormName">Full Name</label>
          <input type="text" id="ContactFormName" name="contact[name]" class="franchise-form-input" required>
        </div>
        
        <div class="franchise-form-group">
          <label class="franchise-form-label" for="ContactFormPhone">Phone Number</label>
          <input type="tel" id="ContactFormPhone" name="contact[phone]" class="franchise-form-input" required>
        </div>
        
        <div class="franchise-form-group">
          <label class="franchise-form-label" for="ContactFormEmail">Email Address</label>
          <input type="email" id="ContactFormEmail" name="contact[email]" class="franchise-form-input" required>
        </div>
        
        <div class="franchise-form-group">
          <label class="franchise-form-label" for="ContactFormZipCode">ZIP Code</label>
          <input type="text" id="ContactFormZipCode" name="contact[zip_code]" class="franchise-form-input" required>
        </div>
        
        <input type="hidden" name="contact[form_type]" value="franchise">
        
        <div class="franchise-form-contact-info">
          <h3 style="margin-bottom: 15px; color: {{ section.settings.primary_color }};">Contact Information</h3>
          
          <div class="franchise-form-contact-item">
            <svg class="franchise-form-contact-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15.05 5A5 5 0 0 1 19 8.95M15.05 1A9 9 0 0 1 23 8.94m-1 7.98v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <span>{{ section.settings.phone_number }}</span>
          </div>
          
          <div class="franchise-form-contact-item">
            <svg class="franchise-form-contact-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <a href="mailto:{{ section.settings.email }}" class="franchise-form-contact-link">{{ section.settings.email }}</a>
          </div>
          
          <div class="franchise-form-contact-item">
            <svg class="franchise-form-contact-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>ZIP Code: {{ section.settings.zip_code }}</span>
          </div>
        </div>
        
        <button type="submit" class="franchise-form-submit">{{ section.settings.submit_text }}</button>
      {% endform %}
    </div>
  </div>
</div>

<script>
  // Form validation and enhancement
  document.addEventListener('DOMContentLoaded', function() {
    const franchiseForm = document.querySelector('.franchise-contact-form');
    
    if (franchiseForm) {
      franchiseForm.addEventListener('submit', function(e) {
        const requiredFields = franchiseForm.querySelectorAll('[required]');
        let isValid = true;
        
        requiredFields.forEach(field => {
          if (!field.value.trim()) {
            isValid = false;
            field.style.borderColor = '#ff4444';
          } else {
            field.style.borderColor = '';
          }
        });
        
        if (!isValid) {
          e.preventDefault();
          alert('Please fill in all required fields.');
        }
      });
    }
  });
</script>