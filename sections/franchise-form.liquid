{% comment %}
  Franchise Form Section
{% endcomment %}
<section class="franchise-form-section">
  <div class="page-width">
    <div class="franchise-form-wrapper">

      <h2 class="ff-title">{{ section.settings.title }}</h2>
      <p class="ff-subtitle">{{ section.settings.subtitle }}</p>

      <!-- FINAL WORKING FORM (use Shopify form tag only - DO NOT wrap in another <form>) -->
      <div class="franchise-form">
        {% form 'contact' %}
          <!-- Force Shopify email routing -->
          <input type="hidden" name="contact[form_type]" value="Franchise Form Submission">
          <input type="hidden" name="contact[subject]" value="New Franchise Lead - Lucira Jewelry">

          <div class="ff-row">
            <div class="ff-field">
              <label>Enter your Full Name</label>
              <input type="text" name="contact[name]" placeholder="Sumit Chavda" required>
            </div>

            <div class="ff-field">
              <label>Enter your Phone Number</label>
              <input type="text" name="contact[phone]" placeholder="+91 9876543210" required>
            </div>

            <div class="ff-field">
              <label>Enter your Mail ID</label>
              <input type="email" name="contact[email]" placeholder="sumit@business.com" required>
            </div>

            <div class="ff-field">
              <label>Enter your City or Pincode</label>
              <input type="text" name="contact[city]" placeholder="400001" required>
            </div>
          </div>

          <button type="submit" class="ff-submit">SUBMIT</button>

          <!-- SUCCESS MESSAGE (Liquid) - MUST be inside the form block so `form` object is available -->
          {% if form.posted_successfully? %}
            <div class="ff-success" id="franchise-success">
              Thank you! Our personnel will contact you shortly.
            </div>
          {% endif %}

        {% endform %}
      </div>

    </div>
  </div>
  <style>
    .franchise-form-section {
      width: 100%;
      padding: 60px 0;
      display: flex;
      justify-content: center;
    }

    .franchise-form-wrapper {
      width: 100%;
      max-width: 1100px;
      text-align: center;
      margin: 0 auto;
      font-family: inherit;
    }

    .franchise-form-section .ff-title {
      font-size: 24px;
      letter-spacing: 1px;
      font-weight: 500;
      margin-bottom: 10px;
      color: #1a1a1a;
    }

    .franchise-form-section .ff-subtitle {
      max-width: 600px;
      margin: 0 auto 40px;
      color: #555;
      font-size: 14px;
      line-height: 1.6;
    }

    .franchise-form-section .ff-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
      margin-bottom: 30px;
    }

    .franchise-form-section .ff-field {
      text-align: left;
      width: 100%;
    }

    .franchise-form-section .ff-field label {
      display: block;
      font-size: 11px;
      margin-bottom: 5px;
      color: #888;
      letter-spacing: 0.3px;
    }

    .franchise-form-section .ff-field input {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 14px;
    }

    .franchise-form-section .ff-submit {
      background: #A68380;
      color: #fff;
      padding: 10px 40px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      letter-spacing: 0.5px;
      transition: 0.2s;
      font-size: 14px;
    }

    .franchise-form-section .ff-submit:hover {
      opacity: 0.85;
    }

    @media (max-width: 900px) {
      .franchise-form-section .ff-row {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 600px) {
      .franchise-form-section .ff-row {
        grid-template-columns: 1fr;
      }
    }
  </style>
</section>

{% raw %}
<script>
document.addEventListener("DOMContentLoaded", function () {
  // IDs/classes in the form
  const form = document.querySelector('.franchise-form form') || document.querySelector('.franchise-form');
  // If your HTML structure differs, this will still try to pick the form element

  // Replace with your webhook endpoint (Zapier/Make/your server). Leave blank to disable.
  const WEBHOOK_URL = ""; // e.g. "https://hooks.zapier.com/hooks/catch/123456/abcdef"

  // Create (or reuse) the success element (for JS-posted success)
  let successEl = document.querySelector('.ff-success');
  if (!successEl) {
      successEl = document.createElement('div');
      successEl.className = 'ff-success';
      successEl.id = 'franchise-success';
      successEl.style.display = 'none';
      successEl.textContent = 'Thank you! Our team will contact you shortly.';
      // Append after the form wrapper
      const wrapper = document.querySelector('.franchise-form-wrapper') || document.body;
      wrapper.appendChild(successEl);
  }

  // Create (or reuse) an inline error element
  let errorEl = document.querySelector('.ff-error');
  if (!errorEl) {
      errorEl = document.createElement('div');
      errorEl.className = 'ff-error';
      errorEl.style.display = 'none';
      errorEl.style.color = '#b00020';
      errorEl.style.marginTop = '12px';
      const wrapper = document.querySelector('.franchise-form-wrapper') || document.body;
      wrapper.appendChild(errorEl);
  }

  // If form not found, stop
  if (!form) return;

  form.addEventListener('submit', function (e) {
      e.preventDefault();

      // Hide messages
      successEl.style.display = 'none';
      errorEl.style.display = 'none';
      errorEl.textContent = '';

      // Gather form data (works for inputs, selects, textareas)
      const fd = new FormData(form);

      // Ensure Shopify's form tag fields are present
      // If you use {% form 'contact' %} these should already be present.
      if (!fd.get('contact[subject]')) {
        fd.set('contact[subject]', 'New Franchise Lead - Lucira Jewelry');
      }
      if (!fd.get('contact[form_type]')) {
        fd.set('contact[form_type]', 'Franchise Form Submission');
      }

      // Disable submit button to prevent double-submits
      const submitButton = form.querySelector('[type="submit"]');
      if (submitButton) submitButton.disabled = true;

      // 1) Submit to Shopify contact endpoint
      fetch('/contact', {
        method: 'POST',
        body: fd,
        credentials: 'same-origin'
      })
      .then(response => {
        // Shopify often responds with 200 and redirects — treat 200/redirect as success
        if (!response.ok && response.status !== 200 && response.status !== 302) {
          throw new Error('Network response was not OK');
        }
        // show on-page success message
        successEl.style.display = 'block';

        // optional: clear form
        form.reset();

        // 2) Send data to your webhook (for sending an email / saving to CRM)
        if (WEBHOOK_URL) {
          // convert to JSON
          const json = {};
          fd.forEach((value, key) => {
            // convert 'contact[name]' to 'name' for webhook convenience
            const simpleKey = key.replace(/^contact\[(.*)\]$/, '$1');
            json[simpleKey] = value;
          });
          // Add metadata
          json._submitted_at = new Date().toISOString();
          json._subject = fd.get('contact[subject]') || '';

          // send webhook (fire-and-forget)
          fetch(WEBHOOK_URL, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(json)
          }).catch(err => {
            // non-blocking: log to console; you may show a small warning if needed
            console.warn('Webhook post failed:', err);
          });
        }
      })
      .catch(err => {
        console.error(err);
        errorEl.textContent = 'Something went wrong while submitting the form. Please try again or contact us directly.';
        errorEl.style.display = 'block';
      })
      .finally(() => {
        if (submitButton) submitButton.disabled = false;
      });
  });
});
</script>
{% endraw %}

{% schema %}
{
  "name": "Franchise Form",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Form Title",
      "default": "FORM"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Form Subtitle",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquip ex ea commodo consequat."
    }
  ],
  "presets": [
    {
      "name": "Franchise Form"
    }
  ]
}
{% endschema %}
