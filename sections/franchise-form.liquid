<!-- Create a new section file: franchise-form.liquid -->

{% schema %}
{
  "name": "Franchise Form",
  "class": "franchise-form-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Main Title",
      "default": "FORM"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut alconsequat."
    },
    {
      "type": "text",
      "id": "full_name_label",
      "label": "Full Name Label",
      "default": "Follow your full Name"
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone Label",
      "default": "Follow your Phone Number"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "491 9876543210"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email Label",
      "default": "Follow your Mail ID"
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Email Address",
      "default": "rabonmethx@business.com"
    },
    {
      "type": "text",
      "id": "zip_code",
      "label": "ZIP Code",
      "default": "400001"
    },
    {
      "type": "text",
      "id": "submit_text",
      "label": "Submit Button Text",
      "default": "SUBMIT"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Color",
      "default": "#e5e5e5"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content Padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Franchise Form",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}

<style>
  /* Section Styles */
  .franchise-form-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.content_padding }}px 20px;
    font-family: Arial, sans-serif;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-container {
    max-width: 600px;
    margin: 0 auto;
    background: white;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    overflow: hidden;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-content {
    padding: 50px 40px;
    text-align: {{ section.settings.content_alignment }};
  }

  .franchise-form-section-{{ section.id }} .franchise-form-title {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 20px;
    color: {{ section.settings.accent_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-description {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 30px;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-divider {
    height: 1px;
    background-color: {{ section.settings.divider_color }};
    margin: 30px 0;
    border: none;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-fields {
    text-align: left;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-group {
    margin-bottom: 25px;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-label {
    display: block;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: {{ section.settings.accent_color }};
  }

  .franchise-form-section-{{ section.id }} .franchise-form-input {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-input:focus {
    border-color: {{ section.settings.accent_color }};
    outline: none;
  }

  .franchise-form-section-{{ section.id }} .franchise-contact-info {
    background-color: #f9f9f9;
    padding: 20px;
    border-radius: 6px;
    margin: 25px 0;
  }

  .franchise-form-section-{{ section.id }} .franchise-contact-item {
    margin-bottom: 15px;
    padding-left: 20px;
    position: relative;
  }

  .franchise-form-section-{{ section.id }} .franchise-contact-item:last-child {
    margin-bottom: 0;
  }

  .franchise-form-section-{{ section.id }} .franchise-contact-item strong {
    color: {{ section.settings.accent_color }};
  }

  .franchise-form-section-{{ section.id }} .franchise-contact-item ul {
    margin: 8px 0;
    padding-left: 20px;
  }

  .franchise-form-section-{{ section.id }} .franchise-contact-item li {
    margin-bottom: 5px;
    list-style-type: none;
    position: relative;
  }

  .franchise-form-section-{{ section.id }} .franchise-contact-item li:before {
    content: "•";
    color: {{ section.settings.accent_color }};
    font-weight: bold;
    position: absolute;
    left: -15px;
  }

  .franchise-form-section-{{ section.id }} .franchise-contact-link {
    color: {{ section.settings.accent_color }};
    text-decoration: none;
    font-weight: 500;
  }

  .franchise-form-section-{{ section.id }} .franchise-contact-link:hover {
    text-decoration: underline;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-submit {
    background-color: {{ section.settings.accent_color }};
    color: white;
    border: none;
    padding: 15px 40px;
    font-size: 1.1rem;
    font-weight: 600;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
    width: 100%;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .franchise-form-section-{{ section.id }} .franchise-form-submit:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  /* Responsive styles */
  @media (max-width: 768px) {
    .franchise-form-section-{{ section.id }} .franchise-form-content {
      padding: 30px 25px;
    }
    
    .franchise-form-section-{{ section.id }} .franchise-form-title {
      font-size: 2rem;
    }
  }

  /* Desktop-only styles */
  @media screen and (min-width: 769px) {
    .franchise-form-section-{{ section.id }} .franchise-form-content {
      padding: {{ section.settings.content_padding }}px;
    }
  }
</style>

<div class="franchise-form-section-{{ section.id }}">
  <div class="franchise-form-container">
    <div class="franchise-form-content">
      <!-- Main Title -->
      <h1 class="franchise-form-title">{{ section.settings.title }}</h1>
      
      <!-- Description -->
      <p class="franchise-form-description">{{ section.settings.description }}</p>
      
      <!-- First Divider -->
      <hr class="franchise-form-divider">
      
      <!-- Form Section -->
      <div class="franchise-form-fields">
        {% form 'contact', class: 'franchise-contact-form' %}
          {% if form.posted_successfully? %}
            <p class="form-success">Thank you for your inquiry! We'll be in touch soon.</p>
          {% endif %}
          
          {{ form.errors | default_errors }}
          
          <!-- Full Name Field -->
          <div class="franchise-form-group">
            <h3 class="franchise-form-label">{{ section.settings.full_name_label }}</h3>
            <input type="text" 
                   id="ContactFormName" 
                   name="contact[name]" 
                   class="franchise-form-input" 
                   placeholder="Enter your full name"
                   required>
          </div>
          
          <!-- Contact Information -->
          <div class="franchise-contact-info">
            <!-- Phone Information -->
            <div class="franchise-contact-item">
              <strong>{{ section.settings.phone_label }}</strong>
              <ul>
                <li>{{ section.settings.phone_number }}</li>
              </ul>
            </div>
            
            <!-- Second Divider -->
            <hr class="franchise-form-divider" style="margin: 20px 0;">
            
            <!-- Email Information -->
            <div class="franchise-contact-item">
              <strong>{{ section.settings.email_label }}</strong>
              <ul>
                <li>
                  <a href="mailto:{{ section.settings.email_address }}" class="franchise-contact-link">
                    {{ section.settings.email_address }}
                  </a>
                </li>
                <li>{{ section.settings.zip_code }}</li>
              </ul>
            </div>
          </div>
          
          <!-- Hidden fields for form type -->
          <input type="hidden" name="contact[form_type]" value="franchise_inquiry">
          <input type="hidden" name="contact[phone_reference]" value="{{ section.settings.phone_number }}">
          <input type="hidden" name="contact[zip_reference]" value="{{ section.settings.zip_code }}">
          
          <!-- Third Divider -->
          <hr class="franchise-form-divider">
          
          <!-- Submit Button -->
          <button type="submit" class="franchise-form-submit">
            {{ section.settings.submit_text }}
          </button>
        {% endform %}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const franchiseForm = document.querySelector('.franchise-contact-form');
    
    if (franchiseForm) {
      franchiseForm.addEventListener('submit', function(e) {
        const nameField = document.getElementById('ContactFormName');
        
        if (!nameField.value.trim()) {
          e.preventDefault();
          alert('Please enter your full name.');
          nameField.focus();
          return;
        }
        
        // Add loading state
        const submitBtn = franchiseForm.querySelector('.franchise-form-submit');
        submitBtn.textContent = 'Submitting...';
        submitBtn.disabled = true;
      });
    }
  });
</script>