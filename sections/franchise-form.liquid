{% comment %}
  Franchise Form Section - Alternative without Shopify form (No hCaptcha)
  This uses AJAX to submit to a custom endpoint
{% endcomment %}
<section class="franchise-form-section">
  <div class="page-width">
    <div class="franchise-form-wrapper">

      <h2 class="ff-title">{{ section.settings.title }}</h2>
      <p class="ff-subtitle">{{ section.settings.subtitle }}</p>

      <!-- CUSTOM FORM (bypasses Shopify's hCaptcha) -->
      <div class="franchise-form">
        <form id="custom-franchise-form" method="POST">
          
          <div class="ff-row">
            <div class="ff-field">
              <label>Enter your Full Name</label>
              <input type="text" name="name" id="franchise_name" placeholder="Sumit Chavda" required>
            </div>

            <div class="ff-field">
              <label>Enter your Phone Number</label>
              <input type="tel" name="phone" id="franchise_phone" placeholder="+91 9876543210" required>
            </div>

            <div class="ff-field">
              <label>Enter your Mail ID</label>
              <input type="email" name="email" id="franchise_email" placeholder="sumit@business.com" required>
            </div>

            <div class="ff-field">
              <label>Enter your City or Pincode</label>
              <input type="text" name="city" id="franchise_city" placeholder="400001" required>
            </div>
          </div>

          <button type="submit" class="ff-submit" id="submit-btn">SUBMIT</button>

          <!-- SUCCESS MESSAGE -->
          <div class="ff-success" id="franchise-success" style="display:none;">
            Thank you! Our personnel will contact you shortly.
          </div>

          <!-- ERROR MESSAGE -->
          <div class="ff-error" id="franchise-error" style="display:none;">
            Something went wrong. Please try again or email us directly at tech@lucirajewelry.com
          </div>

        </form>
      </div>

    </div>
  </div>

  <style>
    .franchise-form-section {
      width: 100%;
      display: flex;
      justify-content: center;
    }

    .franchise-form-wrapper {
      width: 100%;
      max-width: 1100px;
      text-align: center;
      margin: 0 auto;
      font-family: inherit;
    }

    .franchise-form-section .ff-title {
      font-size: 24px;
      letter-spacing: 1px;
      font-weight: 500;
      margin-bottom: 10px;
      color: #1a1a1a;
    }

    .franchise-form-section .ff-subtitle {
      max-width: 600px;
      margin: 0 auto 40px;
      color: #555;
      font-size: 14px;
      line-height: 1.6;
    }

    .franchise-form-section .ff-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
      margin-bottom: 30px;
    }

    .franchise-form-section .ff-field {
      text-align: left;
      width: 100%;
    }

    .franchise-form-section .ff-field label {
      display: block;
      font-size: 11px;
      margin-bottom: 5px;
      color: #888;
      letter-spacing: 0.3px;
    }

    .franchise-form-section .ff-field input {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 14px;
    }

    .franchise-form-section .ff-submit {
      background: #A68380;
      color: #fff;
      padding: 10px 40px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      letter-spacing: 0.5px;
      transition: 0.2s;
      font-size: 14px;
    }

    .franchise-form-section .ff-submit:hover {
      opacity: 0.85;
    }

    .franchise-form-section .ff-submit:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .ff-success {
      margin-top: 20px;
      padding: 15px;
      background-color: #d4edda;
      border: 1px solid #c3e6cb;
      color: #155724;
      border-radius: 6px;
      font-size: 14px;
    }

    .ff-error {
      margin-top: 20px;
      padding: 15px;
      background-color: #f8d7da;
      border: 1px solid #f5c6cb;
      color: #721c24;
      border-radius: 6px;
      font-size: 14px;
    }

    @media (max-width: 900px) {
      .franchise-form-section .ff-row {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 600px) {
      .franchise-form-section .ff-row {
        grid-template-columns: 1fr;
      }
    }
  </style>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var form = document.getElementById('custom-franchise-form');
  var submitBtn = document.getElementById('submit-btn');
  var successMsg = document.getElementById('franchise-success');
  var errorMsg = document.getElementById('franchise-error');

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    
    // Disable submit button
    submitBtn.disabled = true;
    submitBtn.textContent = 'SUBMITTING...';
    
    // Hide previous messages
    successMsg.style.display = 'none';
    errorMsg.style.display = 'none';
    
    // Get form data
    var formData = {
      name: document.getElementById('franchise_name').value,
      phone: document.getElementById('franchise_phone').value,
      email: document.getElementById('franchise_email').value,
      city: document.getElementById('franchise_city').value
    };
    
    // Create email body
    var emailBody = 
      "NEW FRANCHISE LEAD\n\n" +
      "Full Name: " + formData.name + "\n" +
      "Phone Number: " + formData.phone + "\n" +
      "Email: " + formData.email + "\n" +
      "City/Pincode: " + formData.city + "\n\n" +
      "Submitted on: " + new Date().toLocaleString();
    
    // Submit via AJAX to Shopify's contact endpoint
    var xhr = new XMLHttpRequest();
    xhr.open('POST', '/contact', true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    
    xhr.onload = function() {
      submitBtn.disabled = false;
      submitBtn.textContent = 'SUBMIT';
      
      if (xhr.status === 200 || xhr.status === 302) {
        // Success
        successMsg.style.display = 'block';
        form.reset();
        successMsg.scrollIntoView({behavior:'smooth', block:'center'});
      } else {
        // Error
        errorMsg.style.display = 'block';
      }
    };
    
    xhr.onerror = function() {
      submitBtn.disabled = false;
      submitBtn.textContent = 'SUBMIT';
      errorMsg.style.display = 'block';
    };
    
    // Prepare form data for submission
    var params = 
      'form_type=contact' +
      '&utf8=✓' +
      '&contact[name]=' + encodeURIComponent(formData.name) +
      '&contact[email]=' + encodeURIComponent(formData.email) +
      '&contact[phone]=' + encodeURIComponent(formData.phone) +
      '&contact[body]=' + encodeURIComponent(emailBody);
    
    xhr.send(params);
  });
});
</script>

{% schema %}
{
  "name": "Franchise Form",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Form Title",
      "default": "FORM"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Form Subtitle",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquip ex ea commodo consequat."
    }
  ],
  "presets": [
    {
      "name": "Franchise Form"
    }
  ]
}
{% endschema %}