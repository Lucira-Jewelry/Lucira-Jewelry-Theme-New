{% comment %}
  Franchise Form Section - Uses AJAX submission to prevent redirect
  Stays on same page and shows success message
  Sends email to tech@lucirajewelry.com
{% endcomment %}

<section class="franchise-form-section">
  <div class="page-width">
    <div class="franchise-form-wrapper">

      <h2 class="ff-title">{{ section.settings.title }}</h2>
      <p class="ff-subtitle">{{ section.settings.subtitle }}</p>

      <!-- SHOPIFY CONTACT FORM with AJAX -->
      {% form 'contact', class: 'franchise-form', id: 'franchise_contact_form' %}
        
        {% comment %} Hidden field to identify form type {% endcomment %}
        <input type="hidden" name="contact[form_type]" value="franchise_inquiry">
        
        <div class="ff-row">
          <div class="ff-field">
            <label for="franchise_name">Enter your Full Name *</label>
            <input 
              type="text" 
              name="contact[name]" 
              id="franchise_name" 
              placeholder="Sumit Chavda"
              oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '');"
              pattern="[A-Za-z\s]+"
              maxlength="50"
              required>
          </div>

          <div class="ff-field">
            <label for="franchise_phone">Enter your Phone Number *</label>
            <input 
              type="tel" 
              name="contact[phone]" 
              id="franchise_phone" 
              placeholder="+91 9876543210"
              maxlength="13"
              inputmode="numeric"
              pattern="[0-9+\s-]+"
              oninput="this.value = this.value.replace(/[^0-9+\s-]/g, '');"
              required>
          </div>

          <div class="ff-field">
            <label for="franchise_email">Enter your Mail ID *</label>
            <input 
              type="email" 
              name="contact[email]" 
              id="franchise_email" 
              placeholder="sumit@business.com"
              required>
          </div>

          <div class="ff-field">
            <label for="franchise_city">Enter your City or Pincode *</label>
            <input 
              type="text" 
              name="contact[city]" 
              id="franchise_city" 
              placeholder="Mumbai / 400001"
              required>
          </div>
        </div>

        {% comment %} Hidden body field with formatted message {% endcomment %}
        <input type="hidden" name="contact[body]" id="franchise_body" value="">

        <div class="ff-submit-wrapper">
          <button type="submit" class="ff-submit">SUBMIT</button>
        </div>

        <!-- SUCCESS MESSAGE (hidden by default) -->
        <div class="ff-success-message" id="ff-success-msg" style="display: none;">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M10 0C4.48 0 0 4.48 0 10C0 15.52 4.48 20 10 20C15.52 20 20 15.52 20 10C20 4.48 15.52 0 10 0ZM8 15L3 10L4.41 8.59L8 12.17L15.59 4.58L17 6L8 15Z" fill="#155724"/>
          </svg>
          <p>Thank you! Our personnel will contact you shortly.</p>
        </div>

        <!-- ERROR MESSAGE (hidden by default) -->
        <div class="ff-error-message" id="ff-error-msg" style="display: none;">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M10 0C4.48 0 0 4.48 0 10C0 15.52 4.48 20 10 20C15.52 20 20 15.52 20 10C20 4.48 15.52 0 10 0ZM11 15H9V13H11V15ZM11 11H9V5H11V11Z" fill="#721c24"/>
          </svg>
          <p>Something went wrong. Please try again or email us at <strong>tech@lucirajewelry.com</strong></p>
        </div>

      {% endform %}

    </div>
  </div>
</section>

<style>
  .franchise-form-section {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 0 20px;
    background: #fff;
  }

  .franchise-form-wrapper {
    width: 100%;
    max-width: 1100px;
    text-align: center;
    margin: 0 auto;
    font-family: inherit;
  }

  .franchise-form-section .ff-title {
    font-size: 26px;
    letter-spacing: 1.5px;
    font-weight: 500;
    margin-bottom: 12px;
    color: #1a1a1a;
    text-transform: uppercase;
  }

  .franchise-form-section .ff-subtitle {
    max-width: 650px;
    margin: 0 auto 40px;
    color: #666;
    font-size: 14px;
    line-height: 1.7;
  }

  .ff-success-message,
  .ff-error-message {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 30px;
    padding: 18px 24px;
    border-radius: 8px;
    font-size: 14px;
    animation: slideDown 0.4s ease-out;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .ff-success-message {
    background-color: #d4edda;
    border: 1px solid #c3e6cb;
    color: #155724;
  }

  .ff-error-message {
    background-color: #f8d7da;
    border: 1px solid #f5c6cb;
    color: #721c24;
  }

  .ff-success-message svg,
  .ff-error-message svg {
    flex-shrink: 0;
  }

  .ff-success-message p,
  .ff-error-message p {
    margin: 0;
    font-weight: 500;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .franchise-form {
    width: 100%;
  }

  .franchise-form-section .ff-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 35px;
  }

  .franchise-form-section .ff-field {
    text-align: left;
    width: 100%;
  }

  .franchise-form-section .ff-field label {
    display: block;
    font-size: 11px;
    margin-bottom: 7px;
    color: #888;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    font-weight: 500;
  }

  .franchise-form-section .ff-field input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #ddd;
    border-radius: 5px;
    font-size: 14px;
    transition: all 0.2s;
    background: #fff;
  }

  .franchise-form-section .ff-field input:focus {
    outline: none;
    border-color: #A68380;
    box-shadow: 0 0 0 3px rgba(166, 131, 128, 0.1);
  }

  .franchise-form-section .ff-field input::placeholder {
    color: #bbb;
  }

  .ff-submit-wrapper {
    text-align: center;
  }

  .franchise-form-section .ff-submit {
    background: #A68380;
    color: #fff;
    padding: 14px 60px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
    box-shadow: 0 4px 12px rgba(166, 131, 128, 0.2);
    font-family:'futura std';
  }

  .franchise-form-section .ff-submit:hover {
    background: #8f6e6b;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(166, 131, 128, 0.35);
  }

  .franchise-form-section .ff-submit:active {
    transform: translateY(0);
    box-shadow: 0 2px 8px rgba(166, 131, 128, 0.2);
  }

  .franchise-form-section .ff-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  @media (max-width: 900px) {
    .franchise-form-section .ff-row {
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }
  }

  @media (max-width: 600px) {
    .franchise-form-section {
      padding: 40px 15px;
    }

    .franchise-form-section .ff-row {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .franchise-form-section .ff-title {
      font-size: 22px;
      letter-spacing: 1px;
    }

    .franchise-form-section .ff-subtitle {
      font-size: 13px;
      margin-bottom: 30px;
    }

    .ff-success-message,
    .ff-error-message {
      font-size: 13px;
      padding: 14px 18px;
      flex-direction: column;
      text-align: center;
    }

    .franchise-form-section .ff-submit {
      width: 100%;
      padding: 14px 30px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('franchise_contact_form');
    const submitBtn = form.querySelector('.ff-submit');
    const successMsg = document.getElementById('ff-success-msg');
    const errorMsg = document.getElementById('ff-error-msg');

    form.addEventListener('submit', function(e) {
      e.preventDefault(); // Prevent default form submission and redirect
      
      // Hide previous messages
      successMsg.style.display = 'none';
      errorMsg.style.display = 'none';
      
      // Disable submit button and show loading
      submitBtn.disabled = true;
      submitBtn.textContent = 'SUBMITTING...';
      
      // Get form data
      const name = document.getElementById('franchise_name').value;
      const phone = document.getElementById('franchise_phone').value;
      const email = document.getElementById('franchise_email').value;
      const city = document.getElementById('franchise_city').value;
      
      // Create formatted email body
      const messageBody = `
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  NEW FRANCHISE INQUIRY
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Full Name: ${name}
Phone Number: ${phone}
Email: ${email}
City/Pincode: ${city}

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Submitted: ${new Date().toLocaleString('en-IN', { 
  timeZone: 'Asia/Kolkata',
  dateStyle: 'full',
  timeStyle: 'short'
})}

⚠️ Please contact this lead within 24 hours.
      `.trim();
      
      // Prepare form data for AJAX submission
      const formData = new FormData();
      formData.append('form_type', 'contact');
      formData.append('utf8', '✓');
      formData.append('contact[name]', name);
      formData.append('contact[email]', email);
      formData.append('contact[phone]', phone);
      formData.append('contact[city]', city);
      formData.append('contact[form_type]', 'franchise_inquiry');
      formData.append('contact[body]', messageBody);
      
      // Submit via AJAX
      fetch('/contact', {
        method: 'POST',
        body: formData,
        headers: {
          'Accept': 'application/javascript'
        }
      })
      .then(function(response) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'SUBMIT';
        
        if (response.ok || response.redirected) {
          // Success - show success message
          successMsg.style.display = 'flex';
          form.reset(); // Clear form
          
          // Scroll to success message
          successMsg.scrollIntoView({ 
            behavior: 'smooth', 
            block: 'center' 
          });
        } else {
          // Error - show error message
          errorMsg.style.display = 'flex';
        }
      })
      .catch(function(error) {
        // Network error
        submitBtn.disabled = false;
        submitBtn.textContent = 'SUBMIT';
        errorMsg.style.display = 'flex';
        console.error('Form submission error:', error);
      });
    });
  });
</script>

{% schema %}
{
  "name": "Franchise Form",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Form Title",
      "default": "FRANCHISE INQUIRY FORM"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Form Subtitle",
      "default": "Join our growing network of franchise partners. Fill out the form below and our team will get back to you within 24 hours to discuss opportunities in your area."
    }
  ],
  "presets": [
    {
      "name": "Franchise Form"
    }
  ]
}
{% endschema %}