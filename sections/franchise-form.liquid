
<section class="franchise-form-section">
  <div class="page-width">
    <div class="franchise-form-wrapper">

      <!-- Success / Error Messages -->
      <div id="ff-success-msg" style="display:none;" class="ff-success-message">
        <p>Thank you! Our team will contact you shortly.</p>
      </div>

      <div id="ff-error-msg" style="display:none;" class="ff-error-message">
        <p>Something went wrong. Please try again.</p>
      </div>

      <!-- TITLE + SUBTITLE -->
      <h2 class="ff-title">{{ section.settings.title }}</h2>
      <p class="ff-subtitle">{{ section.settings.subtitle }}</p>

      <!-- FORM -->
      <form class="franchise-form" id="franchise_contact_form" novalidate>

        <!-- ⭐ 4-Column Row (Matches your original style) -->
        <div class="ff-row">
          <div class="ff-field">
            <label>Name</label>
            <input type="text" id="franchise-name" placeholder="Enter your Full Name" required>
          </div>

          <div class="ff-field">
            <label>Phone Number</label>
            <input type="number" id="franchise-phone" maxlength="10" placeholder="10-digit mobile number" required>
          </div>

          <div class="ff-field">
            <label>Email</label>
            <input type="email" id="franchise-email" placeholder="Enter your Mail ID" required>
          </div>

          <div class="ff-field">
            <label>City</label>
            <input type="text" id="franchise-city" placeholder="Enter your City or Pincode" required>
          </div>
        </div>

        <!-- BUTTON CENTERED -->
        <div class="ff-submit-wrapper">
          <button type="submit" class="ff-submit" disabled style="opacity:0.6;">
            SUBMIT
          </button>
        </div>

      </form>

    </div>
  </div>
</section>


<style>
  .franchise-form-section {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 0 20px;
    background: #fff;
  }

  .franchise-form-wrapper {
    width: 100%;
    max-width: 1100px;
    text-align: center;
    margin: 0 auto;
    font-family: inherit;
  }

  .franchise-form-section .ff-title {
    font-size: 26px;
    letter-spacing: 1.5px;
    font-weight: 500;
    margin-bottom: 12px;
    color: #1a1a1a;
    text-transform: uppercase;
  }

  .franchise-form-section .ff-subtitle {
    max-width: 650px;
    margin: 0 auto 40px;
    color: #666;
    font-size: 18px;
    line-height: 1.8;
    letter-spacing:1px;
  }

  .ff-success-message,
  .ff-error-message {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 30px;
    padding: 18px 24px;
    border-radius: 8px;
    font-size: 14px;
    animation: slideDown 0.4s ease-out;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .ff-success-message {
    background-color: #d4edda;
    border: 1px solid #c3e6cb;
    color: #155724;
  }

  .ff-error-message {
    background-color: #f8d7da;
    border: 1px solid #f5c6cb;
    color: #721c24;
  }

  .ff-success-message svg,
  .ff-error-message svg {
    flex-shrink: 0;
  }

  .ff-success-message p,
  .ff-error-message p {
    margin: 0;
    font-weight: 500;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .franchise-form {
    width: 100%;
  }

  .franchise-form-section .ff-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 35px;
    margin-bottom: 35px;
  }

  .franchise-form-section .ff-field {
    text-align: left;
    width: 100%;
  }

  .franchise-form-section .ff-field label {
    display: block;
    font-size: 14px;
    margin-bottom: 7px;
    color: #1a1a1a;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 500;
  }

  .franchise-form-section .ff-field input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #ddd;
    border-radius: 5px;
    font-size: 14px;
    transition: all 0.2s;
    background: #fff;
    font-family: 'futura std';
    letter-spacing:1px;
  }

  .franchise-form-section .ff-field input:focus {
    outline: none;
    border-color: #A68380;
    box-shadow: 0 0 0 3px rgba(166, 131, 128, 0.1);
  }

  .franchise-form-section .ff-field input::placeholder {
    color: #bbb;
  }

  .ff-submit-wrapper {
    text-align: center;
  }

  .franchise-form-section .ff-submit {
    background: #A68380;
    color: #fff;
    padding: 14px 60px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    letter-spacing: 2px;
    transition: all 0.3s ease;
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
    box-shadow: 0 4px 12px rgba(166, 131, 128, 0.2);
    font-family:'futura std';
  }

  .franchise-form-section .ff-submit:hover {
    background: #8f6e6b;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(166, 131, 128, 0.35);
  }

  .franchise-form-section .ff-submit:active {
    transform: translateY(0);
    box-shadow: 0 2px 8px rgba(166, 131, 128, 0.2);
  }

  .franchise-form-section .ff-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  @media (max-width: 900px) {
    .franchise-form-section .ff-row {
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }
  }

  @media (max-width: 600px) {
    .franchise-form-section {
      padding: 0 15px;
    }

    .franchise-form-section .ff-row {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .franchise-form-section .ff-title {
      font-size: 18px;
      letter-spacing: 1px;
    }

    .franchise-form-section .ff-subtitle {
      font-size: 13px;
      margin-bottom: 30px;
    }

    .ff-success-message,
    .ff-error-message {
      font-size: 13px;
      padding: 14px 18px;
      flex-direction: column;
      text-align: center;
    }

    .franchise-form-section .ff-submit {
      width: 50%;
      padding: 14px 30px;
    }
  }
</style>


<script>
document.addEventListener('DOMContentLoaded', function () {
  const form = document.getElementById('franchise_contact_form');
  const submitBtn = form.querySelector('.ff-submit');
  const successMsg = document.getElementById('ff-success-msg');
  const errorMsg = document.getElementById('ff-error-msg');

  const nameInput = document.getElementById('franchise-name');
  const phoneInput = document.getElementById('franchise-phone');
  const emailInput = document.getElementById('franchise-email');
  const cityInput = document.getElementById('franchise-city');

  function validateInputs() {
    const phoneValid = /^\d{10}$/.test(phoneInput.value.trim());
    const nameValid = nameInput.value.trim().length > 0;
    const emailValid = emailInput.value.trim().length > 0 && emailInput.validity.valid;
    const cityValid = cityInput.value.trim().length > 0;

    submitBtn.disabled = !(phoneValid && nameValid && emailValid && cityValid);
    submitBtn.style.opacity = submitBtn.disabled ? '0.6' : '1';
  }

  // Validate on input
  [nameInput, phoneInput, emailInput, cityInput].forEach(input => {
    input.addEventListener('input', validateInputs);
  });

  form.addEventListener('submit', function (e) {
    e.preventDefault();

    const phone = phoneInput.value.trim();
    const name = nameInput.value.trim();
    const email = emailInput.value.trim();
    const city = cityInput.value.trim();

    if (!/^\d{10}$/.test(phone)) {
      alert('Please enter a valid 10-digit phone number');
      return;
    }

    const payload = {
      name: name,
      phone: phone,
      email: email,
      city: city,
      formType: 'franchise_registration',
      pageUrl: window.location.href,
      timestamp: new Date().toISOString(),
      submittedAt: new Date().toLocaleString('en-IN', { 
        timeZone: 'Asia/Kolkata',
        dateStyle: 'full',
        timeStyle: 'short'
      })
    };

    // Disable button
    submitBtn.textContent = 'Submitting...';
    submitBtn.disabled = true;
    submitBtn.style.opacity = '0.6';

    fetch('https://franchise-api-385594025448.asia-south1.run.app/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
      .then(response => {
        if (!response.ok) throw new Error('Submission failed');
        return response.json();
      })
      .then(() => {
        // Push to dataLayer
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'franchiseRegistrationSubmit',
          franchiseData: payload
        });

        // Show success message
        successMsg.style.display = 'flex';
        errorMsg.style.display = 'none';
        form.reset();
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.6';
        submitBtn.textContent = 'SUBMIT';

        // Scroll to success
        successMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
      })
      .catch(err => {
        console.error('Form submission error:', err);
        errorMsg.style.display = 'flex';
        successMsg.style.display = 'none';
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
        submitBtn.textContent = 'SUBMIT';
      });
  });
});
</script>


{% schema %}
{
  "name": "Franchise Form",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Form Title",
      "default": "FRANCHISE INQUIRY FORM"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Form Subtitle",
      "default": "Join our growing network of franchise partners. Fill out the form below and our team will get back to you within 24 hours to discuss opportunities in your area."
    }
  ],
  "presets": [
    {
      "name": "Franchise Form"
    }
  ]
}
{% endschema %}