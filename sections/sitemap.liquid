        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sitemap",
      "blocks": [
        {
          "type": "section_start",
          "settings": {
            "section_title": "JEWELRY"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "RINGS",
            "links": "Engagement Rings|/collections/engagement-rings\nSolitaire Rings|/collections/solitaire\nEternity Rings|/collections/eternity\nStackable Rings|/collections/stackable\nCasual Rings|/collections/casual\nMen's Ring|/collections/mens-rings"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "EARRINGS",
            "links": "Studs|/collections/studs\nHoops|/collections/hoops\nSui Dhagas|/collections/sui-dhagas\nDangles|/collections/dangles"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "BRACELETS",
            "links": "Chain Bracelets|/collections/chain-bracelets\nTennis Bracelets|/collections/tennis-bracelets\nCuff Bracelets|/collections/cuff-bracelets\nMangalsutra Bracelets|/collections/mangalsutra-bracelets"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "NECKLACES",
            "links": "Chain Necklaces|/collections/chain-necklaces\nPendant Necklaces|/collections/pendant-necklaces\nMangalsutra Necklaces|/collections/mangalsutra-necklaces\nTennis Necklace|/collections/tennis-necklace"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "OTHERS",
            "links": "Nose Pins|/collections/nose-pins\nMen's Studs|/collections/mens-studs"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "EDUCATION",
            "links": "Hoop Earring Styles|/pages/hoop-styles\nDifferent types of Diamond|/pages/diamond-types\nJewelry Trends 2025|/blogs/news/trends-2025\nHow to read certificate|/pages/certificate-guide"
          }
        },
        {
          "type": "divider"
        },
        {
          "type": "section_start",
          "settings": {
            "section_title": "FAVORITES"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "FAST SHIPPING",
            "links": "Rings|/collections/fast-shipping-rings\nEarrings|/collections/fast-shipping-earrings\nBracelets|/collections/fast-shipping-bracelets\nPendant Necklaces|/collections/fast-shipping-pendants"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "NEW ARRIVALS",
            "links": "Rings|/collections/new-rings\nEarrings|/collections/new-earrings\nNose Pins|/collections/new-nose-pins\nBracelets|/collections/new-bracelets\nPendant Necklaces|/collections/new-pendants"
          }
        }
      ]
    }
  ]
}
{% endschema %} {% endcomment %}







