<style>
  .sitemap-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 20px 10px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .sitemap-page-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .sitemap-page-title {
    font-size: 28px;
    font-weight: 400;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin: 0;
    color: #000;
  }

  /* Main Section Container */
  .sitemap-main-section {
    margin-bottom: 20px;
    padding:  0 60px 30px 60px ;
  }

  .sitemap-main-section:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  /* Section Title */
  .sitemap-section-header {
    margin-bottom: 40px;
  }

  .sitemap-section-title {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin: 0;
    color: #1A1A1A;
    border-bottom: 1px solid #D9D9D9;
    padding-bottom:12px;
    line-height:1.7;
  }

  .sitemap-section-title a {
    color: #000;
    text-decoration: none;
  }

  .sitemap-section-title a:hover {
    opacity: 0.7;
  }

  /* Grid for subsections */
  .sitemap-subsections-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 20px;
  }

  /* Individual Column */
  .sitemap-column {
    min-width: 0;
  }

  .sitemap-column-title {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin: 0 0 15px 0;
    color: #1a1a1a;
  }

  /* Links List */
  .sitemap-links-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sitemap-links-list li {
    margin-bottom: 8px;
  }

  .sitemap-links-list a {
    font-size: 12px;
    color: #666666;
    text-decoration: none;
    line-height: 1.6;
    display: block;
  }

  .sitemap-links-list a:hover {
    color: #000;
    text-decoration:underline;
  }

  /* Responsive Design */
  @media (max-width: 1200px) {
    .sitemap-subsections-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 35px;
    }
  }

  @media (max-width: 768px) {
    .sitemap-subsections-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
    }
    
    .sitemap-section-title {
      font-size: 18px;
    }
    
    .sitemap-main-section {
      margin-bottom: 60px;
      {% comment %} padding-top: 35px; {% endcomment %}
    padding: 0 10px 10px 10px;
    }

    .sitemap-column-title {
    margin: 0 0 20px 0;
    }

  }

  @media (max-width: 480px) {
    .sitemap-subsections-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 25px;
    }
    
    .sitemap-page {
      padding: 30px 15px 0px;
    }
    
    .sitemap-page-header {
      margin-bottom: 50px;
    }
    
    .sitemap-page-title {
      font-size: 22px;
    }
  }
</style>

<div class="sitemap-page">
  <!-- Page Header -->
  <div class="sitemap-page-header">
    <h1 class="sitemap-page-title">{{ section.settings.page_title }}</h1>
  </div>


  
  {% assign in_section = false %}
  {% assign section_title = '' %}
  {% assign section_url = '' %}
  {% assign subsections = '' %}
  
  {% for block in section.blocks %}
    {% if block.type == 'section_start' %}
      
      {% comment %} If we were already in a section, close it first {% endcomment %}
      {% if in_section %}
        <div class="sitemap-main-section">
          <div class="sitemap-section-header">
            <h2 class="sitemap-section-title">
              {% if section_url != blank %}
                <a href="{{ section_url }}">{{ section_title }}</a>
              {% else %}
                {{ section_title }}
              {% endif %}
            </h2>
          </div>
          <div class="sitemap-subsections-grid">
            {{ subsections }}
          </div>
        </div>
        {% assign subsections = '' %}
      {% endif %}
      
      {% comment %} Start new section {% endcomment %}
      {% assign in_section = true %}
      {% assign section_title = block.settings.section_title %}
      {% assign section_url = block.settings.section_url %}
      
    {% elsif block.type == 'subsection' and in_section %}
      
      {% comment %} Collect subsection HTML {% endcomment %}
      {% capture subsection_html %}
        <div class="sitemap-column" {{ block.shopify_attributes }}>
          <h3 class="sitemap-column-title">{{ block.settings.subsection_title }}</h3>
          
          {% if block.settings.links != blank %}
            <ul class="sitemap-links-list">
              {% assign links_array = block.settings.links | newline_to_br | split: '<br />' %}
              {% for link_item in links_array %}
                {% assign link_item = link_item | strip %}
                {% if link_item != '' %}
                  {% assign link_parts = link_item | split: '|' %}
                  {% if link_parts.size == 2 %}
                    <li><a href="{{ link_parts[1] | strip }}">{{ link_parts[0] | strip }}</a></li>
                  {% else %}
                    <li><a href="#">{{ link_item }}</a></li>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      {% endcapture %}
      {% assign subsections = subsections | append: subsection_html %}
      
    {% endif %}
  {% endfor %}
  
  {% comment %} Close the last section if exists {% endcomment %}
  {% if in_section %}
    <div class="sitemap-main-section">
      <div class="sitemap-section-header">
        <h2 class="sitemap-section-title">
          {% if section_url != blank %}
            <a href="{{ section_url }}">{{ section_title }}</a>
          {% else %}
            {{ section_title }}
          {% endif %}
        </h2>
      </div>
      <div class="sitemap-subsections-grid">
        {{ subsections }}
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Sitemap",
  "settings": [
    {
      "type": "text",
      "id": "page_title",
      "label": "Page Title",
      "default": "SITEMAP"
    },
    {
      "type": "paragraph",
      "content": "📖 HOW TO USE: Add blocks in order: 1) 'Section Start' for main category (FAVORITES), 2) Add multiple 'Subsection' blocks right after it (FAST SHIPPING, NEW ARRIVALS, etc.), 3) Add next 'Section Start' (ENGAGEMENT RINGS), 4) Add its subsections. The blocks are grouped automatically by order!"
    }
  ],
  "blocks": [
    {
      "type": "section_start",
      "name": "🔵 Section Start",
      "settings": [
        {
          "type": "paragraph",
          "content": "⭐ This starts a new main section (like FAVORITES, ENGAGEMENT RINGS, JEWELRY, etc.). All 'Subsection' blocks you add after this will belong to this section, until you add another 'Section Start'."
        },
        {
          "type": "text",
          "id": "section_title",
          "label": "Main Section Title",
          "default": "JEWELRY",
          "info": "Examples: FAVORITES, ENGAGEMENT RINGS, WEDDING RINGS, JEWELRY, SOLITAIRE, COLLECTION, GIFTING"
        },
        {
          "type": "url",
          "id": "section_url",
          "label": "Section URL (Optional)",
          "info": "Make the title clickable by adding a URL"
        }
      ]
    },
    {
      "type": "subsection",
      "name": "📄 Subsection",
      "settings": [
        {
          "type": "paragraph",
          "content": "📌 This is a column that appears under the most recent 'Section Start'. Add multiple subsection blocks to create side-by-side columns."
        },
        {
          "type": "text",
          "id": "subsection_title",
          "label": "Column Title",
          "default": "RINGS",
          "info": "Examples: RINGS, FAST SHIPPING, Shop by Style, NEW ARRIVALS, EDUCATION"
        },
        {
          "type": "textarea",
          "id": "links",
          "label": "Links (one per line)",
          "placeholder": "Engagement Rings|/collections/engagement-rings\nSolitaire Rings|/collections/solitaire\nEternity Rings|/collections/eternity",
          "info": "Format: 'Link Text|/url' OR just 'Link Text' for placeholder links"
        }
      ]
    },
    {
      "type": "divider",
      "name": "➖ Visual Divider",
      "settings": [
        {
          "type": "paragraph",
          "content": "📐 This is just a visual separator in the editor to help you organize blocks. It doesn't appear on your sitemap page. Use it to visually separate different main sections while editing."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sitemap",
      "blocks": [
        {
          "type": "section_start",
          "settings": {
            "section_title": "JEWELRY"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "RINGS",
            "links": "Engagement Rings|/collections/engagement-rings\nSolitaire Rings|/collections/solitaire\nEternity Rings|/collections/eternity\nStackable Rings|/collections/stackable\nCasual Rings|/collections/casual\nMen's Ring|/collections/mens-rings"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "EARRINGS",
            "links": "Studs|/collections/studs\nHoops|/collections/hoops\nSui Dhagas|/collections/sui-dhagas\nDangles|/collections/dangles"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "BRACELETS",
            "links": "Chain Bracelets|/collections/chain-bracelets\nTennis Bracelets|/collections/tennis-bracelets\nCuff Bracelets|/collections/cuff-bracelets\nMangalsutra Bracelets|/collections/mangalsutra-bracelets"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "NECKLACES",
            "links": "Chain Necklaces|/collections/chain-necklaces\nPendant Necklaces|/collections/pendant-necklaces\nMangalsutra Necklaces|/collections/mangalsutra-necklaces\nTennis Necklace|/collections/tennis-necklace"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "OTHERS",
            "links": "Nose Pins|/collections/nose-pins\nMen's Studs|/collections/mens-studs"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "EDUCATION",
            "links": "Hoop Earring Styles|/pages/hoop-styles\nDifferent types of Diamond|/pages/diamond-types\nJewelry Trends 2025|/blogs/news/trends-2025\nHow to read certificate|/pages/certificate-guide"
          }
        },
        {
          "type": "divider"
        },
        {
          "type": "section_start",
          "settings": {
            "section_title": "FAVORITES"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "FAST SHIPPING",
            "links": "Rings|/collections/fast-shipping-rings\nEarrings|/collections/fast-shipping-earrings\nBracelets|/collections/fast-shipping-bracelets\nPendant Necklaces|/collections/fast-shipping-pendants"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "subsection_title": "NEW ARRIVALS",
            "links": "Rings|/collections/new-rings\nEarrings|/collections/new-earrings\nNose Pins|/collections/new-nose-pins\nBracelets|/collections/new-bracelets\nPendant Necklaces|/collections/new-pendants"
          }
        }
      ]
    }
  ]
}
{% endschema %}
