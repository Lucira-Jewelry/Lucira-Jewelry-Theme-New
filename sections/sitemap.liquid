<div class="sitemap-page">
  <div class="sitemap-page-header">
    <h1 class="sitemap-page-title">{{ section.settings.page_title }}</h1>
  </div>

  {% comment %} ===== AUTOMATED COLLECTIONS SECTION ===== {% endcomment %}
  {% if section.settings.show_collections %}
    <div class="sitemap-main-section">
      <div class="sitemap-section-header">
        <h2 class="sitemap-section-title">
          <a href="/collections">Collections</a>
        </h2>
      </div>
      <div class="sitemap-subsections-grid">
        {% assign collections_per_column = section.settings.collections_per_column | default: 10 %}
        {% assign collection_count = 0 %}
        {% assign column_open = false %}
        
        {% for collection in collections %}
          {% if collection_count == 0 %}
            <div class="sitemap-column">
              <ul class="sitemap-links-list">
            {% assign column_open = true %}
          {% endif %}
          
          <li><a href="{{ collection.url | default: '/collections/' | append: collection.handle }}">{{ collection.title }}</a></li>
          
          {% assign collection_count = collection_count | plus: 1 %}
          
          {% if collection_count == collections_per_column %}
            </ul>
            </div>
            {% assign collection_count = 0 %}
            {% assign column_open = false %}
          {% endif %}
        {% endfor %}
        
        {% if column_open %}
          </ul>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% comment %} ===== AUTOMATED PAGES SECTION ===== {% endcomment %}
  {% if section.settings.show_pages %}
    <div class="sitemap-main-section">
      <div class="sitemap-section-header">
        <h2 class="sitemap-section-title">Pages</h2>
      </div>
      <div class="sitemap-subsections-grid">
        {% assign pages_per_column = section.settings.pages_per_column | default: 10 %}
        {% assign page_count = 0 %}
        {% assign column_open = false %}
        
        {% for page in pages %}
          {% if page_count == 0 %}
            <div class="sitemap-column">
              <ul class="sitemap-links-list">
            {% assign column_open = true %}
          {% endif %}
          
          <li><a href="{{ page.url | default: '/pages/' | append: page.handle }}">{{ page.title }}</a></li>
          
          {% assign page_count = page_count | plus: 1 %}
          
          {% if page_count == pages_per_column %}
            </ul>
            </div>
            {% assign page_count = 0 %}
            {% assign column_open = false %}
          {% endif %}
        {% endfor %}
        
        {% if column_open %}
          </ul>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% comment %} ===== AUTOMATED BLOG POSTS SECTION ===== {% endcomment %}
  {% if section.settings.show_blogs %}
    {% for blog in blogs %}
      {% if blog.articles_count > 0 %}
        <div class="sitemap-main-section">
          <div class="sitemap-section-header">
            <h2 class="sitemap-section-title">
              <a href="{{ blog.url | default: '/blogs/' | append: blog.handle }}">{{ blog.title }}</a>
            </h2>
          </div>
          <div class="sitemap-subsections-grid">
            {% assign posts_per_column = section.settings.posts_per_column | default: 10 %}
            {% assign post_count = 0 %}
            {% assign column_open = false %}
            
            {% for article in blog.articles limit: section.settings.max_blog_posts %}
              {% if post_count == 0 %}
                <div class="sitemap-column">
                  <ul class="sitemap-links-list">
                {% assign column_open = true %}
              {% endif %}
              
              <li><a href="{{ article.url | default: blog.url | append: '/' | append: article.handle }}">{{ article.title }}</a></li>
              
              {% assign post_count = post_count | plus: 1 %}
              
              {% if post_count == posts_per_column %}
                </ul>
                </div>
                {% assign post_count = 0 %}
                {% assign column_open = false %}
              {% endif %}
            {% endfor %}
            
            {% if column_open %}
              </ul>
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  {% endif %}

  {% comment %} ===== AUTOMATED PRODUCTS SECTION ===== {% endcomment %}
  {% if section.settings.show_products %}
    <div class="sitemap-main-section">
      <div class="sitemap-section-header">
        <h2 class="sitemap-section-title">
          <a href="/collections/all">Products</a>
        </h2>
      </div>
      <div class="sitemap-subsections-grid">
        {% assign products_per_column = section.settings.products_per_column | default: 10 %}
        {% assign product_count = 0 %}
        {% assign column_open = false %}
        
        {% for product in collections.all.products limit: section.settings.max_products %}
          {% if product_count == 0 %}
            <div class="sitemap-column">
              <ul class="sitemap-links-list">
            {% assign column_open = true %}
          {% endif %}
          
          <li><a href="{{ product.url | default: '/products/' | append: product.handle }}">{{ product.title }}</a></li>
          
          {% assign product_count = product_count | plus: 1 %}
          
          {% if product_count == products_per_column %}
            </ul>
            </div>
            {% assign product_count = 0 %}
            {% assign column_open = false %}
          {% endif %}
        {% endfor %}
        
        {% if column_open %}
          </ul>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% comment %} ===== MANUAL SECTIONS (Your original code) ===== {% endcomment %}
  {% assign in_section = false %}
  {% assign section_title = '' %}
  {% assign section_url = '' %}
  {% assign subsections = '' %}
  
  {% for block in section.blocks %}
    {% if block.type == 'section_start' %}
      {% if in_section %}
        <div class="sitemap-main-section">
          <div class="sitemap-section-header">
            <h2 class="sitemap-section-title">
              {% if section_url != blank %}
                <a href="{{ section_url }}">{{ section_title }}</a>
              {% else %}
                {{ section_title }}
              {% endif %}
            </h2>
          </div>
          <div class="sitemap-subsections-grid">
            {{ subsections }}
          </div>
        </div>
        {% assign subsections = '' %}
      {% endif %}
      
      {% assign in_section = true %}
      {% assign section_title = block.settings.section_title %}
      {% assign section_url = block.settings.section_url %}
      
    {% elsif block.type == 'subsection' and in_section %}
      {% capture subsection_html %}
        <div class="sitemap-column" {{ block.shopify_attributes }}>
          <h3 class="sitemap-column-title">{{ block.settings.subsection_title }}</h3>
          
          {% if block.settings.links != blank %}
            <ul class="sitemap-links-list">
              {% assign links_array = block.settings.links | newline_to_br | split: '<br />' %}
              {% for link_item in links_array %}
                {% assign link_item = link_item | strip %}
                {% if link_item != '' %}
                  {% assign link_parts = link_item | split: '|' %}
                  {% if link_parts.size == 2 %}
                    <li><a href="{{ link_parts[1] | strip }}">{{ link_parts[0] | strip }}</a></li>
                  {% else %}
                    <li><a href="#">{{ link_item }}</a></li>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      {% endcapture %}
      {% assign subsections = subsections | append: subsection_html %}
    {% endif %}
  {% endfor %}
  
  {% if in_section %}
    <div class="sitemap-main-section">
      <div class="sitemap-section-header">
        <h2 class="sitemap-section-title">
          {% if section_url != blank %}
            <a href="{{ section_url }}">{{ section_title }}</a>
          {% else %}
            {{ section_title }}
          {% endif %}
        </h2>
      </div>
      <div class="sitemap-subsections-grid">
        {{ subsections }}
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Automated Sitemap",
  "settings": [
    {
      "type": "text",
      "id": "page_title",
      "label": "Page Title",
      "default": "SITEMAP"
    },
    {
      "type": "header",
      "content": "🤖 AUTOMATED SECTIONS"
    },
    {
      "type": "paragraph",
      "content": "Toggle automated sections on/off. URLs are generated automatically from Shopify handles."
    },
    {
      "type": "checkbox",
      "id": "show_collections",
      "label": "Show Collections Section",
      "default": true
    },
    {
      "type": "range",
      "id": "collections_per_column",
      "min": 5,
      "max": 20,
      "step": 1,
      "label": "Collections per column",
      "default": 10
    },
    {
      "type": "checkbox",
