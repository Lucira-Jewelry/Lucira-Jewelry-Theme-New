<style>
  .sitemap-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 20px 10px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .sitemap-page-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .sitemap-page-title {
    font-size: 28px;
    font-weight: 400;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin: 0;
    color: #000;
  }

  .sitemap-main-section {
    margin-bottom: 20px;
    padding: 0 60px 30px 60px;
  }

  .sitemap-main-section:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .sitemap-section-header {
    margin-bottom: 40px;
  }

  .sitemap-section-title {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin: 0;
    color: #1A1A1A;
    border-bottom: 1px solid #D9D9D9;
    padding-bottom: 12px;
    line-height: 1.7;
  }

  .sitemap-section-title a {
    color: #000;
    text-decoration: none;
  }

  .sitemap-section-title a:hover {
    opacity: 0.7;
  }

  .sitemap-subsections-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 35px;
  }

  .sitemap-column {
    min-width: 0;
  }

  .sitemap-column-title {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin: 0 0 15px 0;
    color: #1a1a1a;
  }

  .sitemap-links-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sitemap-links-list li {
    margin-bottom: 8px;
  }

  .sitemap-links-list a {
    font-size: 12px;
    color: #666666;
    text-decoration: none;
    line-height: 1.6;
    display: block;
  }

  .sitemap-links-list a:hover {
    color: #000;
    text-decoration: underline;
  }

  @media (max-width: 1200px) {
    .sitemap-subsections-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 35px;
    }
  }

  @media (max-width: 768px) {
    .sitemap-subsections-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
    }
    
    .sitemap-section-title {
      font-size: 18px;
    }
    
    .sitemap-main-section {
      margin-bottom: 50px;
      padding: 0 10px 10px 10px;
    }

    .sitemap-column-title {
      margin: 0 0 20px 0;
    }
  }

  @media (max-width: 480px) {
    .sitemap-subsections-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
      row-gap:45px;
    }

    .sitemap-page {
      padding: 40px 15px 0px;
    }
    
    .sitemap-page-header {
      margin-bottom: 40px;
    }
    
    .sitemap-page-title {
      font-size: 22px;
    }

    .sitemap-links-list li:last-child {
      margin-bottom: 0 !important;
    }
  }
</style>

<div class="sitemap-page">
  <div class="sitemap-page-header">
    <h1 class="sitemap-page-title">{{ section.settings.page_title }}</h1>
  </div>

  {% comment %} ===== AUTOMATED COLLECTIONS SECTION - ALL COLLECTIONS ===== {% endcomment %}
  {% if section.settings.show_collections %}
    <div class="sitemap-main-section">
      <div class="sitemap-section-header">
        <h2 class="sitemap-section-title">
          <a href="/collections">Collections</a>
        </h2>
      </div>
      <div class="sitemap-subsections-grid">
        {% assign collections_per_column = section.settings.collections_per_column %}
        {% assign collection_count = 0 %}
        {% assign column_open = false %}
        
        {% comment %} Get ALL collections - paginate up to 1000 {% endcomment %}
        {% paginate collections by 1000 %}
          {% assign sorted_collections = collections | sort: 'title' %}
          
          {% for collection in sorted_collections %}
            {% comment %} Skip empty collections if setting is enabled {% endcomment %}
            {% if section.settings.hide_empty_collections and collection.all_products_count == 0 %}
              {% continue %}
            {% endif %}
            
            {% if collection_count == 0 %}
              <div class="sitemap-column">
                <ul class="sitemap-links-list">
              {% assign column_open = true %}
            {% endif %}
            
            {% comment %} Generate proper collection URL {% endcomment %}
            {% if collection.url and collection.url != blank %}
              {% assign collection_link = collection.url %}
            {% else %}
              {% assign collection_link = '/collections/' | append: collection.handle %}
            {% endif %}
            
            <li><a href="{{ collection_link }}">{{ collection.title }}</a></li>
            
            {% assign collection_count = collection_count | plus: 1 %}
            
            {% if collection_count == collections_per_column %}
              </ul>
              </div>
              {% assign collection_count = 0 %}
              {% assign column_open = false %}
            {% endif %}
          {% endfor %}
          
          {% if column_open %}
            </ul>
            </div>
          {% endif %}
        {% endpaginate %}
      </div>
    </div>
  {% endif %}

  {% comment %} ===== AUTOMATED PAGES SECTION - ALL PAGES ===== {% endcomment %}
  {% if section.settings.show_pages %}
    <div class="sitemap-main-section">
      <div class="sitemap-section-header">
        <h2 class="sitemap-section-title">Pages</h2>
      </div>
      <div class="sitemap-subsections-grid">
        {% assign pages_per_column = section.settings.pages_per_column %}
        {% assign page_count = 0 %}
        {% assign column_open = false %}
        
        {% comment %} Get ALL pages - paginate up to 1000 {% endcomment %}
        {% paginate pages by 5000 %}
          {% assign sorted_pages = pages | sort: 'title' %}
          
          {% for page in sorted_pages %}
            {% if page_count == 0 %}
              <div class="sitemap-column">
                <ul class="sitemap-links-list">
              {% assign column_open = true %}
            {% endif %}
            
            {% comment %} Generate proper page URL {% endcomment %}
            {% if page.url and page.url != blank %}
              {% assign page_link = page.url %}
            {% else %}
              {% assign page_link = '/pages/' | append: page.handle %}
            {% endif %}
            
            <li><a href="{{ page_link }}">{{ page.title }}</a></li>
            
            {% assign page_count = page_count | plus: 1 %}
            
            {% if page_count == pages_per_column %}
              </ul>
              </div>
              {% assign page_count = 0 %}
              {% assign column_open = false %}
            {% endif %}
          {% endfor %}
          
          {% if column_open %}
            </ul>
            </div>
          {% endif %}
        {% endpaginate %}
      </div>
    </div>
  {% endif %}

  {% comment %} ===== AUTOMATED BLOG POSTS SECTION - ALL ARTICLES ===== {% endcomment %}
  {% if section.settings.show_blogs %}
    {% assign main_blog = blogs.stories %}
    {% if main_blog and main_blog.articles_count > 0 %}
      <div class="sitemap-main-section">
        <div class="sitemap-section-header">
          <h2 class="sitemap-section-title">
            <a href="/blogs/stories">{{ main_blog.title }}</a>
          </h2>
        </div>
        <div class="sitemap-subsections-grid">
          {% assign posts_per_column = section.settings.posts_per_column %}
          {% assign post_count = 0 %}
          {% assign column_open = false %}
          
          {% comment %} Get ALL articles - paginate up to 1000 {% endcomment %}
          {% paginate main_blog.articles by 1000 %}
            {% for article in main_blog.articles %}
              {% if post_count == 0 %}
                <div class="sitemap-column">
                  <ul class="sitemap-links-list">
                {% assign column_open = true %}
              {% endif %}
              
              {% comment %} Generate proper article URL {% endcomment %}
              {% if article.url and article.url != blank %}
                {% assign article_link = article.url %}
              {% else %}
                {% assign article_link = '/blogs/stories/' | append: article.handle %}
              {% endif %}
              
              <li><a href="{{ article_link }}">{{ article.title }}</a></li>
              
              {% assign post_count = post_count | plus: 1 %}
              
              {% if post_count == posts_per_column %}
                </ul>
                </div>
                {% assign post_count = 0 %}
                {% assign column_open = false %}
              {% endif %}
            {% endfor %}
            
            {% if column_open %}
              </ul>
              </div>
            {% endif %}
          {% endpaginate %}
        </div>
      </div>
    {% endif %}
  {% endif %}

  {% comment %} ===== AUTOMATED PRODUCTS SECTION - ALL PRODUCTS ===== {% endcomment %}
  {% if section.settings.show_products %}
    <div class="sitemap-main-section">
      <div class="sitemap-section-header">
        <h2 class="sitemap-section-title">
          <a href="/collections/all">Products</a>
        </h2>
      </div>
      <div class="sitemap-subsections-grid">
        {% assign products_per_column = section.settings.products_per_column %}
        {% assign product_count = 0 %}
        {% assign column_open = false %}
        
        {% comment %} Get ALL products - paginate up to max limit {% endcomment %}
        {% paginate collections.all.products by section.settings.max_products %}
          {% assign sorted_products = collections.all.products | sort: 'title' %}
          
          {% for product in sorted_products %}
            {% if product_count == 0 %}
              <div class="sitemap-column">
                <ul class="sitemap-links-list">
              {% assign column_open = true %}
            {% endif %}
            
            {% comment %} Generate proper product URL {% endcomment %}
            {% if product.url and product.url != blank %}
              {% assign product_link = product.url %}
            {% else %}
              {% assign product_link = '/products/' | append: product.handle %}
            {% endif %}
            
            <li><a href="{{ product_link }}">{{ product.title }}</a></li>
            
            {% assign product_count = product_count | plus: 1 %}
            
            {% if product_count == products_per_column %}
              </ul>
              </div>
              {% assign product_count = 0 %}
              {% assign column_open = false %}
            {% endif %}
          {% endfor %}
          
          {% if column_open %}
            </ul>
            </div>
          {% endif %}
        {% endpaginate %}
      </div>
    </div>
  {% endif %}

  {% comment %} ===== MANUAL SECTIONS ===== {% endcomment %}
  {% assign in_section = false %}
  {% assign section_title = '' %}
  {% assign section_url = '' %}
  {% assign subsections = '' %}
  
  {% for block in section.blocks %}
    {% if block.type == 'section_start' %}
      {% if in_section %}
        <div class="sitemap-main-section">
          <div class="sitemap-section-header">
            <h2 class="sitemap-section-title">
              {% if section_url != blank %}
                <a href="{{ section_url }}">{{ section_title }}</a>
              {% else %}
                {{ section_title }}
              {% endif %}
            </h2>
          </div>
          <div class="sitemap-subsections-grid">
            {{ subsections }}
          </div>
        </div>
        {% assign subsections = '' %}
      {% endif %}
      
      {% assign in_section = true %}
      {% assign section_title = block.settings.section_title %}
      {% assign section_url = block.settings.section_url %}
      
    {% elsif block.type == 'subsection' and in_section %}
      {% capture subsection_html %}
        <div class="sitemap-column" {{ block.shopify_attributes }}>
          <h3 class="sitemap-column-title">{{ block.settings.subsection_title }}</h3>
          
          {% if block.settings.links != blank %}
            <ul class="sitemap-links-list">
              {% assign links_array = block.settings.links | newline_to_br | split: '<br />' %}
              {% for link_item in links_array %}
                {% assign link_item = link_item | strip %}
                {% if link_item != '' %}
                  {% assign link_parts = link_item | split: '|' %}
                  {% if link_parts.size == 2 %}
                    <li><a href="{{ link_parts[1] | strip }}">{{ link_parts[0] | strip }}</a></li>
                  {% else %}
                    <li><a href="#">{{ link_item }}</a></li>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      {% endcapture %}
      {% assign subsections = subsections | append: subsection_html %}
    {% endif %}
  {% endfor %}
  
  {% if in_section %}
    <div class="sitemap-main-section">
      <div class="sitemap-section-header">
        <h2 class="sitemap-section-title">
          {% if section_url != blank %}
            <a href="{{ section_url }}">{{ section_title }}</a>
          {% else %}
            {{ section_title }}
          {% endif %}
        </h2>
      </div>
      <div class="sitemap-subsections-grid">
        {{ subsections }}
      </div>
    </div>
  {% endif %}
</div>

