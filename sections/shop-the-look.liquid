{% schema %}
{
  "name": "Home STL",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "image_card",
      "limit": 3,
      "name": "Image Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "parent_id",
          "label": "Parent Id"
        }
      ]
    },
    {
      "type": "pin",
      "name": "Pin",
      "settings": [
        {
          "type": "range",
          "id": "horizontal_position",
          "label": "Horizontal Position",
          "min": 0,
          "max": 100,
          "default": 50,
          "unit": "%"
        },
        {
          "type": "range",
          "id": "vertical_position",
          "label": "Vertical Position",
          "min": 0,
          "max": 100,
          "default": 50,
          "unit": "%"
        },
        {
          "type": "select",
          "id": "product_position",
          "label": "Product Position",
          "options": [
            {
              "label": "Top",
              "value": "top"
            },
            {
              "label": "Bottom",
              "value": "bottom"
            },
            {
              "label": "Left",
              "value": "left"
            },
            {
              "label": "Right",
              "value": "right"
            },
            {
              "label": "Top Left",
              "value": "top-left"
            },
            {
              "label": "Top Right",
              "value": "top-right"
            },
            {
              "label": "Bottom Left",
              "value": "bottom-left"
            },
            {
              "label": "Bottom Right",
              "value": "bottom-right"
            }
          ],
          "default": "top"
        },
        {
          "type": "product",
          "id": "pin_product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "parent_id",
          "label": "Parent Id"
        }
      ]
    }
  ],
  "presets": [{ "name": "Home Shop the Look" }]
}
{% endschema %}

<link rel="stylesheet" href="{{ 'owl.carousel.min.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'owl.theme.default.min.css' | asset_url }}" media="print" onload="this.media='all'">
<script src="{{ 'owl.carousel.min.js' | asset_url }}" defer="defer"></script>

<section class="home-shop-the-look">
  <div class="page-width">
    <p class="home-stl-heading">{{ section.settings.heading }}</p>
    <p class="home-stl-subheading">{{ section.settings.subheading }}</p>
    <div class="home-stl-container shop-look-carousel owl-carousel owl-theme" id="stl-carousel">
      {% for block in section.blocks %}
        {% if block.type == 'image_card' %}
          <div class="home-stl-item" data-parent-id="{{ block.settings.parent_id }}">
            <picture>
              <source
                type="image/webp"
                srcset="
                  {{ block.settings.card_image | image_url: width: 400, format: 'webp' }} 400w,
                  {{ block.settings.card_image | image_url: width: 800, format: 'webp' }} 800w,
                  {{ block.settings.card_image | image_url: width: 1200, format: 'webp' }} 1200w
                "
                sizes="100vw"
              >
              <source
                type="image/jpeg"
                srcset="
                  {{ block.settings.card_image | image_url: width: 400 }} 400w,
                  {{ block.settings.card_image | image_url: width: 800 }} 800w,
                  {{ block.settings.card_image | image_url: width: 1200 }} 1200w
                "
                sizes="100vw"
              >

              <img
                srcset="
                  {%- if block.settings.card_image.width >= 165 -%}{{ block.settings.card_image | image_url: width: 165 }} 165w,{%- endif -%}
                  {%- if block.settings.card_image.width >= 360 -%}{{ block.settings.card_image | image_url: width: 360 }} 360w,{%- endif -%}
                  {%- if block.settings.card_image.width >= 535 -%}{{ block.settings.card_image | image_url: width: 535 }} 535w,{%- endif -%}
                  {%- if block.settings.card_image.width >= 750 -%}{{ block.settings.card_image | image_url: width: 750 }} 750w,{%- endif -%}
                  {%- if block.settings.card_image.width >= 1070 -%}{{ block.settings.card_image | image_url: width: 1070 }} 1070w,{%- endif -%}
                  {%- if block.settings.card_image.width >= 1500 -%}{{ block.settings.card_image | image_url: width: 1500 }} 1500w,{%- endif -%}
                  {{ block.settings.card_image | image_url }} {{ block.settings.card_image.width }}w
                "
                src="{{ block.settings.card_image | image_url: width: 1500 }}"
                sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)"
                alt="{{ block.settings.card_image.alt | escape }}"
                loading="lazy"
                width="564"
                height="752"
                style="width: 100%; height: auto;"
                class="home-stl-image"
                title="shop-the-look"
              >
            </picture>

            <div class="home-stl-pins-wrapper">
              {% for pin in section.blocks %}
                {% if pin.type == 'pin' and pin.settings.parent_id == block.settings.parent_id %}
                  <svg width="40" height="40" class="home-stl-pin" style="left: {{ pin.settings.horizontal_position }}%; top: {{ pin.settings.vertical_position }}%">
                    <use href="#icon-circle-heart"></use>
                  </svg>
                  {% if pin.settings.pin_product.url %}
                    <a
                      href="{{ pin.settings.pin_product.url }}"
                      class="home-stl-pin-product stl-shop-now"
                      style="
                        text-decoration: none;
                        left: {{ pin.settings.horizontal_position }}%;
                        top: {{ pin.settings.vertical_position }}%;
                        {% case pin.settings.product_position %}
                          {% when "top" %}
                            transform: translate(-33%, -100%);
                          {% when "bottom" %}
                            transform: translate(-70%, -115px);
                          {% when "left" %}
                            transform: translate(-60%, -100%);
                          {% when "right" %}
                            transform: translate(32px, -50%);
                          {% when "top-left" %}
                            transform: translate(-100%, -100%);
                          {% when "top-right" %}
                            transform: translate(0%, -100%);
                          {% when "bottom-left" %}
                            transform: translate(-100%, 0%);
                          {% when "bottom-right" %}
                            transform: translate(0%, 0%);
                          {% else %}
                            transform: translate(-50%, 32px);
                        {% endcase %}
                      "
                    >
                      <span class="home-stl-pin-product-image">
                        <picture>
                          <source
                            type="image/webp"
                            srcset="
                              {{ pin.settings.pin_product.featured_image | image_url: width: 80, format: 'webp' }} 80w,
                              {{ pin.settings.pin_product.featured_image | image_url: width: 80, format: 'webp' }} 80w,
                              {{ pin.settings.pin_product.featured_image | image_url: width: 80, format: 'webp' }} 80w
                            "
                            sizes="(max-width: 768px) 100vw, 300px"
                          >
                          <source
                            type="image/jpeg"
                            srcset="
                              {{ pin.settings.pin_product.featured_image | image_url: width: 80 }} 80w,
                              {{ pin.settings.pin_product.featured_image | image_url: width: 80 }} 80w,
                              {{ pin.settings.pin_product.featured_image | image_url: width: 80 }} 80w
                            "
                            sizes="(max-width: 768px) 100vw, 300px"
                          >
                          <img
                            src="{{ pin.settings.pin_product.featured_image | image_url: width: 80 }}"
                            alt="{{ block.settings.card_image.alt | escape }}"
                            title="{{ block.settings.card_image.alt | escape }}"
                            loading="lazy"
                            decoding="async"
                            style="width: auto; height: 100%; border-radius: 12px; object-fit: cover;"
                            width="40"
                            height="40"
                          >
                        </picture>
                      </span>
                      <span>
                        <p style="margin: 0; font-size: 12px; line-height: initial;">
                          {{ pin.settings.pin_product.title }}
                        </p>
                        <p style="margin: 8px 0 0; font-size: 10px; line-height: initial; text-decoration: underline;">
                          Shop Now
                        </p>
                      </span>
                    </a>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
.home-shop-the-look{margin-block:0;padding:0 0;padding-top:30px;padding-bottom:30px;overflow:hidden}
.home-stl-heading{height:auto!important;margin:0;font-size:28px!important;line-height:150%;font-weight:500;line-height:normal;text-align:center;vertical-align:middle;text-transform:uppercase;color:#1a1a1a;margin-bottom:0}
.home-stl-subheading{text-align:center;margin:0;font-size:18px;color:#535361;font-family:Futura,sans-serif}
.home-stl-container{margin-top:40px;position:relative}
.shop-look-carousel.owl-carousel .owl-stage-outer{overflow:visible}
.shop-look-carousel.owl-carousel .owl-stage{display:flex;align-items:stretch}
.shop-look-carousel .owl-nav{display:none}
.shop-look-carousel .owl-dots{display:none}
.home-stl-item{position:relative;border-radius:12px;width:100%;height:auto}
.home-stl-item img{border-radius:12px;display:block}
.home-stl-pins-wrapper{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none}
.home-stl-pin{position:absolute;cursor:pointer;width:30px!important;height:30px;z-index:1;pointer-events:all}
.home-stl-pin-product{position:absolute;visibility:hidden;opacity:0;display:flex;align-items:stretch;justify-content:space-between;gap:1rem;min-width:250px;background:#00000080;padding:12px;border-radius:12px;color:#fff;z-index:2;transition:visibility .2s ease,opacity .2s ease;pointer-events:all}
.home-stl-pin-product:hover,.home-stl-pin:hover+.home-stl-pin-product{visibility:visible;opacity:1}
.home-stl-pin-product span{pointer-events:none;text-align:left}
.home-stl-pin-product-image{height:72px;width:72px}
.home-card-grid-section p{line-height:2}
.home-stl-heading{height:auto!important;font-size:24px!important;font-weight:500;line-height:normal;vertical-align:middle;text-transform:uppercase}

/* Ensure cloned items also get pins */
.owl-item .home-stl-pins-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

@media screen and (max-width:428px){
.home-shop-the-look{margin-block:24px}
}
@media screen and (max-width:768px){
.home-shop-the-look{margin:24px 0;padding:0 1rem}
.home-stl-heading{font-size:18px}
.home-stl-subheading{font-size:12px}
.home-stl-pin-product{min-width:200px}
.home-stl-pin-product-image{height:48px;width:48px}
.home-stl-pin-product p{font-size:12px;margin:2px 0}
.home-stl-pin{position:absolute;cursor:pointer;width:26px!important;height:26px;z-index:1}
}
@media only screen and (min-width:1600px) and (max-width:2100px){
.home-stl-heading{font-size:28px!important}
}
@media only screen and (min-width:0px) and (max-width:767px){
.home-stl-container{margin-top:24px}
.home-stl-heading{font-size:18px!important}
.home-stl-subheading{height:auto!important;font-size:12px!important;line-height:2}
.home-shop-the-look{padding-bottom: 20px;margin:0!important; padding-top:20px;}
section.watch-and-buy-section h2.section-subtitle{margin-bottom:24px}
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const carousel = document.getElementById('stl-carousel');

    if (!carousel) return;

    // Initialize Owl Carousel
    $(carousel).owlCarousel({
      items: 3,
      loop: false,
      center: false,
      margin: 20,
      nav: false,
      dots: false,
      autoWidth: false,
      mouseDrag: false,
      touchDrag: false,
      pullDrag: false,
      freeDrag: false,
      stagePadding: 0,
      responsive: {
        0: {
          items: 1,
          margin: 12,
          center: true,
          loop: true,
          mouseDrag: true,
          touchDrag: true,
          pullDrag: true,
          stagePadding: 50,
        },
        768: {
          items: 3,
          center: false,
          loop: false,
          mouseDrag: false,
          touchDrag: false,
          pullDrag: false,
          stagePadding: 0,
        },
        1000: {
          items: 3,
          center: false,
          loop: false,
          mouseDrag: false,
          touchDrag: false,
          pullDrag: false,
          stagePadding: 0,
        },
      },
      onInitialized: function(event) {
        // Ensure pins work on cloned items
        fixPinsOnClonedItems();
      },
      onTranslated: function(event) {
        // Fix pins after carousel moves
        fixPinsOnClonedItems();
      }
    });

    function fixPinsOnClonedItems() {
      // This ensures cloned carousel items also display pins correctly
      const allItems = carousel.querySelectorAll('.owl-item');
      allItems.forEach(item => {
        if (!item.classList.contains('cloned')) return;
        
        const pinsWrapper = item.querySelector('.home-stl-pins-wrapper');
        if (pinsWrapper) {
          pinsWrapper.style.position = 'absolute';
          pinsWrapper.style.top = '0';
          pinsWrapper.style.left = '0';
          pinsWrapper.style.width = '100%';
          pinsWrapper.style.height = '100%';
        }
      });
    }
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const shopNowLinks = document.querySelectorAll('.stl-shop-now');

    shopNowLinks.forEach(function(link) {
      link.addEventListener('click', function(event) {
        const promoId = link.getAttribute('data-promo-id') || '';
        const creativeName = link.getAttribute('data-creative-name') || 'Shop_the_look_banner_image';
        const promoPosition = link.getAttribute('data-promo-position') || 'homepage_shop_the_look';

        // Push to GTM dataLayer
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "promoClick",
          promoClick: {
            promo_id: promoId,
            creative_name: creativeName,
            promo_position: promoPosition
          }
        });

        console.log('GTM promoClick fired:', promoId, creativeName, promoPosition);
      });
    });
  });
</script>