<section class="facts-section section-{{ section.id }}">
  <div class="facts-container">

    {% for block in section.blocks %}
      <div class="fact-card" {{ block.shopify_attributes }}>
        
        {% if block.settings.heading %}
          <h3 class="fact-title">{{ block.settings.heading }}</h3>
        {% endif %}

        {% if block.settings.text %}
          <p class="fact-text">
            <span class="fact-short">{{ block.settings.text | truncate: 120 }}</span>
            <span class="fact-full" style="display:none;">{{ block.settings.text }}</span>
          </p>
          <button class="read-more-btn" type="button">Read more</button>
        {% endif %}

      </div>
    {% endfor %}

  </div>
</section>

<style>
.facts-section .fact-card {
  background: #f8f1e8;
  padding: 22px;
  border-radius: 12px;
  margin-bottom: 20px;
}

.facts-section .fact-title {
  font-size: 22px;
  font-weight: 600;
  margin:0px;
}

.facts-section .fact-text {
    font-size: 15px;
    line-height: 1.6;
    color: #222;
    margin:0px;
}

.facts-section .read-more-btn {
  background: none;
  border: none;
  padding: 0;
  margin-top: 5px;
  color: #000;
  font-weight: 500;
  cursor: pointer;
  text-decoration: underline;
}
</style>

<script>
document.querySelectorAll('.facts-section .read-more-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    let card = this.closest('.fact-card');
    let shortText = card.querySelector('.fact-short');
    let fullText = card.querySelector('.fact-full');

    if (fullText.style.display === "none") {
      fullText.style.display = "inline";
      shortText.style.display = "none";
      this.textContent = "Read less";
    } else {
      fullText.style.display = "none";
      shortText.style.display = "inline";
      this.textContent = "Read more";
    }
  });
});
</script>

{% schema %}
{
  "name": "Facts List",
  "settings": [
  ],
  "blocks": [
    {
      "type": "fact",
      "name": "Fact item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "FACTS"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Paragraph"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Facts List"
    }
  ]
}
{% endschema %}
