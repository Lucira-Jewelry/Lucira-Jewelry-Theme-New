{% schema %}
{
  "name": "Custom Map with Button",
  "settings": [
    {
      "type": "html",
      "id": "map_iframe",
      "label": "Google Maps Iframe",
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "DIRECT ME"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
    }
  ],
  "presets": [
    {
      "name": "Custom Map with Button",
      "category": "Contact"
    }
  ]
}
{% endschema %}

<section class="map-section">
  <div class="map-container">
    <div class="map-frame">
<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3768.09804650552!2d72.83715459999999!3d19.190919499999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be7b79870c015b5%3A0x268fe0bb8a89f9bb!2sLucira%20Jewelry!5e0!3m2!1sen!2sin!4v1756794207014!5m2!1sen!2sin" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>    </div>
  </div>
</section>

<style>
.map-section{position:relative;width:100%;height:450px;margin-bottom:30px}
.map-container{position:relative;width:100%;height:100%}
.map-frame iframe{width:100%!important;height:450px!important;border:none}
.map-frame iframe{width:100%;height:100%;border:none}
.map-marker{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center}
.map-marker .pin{width:20px;height:20px;background:#8b5c5c;border-radius:50%;margin:0 auto 10px;border:3px solid #fff;box-shadow:0 0 8px rgba(0,0,0,.3)}
.direct-btn{background:#8b5c5c;color:#fff;border:none;padding:8px 20px;border-radius:20px;cursor:pointer;font-weight:600;text-decoration:none}
.direct-btn:hover{background:#6a4343}
</style>
