{% schema %}
{
  "name": "Upcoming Events Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR UPCOMING EVENTS"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor."
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4"
    }
  ],
  "presets": [
    {
      "name": "Upcoming Events – Image Grid"
    }
  ]
}
{% endschema %}

<section class="upcoming-events">
  <div class="upcoming-events__container">

    <!-- Heading -->
    <div class="upcoming-events__header">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
    </div>

    <!-- Image Grid -->
    <div class="upcoming-events__grid">
      {% if section.settings.image_1 != blank %}
        <img src="{{ section.settings.image_1 | image_url: width: 600 }}" alt="Event image 1">
      {% endif %}

      {% if section.settings.image_2 != blank %}
        <img src="{{ section.settings.image_2 | image_url: width: 600 }}" alt="Event image 2">
      {% endif %}

      {% if section.settings.image_3 != blank %}
        <img src="{{ section.settings.image_3 | image_url: width: 600 }}" alt="Event image 3">
      {% endif %}

      {% if section.settings.image_4 != blank %}
        <img src="{{ section.settings.image_4 | image_url: width: 600 }}" alt="Event image 4">
      {% endif %}
    </div>

  </div>
</section>

<style>
.upcoming-events{padding:30px 0}
.upcoming-events__container{max-width:1300px;margin:0 auto;padding:0 20px}
.upcoming-events__header{text-align:center;margin-bottom:30px}
.upcoming-events__header h2{font-size:22px;letter-spacing:1.5px;margin-bottom:8px;text-transform:uppercase}
.upcoming-events__header p{font-size:13px;color:#666;max-width:520px;margin:0 auto}
.upcoming-events__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.upcoming-events__grid img{width:100%;height:260px;object-fit:cover;border-radius:4px}
@media (max-width:1024px){
.upcoming-events__grid{grid-template-columns:repeat(2,1fr)}
}
@media (max-width:640px){
.upcoming-events__grid{grid-template-columns:1fr}
.upcoming-events__grid img{height:220px}
}
</style>
