{% comment %} 
<style>
  .brad_{{ section.id }} {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  @media (max-width: 767px) {
    .brad_{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  .brad_{{ section.id }} .how-it-works-heading {
    text-align: center;
    margin: 0;
    font-weight: 500;
    font-size: 24px;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
    margin-bottom: 12px;
}

.brad_{{ section.id }} .how-it-works-subheading {
    text-align: center;
    margin: 0;
    margin-bottom: 40px;
    font-weight: 400;
    font-size: 18px;
    line-height: 24px;
    vertical-align: middle;
  }

  .brad_{{ section.id }} .how-it-works-left {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .brad_{{ section.id }} .how-it-works-step {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    cursor:default;
  }

  .brad_{{ section.id }} .how-it-works-step-image {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 16px;
  }

  .brad_{{ section.id }} .how-it-works-step img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .brad_{{ section.id }} .how-it-works-step:hover img {
    transform: scale(1.05);
  }

  .brad_{{ section.id }} .how-it-works-step-content {
    color: #000;
    font-size: 14px;
  }

  .brad_{{ section.id }} .how-it-works-step-content .step-number {
    margin: 0;
    font-weight: 400;
    font-size: 18px;
    vertical-align: middle;
    margin-bottom: 4px;
  }

  .brad_{{ section.id }} .how-it-works-step-content .step-title {
    margin: 0;
    font-weight: 500;
    font-size: 18px;
    line-height: 150%;
    text-transform: uppercase;
  }

  .brad_{{ section.id }} .how-it-works-right {
    position: relative;
  }

  .brad_{{ section.id }} .how-it-works-video {
    width: 100%;
    height: auto;
    border-radius: 10px;
    object-fit: cover;
    display: block;
  }

    @media (max-width: 1440px) {
    .brad_{{ section.id }} .how-it-works-heading{
      font-size: 24px;
      margin-bottom: 9px;
    }
    .brad_{{ section.id }} .how-it-works-subheading{
      font-size: 18px;
      margin-bottom: 30px;
    }
    .brad_{{ section.id }} .how-it-works-step-content .step-number {
      font-size: 12px;
    }
    .brad_{{ section.id }} .how-it-works-step-content .step-title {
      font-size: 18px;
    }
    .brad_{{ section.id }} .how-it-works-step-image {
      margin-bottom: 12px;
    }
  }

  /* Responsive */
  @media (max-width: 767px) {
    .brad_{{ section.id }} .how-it-works-container {
      display: flex;
      flex-direction: column-reverse;
      gap: 12px;
    }

    .brad_{{ section.id }} .how-it-works-right {
      order: -1;
    }

    .brad_{{ section.id }} .how-it-works-heading {
        font-size: 18px;
        margin-bottom: 0;
        line-height:1.7;
    }

    .brad_{{ section.id }} .how-it-works-subheading {
      font-size: 12px;
      margin-bottom: 30px;
    }
    .brad_{{ section.id }} .how-it-works-left{
        gap:12px;
        grid-template-columns: repeat(2, 1fr);
    }
    .brad_{{ section.id }} .how-it-works-step-content .step-number{
        font-size: 8px;
    }
    .brad_{{ section.id }} .how-it-works-step-content .step-title{
        font-size: 12px;
    }
    .brad_{{ section.id }} .how-it-works-step-image {
      margin-bottom: 8px;
    }
  }
</style>

<div class="page-width brad_{{ section.id }}">
  <section class="how-it-works-section">
    {% if section.settings.heading != blank %}
      <h2 class="how-it-works-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="how-it-works-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="how-it-works-container">
      <div class="how-it-works-left">
        {% for block in section.blocks %}
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="how-it-works-step" target="_blank">
          {% else %}
            <div class="how-it-works-step">
          {% endif %}

          <div class="how-it-works-step-image">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: alt: block.settings.title }}
            {% endif %}
          </div>

          <div class="how-it-works-step-content">
            {% if block.settings.step_number != blank %}
              <p class="step-number">Step {{ block.settings.step_number }}</p>
            {% endif %}
            {% if block.settings.title != blank %}
              <p class="step-title">{{ block.settings.title }}</p>
            {% endif %}
          </div>

          {% if block.settings.link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "How It Works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "HOW IT WORKS"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Right Side Video"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "default": 80,
      "min": 0,
      "max": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "default": 80,
      "min": 0,
      "max": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "default": 40,
      "min": 0,
      "max": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "default": 40,
      "min": 0,
      "max": 100,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step Image"
        },
        {
          "type": "text",
          "id": "step_number",
          "label": "Step Number (e.g. 01, 02)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Step Link"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "How It Works"
    }
  ]
}
{% endschema %} {% endcomment %}


