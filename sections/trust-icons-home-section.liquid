<div class="lucira-trust-icons-section">
  <div class="page-width">
    
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="heading-wrapper">
        {% if section.settings.heading != blank %}
          <h2 class="lucira-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="lucira-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="lucira-trust-icons-wrapper">
      <div class="grid-row">
        {% for block in section.blocks %}
          <div class="grid-column">
            <div class="trust-icon-wrapper-lucira">
              
              <div class="lucira-icon-wrap">
                {% if block.settings.icon != blank %}
                  <img
                    src="{{ block.settings.icon | image_url: width: 100 }}"
                    alt="{{ block.settings.title }}"
                    loading="lazy"
                  >
                {% else %}
                  {{ 'icon-cart.svg' | inline_asset_content }}
                {% endif %}
              </div>

              <div class="lucira-icon-content">
                <h3>{{ block.settings.title }}</h3>
                <p>{{ block.settings.text }}</p>
              </div>

            </div>
          </div>
        {% endfor %}
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Lucira Trust Icons",
  "tag": "section",
  "class": "section-lucira-trust-icons",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Shop With Us"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Trusted by thousands of happy customers"
    }
  ],
  "blocks": [
    {
      "type": "icon",
      "name": "Trust Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "15 Days Easy Return"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Keep it only if you love it."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Lucira Trust Icons",
      "blocks": [
        { "type": "icon" },
        { "type": "icon" },
        { "type": "icon" },
        { "type": "icon" }
      ]
    }
  ]
}
{% endschema %}