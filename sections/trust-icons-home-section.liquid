<div class="lucira-trust-icons-section">
  <div class="page-width">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="heading-wrapper">
        {% if section.settings.heading != blank %}
          <h2 class="lucira-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="lucira-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="lucira-trust-icons-wrapper">
      <div class="grid-row">
        {% for block in section.blocks %}
          <div class="grid-column">
            <div class="trust-icon-wrapper-lucira">
              
              <div class="lucira-icon-wrap">
                <div class="lucira-icon-wrap">
                    {% if block.settings.svg_code != blank %}
                        {{ block.settings.svg_code }}
                    {% endif %}
                </div>
              </div>

              <div class="lucira-icon-content">
                <h3>{{ block.settings.title }}</h3>
                <p>{{ block.settings.text }}</p>
              </div>

            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
    .lucira-trust-icons-section { padding: 30px 0; }
    .lucira-trust-icons-section p.lucira-subheading { margin-top: 0; font-size: 18px; color: #666; margin-bottom: 0; line-height: 34px; text-align: center; }
    .lucira-trust-icons-section h2.lucira-heading { margin: 0; font-weight: 500; font-size: 24px; line-height: 150%; text-align: center; vertical-align: middle; text-transform: uppercase; color: #1a1a1a; }
    .lucira-trust-icons-section .heading-wrapper {margin-bottom: 40px;}
    .lucira-trust-icons-section {display: flex; align-items: center; gap: 12px;}
    .trust-icon-wrapper-lucira {display: flex; align-items: center; gap: 12px;}
    .trust-icon-wrapper-lucira .lucira-icon-wrap svg { width: 50px; display: block; cursor: auto;}
    .trust-icon-wrapper-lucira h3 {font-weight: 500; font-size: 14px; line-height: 150%; letter-spacing: 1px; vertical-align: middle; text-transform: uppercase; margin-top: 0; text-align: left;     margin-bottom: 4px;}
    .trust-icon-wrapper-lucira p { font-family: Futura Std; font-weight: 400; font-size: 12px; line-height: 150%; letter-spacing: 1px; vertical-align: middle; margin: 0; }
    .lucira-trust-icons-wrapper .grid-row {display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; max-width: 1240px; margin: 0 auto;}
    
    @media only screen and (min-width:0px) and (max-width:767px){
      .lucira-trust-icons-section .heading-wrapper { margin-bottom: 25px; }
      .trust-icon-wrapper-lucira h3 {font-weight: 500; font-size: 11px; line-height: 150%; letter-spacing: 1px; vertical-align: middle; text-transform: uppercase; margin-top: 0; text-align: left; margin-bottom: 0 !important;}
      .trust-icon-wrapper-lucira p {display: none;}
      .lucira-trust-icons-wrapper .grid-row {display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px 36px; max-width: 312px; margin: 0 auto;}
      .lucira-trust-icons-section p.lucira-subheading {font-size: 12px; line-height: 1.9;}
      .lucira-trust-icons-section h2.lucira-heading { font-size: 18px; }
      .trust-icon-wrapper-lucira { display: flex; align-items: center; gap: 8px; }
      .trust-icon-wrapper-lucira { display: flex; align-items: center; gap: 8px; }
      .trust-icon-wrapper-lucira h3 {max-width: 110px;}
      .trust-icon-wrapper-lucira .lucira-icon-wrap svg { width: 42px; display: block; }
    }

    @media only screen and (min-width:0px) and (max-width:385px){
      
    }
</style>

{% schema %}
{
  "name": "Lucira Trust Icons",
  "tag": "section",
  "class": "section-lucira-trust-icons",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Shop With Us"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Trusted by thousands of happy customers"
    }
  ],
  "blocks": [
    {
      "type": "icon",
      "name": "Trust Icon",
      "settings": [
        {
          "type": "html",
          "id": "svg_code",
          "label": "SVG Code",
          "info": "Paste inline SVG code here"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "15 Days Easy Return"
        },
        {
          "type": "html",
          "id": "text",
          "label": "Description",
          "default": "Keep it only if you love it."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Lucira Trust Icons",
      "blocks": [
        { "type": "icon" },
        { "type": "icon" },
        { "type": "icon" },
        { "type": "icon" }
      ]
    }
  ]
}
{% endschema %}