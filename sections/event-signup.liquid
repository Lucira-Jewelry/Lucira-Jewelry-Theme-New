{% schema %}
{
  "name": "Event Signup",
  "settings": [
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BE THE FIRST ONE TO KNOW ABOUT OUR UPCOMING EVENTS"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SUBMIT"
    }
  ],
  "presets": [
    {
      "name": "Event Signup Section"
    }
  ]
}
{% endschema %}

<section class="event-signup">
  <div class="event-signup__wrapper">
    
    <!-- Left Image -->
    <div class="event-signup__image">
      {% if section.settings.left_image != blank %}
        <img 
          src="{{ section.settings.left_image | image_url: width: 800 }}"
          alt="Event image"
          loading="lazy"
        >
      {% endif %}
    </div>

    <!-- Right Content -->
    <div class="event-signup__content">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>

      <form method="post" action="/contact#event-signup" class="event-signup__form">
        <input type="hidden" name="form_type" value="contact">
        <input type="hidden" name="utf8" value="✓">

        <div class="form-field">
          <label>Enter Full Name*</label>
          <input type="text" name="contact[name]" placeholder="Enter Your Full Name" required>
        </div>

        <div class="form-field">
          <label>Enter Phone Number*</label>
          <input type="tel" name="contact[phone]" placeholder="Enter Your Phone Number" required>
        </div>

        <div class="form-field">
          <label>Enter Mail ID*</label>
          <input type="email" name="contact[email]" placeholder="Enter Your Mail ID" required>
        </div>

        <button type="submit" class="event-signup__btn">
          {{ section.settings.button_text }}
        </button>
      </form>
    </div>

  </div>
</section>

<style>
.event-signup__content,.event-signup__image{opacity:0;transition:all 1.6s cubic-bezier(.25,.46,.45,.94);will-change:transform,opacity}
.event-signup__image{transform:translateX(-80px)}
.event-signup__content{transform:translateX(80px)}
.event-signup__wrapper.is-visible .event-signup__content,.event-signup__wrapper.is-visible .event-signup__image{opacity:1;transform:translateX(0)}
.event-signup__content,.event-signup__image,.upcoming-events__grid{opacity:0;transition:all 1.6s cubic-bezier(.16,1,.3,1);will-change:transform,opacity}
.event-signup__image{transform:translateX(-80px)}
.event-signup__content{transform:translateX(80px)}
.upcoming-events__grid{transform:translateX(80px)}
.event-signup__wrapper.is-visible .event-signup__content,.event-signup__wrapper.is-visible .event-signup__image,.upcoming-events__grid.is-visible{opacity:1;transform:translateX(0)}
.event-signup{padding:30px 0}
.event-signup__wrapper{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.event-signup__image img{width:100%;height:auto;border-radius:6px;object-fit:cover}
.event-signup__content h2{font-size:32px;letter-spacing:1px;margin-bottom:15px;text-transform:uppercase;text-align:center}
.event-signup__content p{font-size:14px;color:#666;margin-bottom:30px;max-width:420px}
.event-signup__form{max-width:420px}
.form-field{margin-bottom:18px}
.form-field label{display:block;font-size:12px;margin-bottom:6px;color:#333}
.form-field input{width:100%;padding:10px 12px;border:1px solid #ddd;font-size:13px}
.event-signup__btn{margin-top:10px;background:#b08a8a;color:#fff;border:none;padding:12px;width:100%;font-size:13px;letter-spacing:1px;cursor:pointer;text-transform:uppercase}
.event-signup__btn:hover{opacity:.9}
@media (max-width:768px){
.event-signup__wrapper{grid-template-columns:1fr;gap:40px}
.event-signup{padding:50px 20px}
}
</style>


<script>
document.addEventListener("DOMContentLoaded", function () {

  const animatedElements = document.querySelectorAll(
    ".event-signup__wrapper, .upcoming-events__grid"
  );

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.25 }
  );

  animatedElements.forEach(el => observer.observe(el));

});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const section = document.querySelector(".event-signup__wrapper");

  if (!section) return;

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target); // animate once only
        }
      });
    },
    {
      threshold: 0.3
    }
  );

  observer.observe(section);

});
</script>