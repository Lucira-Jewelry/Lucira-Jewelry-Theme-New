{% schema %}
{
  "name": "Home Cards Grid",
  "settings": [
    {
      "type": "text",
      "id": "header",
      "label": "Header"
    },
    {
      "type": "text",
      "id": "subheader",
      "label": "Subheader"
    },
    {
      "type": "text",
      "id": "gtm-prefix",
      "label": "GTM Prefix"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card Image"
        },
        {
          "type": "image_picker",
          "id": "card_image_mobile",
          "label": "Card Image (Mobile)"
        },
        {
          "type": "url",
          "id": "card_link",
          "label": "Card Link"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title",
          "default": "Card Title"
        },
        {
          "type": "textarea",
          "id": "card_description",
          "label": "Card Description",
          "default": "Card description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Page Cards Grid"
    }
  ]
}
{% endschema %}

<section class="home-card-grid-section">
  <div class="page-width">
    <h2 class="home-card-grid-main-header">{{ section.settings.header }}</h2>
    <p class="home-card-grid-main-subheader">{{ section.settings.subheader }}</p>

    <!-- DESKTOP GRID (hidden on mobile) -->
    <div class="home-card-grid-container hide-mobile">
      {% for block in section.blocks %}
        {% assign odd_or_even = forloop.length | modulo: 2 %}
        {% assign second_last = forloop.length | minus: 1 %}

        <div
          class="home-card-grid"
          {{ block.shopify_attributes }}
          {% if odd_or_even == 1 and forloop.index == second_last %}
            
          {% endif %}
        >
          <a
            href="{{ block.settings.card_link }}"
            class="home-card-grid-link home-tile {{ section.settings.gtm-prefix }}"
            data-info="tile-{{ forloop.index }}"
          >
            {% if block.settings.card_image %}
              <picture>
                <!-- Medium screens (tablet) -->
                <source 
                  media="(min-width: 750px) and (max-width: 1199px)" 
                  srcset="
                    {{ block.settings.card_image | img_url: '400x' }} 1x,
                    {{ block.settings.card_image | img_url: '800x' }} 2x
                  "
                >
                <!-- Large screens (desktop and above) -->
                <source 
                  media="(min-width: 1200px)" 
                  srcset="
                    {{ block.settings.card_image | img_url: '800x' }} 1x,
                    {{ block.settings.card_image | img_url: '1600x' }} 2x
                  "
                >
                <!-- Fallback for desktop -->
                <img 
                  src="{{ block.settings.card_image | img_url: '400x' }}" 
                  srcset="
                    {{ block.settings.card_image | img_url: '400x' }} 1x,
                    {{ block.settings.card_image | img_url: '800x' }} 2x
                  "
                  sizes="(min-width: 750px) and (max-width: 1199px) 50vw, (min-width: 1200px) 800px"
                  alt="{{ block.settings.card_title | escape }}"
                  class="card-image"
                  loading="lazy"
                  width="800"
                  height="auto"
                >
              </picture>
            {% endif %}
            <div class="home-card-grid-content">
              <span style="max-width: 100%;">
                <div class="home-card-grid-title">{{ block.settings.card_title }}</div>
                <p class="home-card-grid-description">{{ block.settings.card_description }}</p>
              </span>
              <span>
                <svg class="icon home-card-grid-arrow">
                  <use xlink:href="#lucira blogs arrow 1"></use>
                </svg>
              </span>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>

    <!-- MOBILE LAYOUT (hidden on desktop) -->
    <div class="hide-desktop">
      <!-- Mobile Static Top Card -->
      <div class="home-card-grid-container-mobile" style="margin-bottom: 1rem;">
        {% assign block = section.blocks.first %}
        <div class="home-card-slider-sticky-item">
          <a href="{{ block.settings.card_link }}" class="home-tile {{ section.settings.gtm-prefix }}">
            {% if block.settings.card_image %}
              <picture>
                <!-- Mobile only -->
                <source 
                  media="(max-width: 749px)" 
                  srcset="
                    {{ block.settings.card_image | img_url: '360x' }} 1x,
                    {{ block.settings.card_image | img_url: '720x' }} 2x
                  "
                >
                <img 
                  src="{{ block.settings.card_image | img_url: '360x' }}" 
                  srcset="
                    {{ block.settings.card_image | img_url: '360x' }} 1x,
                    {{ block.settings.card_image | img_url: '720x' }} 2x
                  "
                  sizes="100vw"
                  alt="{{ block.settings.card_title | escape }}"
                  class="card-image"
                  loading="lazy"
                  width="360"
                  height="auto"
                >
              </picture>
            {% endif %}
            <div class="home-card-grid-content">
              <span style="max-width: 85%;">
                <h3 class="home-card-grid-title">{{ block.settings.card_title }}</h3>
                <p class="home-card-grid-description">{{ block.settings.card_description }}</p>
              </span>
              <span>
                <svg class="icon home-card-grid-arrow" style="width: 40px; height: 40px;">
                  <use xlink:href="#lucira blogs arrow 1"></use>
                </svg>
              </span>
            </div>
          </a>
        </div>
      </div>

      <!-- Mobile Slider for Remaining Cards -->
      <div
        class="home-card-grid-container-mobile"
        style="{% if section.blocks.size > 2 %} align-items: flex-start; margin-bottom: -2rem; {% endif %}"
      >
        {% for block in section.blocks %}
          {% if forloop.index > 1 %}
            <div
              class="home-card-slider-item 11"
              style="{% if section.blocks.size > 2 %} height: 90%; {% else %} height: 100%; {% endif %}"
            >
              <a href="{{ block.settings.card_link }}" class="home-tile {{ section.settings.gtm-prefix }}">
                {% if block.settings.card_image %}
                  <picture>
                    {% if block.settings.card_image_mobile %}
                      <source
                        media="(max-width: 749px)"
                        srcset="{{ block.settings.card_image_mobile | image_url: width: 540 }}"
                      >
                    {% endif %}
                    <img
                      src="{{ block.settings.card_image | image_url: width: 360 }}"
                      srcset="
                        {{ block.settings.card_image | image_url: width: 360 }} 360w,
                        {{ block.settings.card_image | image_url: width: 540 }} 540w,
                        {{ block.settings.card_image | image_url: width: 720 }} 720w
                      "
                      sizes="100vw"
                      width="360"
                      height="300"
                      loading="lazy"
                      alt="{{ block.settings.card_title }}"
                      class="card-image"
                    >
                  </picture>
                {% endif %}
                <div class="home-card-grid-content">
                  <span style="max-width: 85%;">
                    <h3 class="home-card-grid-title">{{ block.settings.card_title }}</h3>
                    <p class="home-card-grid-description">{{ block.settings.card_description }}</p>
                  </span>
                  <span>
                    <svg class="icon home-card-grid-arrow">
                      <use xlink:href="#lucira blogs arrow 1"></use>
                    </svg>
                  </span>
                </div>
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Select all banner tiles based on a shared class
    const bannerTiles = document.querySelectorAll('.home-tile');

    bannerTiles.forEach(function (tile) {
      tile.addEventListener('click', function () {
        // Find the promo name from the title inside the tile
        const titleElement = tile.querySelector('.home-card-grid-title');
        const promoName = titleElement ? titleElement.textContent.trim() : 'Unknown Promo';

        // Construct the promo ID based on index or fallback
        const index = Array.from(bannerTiles).indexOf(tile) + 1;
        const promoId = `home-banner-${index}`;

        const promoData = {
          event: 'promoClick',
          promoClick: {
            promo_id: promoId,
            creative_name: 'Homepage Collection Banner',
            promo_name: promoName,
          },
        };

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push(promoData);
      });
    });
  });

  {% comment %} document.addEventListener("DOMContentLoaded", function () {
  // Scroll reveal for section
  const sections = document.querySelectorAll('.home-card-grid-section');
  if (sections.length) {
    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });

    sections.forEach(section => observer.observe(section));
  }
}); {% endcomment %}
  
</script>

<style>
.home-card-grid-section {
  content-visibility: auto;
  contain-intrinsic-size: 650px auto;
  transform: translateY(0);
  opacity: 1;
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.home-card-grid-section.visible {
  opacity: 1;
  transform: translateY(0);
}

 
  p.home-card-grid-main-header{text-align:center;font-size:24px;margin:0;color:#000;font-family:Futura,sans-serif;}
  .home-card-grid-main-header{height:auto!important;}
  .home-card-grid-main-subheader{text-align:center;font-size:20px;color:#666;font-family:Futura,sans-serif;}
  .home-card-grid-container{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;}
  .home-card-grid{overflow:hidden;position:relative;background:#fff;}
  .home-card-grid .card-image,.home-card-slider-item .card-image,.home-card-slider-sticky-item .card-image{border-radius:12px;width:100%;height:100%;object-fit:cover;object-position:bottom;}
  .home-card-grid-content{position: absolute; bottom: 20px; padding-inline: 30px !important; color: #fff; width: 100%; display: flex ; justify-content: space-between; align-items: flex-end !important; gap: 10px !important;}
  .home-card-grid-title{color:#fff;margin:0;font-size:24px;font-family:Futura,sans-serif;}
  .home-card-grid-description{margin:0;font-size:18px;font-family:Futura,sans-serif;}
  .home-card-grid-arrow { height: 35px !important; width: 35px !important; transition: transform .5s ease; margin-bottom: 8px; }
  .home-card-grid-container-mobile{display:none;width:100%;aspect-ratio:1/1;overflow-x:auto;overflow-y:hidden;gap:10px;align-items:center;}
  .home-card-grid-container-mobile::-webkit-scrollbar{display:none;}
  .home-card-slider-sticky-item{height:100%;aspect-ratio:1/1;position:relative;}
  .home-card-slider-item{aspect-ratio:1/1;position:relative;}
  .home-card-grid:hover .home-card-grid-arrow{transform:rotate(-45deg);}
  .home-card-grid-section{padding-top:30px;padding-bottom:30px;margin:0 auto; }
  .home-card-grid-section h2.home-card-grid-main-header{line-height:150%;font-size:24px;margin:0;font-weight:500;line-height:1.7;text-align:center;vertical-align:middle;text-transform:uppercase;color:#1a1a1a;margin-bottom:0;}
  .home-card-grid-section p{font-size:18px;line-height: 1.7;}
  .home-card-grid-section p {margin: 0;}
  p.home-card-grid-main-subheader { margin-bottom: 40px; }
 .home-card-grid-title{    color: #fff; margin: 0; font-size: 24px; font-family: "Futura Std", sans-serif !important; }

  @media screen and (max-width:45em){
    .home-card-grid-section p{font-size:16px;}
    .home-card-grid-section{margin-block:24px;}
    .home-card-grid-container{display:none;}
    .home-card-grid-main-header{font-size:18px;}
    .home-card-grid-main-subheader{font-size:12px;margin:0 0 24px 0;}
    .home-card-grid-container-mobile{display:flex;}
    .home-card-grid-title{font-size:14px;}
    .home-card-grid-description{font-size:10px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%;}
    .home-card-grid-arrow{height:28px;width:28px;}
    .home-card-grid-section{padding-top:30px;padding-bottom:0px;margin:0 auto; }
  }
  @media only screen and (min-width:0px) and (max-width:767px){
    .home-card-grid-main-header{font-size:18px!important;height:auto!important;line-height:1.6!important;}
    .home-card-grid-main-subheader{font-size:12px!important;margin:0 0 24px 0;height:auto!important;}
    .home-card-grid-content{padding-inline:20px!important;}
    .home-card-grid-section{margin-top:0!important;margin-bottom:0!important;padding-bottom:30px!important;padding-top:30px!important;margin:0 auto;}
    .home-card-grid-arrow{height:35px!important;width:35px!important;}
    .home-card-grid-content span{max-width:76%!important;}
    p.home-card-grid-main-subheader {margin-bottom: 30px;}
  }
  @media only screen and (min-width:1600px) and (max-width:2100px){
    .home-card-grid-section{padding-top:30px;padding-bottom:30px;margin:0 auto;}
    .home-card-grid-section h2{font-size:28px;line-height:150%;}
    .home-card-grid-section p{font-size:18px;}
    .home-card-grid-section h2.home-card-grid-main-header{font-size:28px!important;}
    .index .collapsible-content__header h2{font-size:32px;}
  }
</style>