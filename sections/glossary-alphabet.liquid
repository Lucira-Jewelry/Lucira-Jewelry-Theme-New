          <div class="accordion-content">
            <div class="alphabet-grid">
              {% for letter in letters %}
                <button class="alphabet-btn" data-letter="{{ letter }}" onclick="scrollToLetter('{{ letter }}')">
                  {{ letter }}
                </button>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>

      <!-- Terms by Letter -->
      <div class="glossary-terms">
        {% assign letter_map = 'a:letter_a,b:letter_b,c:letter_c,d:letter_d,e:letter_e,f:letter_f,g:letter_g,h:letter_h,i:letter_i,j:letter_j,k:letter_k,l:letter_l,m:letter_m,n:letter_n,o:letter_o,p:letter_p,q:letter_q,r:letter_r,s:letter_s,t:letter_t,u:letter_u,v:letter_v,w:letter_w,x:letter_x,y:letter_y,z:letter_z' | split: ',' %}
        
        {% for letter in letters %}
          {% assign letter_lower = letter | downcase %}
          {% assign block_type = 'letter_' | append: letter_lower %}
          {% assign letter_block = section.blocks | where: 'type', block_type | first %}
          
          {% if letter_block and letter_block.settings.terms != blank %}
            {% assign terms_list = letter_block.settings.terms | newline_to_br | split: '<br />' %}
            <div class="letter-section" id="letter-{{ letter }}" data-letter="{{ letter }}">
              <h2 class="letter-heading">{{ letter }}</h2>
              {% for term_line in terms_list %}
                {% assign term_line = term_line | strip %}
                {% if term_line != blank %}
                  {% assign term_parts = term_line | split: '|' %}
                  {% if term_parts.size == 2 %}
                    <div class="term-item" data-term="{{ term_parts[0] | strip | downcase }}" data-def="{{ term_parts[1] | strip | downcase }}">
                      <h3 class="term-title">{{ term_parts[0] | strip }}</h3>
                      <p class="term-definition">{{ term_parts[1] | strip }}</p>
                    </div>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="no-results" style="display: none;">
        <p>No terms found matching your search.</p>
      </div>
    </main>
  </div>
</div>

<script>
  // Enhanced search functionality
  function setupSearch(inputClass) {
    const input = document.querySelector(`.${inputClass}`);
    if (!input) return;

    input.addEventListener('input', function(e) {
      const query = e.target.value.toLowerCase().trim();
      const sections = document.querySelectorAll('.letter-section');
      const terms = document.querySelectorAll('.term-item');
      const noResults = document.querySelector('.no-results');
      let hasResults = false;

      // Clear search if query is empty
      if (query === '') {
        sections.forEach(s => {
          s.style.display = 'block';
          const sectionTerms = s.querySelectorAll('.term-item');
          sectionTerms.forEach(t => t.style.display = 'block');
        });
        noResults.style.display = 'none';
        return;
      }

      // Hide all sections and terms initially
      sections.forEach(s => {
        s.style.display = 'none';
        const sectionTerms = s.querySelectorAll('.term-item');
        sectionTerms.forEach(t => t.style.display = 'none');
      });

      // Split query into individual words
      const searchWords = query.split(/\s+/).filter(word => word.length > 0);
      
      sections.forEach(section => {
        const sectionTerms = section.querySelectorAll('.term-item');
        let sectionHasMatch = false;

        sectionTerms.forEach(term => {
          const termText = term.dataset.term || '';
          const termDef = term.dataset.def || '';
          const combinedText = (termText + ' ' + termDef).toLowerCase();
          
          // Check if ALL search words are found in the term
          const allWordsMatch = searchWords.every(word => 
            combinedText.includes(word)
          );
          
          if (allWordsMatch) {
            term.style.display = 'block';
            sectionHasMatch = true;
            hasResults = true;
          }
        });

        // Show section if it has any matching terms
        if (sectionHasMatch) {
          section.style.display = 'block';
        }
      });

      // Show/hide no results message
      noResults.style.display = hasResults ? 'none' : 'block';
      
      // Highlight search terms in results
      if (hasResults && searchWords.length > 0) {
        highlightSearchTerms(searchWords);
      } else {
        removeHighlights();
      }
    });
  }

  // Function to highlight search terms in the results
  function highlightSearchTerms(searchWords) {
    const terms = document.querySelectorAll('.term-item[style="display: block;"]');
    
    terms.forEach(term => {
      const titleElement = term.querySelector('.term-title');
      const defElement = term.querySelector('.term-definition');
      
      if (titleElement && defElement) {
        let titleText = titleElement.textContent;
        let defText = defElement.textContent;
        
        // Highlight each search word
        searchWords.forEach(word => {
          const regex = new RegExp(`(${word})`, 'gi');
          titleText = titleText.replace(regex, '<mark>$1</mark>');
          defText = defText.replace(regex, '<mark>$1</mark>');
        });
        
        titleElement.innerHTML = titleText;
        defElement.innerHTML = defText;
      }
    });
  }

  // Function to remove highlights
  function removeHighlights() {
    document.querySelectorAll('.term-item').forEach(term => {
      const titleElement = term.querySelector('.term-title');
      const defElement = term.querySelector('.term-definition');
      
      if (titleElement) {
        titleElement.innerHTML = titleElement.textContent;
      }
      if (defElement) {
        defElement.innerHTML = defElement.textContent;
      }
    });
  }

  // Initialize search for both desktop and mobile
  setupSearch('desktop-search');
  setupSearch('mobile-search');

  // Clear search when clicking on alphabet links
  document.querySelectorAll('.alphabet-link, .alphabet-btn').forEach(link => {
    link.addEventListener('click', function() {
      // Clear search inputs
      document.querySelectorAll('.search-input').forEach(input => {
        input.value = '';
      });
      
      // Trigger search to show all results
      document.querySelectorAll('.search-input').forEach(input => {
        input.dispatchEvent(new Event('input'));
      });
      
      // Remove highlights
      removeHighlights();
    });
  });

  // Smooth scroll to letter
  function scrollToLetter(letter) {
    const section = document.getElementById(`letter-${letter}`);
    if (section) {
      const offset = window.innerWidth <= 968 ? 180 : 100;
      const top = section.getBoundingClientRect().top + window.pageYOffset - offset;
      window.scrollTo({ top, behavior: 'smooth' });
      
      // Close accordion on mobile
      if (window.innerWidth <= 968) {
        const content = document.querySelector('.accordion-content');
        const icon = document.querySelector('.accordion-icon');
        if (content && content.classList.contains('open')) {
          toggleAccordion();
        }
      }
    }
  }

  // Alphabet link clicks
  document.querySelectorAll('.alphabet-link').forEach(link => {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      const letter = this.dataset.letter;
      scrollToLetter(letter);
    });
  });

  // Mobile accordion
  function toggleAccordion() {
    const content = document.querySelector('.accordion-content');
    const icon = document.querySelector('.accordion-icon');
    if (content && icon) {
      content.classList.toggle('open');
      icon.classList.toggle('open');
    }
  }

  // Active letter highlighting on scroll
  let ticking = false;
  window.addEventListener('scroll', function() {
    if (!ticking) {
      window.requestAnimationFrame(function() {
        const sections = document.querySelectorAll('.letter-section');
        const scrollPos = window.pageYOffset + 380;

        sections.forEach(section => {
          const top = section.offsetTop;
          const bottom = top + section.offsetHeight;
          const letter = section.dataset.letter;

          if (scrollPos >= top && scrollPos < bottom) {
            document.querySelectorAll('.alphabet-link, .alphabet-btn').forEach(l => {
              l.classList.remove('active');
            });
            document.querySelectorAll(`[data-letter="${letter}"]`).forEach(l => {
              l.classList.add('active');
            });
          }
        });

        ticking = false;
      });
      ticking = true;
    }
  });

  // Add CSS for highlight
  const style = document.createElement('style');
  style.textContent = `
    mark {
      background-color: #fffacd;
      color: #333;
      padding: 1px 3px;
      border-radius: 2px;
      font-weight: 600;
    }
    
    .search-input:focus {
      outline: 2px solid #333;
      outline-offset: -2px;
    }
  `;
  document.head.appendChild(style);
</script>