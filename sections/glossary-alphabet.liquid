<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .glossary-container {
    max-width: 100%;
    margin: 0 auto;
  }

  .glossary-header {
    text-align: center;
    padding: 20px 20px;
    background: #fff;
  }

  .glossary-title {
    font-size: 36px;
    font-weight: 300;
    letter-spacing: 4px;
    margin: 0;
  }

  /* Sticky Search Container - MOVED HERE */
  .sticky-search-container {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid #e5e5e5;
    padding: 20px 0;
    {% comment %} display:flex;
    flex-direction:row; {% endcomment %}
  }

  .search-wrapper {
    {% comment %} max-width: 1400px; {% endcomment %}
    margin: 0 auto;
    {% comment %} padding: 0 20px; {% endcomment %}
  }

  .search-box {
    position: relative;
    margin: 0 auto;
  }

  .search-input {
    width: 70%;
    padding: 12px 15px 12px 40px;
    border: 1px solid #1a1a1a;
    border-radius: 4px;
    font-size: 13px;
    background: #fff;
  }

  .search-input::placeholder {
    color: #999;
  }

  .search-icon {
    position: absolute;
    left: 15px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 16px;
    color: #666;
  }

  .glossary-layout {
    display: flex;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
  }

  /* Desktop Sidebar */
  .glossary-sidebar {
    width: 440px;
    flex-shrink: 0;
    padding: 20px;
    background: #fff;
    margin-top: 20px;
  }

  .sidebar-inner {
    position: sticky;
    top: 100px; /* Account for sticky search height */
  }

  .alphabet-filter {
    padding: 20px;
  }

  .filter-header {
    align-items: center;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 1.5px;
    color: #333;
  }

  .alphabet-list {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
  }

  .alphabet-item {
    display: block;
  }

  .alphabet-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 15px;
    text-decoration: none;
    color: #1a1a1a;
    background: #F1F1F1;
    font-size: 18px;
    font-weight: 400;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .alphabet-link:hover {
    background: #e8e8e8;
    color: #333;
  }

  .alphabet-link.active {
    background: #F1F1F1;
    color: #1A1A1A;
    font-weight: 500;
  }

  /* Main Content */
  .glossary-content {
    flex: 1;
    padding: 20px 40px 60px 60px;
    min-width: 0;
  }

  .sticky-search-mobile {
    display: none;
  }

  .glossary-terms {
    max-width: 900px;
  }

  .letter-section {
    margin-bottom: 80px;
  }

  .letter-section:last-child {
    margin-bottom: 0;
  }

  .letter-heading {
    font-size: 64px;
    font-weight: 300;
    margin: 0 0 40px 0;
    color: #333;
    letter-spacing: 2px;
  }

  .term-item {
    margin-bottom: 35px;
  }

  .term-item:last-child {
    margin-bottom: 0;
  }

  .term-title {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 1.2px;
    margin: 0 0 10px 0;
    color: #000;
    text-transform: uppercase;
  }

  .term-definition {
    font-size: 14px;
    line-height: 1.7;
    color: #666;
    margin: 0;
  }

  .no-results {
    text-align: center;
    padding: 100px 20px;
    color: #999;
    font-size: 16px;
  }

  /* Mobile Styles */
  @media (max-width: 968px) {
    .sticky-search-container {
      display: none;
    }

    .glossary-sidebar {
      display: none;
    }

    .glossary-content {
      padding: 20px;
    }

    .sticky-search-mobile {
      display: block;
      position: sticky;
      top: 40px;
      background: #fff;
      z-index: 100;
      padding: 20px 0;
      margin-bottom: 30px;
      border-bottom: 1px solid #e5e5e5;
    }

    .mobile-search-box {
      position: relative;
      margin-bottom: 15px;
      padding: 0 20px;
    }

    .alphabet-accordion {
      background: #f5f5f5;
      border-radius: 4px;
      overflow: hidden;
      margin: 0 20px;
    }

    .accordion-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 20px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 1.5px;
      user-select: none;
    }

    .accordion-icon {
      font-size: 12px;
      transition: transform 0.3s ease;
    }

    .accordion-icon.open {
      transform: rotate(180deg);
    }

    .accordion-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease;
    }

    .accordion-content.open {
      max-height: 500px;
      overflow-y: auto;
    }

    .alphabet-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 10px;
      padding: 20px;
    }

    .alphabet-btn {
      padding: 14px;
      background: #fff;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 16px;
      font-weight: 400;
      cursor: pointer;
      transition: all 0.2s ease;
      color: #666;
    }

    .alphabet-btn.active {
      background: #333;
      color: #fff;
      border-color: #333;
    }

    .letter-heading {
      font-size: 48px;
      margin-bottom: 30px;
    }
  }

  @media (max-width: 480px) {
    .search-input {
    width: 100%;
}
    .glossary-title {
      font-size: 28px;
      letter-spacing: 3px;
    }

    .alphabet-grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 8px;
      padding: 15px;
    }

    .alphabet-btn {
      padding: 12px;
      font-size: 14px;
    }

    .letter-heading {
      font-size: 40px;
    }
  }
</style>

