          "type": "letter_t"
        },
        {
          "type": "letter_u"
        },
        {
          "type": "letter_v"
        },
        {
          "type": "letter_w"
        },
        {
          "type": "letter_x"
        },
        {
          "type": "letter_y"
        },
        {
          "type": "letter_z"
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .glossary-container {
    max-width: 100%;
    margin: 0 auto;
  }

  .glossary-header {
    text-align: center;
    padding: 20px 20px;
    background: #fff;
  }

  .glossary-title {
    font-size: 36px;
    font-weight: 300;
    letter-spacing: 4px;
    margin: 0;
  }

  /* Sticky Search Container */
  .sticky-search-container {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid #e5e5e5;
    padding: 20px 40px;
    display: flex;
    align-items: center;
    gap: 29%;
  }

  .alphabet-label {
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 1.5px;
    color: #333;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .search-wrapper {
    flex: 1;
    max-width: 500px;
  }

  .search-box {
    position: relative;
    width: 100%;
  }

  .search-input {
    width: 100%;
    padding: 12px 15px 12px 40px;
    border: 1px solid #1a1a1a;
    border-radius: 8px;
    font-size: 13px;
    background: #fff;
  }

  .search-input::placeholder {
    color: #999;
  }

  .search-icon {
    position: absolute;
    left: 2%;
    top: 55%;
    transform: translateY(-50%);
    font-size: 16px;
    color: #666;
  }

  .glossary-layout {
    display: flex;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
  }

  /* Desktop Sidebar */
  .glossary-sidebar {
    width: 440px;
    flex-shrink: 0;
    padding: 20px;
    background: #fff;
    margin-top: 20px;
  }

  .sidebar-inner {
    position: sticky;
    top: 100px;
  }

  .alphabet-filter {
    padding: 20px;
  }

  .filter-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 1.5px;
    color: #333;
  }

  .alphabet-list {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
  }

  .alphabet-item {
    display: block;
  }

  .alphabet-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 15px;
    text-decoration: none;
    color: #1a1a1a;
    background: #F1F1F1;
    font-size: 18px;
    font-weight: 400;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .alphabet-link:hover {
    background: #e8e8e8;
    color: #333;
  }

  .alphabet-link.active {
    background: #F1F1F1;
    color: #1A1A1A;
    font-weight: 500;
  }

  /* Main Content */
  .glossary-content {
    flex: 1;
    padding: 20px 40px 60px 60px;
    min-width: 0;
  }

  .sticky-search-mobile {
    display: none;
  }

  .glossary-terms {
    max-width: 900px;
  }

  .letter-section {
    margin-bottom: 80px;
  }

  .letter-section:last-child {
    margin-bottom: 0;
  }

  .letter-heading {
    font-size: 64px;
    font-weight: 300;
    margin: 0 0 40px 0;
    color: #333;
    letter-spacing: 2px;
  }

  .term-item {
    margin-bottom: 35px;
  }

  .term-item:last-child {
    margin-bottom: 0;
  }

  .term-title {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 1.2px;
    margin: 0 0 10px 0;
    color: #000;
    text-transform: uppercase;
  }

  .term-definition {
    font-size: 14px;
    line-height: 1.7;
    color: #666;
    margin: 0;
  }

  .no-results {
    text-align: center;
    padding: 100px 20px;
    color: #999;
    font-size: 16px;
  }

  /* Mobile Styles */
  @media (max-width: 968px) {
    .sticky-search-container {
      display: none;
    }

    .glossary-sidebar {
      display: none;
    }

    .glossary-content {
      padding: 20px;
    }

    .sticky-search-mobile {
      display: block;
      position: sticky;
      top: 40px;
      background: #fff;
      z-index: 100;
      padding: 20px 0;
      margin-bottom: 30px;
      border-bottom: 1px solid #e5e5e5;
    }

    .mobile-search-box {
      position: relative;
      margin-bottom: 15px;
      padding: 0 20px;
    }

    .mobile-search-box .search-input {
      width: 100%;
    }

    .alphabet-accordion {
      background: #f5f5f5;
      border-radius: 4px;
      overflow: hidden;
      margin: 0 20px;
    }

    .accordion-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 20px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 1.5px;
      user-select: none;
    }

    .accordion-icon {
      font-size: 12px;
      transition: transform 0.3s ease;
    }

    .accordion-icon.open {
      transform: rotate(180deg);
    }

    .accordion-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease;
    }

    .accordion-content.open {
      max-height: 500px;
      overflow-y: auto;
    }

    .alphabet-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 10px;
      padding: 20px;
    }

    .alphabet-btn {
      padding: 14px;
      background: #fff;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 16px;
      font-weight: 400;
      cursor: pointer;
      transition: all 0.2s ease;
      color: #666;
    }

    .alphabet-btn.active {
      background: #333;
      color: #fff;
      border-color: #333;
    }

    .letter-heading {
      font-size: 48px;
      margin-bottom: 30px;
    }
  }

  @media (max-width: 480px) {
      .search-icon {
    position: absolute;
     left: 34px;
    top: 57%;
    transform: translateY(-50%);
    font-size: 16px;
    color: #666;
  }

    .sticky-search-container {
      padding: 15px 20px;
      flex-direction: column;
      align-items: flex-start;
      gap: 15px;
    }

    .search-wrapper {
      max-width: 100%;
    }

    .glossary-title {
      font-size: 28px;
      letter-spacing: 3px;
    }

    .alphabet-grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 8px;
      padding: 15px;
    }

    .alphabet-btn {
      padding: 12px;
      font-size: 14px;
    }

    .letter-heading {
      font-size: 40px;
    }
  }
</style>

<div class="glossary-container">
  <div class="glossary-header">
    <h1 class="glossary-title">{{ section.settings.title }}</h1>
  </div>

  <!-- Sticky Search Bar -->
  <div class="sticky-search-container">
    <span class="alphabet-label">ALPHABETS</span>
    <div class="search-wrapper">
      <div class="search-box">
