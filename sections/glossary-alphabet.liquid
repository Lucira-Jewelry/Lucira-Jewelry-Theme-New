      <!-- Terms by Letter -->
      <div class="glossary-terms">
        {% assign letter_map = 'a:letter_a,b:letter_b,c:letter_c,d:letter_d,e:letter_e,f:letter_f,g:letter_g,h:letter_h,i:letter_i,j:letter_j,k:letter_k,l:letter_l,m:letter_m,n:letter_n,o:letter_o,p:letter_p,q:letter_q,r:letter_r,s:letter_s,t:letter_t,u:letter_u,v:letter_v,w:letter_w,x:letter_x,y:letter_y,z:letter_z'
          | split: ','
        %}

        {% for letter in letters %}
          {% assign letter_lower = letter | downcase %}
          {% assign block_type = 'letter_' | append: letter_lower %}
          {% assign letter_block = section.blocks | where: 'type', block_type | first %}

          {% if letter_block and letter_block.settings.terms != blank %}
            {% assign terms_list = letter_block.settings.terms | newline_to_br | split: '<br />' %}
            <div class="letter-section" id="letter-{{ letter }}" data-letter="{{ letter }}">
              <h2 class="letter-heading">{{ letter }}</h2>
              {% for term_line in terms_list %}
                {% assign term_line = term_line | strip %}
                {% if term_line != blank %}
                  {% assign term_parts = term_line | split: '|' %}
                  {% if term_parts.size == 2 %}
                    <div
                      class="term-item"
                      data-term="{{ term_parts[0] | strip | downcase }}"
                      data-def="{{ term_parts[1] | strip | downcase }}"
                    >
                      <h3 class="term-title">{{ term_parts[0] | strip }}</h3>
                      <p class="term-definition">{{ term_parts[1] | strip }}</p>
                    </div>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="no-results" style="display: none;">
        <p>No terms found matching your search.</p>
      </div>
