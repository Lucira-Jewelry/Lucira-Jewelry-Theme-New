<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .glossary-container {
    max-width: 100%;
    margin: 0 auto;
  }

  .glossary-header {
    text-align: center;
    padding: 20px 20px;
    background: #fff;
  }

  .glossary-title {
    font-size: 36px;
    font-weight: 500;
    letter-spacing: 4px;
    margin: 0;
  }

  /* Sticky Search Container - Updated for Desktop */
  .sticky-search-container {
    position: sticky;
    top: 60px; /* Adjusted for header height */
    z-index: 1; /* Lower z-index than header dropdown */
    background: #fff;
    border-bottom: 1px solid #e5e5e5;
    padding: 20px 40px;
    display: flex;
    align-items: center;
    gap: 26%;
  }

  @media (min-width: 969px) {
    .sticky-search-container {
      top: 60px !important;
    }
    
    /* Adjust layout positioning for desktop */
    .glossary-layout {
      padding-top: 20px;
    }
    
    /* Adjust sidebar positioning */
    .glossary-sidebar .sidebar-inner {
      top: 155px; /* Account for header + sticky search */
    }
    
    /* Add scroll-margin-top to letter sections for proper scrolling */
    .letter-section {
      scroll-margin-top: 140px; /* Header height + sticky search height + some spacing */
    }
  }

  .alphabet-label {
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 1.5px;
    color: #1a1a1a;
    white-space: nowrap;
    flex-shrink: 0;
    position:relative;
    left:1%;
    display:flex;
    gap:8px;
  }

  .search-wrapper {
    flex: 1;
    max-width: 500px;
  }

  .search-box {
    position: relative;
    width: 100%;
  }

  .search-input {
    width: 100%;
    padding: 12px 15px 12px 40px;
    border: 1px solid #1a1a1a;
    border-radius: 8px;
    font-size: 13px;
    background: #fff;
  }

  .search-input::placeholder {
    color: #999;
  }

  .search-icon {
    position: absolute;
    left: 2%;
    top: 55%;
    transform: translateY(-50%);
    font-size: 16px;
    color: #666;
  }

  .glossary-layout {
    display: flex;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
  }

  /* Desktop Sidebar */
  .glossary-sidebar {
    width: 440px;
    flex-shrink: 0;
    padding: 20px;
    background: #fff;
    {% comment %} margin-top: 20px; {% endcomment %}
  }

  .sidebar-inner {
    position: sticky;
    top: 180px; /* Updated for new positioning */
  }

  .alphabet-filter {
    padding: 0 20px;
  }

  .filter-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 1.5px;
    color: #333;
  }

  .alphabet-list {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
  }

  .alphabet-item {
    display: block;
  }

  .alphabet-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 15px;
    text-decoration: none;
    color: #1a1a1a;
    background: #F1F1F1;
    font-size: 18px;
    font-weight: 400;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .alphabet-link:hover {
    background: #e8e8e8;
    color: #333;
  }

  .alphabet-link.active {
    background: #333;
    color: #fff;
    border-color: #333;
  }

  /* Main Content */
  .glossary-content {
    flex: 1;
    padding: 20px 40px 60px 60px;
    min-width: 0;
  }

  .sticky-search-mobile {
    display: none;
  }

  .glossary-terms {
    max-width: 900px;
  }

  .letter-section {
    margin-bottom: 60px;
    /* Add padding-top to prevent content hiding under sticky header */
    padding-top: 40px;
    margin-top: -40px; /* Compensate for the padding so spacing stays the same */
  }

  .letter-section:first-child {
    padding-top: 0;
    margin-top: 0;
  }

  .letter-heading {
    font-size: 64px;
    font-weight: 300;
    margin: 0 0 25px 0;
    color: #333;
    letter-spacing: 2px;
  }

  .term-item {
    margin-bottom: 20px;
  }

  .term-item:last-child {
    margin-bottom: 0;
  }

  .term-title {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 1.2px;
    margin: 0 0 10px 0;
    color: #000;
    text-transform: uppercase;
  }

  .term-definition {
    font-size: 14px;
    line-height: 1.7;
    color: #666;
    margin: 0;
  }

  .no-results {
    text-align: center;
    padding: 100px 20px;
    color: #999;
    font-size: 16px;
  }

  /* Mobile Styles */
  @media (max-width: 968px) {
    .glossary-header {
      padding: 20px 20px 0 20px;
    }
    
    .sticky-search-container {
      display: none;
    }

    .glossary-sidebar {
      display: none;
    }

    .glossary-content {
      padding: 20px;
    }

    .sticky-search-mobile {
      display: block;
      position: sticky;
      top: 62px;
      background: #fff;
      z-index: 100;
      padding-bottom: 20px;
      padding-top:10px;
      margin-bottom: 30px;
    }

    .mobile-search-box {
      position: relative;
      margin-bottom: 15px;
      margin-top:15px;
      padding: 0 20px;
    }

    .mobile-search-box .search-input {
      width: 100%;
      background:#F9F9F9;
    }

    .alphabet-accordion {
      border-radius: 8px;
      overflow: hidden;
    }

    .accordion-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 20px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 1.5px;
      user-select: none;
      border-bottom: solid 1px #D9D9D9;
    }

    .accordion-icon {
      font-size: 12px;
      transition: transform 0.3s ease;
    }

    .accordion-icon.open {
      transform: rotate(180deg);
    }

    .accordion-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease;
    }

    .accordion-content.open {
      max-height: 500px;
      overflow-y: auto;
    }

    .alphabet-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 10px;
      padding: 20px;
    }

    .alphabet-btn {
      padding: 14px;
      background: #F1F1F1;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s ease;
      color: #1a1a1a;
    }

    .alphabet-btn.active {
      background: #333;
      color: #fff;
      border-color: #333;
    }

    .letter-heading {
      font-size: 48px;
      margin-bottom: 30px;
    }
    
    /* Mobile scroll adjustment */
    .letter-section {
      scroll-margin-top: 180px; /* Adjust based on mobile sticky header height */
      padding-top: 20px;
      margin-top: -20px;
    }
    
    .letter-section:first-child {
      padding-top: 0;
      margin-top: 0;
    }
  }

  @media (max-width: 480px) {
    .search-icon {
      position: absolute;
      left: 34px;
      top: 57%;
      transform: translateY(-50%);
      font-size: 16px;
      color: #666;
    }

    .sticky-search-container {
      padding: 15px 20px;
      flex-direction: column;
      align-items: flex-start;
      gap: 15px;
    }

    .search-wrapper {
      max-width: 100%;
    }

    .glossary-title {
      font-size: 28px;
      letter-spacing: 3px;
    }

    .alphabet-grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 12px;
      padding: 15px;
    }

    .alphabet-btn {
      padding: 14px;
      font-size: 16px;
    }

    .letter-heading {
      font-size: 40px;
    }
    
    .alphabet-accordion .accordion-header span {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight:500;
    }
    
    /* Adjust for smaller mobile */
    .letter-section {
      scroll-margin-top: 200px;
    }
  }
</style>

<div class="glossary-container">
