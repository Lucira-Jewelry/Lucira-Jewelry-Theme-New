<section class="video-call-scheduler">
  <!-- MOBILE IMAGE -->
  {% if section.settings.mobile_image != blank %}
    <div class="scheduler-image videomobile-only">
      <img
        src="{{ section.settings.mobile_image | img_url: 'master' }}"
        width="auto"
        height="auto"
        loading="lazy"
        alt="Video Call Mobile"
      >
    </div>
  {% endif %}

  <div class="scheduler-wrapper page-width" id="form-call">
    {% if section.settings.layout_order == 'form-image' %}
      <!-- FORM FIRST -->
      <div class="scheduler-form">
        <h2>{{ section.settings.videoheading }}</h2>
        <p>{{ section.settings.videosubheading }}</p>

        <div class="contact-form" id="contact-form-container">
          <form id="contact-form" action="/contact#contact-form" method="post" onsubmit="return validateForm()">
            <input type="hidden" name="form_type" value="contact">
            <input type="hidden" name="utf8" value="✓">

            <!-- First Name -->
            <div class="form-group">
              <label class="form-label" for="contact-first-name">First Name</label>
              <input class="form-input" type="text" id="contact-first-name" name="contact[First Name]" required>
              <div class="error-message" id="first-name-error">Please enter your first name</div>
            </div>

            <!-- Email -->
            <div class="form-group">
              <label class="form-label" for="contact-email">Email</label>
              <input class="form-input" type="email" id="contact-email" name="contact[email]" required>
              <div class="error-message" id="email-error">Please enter a valid email address</div>
            </div>

            <!-- Phone -->
            <div class="form-group">
              <label class="form-label" for="contact-phone">Phone Number</label>
              <input class="form-input" type="tel" id="contact-phone" name="contact[Phone]">
              <div class="error-message" id="phone-error">Please enter a valid phone number</div>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="send-button">
              {{ section.settings.button_label }}
            </button>
          </form>
        </div>
      </div>

      {% if section.settings.image != blank %}
        <div class="scheduler-image videodesktop-only">
          <img src="{{ section.settings.image | img_url: 'master' }}" alt="Video Call Desktop">
        </div>
      {% endif %}

    {% else %}
      <!-- IMAGE FIRST -->
      {% if section.settings.image != blank %}
        <div class="scheduler-image videodesktop-only">
          <img src="{{ section.settings.image | img_url: 'master' }}" alt="Video Call Desktop">
        </div>
      {% endif %}

      <div class="scheduler-form">
        <h2>{{ section.settings.videoheading }}</h2>
        <p>{{ section.settings.videosubheading }}</p>

        <div class="contact-form" id="contact-form-container">
          <form id="contact-form" action="/contact#contact-form" method="post" onsubmit="return validateForm()">
            <input type="hidden" name="form_type" value="contact">
            <input type="hidden" name="utf8" value="✓">

            <!-- First Name -->
            <div class="form-group">
              <label class="form-label" for="contact-first-name">First Name</label>
              <input class="form-input" type="text" id="contact-first-name" name="contact[First Name]" required>
              <div class="error-message" id="first-name-error">Please enter your first name</div>
            </div>

            <!-- Email -->
            <div class="form-group">
              <label class="form-label" for="contact-email">Email</label>
              <input class="form-input" type="email" id="contact-email" name="contact[email]" required>
              <div class="error-message" id="email-error">Please enter a valid email address</div>
            </div>

            <!-- Phone -->
            <div class="form-group">
              <label class="form-label" for="contact-phone">Phone Number</label>
              <input class="form-input" type="tel" id="contact-phone" name="contact[Phone]">
              <div class="error-message" id="phone-error">Please enter a valid phone number</div>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="send-button">
              {{ section.settings.button_label }}
            </button>
          </form>
        </div>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .video-call-scheduler {
    padding: 80px 0 0;
  }

  .scheduler-wrapper {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 40px;
    padding: 4% 8%;
    align-items: flex-start;
  }

  .scheduler-form {
    flex: 1 1 40%;
    max-width: 450px;
  }

  .scheduler-form h2 {
    font-size: 24px; font-weight: 500; margin-bottom: 10px; text-align: left; vertical-align: middle; text-transform: uppercase;
  }

  .scheduler-form p { color: #1a1a1a; font-family: Futura, sans-serif; font-weight: 400; font-size: 16px; line-height: 24px; text-align: left; vertical-align: middle; margin: 12px auto 40px; }


  .scheduler-form label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    margin-bottom: 6px;
    margin-top: 20px;
    text-transform: uppercase;
  }

  .form-input {
    width: 100%;
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 13px;
    background-color: #fff;
  }

  .send-button {
    margin-top: 25px;
    background-color: #9d7c78;
    color: #fff;
    border: none;
    padding: 12px 25px;
    border-radius: 10px;
    font-size: 14px;
    cursor: pointer;
    width: 100%;
  }

  .error-message {
    color: red;
    font-size: 12px;
    display: none;
    margin-top: 5px;
  }

  .scheduler-image {
    flex: 1 1 50%;
    text-align: center;
  }

  .scheduler-image img {
    max-width: 100%;
    height: auto;
  }

  .videodesktop-only {
    display: block;
  }

  .videomobile-only {
    display: none;
  }
  .scheduler-form h2{
    color:black;
  }
  @media (max-width: 767px) {
    .video-call-scheduler {
      padding-bottom: 24px;
      padding-top: 40px;
    }

    .videomobile-only {
      display: block;
      margin-bottom: 30px;
      padding:20px;
    }

    .scheduler-wrapper {
      flex-direction: column;
    }

    .scheduler-form {
      max-width: 90%;
      margin: 0 auto;
    }

    .scheduler-image.videodesktop-only {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('success') === 'true') {
      showThankYouMessage();
    }

    document.getElementById('contact-email').addEventListener('blur', function () {
      validateEmail(this);
    });

    document.getElementById('contact-phone').addEventListener('blur', function () {
      if (this.value) validatePhone(this);
    });
  });

  function showThankYouMessage() {
    document.getElementById('contact-form-container').style.display = 'none';
    document.getElementById('thank-you-message').style.display = 'block';
  }

  function resetForm() {
    document.getElementById('contact-form-container').style.display = 'block';
    document.getElementById('thank-you-message').style.display = 'none';
    document.getElementById('contact-form').reset();
    document.querySelectorAll('.error-message').forEach(el => el.style.display = 'none');
    document.querySelectorAll('.form-input').forEach(el => el.classList.remove('error'));
  }

  function validateEmail(input) {
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const isValid = emailRegex.test(input.value);
    const errorEl = document.getElementById('email-error');
    if (!isValid) {
      input.classList.add('error');
      errorEl.style.display = 'block';
      return false;
    } else {
      input.classList.remove('error');
      errorEl.style.display = 'none';
      return true;
    }
  }

  function validatePhone(input) {
    const phoneRegex = /^[\d\s\+\-\(\)]{7,20}$/;
    const isValid = phoneRegex.test(input.value);
    const errorEl = document.getElementById('phone-error');
    if (input.value && !isValid) {
      input.classList.add('error');
      errorEl.style.display = 'block';
      return false;
    } else {
      input.classList.remove('error');
      errorEl.style.display = 'none';
      return true;
    }
  }

  function validateForm() {
    let isValid = true;

    const firstName = document.getElementById('contact-first-name');
    const email = document.getElementById('contact-email');
    const phone = document.getElementById('contact-phone');

    if (!firstName.value.trim()) {
      firstName.classList.add('error');
      document.getElementById('first-name-error').style.display = 'block';
      isValid = false;
    } else {
      firstName.classList.remove('error');
      document.getElementById('first-name-error').style.display = 'none';
    }

    if (!validateEmail(email)) isValid = false;
    if (phone.value && !validatePhone(phone)) isValid = false;

    if (isValid) {
      setTimeout(() => showThankYouMessage(), 1000);
      return false; // prevent real submission
    }

    return false;
  }
</script>

{% schema %}
{
  "name": "Video Call Scheduler",
  "settings": [
    {
      "type": "text",
      "id": "videoheading",
      "label": "Heading",
      "default": "Schedule a Video Call"
    },
    {
      "type": "text",
      "id": "videosubheading",
      "label": "Subheading",
      "default": "Enter your details and we'll get back to you."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Send Message"
    },
    {
      "type": "select",
      "id": "layout_order",
      "label": "Layout Order",
      "default": "image-form",
      "options": [
        {
          "value": "image-form",
          "label": "Image | Form"
        },
        {
          "value": "form-image",
          "label": "Form | Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Call Scheduler",
      "category": "Custom"
    }
  ]
}
{% endschema %}
