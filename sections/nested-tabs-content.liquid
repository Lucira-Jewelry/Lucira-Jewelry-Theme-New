{% comment %}
  Section: Nested Tabs Content - SIMPLIFIED WORKING VERSION
{% endcomment %}

{% assign category_handle = page.handle %}
{% assign current_category = metaobjects.category_page[category_handle] %}
{% assign tab_slug = request.query.tab | default: current_category.default_tab_slug %}

<style>
  /* [Keep all your CSS styles] */
  .nested-tabs-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }
  .tabs-navigation {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #f0f0f0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .tabs-navigation::-webkit-scrollbar {
    display: none;
  }
  .tab-link {
    padding: 0.75rem 1.5rem;
    background: white;
    border: 2px solid #e0e0e0;
    border-radius: 50px;
    color: #333;
    text-decoration: none;
    font-weight: 500;
    white-space: nowrap;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .tab-link:hover {
    border-color: #b8860b;
    color: #b8860b;
  }
  .tab-link.active {
    background: #b8860b;
    border-color: #b8860b;
    color: white;
  }
  .tab-content-area {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 992px) {
    .tab-content-area.with-image {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }
  .tab-content-header {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1.5rem;
    color: #333;
  }
  .tab-content-description {
    font-size: 1.125rem;
    line-height: 1.6;
    color: #666;
    margin-bottom: 2rem;
  }
  .tab-content-image {
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  .tab-content-image img {
    width: 100%;
    height: auto;
    display: block;
  }
  .tab-cta-button {
    display: inline-block;
    padding: 1rem 2rem;
    background: #b8860b;
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background 0.3s ease;
  }
  .tab-cta-button:hover {
    background: #a0760a;
  }
  .related-topics {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #eee;
  }
  .related-topics h3 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: #333;
  }
  .blog-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  .blog-link {
    display: block;
    padding: 1rem;
    background: #f9f9f9;
    border-radius: 4px;
    color: #333;
    text-decoration: none;
    transition: background 0.3s ease;
  }
  .blog-link:hover {
    background: #f0f0f0;
    text-decoration: underline;
  }
  .no-tabs-message {
    text-align: center;
    padding: 3rem;
    background: #f9f9f9;
    border-radius: 8px;
    color: #666;
  }
</style>

<div class="nested-tabs-container">
  {% comment %} SIMPLE DIRECT APPROACH - Based on what worked in debug {% endcomment %}
  {% assign all_tabs = metaobjects.tab_content.values %}
  {% assign category_tabs = "" | split: "" %}
  
  {% comment %} Option 1: Get ALL tabs (for testing) {% endcomment %}
  {% for tab in all_tabs %}
    {% assign category_tabs = category_tabs | push: tab %}
  {% endfor %}
  
  {% comment %} Option 2: If you want to filter, use this simpler logic {% endcomment %}
  {% comment %}
  {% assign category_tabs = "" | split: "" %}
  {% for tab in all_tabs %}
    {% if tab.parent_category %}
      {% comment %} Just check if parent_category exists, don't overcomplicate {% endcomment %}
      {% assign category_tabs = category_tabs | push: tab %}
    {% endif %}
  {% endfor %}
  {% endcomment %}
  
  {% comment %} Find current tab {% endcomment %}
  {% assign current_tab = nil %}
  {% for tab in category_tabs %}
    {% if tab.tab_slug == tab_slug %}
      {% assign current_tab = tab %}
      {% break %}
    {% endif %}
  {% endfor %}
  
  {% if current_tab == nil and category_tabs.size > 0 %}
    {% assign current_tab = category_tabs.first %}
    {% assign tab_slug = current_tab.tab_slug %}
  {% endif %}
  
  {% comment %} Display {% endcomment %}
  {% if category_tabs.size > 0 %}
    <!-- Tabs Navigation -->
    <nav class="tabs-navigation" role="tablist">
      {% for tab in category_tabs %}
        <a 
          href="{{ request.path }}?tab={{ tab.tab_slug }}" 
          class="tab-link {% if tab.tab_slug == tab_slug %}active{% endif %}"
          data-tab-slug="{{ tab.tab_slug }}"
          role="tab"
        >
          {{ tab.title }}
        </a>
      {% endfor %}
    </nav>

    <!-- Tab Content -->
    <div class="tab-content">
      {% if current_tab %}
        <div class="tab-content-area {% if current_tab.content_image %}with-image{% endif %}">
          <div class="tab-content-text">
            {% if current_tab.header %}
              <h2 class="tab-content-header">{{ current_tab.header }}</h2>
            {% endif %}
            
            {% if current_tab.description %}
              <div class="tab-content-description">
                {{ current_tab.description }}
              </div>
            {% endif %}
            
            {% if current_tab.cta_text and current_tab.cta_link %}
              <a href="{{ current_tab.cta_link }}" class="tab-cta-button">
                {{ current_tab.cta_text }}
              </a>
            {% endif %}
          </div>
          
          {% if current_tab.content_image %}
            <div class="tab-content-image">
              <img 
                src="{{ current_tab.content_image | image_url: width: 800 }}" 
                alt="{{ current_tab.header | default: current_tab.title | escape }}"
                loading="lazy"
                width="800"
                height="600"
              >
            </div>
          {% endif %}
        </div>

        <!-- Related Topics -->
        {% if current_tab.related_blogs and current_tab.related_blogs.size > 0 %}
          <div class="related-topics">
            <h3>Related Topics</h3>
            <div class="blog-links">
              {% for article_ref in current_tab.related_blogs %}
                {% assign article = article_ref %}
                {% if article %}
                  <a href="{{ article.url }}" class="blog-link">
                    {{ article.title }}
                  </a>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      {% else %}
        <div class="no-tabs-message">
          <p>Select a tab to view content.</p>
        </div>
      {% endif %}
    </div>
  {% else %}
    <div class="no-tabs-message">
      <h3>Debug Information</h3>
      <p>Total tabs in system: {{ all_tabs.size }}</p>
      
      {% if all_tabs.size > 0 %}
        <p>Tabs found:</p>
        <ul>
          {% for tab in all_tabs %}
            <li>{{ tab.title }} ({{ tab.tab_slug }}) - Parent: {% if tab.parent_category %}Yes{% else %}No{% endif %}</li>
          {% endfor %}
        </ul>
      {% else %}
        <p>No tabs found in metaobjects. Please create tab_content entries.</p>
      {% endif %}
    </div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabLinks = document.querySelectorAll('.tab-link');
    
    tabLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        tabLinks.forEach(l => l.classList.remove('active'));
        this.classList.add('active');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Nested Tabs Content",
  "tag":  "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "Nested Tabs Content"
    }
  ]
}
{% endschema %}