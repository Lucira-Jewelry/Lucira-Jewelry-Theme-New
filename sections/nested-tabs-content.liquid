{% comment %}
  Section: Nested Tabs Content - DEBUGGED VERSION
{% endcomment %}

{% assign category_handle = page.handle %}
{% assign current_category = metaobjects.category_page[category_handle] %}

{% comment %} Extract tab from URL - SAME AS TEMPLATE {% endcomment %}
{% assign url_search = request.search %}
{% assign url_tab = '' %}

{% if url_search contains 'tab=' %}
  {% assign url_parts = url_search | remove: '?' | split: '&' %}
  {% for part in url_parts %}
    {% if part contains 'tab=' %}
      {% assign url_tab = part | split: '=' | last %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign default_tab = current_category.default_tab_slug | default: 'style' %}
{% assign tab_slug = url_tab | default: default_tab %}
{% assign tab_slug_lower = tab_slug | downcase %}

<style>
  .nested-tabs-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }
  
  .tabs-navigation {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #f0f0f0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  
  .tabs-navigation::-webkit-scrollbar {
    display: none;
  }
  
  .tab-link {
    padding: 0.75rem 1.5rem;
    background: white;
    border: 2px solid #e0e0e0;
    border-radius: 50px;
    color: #333;
    text-decoration: none;
    font-weight: 500;
    white-space: nowrap;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  
  .tab-link:hover {
    border-color: #b8860b;
    color: #b8860b;
  }
  
  .tab-link.active {
    background: #b8860b;
    border-color: #b8860b;
    color: white;
  }
  
  .tab-content-area {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  
  @media (min-width: 992px) {
    .tab-content-area.with-image {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }
  
  .tab-content-header {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1.5rem;
    color: #333;
  }
  
  .tab-content-description {
    font-size: 1.125rem;
    line-height: 1.6;
    color: #666;
    margin-bottom: 2rem;
  }
  
  .tab-content-image {
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  
  .tab-content-image img {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .tab-cta-button {
    display: inline-block;
    padding: 1rem 2rem;
    background: #b8860b;
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background 0.3s ease;
  }
  
  .tab-cta-button:hover {
    background: #a0760a;
  }
  
  .related-topics {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #eee;
  }
  
  .related-topics h3 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: #333;
  }
  
  .blog-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  
  .blog-link {
    display: block;
    padding: 1rem;
    background: #f9f9f9;
    border-radius: 4px;
    color: #333;
    text-decoration: none;
    transition: background 0.3s ease;
  }
  
  .blog-link:hover {
    background: #f0f0f0;
    text-decoration: underline;
  }
  
  .debug-panel {
    background: #fff3cd;
    border: 2px solid #ffc107;
    padding: 1rem;
    margin-bottom: 2rem;
    border-radius: 4px;
  }
  
  .data-preview {
    background: #e9ecef;
    padding: 1rem;
    margin: 1rem 0;
    border-radius: 4px;
    font-size: 14px;
    overflow-x: auto;
  }
</style>

<div class="nested-tabs-container">
  {% comment %} DEBUG PANEL - REMOVE AFTER FIXING {% endcomment %}
  <div class="debug-panel">
    <h3>🔧 Debug Information</h3>
    <p><strong>Current Page:</strong> {{ page.title }} (handle: {{ page.handle }})</p>
    <p><strong>Current Category:</strong> {{ current_category.title }}</p>
    <p><strong>URL Tab Parameter:</strong> "{{ url_tab }}"</p>
    <p><strong>Using Tab Slug:</strong> "{{ tab_slug }}" (lowercase: "{{ tab_slug_lower }}")</p>
  </div>
  
  {% comment %} Get ALL tabs and filter by parent category {% endcomment %}
  {% assign all_tabs = metaobjects.tab_content.values %}
  {% assign category_tabs = "" | split: "" %}
  
  <div class="data-preview">
    <p><strong>All Tabs in System ({{ all_tabs.size }}):</strong></p>
    {% for tab in all_tabs %}
      <div style="border-bottom: 1px solid #ccc; padding: 5px 0;">
        <p><strong>{{ tab.title }}</strong> 
          - Slug: "{{ tab.tab_slug }}" 
          - Parent: {% if tab.parent_category %}
            {{ tab.parent_category.title | default: 'Has parent but no title' }}
          {% else %}
            No parent
          {% endif %}
        </p>
      </div>
    {% endfor %}
  </div>
  
  {% comment %} Filter tabs for current category {% endcomment %}
  {% assign category_tabs = "" | split: "" %}
  {% for tab in all_tabs %}
    {% if tab.parent_category %}
      {% assign parent_category = tab.parent_category %}
      
      {% comment %} Check if parent matches current category {% endcomment %}
      {% if parent_category.system.handle == current_category.system.handle 
          or parent_category.title == current_category.title 
          or parent_category.system.id == current_category.system.id %}
        
        {% assign category_tabs = category_tabs | push: tab %}
      {% endif %}
    {% endif %}
  {% endfor %}
  
  {% comment %} If no filtered tabs, show all tabs as fallback {% endcomment %}
  {% if category_tabs.size == 0 %}
    {% assign category_tabs = all_tabs %}
  {% endif %}
  
  <div class="data-preview">
    <p><strong>Tabs for this category ({{ category_tabs.size }}):</strong></p>
    {% for tab in category_tabs %}
      <p>{{ tab.title }} - "{{ tab.tab_slug }}"</p>
    {% endfor %}
  </div>
  
  {% comment %} Find current tab {% endcomment %}
  {% assign current_tab = nil %}
  {% for tab in category_tabs %}
    {% assign tab_slug_lowercase = tab.tab_slug | downcase %}
    {% if tab_slug_lowercase == tab_slug_lower %}
      {% assign current_tab = tab %}
      {% break %}
    {% endif %}
  {% endfor %}
  
  {% comment %} Fallback to first tab if not found {% endcomment %}
  {% if current_tab == nil and category_tabs.size > 0 %}
    {% assign current_tab = category_tabs.first %}
    {% assign tab_slug = current_tab.tab_slug %}
    {% assign tab_slug_lower = tab_slug | downcase %}
  {% endif %}
  
  <div class="data-preview">
    <p><strong>Current Tab:</strong> 
      {% if current_tab %}
        {{ current_tab.title }} ({{ current_tab.tab_slug }})
        <br>Header: "{{ current_tab.header }}"
        <br>Description: "{{ current_tab.description | truncate: 50 }}"
      {% else %}
        NOT FOUND
      {% endif %}
    </p>
  </div>
  
  {% comment %} Display tabs and content {% endcomment %}
  {% if category_tabs.size > 0 %}
    <!-- Sub Tabs Navigation -->
    <nav class="tabs-navigation" role="tablist">
      {% for tab in category_tabs %}
        {% assign tab_slug_lowercase = tab.tab_slug | downcase %}
        <a 
          href="?tab={{ tab.tab_slug }}" 
          class="tab-link {% if tab_slug_lowercase == tab_slug_lower %}active{% endif %}"
          data-tab-slug="{{ tab.tab_slug }}"
          role="tab"
        >
          {{ tab.title }}
        </a>
      {% endfor %}
    </nav>

    <!-- Tab Content -->
    <div class="tab-content">
      {% if current_tab %}
        <div class="tab-content-area {% if current_tab.content_image %}with-image{% endif %}">
          <div class="tab-content-text">
            {% if current_tab.header %}
              <h2 class="tab-content-header">{{ current_tab.header }}</h2>
            {% else %}
              <h2 class="tab-content-header">{{ current_tab.title }}</h2>
            {% endif %}
            
            {% if current_tab.description %}
              <div class="tab-content-description">
                {{ current_tab.description }}
              </div>
            {% endif %}
            
            {% if current_tab.cta_text and current_tab.cta_link %}
              <a href="{{ current_tab.cta_link }}" class="tab-cta-button">
                {{ current_tab.cta_text }}
              </a>
            {% endif %}
          </div>
          
          {% if current_tab.content_image %}
            <div class="tab-content-image">
              <img 
                src="{{ current_tab.content_image | image_url: width: 800 }}" 
                alt="{{ current_tab.header | default: current_tab.title | escape }}"
                loading="lazy"
                width="800"
                height="600"
              >
            </div>
          {% endif %}
        </div>

        <!-- Related Topics -->
        {% if current_tab.related_blogs and current_tab.related_blogs.size > 0 %}
          <div class="related-topics">
            <h3>Related Topics</h3>
            <div class="blog-links">
              {% for article_ref in current_tab.related_blogs %}
                {% assign article = article_ref %}
                {% if article %}
                  <a href="{{ article.url }}" class="blog-link">
                    {{ article.title }}
                  </a>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      {% else %}
        <div style="text-align: center; padding: 3rem; background: #f8f9fa; border-radius: 8px;">
          <h3>No Content Loaded</h3>
          <p>Tab slug "{{ tab_slug }}" not found in available tabs.</p>
        </div>
      {% endif %}
    </div>
  {% else %}
    <div style="text-align: center; padding: 3rem; background: #f8f9fa; border-radius: 8px;">
      <h3>No Tabs Available</h3>
      <p>Please create tab_content entries in Shopify admin.</p>
    </div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabLinks = document.querySelectorAll('.tab-link');
    
    tabLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        tabLinks.forEach(l => l.classList.remove('active'));
        this.classList.add('active');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Nested Tabs Content",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "Nested Tabs Content"
    }
  ]
}
{% endschema %}