{% comment %}
  Section: Nested Tabs Content - WORKING VERSION
  Temporary workaround for text-based parent_category field
{% endcomment %}

{% assign category_handle = page.handle %}
{% assign current_category = metaobjects.category_page[category_handle] %}
{% assign tab_slug = request.query.tab | default: current_category.default_tab_slug %}

<style>
  .nested-tabs-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }
  
  /* Tabs Navigation */
  .tabs-navigation {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #f0f0f0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  
  .tabs-navigation::-webkit-scrollbar {
    display: none;
  }
  
  .tab-link {
    padding: 0.75rem 1.5rem;
    background: white;
    border: 2px solid #e0e0e0;
    border-radius: 50px;
    color: #333;
    text-decoration: none;
    font-weight: 500;
    white-space: nowrap;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  
  .tab-link:hover {
    border-color: #b8860b;
    color: #b8860b;
  }
  
  .tab-link.active {
    background: #b8860b;
    border-color: #b8860b;
    color: white;
  }
  
  /* Tab Content */
  .tab-content-area {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  
  @media (min-width: 992px) {
    .tab-content-area.with-image {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }
  
  .tab-content-header {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1.5rem;
    color: #333;
  }
  
  .tab-content-description {
    font-size: 1.125rem;
    line-height: 1.6;
    color: #666;
    margin-bottom: 2rem;
  }
  
  .tab-content-image {
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  
  .tab-content-image img {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .tab-cta-button {
    display: inline-block;
    padding: 1rem 2rem;
    background: #b8860b;
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background 0.3s ease;
  }
  
  .tab-cta-button:hover {
    background: #a0760a;
  }
  
  /* Related Topics */
  .related-topics {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #eee;
  }
  
  .related-topics h3 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: #333;
  }
  
  .blog-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  
  .blog-link {
    display: block;
    padding: 1rem;
    background: #f9f9f9;
    border-radius: 4px;
    color: #333;
    text-decoration: none;
    transition: background 0.3s ease;
  }
  
  .blog-link:hover {
    background: #f0f0f0;
    text-decoration: underline;
  }
  
  /* Loading State */
  .tab-content-loading {
    text-align: center;
    padding: 3rem;
    color: #666;
  }
  
  /* No Tabs Message */
  .no-tabs-message {
    text-align: center;
    padding: 3rem;
    background: #f9f9f9;
    border-radius: 8px;
    color: #666;
  }
  
  /* Debug styles */
  .debug-info {
    background: #fff3cd;
    border: 1px solid #ffeaa7;
    padding: 1rem;
    margin-bottom: 2rem;
    border-radius: 4px;
    font-size: 14px;
  }
  
  .debug-warning {
    background: #f8d7da;
    border: 1px solid #f5c6cb;
    padding: 1rem;
    margin-bottom: 2rem;
    border-radius: 4px;
    font-size: 14px;
  }
</style>

<div class="nested-tabs-container">
  {% comment %} DEBUG INFO - Remove after testing {% endcomment %}
  <div class="debug-info">
    <p><strong>Debug Info:</strong></p>
    <p>Category: {{ current_category.title }}</p>
    <p>Category Handle: {{ current_category.system.handle }}</p>
    <p>Category System ID: {{ current_category.system.id }}</p>
    <p>Current tab slug: {{ tab_slug }}</p>
    <p>Page handle: {{ category_handle }}</p>
  </div>
  
  {% comment %} 
    TEMPORARY WORKAROUND: Since parent_category is stored as text ("gold"), 
    we need to match by category title
  {% endcomment %}
  {% assign all_tabs = metaobjects.tab_content.values %}
  {% assign category_tabs = "" | split: "" %}
  
  {% comment %} Check what values are stored in parent_category {% endcomment %}
  <div class="debug-warning">
    <p><strong>⚠️ Temporary Workaround Active</strong></p>
    <p>Your <code>parent_category</code> field is storing text values, not references.</p>
    <p>Looking for tabs where parent_category = "{{ current_category.title }}"</p>
    <p>Found values in tabs:</p>
    <ul>
      {% for tab in all_tabs %}
        <li><strong>{{ tab.title }}:</strong> "{{ tab.parent_category }}"</li>
      {% endfor %}
    </ul>
  </div>
  
  {% comment %} Try multiple matching strategies {% endcomment %}
  {% for tab in all_tabs %}
    {% comment %} Strategy 1: Match exact title {% endcomment %}
    {% if tab.parent_category == current_category.title %}
      {% assign category_tabs = category_tabs | push: tab %}
    {% comment %} Strategy 2: Match "Engagement Rings" if stored differently {% endcomment %}
    {% elsif tab.parent_category == "Engagement Rings" %}
      {% assign category_tabs = category_tabs | push: tab %}
    {% comment %} Strategy 3: Match "gold" if that's what's stored {% endcomment %}
    {% elsif tab.parent_category == "gold" and current_category.title == "Engagement Rings" %}
      {% assign category_tabs = category_tabs | push: tab %}
    {% comment %} Strategy 4: Case-insensitive match {% endcomment %}
    {% elsif tab.parent_category and current_category.title and tab.parent_category.downcase == current_category.title.downcase %}
      {% assign category_tabs = category_tabs | push: tab %}
    {% endif %}
  {% endfor %}
  
  {% comment %} If still no tabs, try to get any tab with any parent_category {% endcomment %}
  {% if category_tabs.size == 0 %}
    {% for tab in all_tabs %}
      {% if tab.parent_category and tab.parent_category != blank %}
        {% assign category_tabs = category_tabs | push: tab %}
      {% endif %}
    {% endfor %}
  {% endif %}
  
  {% comment %} Final fallback: Get all tabs {% endcomment %}
  {% if category_tabs.size == 0 %}
    {% for tab in all_tabs %}
      {% assign category_tabs = category_tabs | push: tab %}
    {% endfor %}
  {% endif %}
  
  {% comment %} Find the current tab {% endcomment %}
  {% assign current_tab = nil %}
  {% for tab in category_tabs %}
    {% if tab.tab_slug == tab_slug %}
      {% assign current_tab = tab %}
      {% break %}
    {% endif %}
  {% endfor %}
  
  {% if current_tab == nil and category_tabs.size > 0 %}
    {% assign current_tab = category_tabs.first %}
    {% assign tab_slug = current_tab.tab_slug %}
  {% endif %}
  
  {% comment %} Display tabs and content {% endcomment %}
  {% if category_tabs.size > 0 %}
    <!-- Tabs Navigation -->
    <nav class="tabs-navigation" role="tablist">
      {% for tab in category_tabs %}
        <a 
          href="{{ request.path }}?tab={{ tab.tab_slug }}" 
          class="tab-link {% if tab.tab_slug == tab_slug %}active{% endif %}"
          data-tab-slug="{{ tab.tab_slug }}"
          role="tab"
        >
          {{ tab.title }}
        </a>
      {% endfor %}
    </nav>

    <!-- Tab Content -->
    <div class="tab-content">
      {% if current_tab %}
        <div class="tab-content-area {% if current_tab.content_image %}with-image{% endif %}">
          <div class="tab-content-text">
            {% if current_tab.header %}
              <h2 class="tab-content-header">{{ current_tab.header }}</h2>
            {% endif %}
            
            {% if current_tab.description %}
              <div class="tab-content-description">
                {{ current_tab.description }}
              </div>
            {% endif %}
            
            {% if current_tab.cta_text and current_tab.cta_link %}
              <a href="{{ current_tab.cta_link }}" class="tab-cta-button">
                {{ current_tab.cta_text }}
              </a>
            {% endif %}
          </div>
          
          {% if current_tab.content_image %}
            <div class="tab-content-image">
              <img 
                src="{{ current_tab.content_image | image_url: width: 800 }}" 
                alt="{{ current_tab.header | default: current_tab.title | escape }}"
                loading="lazy"
                width="800"
                height="600"
              >
            </div>
          {% endif %}
        </div>

        <!-- Related Topics -->
        {% if current_tab.related_blogs and current_tab.related_blogs.size > 0 %}
          <div class="related-topics">
            <h3>Related Topics</h3>
            <div class="blog-links">
              {% for article_ref in current_tab.related_blogs %}
                {% assign article = article_ref %}
                {% if article %}
                  <a href="{{ article.url }}" class="blog-link">
                    {{ article.title }}
                  </a>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      {% else %}
        <div class="no-tabs-message">
          <p>No content available for the selected tab.</p>
        </div>
      {% endif %}
    </div>
  {% else %}
    <div class="no-tabs-message">
      <h3>Configuration Needed</h3>
      <p>Please fix your metaobject setup:</p>
      <div style="text-align: left; display: inline-block; max-width: 600px;">
        <p><strong>Current Issue:</strong> Your <code>parent_category</code> field in the <code>tab_content</code> metaobject is storing text values instead of references.</p>
        
        <p><strong>To fix permanently:</strong></p>
        <ol>
          <li>Go to <strong>Settings → Custom Data → tab_content → Manage definition</strong></li>
          <li>Delete the current <code>parent_category</code> field</li>
          <li>Create a new field:
            <ul>
              <li>Name: <code>parent_category</code></li>
              <li>Type: <strong>Reference</strong> (not Text)</li>
              <li>Reference to: <code>category_page</code></li>
            </ul>
          </li>
          <li>Re-select "Engagement Rings" for each tab entry</li>
          <li>Save and refresh this page</li>
        </ol>
        
        <p><strong>Current tab parent_category values:</strong></p>
        <ul>
          {% for tab in all_tabs %}
            <li><code>{{ tab.title }}</code>: "{{ tab.parent_category }}"</li>
          {% endfor %}
        </ul>
      </div>
    </div>
  {% endif %}
</div>

<script>
  // JavaScript for better UX
  document.addEventListener('DOMContentLoaded', function() {
    const tabLinks = document.querySelectorAll('.tab-link');
    
    tabLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        // Update active tab visually
        tabLinks.forEach(l => l.classList.remove('active'));
        this.classList.add('active');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Nested Tabs Content",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "Nested Tabs Content"
    }
  ]
}
{% endschema %}