{% comment %}
  Section: Nested Tabs Content
  Description: Tabs navigation and dynamic content
{% endcomment %}

{%- assign category_handle = page.handle -%}
{%- assign current_category = metaobjects.category_page[category_handle] -%}
{%- assign tab_slug = request.query.tab | default: current_category.default_tab_slug -%}

{%- assign category_tabs = metaobjects.tab_content.values | where: "parent_category.system.handle", current_category.system.handle | sort: 'title' -%}
{%- assign current_tab = nil -%}

{%- for tab in category_tabs -%}
  {%- if tab.tab_slug == tab_slug -%}
    {%- assign current_tab = tab -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if current_tab == nil and category_tabs.size > 0 -%}
  {%- assign current_tab = category_tabs.first -%}
  {%- assign tab_slug = current_tab.tab_slug -%}
{%- endif -%}

<style>
  .nested-tabs-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }
  
  /* Tabs Navigation */
  .tabs-navigation {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #f0f0f0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  
  .tabs-navigation::-webkit-scrollbar {
    display: none;
  }
  
  .tab-link {
    padding: 0.75rem 1.5rem;
    background: white;
    border: 2px solid #e0e0e0;
    border-radius: 50px;
    color: #333;
    text-decoration: none;
    font-weight: 500;
    white-space: nowrap;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  
  .tab-link:hover {
    border-color: #b8860b;
    color: #b8860b;
  }
  
  .tab-link.active {
    background: #b8860b;
    border-color: #b8860b;
    color: white;
  }
  
  /* Tab Content */
  .tab-content-area {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  
  @media (min-width: 992px) {
    .tab-content-area.with-image {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }
  
  .tab-content-header {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1.5rem;
    color: #333;
  }
  
  .tab-content-description {
    font-size: 1.125rem;
    line-height: 1.6;
    color: #666;
    margin-bottom: 2rem;
  }
  
  .tab-content-image {
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  
  .tab-content-image img {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .tab-cta-button {
    display: inline-block;
    padding: 1rem 2rem;
    background: #b8860b;
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background 0.3s ease;
  }
  
  .tab-cta-button:hover {
    background: #a0760a;
  }
  
  /* Related Topics */
  .related-topics {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #eee;
  }
  
  .related-topics h3 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: #333;
  }
  
  .blog-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  
  .blog-link {
    display: block;
    padding: 1rem;
    background: #f9f9f9;
    border-radius: 4px;
    color: #333;
    text-decoration: none;
    transition: background 0.3s ease;
  }
  
  .blog-link:hover {
    background: #f0f0f0;
    text-decoration: underline;
  }
  
  /* Loading State */
  .tab-content-loading {
    text-align: center;
    padding: 3rem;
    color: #666;
  }
  
  /* No Tabs Message */
  .no-tabs-message {
    text-align: center;
    padding: 3rem;
    background: #f9f9f9;
    border-radius: 8px;
  }
</style>

{% comment %} <div class="nested-tabs-container">
  {%- if category_tabs.size > 0 -%}
    <!-- Tabs Navigation -->
    <nav class="tabs-navigation" role="tablist">
      {%- for tab in category_tabs -%}
        <a 
          href="{{ request.path }}?tab={{ tab.tab_slug }}" 
          class="tab-link {% if tab.tab_slug == tab_slug %}active{% endif %}"
          data-tab-slug="{{ tab.tab_slug }}"
          role="tab"
        >
          {{ tab.title }}
        </a>
      {%- endfor -%}
    </nav>

    <!-- Tab Content -->
    <div class="tab-content">
      {%- if current_tab -%}
        <div class="tab-content-area {% if current_tab.content_image %}with-image{% endif %}">
          <div class="tab-content-text">
            <h2 class="tab-content-header">{{ current_tab.header }}</h2>
            
            <div class="tab-content-description">
              {{ current_tab.description }}
            </div>
            
            {%- if current_tab.cta_text and current_tab.cta_link -%}
              <a href="{{ current_tab.cta_link }}" class="tab-cta-button">
                {{ current_tab.cta_text }}
              </a>
            {%- endif -%}
          </div>
          
          {%- if current_tab.content_image -%}
            <div class="tab-content-image">
              <img 
                src="{{ current_tab.content_image | image_url: width: 800 }}" 
                alt="{{ current_tab.header | escape }}"
                loading="lazy"
                width="800"
                height="600"
              >
            </div>
          {%- endif -%}
        </div>

        <!-- Related Topics -->
        {%- if current_tab.related_blogs.size > 0 -%}
          <div class="related-topics">
            <h3>Related Topics</h3>
            <div class="blog-links">
              {%- for article_ref in current_tab.related_blogs -%}
                {%- assign article = article_ref -%}
                {%- if article -%}
                  <a href="{{ article.url }}" class="blog-link">
                    {{ article.title }}
                  </a>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="tab-content-loading">
          <p>Loading content...</p>
        </div>
      {%- endif -%}
    </div>
  {%- else -%}
    <div class="no-tabs-message">
      <h3>No tabs available for this category</h3>
      <p>Please add tab content in the Shopify admin.</p>
    </div>
  {%- endif -%}
</div> {% endcomment %}

{% assign category_handle = page.handle %}
{% assign current_category = metaobjects.category_page[category_handle] %}
{% assign tab_slug = request.query.tab | default: current_category.default_tab_slug %}

{% comment %} Get all tabs for this category {% endcomment %}
{% assign all_tabs = metaobjects.tab_content.values %}
{% assign category_tabs = "" | split: "" %}

{% for tab in all_tabs %}
  {% if tab.parent_category and tab.parent_category.system.handle == current_category.system.handle %}
    {% assign category_tabs = category_tabs | push: tab %}
  {% endif %}
{% endfor %}

{% comment %} Find current tab {% endcomment %}
{% assign current_tab = nil %}
{% for tab in category_tabs %}
  {% if tab.tab_slug == tab_slug %}
    {% assign current_tab = tab %}
    {% break %}
  {% endif %}
{% endfor %}

{% if current_tab == nil and category_tabs.size > 0 %}
  {% assign current_tab = category_tabs.first %}
  {% assign tab_slug = current_tab.tab_slug %}
{% endif %}

<style>
  /* Your CSS styles here */
</style>

<div class="nested-tabs-container">
  {% if category_tabs.size > 0 %}
    <!-- Tabs Navigation -->
    <nav class="tabs-navigation">
      {% for tab in category_tabs %}
        <a href="{{ request.path }}?tab={{ tab.tab_slug }}" 
           class="tab-link {% if tab.tab_slug == tab_slug %}active{% endif %}">
          {{ tab.title }}
        </a>
      {% endfor %}
    </nav>

    <!-- Tab Content -->
    <div class="tab-content">
      {% if current_tab %}
        <!-- Your content rendering here -->
        <h2>{{ current_tab.header }}</h2>
        {{ current_tab.description }}
        
        {% if current_tab.content_image %}
          <img src="{{ current_tab.content_image | image_url }}" alt="{{ current_tab.header }}">
        {% endif %}
        
        {% if current_tab.cta_text and current_tab.cta_link %}
          <a href="{{ current_tab.cta_link }}" class="cta-button">
            {{ current_tab.cta_text }}
          </a>
        {% endif %}
        
        <!-- Related Topics -->
        {% if current_tab.related_blogs.size > 0 %}
          <div class="related-topics">
            <h3>Related Topics</h3>
            {% for article_ref in current_tab.related_blogs %}
              <a href="{{ article_ref.url }}">{{ article_ref.title }}</a>
            {% endfor %}
          </div>
        {% endif %}
      {% endif %}
    </div>
  {% else %}
    <div class="no-tabs-message">
      <h3>No tabs available for this category</h3>
      <p>Found {{ all_tabs.size }} total tabs in system.</p>
      <p>Current category handle: {{ current_category.system.handle }}</p>
      <p>Debug: Checking tabs with parent...</p>
      <ul>
        {% for tab in all_tabs %}
          <li>
            {{ tab.title }} - 
            Parent: {% if tab.parent_category %}{{ tab.parent_category.title }} ({{ tab.parent_category.system.handle }}){% else %}None{% endif %}
          </li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}
</div>


<script>
  class NestedTabs extends HTMLElement {
    constructor() {
      super();
      
      // Handle tab clicks with AJAX for smooth transitions
      this.tabLinks = this.querySelectorAll('.tab-link');
      this.tabContent = this.querySelector('.tab-content');
      
      this.initEventListeners();
    }
    
    initEventListeners() {
      this.tabLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          // Only prevent default if we're doing AJAX loading
          // For now, let it follow the link normally
          // You can enhance with AJAX later
        });
      });
    }
    
    // Optional: Add AJAX loading for better UX
    async loadTabContent(tabSlug) {
      try {
        // Show loading state
        this.tabContent.innerHTML = `
          <div class="tab-content-loading">
            <p>Loading...</p>
          </div>
        `;
        
        // Fetch the page with the new tab parameter
        const response = await fetch(`${window.location.pathname}?tab=${tabSlug}`);
        const text = await response.text();
        
        // Parse the HTML and extract just the tab content
        const parser = new DOMParser();
        const doc = parser.parseFromString(text, 'text/html');
        const newContent = doc.querySelector('.tab-content');
        
        if (newContent) {
          this.tabContent.innerHTML = newContent.innerHTML;
          this.updateActiveTab(tabSlug);
          this.updateURL(tabSlug);
          
          // Dispatch event for other components
          this.dispatchEvent(new CustomEvent('tabchange', {
            detail: { tabSlug }
          }));
        }
      } catch (error) {
        console.error('Error loading tab:', error);
        // Fallback to regular navigation
        window.location.href = `${window.location.pathname}?tab=${tabSlug}`;
      }
    }
    
    updateActiveTab(tabSlug) {
      this.tabLinks.forEach(link => {
        const isActive = link.dataset.tabSlug === tabSlug;
        link.classList.toggle('active', isActive);
      });
    }
    
    updateURL(tabSlug) {
      const url = new URL(window.location);
      url.searchParams.set('tab', tabSlug);
      window.history.replaceState({}, '', url);
    }
  }
  
  // Define custom element
  if (!customElements.get('nested-tabs')) {
    customElements.define('nested-tabs', NestedTabs);
  }
  
  // Initialize
  document.addEventListener('DOMContentLoaded', () => {
    const tabsContainer = document.querySelector('.nested-tabs-container');
    if (tabsContainer) {
      // You can wrap the container or just use the script as is
    }
  });
</script>

