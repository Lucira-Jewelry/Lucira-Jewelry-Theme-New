{% comment %}
  Section: Nested Tabs Content
  Description: Tabs navigation and dynamic content
  FIXED VERSION - Handles metafield references correctly
{% endcomment %}

{% assign category_handle = page.handle %}
{% assign current_category = metaobjects.category_page[category_handle] %}
{% assign tab_slug = request.query.tab | default: current_category.default_tab_slug %}

<style>
  .nested-tabs-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }
  
  /* Tabs Navigation */
  .tabs-navigation {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #f0f0f0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  
  .tabs-navigation::-webkit-scrollbar {
    display: none;
  }
  
  .tab-link {
    padding: 0.75rem 1.5rem;
    background: white;
    border: 2px solid #e0e0e0;
    border-radius: 50px;
    color: #333;
    text-decoration: none;
    font-weight: 500;
    white-space: nowrap;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  
  .tab-link:hover {
    border-color: #b8860b;
    color: #b8860b;
  }
  
  .tab-link.active {
    background: #b8860b;
    border-color: #b8860b;
    color: white;
  }
  
  /* Tab Content */
  .tab-content-area {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  
  @media (min-width: 992px) {
    .tab-content-area.with-image {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }
  
  .tab-content-header {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1.5rem;
    color: #333;
  }
  
  .tab-content-description {
    font-size: 1.125rem;
    line-height: 1.6;
    color: #666;
    margin-bottom: 2rem;
  }
  
  .tab-content-image {
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  
  .tab-content-image img {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .tab-cta-button {
    display: inline-block;
    padding: 1rem 2rem;
    background: #b8860b;
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background 0.3s ease;
  }
  
  .tab-cta-button:hover {
    background: #a0760a;
  }
  
  /* Related Topics */
  .related-topics {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #eee;
  }
  
  .related-topics h3 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: #333;
  }
  
  .blog-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  
  .blog-link {
    display: block;
    padding: 1rem;
    background: #f9f9f9;
    border-radius: 4px;
    color: #333;
    text-decoration: none;
    transition: background 0.3s ease;
  }
  
  .blog-link:hover {
    background: #f0f0f0;
    text-decoration: underline;
  }
  
  /* Loading State */
  .tab-content-loading {
    text-align: center;
    padding: 3rem;
    color: #666;
  }
  
  /* No Tabs Message */
  .no-tabs-message {
    text-align: center;
    padding: 3rem;
    background: #f9f9f9;
    border-radius: 8px;
    color: #666;
  }
  
  /* Debug styles (remove in production) */
  .debug-info {
    background: #fff3cd;
    border: 1px solid #ffeaa7;
    padding: 1rem;
    margin-bottom: 2rem;
    border-radius: 4px;
    font-size: 14px;
  }
</style>

<div class="nested-tabs-container">
  {% comment %} 
    FIXED: Get tabs for this category using metafield references
  {% endcomment %}
  {% assign all_tabs = metaobjects.tab_content.values %}
  {% assign category_tabs = "" | split: "" %}
  
  {% comment %} Debug info - remove after testing {% endcomment %}
  <div class="debug-info">
    <p><strong>Debug Info:</strong></p>
    <p>Category: {{ current_category.title }} (ID: {{ current_category.id }})</p>
    <p>Total tabs in system: {{ all_tabs.size }}</p>
    <p>Current tab slug: {{ tab_slug }}</p>
  </div>
  
  {% comment %} Find all tabs that belong to this category {% endcomment %}
  {% for tab in all_tabs %}
    {% comment %} Access parent_category from metafields {% endcomment %}
    {% assign parent_metafield = tab.metafields.custom.parent_category %}
    
    {% if parent_metafield and parent_metafield.value %}
      {% comment %} Check if this tab belongs to current category {% endcomment %}
      {% if parent_metafield.value.id == current_category.id %}
        {% assign category_tabs = category_tabs | push: tab %}
      {% endif %}
    {% endif %}
  {% endfor %}
  
  {% comment %} Find the current tab {% endcomment %}
  {% assign current_tab = nil %}
  {% for tab in category_tabs %}
    {% if tab.tab_slug == tab_slug %}
      {% assign current_tab = tab %}
      {% break %}
    {% endif %}
  {% endfor %}
  
  {% if current_tab == nil and category_tabs.size > 0 %}
    {% assign current_tab = category_tabs.first %}
    {% assign tab_slug = current_tab.tab_slug %}
  {% endif %}
  
  {% comment %} Display tabs and content {% endcomment %}
  {% if category_tabs.size > 0 %}
    <!-- Tabs Navigation -->
    <nav class="tabs-navigation" role="tablist">
      {% for tab in category_tabs %}
        <a 
          href="{{ request.path }}?tab={{ tab.tab_slug }}" 
          class="tab-link {% if tab.tab_slug == tab_slug %}active{% endif %}"
          data-tab-slug="{{ tab.tab_slug }}"
          role="tab"
        >
          {{ tab.title }}
        </a>
      {% endfor %}
    </nav>

    <!-- Tab Content -->
    <div class="tab-content">
      {% if current_tab %}
        <div class="tab-content-area {% if current_tab.content_image %}with-image{% endif %}">
          <div class="tab-content-text">
            {% if current_tab.header %}
              <h2 class="tab-content-header">{{ current_tab.header }}</h2>
            {% endif %}
            
            {% if current_tab.description %}
              <div class="tab-content-description">
                {{ current_tab.description }}
              </div>
            {% endif %}
            
            {% if current_tab.cta_text and current_tab.cta_link %}
              <a href="{{ current_tab.cta_link }}" class="tab-cta-button">
                {{ current_tab.cta_text }}
              </a>
            {% endif %}
          </div>
          
          {% if current_tab.content_image %}
            <div class="tab-content-image">
              <img 
                src="{{ current_tab.content_image | image_url: width: 800 }}" 
                alt="{{ current_tab.header | default: current_tab.title | escape }}"
                loading="lazy"
                width="800"
                height="600"
              >
            </div>
          {% endif %}
        </div>

        <!-- Related Topics -->
        {% if current_tab.related_blogs and current_tab.related_blogs.size > 0 %}
          <div class="related-topics">
            <h3>Related Topics</h3>
            <div class="blog-links">
              {% for article_ref in current_tab.related_blogs %}
                {% assign article = article_ref %}
                {% if article %}
                  <a href="{{ article.url }}" class="blog-link">
                    {{ article.title }}
                  </a>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      {% else %}
        <div class="tab-content-loading">
          <p>Loading content...</p>
        </div>
      {% endif %}
    </div>
  {% else %}
    <div class="no-tabs-message">
      <h3>No tabs available for this category</h3>
      <p>Found {{ all_tabs.size }} total tabs in system.</p>
      <p>Please check that:</p>
      <ul style="text-align: left; display: inline-block;">
        <li>Parent category is set in each tab's metafields</li>
        <li>You're using the correct page handle: {{ category_handle }}</li>
        <li>The category exists: {{ current_category.title }}</li>
      </ul>
      
      {% comment %} Debug output {% endcomment %}
      <div style="margin-top: 2rem; text-align: left;">
        <h4>Debug - All Tabs:</h4>
        {% for tab in all_tabs %}
          <div style="border: 1px solid #ddd; padding: 10px; margin: 10px 0;">
            <p><strong>{{ tab.title }}</strong> ({{ tab.tab_slug }})</p>
            <p>Parent Metafield: {{ tab.metafields.custom.parent_category | json }}</p>
            {% if tab.metafields.custom.parent_category.value %}
              <p>Parent ID: {{ tab.metafields.custom.parent_category.value.id }}</p>
              <p>Parent Title: {{ tab.metafields.custom.parent_category.value.title }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>

<script>
  // JavaScript for better UX
  document.addEventListener('DOMContentLoaded', function() {
    const tabLinks = document.querySelectorAll('.tab-link');
    
    tabLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        // Remove active class from all tabs
        tabLinks.forEach(l => l.classList.remove('active'));
        // Add active class to clicked tab
        this.classList.add('active');
        
        // Optional: Add smooth scroll to content
        const tabContent = document.querySelector('.tab-content');
        if (tabContent) {
          tabContent.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Nested Tabs Content",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "Nested Tabs Content"
    }
  ]
}
{% endschema %}