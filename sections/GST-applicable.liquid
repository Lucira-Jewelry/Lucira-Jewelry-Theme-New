{% schema %}
{
  "name": "3% GST Section",
  "tag": "section",
  "class": "sect-gst--gold-info",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "WHEN IS 3% GST APPLICABLE"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "SOLID GOLD"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "3% GST Section",
      "blocks": [{ "type": "column" }, { "type": "column" }, { "type": "column" }]
    }
  ]
}
{% endschema %}

<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.css">

<style>
  /* Common section styling */
  .sect-gst--gold-info {
    text-align: center;
    padding: 40px 0;
  }

  /* Heading styling */
  .section-gst__heading {
    font-size: 24px;
    margin-bottom: 40px;
    color: #333;
    margin-top:0;
  }

  /* Desktop container */
  .section-gst__container--desktop {
    display: flex;
    justify-content: center;
    gap: 20px;
    width: 75%;
    margin: 0 auto;
    padding-left:20px;
    padding-right:20px;

  }

  .section-gst__column {
    text-align: center;
    border-radius: 12px;
  }

  .section-gst__image-wrapper img {
    max-width: 100%;
    height: 100%;
    border-radius: 8px;
    object-fit: cover;
  }

  .section-gst__image-wrapper {
    height: 475px;
  }

  .section-gst__text-content {
    margin-top: 24px;
    font-size: 18px;
    color: #555;
    text-transform: uppercase;
  }

  /* Mobile container (Swiper) */
  .section-gst__container--mobile {
    display: none; /* hidden on desktop */
  }
   .shopify-section.sect-gst--gold-info {
    padding-top: 0!important;
    padding-bottom: 0!important;
  }
  /* Mobile styling */
  @media screen and (max-width: 767px) {
    .section-gst__image-wrapper img {
      height: unset;
    }

    .section-gst__image-wrapper {
      height: unset;
    }
    .section-gst__container--desktop {
      display: none;
    }
   .section-gst__image-wrapper {
      width: 100%;
      height: auto; /* let height adjust naturally */
    }

    .section-gst__image-wrapper img {
      width: 100%;
      height: auto;
      object-fit: contain; /* prevent cropping */
      border-radius: 8px;
    }
    .section-gst__container--mobile {
      display: block;
    }
  .sect-gst--gold-info .swiper-wrapper{
  padding-left:20px;
  padding-right:20px;
  gap:12px;
  }
    .section-gst__heading {
      font-size: 18px;
      margin-bottom: 16px!important;
      margin:0;
    }

    .section-gst__text-content {
      margin-top: 12px;
      font-size: 14px;
    }
    .shopify-section.sect-gst--gold-info {
    padding-top: 0!important;
    padding-bottom: 0!important;
  }
  .sect-gst--gold-info {
    padding: 20px 0;
  }

  }
  @media (max-width: 748px) {
      .sect-gst--gold-info .swiper-slide {
          aspect-ratio: unset!important;
          overflow: hidden;
          margin-right:unset!important;
      }
      .sect-gst--gold-info .swiper-wrapper{
padding-left:20px;
padding-right:20px;
}
    .section-gst__container--mobile {
        display: block;
        padding-right: 20px;
    }
</style>

<div class="sect-gst--gold-info">
  <h2 class="section-gst__heading">{{ section.settings.heading }}</h2>

  <!-- Desktop -->
  <div class="section-gst__container--desktop">
    {% for block in section.blocks %}
      <div class="section-gst__column">
        <div class="section-gst__image-wrapper">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | img_url: '400x' }}" alt="{{ block.settings.text }}" title="{{ block.settings.text }}">
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
        <p class="section-gst__text-content">{{ block.settings.text }}</p>
      </div>
    {% endfor %}
  </div>

  <!-- Mobile Swiper -->
  <div class="section-gst__container--mobile swiper swiper-{{ section.id }}">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div class="section-gst__column swiper-slide">
          <div class="section-gst__image-wrapper">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | img_url: '400x' }}" title="{{ block.settings.text }}" alt="{{ block.settings.text }}" title="{{ block.settings.text }}">
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <p class="section-gst__text-content">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<!-- Swiper JS -->
<script>
let gstSwiperMobile = null;

function initGstSwiper() {
  const swiperContainer = document.querySelector('.swiper-{{ section.id }}');
  if (!swiperContainer) return;

  if (window.innerWidth < 768) {
    if (!gstSwiperMobile) {
      gstSwiperMobile = new Swiper(swiperContainer, {
        slidesPerView: 1.2,
        // Increase this value for a larger gap
        spaceBetween: 20, 
        pagination: {
          el: swiperContainer.querySelector('.swiper-pagination'),
          clickable: true,
        },
      });
    }
  } else {
    if (gstSwiperMobile) {
      gstSwiperMobile.destroy(true, true);
      gstSwiperMobile = null;
    }
  }
}

document.addEventListener("DOMContentLoaded", () => {
  initGstSwiper();
  window.addEventListener("resize", initGstSwiper);
});
</script>