<script>
    (function() {
        const totalSteps = {{ section.blocks.size }};
        const dots = document.querySelectorAll('.curved-steps-slider-section .step-dot');
        const progressPath = document.getElementById('progressPath');
        const sliderSection = document.querySelector('.curved-steps-slider-section');

        let isLocked = false;
        let scrollAccumulator = 0;
        const scrollThreshold = 50; // Reduced for more responsive scrolling
        let lastScrollTime = 0;
        const scrollCooldown = 100; // Minimum time between scroll detections

        // Initialize Swiper with VERTICAL direction
        const swiper = new Swiper('.curved-steps-swiper', {
            direction: 'vertical',
            slidesPerView: 1,
            spaceBetween: 0,
            speed: 600,
            allowTouchMove: true,
            effect: 'slide',
            mousewheel: false, // We'll handle this manually for better control
            on: {
                slideChange: function() {
                    updateDotsAndProgress(this.activeIndex + 1);
                }
            }
        });

        function updateDotsAndProgress(step) {
            dots.forEach((dot, index) => {
                dot.classList.remove('active');
                if (index + 1 === step) {
                    dot.classList.add('active');
                    dot.classList.remove('small');
                } else {
                    dot.classList.add('small');
                }
            });

            // Custom values for each step
            const stepValues = {
                1: { dasharray: 502.465, dashoffset: 408.465 },
                2: { dasharray: 435.465, dashoffset: 272.31 },
                3: { dasharray: 390.465, dashoffset: 136.155 },
                4: { dasharray: 410.465, dashoffset: 0 }
            };

            const values = stepValues[step] || stepValues[1];
            progressPath.style.strokeDasharray = values.dasharray;
            progressPath.style.strokeDashoffset = values.dashoffset;
        }

        function isSectionCentered() {
            const rect = sliderSection.getBoundingClientRect();
            const windowHeight = window.innerHeight;
            
            const isInViewport = rect.top < windowHeight && rect.bottom > 0;
            
            if (!isInViewport) return false;
            
            const sectionMiddle = rect.top + (rect.height / 2);
            const windowMiddle = windowHeight / 2;
            
            const tolerance = windowHeight * 0.2; // Slightly increased tolerance
            
            return Math.abs(sectionMiddle - windowMiddle) < tolerance;
        }

        dots.forEach(dot => {
            dot.addEventListener('click', () => {
                const step = parseInt(dot.dataset.step);
                swiper.slideTo(step - 1);
                scrollAccumulator = 0; // Reset accumulator on click
            });
        });

        window.addEventListener('wheel', (e) => {
            const centered = isSectionCentered();
            const currentTime = Date.now();

            if (centered) {
                const canScrollDown = swiper.activeIndex < totalSteps - 1;
                const canScrollUp = swiper.activeIndex > 0;

                // Allow page scroll if at boundaries
                if (!canScrollDown && e.deltaY > 0) {
                    scrollAccumulator = 0;
                    return;
                }

                if (!canScrollUp && e.deltaY < 0) {
                    scrollAccumulator = 0;
                    return;
                }

                e.preventDefault();

                // Skip if locked or in cooldown
                if (isLocked || (currentTime - lastScrollTime) < scrollCooldown) {
                    return;
                }

                // Normalize scroll delta for different input devices
                const normalizedDelta = Math.sign(e.deltaY) * Math.min(Math.abs(e.deltaY), 100);
                scrollAccumulator += normalizedDelta;

                // Check if threshold is reached
                if (Math.abs(scrollAccumulator) >= scrollThreshold) {
                    isLocked = true;
                    lastScrollTime = currentTime;

                    if (scrollAccumulator > 0 && canScrollDown) {
                        swiper.slideNext();
                    } else if (scrollAccumulator < 0 && canScrollUp) {
                        swiper.slidePrev();
                    }

                    scrollAccumulator = 0;

                    setTimeout(() => {
                        isLocked = false;
                    }, 650); // Slightly longer than slide transition
                }
            } else {
                scrollAccumulator = 0;
                isLocked = false;
            }
        }, { passive: false });

        // Reset on scroll when leaving section
        let wasInSection = false;
        window.addEventListener('scroll', () => {
            const inSection = isSectionCentered();
            if (wasInSection && !inSection) {
                scrollAccumulator = 0;
                isLocked = false;
            }
            wasInSection = inSection;
        });

        // Initialize with step 1 values
        progressPath.style.strokeDasharray = 502.465;
        progressPath.style.strokeDashoffset = 408.465;
        
        updateDotsAndProgress(1);
    })();
</script>