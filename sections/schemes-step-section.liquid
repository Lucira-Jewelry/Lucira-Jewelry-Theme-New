<section class="curved-steps-slider-section">
    <div class="title-wrapper">
        {% if section.settings.curved_steps_title != blank %}
            <h2>{{ section.settings.curved_steps_title }}</h2>
        {% endif %}
        {% if section.settings.curved_steps_subtitle != blank %}
            <p>{{ section.settings.curved_steps_subtitle }}</p>
        {% endif %}
    </div>
    <div class="slider-container">
        <div class="semicircle-wrapper">
            <svg viewBox="0 0 140 270" xmlns="http://www.w3.org/2000/svg">
                <path class="curve-path" d="M 5,5 A 130,130 0 0,1 135,135 A 130,130 0 0,1 5,265" fill="none" stroke="#e0e0e0" stroke-width="10"/>
                <path class="curve-progress" id="progressPath" d="M 5,5 A 130,130 0 0,1 135,135 A 130,130 0 0,1 5,265" fill="none" stroke="#4CAF50" stroke-width="10" style="stroke-dasharray: 408.465; stroke-dashoffset: 408.465;"/>
            </svg>
            {% for block in section.blocks %}
                <div class="step-dot step-{{ forloop.index }}{% if forloop.first %} active{% endif %} small" data-step="{{ forloop.index }}">
                    {{ forloop.index }}
                </div>
            {% endfor %}
        </div>

        <div class="content-area">
            {% for block in section.blocks %}
                <div class="slide-content{% if forloop.first %} active{% endif %}" data-slide="{{ forloop.index }}" {{ block.shopify_attributes }}>
                    <div class="content-image">
                        <div class="placeholder">
                            {% if block.settings.image != blank %}
                                {{ block.settings.image | image_url: width: 560 | image_tag: loading: 'lazy', width: 560, height: 700, alt: block.settings.heading }}
                            {% else %}
                                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                            {% endif %}
                        </div>
                    </div>
                    <div class="content-text">
                        {% if block.settings.heading != blank %}
                            <h2>{{ block.settings.heading }}</h2>
                        {% endif %}
                        {% if block.settings.description != blank %}
                            <p>{{ block.settings.description }}</p>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

<script>
    (function() {
        let currentStep = 1;
        const totalSteps = {{ section.blocks.size }};
        let isLocked = false;
        let scrollAccumulator = 0;
        const scrollThreshold = 80; // Increased threshold for less sensitivity

        const dots = document.querySelectorAll('.curved-steps-slider-section .step-dot');
        const slides = document.querySelectorAll('.curved-steps-slider-section .slide-content');
        const progressPath = document.getElementById('progressPath');
        const sliderSection = document.querySelector('.curved-steps-slider-section');

        function updateSlider(step) {
            currentStep = step;

            dots.forEach((dot, index) => {
                dot.classList.remove('active');
                if (index + 1 === step) {
                    dot.classList.add('active');
                    dot.classList.remove('small');
                } else {
                    dot.classList.add('small');
                }
            });

            slides.forEach((slide, index) => {
                slide.classList.remove('active');
                if (index + 1 === step) {
                    slide.classList.add('active');
                }
            });

            // Fixed progress calculation
            const pathLength = progressPath.getTotalLength();
            const segmentLength = pathLength / (totalSteps - 1);
            const progress = (step - 1) * segmentLength;
            progressPath.style.strokeDashoffset = pathLength - progress;
        }

        function isSectionCentered() {
            const rect = sliderSection.getBoundingClientRect();
            const windowHeight = window.innerHeight;
            
            // Check if section is in viewport and more strictly centered
            const isInViewport = rect.top < windowHeight && rect.bottom > 0;
            
            if (!isInViewport) return false;
            
            const sectionMiddle = rect.top + (rect.height / 2);
            const windowMiddle = windowHeight / 2;
            
            // Reduced tolerance to 15% for more precise detection
            const tolerance = windowHeight * 0.15;
            
            return Math.abs(sectionMiddle - windowMiddle) < tolerance;
        }

        dots.forEach(dot => {
            dot.addEventListener('click', () => {
                const step = parseInt(dot.dataset.step);
                updateSlider(step);
            });
        });

        window.addEventListener('wheel', (e) => {
            const centered = isSectionCentered();

            if (centered) {
                // Section is centered - handle slide navigation
                const canScrollDown = currentStep < totalSteps;
                const canScrollUp = currentStep > 1;

                if (!canScrollDown && e.deltaY > 0) {
                    // Allow normal scroll when at last slide and scrolling down
                    scrollAccumulator = 0;
                    return;
                }

                if (!canScrollUp && e.deltaY < 0) {
                    // Allow normal scroll when at first slide and scrolling up
                    scrollAccumulator = 0;
                    return;
                }

                // Prevent normal scroll and handle slide changes
                e.preventDefault();

                if (isLocked) return;

                scrollAccumulator += e.deltaY;

                if (Math.abs(scrollAccumulator) >= scrollThreshold) {
                    isLocked = true;

                    if (scrollAccumulator > 0 && canScrollDown) {
                        updateSlider(currentStep + 1);
                    } else if (scrollAccumulator < 0 && canScrollUp) {
                        updateSlider(currentStep - 1);
                    }

                    scrollAccumulator = 0;

                    setTimeout(() => {
                        isLocked = false;
                    }, 600);
                }
            } else {
                // Section is not centered - reset accumulator and allow normal scrolling
                scrollAccumulator = 0;
            }
        }, { passive: false });

        // Initialize
        const pathLength = progressPath.getTotalLength();
        progressPath.style.strokeDasharray = pathLength;
        progressPath.style.strokeDashoffset = pathLength;
        
        updateSlider(1);
    })();
</script>

<style>
    .semicircle-wrapper { position: relative; width: 205px; height: 400px; flex-shrink: 0; left: -6px; }
    .semicircle-path{position:absolute;top:0;left:0;width:100%;height:100%}
    .step-dot{position:absolute;width:70px;height:70px;border-radius:50%;background: #F3DCE0; color: #1a1a1a; font-family: Futura Std; font-weight: 500; font-size: 20px; line-height: 150%; vertical-align: middle; text-transform: uppercase;cursor:pointer;transition:all .6s cubic-bezier(.4,0,.2,1);box-shadow:0 4px 15px rgba(0,0,0,.08);display: flex;  align-items: center; justify-content: center;}
    .step-dot.active {width: 70px; height: 70px; color: #fff; background: #DAA7B4; font-size: 24px; box-shadow: 0 8px 30px rgba(212, 160, 184, .4); z-index: 2;}
    .step-dot.small{width:50px;height:50px;font-size:18px;transition:all .6s cubic-bezier(.4,0,.2,1);}
    .curved-steps-slider-section .step-1{top: 80px; left: 78%;transform:translate(-50%,-50%);}
    .curved-steps-slider-section .step-2{top: 42%; right: 12px;transform: translate(50%, -50%);}
    .curved-steps-slider-section .step-3{bottom: 142px; right: 14px;transform: translate(50%, 50%);}
    .curved-steps-slider-section .step-4{bottom: 65px; left: 70%;transform:translate(-50%,50%)}
    .curved-steps-slider-section svg{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none}
    .curved-steps-slider-section .curve-path{fill:#F4F0F0;stroke:#1A1A1A;stroke-width:1}
    .curved-steps-slider-section .curve-progress{fill:none;stroke:#d4a0b8;stroke-width:2;stroke-linecap:round;stroke-dasharray:1000;stroke-dashoffset:1000;transition:stroke-dashoffset 1s cubic-bezier(.4,0,.2,1)}
    .curved-steps-slider-section .content-area{flex:1;max-width:900px;opacity:0;transform:translateX(50px);animation:fadeInContent .8s ease forwards;animation-delay:.3s}
    .slider-container {display: grid ; grid-template-columns: calc(25% - 0px) calc(70% - 0px); align-items: flex-start; margin: 60px 0 0;}
    .slider-container .slide-content {display: flex ; align-items: center; gap: 40px;}
    .curved-steps-slider-section { position: relative; padding: 60px 0 0;}
    @keyframes fadeInContent{
    to{opacity:1;transform:translateX(0)}
    }
    .curved-steps-slider-section .slide-content{display:none;opacity:0;transition:opacity .8s ease, transform .8s ease;}
    .curved-steps-slider-section .slide-content.active{display: flex !important ; align-items: center;opacity:1;transform:translateY(0);animation:slideIn .8s cubic-bezier(.4,0,.2,1);}
    @keyframes slideIn{
    0%{opacity:0;transform:translateY(40px) scale(0.95);}
    100%{opacity:1;transform:translateY(0) scale(1);}
    }
    .curved-steps-slider-section .content-image{width:100%;max-width:370px;overflow:hidden;margin-bottom:0px;box-shadow:0 10px 40px rgba(0,0,0,.1)}
    .curved-steps-slider-section .content-image img{width:100%;height:100%;object-fit:cover;display: block;}
    .curved-steps-slider-section .content-text h2{color: #1A1A1A; margin-bottom: 12px; margin-top: 0; font-weight: 500; font-size: 20px; line-height: 1.5; letter-spacing: 1.2px; vertical-align: middle; text-transform: uppercase;}
    .curved-steps-slider-section .content-text p { color: #1A1A1A; line-height: 1.8; margin-top: 12px; font-size: 14px; margin-bottom: 0;}
    .curved-steps-slider-section h2 {font-weight: 500; font-size: 24px; line-height: 150%; text-align: center; vertical-align: middle; text-transform: uppercase; margin-top: 0; margin-bottom: 12px;}
    .curved-steps-slider-section p {color: #1a1a1a; max-width: 690px; margin: 0 auto; font-weight: 400; font-size: 16px; letter-spacing: 1px; text-align: center; vertical-align: middle; line-height: 1.6;}
    .slider-container .content-text h2, .slider-container .content-text p{text-align: left;}
    @media (max-width:1024px){
    .curved-steps-slider-section .slider-container{flex-direction:column;gap:60px}
    .curved-steps-slider-section .semicircle-wrapper{width:300px;height:300px}
    }
    @media (max-width:767px){
      .curved-steps-slider-section .step-1 {top: 30px; left: 20%; transform: translate(-50%, -50%);}
      .step-dot.active { width: 50px; height: 50px; color: #fff; background: #DAA7B4; font-size: 14px; box-shadow: 0 8px 30px rgba(212, 160, 184, .4); z-index: 2; }
      .curved-steps-slider-section .step-2 { top: 32%; right: 168px; transform: translate(50% 50% , -50%); }
      .step-dot {width: 40px; height: 40px;}
      .curved-steps-slider-section svg {width: 50%;}
      .curved-steps-slider-section .step-3 { bottom: 90px; right: 166px; transform: translate(50%, 50%); }
      .curved-steps-slider-section .step-4 { bottom: 25px; left: 20%; transform: translate(-50%, 50%); }
      .slider-container { display: grid ; grid-template-columns: calc(30% - 0px) calc(56% - 0px); align-items: flex-start; margin: 60px 0 0; padding: 0 12px 0 0; }
      .curved-steps-slider-section .slide-content.active {flex-direction: column;}
      .curved-steps-slider-section .content-text h2 {font-size: 14px;}
      .slider-container .slide-content {gap: 22px;}
      .curved-steps-slider-section .content-text p { color: #1A1A1A; margin-top: 12px; margin-bottom: 0; font-weight: 400; font-size: 12px; line-height: 150%; letter-spacing: 1px; }
      .curved-steps-slider-section h2 {font-size: 18px;}
      .curved-steps-slider-section p { color: #1a1a1a; margin: 0 auto; letter-spacing: 1px; vertical-align: middle; font-weight: 400; font-size: 12px; line-height: 150%; text-align: center; max-width: 90%; }
      .curved-steps-slider-section .content-text p {margin: 0;}
    }
</style>

