<style>
.jewelry-size-guide { margin: 0 auto; padding: 40px 20px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif; }
.jsg-tabs{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:15px;margin-bottom:50px;max-width:1300px;height:130px;margin-left:auto;margin-right:auto}
.jsg-tab{background:#fff;border:2px solid #e5e5e5;border-radius:8px;padding:20px 15px;text-align:center;cursor:pointer;transition:all .3s ease;display:flex;flex-direction:row;align-items:center;gap:30px}
.jsg-tab:hover{border-color:#d4a574;transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.1)}
.jsg-tab.active{border-color:#d4a574;background:#fefbf7;box-shadow:0 4px 12px rgba(212,165,116,.2)}
.jsg-tab-icon{width:50px;height:50px;object-fit:contain}
.jsg-tab-label{font-size:20px;font-weight:500;text-transform:uppercase;letter-spacing:.5px;color:#333}
.jsg-content{display:none}
.jsg-content.active{display:block}
.jsg-chart-section{margin-bottom:60px}
.jsg-chart-title{text-align:center;font-size:24px;font-weight:500;text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;color:#333}
.jsg-chart-subtitle{text-align:center;font-size:14px;color:#666;margin-bottom:40px;line-height:1.6;max-width:800px;margin-left:auto;margin-right:auto}
.jsg-chart-wrapper{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}
.jsg-table-container{background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.08)}
.jsg-table{width:100%;border-collapse:collapse}
.jsg-table thead{background:#f8f8f8}
.jsg-table th{padding:15px 12px;text-align:center;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#333;border:2px solid #e5e5e5}
.jsg-table td{padding:12px;text-align:center;font-size:14px;color:#666;border:2px solid #e5e5e5}
.jsg-table tbody tr:hover{background:#fefbf7}
.jsg-chart-images{display:flex;flex-direction:column;gap:75px}
.jsg-ring-diagram{border-radius:8px;display:flex;justify-content:space-around;align-items:center}
.jsg-ring-visual{text-align:center}
.jsg-ring-image{width:150px;height:150px;object-fit:contain}
.jsg-ring-label{font-size:13px;font-weight:600;color:#333;text-transform:uppercase;letter-spacing:.5px}
.jsg-download-btn{display:inline-flex;align-items:center;gap:10px;background:#a68380;color:#fff;padding:15px 30px;border-radius:6px;text-decoration:none;font-weight:500;font-size:14px;text-transform:uppercase;letter-spacing:.5px;transition:all .3s ease;border:none;cursor:pointer;margin-top:20px}
.jsg-download-btn:hover{background:#c49563;transform:translateY(-2px);box-shadow:0 4px 12px rgba(212,165,116,.3)}
.jsg-download-btn svg{width:18px;height:18px}
.jsg-diy-section{margin-top:60px}
.jsg-diy-title{text-align:center;font-size:24px;font-weight:500;text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;color:#333}
.jsg-diy-subtitle{text-align:center;font-size:14px;color:#666;margin-bottom:40px;line-height:1.6;max-width:800px;margin-left:auto;margin-right:auto}
.jsg-diy-wrapper{display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start}
.jsg-diy-steps{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
.jsg-step-card{background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.08);transition:transform .3s ease,box-shadow .3s ease}
.jsg-step-card:hover{transform:translateY(-5px);box-shadow:0 8px 20px rgba(0,0,0,.12)}
.jsg-step-image{width:100%;height:180px;object-fit:cover}
.jsg-step-content{padding:15px;background:0 0;color:#1a1a1a}
.jsg-step-number{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:#d4a574;margin-bottom:5px}
.jsg-step-text{font-size:14px;line-height:1.4;text-transform:uppercase;letter-spacing:.5px}
.jsg-video-container{background:#f8f8f8;border-radius:8px;overflow:hidden;position:relative;padding-bottom:100%;box-shadow:0 2px 8px rgba(0,0,0,.08)}
.jsg-video-container iframe,.jsg-video-container img,.jsg-video-container video{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover}
@media (max-width:968px){
.jsg-chart-wrapper,.jsg-diy-wrapper{grid-template-columns:1fr;gap:30px}
.jsg-ring-diagram{flex-direction:column;gap:20px}
.jsg-measure-guide-wrapper{grid-template-columns:1fr;gap:30px}
}
@media (max-width:640px){
.jsg-tabs{grid-template-columns:repeat(2,1fr)}
.jsg-diy-steps{grid-template-columns:1fr}
.jsg-chart-title,.jsg-diy-title,.jsg-measure-guide-title{font-size:22px}
.jsg-table td,.jsg-table th{padding:8px 5px;font-size:11px}
.jsg-measure-guide-cta{width:100%;justify-content:center}
}
.jsg-measure-guide-section{padding-top:80px}
.jsg-measure-guide-wrapper{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.jsg-measure-guide-image-container{position:relative;border-radius:12px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.1)}
.jsg-measure-guide-image{width:100%;height:auto;display:block;object-fit:cover}
.jsg-measure-guide-content{padding:20px 0}
.jsg-measure-guide-title{font-size:24px;font-weight:500;text-transform:uppercase;letter-spacing:1.5px;color:#333;margin-bottom:25px;line-height:1.2}
.jsg-measure-guide-instructions{margin-bottom:30px}
.jsg-measure-guide-instruction-item{display:flex;gap:12px;margin-bottom:15px;font-size:14px;line-height:1.6;color:#666}
.jsg-measure-guide-instruction-number{flex-shrink:0;font-weight:600;color:#333}
.jsg-measure-guide-instruction-text{flex:1}
.jsg-measure-guide-cta{display:inline-flex;align-items:center;gap:10px;background:#a68380;color:#fff;padding:16px 32px;border-radius:6px;text-decoration:none;font-weight:500;font-size:13px;text-transform:uppercase;letter-spacing:1px;transition:all .3s ease;border:none;cursor:pointer}
.jsg-measure-guide-cta:hover{background:#8a7468;transform:translateY(-2px);box-shadow:0 6px 16px rgba(155,133,121,.3);color:#fff}
.jsg-measure-guide-cta svg{width:18px;height:18px}
@media (max-width:767px){
.jewelry-size-guide{padding:20px 15px}
.jsg-tabs{grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:30px;height:auto}
.jsg-tab{flex-direction:row;gap:8px;padding:15px 10px;min-height:80px}
.jsg-tab-icon{width:40px;height:40px}
.jsg-tab-label{font-size:16px;letter-spacing:.3px;line-height:1.2}
.jsg-chart-section{margin-bottom:40px}
.jsg-chart-title{font-size:18px;margin-bottom:8px;letter-spacing:.5px}
.jsg-chart-subtitle{font-size:12px;margin-bottom:25px;padding:0 10px}
.jsg-chart-wrapper{grid-template-columns:1fr;gap:25px}
.jsg-table-container{overflow-x:auto;-webkit-overflow-scrolling:touch}
.jsg-table{font-size:11px;min-width:100%}
.jsg-table th{padding:10px 6px;font-size:9px;white-space:nowrap;letter-spacing:.3px}
.jsg-table td{padding:10px 6px;font-size:11px;white-space:nowrap}
.jsg-chart-images{gap:15px}
.jsg-ring-diagram{flex-direction:row;padding:20px 15px;gap:15px}
.jsg-ring-visual{flex:1}
.jsg-ring-image{width:100px;height:100px}
.jsg-ring-label{font-size:10px;letter-spacing:.3px}
.jsg-download-btn{width:100%;justify-content:center;padding:12px 20px;font-size:11px;margin-top:0;letter-spacing:.8px}
.jsg-download-btn svg{width:16px;height:16px}
.jsg-diy-section{margin-top:40px}
.jsg-diy-title{font-size:18px;margin-bottom:8px;letter-spacing:.5px}
.jsg-diy-subtitle{font-size:12px;margin-bottom:25px;padding:0 10px}
.jsg-diy-wrapper{grid-template-columns:1fr;gap:25px}
.jsg-diy-steps{grid-template-columns:repeat(2,1fr);gap:12px;order:1}
.jsg-step-card{border-radius:6px}
.jsg-step-image{height:140px}
.jsg-step-content{padding:12px 10px}
.jsg-step-number{font-size:9px;margin-bottom:4px;letter-spacing:.8px}
.jsg-step-text{font-size:11px;letter-spacing:.3px;line-height:1.3}
.jsg-video-container{padding-bottom:56.25%;border-radius:6px;order:2}
.jsg-measure-guide-section{margin-top:40px;padding-top:40px}
.jsg-measure-guide-wrapper{grid-template-columns:1fr;gap:25px}
.jsg-measure-guide-image-container{border-radius:8px;order:1}
.jsg-measure-guide-content{padding:0;order:2}
.jsg-measure-guide-title{font-size:18px;margin-bottom:20px;letter-spacing:1px}
.jsg-measure-guide-instruction-item{gap:10px;margin-bottom:6px;font-size:12px}
.jsg-measure-guide-instruction-number{font-size:13px}
.jsg-measure-guide-cta{width:100%;justify-content:center;padding:14px 24px;font-size:11px;letter-spacing:.8px;margin-top:20px}
.jsg-measure-guide-cta svg{width:16px;height:16px}
}
@media (max-width:374px){
.jsg-tab{padding:12px 8px;min-height:90px}
.jsg-tab-icon{width:35px;height:35px}
.jsg-tab-label{font-size:10px}
.jsg-table th{padding:8px 4px;font-size:8px}
.jsg-table td{padding:8px 4px;font-size:10px}
.jsg-ring-image{width:80px;height:80px}
.jsg-step-image{height:120px}
.jsg-step-content{padding:10px 8px}
}
.jsg-step-card{position:relative;border-radius:12px;overflow:hidden}
.jsg-step-image{width:100%;height:100%;min-height:220px;object-fit:cover;display:block}
.jsg-step-card::after{content:"";position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,0) 45%,rgba(0,0,0,.75) 100%);z-index:1}
.jsg-step-content{position:absolute;bottom:18px;left:18px;right:18px;padding:0;background:0 0;color:#fff;z-index:2}
.jsg-step-number{font-size:12px;font-weight:500;letter-spacing:1px;color:rgba(255,255,255,.85);margin-bottom:6px}
.jsg-step-text{font-size:18px;font-weight:400;line-height:1.2;letter-spacing:.8px;color:#fff}
@media (max-width:767px){
.jsg-step-image{min-height:160px}
.jsg-step-content{bottom:12px;left:12px;right:12px}
.jsg-step-number{font-size:10px}
.jsg-step-text{font-size:14px}
}
@media (max-width:374px){
.jsg-step-image{min-height:140px}
.jsg-step-text{font-size:13px}
}
.jsg-ring-visual-full{width:100%;max-width:100%}
.jsg-ring-image-full{width:100%;height:auto}
</style>

<div class="page-width jewelry-size-guide">
  <!-- Tab Navigation -->
  <div class="jsg-tabs">
    {% for tab in section.blocks %}
      {% if tab.type == 'tab' %}
        <div class="jsg-tab {% if forloop.first %}active{% endif %}" 
             data-tab="{{ tab.id }}"
             onclick="switchTab('{{ tab.id }}')">
          {% if tab.settings.tab_icon %}
            <img src="{{ tab.settings.tab_icon | image_url: width: 100 }}" 
                 alt="{{ tab.settings.tab_label }}" 
                 class="jsg-tab-icon">
          {% endif %}
          <span class="jsg-tab-label">{{ tab.settings.tab_label }}</span>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <!-- Tab Content -->
  {% for tab in section.blocks %}
    {% if tab.type == 'tab' %}
      <div class="jsg-content {% if forloop.first %}active{% endif %}" 
           id="content-{{ tab.id }}">
        
        <!-- Size Chart Section -->
        <div class="jsg-chart-section">
          <h2 class="jsg-chart-title">{{ tab.settings.chart_title }}</h2>
          <p class="jsg-chart-subtitle">{{ tab.settings.chart_subtitle }}</p>

          <div class="jsg-chart-wrapper">
            <!-- Size Chart Table -->
            <div class="jsg-table-container">
              <table class="jsg-table">
                <thead>
                  <tr>
                    <th>{{ tab.settings.col1_header }}</th>
                    <th>{{ tab.settings.col2_header }}</th>
                    <th>{{ tab.settings.col3_header }}</th>
                    <th>{{ tab.settings.col4_header }}</th>
                    <th>{{ tab.settings.col5_header }}</th>
                  </tr>
                </thead>
                <tbody>
                  {% assign rows = tab.settings.table_data | newline_to_br | split: '<br />' %}
                  {% for row in rows %}
                    {% if row != blank %}
                      <tr>
                        {% assign cells = row | split: '|' %}
                        {% for cell in cells %}
                          <td>{{ cell | strip }}</td>
                        {% endfor %}
                      </tr>
                    {% endif %}
                  {% endfor %}
                </tbody>
              </table>
            </div>

              <div class="jsg-chart-images">
              <div class="jsg-ring-diagram">
                {% if tab.settings.diagram_image_1 %}
                  <div class="jsg-ring-visual jsg-ring-visual-full">
                    <img src="{{ tab.settings.diagram_image_1 | image_url: width: 800 }}" 
                        alt="{{ tab.settings.diagram_label_1 }}" 
                        class="jsg-ring-image jsg-ring-image-full">

                  </div>
                {% endif %}
              </div>

              <!-- PDF Download Button -->
              {% if tab.settings.pdf_file %}
                <div style="text-align: center;">
                  <a href="{{ tab.settings.pdf_file }}" 
                     class="jsg-download-btn" 
                     download>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    {{ tab.settings.pdf_button_text | default: 'Download Size Guide PDF' }}
                  </a>
                </div>
              {% endif %}
            </div>
          </div>
        </div>

        <!-- DIY Measurement Section -->
        <div class="jsg-diy-section">
          <h2 class="jsg-diy-title">{{ tab.settings.diy_title }}</h2>
          <p class="jsg-diy-subtitle">{{ tab.settings.diy_subtitle }}</p>

          <div class="jsg-diy-wrapper">
            <!-- DIY Steps Grid -->
            <div class="jsg-diy-steps">
              {% if tab.settings.step1_image %}
                <div class="jsg-step-card">
                  <img src="{{ tab.settings.step1_image | image_url: width: 400 }}" 
                       alt="Step 1" 
                       class="jsg-step-image">
                  <div class="jsg-step-content">
                    <div class="jsg-step-number">{{ tab.settings.step1_number | default: 'Step 01' }}</div>
                    <div class="jsg-step-text">{{ tab.settings.step1_text }}</div>
                  </div>
                </div>
              {% endif %}

              {% if tab.settings.step2_image %}
                <div class="jsg-step-card">
                  <img src="{{ tab.settings.step2_image | image_url: width: 400 }}" 
                       alt="Step 2" 
                       class="jsg-step-image">
                  <div class="jsg-step-content">
                    <div class="jsg-step-number">{{ tab.settings.step2_number | default: 'Step 02' }}</div>
                    <div class="jsg-step-text">{{ tab.settings.step2_text }}</div>
                  </div>
                </div>
              {% endif %}

              {% if tab.settings.step3_image %}
                <div class="jsg-step-card">
                  <img src="{{ tab.settings.step3_image | image_url: width: 400 }}" 
                       alt="Step 3" 
                       class="jsg-step-image">
                  <div class="jsg-step-content">
                    <div class="jsg-step-number">{{ tab.settings.step3_number | default: 'Step 03' }}</div>
                    <div class="jsg-step-text">{{ tab.settings.step3_text }}</div>
                  </div>
                </div>
              {% endif %}

              {% if tab.settings.step4_image %}
                <div class="jsg-step-card">
                  <img src="{{ tab.settings.step4_image | image_url: width: 400 }}" 
                       alt="Step 4" 
                       class="jsg-step-image">
                  <div class="jsg-step-content">
                    <div class="jsg-step-number">{{ tab.settings.step4_number | default: 'Step 04' }}</div>
                    <div class="jsg-step-text">{{ tab.settings.step4_text }}</div>
                  </div>
                </div>
              {% endif %}
            </div>

            <!-- Video Container -->
            <div class="jsg-video-container">
              {% if tab.settings.video_url contains 'youtube.com' or tab.settings.video_url contains 'youtu.be' %}
                {% assign video_id = tab.settings.video_url | split: 'v=' | last | split: '/' | last | split: '&' | first %}
                <iframe src="https://www.youtube.com/embed/{{ video_id }}" 
                        frameborder="0" 
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                        allowfullscreen>
                </iframe>
              {% elsif tab.settings.video_url contains 'vimeo.com' %}
                {% assign video_id = tab.settings.video_url | split: '/' | last %}
                <iframe src="https://player.vimeo.com/video/{{ video_id }}" 
                        frameborder="0" 
                        allow="autoplay; fullscreen; picture-in-picture" 
                        allowfullscreen>
                </iframe>
              {% elsif tab.settings.video_file %}
                <video controls>
                  <source src="{{ tab.settings.video_file }}" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
              {% elsif tab.settings.video_placeholder %}
                <img src="{{ tab.settings.video_placeholder | image_url: width: 800 }}" 
                     alt="Video Placeholder">
              {% endif %}
            </div>
          </div>
        </div>

        <!-- Measure Guide Section (Optional) -->
        {% if tab.settings.show_measure_guide %}
          <div class="jsg-measure-guide-section">
            <div class="jsg-measure-guide-wrapper">
              
              <!-- Image Side -->
              <div class="jsg-measure-guide-image-container">
                {% if tab.settings.measure_image %}
                  <img 
                    src="{{ tab.settings.measure_image | image_url: width: 800 }}" 
                    alt="{{ tab.settings.measure_title }}"
                    class="jsg-measure-guide-image"
                    loading="lazy"
                  >
                {% else %}
                  <div style="background: #f0f0f0; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; color: #999;">
                    <p>Add your measure guide image</p>
                  </div>
                {% endif %}
              </div>

              <!-- Content Side -->
              <div class="jsg-measure-guide-content">
                {% if tab.settings.measure_title != blank %}
                  <h2 class="jsg-measure-guide-title">{{ tab.settings.measure_title }}</h2>
                {% endif %}

                <div class="jsg-measure-guide-instructions">
                  {% if tab.settings.measure_instruction_1 != blank %}
                    <div class="jsg-measure-guide-instruction-item">
                      <span class="jsg-measure-guide-instruction-number">1.</span>
                      <span class="jsg-measure-guide-instruction-text">{{ tab.settings.measure_instruction_1 }}</span>
                    </div>
                  {% endif %}

                  {% if tab.settings.measure_instruction_2 != blank %}
                    <div class="jsg-measure-guide-instruction-item">
                      <span class="jsg-measure-guide-instruction-number">2.</span>
                      <span class="jsg-measure-guide-instruction-text">{{ tab.settings.measure_instruction_2 }}</span>
                    </div>
                  {% endif %}

                  {% if tab.settings.measure_instruction_3 != blank %}
                    <div class="jsg-measure-guide-instruction-item">
                      <span class="jsg-measure-guide-instruction-number">3.</span>
                      <span class="jsg-measure-guide-instruction-text">{{ tab.settings.measure_instruction_3 }}</span>
                    </div>
                  {% endif %}

                  {% if tab.settings.measure_instruction_4 != blank %}
                    <div class="jsg-measure-guide-instruction-item">
                      <span class="jsg-measure-guide-instruction-number">4.</span>
                      <span class="jsg-measure-guide-instruction-text">{{ tab.settings.measure_instruction_4 }}</span>
                    </div>
                  {% endif %}

                  {% if tab.settings.measure_instruction_5 != blank %}
                    <div class="jsg-measure-guide-instruction-item">
                      <span class="jsg-measure-guide-instruction-number">5.</span>
                      <span class="jsg-measure-guide-instruction-text">{{ tab.settings.measure_instruction_5 }}</span>
                    </div>
                  {% endif %}
                </div>

                {% if tab.settings.measure_pdf_url != blank %}
                  <a 
                    href="{{ tab.settings.measure_pdf_url }}" 
                    class="jsg-measure-guide-cta"
                    download
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    {{ tab.settings.measure_button_text | default: 'Download Ring Size Guide PDF' }}
                  </a>
                {% endif %}
              </div>

            </div>
          </div>
        {% endif %}

      </div>
    {% endif %}
  {% endfor %}
</div>

<script>
  function switchTab(tabId) {
    // Remove active class from all tabs
    document.querySelectorAll('.jsg-tab').forEach(tab => {
      tab.classList.remove('active');
    });
    
    // Remove active class from all content
    document.querySelectorAll('.jsg-content').forEach(content => {
      content.classList.remove('active');
    });
    
    // Add active class to clicked tab
    document.querySelector(`[data-tab="${tabId}"]`).classList.add('active');
    
    // Add active class to corresponding content
    document.getElementById(`content-${tabId}`).classList.add('active');
    
    // Scroll to top of section smoothly
    document.querySelector('.jewelry-size-guide').scrollIntoView({ 
      behavior: 'smooth',
      block: 'start'
    });
  }
</script>

{% schema %}
{
  "name": "Jewelry Size Guide",
  "tag": "section",
  "class": "section-jewelry-size-guide",
  "settings": [],
  "blocks": [
    {
      "type": "tab",
      "name": "Product Tab",
      "settings": [
        {
          "type": "header",
          "content": "Tab Settings"
        },
        {
          "type": "image_picker",
          "id": "tab_icon",
          "label": "Tab Icon Image"
        },
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab Label",
          "default": "Rings"
        },
        {
          "type": "header",
          "content": "Size Chart Section"
        },
        {
          "type": "text",
          "id": "chart_title",
          "label": "Chart Title",
          "default": "Ring Size Chart"
        },
        {
          "type": "textarea",
