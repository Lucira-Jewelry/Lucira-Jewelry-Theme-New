{% comment %}
File: sections/store-collection-banner.liquid
{% endcomment %}

<section class="store-collection-banner">
  <div class="grid-row">
    <div class="grid-column">
      <div class="grid-banner-collection-wrapper">
        <div class="swiper grid-banner-collection-carousel">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              <div class="swiper-slide">
                {% if block.settings.image != blank %}
                  <img 
                    src="{{ block.settings.image | img_url: 'master' }}" 
                    alt="{{ block.settings.alt_text | escape }}"
                    loading="lazy" width="100%" height="auto"
                  >
                {% endif %}

              </div>
            {% endfor %}
          </div>

          <!-- Add navigation arrows -->
          <div class="swiper-button-next"></div>
          <div class="swiper-button-prev"></div>

          <!-- Add pagination if needed -->
          <div class="swiper-pagination"></div>
        </div>
      </div>
    </div>

    <div class="grid-column">
      <div class="store-collection-banner-content">
        {{ section.settings.right_content }}
      </div>
    </div>
  </div>
</section>

<style>
  .store-collection-banner .grid-row {display: grid ; grid-template-columns: calc(55% - 0px) calc(45% - 0px);}
  .store-collection-banner .grid-banner-collection-carousel img {width: 100%; display: block;}
  .store-collection-banner .swiper-pagination-bullets {display: none;}
  .grid-banner-collection-carousel{position:relative;width:100%;height:100%}
  .grid-banner-collection-carousel .swiper-slide{background:0 0!important;opacity:0;transition:opacity .8s ease}
  .grid-banner-collection-carousel .swiper-slide-active{opacity:1}
  .grid-banner-collection-carousel img{display:block;width:100%;height:auto}
  .banner-slide-text{position:absolute;bottom:20px;left:20px;z-index:2;color:#fff}
  .swiper-fade .swiper-slide{pointer-events:none}
  .swiper-fade .swiper-slide-active{pointer-events:auto}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof Swiper === 'undefined') {
      console.error('⚠️ Swiper not found. Make sure swiper-bundle.min.js and swiper-bundle.min.css are included.');
      return;
    }

    new Swiper('.grid-banner-collection-carousel', {
      loop: true,
      slidesPerView: 1,
      effect: 'fade',
      fadeEffect: {
        crossFade: true
      },
      speed: 800,
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      }
    });
  });
</script>


{% schema %}
{
  "name": "Store Collection Banner",
  "settings": [
    {
      "type": "richtext",
      "id": "left_content",
      "label": "Left Column Content",
      "default": "<p>Left column content</p>"
    },
    {
      "type": "richtext",
      "id": "right_content",
      "label": "Right Column Content",
      "default": "<p>Right column content</p>"
    }
  ],
  "blocks": [
    {
      "type": "banner_slide",
      "name": "Banner Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt Text",
          "default": "Banner image"
        },
        {
          "type": "richtext",
          "id": "slide_text",
          "label": "Slide Text",
          "default": "<p>Your banner slide text here</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Collection Banner",
      "blocks": [
        { "type": "banner_slide" },
        { "type": "banner_slide" },
        { "type": "banner_slide" }
      ]
    }
  ]
}
{% endschema %}
