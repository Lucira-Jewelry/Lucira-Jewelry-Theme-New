{% comment %}
File: sections/store-collection-banner.liquid
{% endcomment %}

<section class="store-collection-banner">
  <div class="swiper store-banner-swiper">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div
          class="swiper-slide"
          style="background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)),
                 url('{{ block.settings.banner_image | img_url: 'master' }}') center / cover no-repeat;"
        >
          <div class="grid-row">
            <div class="grid-column grid-banner-collection-wrapper">
              {{ section.settings.left_content }}
            </div>
            <div class="grid-column">
              {{ section.settings.right_content }}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- Swiper controls -->
    <div class="swiper-pagination"></div>
    <div class="swiper-button-prev"></div>
    <div class="swiper-button-next"></div>
  </div>
</section>

<style>
  .store-collection-banner {
    position: relative;
  }
  .store-banner-swiper {
    width: 100%;
    height: 420px;
  }
  .store-banner-swiper .swiper-slide {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 420px;
    color: #fff;
  }
  .grid-row {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    padding: 0 40px;
  }
  .grid-column {
    flex: 1;
  }
  .store-collection-banner p { margin: 0; }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    if (typeof Swiper !== "undefined") {
      new Swiper(".store-banner-swiper", {
        loop: true,
        autoplay: {
          delay: 4000,
          disableOnInteraction: false,
        },
        pagination: {
          el: ".swiper-pagination",
          clickable: true,
        },
        navigation: {
          nextEl: ".swiper-button-next",
          prevEl: ".swiper-button-prev",
        },
        effect: "fade",
      });
    }
  });
</script>

{% schema %}
{
  "name": "Store Collection Banner",
  "settings": [
    {
      "type": "richtext",
      "id": "left_content",
      "label": "Left Column Content",
      "default": "<p>Left column content</p>"
    },
    {
      "type": "richtext",
      "id": "right_content",
      "label": "Right Column Content",
      "default": "<p>Right column content</p>"
    }
  ],
  "blocks": [
    {
      "type": "banner_image",
      "name": "Banner Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "banner_image",
          "label": "Background Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Collection Banner",
      "blocks": [
        { "type": "banner_image" },
        { "type": "banner_image" }
      ]
    }
  ]
}
{% endschema %}
