{% comment %}
File: sections/store-collection-banner.liquid
{% endcomment %}

<section class="store-collection-banner">
  <div class="grid-row">
    <div class="grid-column">
      <div class="grid-banner-collection-wrapper">
        <div class="grid-banner-collection-carousel owl-carousel owl-theme">
          {% for block in section.blocks %}
            <div class="item">
              {% if block.settings.image != blank %}
                <img 
                  src="{{ block.settings.image | img_url: 'master' }}" 
                  alt="{{ block.settings.alt_text | escape }}"
                  loading="lazy"
                >
              {% endif %}

              {% if block.settings.slide_text != blank %}
                <div class="banner-slide-text">
                  {{ block.settings.slide_text }}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="grid-column">
      <div class="store-collection-banner-content">
        {{ section.settings.right_content }}
      </div>
    </div>
  </div>
</section>
<script src="{{ 'jquery.min.js' | asset_url }}"></script>
<script>
  $('.grid-banner-collection-carousel').owlCarousel({
      loop:true,
      margin:10,
      nav:true,
      responsive:{
          0:{
              items:1
          },
          600:{
              items:3
          },
          1000:{
              items:5
          }
      }
  });
</script>

{% schema %}
{
  "name": "Store Collection Banner",
  "settings": [
    {
      "type": "richtext",
      "id": "left_content",
      "label": "Left Column Content",
      "default": "<p>Left column content</p>"
    },
    {
      "type": "richtext",
      "id": "right_content",
      "label": "Right Column Content",
      "default": "<p>Right column content</p>"
    }
  ],
  "blocks": [
    {
      "type": "banner_slide",
      "name": "Banner Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt Text",
          "default": "Banner image"
        },
        {
          "type": "richtext",
          "id": "slide_text",
          "label": "Slide Text",
          "default": "<p>Your banner slide text here</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Collection Banner",
      "blocks": [
        {
          "type": "banner_slide"
        },
        {
          "type": "banner_slide"
        },
        {
          "type": "banner_slide"
        }
      ]
    }
  ]
}
{% endschema %}