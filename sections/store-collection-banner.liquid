{% comment %}
File: sections/store-collection-banner.liquid
{% endcomment %}

<section class="store-collection-banner">
  <div class="store-banner-swiper swiper">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
      <div
        class="swiper-slide"
        style="background: linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.35)),
                url('{{ block.settings.banner_image | img_url: 'master' }}') center / cover no-repeat;"
      >
        <div class="banner-grid">
          <div class="banner-left">
            {{ section.settings.left_content }}
          </div>
          <div class="banner-right">
            {{ section.settings.right_content }}
          </div>
        </div>
      </div>
      {% endfor %}
    </div>

    <!-- Swiper Controls -->
    <div class="swiper-pagination"></div>
    <div class="swiper-button-prev"></div>
    <div class="swiper-button-next"></div>
  </div>
</section>

<style>
  .store-collection-banner {
    position: relative;
    width: 100%;
  }

  .store-banner-swiper {
    width: 100%;
    height: 420px;
  }

  .store-banner-swiper .swiper-slide {
    display: flex;
    align-items: center;
    height: 420px;
    color: #fff;
  }

  /* Grid layout for content inside each slide */
  .banner-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .banner-left,
  .banner-right {
    color: #fff;
  }

  .store-collection-banner p {
    margin: 0;
  }

  /* Swiper pagination + nav */
  .swiper-pagination-bullet {
    background: #fff !important;
    opacity: 0.6;
  }
  .swiper-pagination-bullet-active {
    opacity: 1;
  }
  .swiper-button-prev,
  .swiper-button-next {
    color: #fff;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .store-banner-swiper {
      height: 320px;
    }
    .banner-grid {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 0 20px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    if (typeof Swiper !== "undefined") {
      new Swiper(".store-banner-swiper", {
        loop: true,
        autoplay: {
          delay: 4000,
          disableOnInteraction: false,
        },
        pagination: {
          el: ".swiper-pagination",
          clickable: true,
        },
        navigation: {
          nextEl: ".swiper-button-next",
          prevEl: ".swiper-button-prev",
        },
        effect: "fade",
        fadeEffect: { crossFade: true },
      });
    }
  });
</script>

{% schema %}
{
  "name": "Store Collection Banner",
  "settings": [
    {
      "type": "richtext",
      "id": "left_content",
      "label": "Left Column Content",
      "default": "<h2>Left Column</h2><p>Your left-side text</p>"
    },
    {
      "type": "richtext",
      "id": "right_content",
      "label": "Right Column Content",
      "default": "<h2>Right Column</h2><p>Your right-side text</p>"
    }
  ],
  "blocks": [
    {
      "type": "banner_image",
      "name": "Banner Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "banner_image",
          "label": "Background Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Collection Banner",
      "blocks": [
        { "type": "banner_image" },
        { "type": "banner_image" }
      ]
    }
  ]
}
{% endschema %}
