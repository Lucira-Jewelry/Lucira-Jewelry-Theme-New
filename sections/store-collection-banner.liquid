{% comment %}
File: sections/store-collection-banner.liquid
{% endcomment %}

<section
  class="store-collection-banner"
  style="
    {% if collection.metafields.custom.banner_image %}
      background: url('{{ collection.metafields.custom.banner_image | image_url: width: 2000 }}') center/cover no-repeat;
    {% endif %}
  "
>
  <div class="page-width">
    <div class="grid-row">
      <div class="grid-column">
        {{ section.settings.left_content }}
      </div>
      <div class="grid-column">
        {{ section.settings.right_content }}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Store Collection Banner",
  "settings": [
    {
      "type": "richtext",
      "id": "left_content",
      "label": "Left Column Content",
      "default": "<p>Left column content</p>"
    },
    {
      "type": "richtext",
      "id": "right_content",
      "label": "Right Column Content",
      "default": "<p>Right column content</p>"
    }
  ],
  "presets": [
    {
      "name": "Store Collection Banner"
    }
  ]
}
{% endschema %}