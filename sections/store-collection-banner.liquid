{% comment %}
File: sections/store-collection-banner.liquid
{% endcomment %}

<section class="store-collection-banner">
  <div class="grid-row">
    <div class="grid-column">
      <div class="grid-banner-collection-wrapper">
        <div class="grid-banner-collection-carousel">
          {% for block in section.blocks %}
            <div class="item">
              {% if block.settings.image != blank %}
                <img 
                  src="{{ block.settings.image | img_url: 'master' }}" 
                  alt="{{ block.settings.alt_text | escape }}"
                  loading="lazy"
                >
              {% endif %}

              {% if block.settings.slide_text != blank %}
                <div class="banner-slide-text">
                  {{ block.settings.slide_text }}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="grid-column">
      <div class="store-collection-banner-content">
        {{ section.settings.right_content }}
      </div>
    </div>
  </div>
</section>

<!-- Slick Carousel Init -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof jQuery === 'undefined' || typeof jQuery.fn.slick === 'undefined') {
      console.error('⚠️ Slick Carousel not found. Make sure slick.min.js and slick.css are included.');
      return;
    }

    $('.grid-banner-collection-carousel').slick({
      infinite: true,
      slidesToShow: 5,
      slidesToScroll: 1,
      arrows: true,
      dots: false,
      autoplay: true,
      autoplaySpeed: 3000,
      responsive: [
        {
          breakpoint: 1000,
          settings: { slidesToShow: 3 }
        },
        {
          breakpoint: 600,
          settings: { slidesToShow: 1 }
        }
      ]
    });
  });
</script>

{% schema %}
{
  "name": "Store Collection Banner",
  "settings": [
    {
      "type": "richtext",
      "id": "left_content",
      "label": "Left Column Content",
      "default": "<p>Left column content</p>"
    },
    {
      "type": "richtext",
      "id": "right_content",
      "label": "Right Column Content",
      "default": "<p>Right column content</p>"
    }
  ],
  "blocks": [
    {
      "type": "banner_slide",
      "name": "Banner Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt Text",
          "default": "Banner image"
        },
        {
          "type": "richtext",
          "id": "slide_text",
          "label": "Slide Text",
          "default": "<p>Your banner slide text here</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Collection Banner",
      "blocks": [
        { "type": "banner_slide" },
        { "type": "banner_slide" },
        { "type": "banner_slide" }
      ]
    }
  ]
}
{% endschema %}