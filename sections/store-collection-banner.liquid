<section class="store-collection-banner">
  {%- comment -%}
    AUTO-DETECT STORE (Priority):
    1) collection.metafields.custom.store_location (chembur/pune/mumbai)
    2) collection.handle contains 'chembur' / 'pune' / 'mumbai'
    3) section setting (manual) or fallback to 'chembur'
  {%- endcomment -%}
  {%- liquid
    assign loc = section.settings.store_location | downcase

    assign meta_loc = collection.metafields.custom.store_location | downcase
    if meta_loc != blank
      assign loc = meta_loc
    endif

    if loc == blank or loc == 'auto'
      assign h = collection.handle | downcase
      if h contains 'chembur'
        assign loc = 'chembur'
      elsif h contains 'pune'
        assign loc = 'pune'
      elsif h contains 'mumbai'
        assign loc = 'mumbai'
      else
        assign loc = 'chembur'
      endif
    endif

    case loc
      when 'chembur'
        assign store_name   = section.settings.store_name_chembur
        assign store_addr   = section.settings.store_address_chembur
        assign map_link     = section.settings.map_link_chembur
        assign direct_text  = section.settings.direct_me_text
        assign direct_link  = section.settings.direct_me_link_chembur
        assign call_text    = section.settings.call_us_text
        assign call_link    = section.settings.call_us_link_chembur
        assign book_text    = section.settings.book_appointment_text
        assign book_link    = section.settings.book_appointment_link_chembur
        assign rating_value = section.settings.rating_chembur
        assign status_mode  = section.settings.store_status_chembur
        assign hours_json   = section.settings.hours_json_chembur
      when 'pune'
        assign store_name   = section.settings.store_name_pune
        assign store_addr   = section.settings.store_address_pune
        assign map_link     = section.settings.map_link_pune
        assign direct_text  = section.settings.direct_me_text
        assign direct_link  = section.settings.direct_me_link_pune
        assign call_text    = section.settings.call_us_text
        assign call_link    = section.settings.call_us_link_pune
        assign book_text    = section.settings.book_appointment_text
        assign book_link    = section.settings.book_appointment_link_pune
        assign rating_value = section.settings.rating_pune
        assign status_mode  = section.settings.store_status_pune
        assign hours_json   = section.settings.hours_json_pune
      when 'mumbai'
        assign store_name   = section.settings.store_name_mumbai
        assign store_addr   = section.settings.store_address_mumbai
        assign map_link     = section.settings.map_link_mumbai
        assign direct_text  = section.settings.direct_me_text
        assign direct_link  = section.settings.direct_me_link_mumbai
        assign call_text    = section.settings.call_us_text
        assign call_link    = section.settings.call_us_link_mumbai
        assign book_text    = section.settings.book_appointment_text
        assign book_link    = section.settings.book_appointment_link_mumbai
        assign rating_value = section.settings.rating_mumbai
        assign status_mode  = section.settings.store_status_mumbai
        assign hours_json   = section.settings.hours_json_mumbai
    endcase
  -%}

  {%- liquid
    # normalize rating_value: ensure it's always a stripped string (so whitespace-only values won't hide the rating)
    assign rating_value = rating_value | default: "" | strip
  -%}

  {%- liquid
    assign legacy_addr = section.settings.store_address
    if store_addr == blank and legacy_addr != blank
      assign store_addr = legacy_addr
    endif
  -%}

  <div class="grid-row">
    <div class="grid-column">
      <div class="grid-banner-collection-wrapper">
        <div class="swiper grid-banner-collection-carousel">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              {% if block.type == 'banner_slide' %}
                <div class="swiper-slide">
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | img_url: 'master' }}"
                      alt="{{ block.settings.alt_text | escape }}"
                      loading="lazy"
                      width="100%"
                      height="auto"
                    >
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
          <div class="swiper-button-next"></div>
          <div class="swiper-button-prev"></div>
          <div class="swiper-pagination"></div>
        </div>
      </div>
    </div>

    <div class="grid-column">
      <div class="store-collection-details-wrapper">
        <div class="mobile-show">
          <div class="store-details-wrapper">
            <div class="store-details-title-wrapper">
              <h1>{{ store_name }}</h1>
              {% comment %}
                Show rating when:
                - show_rating checkbox is enabled
                - rating_value is not empty or meaningless like '0' / '0.0'
              {% endcomment %}
              {% if section.settings.show_rating and rating_value != '' and rating_value != '0' and rating_value != '0.0' %}
                <a href="{{ map_link | default: '#' }}" target="_blank" class="rating-text">
                  {{ rating_value }}
                  {{- 'five-star-rating.svg' | inline_asset_content -}}
                </a>
              {% endif %}
            </div>
            {% if store_addr != blank %}
              <p>{{ store_addr | newline_to_br }}</p>
            {% endif %}
          </div>
        </div>

        <div class="store-status-wrapper">
          <div class="store-status" id="store-status" data-hours='{{ hours_json | strip | escape }}'>
            <div class="status-info">
              <span class="status-dot"></span>
              <span class="status-text"></span>
            </div>
            <span class="today-hours"></span>
            <span class="dropdown-arrow">{{- 'icon-angle-arrow.svg' | inline_asset_content -}}</span>
            <div class="store-hours-dropdown">
              <ul id="hours-list"></ul>
            </div>
          </div>
        </div>

        {% if status_mode == 'opening_soon' %}
          <span class="status-info">
            Opening Soon
          </span>
        {% endif %}

        <div class="store-facilities-wrapper">
          <div class="store-facilities-icon-wrapper">
            <span class="store-facilities-icon">
              {{- 'icon-facilities.svg' | inline_asset_content -}}
            </span>
            Facilities At store
          </div>
          {% assign facility_blocks = section.blocks | where: 'type', 'facility' %}
          {% if facility_blocks.size > 0 %}
            <ul class="store-facilities-list">
              {% for block in facility_blocks %}
                <li>{{ block.settings.facility_name }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>

        <div class="store-services-wrapper">
          <div class="store-services-icon-wrapper">
            <span class="store-services-icon">
              {{- 'icon-facilities.svg' | inline_asset_content -}}
            </span>
            Services At Store
          </div>
          {% assign services_blocks = section.blocks | where: 'type', 'services' %}
          {% if services_blocks.size > 0 %}
            <ul class="store-services-list">
              {% for block in services_blocks %}
                <li class="store-service-item">
                  {% if block.settings.service_image != blank %}
                    <span class="service-icon">
                      <img
                        src="{{ block.settings.service_image | img_url: 'master' }}"
                        title="{{ block.settings.service_name | escape }}"
                        alt="{{ block.settings.service_name | escape }}"
                      >
                    </span>
                  {% endif %}
                  <span class="service-text">{{ block.settings.service_name }}</span>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <div class="page-width">
    <div class="store-collection-book-appoinment-block">
      <div class="grid-row">
        <div class="grid-column">
          <div class="store-details-wrapper">
            <div class="store-details-title-wrapper">
              <div>{{ store_name }}</div>
              {% comment %}
                Show rating when:
                - show_rating checkbox is enabled
                - rating_value is not empty or meaningless like '0' / '0.0'
              {% endcomment %}
              {% if section.settings.show_rating and rating_value != '' and rating_value != '0' and rating_value != '0.0' %}
                <a href="{{ map_link | default: '#' }}" target="_blank" class="rating-text">
                  {{ rating_value }}
                  {{- 'five-star-rating.svg' | inline_asset_content -}}
                </a>
              {% endif %}
            </div>
            {% if store_addr != blank %}
              <p>{{ store_addr | newline_to_br }}</p>
            {% endif %}
          </div>
        </div>
        <div class="grid-column">
          <div class="store-btn-wrapper">
            <a href="{{ direct_link }}" class="direct-me-btn secondary-btn" target="_blank">
              {{- 'direction-icon.svg' | inline_asset_content -}}
              <span>{{ direct_text }}</span>
            </a>
            <a href="{{ call_link }}" class="call-us-btn secondary-btn" target="_blank">
              {{- 'call-us-icon.svg' | inline_asset_content -}}
              <span>{{ call_text }}</span>
            </a>
            <a href="{{ book_link }}" class="book-appointment-btn primary-btn" target="_blank">
              {{- 'icon-calender.svg' | inline_asset_content -}}
              <span>{{ book_text }}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% if status_mode != 'open' %}
  <style>.store-status{display:none !important;}</style>
{% endif %}

<style>
  .store-collection-banner {margin-bottom: 70px;}
  .store-collection-banner .grid-row {display: grid ; grid-template-columns: calc(55% - 0px) calc(45% - 0px);}
  .store-collection-banner .grid-banner-collection-carousel img {width: 100%; height: 100%; object-fit: cover; display: block;}
  .store-collection-banner .swiper-pagination-bullets {display: none;}
  .store-status-wrapper{position:relative;display:inline-block;font-family:inherit}
  .store-status{display:inline-flex;align-items:center;gap:6px;position:relative;cursor:pointer;font-size:14px}
  .status-info { display: inline-flex ; align-items: center; gap: 6px; border: 1px solid #008000; padding: 4px 8px; border-radius: 8px; }
  .status-dot{width:8px;height:8px;border-radius:50%}
  .status-dot.open{background-color:#008000}
  .status-dot.closed{background-color:#dc3545}
  .status-text{font-weight: 500; font-size: 14px; line-height: 24px; letter-spacing: 1px; vertical-align: middle; text-transform: uppercase; color: #008000;}
  .today-hours{color: #1A1A1A; display: inline-flex ; align-items: center; gap: 8px; font-weight: 400; font-size: 16px; line-height: 24px; letter-spacing: 1px; margin-left: 12px; margin-right: 12px;}
