<section class="store-collection-banner">
  <div class="grid-row">
    <div class="grid-column">
      <div class="grid-banner-collection-wrapper">
        <div class="swiper grid-banner-collection-carousel">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              <div class="swiper-slide">
                {% if block.settings.image != blank %}
                  <img 
                    src="{{ block.settings.image | img_url: 'master' }}" 
                    alt="{{ block.settings.alt_text | escape }}"
                    loading="lazy" width="100%" height="auto"
                  >
                {% endif %}
              </div>
            {% endfor %}
          </div>
          <div class="swiper-button-next"></div>
          <div class="swiper-button-prev"></div>
          <div class="swiper-pagination"></div>
        </div>
      </div>
    </div>

    <div class="grid-column">
      <div class="store-status-wrapper">
        <div class="store-status" id="store-status">
          <span class="status-dot"></span>
          <span class="status-text"></span>
          <span class="today-hours"></span>
          <span class="dropdown-arrow">▾</span>

          <div class="store-hours-dropdown">
            <ul id="hours-list"></ul>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .store-collection-banner .grid-row {display: grid ; grid-template-columns: calc(55% - 0px) calc(45% - 0px);}
  .store-collection-banner .grid-banner-collection-carousel img {width: 100%; display: block;}
  .store-collection-banner .swiper-pagination-bullets {display: none;}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof Swiper === 'undefined') {
      console.error('⚠️ Swiper not found. Make sure swiper-bundle.min.js and swiper-bundle.min.css are included.');
      return;
    }

    new Swiper('.grid-banner-collection-carousel', {
      loop: true,
      slidesPerView: 1,
      spaceBetween: 0,
      effect: 'fade',
      fadeEffect: {
        crossFade: true
      },
      speed: 800,
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      }
    });
  });
</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Business hours (24-hour format)
    const hours = {
      sunday:    { open: "10:00", close: "22:00" },
      monday:    { open: "10:00", close: "22:00" },
      tuesday:   { open: "10:00", close: "22:00" },
      wednesday: { open: "10:00", close: "22:00" },
      thursday:  { open: "10:00", close: "22:00" },
      friday:    { open: "10:00", close: "22:00" },
      saturday:  { open: "10:00", close: "22:00" }
    };

    const now = new Date();
    const dayIndex = now.getDay(); // 0 = Sunday, 6 = Saturday
    const dayNames = Object.keys(hours);
    const today = dayNames[dayIndex];

    const currentMinutes = now.getHours() * 60 + now.getMinutes();
    const openTime = toMinutes(hours[today].open);
    const closeTime = toMinutes(hours[today].close);

    const isOpen = currentMinutes >= openTime && currentMinutes < closeTime;

    const statusDot = document.querySelector(".status-dot");
    const statusText = document.querySelector(".status-text");
    const todayHours = document.querySelector(".today-hours");

    if (isOpen) {
      statusDot.classList.add("open");
      statusText.textContent = "Open Now";
    } else {
      statusDot.classList.add("closed");
      statusText.textContent = "Closed";
    }

    todayHours.textContent = ` | ${today.toUpperCase()} ${formatTime(hours[today].open)} - ${formatTime(hours[today].close)}`;

    // Helpers
    function toMinutes(timeStr) {
      const [h, m] = timeStr.split(":").map(Number);
      return h * 60 + m;
    }

    function formatTime(timeStr) {
      const [h, m] = timeStr.split(":").map(Number);
      const date = new Date();
      date.setHours(h, m);
      return date.toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }).toLowerCase();
    }
  });
</script>


{% schema %}
{
  "name": "Store Collection Banner",
  "settings": [
    {
      "type": "richtext",
      "id": "left_content",
      "label": "Left Column Content",
      "default": "<p>Left column content</p>"
    },
    {
      "type": "richtext",
      "id": "right_content",
      "label": "Right Column Content",
      "default": "<p>Right column content</p>"
    }
  ],
  "blocks": [
    {
      "type": "banner_slide",
      "name": "Banner Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt Text",
          "default": "Banner image"
        },
        {
          "type": "richtext",
          "id": "slide_text",
          "label": "Slide Text",
          "default": "<p>Your banner slide text here</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Collection Banner",
      "blocks": [
        { "type": "banner_slide" },
        { "type": "banner_slide" },
        { "type": "banner_slide" }
      ]
    }
  ]
}
{% endschema %}
