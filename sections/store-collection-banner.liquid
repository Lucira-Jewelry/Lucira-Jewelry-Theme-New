<section class="store-collection-banner">
  <div class="grid-row">
    <div class="grid-column">
      <div class="grid-banner-collection-wrapper">
        <div class="swiper grid-banner-collection-carousel">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              {% if block.type == 'banner_slide' %}
              <div class="swiper-slide">
                {% if block.settings.image != blank %}
                  <img 
                    src="{{ block.settings.image | img_url: 'master' }}" 
                    alt="{{ block.settings.alt_text | escape }}"
                    loading="lazy" width="100%" height="auto"
                  >
                {% endif %}
              </div>
              {% endif %}
            {% endfor %}
          </div>
          <div class="swiper-button-next"></div>
          <div class="swiper-button-prev"></div>
          <div class="swiper-pagination"></div>
        </div>
      </div>
    </div>

    <div class="grid-column">
      <div class="store-collection-details-wrapper">
        <div class="store-status-wrapper">
          <div class="store-status" id="store-status">
            <div class="status-info">
              <span class="status-dot"></span>
              <span class="status-text"></span>
            </div>
            <span class="today-hours"></span>
            <span class="dropdown-arrow">{{- 'icon-angle-arrow.svg' | inline_asset_content -}}</span>

            <div class="store-hours-dropdown">
              <ul id="hours-list"></ul>
            </div>
          </div>
        </div>

        <div class="store-facilities-wrapper">
          <div class="store-facilities-icon-wrapper">
            <span class="store-facilities-icon">
              {{- 'icon-facilities.svg' | inline_asset_content -}}
            </span>
            Facilities At store
          </div>
          {% assign facility_blocks = section.blocks | where: "type", "facility" %}
          {% if facility_blocks.size > 0 %}
          <ul class="store-facilities-list">
            {% for block in facility_blocks %}
              <li>{{ block.settings.facility_name }}</li>
            {% endfor %}
          </ul>
          {% endif %}
        </div>

        <div class="store-services-wrapper">
          <div class="store-services-icon-wrapper">
            <span class="store-services-icon">
              {{- 'icon-facilities.svg' | inline_asset_content -}}
            </span>
            Services At Store
          </div>
          {% assign services_blocks = section.blocks | where: "type", "services" %}
          {% if services_blocks.size > 0 %}
            <ul class="store-services-list">
              {% for block in services_blocks %}
                <li class="store-service-item">
                  {% if block.settings.service_image != blank %}
                    <span class="service-icon">
                      <img src="{{ block.settings.service_image | img_url: 'master' }}" alt="{{ block.settings.service_name | escape }}" />
                    </span>
                  {% endif %}
                  <span class="service-text">{{ block.settings.service_name }}</span>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </div>

  </div>
  <div class="page-width">
    <div class="store-collection-book-appoinment-block">
      <div class="grid-row">
        <div class="grid-column">
          <div class="store-details-wrapper">
            <div class="store-details-title-wrapper">
              <h2>Chembur Lucira Store</h2>
            </div>
            <p>Unit No. 305, B2B Centre Cabin A, Malad Industrial Estate, Orlem, Kaachpada, Malad West, Mumbai - 400064</p>
          </div>
        </div>
        <div class="grid-column">
          <div class="store-btn-wrapper">
            <a href="#" class="direct-me-btn secondary-btn">{{- 'direction-icon.svg' | inline_asset_content -}} Direct Me</a>
            <a href="#" class="call-us-btn secondary-btn">{{- 'call-us-icon.svg' | inline_asset_content -}} Call us</a>
            <a href="#" class="book-appointment-btn primary-btn">{{- 'icon-calender.svg' | inline_asset_content -}} Book Appointment</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .store-collection-banner .grid-row {display: grid ; grid-template-columns: calc(55% - 0px) calc(45% - 0px);}
  .store-collection-banner .grid-banner-collection-carousel img {width: 100%; height: 100%; object-fit: cover; display: block;}
  .store-collection-banner .swiper-pagination-bullets {display: none;}
  .store-status-wrapper{position:relative;display:inline-block;font-family:inherit}
  .store-status{display:inline-flex;align-items:center;gap:6px;position:relative;cursor:pointer;font-size:14px}
  .status-info { display: inline-flex ; align-items: center; gap: 6px; border: 1px solid #008000; padding: 4px 8px; border-radius: 8px; }
  .status-dot{width:8px;height:8px;border-radius:50%}
  .status-dot.open{background-color:#008000}
  .status-dot.closed{background-color:#dc3545}
  .status-text{font-weight: 500; font-size: 14px; line-height: 24px; letter-spacing: 1px; vertical-align: middle; text-transform: uppercase; color: #008000;}
  .today-hours{color: #1A1A1A; display: inline-flex ; align-items: center; gap: 8px; font-weight: 400; font-size: 16px; line-height: 24px; letter-spacing: 1px; margin-left: 12px; margin-right: 12px;}
  .today-hours svg { width:28px; height:28px; vertical-align:middle; }
  .dropdown-arrow{font-size:12px;color:#777}
  .store-hours-dropdown{display:none;position: absolute; top: 130%; left: 0; background: #fff; border: 1px solid #eaeaea; border-radius: 6px; box-shadow: 0 4px 8px rgb(56 56 56 / 10%); padding: 8px 4px; min-width: 100%; z-index: 2;}
  .store-hours-dropdown ul{list-style:none;margin:0;padding:0}
  .store-hours-dropdown li{padding: 6px 14px; display: flex ; justify-content: space-between; white-space: nowrap; font-size: 16px; color: #1A1A1A; letter-spacing: 0.6px; font-weight: 500;}
  .store-hours-dropdown li.today{font-weight:500;color:#008000}
  .store-status:hover .store-hours-dropdown{display:block}
  .store-collection-details-wrapper {height: 100%; padding: 20px 26px;}
  .store-facilities-icon svg {display: block; margin-right: 6px; width: 28px; height: 28px;}
  .store-facilities-wrapper .store-facilities-icon-wrapper {display: flex ; align-items: center; font-family: Futura Std; font-weight: 400; font-size: 16px; line-height: 24px; letter-spacing: 1px; text-transform: uppercase; color: #1A1A1A; margin-top: 20px;}
  .store-facilities-list { list-style: none; margin: 0; padding: 0; display: flex ; align-items: center; flex-wrap: wrap; gap: 12px; color: #B76F79; margin-top: 20px; font-family: Futura Std; font-weight: 400; font-size: 14px; line-height: 24px; vertical-align: middle; text-transform: capitalize; max-width: 500px;}
  .store-facilities-list li { margin-bottom: 0; border: 1px solid #B76F79; padding: 4px 16px; border-radius: 3rem; font-weight: 500; }
  .store-services-icon-wrapper {display: flex ; align-items: center; font-family: Futura Std; font-weight: 400; font-size: 16px; line-height: 24px; letter-spacing: 1px; text-transform: uppercase; color: #1A1A1A; margin-top: 20px;}
  .store-services-icon svg { display: block; margin-right: 6px; width: 28px; height: 28px; }
  .store-services-wrapper .store-service-item img { width: 100%; display: block;}
  ul.store-services-list { padding: 0; list-style: none; display: grid ; grid-template-columns: repeat(4, 1fr); gap: 12px;     max-width: 85%; margin-bottom: 0;}
  li.store-service-item { position: relative; }
  .store-service-item {position: relative; height: 100%;}
  .service-text {font-weight: 500; font-size: 12px; line-height: 150%; letter-spacing: 0.7px; vertical-align: middle; text-transform: uppercase; position: absolute; left: 10px; bottom: 10px; color: #fff;}
  .service-icon {display: block;}
  .store-details-title-wrapper h2 {margin: 0;} 
  .store-collection-book-appoinment-block .grid-row { display: grid ; grid-template-columns: calc(45% - 0px) calc(55% - 0px); align-items: center; }
  .store-collection-banner {position: relative;}
  .store-collection-book-appoinment-block { box-shadow: 0px 4px 20px 0px #00000040; position: absolute; bottom: -60px; left: 50%; transform: translate(-50%); width: 92%; padding: 20px; z-index: 1; background: #fff; border-radius: 12px;}
  .store-details-title-wrapper h2 { margin: 0; font-weight: 500; font-size: 22px; line-height: 24px; letter-spacing: 1px; vertical-align: middle; text-transform: uppercase; }
  .store-details-wrapper p { font-family: Futura Std; font-weight: 400; font-size: 14px; letter-spacing: 0.7px; line-height: 1.7; max-width: 420px; margin-bottom: 0; }
  .store-collection-book-appoinment-block .grid-row { display: grid ; grid-template-columns: calc(40% - 0px) calc(60% - 0px) !important; }
  .store-collection-book-appoinment-block a.secondary-btn { font-weight: 500; font-size: 16px; line-height: 100%; letter-spacing: 1.2px; text-transform: uppercase; padding: 16px 26px; border: 1px solid #B76F79; border-radius: 8px; color: #B76F79; display: inline-flex ; align-items: center; gap: 12px; }
  .store-btn-wrapper {display: flex ; gap: 12px; align-items: center; justify-content: flex-end;}
  .store-collection-book-appoinment-block a.primary-btn { font-weight: 500; font-size: 16px; line-height: 100%; letter-spacing: 1.2px; text-transform: uppercase; padding: 16px 26px; border: 1px solid #B76F79; border-radius: 8px; color: #fff; display: inline-flex ; align-items: center; gap: 12px; background: #B76F79;}
  .store-btn-wrapper {display: flex ; gap: 12px; align-items: center; justify-content: flex-end;}

  @media only screen and (min-width:1401px) and (max-width:1500px){
    .status-text {font-size: 12px;}
    .today-hours svg { width: 20px; height: 20px; vertical-align: middle; }
    .today-hours { color: #1A1A1A; display: inline-flex ; align-items: center; gap: 8px; font-weight: 400; font-size: 14px; line-height: normal; letter-spacing: 1px; margin-left: 12px; margin-right: 12px; }
    .status-text { font-weight: 500; font-size: 12px; line-height: 24px; letter-spacing: 1px; vertical-align: middle; text-transform: uppercase; color: #008000; }
    .store-facilities-wrapper .store-facilities-icon-wrapper {display: flex ; align-items: center; font-family: Futura Std; font-weight: 400; font-size: 14px; line-height: 24px; letter-spacing: 1px; text-transform: uppercase; color: #1A1A1A; margin-top: 20px;}
    .store-facilities-icon svg { display: block; margin-right: 6px; width: 20px; height: 20px; }
    .store-services-icon svg { display: block; margin-right: 6px; width: 20px; height: 20px;}
    .store-services-icon-wrapper {display: flex ; align-items: center; font-family: Futura Std; font-weight: 400; font-size: 14px; line-height: 24px; letter-spacing: 1px; text-transform: uppercase; color: #1A1A1A; margin-top: 20px;}
    .store-facilities-list li { margin-bottom: 0; border: 1px solid #B76F79; padding: 2px 12px; border-radius: 3rem; font-weight: 500; font-size: 12px; }
    .store-facilities-list {gap: 10px;}
    .store-hours-dropdown li {font-size: 14px;}
    .store-collection-details-wrapper {padding: 14px 26px;}
    .store-collection-book-appoinment-block {bottom: -60px;}
    .store-collection-banner .grid-row { display: grid ; grid-template-columns: calc(58% - 0px) calc(42% - 0px); }
    ul.store-services-list {max-width: 85%;}
  }

  @media only screen and (min-width:1200px) and (max-width:1400px){
    .store-collection-banner .grid-row {display: grid; grid-template-columns: calc(60% - 0px) calc(40% - 0px);}
  }

  @media only screen and (min-width:1000px) and (max-width:1200px){
    .store-collection-banner .grid-row { display: grid ; grid-template-columns: calc(55% - 0px) calc(45% - 0px);}
    .store-collection-book-appoinment-block {bottom: -95px;}
  }

  @media only screen and (min-width:0px) and (max-width:767px){
    .store-collection-banner .grid-row { display: grid ; grid-template-columns: calc(100% - 0px); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof Swiper === 'undefined') {
      console.error('⚠️ Swiper not found. Make sure swiper-bundle.min.js and swiper-bundle.min.css are included.');
      return;
    }

    new Swiper('.grid-banner-collection-carousel', {
      loop: true,
      slidesPerView: 1,
      spaceBetween: 0,
      effect: 'fade',
      fadeEffect: { crossFade: true },
      speed: 800,
      autoplay: { delay: 3000, disableOnInteraction: false },
      navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
      pagination: { el: '.swiper-pagination', clickable: true }
    });
  });
</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const hours = {
      sunday:    { open: "10:00", close: "22:00" },
      monday:    { open: "10:00", close: "22:00" },
      tuesday:   { open: "10:00", close: "22:00" },
      wednesday: { open: "10:00", close: "22:00" },
      thursday:  { open: "10:00", close: "22:00" },
      friday:    { open: "10:00", close: "22:00" },
      saturday:  { open: "10:00", close: "22:00" }
    };

    const now = new Date();
    const dayNames = Object.keys(hours);
    const today = dayNames[now.getDay()];
    const currentMinutes = now.getHours() * 60 + now.getMinutes();

    const openTime = toMinutes(hours[today].open);
    const closeTime = toMinutes(hours[today].close);
    const isOpen = currentMinutes >= openTime && currentMinutes < closeTime;

    const statusDot = document.querySelector(".status-dot");
    const statusText = document.querySelector(".status-text");
    const todayHours = document.querySelector(".today-hours");
    const hoursList = document.querySelector("#hours-list");

    if (isOpen) {
      statusDot.classList.add("open");
      statusText.textContent = "OPEN NOW";
    } else {
      statusDot.classList.add("closed");
      statusText.textContent = "CLOSED";
    }

    todayHours.innerHTML = `
      {{ 'icon-clock.svg' | inline_asset_content }}
      ${today.toUpperCase()} ${formatTime(hours[today].open)} - ${formatTime(hours[today].close)}
    `;

    dayNames.forEach(day => {
      const li = document.createElement("li");
      li.textContent = `${capitalize(day)} `;
      const span = document.createElement("span");
      span.textContent = `${formatTime(hours[day].open)} - ${formatTime(hours[day].close)}`;
      li.appendChild(span);

      if (day === today) li.classList.add("today");
      hoursList.appendChild(li);
    });

    function toMinutes(timeStr) {
      const [h, m] = timeStr.split(":").map(Number);
      return h * 60 + m;
    }

    function formatTime(timeStr) {
      const [h, m] = timeStr.split(":").map(Number);
      const date = new Date();
      date.setHours(h, m);
      return date.toLocaleTimeString([], { hour: 'numeric', minute: '2-digit', hour12: true }).toLowerCase();
    }

    function capitalize(str) {
      return str.charAt(0).toUpperCase() + str.slice(1);
    }
  });
</script>

{% schema %}
{
  "name": "Store Collection Banner",
  "settings": [
    {
      "type": "richtext",
      "id": "left_content",
      "label": "Left Column Content",
      "default": "<p>Left column content</p>"
    },
    {
      "type": "richtext",
      "id": "right_content",
      "label": "Right Column Content",
      "default": "<p>Right column content</p>"
    }
  ],
  "blocks": [
    {
      "type": "facility",
      "name": "Facility",
      "settings": [
        {
          "type": "text",
          "id": "facility_name",
          "label": "Facility Name",
          "default": "Free Parking"
        }
      ]
    },
    {
      "type": "services",
      "name": "Service",
      "settings": [
        {
          "type": "image_picker",
          "id": "service_image",
          "label": "Service Image"
        },
        {
          "type": "text",
          "id": "service_name",
          "label": "Service Name",
          "default": "Free Wi-Fi"
        }
      ]
    },
    {
      "type": "banner_slide",
      "name": "Banner Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt Text",
          "default": "Banner image"
        },
        {
          "type": "richtext",
          "id": "slide_text",
          "label": "Slide Text",
          "default": "<p>Your banner slide text here</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Collection Banner",
      "blocks": [
        { "type": "banner_slide" },
        { "type": "banner_slide" },
        { "type": "banner_slide" },
        { "type": "facility" },
        { "type": "facility" }
      ]
    }
  ]
}
{% endschema %}
