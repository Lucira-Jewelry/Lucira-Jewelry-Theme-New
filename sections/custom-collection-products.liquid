{% comment %}
  Custom Collection Section with per-block facts
  Desktop facts beside collection, scrollable, height matches product cards
  Mobile facts under collection, with Read More
{% endcomment %}

{%- assign skip_card_product_styles = false -%}

{{ 'plp-product-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'product-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'template-collection.css' | asset_url | stylesheet_tag: preload: true }}

<link rel="preload"
  href="{{ 'component-card.css' | asset_url }}"
  as="style"
  onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="{{ 'component-card.css' | asset_url }}"></noscript>

{{ 'product-detail.css' | asset_url | stylesheet_tag: preload: true }}

<style>
/* ------------------------ */
/* MAIN LAYOUT */
/* ------------------------ */
.collection-row {
  display: flex;
  gap: 30px;
  align-items: flex-start;
  margin-bottom: 70px;
}

.collection-left {
  width: 70%;
}

.collection-left-inner {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.collection-right {
  width: 30%;
  background: #FBF3EC;
  padding: 24px;
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border: 1px solid #00000033;
}

/* Facts Scroll */
.collection-right .fact-text {
  overflow-y: auto;
  overflow-x: hidden;
}
.collection-right .fact-text {
  font-family: Futura Std;
font-weight: 300;
font-style: Light;
font-size: 18px;
leading-trim: NONE;
line-height: 150%;
letter-spacing: 4%;
margin: 0;
}

/* Scrollbar */
.collection-right .fact-text::-webkit-scrollbar {
  width: 4px;
}
.collection-right .fact-text::-webkit-scrollbar-track {
  background: transparent;
}
.collection-right .fact-text::-webkit-scrollbar-thumb {
  background: #ccc;
  border-radius: 3px;
}

/* Chips */
.chips_main {
  display: flex;
  gap: 12px;
  margin-bottom: 40px;
  margin-top: 10px;
  overflow-x: scroll;
  overflow-y: hidden;
  -ms-overflow-style: none;
  scrollbar-width: none;
}
.chips_main::-webkit-scrollbar { display: none; }

.chips_capsule {
  border: 1px solid #1A1A1A;
  padding: 10px 28px;
  border-radius: 60px;
  cursor: pointer;
}

/* Grid */
.collection-products-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

/* Facts */
.facts_head {
  margin: 0;
  margin-bottom: 12px;
font-weight: 500;
font-size: 26px;
line-height: 150%;
letter-spacing: 4%;
vertical-align: middle;
text-transform: uppercase;

}
.read-more-btn{
  padding: inherit;
    border: navajowhite;
    background: none;
}

.fact-text-wrapper {
  flex: 1;
  overflow: scroll;
}
.fact-text-wrapper {
  overflow: auto;    
  -ms-overflow-style: none; 
  scrollbar-width: none;  
}

.fact-text-wrapper::-webkit-scrollbar {
  display: none;  
}
.fact-text{
  margin: 0;
}
/* Reverse row for odd blocks */
.flex-row-reverse {
  flex-direction: row-reverse;
}

/* Hide 3rd card on desktop */
.collection-products-grid .card_3 {
  display: none;
}

/* View all button (removed inline style) */
.view-all-wrapper {
  max-width: max-content;
    margin: 0 auto;
  margin-top: 20px;
}
.view-all-wrapper a{
  color:#ffffff;
  background-color: #A68380;
  padding: 16px 24px;
font-weight: 500;
font-size: 12px;
line-height: 100%;
letter-spacing: 4%;
text-transform: uppercase;
border-radius: 8px;
}

/* MOBILE */
.facts_mob_main {
  display: none;
}

@media (max-width: 768px) {
  .collection-products-grid .card_3 {
    display: block;
  }

  .collection-row {
    flex-direction: column;
    gap: 20px;
  }

  .collection-left,
  .collection-right {
    width: 100%;
  }

  .collection-right {
    display: none;
  }

  .facts_mob_main {
    display: block;
    margin-bottom: 24px;
    padding: 20px;
    background-color: #fbf3ec;
    border-radius: 12px;
    border: 1px solid #00000033;
  }

  .facts_head_mob {
    margin: 0 0 10px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .collection-products-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>

<div class="page-width">

  <!-- CHIPS -->
  <div class="chips_main">
    {% for block in section.blocks %}
      {% if block.type == 'collection_block' %}
        <div class="chips_capsule"
          onclick="scrollToCollection('{{ block.settings.chips_text | handleize }}')">
          {{ block.settings.chips_text }}
        </div>
      {% endif %}
    {% endfor %}
  </div>

{% assign index = 0 %}

<!-- COLLECTION BLOCKS -->
{% for block in section.blocks %}
  {% assign index = index | plus: 1 %}
  {% assign is_even = index | modulo: 2 %}
  {% if is_even == 0 %}
    {% assign is_even = true %}
  {% else %}
    {% assign is_even = false %}
  {% endif %}

  {% if block.type == 'collection_block' %}

  <div class="collection-row {% if is_even %}flex-row-reverse{% endif %}"
       id="collection-{{ block.settings.chips_text | handleize }}"
       {{ block.shopify_attributes }}>

    <!-- MOBILE FACTS -->
    <div class="facts_mob_main">
      <p class="facts_head_mob">{{ block.settings.fact_heading }}</p>
      <div class="fact-text-wrapper">
        <p class="fact-text" data-full-text="{{ block.settings.fact_text }}">
          {{ block.settings.fact_text | truncate: 120 }}
          <button class="read-more-btn" onclick="toggleReadMore(this)">Read More</button>
        </p>
      </div>
    </div>

    <!-- LEFT PRODUCTS -->
    <div class="collection-left collection-left-inner">

      {% if block.settings.collection %}
        {% assign custom_collection = block.settings.collection.products %}

        <div class="collection-products-grid">
          {% for product in custom_collection limit: 4 %}
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              image_shape: section.settings.image_shape,
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: section.settings.show_vendor,
              show_rating: section.settings.show_rating,
              skip_styles: skip_card_product_styles,
              section_id: section.id,
              quick_add: section.settings.quick_add,
              forloop: forloop
            %}
          {% endfor %}
        </div>

        <div class="view-all-wrapper">
          <a href="{{ block.settings.collection.url }}" class="view-all-btn">
            {{ block.settings.button_text }}
          </a>
        </div>

      {% endif %}
    </div>

    <!-- RIGHT DESKTOP FACTS -->
    <div class="collection-right">
      <p class="facts_head">{{ block.settings.fact_heading }}</p>
      <div class="fact-text-wrapper">
        <p class="fact-text">
          {{ block.settings.fact_text }}
        </p>
      </div>
    </div>

  </div>
  {% endif %}
{% endfor %}

</div>

<script>
/* Mobile Read More */
function toggleReadMore(btn) {
  const p = btn.closest("p");
  const full = p.getAttribute("data-full-text");
  const truncated = full.length > 120 ? full.substring(0, 120) : full;

  if (p.classList.contains("expanded")) {
    p.classList.remove("expanded");
    p.innerHTML = truncated + ' <button class="read-more-btn" onclick="toggleReadMore(this)">Read More</button>';
  } else {
    p.classList.add("expanded");
    p.innerHTML = full + ' <button class="read-more-btn" onclick="toggleReadMore(this)">Read Less</button>';
  }
}

/* Chips Scroll To */
function scrollToCollection(handle) {
  const target = document.getElementById("collection-" + handle);
  if (!target) return;

  const header = document.querySelector(".sticky-header");
  const headerHeight = header ? header.offsetHeight : 0;

  const topPos = target.getBoundingClientRect().top + window.scrollY;

  window.scrollTo({
    top: topPos - headerHeight - 200,
    behavior: "smooth"
  });
}

/* Match Desktop Heights */
function updateFactHeights() {
  if (window.innerWidth <= 768) return;

  document.querySelectorAll('.collection-row').forEach(row => {
    const left = row.querySelector('.collection-products-grid');
    const right = row.querySelector('.collection-right');
    if (left && right) {
      right.style.height = left.offsetHeight + 'px';
    }
  });
}

window.addEventListener('load', updateFactHeights);
window.addEventListener('resize', updateFactHeights);

</script>

{% schema %}
{
  "name": "Custom Collection",
  "settings": [
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image Aspect Ratio",
      "default": "square",
      "options": [
        { "label": "Square", "value": "square" },
        { "label": "Portrait", "value": "portrait" },
        { "label": "Landscape", "value": "landscape" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show secondary image",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating",
      "default": false
    }
  ],

  "blocks": [
    {
      "type": "collection_block",
      "name": "Collection Block",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Select Collection" },
        { "type": "text", "id": "chips_text", "label": "Chips Name" },
        { "type": "text", "id": "button_text", "label": "Button Text" },
        { "type": "text", "id": "fact_heading", "label": "Fact Heading" },
        { "type": "text", "id": "fact_text", "label": "Fact Text" }
      ]
    }
  ],

  "presets": [
    { "name": "Custom Collection" }
  ]
}
{% endschema %}
