{% comment %}
  Featured Collection Section (Minimal) using card-product
{% endcomment %}

{%- assign skip_card_product_styles = false -%}

{{ 'plp-product-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'product-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'template-collection.css' | asset_url | stylesheet_tag: preload: true }}
<link rel="preload" href="{{ 'component-card.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="{{ 'component-card.css' | asset_url }}"></noscript>
{{ 'product-detail.css' | asset_url | stylesheet_tag: preload: true }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag: preload: true }}
{% endif %}

{% unless section.settings.quick_add == 'none' %}
  {{ 'quick-add.css' | asset_url | stylesheet_tag: preload: true }}
{% endunless %}

{% if section.settings.quick_add == 'standard' %}
  <script src="{{ 'quick-add.js' | asset_url }}" defer></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer></script>
{% endif %}

{% if section.settings.quick_add == 'bulk' %}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer></script>
{% endif %}

<style>
.custom-layout-section {
  display: flex;
  gap: 20px;
  align-items: start;
  margin: 0 auto;
}

.left-side { width: 70%; }
.right-side {
  width: 30%;
  display: flex;
  flex-direction: column;
  gap: 20px;
  position: sticky;
  top: 0;
}

.facts_head { margin: 0 0 8px 0; font-weight: 600; }

/* --- FIXED: Show 2 lines before truncation, allow wrapping --- */
.fact-text-wrapper {
  display: flex;
  align-items: flex-start;
  gap: 6px;
}

.fact-text {
  margin: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.8em;
  max-height: 3.6em; /* 2 lines */
  display: block;
}

/* Read More Button */
.read-more-btn {
  background: none;
  border: none;
  color: #000;
  padding: 0;
  cursor: pointer;
  text-decoration: underline;
  font-size: 14px;
}

.text-only-block,
.collection-block {
  padding: 16px;
  border: 1px solid #eee;
  border-radius: 8px;
  background: #fff;
}

.collection-products-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-top: 12px;
}

.view-all-wrapper { text-align: center; margin-top: 16px; }
.view-all-btn {
  display: inline-block;
  padding: 10px 18px;
  background: #000;
  color: #fff;
  border-radius: 6px;
  text-decoration: none;
  font-size: 14px;
}
.view-all-btn:hover { opacity: 0.9; }

.facts_mob_main { display: none; }

@media(max-width: 768px) {
  .custom-layout-section { flex-direction: column; gap: 12px; }
  .left-side { width: 100%; }
  .right-side { display: none; }

  .facts_mob_main {
    display: block;
    margin-bottom: 40px;
    padding: 20px;
    background-color: #FBF3EC;
  }

  .facts_head_mob {
    margin: 0;
    font-weight: 500;
    font-size: 20px;
    line-height: 150%;
    text-transform: uppercase;
  }

  .collection-products-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>

<div class="custom-layout-section custom_facts_collection_brad_{{ section.id }} page-width">
  <div class="left-side">

    {% for block in section.blocks %}
      {% case block.type %}

        {% when 'collection_block' %}
          <div class="collection-block" {{ block.shopify_attributes }}>

            {% if block.settings.collection %}

              <!-- MOBILE FACTS -->
              <div class="facts_mob_main">
                <p class="facts_head_mob">{{ block.settings.text_1 }}</p>

                <div class="fact-text-wrapper">
                  <p class="facts_content_mob fact-text" data-full-text="{{ block.settings.text_2 }}">
                    {{ block.settings.text_2 | truncate: 120 }}
                  </p>
                  <button class="read-more-btn" onclick="toggleReadMore(this)">Read More</button>
                </div>
              </div>

              {% assign custom_collection = block.settings.collection.products %}

              {% if custom_collection.size > 0 %}
                <div class="collection-products-grid">
                  {% for product in custom_collection limit: 4 %}
                    {% render 'card-product',
                      card_product: product,
                      media_aspect_ratio: section.settings.image_ratio,
                      image_shape: section.settings.image_shape,
                      show_secondary_image: section.settings.show_secondary_image,
                      show_vendor: section.settings.show_vendor,
                      show_rating: section.settings.show_rating,
                      skip_styles: skip_card_product_styles,
                      section_id: section.id,
                      quick_add: section.settings.quick_add
                    %}
                  {% endfor %}
                </div>

                <div class="view-all-wrapper">
                  <a href="{{ block.settings.collection.url }}" class="view-all-btn">View more design</a>
                </div>

              {% else %}
                <p class="facts_content">No products found in this collection.</p>
              {% endif %}

            {% endif %}
          </div>

      {% endcase %}
    {% endfor %}
  </div>

  <!-- RIGHT SIDE FACTS BLOCKS -->
  <div class="right-side">
    {% for block in section.blocks %}
      {% case block.type %}

        {% when 'text_block' %}

          <div class="text-only-block_1" {{ block.shopify_attributes }}>
            <p class="facts_head">{{ block.settings.text_1 }}</p>

            <div class="fact-text-wrapper">
              <p class="facts_content fact-text" data-full-text="{{ block.settings.text_2 }}">
                {{ block.settings.text_2 | truncate: 120 }}
              </p>
              <button class="read-more-btn" onclick="toggleReadMore(this)">Read More</button>
            </div>
          </div>

          <div class="text-only-block_2" {{ block.shopify_attributes }}>
            <p class="facts_head">{{ block.settings.text_3 }}</p>

            <div class="fact-text-wrapper">
              <p class="facts_content fact-text" data-full-text="{{ block.settings.text_4 }}">
                {{ block.settings.text_4 | truncate: 120 }}
              </p>
              <button class="read-more-btn" onclick="toggleReadMore(this)">Read More</button>
            </div>
          </div>

          <div class="text-only-block_3" {{ block.shopify_attributes }}>
            <p class="facts_head">{{ block.settings.text_5 }}</p>

            <div class="fact-text-wrapper">
              <p class="facts_content fact-text" data-full-text="{{ block.settings.text_6 }}">
                {{ block.settings.text_6 | truncate: 120 }}
              </p>
              <button class="read-more-btn" onclick="toggleReadMore(this)">Read More</button>
            </div>
          </div>

          <div class="text-only-block_4" {{ block.shopify_attributes }}>
            <p class="facts_head">{{ block.settings.text_7 }}</p>

            <div class="fact-text-wrapper">
              <p class="facts_content fact-text" data-full-text="{{ block.settings.text_8 }}">
                {{ block.settings.text_8 | truncate: 120 }}
              </p>
              <button class="read-more-btn" onclick="toggleReadMore(this)">Read More</button>
            </div>
          </div>

      {% endcase %}
    {% endfor %}
  </div>
</div>

<script>
function toggleReadMore(btn) {
  const p = btn.previousElementSibling;
  const full = p.getAttribute("data-full-text");
  const truncated = full.length > 120 ? full.substring(0, 120) + "…" : full;

  if (p.classList.contains("expanded")) {
    p.classList.remove("expanded");
    p.style.maxHeight = "3.6em";
    p.textContent = truncated;
    btn.textContent = "Read More";
  } else {
    p.classList.add("expanded");
    p.style.maxHeight = "none";
    p.textContent = full;
    btn.textContent = "Read Less";
  }
}

document.addEventListener('DOMContentLoaded', function () {
  const header = document.querySelector('header');
  const stickyElm = document.querySelector('.right-side');

  function updateTop() {
    if (!header || !stickyElm) return;
    stickyElm.style.top = header.offsetHeight + "px";
  }

  updateTop();
  window.addEventListener('scroll', updateTop);
  window.addEventListener('resize', updateTop);
});
</script>

{% schema %}
{
  "name": "Custom Collection",
  "settings": [
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image Aspect Ratio",
      "default": "square",
      "options": [
        { "label": "Square", "value": "square" },
        { "label": "Portrait", "value": "portrait" },
        { "label": "Landscape", "value": "landscape" }
      ]
    },
    {
      "type": "select",
      "id": "image_shape",
      "label": "Image Shape",
      "default": "default",
      "options": [
        { "label": "Default", "value": "default" },
        { "label": "Rounded", "value": "rounded" },
        { "label": "Blob", "value": "blob" }
      ]
    },
    {
      "type": "select",
      "id": "quick_add",
      "label": "Quick add type",
      "default": "none",
      "options": [
        { "label": "None", "value": "none" },
        { "label": "Standard", "value": "standard" },
        { "label": "Bulk", "value": "bulk" }
      ]
    },
    { "type": "checkbox", "id": "show_secondary_image", "label": "Show secondary image", "default": false },
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": false },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating", "default": false }
  ],

  "blocks": [
    {
      "type": "collection_block",
      "name": "Collection Block",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Select Collection" },
        { "type": "text", "id": "text_1", "label": "Facts Heading (Mobile)" },
        { "type": "text", "id": "text_2", "label": "Facts Content (Mobile)" }
      ]
    },

    {
      "type": "text_block",
      "name": "Text Only Block",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text_1", "label": "Facts Heading" },
        { "type": "text", "id": "text_2", "label": "Facts Content" },
        { "type": "text", "id": "text_3", "label": "Facts Heading" },
        { "type": "text", "id": "text_4", "label": "Facts Content" },
        { "type": "text", "id": "text_5", "label": "Facts Heading" },
        { "type": "text", "id": "text_6", "label": "Facts Content" },
        { "type": "text", "id": "text_7", "label": "Facts Heading" },
        { "type": "text", "id": "text_8", "label": "Facts Content" }
      ]
    }
  ],

  "presets": [
    { "name": "Custom Collection" }
  ]
}
{% endschema %}
