<style>
.jewelry-care-section_img_text {
    max-width: 1180px !important;
  }

  .jewelry-care-text {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .headings_main {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .heading_img_text_tips {
    font-weight: 500;
    font-size: 24px;
    letter-spacing: 4%;
    text-transform: uppercase;
    color: #1A1A1A;
    margin: 0;
  }

  .sub_heading_img_text_tips {
    font-weight: 400;
    font-size: 18px;
    line-height: 24px;
    letter-spacing: 4%;
    color: #1A1A1A;
    margin: 0;
  }

  .jewelry-care-text ul li {
    font-weight: 400;
    font-size: 18px;
    line-height: 24px;
    letter-spacing: 4%;
    color: #1A1A1A;
    margin: 0;
  }

  .jewelry-care-wrapper {
    display: flex;
    flex-direction: row;
    gap: 40px;
    justify-content: center;
    margin: auto;
  }

  .jewelry-care-text ul {
    margin: 0;
    padding-left: 18px;
  }

  .jewelry-care-wrapper.reverse {
    flex-direction: row-reverse;
  }

  .jewelry-care-text {
    flex: 1;
  }

  .jewelry-care-image {
    flex: 1;
  }

  .jewelry-care-image video {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 6px;
  }
 .jewelry-care-section_img_text {
      margin-top: {{ section.settings.margin_top_desktop }}px !important;
      margin-bottom: {{ section.settings.margin_bottom_desktop }}px !important;
    }
  @media screen and (max-width: 768px) {
    .jewelry-care-section_img_text {
      margin-top: {{ section.settings.margin_top_mobile }}px !important;
      margin-bottom: {{ section.settings.margin_bottom_mobile }}px !important;
    }

    .heading_img_text_tips {
      font-size: 18px;
    }

    .sub_heading_img_text_tips {
      font-size: 12px;
    }

    .jewelry-care-text ul li {
      font-size: 12px;
    }

    .jewelry-care-wrapper.reverse,
    .jewelry-care-wrapper {
      flex-direction: column-reverse;
      gap: 0;
    }
  }
</style>

<div class="jewelry-care-section_img_text page-width">
  <div class="jewelry-care-wrapper{% if section.settings.video_position == 'left' %} reverse{% endif %}">
   {% if section.settings.video %}
  <div class="jewelry-care-image">
    <div class="jewelry-care-image">
    {{ section.settings.video | video_tag: controls: true, autoplay: true, loop: true, muted: true, playsinline: true }}
  </div>
  </div>
{% endif %}

    <div class="jewelry-care-text">
      <div class="headings_main">
        <p class="heading_img_text_tips">{{ section.settings.heading }}</p>
        <p class="sub_heading_img_text_tips">{{ section.settings.sub_heading }}</p>
      </div>
      {{ section.settings.paragraph }}
    </div>
  </div>
</div>



{% schema %}
{
  "name": "Tips Video With Text",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Daily Jewelry Care Tips"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading",
      "default": "A little care goes a long way in keeping your jewelry radiant!"
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "Points"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "select",
      "id": "video_position",
      "label": "Video Position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "margin_top_desktop",
      "label": "Margin Top (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "label": "Margin Bottom (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Margin Top (Mobile)",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Margin Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Tips Video With Text"
    }
  ]
}
{% endschema %}
