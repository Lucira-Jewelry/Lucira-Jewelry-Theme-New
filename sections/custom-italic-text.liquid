{% schema %}
{
  "name": "Custom Italic Text",
  "settings": [
    {
      "type": "text",
      "id": "quote_text",
      "label": "Quote Text",
      "default": "\"A masterpiece blooms in patience – each step crafted with intention, until brilliance finally meets your hands.\""
    },
    {
      "type": "range",
      "id": "margin_top_desktop",
      "label": "Margin Top (Desktop)",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "label": "Margin Bottom (Desktop)",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Margin Top (Mobile)",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Margin Bottom (Mobile)",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Custom Italic Text"
    }
  ]
}
{% endschema %}

<section 
  class="quote-section quote-section-{{ section.id }}"
  style="
    margin-top: {{ section.settings.margin_top_desktop }}px;
    margin-bottom: {{ section.settings.margin_bottom_desktop }}px;
  "
>
  <div class="quote-wrapper page-width">
    <p class="quote-text">{{ section.settings.quote_text }}</p>
  </div>
</section>

<style>
  .quote-section-{{ section.id }} .quote-wrapper {
    width: 100%;
    text-align: center;
  }

  .quote-section-{{ section.id }} .quote-text {
    max-width: 850px;
    margin: 0 auto;
font-weight: 400;
font-size: 32px;
line-height: 150%;
letter-spacing: 4.4px;
text-align: center;
vertical-align: middle;
font-style: italic;
color: #1A1A1A;
  }

  /* Mobile spacing overrides */
  @media screen and (max-width: 767px) {
    .quote-section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top_mobile }}px !important;
      margin-bottom: {{ section.settings.margin_bottom_mobile }}px !important;
    }

    .quote-section-{{ section.id }} .quote-text {
font-size: 20px;

    }
  }
</style>
