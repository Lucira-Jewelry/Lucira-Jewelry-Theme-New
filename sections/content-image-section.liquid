{% schema %}
{
  "name": "Contact Us Section",
  "settings": [
    {
      "type": "text",
      "id": "contheading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "textarea",
      "id": "contdescription",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    },
    {
      "type": "text",
      "id": "contphone",
      "label": "Phone Number",
      "default": "+91 9004430602"
    },
    {
      "type": "text",
      "id": "contemail",
      "label": "Email Address",
      "default": "support@vicingjewelry.com"
    },
    {
      "type": "text",
      "id": "contaddress",
      "label": "Address",
      "default": "Unit No. 305, B28 Centre Cabin A, Modal Industrial Estate, Oshiwara, Jogeshwari, Mumbai - 400064"
    },
    {
      "type": "image_picker",
      "id": "contact_image",
      "label": "Right Side Image"
    }
  ],
  "presets": [
    {
      "name": "Contact Us Section"
    }
  ]
}
{% endschema %}

<div id="brad-contact-section" class="brad-contact-section page-width">
  <div class="brad-contact-grid">
    <div class="brad-contact-info">
      <h2><span class="brad-highlight">{{ section.settings.contheading }}</span></h2>
      <p class="brad-description">{{ section.settings.contdescription }}</p>

      <div class="brad-contact-details">

        <!-- Phone -->
        <div class="brad-detail">
          <div class="brad-label">CALL US</div>
          <div class="brad-inline">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24">
              <path d="M20.9994 16.4765V19.1862C21.0005 19.4377 20.9488 19.6867 20.8479 19.9172C20.7469 20.1477 20.5988 20.3546 20.413 20.5247C20.2273 20.6947 20.008 20.8242 19.7693 20.9048C19.5305 20.9854 19.2775 21.0153 19.0265 20.9927C16.2415 20.6907 13.5664 19.7409 11.216 18.2197C9.02929 16.8329 7.17534 14.9827 5.7858 12.8003C4.25627 10.4439 3.30442 7.76107 3.00735 4.96915C2.98473 4.71938 3.01447 4.46764 3.09468 4.22996C3.17489 3.99229 3.30381 3.77389 3.47323 3.58866C3.64265 3.40343 3.84885 3.25544 4.07872 3.15411C4.30858 3.05278 4.55707 3.00032 4.80837 3.00009H7.52347C7.96269 2.99577 8.3885 3.151 8.72152 3.43683C9.05455 3.72267 9.27207 4.11961 9.33354 4.55366C9.44814 5.42084 9.66067 6.27229 9.96707 7.09177C10.0888 7.41507 10.1152 7.76642 10.043 8.1042C9.97082 8.44198 9.80313 8.75203 9.5598 8.99761L8.41041 10.1447C9.69877 12.406 11.5748 14.2784 13.8406 15.5642L14.99 14.4171C15.2361 14.1742 15.5467 14.0069 15.8852 13.9348C16.2236 13.8628 16.5757 13.8891 16.8996 14.0106C17.7207 14.3164 18.5739 14.5285 19.4428 14.6429C19.8824 14.7048 20.2839 14.9258 20.5709 15.2639C20.858 15.6019 21.0105 16.0335 20.9994 16.4765Z" stroke="#666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{{ section.settings.contphone }}</span>
          </div>
        </div>

        <!-- Email -->
        <div class="brad-detail">
          <div class="brad-label">MAIL US</div>
          <div class="brad-inline">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24">
              <path d="M22 7L13.009 12.727C12.7039 12.9042 12.3573 12.9976 12.0045 12.9976C11.6517 12.9976 11.3051 12.9042 11 12.727L2 7" stroke="#666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M20 4H4C2.89543 4 2 4.89543 2 6V18C2 19.1046 2.89543 20 4 20H20C21.1046 20 22 19.1046 22 18V6C22 4.89543 21.1046 4 20 4Z" stroke="#666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{{ section.settings.contemail }}</span>
          </div>
        </div>

        <!-- Address -->
        <div class="brad-detail">
          <div class="brad-label">VISIT US</div>
          <div class="brad-inline">
            <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/location_on_1.svg?v=1757675565" height="24px" width="24px" title="content-image" style="position:relative">
            <span>{{ section.settings.contaddress }}</span>
          </div>
        </div>

      </div>
    </div>

    <div class="brad-contact-image">
      {% if section.settings.contact_image != blank %}
        <img src="{{ section.settings.contact_image | img_url: '900x' }}" alt="Contact Image" title="Contact Image" class="brad-image">
      {% endif %}
    </div>
  </div>
</div>

<style>
#brad-contact-section{margin:50px 0}
.brad-contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center}
.brad-contact-info h2{font-size:28px;margin-bottom:12px}
.brad-highlight{padding:2px 0}
.brad-description{margin-bottom:20px;color:#555}
.brad-contact-details{display:flex;flex-direction:column;gap:20px}
.brad-detail{display:flex;flex-direction:column;gap:6px}
.brad-label{font-size:14px;color:#000}
.brad-inline{display:flex;align-items:flex-start;gap:8px;color:#333;font-size:14px;line-height:1.6}
.brad-contact-image .brad-image{width:100%;border-radius:5px;object-fit:cover}
@media(max-width:768px){
.brad-contact-grid{grid-template-columns:1fr}
.brad-contact-info h2{margin-top:0}
.brad-description{margin-top:12px;margin-bottom:24px;color:#555}
}
</style>
