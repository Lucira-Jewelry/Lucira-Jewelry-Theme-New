{% schema %}
{
  "name": "On The Move Section",
  "settings": [
    {
      "type": "collection",
      "id": "target_collection",
      "label": "Target Collection",
      "info": "Select the collection where this section should appear on product pages"
    },
    {
      "type": "text",
      "id": "on_the_move_subheading",
      "label": "Subheading",
      "default": "ON THE MOVE"
    },
    {
      "type": "text",
      "id": "on_the_move_heading",
      "label": "Heading",
      "default": "for them who wanna stay in motion"
    },
    {
      "type": "richtext",
      "id": "on_the_move_text",
      "label": "Text",
      "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip consequat.</p>"
    }
  ],
  "presets": [
    {
      "name": "On The Move Section (Collection Products)"
    }
  ]
}
{% endschema %}

{%- assign target_collection = section.settings.target_collection -%}
{%- assign product_collections = product.collections -%}

{% comment %} Check if product belongs to target collection {% endcomment %}
{%- assign show_section = false -%}
{% for collection in product_collections %}
  {% if collection.handle == collections[target_collection].handle %}
    {% assign show_section = true %}
    {% break %}
  {% endif %}
{% endfor %}

{% if show_section %}
  <section class="on-the-move-banner">
    <div class="page-width">
        <div class="on-the-move-banner-wrapper">
            <div class="on-the-move-content-wrap">
              {% if section.settings.on_the_move_subheading != blank %}
                <h4>{{ section.settings.on_the_move_subheading }}</h4>
              {% endif %}
              {% if section.settings.on_the_move_heading != blank %}
                <h2>{{ section.settings.on_the_move_heading }}</h2>
              {% endif %}
              {% if section.settings.on_the_move_text != blank %}
                <div>{{ section.settings.on_the_move_text }}</div>
              {% endif %}
            </div>
        </div>
    </div>
  </section>
  <style>
  html {
    scroll-behavior: smooth;
  }
.on-the-move-banner-wrapper{background:url(https://cdn.shopify.com/s/files/1/0739/8516/3482/files/PDP-Banner-Web_N.jpg?v=1750322494);height:710px;background-size:100%;background-repeat:no-repeat;padding:70px 80px 70px;position:relative;overflow:hidden}
.on-the-move-banner-wrapper{border-radius:12px}
.on-the-move-content-wrap{height:auto;position:absolute;top:70px;left:80px;right:80px;transition:transform .1s ease-out}
.on-the-move-banner-wrapper h4{font-family:Futura;font-weight:400;font-size:18px;line-height:20px;text-align:left;vertical-align:middle;text-transform:uppercase;margin-bottom:14px;color:#fff;margin-top:0}
.on-the-move-banner-wrapper h2{font-family:Futura;font-weight:400;font-size:32px;line-height:20px;text-transform:uppercase;margin-top:8px;color:#fff;text-align:left;margin-bottom:36px}
.on-the-move-banner-wrapper p{font-family:Futura;text-align:left;font-weight:400;font-size:16px;line-height:24px;vertical-align:middle;color:#fff;max-width:620px;margin-top:20px}
.on-the-move-banner{padding:60px 0 0 0}

  @media only screen and (min-width:1024px) and (max-width:1600px){
    .on-the-move-banner-wrapper h2 { font-weight: 400; font-size: 32px; line-height: 1.4; text-transform: uppercase; margin-top: 10px; max-width: 535px; }
    .on-the-move-banner-wrapper p {margin-top: 22px; max-width: 470px; }
    .on-the-move-banner-wrapper {padding: 20px 80px 20px;}
    .on-the-move-banner-wrapper {height: 480px;}
    .on-the-move-content-wrap { top: 20px; left: 80px; right: 80px; }
    .on-the-move-banner-wrapper h2 {    margin-bottom: 20px;}
  }

  @media only screen and (min-width:1500px) and (max-width:1679px){
    .on-the-move-banner-wrapper {height: 570px;}
  }

  @media only screen and (min-width:1680px) and (max-width:1800px){
    .on-the-move-banner-wrapper {height: 660px;}
  }

  @media only screen and (min-width:1680px) and (max-width:1800px){
    .on-the-move-banner-wrapper {background-size: 100%;}
    .on-the-move-banner-wrapper {height: 615px;}
  }

   @media only screen and (min-width:1801px) and (max-width:2100px){
     .on-the-move-banner-wrapper h4 {margin-bottom: 30px;}
     .on-the-move-banner-wrapper {height: 665px;}
   }

  @media only screen and (min-width:1024px) and (max-width:1199px){
    .on-the-move-banner-wrapper { height: 440px; }
  }

  @media only screen and (min-width:0px) and (max-width:767px){
    .on-the-move-banner-wrapper p {font-family: 'Futura'; font-weight: 400; font-size: 18px; line-height: 1.6; margin-top: 6px;}
    .on-the-move-banner-wrapper { background: url(https://cdn.shopify.com/s/files/1/0739/8516/3482/files/PDP-Banner-Mob_N.jpg?v=1750322495); height: 490px; background-size: 100%; background-repeat: no-repeat; padding: 2px 22px 20px; }
    .on-the-move-banner-wrapper h4 {margin-top: 0px; margin-bottom: 8px; color: #FFFFFF; font-family: 'Futura'; font-weight: 400; font-size: 12px; line-height: 20px; vertical-align: middle; text-transform: uppercase; }
    .on-the-move-banner-wrapper h2 { color: #FFFFFF; margin: 0; margin-bottom: 8px; font-family: 'Futura'; font-weight: 400; font-size: 18px; line-height: 1.6; text-transform: uppercase; }
    .on-the-move-banner-wrapper p { font-weight: 400; color: #ffffff; max-width: 620px; margin-top: 6px; font-family: 'Futura'; font-size: 12px; line-height: 16px; vertical-align: middle; }
    .on-the-move-content-wrap { top: 18px; left: 22px; right: 22px; }
    .on-the-move-content-wrap { top: 20px; transform: translateY(0) ! IMPORTANT; left: 22px; right: 22px; }
  }
  @media only screen and (min-width:0px) and (max-width:380px){
    .on-the-move-banner-wrapper {height: 400px;}
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Only run this effect on screens wider than 1024px
    if (window.innerWidth <= 1024) return;

    const section = document.querySelector('.on-the-move-banner-wrapper');
    const content = document.querySelector('.on-the-move-content-wrap');
    
    // Get initial measurements
    const contentHeight = content.offsetHeight;
    const sectionHeight = section.offsetHeight;
    const paddingTop = parseInt(window.getComputedStyle(section).paddingTop);
    const paddingBottom = parseInt(window.getComputedStyle(section).paddingBottom);
    
    // Calculate the available space for movement
    const availableSpace = sectionHeight - contentHeight - paddingTop - paddingBottom;
    
    // Only apply the effect if there's space to move (content is smaller than section)
    if (availableSpace > 0) {
        let lastScrollPosition = 0;
        let ticking = false;
        
        function updateContentPosition(scrollPos) {
            const sectionTop = section.offsetTop;
            const sectionBottom = sectionTop + sectionHeight;
            const viewportHeight = window.innerHeight;
            
            // Calculate how much of the section is visible (0 when above viewport, 1 when fully in view)
            const visibleRatio = Math.min(
                Math.max(
                    (scrollPos + viewportHeight - sectionTop) / (viewportHeight + sectionHeight),
                    0
                ),
                1
            );
            
            // Calculate the translateY position
            const translateY = visibleRatio * availableSpace;
            
            // Apply the transformation
            content.style.transform = `translateY(${translateY}px)`;
            content.style.willChange = 'transform';
        }
        
        window.addEventListener('scroll', function() {
            lastScrollPosition = window.scrollY;
            
            if (!ticking) {
                window.requestAnimationFrame(function() {
                    updateContentPosition(lastScrollPosition);
                    ticking = false;
                });
                ticking = true;
            }
        });
        
        // Initialize position
        updateContentPosition(window.scrollY);
    } else {
        // If content is taller than section, pin it to top
        content.style.transform = 'translateY(0)';
    }
});
</script>

{% endif %}

