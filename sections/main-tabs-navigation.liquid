{% comment %}
  Section: Main Tabs Navigation
  First layer: Engagement, Wedding, Jewelry, etc.
{% endcomment %}

{% assign main_tabs = metaobjects.category_page.values %}

<style>
  .main-tabs-navigation {
    background: #f8f8f8;
    padding: 1rem 0;
    border-bottom: 2px solid #eee;
  }
  
  .main-tabs-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    gap: 2rem;
    overflow-x: auto;
  }
  
  .main-tab-link {
    padding: 0.75rem 1.5rem;
    background: white;
    border: 2px solid #ddd;
    border-radius: 25px;
    color: #333;
    text-decoration: none;
    font-weight: 500;
    white-space: nowrap;
    transition: all 0.3s ease;
  }
  
  .main-tab-link:hover {
    border-color: #b8860b;
    color: #b8860b;
  }
  
  .main-tab-link.active {
    background: #b8860b;
    border-color: #b8860b;
    color: white;
  }
</style>

<div class="main-tabs-navigation">
  <div class="main-tabs-container">
    {% for category in main_tabs %}
      <a 
        href="/pages/{{ category.system.handle }}" 
        class="main-tab-link {% if page.handle == category.system.handle %}active{% endif %}"
      >
        {{ category.title }}
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Main Tabs Navigation",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "Main Tabs Navigation"
    }
  ]
}
{% endschema %}