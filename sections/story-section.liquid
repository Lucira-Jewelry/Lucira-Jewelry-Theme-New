{% comment %} Solitaire Story Section {% endcomment %}

<section class="solitaire-story-section lucira-wc-section" id="solitaire-story-{{ section.id }}">
  <div class="solitaire-page-width">
    <div class="solitaire-heading-wrapper">
      {% if section.settings.heading != blank %}
        <h2 class="solitaire-heading lucira-wc-header">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
        <p class="solitaire-subtext lucira-wc-subheader">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    <div class="solitaire-story-wrapper">
      <div class="solitaire-grid-row">
        {% for block in section.blocks %}
          {% if block.type == 'ring_item' %}
            <div class="solitaire-grid-column" {{ block.shopify_attributes }}>
              <div class="solitaire-story-item">
                <div class="solitaire-image-wrapper">
                  {% if block.settings.ring_image != blank %}
                    <img
                      src="{{ block.settings.ring_image | image_url: width: 400 }}"
                      alt="{{ block.settings.ring_name | escape }}"
                      width="400"
                      height="400"
                      loading="lazy"
                      class="solitaire-ring-image"
                    >
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'solitaire-placeholder-svg' }}
                  {% endif %}
                </div>


                <div class="solitaire-item-details">
                  {% if block.settings.ring_name != blank %}
                    <h3 class="solitaire-ring-name">{{ block.settings.ring_name }}</h3>
                  {% endif %}
                  {% if block.settings.carat_range != blank %}
                    <p class="solitaire-carat-range">{{ block.settings.carat_range }}</p>
                  {% endif %}
                  {% if block.settings.link != blank %}
                    <a href="{{ block.settings.link }}" class="solitaire-item-link" aria-label="{{ block.settings.ring_name }}">
                      <span>{{ block.settings.link_label | default: 'Shop Now' }}</span>
                    </a>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  .solitaire-story-item { background: #fff; padding: 10px 0; border-radius: 8px; }
  /* ─── Section Wrapper ─────────────────────────────────────────── */
  #solitaire-story-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
  }

  #solitaire-story-{{ section.id }} .solitaire-page-width {
    max-width: {{ section.settings.max_width }}px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 24px;
    padding-right: 24px;
  }

  /* ─── Heading Block ───────────────────────────────────────────── */
  #solitaire-story-{{ section.id }} .solitaire-heading-wrapper {
    text-align: center;
    max-width: 640px;
    margin: 0 auto {{ section.settings.heading_gap }}px;
  }

  /* ─── Grid ────────────────────────────────────────────────────── */
  #solitaire-story-{{ section.id }} .solitaire-grid-row {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ section.settings.column_gap }}px;
    align-items: end;
    position: relative;
  }

  /* ─── Grid Column ─────────────────────────────────────────────── */
  #solitaire-story-{{ section.id }} .solitaire-grid-column {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ─── Story Item ──────────────────────────────────────────────── */
  #solitaire-story-{{ section.id }} .solitaire-story-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    text-align: center;
  }

  /* ─── Image Wrapper ───────────────────────────────────────────── */
  #solitaire-story-{{ section.id }} .solitaire-image-wrapper {
    width: 100%;
    max-width: {{ section.settings.image_max_width }}px;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  #solitaire-story-{{ section.id }} .solitaire-ring-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: transform 0.4s ease;
  }

  #solitaire-story-{{ section.id }} .solitaire-story-item:hover .solitaire-ring-image {
    transform: translateY(-6px) scale(1.03);
  }

  #solitaire-story-{{ section.id }} .solitaire-placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.25;
  }

  /* ─── Item Details ────────────────────────────────────────────── */
  #solitaire-story-{{ section.id }} .solitaire-item-details {
    padding-top: {{ section.settings.details_padding_top }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  #solitaire-story-{{ section.id }} .solitaire-ring-name {
    font-family: {{ section.settings.heading_font.family }}, serif;
    font-size: clamp(11px, 1vw, {{ section.settings.name_size }}px);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    margin: 0;
  }

  #solitaire-story-{{ section.id }} .solitaire-carat-range {
    font-size: clamp(10px, 0.85vw, {{ section.settings.carat_size }}px);
    color: {{ section.settings.carat_color }};
    margin: 0;
    letter-spacing: 0.05em;
  }

  #solitaire-story-{{ section.id }} .solitaire-item-link {
    display: inline-block;
    margin-top: 6px;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ section.settings.link_color }};
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s ease;
  }

  #solitaire-story-{{ section.id }} .solitaire-item-link:hover {
    opacity: 0.65;
  }

  @media (max-width: 900px) {
    #solitaire-story-{{ section.id }} .solitaire-grid-row {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px 16px;
    }
  }

  @media (max-width: 540px) {
    #solitaire-story-{{ section.id }} .solitaire-grid-row {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 12px;
    }
    #solitaire-story-{{ section.id }} .solitaire-page-width {
      padding-left: 16px;
      padding-right: 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Solitaire Story",
  "tag": "section",
  "class": "solitaire-story-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Solitaire Story"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Section max width (px)",
      "min": 800,
      "max": 1600,
      "step": 40,
      "default": 1200
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 16
    },
    {
      "type": "range",
      "id": "image_max_width",
      "label": "Image max width (px)",
      "min": 80,
      "max": 320,
      "step": 10,
      "default": 200
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section padding top (px)",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section padding bottom (px)",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "heading_gap",
      "label": "Heading to grid gap (px)",
      "min": 16,
      "max": 100,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "details_padding_top",
      "label": "Details padding top (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 12
    },
    {
      "type": "header",
      "content": "Connector Line"
    },
    {
      "type": "range",
      "id": "connector_height",
      "label": "Connector line area height (px)",
      "min": 10,
      "max": 60,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "connector_bottom_offset",
      "label": "Horizontal line bottom offset (px)",
      "min": 40,
      "max": 200,
      "step": 4,
      "default": 100
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Horizontal line color",
      "default": "#C9A84C"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Connector dot color",
      "default": "#C9A84C"
    },
    {
      "type": "header",
      "content": "Typography & Colors"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size (px)",
      "min": 14,
      "max": 48,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "subtext_size",
      "label": "Subtext font size (px)",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "name_size",
      "label": "Ring name font size (px)",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "carat_size",
      "label": "Carat range font size (px)",
      "min": 9,
      "max": 18,
      "step": 1,
      "default": 12
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FEF5F1"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading & name color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "carat_color",
      "label": "Carat range color",
      "default": "#888888"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#1A1A1A"
    }
  ],
  "blocks": [
    {
      "type": "ring_item",
      "name": "Ring Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "ring_image",
          "label": "Ring image"
        },
        {
          "type": "text",
          "id": "ring_name",
          "label": "Ring name",
          "default": "Spark"
        },
        {
          "type": "text",
          "id": "carat_range",
          "label": "Carat range",
          "default": "0.25 ct – 0.40 ct"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Shop Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Solitaire Story",
      "blocks": [
        {
          "type": "ring_item",
          "settings": {
            "ring_name": "Spark",
            "carat_range": "0.25 ct – 0.40 ct"
          }
        },
        {
          "type": "ring_item",
          "settings": {
            "ring_name": "Rise",
            "carat_range": "0.40 ct – 0.75 ct"
          }
        },
        {
          "type": "ring_item",
          "settings": {
            "ring_name": "Presence",
            "carat_range": "0.75 ct – 1.25 ct"
          }
        },
        {
          "type": "ring_item",
          "settings": {
            "ring_name": "Legacy",
            "carat_range": "1.25+ ct"
          }
        }
      ]
    }
  ]
}
{% endschema %}
