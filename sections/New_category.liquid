<div class="categories-lazy" data-categories>
  <div class="categories-skeleton">
    {% for i in (1..12) %}
      <div class="skeleton-card"></div>
    {% endfor %}
  </div>

  <div class="categories-content" style="display:none">
    <!-- REMOVED ALL PRELOAD TAGS - They were causing early loading -->
    
    <div class="categories-section page-width">
      {% comment %} Better SEO: Use visible H1 or move to main page context {% endcomment %}
      <div class="visually-hidden">
        <h1>Lucira Jewelry - Official Lab Grown Diamond Jewelry in India</h1>
      </div>

      {% if section.settings.category_heading != blank %}
        <h2 class="categories-heading">{{ section.settings.category_heading }}</h2>
      {% endif %}
      
      {% if section.settings.category_subheading != blank %}
        <p class="categories-subheading">{{ section.settings.category_subheading }}</p>
      {% endif %}

      <div class="categories-grid">
        {% for block in section.blocks %}
          {% liquid
            assign desktop_img = block.settings.category_image_desktop
            assign mobile_img = block.settings.category_image_mobile
            assign placeholder_svg = 'image' | placeholder_svg_tag: 'category-image-placeholder'
          %}
          
          <div class="category-card" data-block-id="{{ block.id }}" data-category-index="{{ forloop.index0 }}">
            {% if block.settings.link != blank %}
              <a
                href="{{ block.settings.link }}"
                class="category-link"
                data-category-title="{{ block.settings.title | escape }}"
                data-category-link="{{ block.settings.link }}"
                data-block-id="{{ block.id }}"
                aria-label="Shop {{ block.settings.title }}"
              >
            {% endif %}

            <div class="category-image-wrapper">
              {% comment %} Lazy placeholder first {% endcomment %}
              <div class="category-image-placeholder">
                {{ placeholder_svg }}
              </div>
              
              {% comment %} Actual images with data-src for lazy loading {% endcomment %}
              <picture class="category-picture" style="display: none;">
                {% if mobile_img %}
                  <source
                    media="(max-width: 767px)"
                    data-srcset="{{ mobile_img | img_url: '300x420', crop: 'center' }} 300w,
                                {{ mobile_img | img_url: '150x210', crop: 'center' }} 150w"
                    data-sizes="(max-width: 767px) 33vw, 300px"
                  >
                {% endif %}
                
                {% if desktop_img %}
                  <source
                    media="(min-width: 768px)"
                    data-srcset="{{ desktop_img | img_url: '400x560', crop: 'center' }} 400w,
                                {{ desktop_img | img_url: '300x420', crop: 'center' }} 300w,
                                {{ desktop_img | img_url: '200x280', crop: 'center' }} 200w"
                    data-sizes="(min-width: 1600px) 300px, (min-width: 1000px) 16.5vw, (min-width: 768px) 30vw, 33vw"
                  >
                  
                  <img
                    class="category-image"
                    src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 400 560'%3E%3C/svg%3E"
                    data-src="{{ desktop_img | img_url: '400x560', crop: 'center' }}"
                    alt="{{ block.settings.title | escape }}"
                    width="400"
                    height="560"
                    loading="lazy"
                    decoding="async"
                  >
                {% endif %}
              </picture>
            </div>

            <span class="category-title">{{ block.settings.title }}</span>
            <span class="shop-now-text desktop-only" aria-hidden="true">Shop Now</span>

            {% if block.settings.link != blank %}
              </a>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
  /* ===== Categories Lazy Load Container ===== */
  .categories-lazy {
    position: relative;
    min-height: 300px;
  }
  
  /* ===== Skeleton Loading Styles ===== */
  .categories-skeleton {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    animation: fadeIn 0.3s ease;
  }
  
  .skeleton-card {
    width: 16.5%;
    min-width: 150px;
    aspect-ratio: 5 / 7;
    border-radius: 8px;
    background: linear-gradient(
      90deg,
      #f0f0f0 25%,
      #f8f8f8 37%,
      #f0f0f0 63%
    );
    background-size: 400% 100%;
    animation: shimmer 1.4s ease infinite;
  }
  
  @keyframes shimmer {
    0% { background-position: 100% 0; }
    100% { background-position: -100% 0; }
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  /* ===== Image Loading States ===== */
  .category-image-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #f8f8f8;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.3s ease;
  }
  
  .category-image-placeholder svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }
  
  .category-picture {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .category-picture.loaded {
    opacity: 1;
  }
  
  .category-picture.loaded + .category-image-placeholder {
    opacity: 0;
    pointer-events: none;
  }
  
  .category-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease, border-radius 0.5s ease;
    will-change: transform;
  }
  
  /* ===== Original Categories Styles ===== */
  .categories-content {
    animation: fadeIn 0.4s ease;
  }
  
  /* Accessibility helper */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
  
  /* Main container */
  .categories-section {
    text-align: center;
    margin: 0 auto;
    padding: 40px 0 0;
  }
  
  .categories-section.page-width {
    padding-left: 0;
    padding-right: 0;
  }
  
  /* Typography */
  .categories-heading {
    margin: 0;
    font-weight: 500;
    font-size: 24px;
    line-height: 1.5;
    text-align: center;
    text-transform: uppercase;
    color: #1a1a1a;
  }
  
  .categories-subheading {
    margin: 0 0 40px;
    font-size: 18px;
    color: #666;
    line-height: 1.9;
  }
  
  /* Grid layout */
  .categories-grid {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  
  /* Category card */
  .category-card {
    width: 16.5%;
    position: relative;
    min-width: 150px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  
  .category-card.loaded {
    opacity: 1;
    transform: translateY(0);
  }
  
  /* Staggered animation for cards */
  .category-card:nth-child(1) { transition-delay: 0.1s; }
  .category-card:nth-child(2) { transition-delay: 0.15s; }
  .category-card:nth-child(3) { transition-delay: 0.2s; }
  .category-card:nth-child(4) { transition-delay: 0.25s; }
  .category-card:nth-child(5) { transition-delay: 0.3s; }
  .category-card:nth-child(6) { transition-delay: 0.35s; }
  .category-card:nth-child(7) { transition-delay: 0.4s; }
  .category-card:nth-child(8) { transition-delay: 0.45s; }
  .category-card:nth-child(9) { transition-delay: 0.5s; }
  .category-card:nth-child(10) { transition-delay: 0.55s; }
  .category-card:nth-child(11) { transition-delay: 0.6s; }
  .category-card:nth-child(12) { transition-delay: 0.65s; }
  
  .category-link {
    display: block;
    position: relative;
    text-decoration: none;
  }
  
  /* Image wrapper with aspect ratio for CLS prevention */
  .category-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 7;
    overflow: hidden;
  }
  
  /* Text overlays */
  .category-title,
  .shop-now-text {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    color: #1a1a1a;
    font-weight: 500;
    z-index: 2;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    pointer-events: none;
  }
  
  .category-title {
    bottom: 10%;
    font-size: 16px;
    transition: bottom 0.4s ease, font-size 0.4s ease;
  }
  
  .shop-now-text {
    bottom: 3%;
    font-size: 10px;
    color: #fff;
    opacity: 0;
    transition: bottom 0.4s ease, opacity 0.4s ease;
  }
  
  /* Desktop hover effects */
  @media (min-width: 768px) {
    .category-card:hover .category-image {
      border-radius: 100% / 60%;
      transform: scale(1.02);
    }
    
    .category-card:hover .shop-now-text {
      opacity: 1;
      bottom: 8%;
    }
    
    .category-card:hover .category-title {
      bottom: 14%;
    }
  }
  
  /* Responsive skeleton and layout */
  @media (max-width: 999px) and (min-width: 768px) {
    .categories-skeleton,
    .categories-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    
    .skeleton-card,
    .category-card {
      width: 100%;
      min-width: auto;
    }
  }
  
  @media (max-width: 767px) {
    .categories-skeleton,
    .categories-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    
    .skeleton-card,
    .category-card {
      width: 100%;
      min-width: auto;
    }
    
    .categories-section {
      padding: 40px 0 0;
    }
    
    .categories-heading {
      font-size: 18px;
    }
    
    .categories-subheading {
      font-size: 12px;
      line-height: 2;
      margin-bottom: 24px;
    }
    
    .category-title {
      bottom: 15%;
      font-size: 12px;
      transform: translate(-50%, 50%);
      text-align: center;
      line-height: 1.3;
    }
    
    .shop-now-text {
      display: none;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const categoriesContainer = document.querySelector('[data-categories]');
  if (!categoriesContainer) return;

  // Initialize Intersection Observer with different threshold for immediate sections
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        loadCategories();
        observer.disconnect();
      }
    });
  }, {
    threshold: 0.1, // Lower threshold since it's below banner
    rootMargin: '100px' // Load 100px before entering viewport
  });

  observer.observe(categoriesContainer);

  function loadCategories() {
    const skeleton = categoriesContainer.querySelector('.categories-skeleton');
    const content = categoriesContainer.querySelector('.categories-content');

    // Show content
    content.style.display = 'block';
    content.style.opacity = '0';
    content.style.transition = 'opacity 0.3s ease';

    // Remove skeleton and show content
    requestAnimationFrame(() => {
      content.style.opacity = '1';
      if (skeleton) {
        skeleton.style.display = 'none';
        skeleton.remove();
      }
      
      // Initialize images and tracking
      lazyLoadImages();
      initCategoryTracking();
    });
  }

  function lazyLoadImages() {
    const pictures = document.querySelectorAll('.category-picture');
    const categoryCards = document.querySelectorAll('.category-card');
    
    // Load images with priority for first 3, lazy for others
    pictures.forEach((picture, index) => {
      const sources = picture.querySelectorAll('source');
      const img = picture.querySelector('img');
      
      // Add loaded class to card for animation
      setTimeout(() => {
        categoryCards[index].classList.add('loaded');
      }, index * 50);
      
      // Load sources
      sources.forEach(source => {
        if (source.dataset.srcset) {
          source.srcset = source.dataset.srcset;
          source.sizes = source.dataset.sizes;
        }
      });
      
      // Load image
      if (img && img.dataset.src) {
        img.src = img.dataset.src;
        
        // Load first 3 images immediately, others lazily
        if (index < 3) {
          img.loading = 'eager';
          img.fetchpriority = 'high';
        }
        
        img.onload = function() {
          picture.style.display = 'block';
          setTimeout(() => {
            picture.classList.add('loaded');
          }, 100);
        };
        
        // Fallback for images that might fail to load
        img.onerror = function() {
          picture.style.display = 'none';
        };
      }
    });
  }

  function initCategoryTracking() {
    const categoryLinks = document.querySelectorAll('.category-link');
    
    categoryLinks.forEach(function(link) {
      link.addEventListener('click', function(event) {
        event.preventDefault();
        
        const title = this.dataset.categoryTitle;
        const url = this.dataset.categoryLink;
        const blockId = this.dataset.blockId;
        
        // Push to GTM dataLayer
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'promoClick',
          promoClick: {
            promo_id: blockId,
            creative_name: title,
            promo_position: url,
            promo_location: 'categories_grid'
          }
        });
        
        // Navigate after brief delay for tracking
        setTimeout(function() {
          window.location.href = url;
        }, 100);
      });
    });
  }
});
</script>