{% comment %} {% schema %}
{
  "name": "Categories_Grid",
  "settings": [
    {
      "type": "text",
      "id": "Cateogory_heading",
      "label": "Section Heading",
    },
    {
      "type": "text",
      "id": "category_subheading",
      "label": "category Subheading",

    }
  ],
"blocks": [
  {
    "type": "category",
    "name": "Category Item",
    "settings": [
      {
        "type": "image_picker",
        "id": "category_image_desktop",
        "label": "Desktop Image"
      },
      {
        "type": "image_picker",
        "id": "category_image_mobile",
        "label": "Mobile Image"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "Category"
      },
      {
        "type": "url",
        "id": "link",
        "label": "Link"
      }
    ]
  }
],

  "presets": [
    {
      "name": "Categories_Grid",

    }
  ]
}
{% endschema %}

<div class="categories-section page-width" style="min-height:369px;">
  <h1 class="h1-tag-homepage" style="display:none;">
    Lucira Jewelry - Official Lab Grown Diamond Jewelry in India
  </h1>

  <h2>{{ section.settings.Cateogory_heading }}</h2>
  <p>{{ section.settings.category_subheading }}</p>

  <div class="categories-grid">
    {% for block in section.blocks %}
      <div class="category-card">
        {% if block.settings.link != blank %}
          <a
            href="{{ block.settings.link }}"
            onclick="
              window.dataLayer = window.dataLayer || []; dataLayer.push({
                event: 'promoClick',
                promoClick: {
          promo_id: target.id,
          creative_name: '{{ block.settings.title | escape }}',
          promo_position: '{{ block.settings.link }}',
        }              
      });
            "
          >
        {% endif %}

        <picture>
          {% if block.settings.category_image_mobile %}
            <source
              media="(max-width: 767px)"
              srcset="{{ block.settings.category_image_mobile | img_url: 'master' }}"
              loading="lazy"
              width="auto"
              height="auto"
            >
          {% endif %}
          {% if block.settings.category_image_desktop %}
            
            <img
              src="{{ block.settings.category_image_desktop | img_url: 'master' }}"
              width="auto"
              loading="lazy"
              height="auto"
              title="new-category"
            
              alt="{{ block.settings.title }}"
            >
          {% endif %}
        </picture>

        <span class="category-title">{{ block.settings.title }}</span>
        <span class="shop-now-text desktop-only">Shop Now</span>

        {% if block.settings.link != blank %}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .categories-section h2{color:#000;}
  .mobilecategory-img{display:none;}
  .categories-section.page-width{padding-left:0;padding-right:0; margin: 0 auto;}
  @media(max-width:767px){
    .desktopcategory-img{display:none!important;}
    .mobilecategory-img{display:block!important;}
  }
  .categories-section{text-align:center;margin:0;padding-top:0px;padding-bottom:0;}
  .categories-section h2{margin:0;font-weight:500;font-size:24px;line-height:150%;text-align:center;vertical-align:middle;text-transform:uppercase;color:#1a1a1a;}
  .categories-section p{margin-top:0;font-size:18px;color:#666;margin-bottom:0;line-height:34px;}
  .categories-grid{display:flex;justify-content:center;gap:20px;margin-top:40px;}
  .category-card{width:16.5%;position:relative;}
  .category-card a{display:block;position:relative;}
  .category-card img{width:100%;height:auto;transition:transform .5s ease,border-radius .5s ease;display:block;}
  .category-title,.shop-now-text{position:absolute;left:50%;transform:translateX(-50%);color:#1a1a1a;font-weight:500;z-index:2;letter-spacing:.5px;text-transform:uppercase;}
  .category-title{bottom:10%;font-size:16px;transition:bottom .4s ease,font-size .4s ease;}
  .shop-now-text{position:absolute;bottom:3%;left:50%;transform:translateX(-50%);font-size:10px;color:#fff;opacity:0;transition:bottom .4s ease,opacity .4s ease;text-transform:uppercase;}
  .category-card:hover .shop-now-text{opacity:1;bottom:8%;}
  .home-shop-the-look{margin-top:0!important;}
  @media(min-width:768px){
  .category-card:hover img{border-radius:100%/60%;}
  .category-card:hover .shop-now-text{opacity:1;}
  .category-card:hover .category-title{bottom:14%;font-size:16px;}
  }
  @media(max-width:999px) and (min-width:768px){
  .categories-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
  .category-card{width:100%;}
  }
  
  @media(max-width:767px){
  .categories-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
  .category-card{width:100%;}
  .category-card img{height:auto;object-fit:cover;aspect-ratio: 1 / 1.4;}
  .category-title{bottom:15%;font-size:12px;transform:translate(-50%,50%);text-align:center;}
  .shop-now-text{display:none;}
  .categories-section h2{font-size:18px;}
  .categories-section p{font-size:12px; line-height:2;}
  .categories-grid{margin-top:24px;}
  .categories-section{text-align:center;margin:0;padding-top:40px;padding-bottom:0;}
  
  }
  @media only screen and (min-width:1024px) and (max-width:1600px){
    .categories-section {padding-top: 40px;}
  }
  @media only screen and (min-width:1600px) and (max-width:2700px){
  .categories-section{padding-bottom:0;margin:0 auto;}
  .categories-section h2{font-size:28px;}
  .categories-section p{font-size:18px;}
  .home-shop-the-look{margin-bottom:0;padding-bottom:80px;}
  .categories-section {padding-top: 20px;}
  }
  
</style> {% endcomment %}


{% comment %}
  OPTIMIZATION CHANGES:
  1. Proper image dimensions and srcset for responsive loading
  2. Aspect ratios to prevent CLS
  3. Eager loading for first 3-6 categories (above fold)
  4. Optimized image sizes instead of 'master'
  5. Removed min-height to prevent CLS
  6. Fixed GTM tracking implementation
  7. Added preload for first category images
  8. Proper fetchpriority for critical images
  9. Fixed width/height attributes
  10. Removed inline onclick, moved to proper event handlers
{% endcomment %}

{% liquid
  assign first_three_blocks = section.blocks | slice: 0, 6
%}

{% comment %} Preload first category images for LCP {% endcomment %}
{% if section.blocks.size > 0 %}
  {% assign first_block = section.blocks.first %}
  {% if first_block.settings.category_image_desktop %}
    <link rel="preload" 
          as="image" 
          href="{{ first_block.settings.category_image_desktop | img_url: '400x560', crop: 'center' }}"
          media="(min-width: 768px)"
          fetchpriority="high">
  {% endif %}
  {% if first_block.settings.category_image_mobile %}
    <link rel="preload" 
          as="image" 
          href="{{ first_block.settings.category_image_mobile | img_url: '300x420', crop: 'center' }}"
          media="(max-width: 767px)"
          fetchpriority="high">
  {% endif %}
{% endif %}

<div class="categories-section page-width">
  {% comment %} Better SEO: Use visible H1 or move to main page context {% endcomment %}
  <div class="visually-hidden">
    <h1>Lucira Jewelry - Official Lab Grown Diamond Jewelry in India</h1>
  </div>

  {% if section.settings.category_heading != blank %}
    <h2 class="categories-heading">{{ section.settings.category_heading }}</h2>
  {% endif %}
  
  {% if section.settings.category_subheading != blank %}
    <p class="categories-subheading">{{ section.settings.category_subheading }}</p>
  {% endif %}

  <div class="categories-grid">
    {% for block in section.blocks %}
      {% liquid
        assign is_priority = false
        if forloop.index <= 6
          assign is_priority = true
        endif
        
        assign desktop_img = block.settings.category_image_desktop
        assign mobile_img = block.settings.category_image_mobile
      %}
      
      <div class="category-card" data-block-id="{{ block.id }}">
        {% if block.settings.link != blank %}
          <a
            href="{{ block.settings.link }}"
            class="category-link"
            data-category-title="{{ block.settings.title | escape }}"
            data-category-link="{{ block.settings.link }}"
            data-block-id="{{ block.id }}"
            aria-label="Shop {{ block.settings.title }}"
          >
        {% endif %}

        <div class="category-image-wrapper">
          <picture>
            {% if mobile_img %}
              <source
                media="(max-width: 767px)"
                srcset="{{ mobile_img | img_url: '300x420', crop: 'center' }} 300w,
                        {{ mobile_img | img_url: '150x210', crop: 'center' }} 150w"
                sizes="(max-width: 767px) 33vw, 300px"
              >
            {% endif %}
            
            {% if desktop_img %}
              <source
                media="(min-width: 768px)"
                srcset="{{ desktop_img | img_url: '400x560', crop: 'center' }} 400w,
                        {{ desktop_img | img_url: '300x420', crop: 'center' }} 300w,
                        {{ desktop_img | img_url: '200x280', crop: 'center' }} 200w"
                sizes="(min-width: 1600px) 300px, (min-width: 1000px) 16.5vw, (min-width: 768px) 30vw, 33vw"
              >
              
              <img
                class="category-image"
                src="{{ desktop_img | img_url: '400x560', crop: 'center' }}"
                alt="{{ block.settings.title | escape }}"
                width="400"
                height="560"
                loading="{% if is_priority %}eager{% else %}lazy{% endif %}"
                decoding="async"
                {% if is_priority %}fetchpriority="high"{% endif %}
              >
            {% endif %}
          </picture>
        </div>

        <span class="category-title">{{ block.settings.title }}</span>
        <span class="shop-now-text desktop-only" aria-hidden="true">Shop Now</span>

        {% if block.settings.link != blank %}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
  /* Accessibility helper */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
  
  /* Main container */
  .categories-section {
    text-align: center;
    margin: 0 auto;
    padding: 40px 0 0;
  }
  
  .categories-section.page-width {
    padding-left: 0;
    padding-right: 0;
  }
  
  /* Typography */
  .categories-heading {
    margin: 0;
    font-weight: 500;
    font-size: 24px;
    line-height: 1.5;
    text-align: center;
    text-transform: uppercase;
    color: #1a1a1a;
  }
  
  .categories-subheading {
    margin: 0 0 40px;
    font-size: 18px;
    color: #666;
    line-height: 1.9;
  }
  
  /* Grid layout */
  .categories-grid {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  
  /* Category card */
  .category-card {
    width: 16.5%;
    position: relative;
    min-width: 150px;
  }
  
  .category-link {
    display: block;
    position: relative;
    text-decoration: none;
  }
  
  /* Image wrapper with aspect ratio for CLS prevention */
  .category-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 7; /* 400/560 = 5/7 */
    overflow: hidden;
  }
  
  .category-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease, border-radius 0.5s ease;
    will-change: transform;
  }
  
  /* Text overlays */
  .category-title,
  .shop-now-text {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    color: #1a1a1a;
    font-weight: 500;
    z-index: 2;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    pointer-events: none;
  }
  
  .category-title {
    bottom: 10%;
    font-size: 16px;
    transition: bottom 0.4s ease, font-size 0.4s ease;
  }
  
  .shop-now-text {
    bottom: 3%;
    font-size: 10px;
    color: #fff;
    opacity: 0;
    transition: bottom 0.4s ease, opacity 0.4s ease;
  }
  
  /* Desktop hover effects */
  @media (min-width: 768px) {
    .category-card:hover .category-image {
      border-radius: 100% / 60%;
      transform: scale(1.02);
    }
    
    .category-card:hover .shop-now-text {
      opacity: 1;
      bottom: 8%;
    }
    
    .category-card:hover .category-title {
      bottom: 14%;
    }
  }
  
  /* Tablet layout */
  @media (max-width: 999px) and (min-width: 768px) {
    .categories-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    
    .category-card {
      width: 100%;
      min-width: auto;
    }
  }
  
  /* Mobile layout */
  @media (max-width: 767px) {
    .categories-section {
      padding: 40px 0 0;
    }
    
    .categories-heading {
      font-size: 18px;
    }
    
    .categories-subheading {
      font-size: 12px;
      line-height: 2;
      margin-bottom: 24px;
    }
    
    .categories-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-top: 24px;
    }
    
    .category-card {
      width: 100%;
      min-width: auto;
    }
    
    .category-image-wrapper {
      aspect-ratio: 5 / 7; /* Mobile aspect ratio */
    }
    
    .category-title {
      bottom: 15%;
      font-size: 12px;
      transform: translate(-50%, 50%);
      text-align: center;
      line-height: 1.3;
    }
    
    .shop-now-text {
      display: none;
    }
  }
  
  /* Large desktop */
  @media (min-width: 1600px) {
    .categories-section {
      padding: 20px 0 0;
    }
    
    .categories-heading {
      font-size: 28px;
    }
    
    .categories-subheading {
      font-size: 18px;
    }
  }
  
  /* Medium desktop */
  @media (min-width: 1024px) and (max-width: 1600px) {
    .categories-section {
      padding-top: 40px;
    }
  }
</style>

<script>
  (function() {
    // Initialize on DOM ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCategoryTracking);
    } else {
      initCategoryTracking();
    }
    
    function initCategoryTracking() {
      const categoryLinks = document.querySelectorAll('.category-link');
      
      categoryLinks.forEach(function(link) {
        link.addEventListener('click', function(event) {
          event.preventDefault();
          
          const title = this.dataset.categoryTitle;
          const url = this.dataset.categoryLink;
          const blockId = this.dataset.blockId;
          
          // Push to GTM dataLayer
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: 'promoClick',
            promoClick: {
              promo_id: blockId,
              creative_name: title,
              promo_position: url,
              promo_location: 'categories_grid'
            }
          });
          
          // Navigate after brief delay for tracking
          setTimeout(function() {
            window.location.href = url;
          }, 100);
        });
      });
      
      // Track promo views on scroll (intersection observer)
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting && !entry.target.dataset.tracked) {
              const link = entry.target.querySelector('.category-link');
              if (link) {
                window.dataLayer = window.dataLayer || [];
                window.dataLayer.push({
                  event: 'promoView',
                  promoView: {
                    promo_id: link.dataset.blockId,
                    creative_name: link.dataset.categoryTitle,
                    promo_position: link.dataset.categoryLink,
                    promo_location: 'categories_grid'
                  }
                });
                entry.target.dataset.tracked = 'true';
              }
            }
          });
        }, { threshold: 0.5 });
        
        document.querySelectorAll('.category-card').forEach(function(card) {
          observer.observe(card);
        });
      }
    }
  })();
</script>

{% schema %}
{
  "name": "Categories Grid",
  "settings": [
    {
      "type": "text",
      "id": "category_heading",
      "label": "Section Heading",
      "default": "Shop By Category"
    },
    {
      "type": "text",
      "id": "category_subheading",
      "label": "Category Subheading",
      "default": "Discover our collection"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "category_image_desktop",
          "label": "Desktop Image",
          "info": "Recommended: 400x560px (5:7 aspect ratio)"
        },
        {
          "type": "image_picker",
          "id": "category_image_mobile",
          "label": "Mobile Image",
          "info": "Recommended: 300x420px (5:7 aspect ratio)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categories Grid"
    }
  ],
  "max_blocks": 12
}
{% endschema %}