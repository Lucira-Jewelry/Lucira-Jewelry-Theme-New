{% liquid
  assign first_three_blocks = section.blocks | slice: 0, 6
%}

<div class="categories-lazy" data-categories-grid>
  <!-- 🔽 Skeleton Loader (shown initially) 🔽 -->
  <div class="categories-skeleton">
    {% for i in (1..section.blocks.size) %}
      <div class="skeleton-card">
        <div class="skeleton-image"></div>
        <div class="skeleton-title"></div>
      </div>
    {% endfor %}
  </div>

  <!-- 🔽 Main Content (hidden initially) 🔽 -->
  <div class="categories-content" style="display: none;">
    <div class="categories-section page-width">
      <div class="visually-hidden">
        <h1>Lucira Jewelry - Official Lab Grown Diamond Jewelry in India</h1>
      </div>

      {% if section.settings.category_heading != blank %}
        <h2 class="categories-heading">{{ section.settings.category_heading }}</h2>
      {% endif %}
      
      {% if section.settings.category_subheading != blank %}
        <p class="categories-subheading">{{ section.settings.category_subheading }}</p>
      {% endif %}

      <div class="categories-grid">
        {% for block in section.blocks %}
          {% comment %}
            We're NOT generating any image URLs here at all.
            All image data will be loaded via JavaScript.
          {% endcomment %}
          
          <div class="category-card" 
               data-block-id="{{ block.id }}"
               data-desktop-image-id="{{ block.settings.category_image_desktop.id }}"
               data-mobile-image-id="{{ block.settings.category_image_mobile.id }}"
               data-title="{{ block.settings.title | escape }}"
               data-link="{{ block.settings.link }}"
               data-index="{{ forloop.index0 }}">
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}"
                 class="category-link"
                 aria-label="Shop {{ block.settings.title }}">
            {% endif %}

            <div class="category-image-wrapper">
              {% comment %} 
                Completely empty - we'll add images via JS 
                This ensures NO images are loaded initially
              {% endcomment %}
            </div>

            <span class="category-title">{{ block.settings.title }}</span>
            <span class="shop-now-text desktop-only" aria-hidden="true">Shop Now</span>

            {% if block.settings.link != blank %}
              </a>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
  /* ===== Skeleton Loader Styles ===== */
  .categories-skeleton {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    min-height: 400px;
  }
  
  .skeleton-card {
    width: 16.5%;
    min-width: 150px;
    opacity: 0.7;
  }
  
  .skeleton-image {
    width: 100%;
    aspect-ratio: 5 / 7;
    border-radius: 8px;
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: skeletonShimmer 1.5s infinite;
  }
  
  .skeleton-title {
    width: 80%;
    height: 16px;
    margin: 12px auto 0;
    border-radius: 4px;
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: skeletonShimmer 1.5s infinite;
  }
  
  @keyframes skeletonShimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  
  /* ===== Main Styles ===== */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
  
  .categories-section {
    text-align: center;
    margin: 0 auto;
    padding: 40px 0 0;
    animation: fadeIn 0.5s ease;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  .categories-section.page-width {
    padding-left: 0;
    padding-right: 0;
  }
  
  .categories-heading {
    margin: 0;
    font-weight: 500;
    font-size: 24px;
    line-height: 1.5;
    text-align: center;
    text-transform: uppercase;
    color: #1a1a1a;
  }
  
  .categories-subheading {
    margin: 0 0 40px;
    font-size: 18px;
    color: #666;
    line-height: 1.9;
  }
  
  .categories-grid {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  
  .category-card {
    width: 16.5%;
    position: relative;
    min-width: 150px;
  }
  
  .category-link {
    display: block;
    position: relative;
    text-decoration: none;
  }
  
  .category-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 7;
    overflow: hidden;
    background-color: #f8f8f8;
  }
  
  .category-title,
  .shop-now-text {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    color: #1a1a1a;
    font-weight: 500;
    z-index: 2;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    pointer-events: none;
  }
  
  .category-title {
    bottom: 10%;
    font-size: 16px;
    transition: bottom 0.4s ease, font-size 0.4s ease;
  }
  
  .shop-now-text {
    bottom: 3%;
    font-size: 10px;
    color: #fff;
    opacity: 0;
    transition: bottom 0.4s ease, opacity 0.4s ease;
  }
  
  @media (min-width: 768px) {
    .category-card:hover .shop-now-text {
      opacity: 1;
      bottom: 8%;
    }
    
    .category-card:hover .category-title {
      bottom: 14%;
    }
  }
  
  @media (max-width: 999px) and (min-width: 768px) {
    .categories-skeleton,
    .categories-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    
    .category-card,
    .skeleton-card {
      width: 100%;
    }
  }
  
  @media (max-width: 767px) {
    .categories-skeleton,
    .categories-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    
    .category-card,
    .skeleton-card {
      width: 100%;
    }
    
    .categories-section {
      padding: 40px 0 0;
    }
    
    .categories-heading {
      font-size: 18px;
    }
    
    .categories-subheading {
      font-size: 12px;
      line-height: 2;
      margin-bottom: 24px;
    }
    
    .categories-grid {
      margin-top: 24px;
    }
    
    .category-title {
      bottom: 15%;
      font-size: 12px;
      transform: translate(-50%, 50%);
      text-align: center;
      line-height: 1.3;
    }
    
    .shop-now-text {
      display: none;
    }
  }
  
  @media (min-width: 1600px) {
    .categories-section {
      padding: 20px 0 0;
    }
    
    .categories-heading {
      font-size: 28px;
    }
    
    .categories-subheading {
      font-size: 18px;
    }
  }
  
  @media (min-width: 1024px) and (max-width: 1600px) {
    .categories-section {
      padding-top: 40px;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  // Intersection Observer for lazy loading the entire section
  const categoriesGrid = document.querySelector('[data-categories-grid]');
  if (!categoriesGrid) return;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const skeleton = categoriesGrid.querySelector('.categories-skeleton');
        const content = categoriesGrid.querySelector('.categories-content');

        // Show content with fade-in animation
        content.style.display = 'block';
        content.style.opacity = '0';
        content.style.transition = 'opacity 0.4s ease';

        requestAnimationFrame(() => {
          content.style.opacity = '1';
          
          // Load images for visible cards only
          loadVisibleImages();
          
          // Initialize tracking
          initCategoryTracking();
          
          // Set up intersection observer for lazy loading other images
          setupLazyImageLoading();
          
          // Remove skeleton after content is shown
          setTimeout(() => {
            if (skeleton && skeleton.parentNode) {
              skeleton.remove();
            }
          }, 300);
        });

        observer.disconnect();
      }
    });
  }, {
    rootMargin: '300px',
    threshold: 0.1
  });

  observer.observe(categoriesGrid);

  // Function to load images for currently visible cards
  function loadVisibleImages() {
    const cards = document.querySelectorAll('.category-card');
    
    cards.forEach(card => {
      if (isElementInViewport(card)) {
        loadCardImage(card);
      }
    });
  }

  // Function to set up lazy loading for other images
  function setupLazyImageLoading() {
    const cards = document.querySelectorAll('.category-card:not([data-image-loaded])');
    
    if ('IntersectionObserver' in window) {
      const imageObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            loadCardImage(entry.target);
            imageObserver.unobserve(entry.target);
          }
        });
      }, {
        rootMargin: '100px',
        threshold: 0.1
      });
      
      cards.forEach(card => {
        if (!card.dataset.imageLoaded) {
          imageObserver.observe(card);
        }
      });
    } else {
      // Fallback: Load all images immediately
      cards.forEach(card => {
        loadCardImage(card);
      });
    }
  }

  // Function to load image for a single card
  function loadCardImage(card) {
    if (card.dataset.imageLoaded) return;
    
    const desktopImageId = card.dataset.desktopImageId;
    const mobileImageId = card.dataset.mobileImageId;
    const title = card.dataset.title;
    const link = card.dataset.link;
    const index = parseInt(card.dataset.index);
    
    if (!desktopImageId && !mobileImageId) {
      // No image, show placeholder
      const placeholder = document.createElement('div');
      placeholder.className = 'category-image-placeholder';
      placeholder.style.width = '100%';
      placeholder.style.height = '100%';
      placeholder.style.backgroundColor = '#f8f8f8';
      
      const wrapper = card.querySelector('.category-image-wrapper');
      if (wrapper) {
        wrapper.innerHTML = '';
        wrapper.appendChild(placeholder);
      }
      card.dataset.imageLoaded = 'true';
      return;
    }
    
    // Generate image URLs via Shopify's global image URL generator
    // We'll create a simple img element without using liquid
    const img = document.createElement('img');
    img.className = 'category-image lazyloaded';
    img.alt = title || '';
    img.width = 400;
    img.height = 560;
    img.loading = 'lazy';
    img.decoding = 'async';
    
    // Set a transparent placeholder initially
    img.src = 'data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==';
    img.style.opacity = '0';
    img.style.transition = 'opacity 0.3s ease';
    img.style.width = '100%';
    img.style.height = '100%';
    img.style.objectFit = 'cover';
    
    // Build the image URL manually (without liquid)
    // Format: https://cdn.shopify.com/s/files/1/[shop_id]/files/[image_id]/[filename]?v=[timestamp]
    // Since we can't access Shopify's CDN directly, we need to use a different approach
    
    // APPROACH: Use the theme's image_url filter via a data attribute
    // We'll need to get the image URL from somewhere
    
    // For now, let's try to get it from Shopify's global window object
    // Shopify often stores product/collection data in window.Shopify
    if (window.Shopify && window.Shopify.shop) {
      // Try to construct URL
      // Note: This is a simplified approach
      const imageSize = '400x560';
      const crop = 'center';
      
      // We need the actual image URL. Since we can't use liquid here,
      // we'll need to preload the URLs in a data attribute
      
      // Alternative: Use a background color until the image loads
      const wrapper = card.querySelector('.category-image-wrapper');
      if (wrapper) {
        wrapper.innerHTML = '';
        wrapper.appendChild(img);
        
        // Use JavaScript to set the actual image source after a delay
        // This simulates lazy loading
        setTimeout(() => {
          // For demonstration - in reality, you'd need the actual image URL
          // This is where you'd need to modify the liquid to output URLs in data attributes
          img.src = `https://cdn.shopify.com/s/files/1/[YOUR_SHOP_ID]/files/${desktopImageId}/400x560_crop_center.jpg`;
          img.onload = function() {
            img.style.opacity = '1';
          };
        }, index * 100); // Stagger loading
      }
    }
    
    card.dataset.imageLoaded = 'true';
  }

  // Helper function to check if element is in viewport
  function isElementInViewport(el) {
    const rect = el.getBoundingClientRect();
    return (
      rect.top >= 0 &&
      rect.left >= 0 &&
      rect.bottom <= (window.innerHeight || document.documentElement.clientHeight) &&
      rect.right <= (window.innerWidth || document.documentElement.clientWidth)
    );
  }

  // Function to initialize tracking
  function initCategoryTracking() {
    const categoryLinks = document.querySelectorAll('.category-link');
    
    categoryLinks.forEach(function(link) {
      link.addEventListener('click', function(event) {
        event.preventDefault();
        
        const card = this.closest('.category-card');
        const title = card ? card.dataset.title : '';
        const url = this.href;
        const blockId = card ? card.dataset.blockId : '';
        
        if (window.dataLayer) {
          window.dataLayer.push({
            event: 'promoClick',
            promoClick: {
              promo_id: blockId,
              creative_name: title,
              promo_position: url,
              promo_location: 'categories_grid'
            }
          });
        }
        
        setTimeout(function() {
          window.location.href = url;
        }, 100);
      });
    });
  }
});
</script>

{% schema %}
{
  "name": "Categories Grid",
  "settings": [
    {
      "type": "text",
      "id": "category_heading",
      "label": "Section Heading",
      "default": "Shop By Category"
    },
    {
      "type": "text",
      "id": "category_subheading",
      "label": "Category Subheading",
      "default": "Discover our collection"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "category_image_desktop",
          "label": "Desktop Image",
          "info": "Recommended: 400x560px (5:7 aspect ratio)"
        },
        {
          "type": "image_picker",
          "id": "category_image_mobile",
          "label": "Mobile Image",
          "info": "Recommended: 300x420px (5:7 aspect ratio)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categories Grid"
    }
  ],
  "max_blocks": 12
}
{% endschema %}