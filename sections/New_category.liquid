{% liquid
  assign first_three_blocks = section.blocks | slice: 0, 6
%}

<div class="categories-lazy" data-categories-grid>
  <!-- 🔽 Skeleton Loader (shown initially) 🔽 -->
  <div class="categories-skeleton">
    {% for i in (1..section.blocks.size) %}
      <div class="skeleton-card">
        <div class="skeleton-image"></div>
        <div class="skeleton-title"></div>
      </div>
    {% endfor %}
  </div>

  <!-- 🔽 Main Content (hidden initially) 🔽 -->
  <div class="categories-content" style="display: none;">
    {% comment %} PRELOAD ONLY WHEN NEEDED - REMOVED IMMEDIATE PRELOAD {% endcomment %}

    <div class="categories-section page-width">
      <div class="visually-hidden">
        <h1>Lucira Jewelry - Official Lab Grown Diamond Jewelry in India</h1>
      </div>

      {% if section.settings.category_heading != blank %}
        <h2 class="categories-heading">{{ section.settings.category_heading }}</h2>
      {% endif %}
      
      {% if section.settings.category_subheading != blank %}
        <p class="categories-subheading">{{ section.settings.category_subheading }}</p>
      {% endif %}

      <div class="categories-grid">
        {% for block in section.blocks %}
          {% liquid
            assign desktop_img = block.settings.category_image_desktop
            assign mobile_img = block.settings.category_image_mobile
            
            # Generate responsive image sizes - only generate URLs when needed
            assign desktop_srcset = ""
            assign mobile_srcset = ""
            assign placeholder_src = ""
            
            if desktop_img
              assign desktop_srcset = desktop_img | img_url: '200x' | append: ' 200w,'
              assign desktop_srcset = desktop_srcset | append: desktop_img | img_url: '300x' | append: ' 300w,'
              assign desktop_srcset = desktop_srcset | append: desktop_img | img_url: '400x' | append: ' 400w'
              
              # Use a transparent 1x1 pixel as placeholder instead of 20px image
              assign placeholder_src = 'data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw=='
            endif
            
            if mobile_img
              assign mobile_srcset = mobile_img | img_url: '150x' | append: ' 150w,'
              assign mobile_srcset = mobile_srcset | append: mobile_img | img_url: '300x' | append: ' 300w'
            endif
          %}
          
          <div class="category-card" data-block-id="{{ block.id }}">
            {% if block.settings.link != blank %}
              <a
                href="{{ block.settings.link }}"
                class="category-link"
                data-category-title="{{ block.settings.title | escape }}"
                data-category-link="{{ block.settings.link }}"
                data-block-id="{{ block.id }}"
                aria-label="Shop {{ block.settings.title }}"
              >
            {% endif %}

            <div class="category-image-wrapper">
              <picture>
                {% if mobile_img and mobile_srcset != blank %}
                  <source
                    media="(max-width: 767px)"
                    data-srcset="{{ mobile_srcset }}"
                    sizes="(max-width: 767px) calc(33vw - 16px), 300px"
                  >
                {% endif %}
                
                {% if desktop_img and desktop_srcset != blank %}
                  <source
                    media="(min-width: 768px)"
                    data-srcset="{{ desktop_srcset }}"
                    sizes="(min-width: 1600px) 300px, (min-width: 1000px) 16.5vw, (min-width: 768px) 30vw, calc(33vw - 16px)"
                  >
                  
                  <img
                    class="category-image lazyload"
                    data-src="{{ desktop_img | img_url: '400x' }}"
                    data-srcset="{{ desktop_srcset }}"
                    alt="{{ block.settings.title | escape }}"
                    width="400"
                    height="560"
                    loading="lazy"
                    decoding="async"
                    src="{{ placeholder_src }}"
                    data-sizes="auto"
                  >
                {% else %}
                  {% comment %} Fallback if no image {% endcomment %}
                  <div class="category-image-placeholder-fallback"></div>
                {% endif %}
              </picture>
            </div>

            <span class="category-title">{{ block.settings.title }}</span>
            <span class="shop-now-text desktop-only" aria-hidden="true">Shop Now</span>

            {% if block.settings.link != blank %}
              </a>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
  /* ===== Skeleton Loader Styles ===== */
  .categories-skeleton {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    min-height: 400px;
  }
  
  .skeleton-card {
    width: 16.5%;
    min-width: 150px;
    opacity: 0.7;
  }
  
  .skeleton-image {
    width: 100%;
    aspect-ratio: 5 / 7;
    border-radius: 8px;
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: skeletonShimmer 1.5s infinite;
  }
  
  .skeleton-title {
    width: 80%;
    height: 16px;
    margin: 12px auto 0;
    border-radius: 4px;
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: skeletonShimmer 1.5s infinite;
  }
  
  @keyframes skeletonShimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  
  /* ===== Optimized Main Styles ===== */
  
  /* Accessibility helper */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
  
  /* Main container */
  .categories-section {
    text-align: center;
    margin: 0 auto;
    padding: 40px 0 0;
    animation: fadeIn 0.5s ease;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  .categories-section.page-width {
    padding-left: 0;
    padding-right: 0;
  }
  
  /* Typography */
  .categories-heading {
    margin: 0;
    font-weight: 500;
    font-size: 24px;
    line-height: 1.5;
    text-align: center;
    text-transform: uppercase;
    color: #1a1a1a;
  }
  
  .categories-subheading {
    margin: 0 0 40px;
    font-size: 18px;
    color: #666;
    line-height: 1.9;
  }
  
  /* Grid layout */
  .categories-grid {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  
  /* Category card */
  .category-card {
    width: 16.5%;
    position: relative;
    min-width: 150px;
    will-change: transform;
  }
  
  .category-link {
    display: block;
    position: relative;
    text-decoration: none;
  }
  
  /* Image wrapper with aspect ratio for CLS prevention */
  .category-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 7;
    overflow: hidden;
    background-color: #f8f8f8;
  }
  
  .category-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease, border-radius 0.5s ease;
    opacity: 0;
    transition: opacity 0.3s ease;
    background-color: #f8f8f8;
  }
  
  .category-image.lazyloaded {
    opacity: 1;
  }
  
  .category-image-placeholder-fallback {
    width: 100%;
    height: 100%;
    background-color: #f8f8f8;
  }
  
  /* Text overlays */
  .category-title,
  .shop-now-text {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    color: #1a1a1a;
    font-weight: 500;
    z-index: 2;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    pointer-events: none;
  }
  
  .category-title {
    bottom: 10%;
    font-size: 16px;
    transition: bottom 0.4s ease, font-size 0.4s ease;
  }
  
  .shop-now-text {
    bottom: 3%;
    font-size: 10px;
    color: #fff;
    opacity: 0;
    transition: bottom 0.4s ease, opacity 0.4s ease;
  }
  
  /* Desktop hover effects */
  @media (min-width: 768px) {
    .category-card:hover .category-image {
      border-radius: 100% / 60%;
      transform: scale(1.02);
    }
    
    .category-card:hover .shop-now-text {
      opacity: 1;
      bottom: 8%;
    }
    
    .category-card:hover .category-title {
      bottom: 14%;
    }
  }
  
  /* Tablet layout */
  @media (max-width: 999px) and (min-width: 768px) {
    .categories-skeleton {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    
    .categories-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    
    .category-card {
      width: 100%;
      min-width: auto;
    }
    
    .skeleton-card {
      width: 100%;
    }
  }
  
  /* Mobile layout */
  @media (max-width: 767px) {
    .categories-skeleton {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    
    .skeleton-card {
      width: 100%;
    }
    
    .categories-section {
      padding: 40px 0 0;
    }
    
    .categories-heading {
      font-size: 18px;
    }
    
    .categories-subheading {
      font-size: 12px;
      line-height: 2;
      margin-bottom: 24px;
    }
    
    .categories-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-top: 24px;
    }
    
    .category-card {
      width: 100%;
      min-width: auto;
    }
    
    .category-title {
      bottom: 15%;
      font-size: 12px;
      transform: translate(-50%, 50%);
      text-align: center;
      line-height: 1.3;
    }
    
    .shop-now-text {
      display: none;
    }
  }
  
  /* Large desktop */
  @media (min-width: 1600px) {
    .categories-section {
      padding: 20px 0 0;
    }
    
    .categories-heading {
      font-size: 28px;
    }
    
    .categories-subheading {
      font-size: 18px;
    }
  }
  
  /* Medium desktop */
  @media (min-width: 1024px) and (max-width: 1600px) {
    .categories-section {
      padding-top: 40px;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  // Intersection Observer for lazy loading the entire section
  const categoriesGrid = document.querySelector('[data-categories-grid]');
  if (!categoriesGrid) return;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const skeleton = categoriesGrid.querySelector('.categories-skeleton');
        const content = categoriesGrid.querySelector('.categories-content');

        // Show content with fade-in animation
        content.style.display = 'block';
        content.style.opacity = '0';
        content.style.transition = 'opacity 0.4s ease';

        requestAnimationFrame(() => {
          content.style.opacity = '1';
          
          // Now preload the first image (LCP candidate)
          preloadFirstImage();
          
          // Initialize lazy loading for all images
          initLazyLoading();
          
          // Initialize tracking
          initCategoryTracking();
          
          // Remove skeleton after content is shown
          setTimeout(() => {
            if (skeleton && skeleton.parentNode) {
              skeleton.remove();
            }
          }, 300);
        });

        observer.disconnect();
      }
    });
  }, {
    rootMargin: '300px', // Load 300px before section becomes visible
    threshold: 0.1
  });

  observer.observe(categoriesGrid);

  // Function to preload only the first image (LCP candidate)
  function preloadFirstImage() {
    const firstImage = document.querySelector('.category-image.lazyload');
    if (firstImage && firstImage.dataset.src) {
      // Create a hidden preload link
      const preloadLink = document.createElement('link');
      preloadLink.rel = 'preload';
      preloadLink.as = 'image';
      preloadLink.href = firstImage.dataset.src;
      preloadLink.fetchpriority = 'high';
      document.head.appendChild(preloadLink);
      
      // Load this image immediately
      firstImage.src = firstImage.dataset.src;
      if (firstImage.dataset.srcset) {
        firstImage.srcset = firstImage.dataset.srcset;
      }
      firstImage.classList.add('lazyloaded');
    }
  }

  // Function to initialize lazy loading for remaining images
  function initLazyLoading() {
    const images = document.querySelectorAll('.category-image.lazyload:not(.lazyloaded)');
    
    if ('loading' in HTMLImageElement.prototype && 'IntersectionObserver' in window) {
      // Modern browsers with both native lazy loading and IntersectionObserver
      const lazyImageObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const img = entry.target;
            if (img.dataset.src) {
              img.src = img.dataset.src;
            }
            if (img.dataset.srcset) {
              img.srcset = img.dataset.srcset;
            }
            img.classList.add('lazyloaded');
            lazyImageObserver.unobserve(img);
            
            // Also load the source elements inside picture
            const picture = img.closest('picture');
            if (picture) {
              const sources = picture.querySelectorAll('source[data-srcset]');
              sources.forEach(source => {
                source.srcset = source.dataset.srcset;
              });
            }
          }
        });
      }, {
        rootMargin: '100px',
        threshold: 0.1
      });
      
      images.forEach(img => lazyImageObserver.observe(img));
    } else {
      // Fallback for older browsers
      images.forEach(img => {
        if (img.dataset.src) {
          img.src = img.dataset.src;
        }
        if (img.dataset.srcset) {
          img.srcset = img.dataset.srcset;
        }
        img.classList.add('lazyloaded');
      });
    }
  }

  // Function to initialize tracking
  function initCategoryTracking() {
    const categoryLinks = document.querySelectorAll('.category-link');
    
    categoryLinks.forEach(function(link) {
      link.addEventListener('click', function(event) {
        event.preventDefault();
        
        const title = this.dataset.categoryTitle;
        const url = this.dataset.categoryLink;
        const blockId = this.dataset.blockId;
        
        // Push to GTM dataLayer
        if (window.dataLayer) {
          window.dataLayer.push({
            event: 'promoClick',
            promoClick: {
              promo_id: blockId,
              creative_name: title,
              promo_position: url,
              promo_location: 'categories_grid'
            }
          });
        }
        
        // Navigate after brief delay for tracking
        setTimeout(function() {
          window.location.href = url;
        }, 100);
      });
    });
    
    // Track promo views on scroll (intersection observer)
    if ('IntersectionObserver' in window) {
      const promoObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting && !entry.target.dataset.tracked) {
            const link = entry.target.querySelector('.category-link');
            if (link && window.dataLayer) {
              window.dataLayer.push({
                event: 'promoView',
                promoView: {
                  promo_id: link.dataset.blockId,
                  creative_name: link.dataset.categoryTitle,
                  promo_position: link.dataset.categoryLink,
                  promo_location: 'categories_grid'
                }
              });
              entry.target.dataset.tracked = 'true';
            }
          }
        });
      }, { threshold: 0.5 });
      
      document.querySelectorAll('.category-card').forEach(function(card) {
        promoObserver.observe(card);
      });
    }
  }
});
</script>