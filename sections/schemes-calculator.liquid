        #free_amount.hidden-value::before { font-size: 12px; letter-spacing: 3px; }
        #total_amount.hidden-value::before { font-size: 14px; letter-spacing: 3px; }
        .total-redeemable span:first-child { font-size: 12px; }
        .total-redeemable { margin-top: 12px; padding-top: 12px; }
        
        /* Mobile styles for revealed values */
        #free_amount:not(.hidden-value) {
            font-size: 12px;
        }
        #total_amount:not(.hidden-value) {
            font-size: 14px;
        }
    }
</style>

