<section class="scheme-calculator-section">
  <div class="page-width">
    <div class="scheme-calculator-content">
      {% if section.settings.calculator_title != blank %}
        <h2>{{ section.settings.calculator_title }}</h2>
      {% endif %}
      {% if section.settings.calculator_subtitle != blank %}
        <p>{{ section.settings.calculator_subtitle }}</p>
      {% endif %}
    </div>

    <div class="grid-row">
      <div class="grid-column left-column">
        <div class="calculator-form-wrapper">
          <h3>Enter Your Monthly Installment To See Your Total Savings</h3>
          <div class="calculator_form_container">
            <label for="calculator_monthly_installment">Monthly Installment</label>
            <div class="input-group">
              <div class="input-wrapper">
                <span class="currency-symbol">₹</span>
                <input
                  type="text"
                  id="calculator_monthly_installment"
                  placeholder="10,000"
                  value="10000"
                  oninput="handleInputChange(this)"
                />
              </div>
              <button class="check-button" onclick="updateCalculation('schemePopup')">CHECK</button>
            </div>

            <div class="range-slider-container">
              <input
                type="range"
                id="installment_slider"
                min="1000"
                max="19000"
                step="500"
                value="10000"
                oninput="updateFromSlider(this.value)"
              />
            </div>

            <p class="or-text">Or</p>

            <div class="price-tabs">
              <button class="price-tab" onclick="selectTab(this, 2000)">₹2,000</button>
              <button class="price-tab" onclick="selectTab(this, 5000)">₹5,000</button>
              <button class="price-tab popular-tab" onclick="selectTab(this, 10000)">
                ₹10,000<span class="popular-badge">Popular</span>
              </button>
              <button class="price-tab" onclick="selectTab(this, 19000)">₹19,000</button>
            </div>
          </div>
        </div>
      </div>

      <div class="grid-column right-column">
        <div class="calculator-results">
          <div class="result-item">
            <div class="check-icon"><i class="fa-solid fa-check"></i></div>
            <div class="result-text">
              <span>Your Premium amount/month</span>
              <span class="result-amount" id="premium_amount">₹10,000</span>
            </div>
          </div>
          <div class="result-item">
            <div class="check-icon"><i class="fa-solid fa-check"></i></div>
            <div class="result-text">
              <span>Total Investment (9 months)</span>
              <span class="result-amount" id="pay_amount">₹90,000</span>
            </div>
          </div>
          <div class="result-item">
            <div class="check-icon"><i class="fa-solid fa-check"></i></div>
            <div class="result-text">
              <span>We Pay your 10th Premium</span>
              <span class="result-amount" id="free_amount">₹10,000</span>
            </div>
          </div>
          <div class="total-redeemable">
            <span>Total Redeemable Amount</span>
            <span class="total-amount" id="total_amount">₹1,00,000</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ==================== Scheme Popup ==================== -->
<div id="schemePopup" class="scheme-popup-overlay">
  <div class="scheme-popup-content">
    <span class="scheme-popup-close" onclick="schemeClosePopup('schemePopup')">&times;</span>
    <h3>Get Your Scheme Details</h3>

    {%- form 'contact', id: 'schemeForm', class: 'scheme-form' -%}
      <!-- Required hidden Shopify fields -->
      <input type="hidden" name="form_type" value="contact">
      <input type="hidden" name="utf8" value="✓">
      <input type="hidden" name="contact[subject]" value="Scheme Calculator Request - Lucira Jewelry">
      <input type="hidden" name="contact[tags]" value="Scheme Calculator">
      <input type="hidden" name="contact[email]" value="support@lucirajewelry.com">

      <!-- Visible user inputs -->
      <input type="text" name="contact[name]" placeholder="Full Name" required />
      <input
        type="tel"
        name="contact[phone]"
        id="schemePhone"
        placeholder="Phone Number"
        required
        oninput="if(this.value.length > 10) this.value = this.value.slice(0, 10);"
      />

      <!-- Hidden message body -->
      <textarea name="contact[body]" id="schemeBody" style="display:none;"></textarea>

      <!-- Hidden calculation fields -->
      <input type="hidden" id="hidden_monthly_installment" />
      <input type="hidden" id="hidden_premium_amount" />
      <input type="hidden" id="hidden_pay_amount" />
      <input type="hidden" id="hidden_free_amount" />
      <input type="hidden" id="hidden_total_amount" />

      <button type="submit" class="scheme-submit-btn">Submit</button>
    {%- endform -%}

    {% if form.posted_successfully? %}
      <div class="form-feedback success">
        Thank you! Our expert will contact you shortly.
      </div>
    {% elsif form.errors %}
      <div class="form-feedback error">
        <ul>
          {% for field in form.errors %}
            <li>{{ form.errors.messages[field] }}</li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}
  </div>
</div>

<!-- ==================== JS Logic ==================== -->
<script>
function formatCurrency(amount) {
  return '₹' + amount.toLocaleString('en-IN');
}

function handleInputChange(input) {
  let value = input.value.replace(/[^0-9]/g, '');
  if (value) input.value = value;
}

function updateCalculation(popupId) {
  const input = document.getElementById('calculator_monthly_installment');
  let value = parseInt(input.value.replace(/[^0-9]/g, '')) || 10000;
  value = Math.max(1000, Math.min(19000, value));
  updateValues(value);

  // Fill hidden fields for the popup form
  document.getElementById('hidden_monthly_installment').value = value;
  document.getElementById('hidden_premium_amount').value = document.getElementById('premium_amount').textContent;
  document.getElementById('hidden_pay_amount').value = document.getElementById('pay_amount').textContent;
  document.getElementById('hidden_free_amount').value = document.getElementById('free_amount').textContent;
  document.getElementById('hidden_total_amount').value = document.getElementById('total_amount').textContent;

  schemeShowPopup(popupId);
}

function schemeShowPopup(id) {
  const popup = document.getElementById(id);
  if (popup) popup.style.display = 'flex';
}

function schemeClosePopup(id) {
  const popup = document.getElementById(id);
  if (popup) popup.style.display = 'none';
}

function updateFromSlider(value) {
  const slider = document.getElementById('installment_slider');
  const min = slider.min;
  const max = slider.max;
  const percentage = ((value - min) / (max - min)) * 100;
  slider.style.setProperty('--slider-progress', percentage + '%');

  document.getElementById('premium_amount').textContent = formatCurrency(parseInt(value));
  document.getElementById('calculator_monthly_installment').value = value;

  const payAmount = value * 9;
  const freeAmount = value;
  const totalAmount = value * 10;
  document.getElementById('pay_amount').textContent = formatCurrency(payAmount);
  document.getElementById('free_amount').textContent = formatCurrency(freeAmount);
  document.getElementById('total_amount').textContent = formatCurrency(totalAmount);
}

function selectTab(button, value) {
  document.querySelectorAll('.price-tab').forEach(tab => tab.classList.remove('active'));
  button.classList.add('active');
  updateValues(value);
}

function updateValues(installmentAmount) {
  const input = document.getElementById('calculator_monthly_installment');
  input.value = installmentAmount;

  const slider = document.getElementById('installment_slider');
  slider.value = installmentAmount;
  const min = slider.min;
  const max = slider.max;
  const percentage = ((installmentAmount - min) / (max - min)) * 100;
  slider.style.setProperty('--slider-progress', percentage + '%');

  document.querySelectorAll('.price-tab').forEach(tab => {
    const tabValue = parseInt(tab.textContent.replace(/[^0-9]/g, ''));
    tab.classList.toggle('active', tabValue === installmentAmount);
  });

  const payAmount = installmentAmount * 9;
  const freeAmount = installmentAmount;
  const totalAmount = installmentAmount * 10;

  document.getElementById('premium_amount').textContent = formatCurrency(installmentAmount);
  document.getElementById('pay_amount').textContent = formatCurrency(payAmount);
  document.getElementById('free_amount').textContent = formatCurrency(freeAmount);
  document.getElementById('total_amount').textContent = formatCurrency(totalAmount);
}

document.addEventListener('DOMContentLoaded', function() {
  updateValues(10000);

  const form = document.getElementById('schemeForm');
  const bodyField = document.getElementById('schemeBody');
  const submitBtn = form.querySelector('.scheme-submit-btn');

  form.addEventListener('submit', () => {
    const monthly = document.getElementById('hidden_monthly_installment').value;
    const premium = document.getElementById('hidden_premium_amount').value;
    const pay = document.getElementById('hidden_pay_amount').value;
    const free = document.getElementById('hidden_free_amount').value;
    const total = document.getElementById('hidden_total_amount').value;
    const phone = document.getElementById('schemePhone').value;

    bodyField.value =
      `Scheme Calculator Request:\n` +
      `Phone: ${phone}\n` +
      `Monthly Installment: ${premium}\n` +
      `Total Investment: ${pay}\n` +
      `Free Premium: ${free}\n` +
      `Total Redeemable: ${total}`;

    submitBtn.textContent = "Processing...";
    submitBtn.style.opacity = "0.6";
    submitBtn.disabled = true;
  });
});
</script>

<!-- ================= CSS (Popup + Section) ================= -->
<style>
.scheme-popup-overlay {
  position: fixed;
  inset: 0;
  display: none;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.6);
  z-index: 9999;
}
.scheme-popup-content {
  background: #fff;
  padding: 25px;
  border-radius: 12px;
  width: 90%;
  max-width: 420px;
  position: relative;
  box-shadow: 0 10px 30px rgba(0,0,0,0.2);
}
.scheme-popup-close {
  position: absolute;
  top: 10px;
  right: 15px;
  font-size: 22px;
  cursor: pointer;
  color: #000;
}
.scheme-popup-content h3 {
  margin-bottom: 15px;
  text-align: center;
}
.scheme-popup-content input {
  display: block;
  width: 100%;
  margin-bottom: 12px;
  padding: 10px;
  border: 1px solid #ccc;
  border-radius: 6px;
}
.scheme-submit-btn {
  background: #000;
  color: #fff;
  width: 100%;
  padding: 12px;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  font-weight: 600;
}
.scheme-submit-btn:hover {
  background: #333;
}
</style>

{% schema %}
{
  "name": "Scheme Calculator",
  "settings": [
    {
      "type": "text",
      "id": "calculator_title",
      "label": "Calculator Title",
      "default": "SCHEME CALCULATOR"
    },
    {
      "type": "textarea",
      "id": "calculator_subtitle",
      "label": "Calculator Subtitle",
      "default": "Plan your savings smartly and enjoy exclusive scheme benefits with Lucira Jewelry."
    }
  ],
  "presets": [
    {
      "name": "Scheme Calculator"
    }
  ]
}
{% endschema %}


