<section class="scheme-calculator-section">
    <div class="page-width">
        <div class="scheme-calculator-content">
            {% if section.settings.calculator_title != blank %}
                <h1>{{ section.settings.calculator_title }}</h1>
            {% else %}
                <h1>SCHEME CALCULATOR</h1>
            {% endif %}
            {% if section.settings.calculator_subtitle != blank %}
                <p>{{ section.settings.calculator_subtitle }}</p>
            {% else %}
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut alconsequat.</p>
            {% endif %}
        </div>
        <div class="grid-row">
            <div class="grid-column left-column">
                <div class="calculator-form-wrapper">
                    <h3>Enter Your Monthly Installment To See Your Total Savings</h3>
                    <div class="calculator_form_container">
                        <label for="calculator_monthly_installment">Monthly Installment</label>
                        <div class="input-group">
                            <input type="text" id="calculator_monthly_installment" placeholder="₹10,000" value="10000" oninput="handleInputChange(this)" />
                            <button class="check-button" onclick="updateCalculation()">CHECK</button>
                        </div>
                        
                        <!-- Range Slider -->
                        <div class="range-slider-container">
                            <input type="range" id="installment_slider" min="10000" max="25000" step="100" value="10000" oninput="updateFromSlider(this.value)" />
                        </div>
                        
                        <p class="or-text">Or</p>
                        
                        <!-- Price Tabs -->
                        <div class="price-tabs">
                            <button class="price-tab" onclick="selectTab(this, 10000)">₹10,000</button>
                            <button class="price-tab" onclick="selectTab(this, 15000)">₹15,000</button>
                            <button class="price-tab active" onclick="selectTab(this, 20000)">₹20,000<span class="popular-badge">Popular</span></button>
                            <button class="price-tab" onclick="selectTab(this, 25000)">₹25,000</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="grid-column right-column">
                <div class="calculator-results">
                    <div class="result-item">
                        <div class="check-icon">✓</div>
                        <div class="result-text">
                            <span>You Pay 9 Installments</span>
                            <span class="result-amount" id="pay_amount">₹90,000</span>
                        </div>
                    </div>
                    <div class="result-item">
                        <div class="check-icon">✓</div>
                        <div class="result-text">
                            <span>You Get 10th Installments Free</span>
                            <span class="result-amount" id="free_amount">₹10,000</span>
                        </div>
                    </div>
                    <div class="total-redeemable">
                        <span>Total Redeemable amount</span>
                        <span class="total-amount" id="total_amount">₹1,00,000</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.scheme-calculator-section {
    padding: 60px 20px;
    background: #fff;
}

.page-width {
    max-width: 1200px;
    margin: 0 auto;
}

.scheme-calculator-content {
    text-align: center;
    margin-bottom: 50px;
}

.scheme-calculator-content h1 {
    font-size: 32px;
    font-weight: 600;
    margin-bottom: 15px;
    letter-spacing: 2px;
}

.scheme-calculator-content p {
    font-size: 14px;
    color: #666;
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.6;
}

.grid-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
}

.calculator-form-wrapper h3 {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 25px;
}

.calculator_form_container label {
    display: block;
    font-size: 14px;
    margin-bottom: 10px;
    color: #333;
}

.input-group {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
}

.input-group input {
    flex: 1;
    padding: 12px 15px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 16px;
}

.check-button {
    padding: 12px 30px;
    background: #9b7b6a;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    transition: background 0.3s;
}

.check-button:hover {
    background: #8a6a59;
}

.range-slider-container {
    margin: 25px 0;
}

#installment_slider {
    width: 100%;
    height: 6px;
    background: #e0e0e0;
    outline: none;
    border-radius: 3px;
    -webkit-appearance: none;
}

#installment_slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    background: #9b7b6a;
    cursor: pointer;
    border-radius: 50%;
}

#installment_slider::-moz-range-thumb {
    width: 20px;
    height: 20px;
    background: #9b7b6a;
    cursor: pointer;
    border-radius: 50%;
    border: none;
}

.or-text {
    text-align: center;
    margin: 20px 0;
    color: #999;
    font-size: 14px;
}

.price-tabs {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
}

.price-tab {
    padding: 15px 10px;
    border: 2px solid #e0e0e0;
    background: white;
    border-radius: 6px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s;
    position: relative;
}

.price-tab:hover {
    border-color: #9b7b6a;
}

.price-tab.active {
    border-color: #9b7b6a;
    background: #f9f9f9;
}

.popular-badge {
    display: block;
    font-size: 10px;
    color: #9b7b6a;
    margin-top: 5px;
    font-weight: 400;
}

.calculator-results {
    background: #f9f9f9;
    padding: 30px;
    border-radius: 8px;
}

.result-item {
    display: flex;
    align-items: flex-start;
    gap: 15px;
    margin-bottom: 20px;
}

.check-icon {
    width: 24px;
    height: 24px;
    background: #4caf50;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
}

.result-text {
    flex: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.result-text span:first-child {
    font-size: 14px;
    color: #333;
}

.result-amount {
    font-weight: 600;
    font-size: 16px;
}

.total-redeemable {
    margin-top: 30px;
    padding-top: 20px;
    border-top: 2px solid #ddd;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.total-redeemable span:first-child {
    font-size: 16px;
    font-weight: 500;
}

.total-amount {
    font-size: 24px;
    font-weight: 700;
    color: #4caf50;
}

@media (max-width: 768px) {
    .grid-row {
        grid-template-columns: 1fr;
    }
    
    .price-tabs {
        grid-template-columns: repeat(2, 1fr);
    }
}
</style>

<script>
function formatCurrency(amount) {
    return '₹' + amount.toLocaleString('en-IN');
}

function handleInputChange(input) {
    // Allow user to type freely
    let value = input.value.replace(/[^0-9]/g, '');
    
    if (value) {
        // Update the input with just numbers as they type
        input.value = value;
    }
}

function updateCalculation() {
    const input = document.getElementById('calculator_monthly_installment');
    let value = parseInt(input.value.replace(/[^0-9]/g, '')) || 10000;
    
    // Clamp value between min and max
    value = Math.max(10000, Math.min(25000, value));
    
    updateValues(value);
}

function updateFromSlider(value) {
    updateValues(parseInt(value));
}

function selectTab(button, value) {
    // Remove active class from all tabs
    document.querySelectorAll('.price-tab').forEach(tab => {
        tab.classList.remove('active');
    });
    
    // Add active class to clicked tab
    button.classList.add('active');
    
    updateValues(value);
}

function updateValues(installmentAmount) {
    // Update input field
    const input = document.getElementById('calculator_monthly_installment');
    input.value = installmentAmount;
    
    // Update slider
    const slider = document.getElementById('installment_slider');
    slider.value = installmentAmount;
    
    // Update active tab if it matches
    document.querySelectorAll('.price-tab').forEach(tab => {
        tab.classList.remove('active');
    });
    
    // Find and activate matching tab
    const tabs = document.querySelectorAll('.price-tab');
    tabs.forEach(tab => {
        const tabValue = parseInt(tab.textContent.replace(/[^0-9]/g, ''));
        if (tabValue === installmentAmount) {
            tab.classList.add('active');
        }
    });
    
    // Calculate amounts
    const payAmount = installmentAmount * 9;
    const freeAmount = installmentAmount;
    const totalAmount = installmentAmount * 10;
    
    // Update display
    document.getElementById('pay_amount').textContent = formatCurrency(payAmount);
    document.getElementById('free_amount').textContent = formatCurrency(freeAmount);
    document.getElementById('total_amount').textContent = formatCurrency(totalAmount);
}

// Initialize with default value
document.addEventListener('DOMContentLoaded', function() {
    updateValues(20000);
});
</script>

{% schema %}
{
  "name": "Scheme Calculator",
  "settings": [
    {
      "type": "text",
      "id": "calculator_title",
      "label": "Calculator Title",
      "default": "SCHEME CALCULATOR"
    },
    {
      "type": "textarea",
      "id": "calculator_subtitle",
      "label": "Calculator Subtitle",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    }
  ],
  "presets": [
    {
      "name": "Scheme Calculator"
    }
  ]
}
{% endschema %}