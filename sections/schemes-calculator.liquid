<section class="scheme-calculator-section">
  <div class="page-width">
    <div class="scheme-calculator-content">
      <h2>Jewelry Savings Scheme Calculator</h2>
      <p>Enter your monthly installment and see your total savings instantly!</p>
    </div>

    <div class="grid-row">
      <div class="grid-column left-column">
        <div class="calculator-form-wrapper">
          <h3>Enter Your Monthly Installment To See Your Total Savings</h3>
          <div class="calculator_form_container">
            <label for="calculator_monthly_installment">Monthly Installment</label>
            <div class="input-group">
              <div class="input-wrapper">
                <span class="currency-symbol">₹</span>
                <input
                  type="text"
                  id="calculator_monthly_installment"
                  placeholder="10,000"
                  value="10000"
                  oninput="handleInputChange(this)"
                />
              </div>
              <button
                class="check-button"
                onclick="updateCalculation('popupForm')"
              >
                CHECK
              </button>
            </div>

            <div class="range-slider-container">
              <input
                type="range"
                id="installment_slider"
                min="1000"
                max="19000"
                step="500"
                value="10000"
                oninput="updateFromSlider(this.value)"
              />
            </div>

            <p class="or-text">Or</p>
            <div class="price-tabs">
              <button class="price-tab" onclick="selectTab(this, 2000)">₹2,000</button>
              <button class="price-tab" onclick="selectTab(this, 5000)">₹5,000</button>
              <button class="price-tab popular-tab" onclick="selectTab(this, 10000)">₹10,000<span class="popular-badge">Popular</span></button>
              <button class="price-tab" onclick="selectTab(this, 19000)">₹19,000</button>
            </div>
          </div>
        </div>
      </div>

      <div class="grid-column right-column">
        <div class="calculator-results">
          <div class="result-item">
            <span>Your Premium amount/month</span>
            <span class="result-amount" id="premium_amount">₹10,000</span>
          </div>
          <div class="result-item">
            <span>Total Investment (9 months)</span>
            <span class="result-amount" id="pay_amount">₹90,000</span>
          </div>
          <div class="result-item">
            <span>We Pay your 10th Premium</span>
            <span class="result-amount" id="free_amount">₹10,000</span>
          </div>
          <div class="total-redeemable">
            <span>Total Redeemable Amount</span>
            <span class="total-amount" id="total_amount">₹1,00,000</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- POPUP -->
<div id="popupForm" class="popup-overlay" style="display:none;">
  <div class="popup-content">
    <span class="close-popup" onclick="closePopup('popupForm')">&times;</span>
    <h3>Get Your Scheme Details</h3>
    <form id="schemeLeadForm" onsubmit="submitSchemeForm(event)">
      <input type="text" name="full_name" placeholder="Full Name" required />
      <input type="tel" name="phone_number" placeholder="Phone Number" required />

      <!-- Hidden fields -->
      <input type="hidden" name="monthly_installment" id="hidden_monthly_installment" />
      <input type="hidden" name="premium_amount" id="hidden_premium_amount" />
      <input type="hidden" name="pay_amount" id="hidden_pay_amount" />
      <input type="hidden" name="free_amount" id="hidden_free_amount" />
      <input type="hidden" name="total_amount" id="hidden_total_amount" />

      <button type="submit" class="submit-btn">Submit</button>
    </form>
  </div>
</div>

<style>
.popup-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.popup-content {
  background: #fff;
  padding: 30px;
  width: 90%;
  max-width: 400px;
  border-radius: 10px;
  position: relative;
}
.close-popup {
  position: absolute;
  right: 10px;
  top: 10px;
  font-size: 22px;
  cursor: pointer;
}
.popup-content input {
  display: block;
  width: 100%;
  padding: 10px;
  margin: 8px 0;
  border-radius: 5px;
  border: 1px solid #ccc;
}
.submit-btn {
  background: #000;
  color: #fff;
  padding: 12px;
  border: none;
  border-radius: 5px;
  width: 100%;
  cursor: pointer;
}
</style>

<script>
function formatCurrency(amount) {
  return '₹' + amount.toLocaleString('en-IN');
}

function handleInputChange(input) {
  let value = input.value.replace(/[^0-9]/g, '');
  if (value) input.value = value;
}

function updateCalculation(popupId) {
  const input = document.getElementById('calculator_monthly_installment');
  let value = parseInt(input.value.replace(/[^0-9]/g, '')) || 10000;
  value = Math.max(1000, Math.min(19000, value));
  updateValues(value);

  // Fill hidden fields before showing popup
  document.getElementById('hidden_monthly_installment').value = value;
  document.getElementById('hidden_premium_amount').value = document.getElementById('premium_amount').textContent;
  document.getElementById('hidden_pay_amount').value = document.getElementById('pay_amount').textContent;
  document.getElementById('hidden_free_amount').value = document.getElementById('free_amount').textContent;
  document.getElementById('hidden_total_amount').value = document.getElementById('total_amount').textContent;

  // Show popup
  showPopup(popupId);
}

function showPopup(id) {
  const popup = document.getElementById(id);
  if (popup) popup.style.display = 'flex';
}

function closePopup(id) {
  const popup = document.getElementById(id);
  if (popup) popup.style.display = 'none';
}

function updateFromSlider(value) {
  const slider = document.getElementById('installment_slider');
  const min = slider.min;
  const max = slider.max;
  const percentage = ((value - min) / (max - min)) * 100;
  slider.style.setProperty('--slider-progress', percentage + '%');

  document.getElementById('premium_amount').textContent = formatCurrency(parseInt(value));
  document.getElementById('calculator_monthly_installment').value = value;

  const payAmount = value * 9;
  const freeAmount = value;
  const totalAmount = value * 10;
  document.getElementById('pay_amount').textContent = formatCurrency(payAmount);
  document.getElementById('free_amount').textContent = formatCurrency(freeAmount);
  document.getElementById('total_amount').textContent = formatCurrency(totalAmount);
}

function selectTab(button, value) {
  document.querySelectorAll('.price-tab').forEach(tab => tab.classList.remove('active'));
  button.classList.add('active');
  updateValues(value);
}

function updateValues(installmentAmount) {
  document.getElementById('calculator_monthly_installment').value = installmentAmount;
  const slider = document.getElementById('installment_slider');
  slider.value = installmentAmount;

  const payAmount = installmentAmount * 9;
  const freeAmount = installmentAmount;
  const totalAmount = installmentAmount * 10;

  document.getElementById('premium_amount').textContent = formatCurrency(installmentAmount);
  document.getElementById('pay_amount').textContent = formatCurrency(payAmount);
  document.getElementById('free_amount').textContent = formatCurrency(freeAmount);
  document.getElementById('total_amount').textContent = formatCurrency(totalAmount);
}

// Submit form handler
function submitSchemeForm(event) {
  event.preventDefault();
  const form = event.target;
  const data = Object.fromEntries(new FormData(form));

  console.log("Form Submitted:", data);

  alert("Thank you! Our team will contact you soon.");
  closePopup('popupForm');
}

// Initialize
document.addEventListener('DOMContentLoaded', function() {
  updateValues(10000);
});
</script>




<style>
    .scheme-calculator-section{padding:60px 0px;background:#fff}
    .scheme-calculator-content{text-align:center;margin-bottom:50px}
    .scheme-calculator-content h2{margin-bottom:15px;margin-top:0;font-weight:500;font-size:24px;line-height:150%;letter-spacing:.7px;text-align:center;vertical-align:middle;text-transform:uppercase}
    .scheme-calculator-content p{color: #1a1a1a; max-width: 690px; margin: 0 auto; font-weight: 400; font-size: 16px; letter-spacing: 1px; text-align: center; vertical-align: middle; line-height: 1.6;}
    .grid-row{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}
    .calculator-form-wrapper h3 {font-weight: 500; font-size: 20px; line-height: 150%; letter-spacing: 0.6px; vertical-align: middle; text-transform: capitalize; margin-top: 0; margin-bottom: 18px;}
    .calculator_form_container label{display:block;font-size:14px;margin-bottom:10px;color:#1A1A1A;}
