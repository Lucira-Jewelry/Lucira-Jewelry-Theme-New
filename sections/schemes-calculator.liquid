        .price-tab { padding: 16px 8px; border: 0px solid #e0e0e0; background: #F2F2F2 !important; border-radius: 8px; cursor: pointer; font-size: 12px; font-weight: 500; transition: all .3s; position: relative; font-family: 'Futura Std', sans-serif; color: #1A1A1A; }
