        constellationGroups.forEach((group, index) => {
            const dataSign = group.getAttribute('data-sign');
            let signName = dataSign;
            
            // Remove 'pre-' prefix for pre-sequence constellations to match text classes
            if (dataSign && dataSign.startsWith('pre-')) {
                signName = dataSign.replace('pre-', '');
            }
            
            const externalText = document.querySelector(`.external-text.${signName}`);
            
            // Click event for both desktop and mobile
            group.addEventListener('click', () => {
                // Only allow clicks for second sequence constellations when in interactive mode
                if (!isInteractiveMode || dataSign.startsWith('pre-')) return;
                
                // Remove active class from all constellation groups and external texts
                document.querySelectorAll('.constellation-group').forEach(g => {
                    g.classList.remove('active');
                });
                document.querySelectorAll('.external-text').forEach(text => {
                    text.classList.remove('active');
                });
                
                // Add active class to clicked constellation and its text
                group.classList.add('active');
                if (externalText) {
                    externalText.classList.add('active');
                }
            });
        });
        
        // Mobile text click functionality
        setupMobileTextClick();
    });

    // Mobile text click functionality
    function setupMobileTextClick() {
        if (window.innerWidth <= 767) {
            const externalTexts = document.querySelectorAll('.external-text');
            
            externalTexts.forEach(text => {
                text.style.pointerEvents = 'auto'; // Enable pointer events on mobile
                text.addEventListener('click', function() {
                    // Remove active from all
                    document.querySelectorAll('.constellation-group').forEach(group => {
                        group.classList.remove('active');
                    });
                    externalTexts.forEach(otherText => {
                        otherText.classList.remove('active');
                    });
                    
                    // Add active to clicked text and corresponding constellation
                    this.classList.add('active');
                    
                    const signClass = this.className.split(' ').find(cls => 
                        ['leo', 'aries', 'gemini', 'sagittarius', 'scorpio', 'virgo'].includes(cls)
                    );
                    
                    if (signClass) {
                        const constellationGroup = document.querySelector(`[data-sign="${signClass}"]`);
                        if (constellationGroup) {
                            constellationGroup.classList.add('active');
                        }
                    }
                });
            });
        }
    }

    // Call on resize to handle mobile/desktop switching
    window.addEventListener('resize', () => {
        setupMobileTextClick();
    });
