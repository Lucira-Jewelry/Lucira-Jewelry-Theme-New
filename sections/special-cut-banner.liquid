{% comment %} <script>
function createSparkles() {
    const sparklesContainer = document.getElementById('sparkles');
    sparklesContainer.innerHTML = '';
    
    for (let i = 0; i < 12; i++) {
        const sparkle = document.createElement('div');
        sparkle.className = 'sparkle';
        
        const angle = (i / 12) * 2 * Math.PI;
        const radius = 120 + Math.random() * 80;
        const x = Math.cos(angle) * radius + 200;
        const y = Math.sin(angle) * radius + 200;
        
        sparkle.style.left = x + 'px';
        sparkle.style.top = y + 'px';
        sparkle.style.animationDelay = (i * 0.2) + 's';
        
        sparklesContainer.appendChild(sparkle);
    }
}

function initializeDiamond() {
    const diamond = document.getElementById('diamond');
    const diamondImg = diamond.querySelector('img');
    const restartBtn = document.getElementById('restartBtn');

    // Create sparkles immediately
    createSparkles();

    // Show diamond immediately without fade-in delay
    diamondImg.style.opacity = '1';
    diamond.style.opacity = '1';
    
    // Start continuous pulsing animation immediately
    diamond.classList.add('animate');
    
    // Hide restart button since we want it permanent
    restartBtn.style.display = 'none';
}

function restartAnimation() {
    const diamond = document.getElementById('diamond');
    const sparklesContainer = document.getElementById('sparkles');

    // Briefly reset and restart (keeping diamond visible)
    diamond.classList.remove('animate');
    sparklesContainer.innerHTML = '';
    
    setTimeout(() => {
        createSparkles();
        diamond.classList.add('animate');
    }, 100);
}

// Initialize immediately when page loads - no delay
window.addEventListener('load', initializeDiamond);

// Also initialize immediately if DOM is already ready
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeDiamond);
} else {
    initializeDiamond();
}
</script> {% endcomment %}
