            constellation.classList.add('hide-constellations');
        });
        
        // Wait for hide animation, then enter interactive mode
        setTimeout(() => {
            const wrapper = document.querySelector('.special-cuts-wrapper');
            wrapper.classList.add('interactive-mode');
            isInteractiveMode = true;
            
            // Reset constellation visibility for click interactions
            constellations.forEach(constellation => {
                constellation.classList.remove('hide-constellations');
            });
            
            // Set default active state - activate the first constellation (Leo)
            setDefaultActiveConstellation();
            
        }, 800);
