    function setDefaultActiveConstellation() {
        // Set Leo as default active
        const leoGroup = document.querySelector('.constellation-group[data-sign="leo"]');
        const leoText = document.querySelector('.external-text.leo');
        
        if (leoGroup) {
            leoGroup.classList.add('active');
        }
        if (leoText) {
            leoText.classList.add('active');
        }
    }

