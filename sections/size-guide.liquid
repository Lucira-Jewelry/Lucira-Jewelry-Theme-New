{% comment %}
  Size Guide Drawer Section
{% endcomment %}

{% comment %}
  Size Guide Drawer Section
{% endcomment %}

<section id="size-guide-section" class="size-guide-section">
  <div class="size-drawer-overlay" id="size-drawer-overlay"></div>
  <div class="size-drawer" id="size-drawer">
    <div class="size-drawer-wrapper">
      <div class="size-drawer-title-wrap">
        <div class="title-wrapper">{{ section.settings.size_guide_title }}</div>
        <div class="close-button" id="close-size-button">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"> <mask id="mask0_10852_4798" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24"> <rect width="24" height="24" fill="#D9D9D9"/> </mask> <g mask="url(#mask0_10852_4798)"> <path d="M12 13.0635L8.75377 16.3095C8.60893 16.4545 8.43335 16.5253 8.22702 16.522C8.02052 16.5188 7.84485 16.4448 7.70002 16.3C7.55518 16.1552 7.48277 15.9779 7.48277 15.7682C7.48277 15.5586 7.55518 15.3813 7.70002 15.2365L10.9365 12L7.69052 8.77874C7.54552 8.6339 7.47468 8.45665 7.47802 8.24699C7.48118 8.03749 7.55518 7.86032 7.70002 7.71549C7.84485 7.57049 8.0221 7.49799 8.23177 7.49799C8.44143 7.49799 8.61868 7.57049 8.76352 7.71549L12 10.9615L15.2213 7.71549C15.3661 7.57049 15.5417 7.49799 15.748 7.49799C15.9545 7.49799 16.1302 7.57049 16.275 7.71549C16.4302 7.87049 16.5078 8.05024 16.5078 8.25474C16.5078 8.45924 16.4302 8.6339 16.275 8.77874L13.0385 12L16.2845 15.2462C16.4295 15.3911 16.502 15.5667 16.502 15.773C16.502 15.9795 16.4295 16.1552 16.2845 16.3C16.1295 16.4552 15.9498 16.5327 15.7453 16.5327C15.5408 16.5327 15.3661 16.4552 15.2213 16.3L12 13.0635Z" fill="#666666"/> </g> </svg>
        </div>
      </div>
      {% if section.settings.size_guide_subtitle != blank %}
        <div class="size-subtitle">{{ section.settings.size_guide_subtitle }}</div>
      {% endif %}
    </div>

    <div class="size-guide-details-wrapper">
      {% if section.settings.size_guide_paragraph != blank %}
        <div class="size-guide-paragraph">{{ section.settings.size_guide_paragraph }}</div>
      {% endif %}

      <div class="grid-row">
        {% for block in section.blocks %}
          <div class="grid-column" {{ block.shopify_attributes }}>
            {% if block.settings.size_guide_link != blank %}
              <a href="{{ block.settings.size_guide_link }}" class="size-guide-item-wrapper size-link" target="_blank">
            {% else %}
              <div class="size-guide-item-wrapper">
            {% endif %}
                {% if block.settings.image_picker != blank %}
                  <div class="size-guide-image">
                    <img src="{{ block.settings.image_picker | img_url: '400x' }}" title="{{ block.settings.size_guide_heading | escape }}"alt="{{ block.settings.size_guide_heading | escape }}" width="410" height="205">
                  </div>
                {% endif %}

                <div class="size-item-title-wrapper">
                  {% if block.settings.size_guide_heading != blank %}
                    <h4>{{ block.settings.size_guide_heading }}</h4>
                  {% endif %}
                  {% if block.settings.size_guide_text != blank %}
                    <p>{{ block.settings.size_guide_text }}</p>
                  {% endif %}
                </div>

                {% if block.settings.size_guide_link != blank %}
                  <span class="arrow">{{- 'arrow.svg' | inline_asset_content -}}</span>
                {% endif %}
                {% if block.settings.size_guide_link != blank %}
                  </a>
                {% else %}
                  </div>
                {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Size Guide Drawer",
  "tag": "section",
  "class": "section-size-guide-drawer",
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "size_guide_title",
      "label": "Title",
      "default": "Size Guide"
    },
    {
      "type": "text",
      "id": "size_guide_subtitle",
      "label": "Subtitle"
    },
    {
      "type": "richtext",
      "id": "size_guide_paragraph",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "size_guide_item",
      "name": "Size Guide Item",
      "settings": [
        {
          "type": "text",
          "id": "size_guide_heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "size_guide_text",
          "label": "Text"
        },
        {
          "type": "image_picker",
          "id": "image_picker",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "size_guide_link",
          "label": "Link URL"
        },
        {
          "type": "text",
          "id": "size_guide_link_text",
          "label": "Link Text",
          "default": "Learn more"
        },
        {
          "type": "checkbox",
          "id": "size_guide_show_arrow",
          "label": "Show arrow after link text",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Size Guide Drawer",
      "blocks": [
        {
          "type": "size_guide_item"
        },
        {
          "type": "size_guide_item"
        }
      ]
    }
  ]
}
{% endschema %}