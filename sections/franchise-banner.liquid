 <style>
.franchise-hero-enhanced{display:grid;grid-template-columns:450px 1fr;gap:60px;padding:80px 50px 0 50px;max-width:1400px;margin:0 auto;align-items:center;min-height:500px}
.franchise-hero-enhanced__content{padding-right:20px}
.franchise-hero-enhanced__title{font-size:32px;font-weight:500;letter-spacing:3px;margin-bottom:25px;text-transform:uppercase;color:#2c2c2c;line-height:1.3}
.franchise-hero-enhanced__text{font-size:14px;line-height:1.9;color:#666;margin-bottom:35px;font-weight:400}
.franchise-hero-enhanced__button{display:inline-block;padding:16px 45px;background-color:#a68380;color:#fff;text-decoration:none;text-transform:uppercase;letter-spacing:1.5px;font-size:16px;font-weight:500;border-radius:8px;transition:all .3s ease;box-shadow:0 4px 15px rgba(168,148,132,.2);cursor:pointer;border:none;font-family:'futura std'}
.franchise-hero-enhanced__button:hover{background-color:#a68380;transform:translateY(-2px)}
.franchise-hero-enhanced__gallery{position:relative;height:500px}
.franchise-hero-enhanced__image{position:absolute;overflow:hidden;background-color:#f5f5f5;box-shadow:0 2px 10px rgba(0,0,0,.1)}
.franchise-hero-enhanced__image img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s ease}
.franchise-hero-enhanced__image:nth-child(1){bottom:62%;left:10%;width:48%;height:38%;z-index:2}
.franchise-hero-enhanced__image:nth-child(2){top:18%;left:59%;width:13%;height:20%;z-index:2}
.franchise-hero-enhanced__image:nth-child(3){top:0;left:73%;width:28%;height:60%;z-index:2}
.franchise-hero-enhanced__image:nth-child(4){top:39.5%;left:19%;width:24%;height:28%;z-index:2}
.franchise-hero-enhanced__image:nth-child(5){top:39.5%;left:44%;width:28%;height:62%;z-index:2}
.franchise-hero-enhanced__image:nth-child(6){bottom:3%;left:73%;width:31%;height:35%;z-index:2}
.franchise-hero-enhanced__image .placeholder-svg{width:100%;height:100%;background-color:#e8e8e8}
.no-scroll{overflow:hidden}
.franchise-overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);display:none;align-items:center;justify-content:center;z-index:99999999}
.franchise-form-container{background:#fff;border-radius:12px;width:90%;max-width:650px;max-height:90vh;position:relative;box-shadow:0 10px 30px rgba(0,0,0,.2);overflow:hidden}
.franchise-close-btn{position:absolute;top:15px;right:20px;font-size:28px;cursor:pointer;color:#666;line-height:1;transition:color .3s;z-index:10;background:#fff;width:35px;height:35px;border-radius:50%;display:flex;align-items:center;justify-content:center}
.franchise-close-btn:hover{color:#000}
.franchise-topic{font-weight:500;font-size:20px;line-height:1.4;letter-spacing:1.5px;text-transform:uppercase;margin:0;padding:25px 30px;text-align:center;color:#2c2c2c;background:#f8f8f8;border-bottom:1px solid #e0e0e0}
.franchise-iframe-wrapper{width:100%;height:calc(90vh - 80px);max-height:600px;overflow:hidden}
.franchise-iframe-wrapper iframe{width:100%;height:100%;border:none}
@media (max-width:1200px){
.franchise-hero-enhanced{grid-template-columns:400px 1fr;gap:40px}
.franchise-hero-enhanced__title{font-size:32px}
.franchise-hero-enhanced__gallery{height:450px}
}
@media (max-width:968px){
.franchise-hero-enhanced{grid-template-columns:1fr;padding:60px 30px;gap:50px}
.franchise-hero-enhanced__content{padding-right:0;text-align:left}
.franchise-hero-enhanced__title{font-size:30px}
.franchise-hero-enhanced__gallery{height:400px}
.franchise-form-container{max-width:90%}
}
@media (max-width:576px){
.franchise-hero-enhanced{padding:0 20px}
.franchise-hero-enhanced__title{font-size:18px;letter-spacing:2px;text-align:left;margin-bottom:0;margin-top:30px}
.franchise-hero-enhanced__text{font-size:13px;text-align:left}
.franchise-hero-enhanced__button{padding:14px 35px;font-size:12px;position:relative}
.franchise-hero-enhanced__gallery{position:relative;height:275px}
.franchise-hero-enhanced__image:nth-child(1){top:0;left:0;width:42%;height:31%;z-index:2}
.franchise-hero-enhanced__image:nth-child(2){top:13%;left:43%;width:20%;height:18%;z-index:2}
.franchise-hero-enhanced__image:nth-child(3){top:-5%;left:64%;width:29%;height:59%;z-index:2}
.franchise-hero-enhanced__image:nth-child(4){top:33%;left:3%;width:28%;height:28%;z-index:2}
.franchise-hero-enhanced__image:nth-child(5){top:32%;left:32%;width:31%;height:64%;z-index:2}
.franchise-hero-enhanced__image:nth-child(6){top:55%;left:64%;width:36%;height:33%;z-index:2}
.franchise-form-container{width:95%;max-width:95%}
.franchise-topic{font-size:16px;padding:20px 15px}
.franchise-iframe-wrapper{height:calc(90vh - 70px)}
.franchise-close-btn{width:30px;height:30px;font-size:24px;top:10px;right:15px}
}
@media (min-width:300px) and (max-width:380px){
.franchise-hero-enhanced__button{padding:14px 35px;font-size:12px;position:relative}
}
</style>

<section class="franchise-hero-enhanced">
  <div class="franchise-hero-enhanced__content">
    <h1 class="franchise-hero-enhanced__title">{{ section.settings.title }}</h1>
    <p class="franchise-hero-enhanced__text">{{ section.settings.description }}</p>
    <button class="franchise-hero-enhanced__button" onclick="openFranchiseOverlay()">
      {{ section.settings.button_text }}
    </button>
  </div>

  <div class="franchise-hero-enhanced__gallery">
    {% assign image_count = 0 %}
    {% for block in section.blocks %}
      {% if image_count < 6 %}
        <div class="franchise-hero-enhanced__image" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.image.alt | default: section.settings.title }}
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
        {% assign image_count = image_count | plus: 1 %}
      {% endif %}
    {% endfor %}
    
    {% if image_count < 6 %}
      {% for i in (1..6) %}
        {% assign remaining = 6 | minus: image_count %}
        {% if forloop.index <= remaining %}
          <div class="franchise-hero-enhanced__image">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}
      {% endfor %}
    {% endif %}
  </div>
</section>

<div id="franchiseOverlay" class="franchise-overlay">
  <div class="franchise-form-container">
    <span class="franchise-close-btn" onclick="closeFranchiseOverlay()">&times;</span>
    
    <h3 class="franchise-topic">{{ section.settings.form_title }}</h3>
    
    <div class="franchise-iframe-wrapper">
     <iframe 
        src="https://docs.google.com/forms/d/e/1FAIpQLScNWHT4WkZTuS8DCCQUOvM7MeUrdOrwqKxxcYfsEJUlapR5CQ/viewform?usp=sharing&ouid=113968896276132378000"
        frameborder="0"
        marginheight="0"
        marginwidth="0"
        loading="lazy">
        Loading…
      </iframe> 
    </div>
  </div>
</div>


<script>
  function openFranchiseOverlay() {
    const overlay = document.getElementById('franchiseOverlay');
    overlay.style.display = 'flex';
    document.body.classList.add('no-scroll');

    // Track event in dataLayer
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'formOpen',
      formName: 'Franchise Registration Form',
      formType: 'google_form',
      timestamp: new Date().toISOString()
    });
  }

  function closeFranchiseOverlay() {
    const overlay = document.getElementById('franchiseOverlay');
    overlay.style.display = 'none';
    document.body.classList.remove('no-scroll');
  }

  document.addEventListener('DOMContentLoaded', function () {
    const overlay = document.getElementById('franchiseOverlay');

    overlay.addEventListener('click', function (e) {
      if (e.target === overlay) closeFranchiseOverlay();
    });
  });
</script>

{% schema %}
{
  "name": "Franchise Hero Enhanced",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "LUCIRA'S FRANCHISE"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut alconsequat."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "REGISTER NOW"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form Title",
      "default": "REGISTRATION FORM"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Position {{ block_index }}: {% if block_index == 1 %}Large top-left{% elsif block_index == 2 %}Small top-center{% elsif block_index == 3 %}Medium top-right{% elsif block_index == 4 %}Small middle-left{% elsif block_index == 5 %}Large center (main){% elsif block_index == 6 %}Medium bottom-right{% endif %}"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Franchise Hero Enhanced",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %} 


