{% comment %}
  Section: Franchise Hero - Enhanced Version
  File: sections/franchise-hero-enhanced.liquid
{% endcomment %}

<style>
  .franchise-hero-enhanced {
    display: grid;
    grid-template-columns: 450px 1fr;
    gap: 60px;
    padding: 80px 50px;
    max-width: 1400px;
    margin: 0 auto;
    align-items: center;
    min-height: 500px;
  }

  .franchise-hero-enhanced__content {
    padding-right: 20px;
  }

  .franchise-hero-enhanced__title {
    font-size: 38px;
    font-weight: 300;
    letter-spacing: 3px;
    margin-bottom: 25px;
    text-transform: uppercase;
    color: #2c2c2c;
    line-height: 1.3;
  }

  .franchise-hero-enhanced__text {
    font-size: 14px;
    line-height: 1.9;
    color: #666;
    margin-bottom: 35px;
    font-weight: 300;
  }

  .franchise-hero-enhanced__button {
    display: inline-block;
    padding: 16px 45px;
    background-color: #a89484;
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-size: 11px;
    font-weight: 500;
    border-radius: 4px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(168, 148, 132, 0.2);
  }

  .franchise-hero-enhanced__button:hover {
    background-color: #8a7869;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(168, 148, 132, 0.3);
  }

  .franchise-hero-enhanced__gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: 12px;
    height: 500px;
  }

  .franchise-hero-enhanced__image {
    position: relative;
    overflow: hidden;
    border-radius: 6px;
    background-color: #f5f5f5;
  }

  .franchise-hero-enhanced__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .franchise-hero-enhanced__image:hover img {
    transform: scale(1.05);
  }

  /* Grid positioning for 6 images matching the design */
  .franchise-hero-enhanced__image:nth-child(1) {
    grid-column: 1 / 3;
    grid-row: 1 / 2;
  }

  .franchise-hero-enhanced__image:nth-child(2) {
    grid-column: 3 / 4;
    grid-row: 1 / 2;
  }

  .franchise-hero-enhanced__image:nth-child(3) {
    grid-column: 3 / 4;
    grid-row: 2 / 3;
  }

  .franchise-hero-enhanced__image:nth-child(4) {
    grid-column: 1 / 2;
    grid-row: 2 / 4;
  }

  .franchise-hero-enhanced__image:nth-child(5) {
    grid-column: 2 / 3;
    grid-row: 2 / 4;
  }

  .franchise-hero-enhanced__image:nth-child(6) {
    grid-column: 3 / 4;
    grid-row: 3 / 4;
  }

  /* Placeholder styling */
  .franchise-hero-enhanced__image .placeholder-svg {
    width: 100%;
    height: 100%;
    background-color: #e8e8e8;
  }

  @media (max-width: 1200px) {
    .franchise-hero-enhanced {
      grid-template-columns: 400px 1fr;
      gap: 40px;
    }

    .franchise-hero-enhanced__title {
      font-size: 32px;
    }

    .franchise-hero-enhanced__gallery {
      height: 450px;
    }
  }

  @media (max-width: 968px) {
    .franchise-hero-enhanced {
      grid-template-columns: 1fr;
      padding: 60px 30px;
      gap: 50px;
    }

    .franchise-hero-enhanced__content {
      padding-right: 0;
      text-align: center;
    }

    .franchise-hero-enhanced__title {
      font-size: 30px;
    }

    .franchise-hero-enhanced__gallery {
      height: 400px;
    }
  }

  @media (max-width: 576px) {
    .franchise-hero-enhanced {
      padding: 40px 20px;
    }

    .franchise-hero-enhanced__title {
      font-size: 24px;
      letter-spacing: 2px;
    }

    .franchise-hero-enhanced__text {
      font-size: 13px;
    }

    .franchise-hero-enhanced__button {
      padding: 14px 35px;
      font-size: 10px;
    }

    .franchise-hero-enhanced__gallery {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(4, 120px);
      height: auto;
      gap: 10px;
    }

    /* Simplified mobile layout */
    .franchise-hero-enhanced__image:nth-child(1) {
      grid-column: 1 / 3;
      grid-row: 1 / 2;
    }

    .franchise-hero-enhanced__image:nth-child(2) {
      grid-column: 1 / 2;
      grid-row: 2 / 3;
    }

    .franchise-hero-enhanced__image:nth-child(3) {
      grid-column: 2 / 3;
      grid-row: 2 / 3;
    }

    .franchise-hero-enhanced__image:nth-child(4) {
      grid-column: 1 / 2;
      grid-row: 3 / 4;
    }

    .franchise-hero-enhanced__image:nth-child(5) {
      grid-column: 2 / 3;
      grid-row: 3 / 4;
    }

    .franchise-hero-enhanced__image:nth-child(6) {
      grid-column: 1 / 3;
      grid-row: 4 / 5;
    }
  }
</style>

<section class="franchise-hero-enhanced">
  <div class="franchise-hero-enhanced__content">
    <h1 class="franchise-hero-enhanced__title">{{ section.settings.title }}</h1>
    <p class="franchise-hero-enhanced__text">{{ section.settings.description }}</p>
    <a href="{{ section.settings.button_link }}" class="franchise-hero-enhanced__button">
      {{ section.settings.button_text }}
    </a>
  </div>

  <div class="franchise-hero-enhanced__gallery">
    {% assign image_count = 0 %}
    {% for block in section.blocks %}
      {% if image_count < 6 %}
        <div class="franchise-hero-enhanced__image" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.image.alt | default: section.settings.title }}
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
        {% assign image_count = image_count | plus: 1 %}
      {% endif %}
    {% endfor %}
    
    {% comment %} Fill remaining slots with placeholders if less than 6 images {% endcomment %}
    {% if image_count < 6 %}
      {% for i in (1..6) %}
        {% assign remaining = 6 | minus: image_count %}
        {% if forloop.index <= remaining %}
          <div class="franchise-hero-enhanced__image">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}
      {% endfor %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Franchise Hero Enhanced",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "LUCIRA'S FRANCHISE"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut alconsequat."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "REGISTER NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "info": "Link to registration page or form"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Recommended: 800x600px. Add up to 6 images for the gallery."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Franchise Hero Enhanced",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}