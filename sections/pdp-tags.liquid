<div class="pdp-tags-container page-width">
  <div class="pdp-tags-title">Related Categories</div>
  <div class="pdp-tags">
    {% for tag in product.tags %}
      {% unless tag == 'YMAL' %}
        <div class="pdp-tag">
          <a 
            href="/collections/all/{{ tag | handleize }}" 
            class="pdp-tag-link"
            data-tag="{{ tag }}"
          >
            {{ tag }}
          </a>
        </div>
      {% endunless %}
    {% endfor %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tagLinks = document.querySelectorAll('.pdp-tag-link');

    tagLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        const tagName = this.dataset.tag;

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'promoClick',
          creative_name: 'PDP Tags - ' + tagName,
        });

        // Optional: Debug log
        console.log('Tag clicked:', tagName);
      });
    });
  });
</script>

{% schema %}
{
  "name": "PDP Tags",
  "settings": [],
  "presets": [
    {
      "name": "PDP Tags"
    }
  ]
}
{% endschema %}
