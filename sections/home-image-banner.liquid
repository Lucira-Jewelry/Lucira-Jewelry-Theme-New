<section class="home-image-banner {{ section.settings.banner_height }} {{ section.settings.banner_height_mobile }}">
  <slideshow-component class="slider-mobile-gutter" role="region" aria-label="Home Image Banner">
    <div
      class="home-image-banner-swiper grid grid--1-col slider slider--everywhere"
      id="Slider-{{ section.id }}"
      data-autoplay="{{ section.settings.autoplay }}"
      data-speed="5"
    >
      {% for block in section.blocks %}
        <div class="swiper-slide grid__item slider__slide" id="Slide-{{ section.id }}-{{ forloop.index }}" {{ block.shopify_attributes }}>
          <a
            id="{{ block.settings.slide_id }}"
            href="{{ block.settings.slide_url }}"
            data-promo-id="{{ block.settings.dlv_promo_id }}"
            data-promo-name="{{ block.settings.dlv_promo_name }}"
            onclick="handleGTMPromoBannerClick(event)"
            aria-label="Shop our collection"
            class="home-image-banner-slider-item"
          >
            <picture>
            <!-- Mobile -->
            <source
              media="(max-width: 749px)"
              srcset="
                {{ block.settings.mobile_slide_image | image_url: width: 375 }} 375w,
                {{ block.settings.mobile_slide_image | image_url: width: 540 }} 540w,
                {{ block.settings.mobile_slide_image | image_url: width: 750 }} 750w
              "
              sizes="100vw"
            >

            <!-- Desktop -->
            <source
              media="(min-width: 750px)"
              srcset="
                {{ block.settings.slide_image | image_url: width: 960 }} 960w,
                {{ block.settings.slide_image | image_url: width: 1200 }} 1200w,
                {{ block.settings.slide_image | image_url: width: 1600 }} 1600w,
                {{ block.settings.slide_image | image_url: width: 1920 }} 1920w
              "
              sizes="100vw"
            >

            <!-- Fallback -->
            <img
              class="home-image-banner-image"
              src="{{ block.settings.slide_image | image_url: width: 1200 }}"
              width="1920"
              height="823"
              alt="{{ block.settings.slide_image.alt | escape }}"
              title="{{ block.settings.slide_image.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              decoding="async"
              {% if forloop.first %}fetchpriority="high"{% endif %}
            >
          </picture>


            <div class="home-image-banner-slider-content {{ section.settings.content_position }}">
              <div>
                <p class="home-image-banner-slider-content-header">{{ block.settings.slide_header }}</p>
                <p>{{ block.settings.slide_subheader }}</p>
                {% if block.settings.show_button %}
                  <button class="home-image-banner-slider-content-button">
                    {{ block.settings.slide_button_text }}
                  </button>
                {% endif %}
              </div>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="slider-buttons no-js-hidden">
        <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="Previous slide">
          {{ 'icon-left-arrow-banner.svg' | inline_asset_content }}
        </button>
        <div class="slider-counter slider-counter--dots">
          <div class="slideshow__control-wrapper">
            {%- for block in section.blocks -%}
              <button class="slider-counter__link slider-counter__link--dots link" aria-label="Load slide {{ forloop.index }} of {{ forloop.length }}" aria-controls="Slider-{{ section.id }}">
                <span class="dot"></span>
              </button>
            {%- endfor -%}
          </div>
        </div>
        <button type="button" class="slider-button slider-button--next" name="next" aria-label="Next slide">
          {{ 'icon-right-arrow-banner.svg' | inline_asset_content }}
        </button>
      </div>
    {%- endif -%}
  </slideshow-component>
</section>

<style>
  .home-image-banner-swiper{width:100%;height:100%; display: flex; flex-wrap: inherit; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth;}
  .home-image-banner-swiper .slider__slide{display:flex;justify-content:center;align-items:center; width: 100%; flex-shrink: 0; scroll-snap-align: start;}
  .home-image-banner-slider-item{position:relative;width:100%;height:100%;display:block;overflow:hidden}
  .home-image-banner-image{width:100%;height:100%;object-fit:cover;display:block;content-visibility:auto}
  .home-image-banner-slider-content{position:absolute;top:0;left:0;right:0;bottom:0;display:flex;align-items:center;justify-content:flex-start;padding:10rem;pointer-events:none}
  .home-image-banner-slider-content>div{max-width:60rem;pointer-events:all}
  .home-image-banner-slider-content-header{font-size:32px;margin:0;color:#fff}
  .home-image-banner-slider-content-button{background:#a68380;text-transform:uppercase;padding:1.2rem 5rem;border-radius:12px;border:none;cursor:pointer;color:#fff}

  .home-image-banner .slider-buttons { position: absolute; bottom: 20px; width: 100%; display: flex; justify-content: center; align-items: center; z-index: 2; }
  .home-image-banner .slider-button { color:#ffffff;height:32px;width:32px;background:#00000042;border-radius:50%; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; margin: 0 10px; }
  .home-image-banner .slider-counter--dots .dot { width: 4px; height: 4px; border-radius: 50%; background: #fff; display: block; margin: 0 4px; }
  .home-image-banner .slider-counter__link--active .dot { background: #fff; width: 14px; border-radius: 3rem; }

  @media (max-width:767px){
    .home-image-banner .slider-button { display: none; }
    .home-image-banner-slider-content {padding:5rem 2rem;}
    .home-image-banner-slider-content-header {font-size:24px;}
  }
</style>

<script src="{{ 'home-custom.js' | asset_url }}" defer="defer"></script>
<script>
  window.addEventListener("DOMContentLoaded", function () {
    const slideshow = document.querySelector('slideshow-component');
    if (slideshow) {
      slideshow.addEventListener('slideChanged', (event) => {
        const slide = event.detail.currentElement;
        const target = slide?.querySelector("a");
        if(target && target.dataset.promoId){
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event:"promoView",
            promoView:{
              promo_id: target.dataset.promoId,
              promo_name: target.dataset.promoName,
              creative_name:"homepage_banner",
              promo_position:"homepage_top"
            }
          });
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Home Image Banner",
  "settings": [
    {
      "type": "select",
      "id": "banner_height",
      "label": "Banner Height",
      "options": [
        { "value": "banner--small", "label": "Small" },
        { "value": "banner--medium", "label": "Medium" },
        { "value": "banner--large", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "banner_height_mobile",
      "label": "Banner Height (Mobile)",
      "options": [
        { "value": "banner--small", "label": "Small" },
        { "value": "banner--medium-mobile", "label": "Medium" },
        { "value": "banner--large-mobile", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content Position",
      "options": [
        { "value": "mid-left", "label": "Middle Left" },
        { "value": "mid-center", "label": "Middle Center" },
        { "value": "mid-right", "label": "Middle Right" }
      ]
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "AutoPlay",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "image_slide",
      "name": "Image Slide",
      "settings": [
        { "type": "text", "id": "slide_id", "label": "Slide ID" },
        { "type": "text", "id": "dlv_promo_id", "label": "DLV Promo ID" },
        { "type": "text", "id": "dlv_promo_name", "label": "DLV Promo Name" },
        {
          "type": "image_picker",
          "id": "slide_image",
          "label": "Desktop Image",
          "info": "Recommended size: 1920x800px. This is your LCP image."
        },
        {
          "type": "image_picker",
          "id": "mobile_slide_image",
          "label": "Mobile Image",
          "info": "Recommended size: 750x1000px. Mobile LCP image."
        },
        { "type": "url", "id": "slide_url", "label": "Slide URL" },
        { "type": "text", "id": "slide_header", "label": "Header Text" },
        { "type": "text", "id": "slide_subheader", "label": "Subheader Text" },
        { "type": "text", "id": "slide_button_text", "label": "Button Text" },
        { "type": "checkbox", "id": "show_button", "label": "Show Button" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Image Banner",
      "category": "Image"
    }
  ],
  "max_blocks": 5
}
{% endschema %}