<section class="home-image-banner {{ section.settings.banner_height }} {{ section.settings.banner_height_mobile }}">
  <div class="swiper home-image-banner-swiper">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        {% assign desktop_image = block.settings.slide_image | image_url %}
        {% assign mobile_image = block.settings.mobile_slide_image | image_url %}
        {% assign image_width = block.settings.slide_image.width %}
        {% assign image_height = block.settings.slide_image.height %}
        {% assign aspect_ratio = image_height | divided_by: image_width | times: 100 %}
        
        <div class="swiper-slide"
            id="{{ block.settings.slide_id }}"
            style="
                background-image: url('{{ desktop_image }}');
                background-size: contain;
                background-position: center;
                background-repeat: no-repeat;
                padding-top: {{ aspect_ratio }}%;
                width: 100%;
                position: relative;
            "
            data-promo-id="{{ block.settings.dlv_promo_id }}"
            data-promo-name="{{ block.settings.dlv_promo_name }}">
          <div class="home-image-banner-slider-content {{ section.settings.content_position }}">
            <div>
              <p class="home-image-banner-slider-content-header">{{ block.settings.slide_header }}</p>
              <p>{{ block.settings.slide_subheader }}</p>
              {% if block.settings.show_button %}
                <button class="home-image-banner-slider-content-button">
                  {{ block.settings.slide_button_text }}
                </button>
              {% endif %}
            </div>
          </div>
        </div>

        <style>
          @media screen and (max-width: 749px) {
            #{{ block.settings.slide_id }} {
              background-image: url('{{ mobile_image }}') !important;
            }
          }
        </style>
      {% endfor %}

    </div>

    <!-- Pagination -->
    <div class="swiper-pagination"></div>

    <!-- Navigation -->
    <div class="swiper-button-prev"></div>
    <div class="swiper-button-next"></div>
  </div>
</section>

{% assign first_slide = section.blocks[0] %}
<link rel="preload" as="image" href="{{ first_slide.settings.slide_image | image_url }}" fetchpriority="high">

<style>
  .home-image-banner-slider-content>div{max-width:60rem;pointer-events:all;color:#fff}
  .home-image-banner-slider-content-header{font-size:2rem;margin:0}
  .home-image-banner-slider-content-button{background:#a68380;text-transform:uppercase;padding:1rem 3rem;border-radius:12px;border:none;cursor:pointer}
  @media screen and (max-width:749px){
  .home-image-banner-slider-content{align-items:center;justify-content:center;padding:2rem}
  .home-image-banner-slider-content>div{max-width:90%;text-align:center}
  .home-image-banner-slider-content>div>p{display:none}
  .home-image-banner-slider-content-button{padding:.6rem 2rem}
  }
  .swiper{width:100%;height:100%}
  .swiper-slide{position:relative}
</style>

<script defer>
document.addEventListener("DOMContentLoaded", function() {
  const swiper = new Swiper(".home-image-banner-swiper", {
    loop: true,
    autoplay: {{ section.settings.autoplay }} ? { delay: 5000, disableOnInteraction: false } : false,
    pagination: { el: ".swiper-pagination", clickable: true },
    navigation: { nextEl: ".swiper-button-next", prevEl: ".swiper-button-prev" },
    on: {
      slideChange: function () {
        const slideEl = this.slides[this.activeIndex];
        if (slideEl.dataset.promoId) {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: "promoView",
            promoView: {
              promo_id: slideEl.dataset.promoId,
              promo_name: slideEl.dataset.promoName,
              creative_name: "homepage_banner",
              promo_position: "homepage_top"
            }
          });
        }
      }
    }
  });

  // GTM Click Tracking
  document.querySelectorAll(".swiper-slide").forEach(slide => {
    slide.addEventListener("click", function(e) {
      e.preventDefault();
      const link = slide.querySelector("a") || slide;
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: "promoClick",
        promoClick: {
          promo_id: slide.dataset.promoId,
          creative_name: "homepage_banner_image",
          promo_position: "homepage_top"
        }
      });
      if (link.href) window.location = link.href;
    });
  });
});
</script>


{% schema %}
{
  "name": "Home Image Banner",
  "settings": [
    {
      "type": "select",
      "id": "banner_height",
      "label": "Banner Height (Desktop)",
      "options": [
        { "value": "banner--small", "label": "Small" },
        { "value": "banner--medium", "label": "Medium" },
        { "value": "banner--large", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "banner_height_mobile",
      "label": "Banner Height (Mobile)",
      "options": [
        { "value": "banner--small", "label": "Small" },
        { "value": "banner--medium-mobile", "label": "Medium" },
        { "value": "banner--large-mobile", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content Position",
      "options": [
        { "value": "mid-left", "label": "Middle Left" },
        { "value": "mid-center", "label": "Middle Center" },
        { "value": "mid-right", "label": "Middle Right" }
      ]
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "image_slide",
      "name": "Image Slide",
      "settings": [
        { "type": "text", "id": "slide_id", "label": "Slide ID" },
        { "type": "text", "id": "dlv_promo_id", "label": "DLV Promo ID" },
        { "type": "text", "id": "dlv_promo_name", "label": "DLV Promo Name" },
        { "type": "image_picker", "id": "slide_image", "label": "Desktop Image" },
        { "type": "image_picker", "id": "mobile_slide_image", "label": "Mobile Image" },
        { "type": "url", "id": "slide_url", "label": "Slide URL" },
        { "type": "text", "id": "slide_header", "label": "Header Text" },
        { "type": "text", "id": "slide_subheader", "label": "Subheader Text" },
        { "type": "text", "id": "slide_button_text", "label": "Button Text" },
        { "type": "checkbox", "id": "show_button", "label": "Show Button" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Image Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}