<section class="home-image-banner {{ section.settings.banner_height }} {{ section.settings.banner_height_mobile }}">
  <div class="home-image-banner-slider">
    {% for block in section.blocks %}
      <a
        id="{{ block.settings.slide_id }}"
        href="{{ block.settings.slide_url }}"
        data-promo-id="{{ block.settings.dlv_promo_id }}"
        data-promo-name="{{ block.settings.dlv_promo_name }}"
        onclick="handleGTMPromoBannerClick(event)"
        class="home-image-banner-slider-item"
      >
        <picture>
          <source 
            media="(max-width: 749px)" 
            srcset="{{ block.settings.mobile_slide_image | image_url }}"
          >
          <img 
            src="{{ block.settings.slide_image | image_url }}"
            class="home-image-banner-image"
            alt="{{ block.settings.slide_image.alt | escape }}"
            loading="lazy"
            fetchpriority="high" width="auto" height="auto"
          >
        </picture>

        <div class="home-image-banner-slider-content {{ section.settings.content_position }}">
          <div>
            <p class="home-image-banner-slider-content-header">{{ block.settings.slide_header }}</p>
            <p>{{ block.settings.slide_subheader }}</p>
            {% if block.settings.show_button %}
              <button class="home-image-banner-slider-content-button">
                {{ block.settings.slide_button_text }}
              </button>
            {% endif %}
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

<style>
.home-image-banner-slider {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  width: 100%;
  overflow: hidden; 
  scroll-snap-type: x mandatory; 
}

.home-image-banner-slider-item {
  flex: 0 0 100%; /* Full width per item */
  scroll-snap-align: start;
}


.banner--small { min-height: 42rem; }
.banner--medium { min-height: 56rem; }
.banner--large { min-height: 72rem; }

@media screen and (max-width: 45em) {
  .banner--small { min-height: 34rem; }
  .banner--medium-mobile { min-height: 48rem; }
  .banner--large-mobile { min-height: 64rem; }
}

.home-image-banner-slider-item {
  position: relative;
  height: 100%;
}
.home-image-banner-slider-item img {
  width: 100%;
  object-fit: cover;
}

.home-image-banner-slider-content {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 10rem;
}
.home-image-banner-slider-content > div {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 1rem;
  max-width: 60rem;
  position: absolute;
}
.home-image-banner-slider-content-header {
  font-size: 32px;
}
@media screen and (max-width: 45em) {
  .home-image-banner-slider-content-header {
    font-size: 20px;
  }
}
.home-image-banner-desktop-image { display: block !important; }
.home-image-banner-mobile-image { display: none !important; }
.home-image-banner-slider-content > div > * {
  margin: 0;
  color: #fff;
}
.home-image-banner-slider-content-button {
  background: #a68380;
  text-transform: uppercase;
  padding: 1.2rem 5rem;
  border-radius: 12px;
  outline: 0;
  box-shadow: none;
  border: none;
  cursor: pointer;
  text-decoration: none;
}
.home-image-banner-slider-content.mid-left > div {
  top: 50%;
  transform: translateY(-50%);
}
.home-image-banner-arrows {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  height: 32px;
  width: 32px;
  z-index: 1;
  cursor: pointer;
}
.home-image-banner-arrows:first-of-type { left: 30px; }
.home-image-banner-arrows:last-of-type { right: 30px; }

.home-image-banner .slick-dots {
  display: flex;
  justify-content: center;
  gap: 8px;
  list-style: none;
  margin-top: 20px;
  padding: 0;
  position: absolute;
  bottom: 5px;
  left: 50%;
  transform: translateX(-50%);
}
.home-image-banner .slick-dots li { margin: 0; }
.home-image-banner-dot {
  display: block;
  width: 30px;
  height: 5px;
  background: #fff;
  border-radius: 8px;
  cursor: pointer;
  transition: background 0.3s ease, width 0.3s ease;
}
.slick-dots .slick-active .home-image-banner-dot {
  width: 45px;
  background: #a68380;
}
@media(max-width:749px){

.home-image-banner-slider-item img {
    width: 100%;
    object-fit: contain;
    height: 100%;
}
}

@media screen and (max-width: 45em) {
  .home-image-banner-desktop-image { display: none !important; }
  .home-image-banner-mobile-image { display: block !important; }
  .home-image-banner-arrows { display: none !important; }
  .home-image-banner-slider-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 4rem 1.5rem;
  }
  .home-image-banner-slider-content > div {
    max-width: 100%;
    align-items: center;
  }
  .home-image-banner-slider-content > div > * {
    text-align: center;
  }
  .home-image-banner-slider-content > div > p {
    display: none;
  }
  .home-image-banner-slider-content button {
    padding: .8rem 3rem;
  }
}
</style>

<script defer>
window.addEventListener("load", function () {
  jQuery(function ($) {
    const $slider = $(".home-image-banner-slider");

    $slider.slick({
      slidesToShow: 1,
      slidesToScroll: 1,
      infinite: true,
      dots: true,
      autoplay: {{ section.settings.autoplay }},
      prevArrow: `<img src="{{ 'home-image-banner-left.svg' | asset_url }}" class="home-image-banner-arrows" />`,
      nextArrow: `<img src="{{ 'home-image-banner-right.svg' | asset_url }}" class="home-image-banner-arrows" />`,
      customPaging: function (slider, i) {
        return `<span class="home-image-banner-dot"></span>`;
      }
    });

    // GTM View Tracking
    function handleGTMPromoBannerView(slide) {
      if (slide) {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "promoView",
          promoView: {
            promo_id: slide.dataset.promoId,
            promo_name: slide.dataset.promoName,
            creative_name: "homepage_banner",
            promo_position: "homepage_top",
          }
        });
      }
    }

    // GTM Click Tracking
    window.handleGTMPromoBannerClick = function (event) {
      event.preventDefault();
      const target = event.currentTarget;

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: "promoClick",
        promoClick: {
          promo_id: target.id,
          creative_name: "homepage_banner_image",
          promo_position: "homepage_top"
        }
      });

      window.location.assign(target.href);
    };

    $slider.on("init afterChange", function (event, slick, currentSlide) {
      let slideElement = slick.$slides[currentSlide];
      if ($(slideElement).data("promo-id")) {
        handleGTMPromoBannerView(slideElement);
      }
    });

    // Fix layout issues from lazyloaded images
    $slider.find("img").on("load", function () {
      $slider.slick("setPosition");
    });

    document.addEventListener("lazyloaded", function () {
      $slider.slick("setPosition");
    });
  });
});
</script>

{% schema %}
{
  "name": "Home Image Banner",
  "settings": [
    {
      "type": "select",
      "id": "banner_height",
      "label": "Banner Height",
      "options": [
        { "value": "banner--small", "label": "Small" },
        { "value": "banner--medium", "label": "Medium" },
        { "value": "banner--large", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "banner_height_mobile",
      "label": "Banner Height (Mobile)",
      "options": [
        { "value": "banner--small", "label": "Small" },
        { "value": "banner--medium-mobile", "label": "Medium" },
        { "value": "banner--large-mobile", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content Position",
      "options": [
        { "value": "mid-left", "label": "Middle Left" },
        { "value": "mid-center", "label": "Middle Center" },
        { "value": "mid-right", "label": "Middle Right" }
      ]
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "AutoPlay",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "image_slide",
      "name": "Image Slide",
      "settings": [
        { "type": "text", "id": "slide_id", "label": "Slide ID" },
        { "type": "text", "id": "dlv_promo_id", "label": "DLV Promo ID" },
        { "type": "text", "id": "dlv_promo_name", "label": "DLV Promo Name" },
        { "type": "image_picker", "id": "slide_image", "label": "Desktop Image" },
        { "type": "image_picker", "id": "mobile_slide_image", "label": "Mobile Image" },
        { "type": "url", "id": "slide_url", "label": "Slide URL" },
        { "type": "text", "id": "slide_header", "label": "Header Text" },
        { "type": "text", "id": "slide_subheader", "label": "Subheader Text" },
        { "type": "text", "id": "slide_button_text", "label": "Button Text" },
        { "type": "checkbox", "id": "show_button", "label": "Show Button" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Image Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}
