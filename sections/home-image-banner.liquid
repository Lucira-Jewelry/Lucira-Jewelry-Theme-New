<section class="home-image-banner">
  <div class="swiper home-image-banner-swiper">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        {% assign desktop_image = block.settings.slide_image | image_url: '1920x1080' %}
        {% assign mobile_image = block.settings.mobile_slide_image | image_url: '768x432' %}
        {% assign desktop_webp = block.settings.slide_image | image_url: '1920x1080', format: 'webp' %}
        {% assign mobile_webp = block.settings.mobile_slide_image | image_url: '768x432', format: 'webp' %}

        <div class="swiper-slide banner-slide {{ section.settings.banner_height }} {{ section.settings.banner_height_mobile }}"
             id="{{ block.settings.slide_id }}"
             data-promo-id="{{ block.settings.dlv_promo_id }}"
             data-promo-name="{{ block.settings.dlv_promo_name }}"
             {% if block.settings.slide_url %}onclick="window.location='{{ block.settings.slide_url }}'"{% endif %}>
          
          <!-- Optimized responsive images -->
          <picture class="banner-image">
            <source media="(max-width: 768px)" srcset="{{ mobile_webp }}" type="image/webp">
            <source media="(max-width: 768px)" srcset="{{ mobile_image }}">
            <source srcset="{{ desktop_webp }}" type="image/webp">
            <img src="{{ desktop_image }}" 
                 alt="{{ block.settings.slide_header | default: 'Banner slide' }}"
                 loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                 fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}"
                 width="1920" 
                 height="1080">
          </picture>

          <div class="home-image-banner-slider-content {{ section.settings.content_position }}">
            <div class="banner-content-wrapper">
              {% if block.settings.slide_header %}
                <h2 class="home-image-banner-slider-content-header">{{ block.settings.slide_header }}</h2>
              {% endif %}
              {% if block.settings.slide_subheader %}
                <p class="banner-subheader">{{ block.settings.slide_subheader }}</p>
              {% endif %}
              {% if block.settings.show_button and block.settings.slide_button_text %}
                <button class="home-image-banner-slider-content-button" type="button">
                  {{ block.settings.slide_button_text }}
                </button>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="swiper-pagination"></div>
    <div class="swiper-button-prev" aria-label="Previous slide"></div>
    <div class="swiper-button-next" aria-label="Next slide"></div>
  </div>
</section>

<!-- Preload first slide images -->
{% assign first_slide = section.blocks[0] %}
{% if first_slide.settings.slide_image %}
  <link rel="preload" as="image" href="{{ first_slide.settings.slide_image | image_url: '1920x1080', format: 'webp' }}" fetchpriority="high">
  <link rel="preload" as="image" href="{{ first_slide.settings.mobile_slide_image | image_url: '768x432', format: 'webp' }}" media="(max-width: 768px)">
{% endif %}

<style>
/* Base banner styles - prevent CLS */
.home-image-banner {
  position: relative;
  width: 100%;
  overflow: hidden;
}

.home-image-banner-swiper {
  width: 100%;
  height: 100%;
  position: relative;
}

.banner-slide {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 400px; /* Prevent CLS with minimum height */
  overflow: hidden;
}

/* Banner height classes */
.banner--small { min-height: 300px; }
.banner--medium { min-height: 500px; }
.banner--large { min-height: 700px; }

@media screen and (max-width: 768px) {
  .banner--small { min-height: 250px; }
  .banner--medium-mobile { min-height: 350px; }
  .banner--large-mobile { min-height: 450px; }
}

/* Optimized image container */
.banner-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.banner-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

/* Content positioning */
.home-image-banner-slider-content {
  position: relative;
  z-index: 2;
  display: flex;
  width: 100%;
  height: 100%;
  padding: 2rem;
  pointer-events: none;
}

.mid-left { justify-content: flex-start; align-items: center; }
.mid-center { justify-content: center; align-items: center; }
.mid-right { justify-content: flex-end; align-items: center; }

.banner-content-wrapper {
  max-width: 60rem;
  pointer-events: all;
  color: #fff;
  text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
}

.home-image-banner-slider-content-header {
  font-size: clamp(1.5rem, 4vw, 2.5rem);
  margin: 0 0 1rem 0;
  font-weight: bold;
  line-height: 1.2;
}

.banner-subheader {
  font-size: clamp(1rem, 2.5vw, 1.25rem);
  margin: 0 0 2rem 0;
  line-height: 1.4;
}

.home-image-banner-slider-content-button {
  background: #a68380;
  color: white;
  text-transform: uppercase;
  padding: 1rem 3rem;
  border-radius: 12px;
  border: none;
  cursor: pointer;
  font-weight: bold;
  transition: all 0.3s ease;
  display: inline-block;
}

.home-image-banner-slider-content-button:hover {
  background: #8b6d6a;
  transform: translateY(-2px);
}

/* Mobile optimizations */
@media screen and (max-width: 768px) {
  .home-image-banner-slider-content {
    padding: 1.5rem;
    align-items: center;
    justify-content: center;
  }
  
  .banner-content-wrapper {
    max-width: 90%;
    text-align: center;
  }
  
  .banner-subheader {
    display: none; /* Hide on mobile as requested */
  }
  
  .home-image-banner-slider-content-button {
    padding: 0.75rem 2rem;
    font-size: 0.9rem;
  }
}

/* Swiper customizations */
.swiper-pagination-bullet {
  background: rgba(255, 255, 255, 0.5);
  opacity: 1;
}

.swiper-pagination-bullet-active {
  background: white;
}

.swiper-button-next,
.swiper-button-prev {
  color: white;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
  width: 44px;
  height: 44px;
}

.swiper-button-next:after,
.swiper-button-prev:after {
  font-size: 18px;
}

@media screen and (max-width: 768px) {
  .swiper-button-next,
  .swiper-button-prev {
    display: none; /* Hide navigation on mobile */
  }
}

/* Loading state to prevent flash */
.home-image-banner-swiper:not(.swiper-initialized) {
  opacity: 0;
}

.home-image-banner-swiper.swiper-initialized {
  opacity: 1;
  transition: opacity 0.3s ease;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  // Check if Swiper is available
  if (typeof Swiper === 'undefined') {
    console.error('Swiper library not loaded');
    return;
  }

  const swiperContainer = document.querySelector(".home-image-banner-swiper");
  if (!swiperContainer) return;

  const swiper = new Swiper(swiperContainer, {
    loop: {{ section.blocks.size | default: 0 }} > 1,
    autoplay: {{ section.settings.autoplay | default: false }} ? { 
      delay: 5000, 
      disableOnInteraction: false,
      pauseOnMouseEnter: true
    } : false,
    pagination: { 
      el: ".swiper-pagination", 
      clickable: true,
      dynamicBullets: true
    },
    navigation: { 
      nextEl: ".swiper-button-next", 
      prevEl: ".swiper-button-prev" 
    },
    lazy: {
      loadPrevNext: true,
      loadPrevNextAmount: 1,
    },
    speed: 600,
    effect: 'fade',
    fadeEffect: {
      crossFade: true
    },
    a11y: {
      enabled: true,
      prevSlideMessage: 'Previous slide',
      nextSlideMessage: 'Next slide',
      paginationBulletMessage: 'Go to slide {{index}}'
    },
    on: {
      init: function() {
        // Trigger view event for first slide
        const firstSlide = this.slides[this.activeIndex];
        if (firstSlide && firstSlide.dataset.promoId) {
          trackPromoView(firstSlide);
        }
      },
      slideChange: function () {
        const slideEl = this.slides[this.activeIndex];
        if (slideEl && slideEl.dataset.promoId) {
          trackPromoView(slideEl);
        }
      }
    }
  });

  // GTM tracking functions
  function trackPromoView(slideEl) {
    if (typeof window.dataLayer !== 'undefined') {
      window.dataLayer.push({
        event: "promoView",
        promoView: {
          promo_id: slideEl.dataset.promoId,
          promo_name: slideEl.dataset.promoName,
          creative_name: "homepage_banner",
          promo_position: "homepage_top"
        }
      });
    }
  }

  function trackPromoClick(slideEl) {
    if (typeof window.dataLayer !== 'undefined') {
      window.dataLayer.push({
        event: "promoClick",
        promoClick: {
          promo_id: slideEl.dataset.promoId,
          promo_name: slideEl.dataset.promoName,
          creative_name: "homepage_banner_image",
          promo_position: "homepage_top"
        }
      });
    }
  }

  // Click tracking with proper event handling
  document.querySelectorAll(".banner-slide").forEach(slide => {
    slide.addEventListener("click", function(e) {
      // Don't interfere with button clicks
      if (e.target.tagName === 'BUTTON') return;
      
      trackPromoClick(slide);
      
      // Handle slide URL navigation
      const slideUrl = slide.getAttribute('onclick');
      if (slideUrl) {
        const url = slideUrl.match(/window\.location='([^']+)'/);
        if (url && url[1]) {
          window.location.href = url[1];
        }
      }
    });
  });

  // Button click tracking
  document.querySelectorAll(".home-image-banner-slider-content-button").forEach(button => {
    button.addEventListener("click", function(e) {
      e.stopPropagation(); // Prevent slide click
      const slide = button.closest('.banner-slide');
      if (slide) {
        trackPromoClick(slide);
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "Home Image Banner",
  "settings": [
    {
      "type": "select",
      "id": "banner_height",
      "label": "Banner Height (Desktop)",
      "options": [
        { "value": "banner--small", "label": "Small (300px)" },
        { "value": "banner--medium", "label": "Medium (500px)" },
        { "value": "banner--large", "label": "Large (700px)" }
      ],
      "default": "banner--medium"
    },
    {
      "type": "select",
      "id": "banner_height_mobile",
      "label": "Banner Height (Mobile)",
      "options": [
        { "value": "banner--small", "label": "Small (250px)" },
        { "value": "banner--medium-mobile", "label": "Medium (350px)" },
        { "value": "banner--large-mobile", "label": "Large (450px)" }
      ],
      "default": "banner--medium-mobile"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content Position",
      "options": [
        { "value": "mid-left", "label": "Middle Left" },
        { "value": "mid-center", "label": "Middle Center" },
        { "value": "mid-right", "label": "Middle Right" }
      ],
      "default": "mid-left"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": false,
      "info": "Slides will auto-advance every 5 seconds"
    }
  ],
  "blocks": [
    {
      "type": "image_slide",
      "name": "Image Slide",
      "settings": [
        { 
          "type": "text", 
          "id": "slide_id", 
          "label": "Slide ID",
          "info": "Unique identifier for this slide" 
        },
        { 
          "type": "text", 
          "id": "dlv_promo_id", 
          "label": "DLV Promo ID",
          "info": "For analytics tracking" 
        },
        { 
          "type": "text", 
          "id": "dlv_promo_name", 
          "label": "DLV Promo Name",
          "info": "For analytics tracking" 
        },
        { 
          "type": "image_picker", 
          "id": "slide_image", 
          "label": "Desktop Image",
          "info": "Recommended: 1920x1080px" 
        },
        { 
          "type": "image_picker", 
          "id": "mobile_slide_image", 
          "label": "Mobile Image",
          "info": "Recommended: 768x432px" 
        },
        { 
          "type": "url", 
          "id": "slide_url", 
          "label": "Slide URL",
          "info": "Where to redirect when slide is clicked" 
        },
        { 
          "type": "text", 
          "id": "slide_header", 
          "label": "Header Text" 
        },
        { 
          "type": "textarea", 
          "id": "slide_subheader", 
          "label": "Subheader Text",
          "info": "Hidden on mobile devices" 
        },
        { 
          "type": "text", 
          "id": "slide_button_text", 
          "label": "Button Text" 
        },
        { 
          "type": "checkbox", 
          "id": "show_button", 
          "label": "Show Button",
          "default": false 
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Image Banner",
      "category": "Image",
      "blocks": [
        {
          "type": "image_slide",
          "settings": {
            "slide_header": "Welcome to Our Store",
            "slide_subheader": "Discover amazing products and exclusive deals",
            "slide_button_text": "Shop Now",
            "show_button": true
          }
        }
      ]
    }
  ]
}
{% endschema %}