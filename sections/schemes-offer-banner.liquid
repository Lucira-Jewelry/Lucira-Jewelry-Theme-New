<div class="schemes-offer-banner">
  <div class="page-width">
    <div class="schemes-offer-banner-wrapper">
      <div class="grid-row">
        <div class="grid-column">
          <div class="schemes-content-wrapper">

            {% if section.settings.schemes_offer_banner_title != blank %}
              <h2>{{ section.settings.schemes_offer_banner_title }}</h2>
            {% endif %}

            {% if section.settings.schemes_offer_banner_subtext != blank %}
              <p>{{ section.settings.schemes_offer_banner_subtext }}</p>
            {% endif %}

            <div class="grid-process-wrapper">
              <div class="grid-process-column">
                <div class="process-number">{{ section.settings.step_one_title }}</div>
                <div class="process-text">{{ section.settings.step_one_subtext }}</div>
              </div>
              <div class="grid-process-arrow-column">
                <div class="process-number">{{ section.settings.step_two_title }}</div>
                <div class="process-arrow desktop-show">{{ 'arrow-right.svg' | inline_asset_content }}</div>
                <div class="process-arrow mobile-show">{{ 'arrow-right-mobile.svg' | inline_asset_content }}</div>
                <div class="process-text">{{ section.settings.step_two_subtext }}</div>
              </div>
              <div class="grid-process-column">
                <div class="process-number">{{ section.settings.step_three_title }}</div>
                <div class="process-text">{{ section.settings.step_three_subtext }}</div>
              </div>
            </div>

            {% if section.settings.schemes_offer_banner_button_label != blank %}
              <a href="{{ section.settings.schemes_offer_banner_button_link }}" class="book-an-appoinment">
                {{ section.settings.schemes_offer_banner_button_label }}
              </a>
            {% endif %}

          </div>
        </div>
        <div class="grid-column">
          {% if section.settings.side_image != blank %}
            <img src="{{ section.settings.side_image | image_url: width: 600 }}" alt="Banner Side Image" class="side-image"/>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
    .schemes-offer-banner-wrapper {background: url({{ section.settings.desktop_banner_image | image_url: width: 1600 }}); background-size: cover; background-position: center; background-repeat: no-repeat; height: 390px; border-radius: 12px;}
    .grid-process-wrapper {display: flex ; align-items: center; justify-content: center; gap: 30px;}
    .grid-process-column {display: flex ; flex-direction: column; align-items: center;}
    .process-number { color: #fff; }
    .process-text {color: #fff;}
    .process-number {text-align: center;}
    .process-text  {text-align: center;}
    .process-number { font-family: Futura Std; font-weight: 500; font-size: 20px; line-height: 150%; letter-spacing: 1.4px; text-align: center; vertical-align: middle; text-transform: uppercase; margin-bottom: 2px;}
    .process-text { font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 150%; letter-spacing: 1.4px; text-align: center; vertical-align: middle; text-transform: uppercase; margin-top: 2px;}
    .schemes-offer-banner-wrapper .grid-row { display: grid ; grid-template-columns: calc(58% - 20px) calc(42% - 20px); gap: 40px; align-items: start; height: 100%; }
    .schemes-content-wrapper h2 { font-family: Futura Std; font-weight: 500; font-size: 24px; line-height: 150%; text-align: center; vertical-align: middle; text-transform: uppercase; color: #fff; letter-spacing: 1.4px; }
    .schemes-offer-banner h2 { font-weight: 500; font-size: 24px; line-height: 150%; text-align: center; vertical-align: middle; text-transform: uppercase; color: #fff; letter-spacing: 1.4px; margin: 0; }
    .schemes-content-wrapper p { font-weight: 400; font-size: 16px; line-height: 1.7; text-align: center; vertical-align: middle; color: #fff; margin-top: 18px; margin-bottom: 30px; max-width: 495px; margin-left: auto; margin-right: auto; }
    .schemes-offer-banner-wrapper .grid-row { display: grid ; grid-template-columns: calc(58% - 20px) calc(42% - 20px); align-items: center; gap: 40px; height: 100%; padding: 0 45px;}
    .book-an-appoinment {background: #FFFFFF; color: #1A1A1A; font-weight: 500; font-size: 16px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; padding: 18px 50px; display: inline-block; text-align: center; margin-top: 30px; border-radius: 8px;}
    .schemes-content-wrapper {text-align: center;}
    .schemes-offer-banner .schemes-offer-banner {padding: 20px 0 30px;}
    

    @media only screen and (min-width:0) and (max-width:767px){
        .schemes-offer-banner-wrapper .grid-row { display: grid ; grid-template-columns: 1fr; align-items: center !important; gap: 40px; height: 100%; padding: 0 30px; }
        .schemes-offer-banner-wrapper {border-radius: 8px;}
        .schemes-offer-banner h2 {font-size: 18px;}
        .schemes-content-wrapper p {color: #ffffff; margin: 0 auto; letter-spacing: 1px; vertical-align: middle; font-weight: 400; font-size: 12px; line-height: 150%; text-align: center; margin-top: 12px; margin-bottom: 28px;}
        .schemes-offer-banner-wrapper svg {width: 135px;}
        .schemes-offer-banner-wrapper .grid-row .grid-column:nth-child(1) {grid-row: 2;}
        .schemes-offer-banner-wrapper { background: url({{ section.settings.mobile_banner_image | image_url: width: 800 }}); background-size: cover; background-position: center; background-repeat: no-repeat; height: 530px;}
        .schemes-offer-banner-wrapper .grid-row {gap: 150px;}
        .book-an-appoinment { background: #FFFFFF; color: #1A1A1A; font-weight: 500; font-size: 16px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; padding: 18px 20px; display: inline-block; text-align: center; margin-top: 30px; border-radius: 8px; width: 95%; }
        .schemes-offer-banner-wrapper .grid-row {padding: 0 12px;}
        
    }

    @media only screen and (min-width:0) and (max-width:430px){
      .schemes-content-wrapper p {font-size: 10px;}
      .process-number { font-size: 10px; }
      .book-an-appoinment { background: #FFFFFF; color: #1A1A1A; font-weight: 500; font-size: 12px; line-height: 100%; letter-spacing: 1.4px; text-transform: uppercase; padding: 14px 20px; display: inline-block; text-align: center; margin-top: 30px; border-radius: 8px; width: 95%; }
      .grid-process-wrapper { display: flex ; align-items: center; justify-content: center; gap: 12px; }
      .process-text { font-size: 8px !important; }
      .process-number { font-size: 10px !important; }
    }
</style>

{% schema %}
{
  "name": "Schemes Offer Banner",
  "tag": "section",
  "class": "schemes-offer-banner",
  "settings": [
    {
      "type": "text",
      "id": "schemes_offer_banner_title",
      "label": "Heading",
      "default": "Start Today Benefit at Diwali"
    },
    {
      "type": "textarea",
      "id": "schemes_offer_banner_subtext",
      "label": "Subtext",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore."
    },
    {
      "type": "text",
      "id": "schemes_offer_banner_button_label",
      "label": "Button Label",
      "default": "Book a Free Consultation"
    },
    {
      "type": "url",
      "id": "schemes_offer_banner_button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "desktop_banner_image",
      "label": "Desktop Banner Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_banner_image",
      "label": "Mobile Banner Image"
    },
    {
      "type": "image_picker",
      "id": "side_image",
      "label": "Side Image (Optional)"
    },
    {
      "type": "text",
      "id": "step_one_title",
      "label": "Step 1 Title",
      "default": "Today"
    },
    {
      "type": "text",
      "id": "step_one_subtext",
      "label": "Step 1 Subtext",
      "default": "(1st month)"
    },
    {
      "type": "text",
      "id": "step_two_title",
      "label": "Step 2 Title",
      "default": "Investment"
    },
    {
      "type": "text",
      "id": "step_two_subtext",
      "label": "Step 2 Subtext",
      "default": "(9 months)"
    },
    {
      "type": "text",
      "id": "step_three_title",
      "label": "Step 3 Title",
      "default": "Diwali"
    },
    {
      "type": "text",
      "id": "step_three_subtext",
      "label": "Step 3 Subtext",
      "default": "(10th month)"
    }
  ],
  "presets": [
    {
      "name": "Schemes Offer Banner"
    }
  ]
}
{% endschema %}