<div class="byoj-step1">
  <div class="byoj-wrapper">
    <!-- LEFT IMAGE -->
    <div class="byoj-left">
      {% if section.settings.main_image != blank %}
        <img
          src="{{ section.settings.main_image | image_url: width: 1200 }}"
          alt="Main Image"
          class="byoj-main-image"
        >
      {% endif %}
    </div>

    <!-- RIGHT CONTENT -->
    <div class="byoj-right">
      <p class="byoj-subheading">{{ section.settings.subheading }}</p>
      <h2 class="byoj-heading">{{ section.settings.heading }}</h2>
      <p class="byoj-description">{{ section.settings.description }}</p>

      <div class="byoj-options">
        {% for block in section.blocks %}
          <div
            class="byoj-option"
            data-type="{{ block.settings.type }}"
            onclick="selectJewelryType(this)"
          >
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                alt="{{ block.settings.label }}"
                class="byoj-image"
              >
            {% endif %}

            <p class="byoj-label">{{ block.settings.label }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>
<script>
  function selectJewelryType(el) {
    const type = el.getAttribute('data-type');

    // Store selection
    localStorage.setItem('byoj_type', type);

    // Optional: highlight selected
    document.querySelectorAll('.byoj-option').forEach((e) => e.classList.remove('active'));
    el.classList.add('active');

    // Redirect to next step (you can change URL later)
    window.location.href = '/pages/build-your-jewelry-step-2?type=' + type;
  }
</script>
<style>
  .byoj-wrapper {
    display: flex;
    align-items: center;
  }

  .byoj-left {
    width: 50%;
  }

  .byoj-main-image {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .byoj-right {
    width: 50%;
    padding: 40px;
    text-align: center;
  }

  .byoj-options {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 20px;
  }

  .byoj-option {
    cursor: pointer;
    transition: 0.3s;
  }

  .byoj-option.active {
    opacity: 0.6;
  }

  .byoj-image {
    width: 100%;
    max-width: 140px;
  }

  .byoj-label {
    margin-top: 10px;
    font-size: 12px;
    letter-spacing: 1px;
  }
</style>
{% schema %}
{
  "name": "BYO Jewelry Step 1",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "YOUR STORY, YOUR SPARKLE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE SELFLOVE CHAIN"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Design your personalized look..."
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Image"
    }
  ],
  "blocks": [
    {
      "type": "option",
      "name": "Jewelry Type",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Bracelet"
        },
        {
          "type": "select",
          "id": "type",
          "label": "Type Value",
          "options": [
            { "value": "bracelet", "label": "Bracelet" },
            { "value": "necklace", "label": "Necklace" },
            { "value": "anklet", "label": "Anklet" }
          ],
          "default": "bracelet"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "BYO Jewelry Step 1",
      "blocks": [{ "type": "option" }, { "type": "option" }, { "type": "option" }]
    }
  ]
}
{% endschema %}
