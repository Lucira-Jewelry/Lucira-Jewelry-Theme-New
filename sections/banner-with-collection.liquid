{{ 'plp-product-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'product-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'template-collection.css' | asset_url | stylesheet_tag: preload: true }}

<link
  rel="preload"
  href="{{ 'component-card.css' | asset_url }}"
  as="style"
  onload="this.onload=null;this.rel='stylesheet'"
>
<noscript><link rel="stylesheet" href="{{ 'component-card.css' | asset_url }}"></noscript>

{{ 'product-detail.css' | asset_url | stylesheet_tag: preload: true }}

<section
  {% if section.settings.section_id != blank %}
    id="{{ section.settings.section_id }}"
  {% endif %}
  class="marquise-collection-section marquise-collection-section-{{ section.id }}"
  data-collection-handle="{{ section.settings.collection.handle }}"
  style="
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  "
>
  <div class="page-width">
    <!-- HEADER -->
    <div class="mc-header">
      {% if section.settings.heading != blank %}
        <h2 class="mc-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="mc-subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <!-- CONTENT -->
    <div class="mc-content {% if section.settings.reverse_layout %}mc-reverse{% endif %}">
      <!-- IMAGE -->
      <div class="mc-image">
        {% if section.settings.image %}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
          >
        {% endif %}
      </div>

      <!-- COLLECTION -->
      <div class="mc-products">
        {% if section.settings.collection %}
          <div class="mc-grid">
            {% for product in section.settings.collection.products limit: 3 %}
              <div class="mc-product-item {% if forloop.index == 3 %}hide-on-mobile{% endif %}">
                {% comment %} {% render 'similar-card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  image_shape: section.settings.image_shape,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  lazy_load: lazy_load,
                  skip_styles: skip_card_product_styles,
                  section_id: section.id,
                  quick_add: section.settings.quick_add,
                  forloop: forloop.index0
                %} {% endcomment %}
                {%- render 'card-product-similar',
                  card_product: similar_product,
                  show_secondary_image: true,
                  show_rating: true
                -%}

              </div>
            {% endfor %}
          </div>

          {% if section.settings.button_text != blank %}
            <a
              class="mc-button mc-shop-now-btn"
              href="{{ section.settings.collection.url }}"
              data-collection-name="{{ section.settings.heading }}"
            >
              {{ section.settings.button_text }}
            </a>
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
 .mc-content .product-video-icon-wrapper{
  display:none;
  }
  .marquise-collection-section {
    background: #fff;
    scroll-margin-top: 100px;
  }
  .mc-image img{
      display: flex;
      width: 100%;
      height: auto;
  }
  .mc-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 40px;
  }

  .mc-heading {
    font-weight: 500;
      font-size: 24px;
      line-height: 150%;
      text-align: center;
      vertical-align: middle;
      text-transform: uppercase;
      margin: 0;
      margin-bottom: 12px;
  }

  .mc-subheading {
    font-weight: 400;
      font-size: 18px;
      line-height: 24px;
      text-align: center;
      vertical-align: middle;
      margin: 0;
      margin-bottom: 60px;
  }

  .mc-content {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .mc-reverse {
    flex-direction: row-reverse;
  }

  .mc-image,
  .mc-products {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .mc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .mc-product-item {
    display: block;
  }

  .mc-card {
    background: #fafafa;
    padding: 16px;
    text-align: center;
    border-radius: 8px;
  }

  .mc-card img {
    width: 100%;
  }

  .mc-price {
    font-size: 14px;
  }

  .mc-compare {
    text-decoration: line-through;
    color: #999;
    font-size: 12px;
    margin-left: 6px;
  }

  .mc-button {
    border-radius: 12px;
      padding: 20px 80px;
      background: #A68380;
      color: #ffffff;
      margin: 0 auto;
      margin-top: 24px;
      font-weight: 500;
      font-size: 16px;
      line-height: 100%;
      text-transform: uppercase;
  }
  .mc-products .card-content-wrapper{
      display: none;
  }

  .gradient a.product-card-link {
    display: none;
  }

  .gradient .price--on-sale .price__sale {
    display: inline-flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .gradient .price--on-sale .price-item--regular {
    font-size: 13px;
    font-weight: 400 !important;
  }

  .gradient .card__content span.price-item.price-item--sale, .price-item {
    letter-spacing: normal;
    font-weight: 600;
    font-size: 16px;
    line-height: 150%;
    vertical-align: middle;
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .marquise-collection-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    .mc-content {
      flex-direction: column;
      gap:24px;
    }

    .mc-grid {
      grid-template-columns: repeat(2, 1fr);
      gap:12px;
    }

    .hide-on-mobile {
      display: none !important;
    }

    .mc-products{
      width: 100%;
    }
    .mc-heading{
      font-size: 18px;
      margin-bottom: 6px;
    }
    .mc-subheading{
      font-size: 12px;
      margin-bottom: 24px;
    }
    .mc-button {
      padding: 15px 53px;
    }
  }

  .gradient .product-video-icon-wrapper {
      bottom: 69px !important;
      right: 4px;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sectionId = '{{ section.id }}';
    const bannerSection = document.querySelector(`.marquise-collection-section-${sectionId}`);
    if (!bannerSection) return;

    // Color Option Change - Image swap functionality
    bannerSection.querySelectorAll('.color-option').forEach((button) => {
      button.addEventListener('click', (event) => {
        const targetButton = event.currentTarget;
        const productId = targetButton.dataset.productId;
        const newImageSrc = targetButton.dataset.imageSrc;
        const newImageAlt = targetButton.dataset.imageAlt;
        const newVariantId = targetButton.dataset.variantId;

        const mainImage = document.getElementById(`product-image-${productId}`);
        if (mainImage && newImageSrc) {
          mainImage.setAttribute('src', newImageSrc);
          mainImage.setAttribute('srcset', newImageSrc);
          mainImage.setAttribute('alt', newImageAlt);

          const productCard = targetButton.closest('.card-wrapper');
          if (productCard) {
            productCard.querySelectorAll('.color-option').forEach((btn) => btn.classList.remove('active'));
            targetButton.classList.add('active');

            if (newVariantId) {
              const variantInput = productCard.querySelector('input[name="id"]');
              if (variantInput) variantInput.value = newVariantId;
            }
          }
        }
      });
    });

    // Video icon click handler with debounce to prevent multiple triggers
    let videoClickTimeout;
    bannerSection.querySelectorAll('.product-video-icon-wrapper').forEach((wrapper) => {
      wrapper.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        
        // Clear any existing timeout
        if (videoClickTimeout) {
          clearTimeout(videoClickTimeout);
        }
        
        // Debounce to prevent multiple rapid clicks
        videoClickTimeout = setTimeout(() => {
          // Let the snippet handle the video functionality
          // This just prevents event bubbling issues
        }, 100);
      }, { once: false, passive: false });
    });

    // Shop Now Button Click Tracking
    const shopNowBtn = bannerSection.querySelector('.mc-shop-now-btn');
    if (shopNowBtn) {
      shopNowBtn.addEventListener('click', (event) => {
        const diamondCutName = shopNowBtn.dataset.collectionName || '{{ section.settings.heading }}';
        const collectionHandle = '{{ section.settings.collection.handle }}';
        
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'promoClick',
          promoClick: {
            promo_id: collectionHandle,
            creative_name: 'Diamond shapes page',
            promo_name: diamondCutName,
            location_id: 'footer',
          },
        });
      });
    }
  });
</script>

{% render 'product-card-variants-change' %}
{% render 'product-collection-card' %}

{% schema %}
{
  "name": "Banner with collection",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "Use this ID to link from other sections (e.g., 'marquise-diamond'). Must be unique and URL-friendly.",
      "placeholder": "e.g., marquise-diamond"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "MARQUISE SHAPE DIAMOND"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "checkbox",
      "id": "reverse_layout",
      "label": "Reverse Layout",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Banner with collection"
    }
  ]
}
{% endschema %}