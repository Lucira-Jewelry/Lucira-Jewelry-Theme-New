<style>
.zodiac-gemstone-explorer{text-align:center;padding:40px 0 40px 0}
.zodiac-heading{font-size:24px;font-weight:500;letter-spacing:1px;margin-bottom:40px;text-transform:uppercase;margin-top:0}
.zodiac-grid{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:60px 40px;justify-items:center;max-width:80%;margin:0 auto}
.zodiac-item img{width:180px;height:auto;object-fit:cover}
.zodiac-name{font-size:24px;margin:0}
.zodiac-date{font-size:16px;color:#444;margin:10px 0 0}
@media(max-width:768px){
.zodiac-grid{grid-template-columns:1fr 1fr 1fr;gap:20px 20px;max-width:100%;margin:0 auto;padding:0 6px}
.zodiac-gemstone-explorer{text-align:center;padding:20px 0 20px 0}
.zodiac-item img{width:80px;height:auto;object-fit:cover}
.zodiac-name{font-size:16px;margin:0}
.zodiac-date{font-size:10px;margin:8px 0 0}
.zodiac-heading{font-size:18px;margin-bottom:24px}
}
</style>
<section class="zodiac-gemstone-explorer">
  <div class="zodiac-gemstone-container">
    {% if section.settings.heading != blank %}
      <h2 class="zodiac-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="zodiac-grid">
      {% for block in section.blocks %}
        <a 
          href="#{{ block.settings.zodiac_name | handleize }}" 
          class="zodiac-item-link"
        >
          <div class="zodiac-item">
            {% if block.settings.image %}
              <div class="zodiac-imag-container">
                <img
                  src="{{ block.settings.image | image_url: width: 400 }}"
                  alt="{{ block.settings.zodiac_name | escape }}"
                  title="{{ block.settings.zodiac_name | escape }}"
                  loading="lazy"
                  width="auto"
                  height="auto"
                >
              </div>
            {% endif %}
            {% if block.settings.zodiac_name != blank %}
              <h3 class="zodiac-name">{{ block.settings.zodiac_name }}</h3>
            {% endif %}
            {% if block.settings.zodiac_date != blank %}
              <p class="zodiac-date">{{ block.settings.zodiac_date }}</p>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>

  </div>
</section>

<script>
  $(document).ready(function () {
    $("div.zodiac-grid").each(function () {
      var active,
        content,
        links = $(this).find("a");
      (active = links.first().addClass("active")),
        (content = $(active.attr("href"))),
        links.not(":first").each(function () {
          $($(this).attr("href")).hide();
        }),
        $(this)
          .find("a")
          .click(function (e) {
            return (
              active.removeClass("active"),
              content.hide(),
              (active = $(this)),
              (content = $($(this).attr("href"))),
              active.addClass("active"),
              content.show(),
              !1
            );
          });
    });
  }),
</script>


{% schema %}
{
  "name": "Zodiac Gemstone Explorer",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "ZODIAC GEMSTONE EXPLORER"
    }
  ],
  "blocks": [
    {
      "type": "zodiac_item",
      "name": "Zodiac Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Gemstone Image"
        },
        {
          "type": "text",
          "id": "zodiac_name",
          "label": "Zodiac Name",
          "default": "ARIES"
        },
        {
          "type": "text",
          "id": "zodiac_date",
          "label": "Date Range",
          "default": "(21st March - 19th April)"
        }
      ]
    }
  ],
  
  "presets": [
    {
      "name": "Zodiac Gemstone Explorer",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
