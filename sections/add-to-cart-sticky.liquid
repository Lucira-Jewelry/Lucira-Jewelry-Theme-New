{% schema %}
{
  "name": "Sticky ATC",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "checkbox",
      "id": "enable_section",
      "label": "Enable \"Sticky ATC\"",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "title_size",
      "label": "Title Size",
      "default": "h4",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_img",
      "default": true,
      "label": "Show image"
    },
    {
      "type": "text",
      "id": "img_width",
      "default": "80",
      "label": "Image width (px)"
    },
    {
      "type": "text",
      "id": "img_height",
      "default": "80",
      "label": "Image height (px)"
    },
    {
      "type": "select",
      "id": "btn_style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" }
      ],
      "default": "primary",
      "label": "Add to cart button style"
    },
    {
      "type": "range",
      "id": "offset",
      "label": "Offset",
      "min": 0,
      "max": 900,
      "step": 10,
      "default": 0
    },
    {
      "type": "range",
      "id": "pt",
      "label": "Padding top",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "default": 0.5
    },
    {
      "type": "range",
      "id": "pb",
      "label": "Padding bottom",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "default": 0.5
    }
  ]
}
{% endschema %}
