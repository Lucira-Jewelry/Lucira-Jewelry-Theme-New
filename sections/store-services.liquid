<div class="our-services">
  <div class="page-width">

    <div class="services-header">
      {% if section.settings.heading != blank %}
        <h2 class="section-header">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="section-subheader">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
    </div>

    <div class="grid-row">
      {% for block in section.blocks %}
        <div class="grid-column" {{ block.shopify_attributes }}>
          <div class="card-wrapper">
            {% if block.settings.icon != blank %}
              <img
                src="{{ block.settings.icon | image_url: width: 600 }}"
                alt="{{ block.settings.title | escape }}"
                class="service-icon" width="auto" height="auto"
                loading="lazy"
              >
            {% endif %}

            {% if block.settings.title != blank %}
              <h3 class="service-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.subtitle != blank %}
              <p class="service-subtitle">{{ block.settings.subtitle }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</div>

<style>
    .our-services .section-header {margin-bottom: 12px; margin-top: 0;}
    .our-services .services-header {max-width: 660px; margin: 0 auto; text-align: center;}
    .our-services .section-header { margin-bottom: 12px; margin-top: 0; text-transform: uppercase; font-size: 20px; }
     .our-services .section-subheader {font-weight: 400; font-size: 14px; line-height: 24px; text-align: center; vertical-align: middle; max-width: 845px; margin: 0 auto 40px;}
    .our-services .grid-row {display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;}
    .our-services img.service-icon { width: 100%; }
    img.service-icon { width: 100%; display: block; }
    .service-title { font-weight: 400; font-size: 16px; line-height: 150%; margin: 0; text-transform: capitalize; color: #fff; position: absolute; bottom: 16px; left: 24px; }
    .our-services { padding: 20px 0 0px; }
    .our-services .section-header { margin-bottom: 12px; margin-top: 0; text-transform: uppercase; }
    .lucira-section .heading-wrapper p {max-width: 660px;}
    p.service-subtitle { position: absolute; z-index: 1; color: #fff; bottom: 4px; left: 12px; font-size: 12px; width: 80%; }
    h3.service-title { font-weight: 400; font-size: 16px; line-height: 150%; margin: 0; text-transform: capitalize; color: #fff; position: absolute; bottom: 91px; left: 12px; }
    .our-services .card-wrapper {border-radius: 8px; overflow: hidden;}

    @media only screen and (min-width: 1400px){
      p.service-subtitle { position: absolute; z-index: 1; color: #fff; bottom: 4px; left: 12px; font-size: 12px; width: 96%; }
      h3.service-title {bottom: 70px; left: 12px;}
    }

    @media only screen and (max-width:767px){
      .our-services .section-header { margin-bottom: 12px; margin-top: 0; text-transform: uppercase; font-size: 16px; }
      .our-services { padding: 0px 0; }
      .our-services img.service-icon { width: 300px; }
      .our-services .grid-row { display: flex; gap: 20px; padding-bottom: 20px; overflow-x: scroll; margin-bottom: 30px; }
      .our-services .section-subheader { max-width: 530px; margin: 0 auto; margin-bottom: 28px; font-weight: 400; font-size: 12px; line-height: 1.6; text-align: center; vertical-align: middle; }
      .page-store-locator-template-page .lucira-section { padding-top: 0px !important; }
    }
</style>

{% schema %}
{
  "name": "Our Services",
  "tag": "section",
  "class": "our-services-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Our Services"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Section Subheading",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Service Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Service Title",
          "default": "Service Title"
        },
         {
          "type": "text",
          "id": "subtitle",
          "label": "Service Subtitle",
          "default": "Service Subtitle"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Our Services",
      "blocks": [
        { "type": "service" },
        { "type": "service" },
        { "type": "service" },
        { "type": "service" }
      ]
    }
  ]
}
{% endschema %}
