<div class="our-services">
  <div class="page-width">

    <div class="services-header">
      {% if section.settings.heading != blank %}
        <h2 class="section-header">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="section-subheader">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
    </div>

    <div class="grid-row">
      {% for block in section.blocks %}
        <div class="grid-column" {{ block.shopify_attributes }}>
          <div class="card-wrapper">
            {% if block.settings.icon != blank %}
              <img
                src="{{ block.settings.icon | image_url: width: 600 }}"
                alt="{{ block.settings.title | escape }}"
                class="service-icon" width="auto" height="auto"
                loading="lazy"
              >
            {% endif %}

            {% if block.settings.title != blank %}
              <h3 class="service-title">{{ block.settings.title }}</h3>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</div>

<style>
    .our-services .section-header {margin-bottom: 12px; margin-top: 0;}
    .our-services .services-header {max-width: 660px; margin: 0 auto; text-align: center;}
    .section-subheader {text-align: center; margin-top: 0;}
</style>

{% schema %}
{
  "name": "Our Services",
  "tag": "section",
  "class": "our-services-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Our Services"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Section Subheading",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Service Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Service Title",
          "default": "Service Title"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Our Services",
      "blocks": [
        { "type": "service" },
        { "type": "service" },
        { "type": "service" },
        { "type": "service" }
      ]
    }
  ]
}
{% endschema %}
