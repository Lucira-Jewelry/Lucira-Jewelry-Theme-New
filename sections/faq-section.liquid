<div class="lucira-section faq-section" id="faq-section-{{ section.id }}">
  <div itemscope itemtype="https://schema.org/FAQPage" class="page-width">
    
    {% if section.settings.faq_heading != blank or section.settings.faq_description != blank %}
      <div class="heading-wrapper">
        {% if section.settings.faq_heading != blank %}
          <h2>{{ section.settings.faq_heading }}</h2>
        {% endif %}
        {% if section.settings.faq_description != blank %}
          <p>{{ section.settings.faq_description }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      
      {%- comment -%} Cache variables & handle non-product pages safely {%- endcomment -%}
      {%- assign track_id = 'N/A' -%}
      {%- assign track_name = page_title | escape -%}
      
      {%- if product -%}
        {%- assign current_variant = product.selected_or_first_available_variant -%}
        {%- assign track_sku = current_variant.sku | escape | default: 'N/A' -%}
        {%- assign track_name = product.title | escape -%}
        {%- assign track_id = current_variant.id | default: 'N/A' -%}
      {%- endif -%}

      <div id="accordion_block_{{ section.id }}" class="accordion">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'faq_item' %}
              <div
                itemscope
                itemprop="mainEntity"
                itemtype="https://schema.org/Question"
                class="accordion-item"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.faq_question != blank %}
                  <h3
                    itemprop="name"
                    class="accordion-title js-faq-track"
                    data-sku="{{ track_sku }}"
                    data-title="{{ track_name }}"
                    data-question="{{ block.settings.faq_question | escape }}"
                    data-id="{{ track_id }}"
                  >
                    {{ block.settings.faq_question }}
                  </h3>
                {% endif %}
                
                {% if block.settings.faq_answer != blank %}
                  <div
                    itemscope
                    itemprop="acceptedAnswer"
                    itemtype="https://schema.org/Answer"
                    class="accordion-content"
                  >
                    <div itemprop="text">{{ block.settings.faq_answer }}</div>
                  </div>
                {% endif %}
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<script>
  // Scoped to this specific section to prevent conflicts if used multiple times
  document.querySelector('#faq-section-{{ section.id }}').addEventListener('click', function(event) {
    const faqTitle = event.target.closest('.js-faq-track');
    
    if (faqTitle) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'promoClick',
        promoClick: {
          promo_id: faqTitle.getAttribute('data-sku') || 'N/A',
          promo_name: faqTitle.getAttribute('data-title'),
          creative_name: 'FAQ Clicked',
          promo_position: faqTitle.getAttribute('data-question'),
          location_id: faqTitle.getAttribute('data-id') || 'N/A'
        }
      });

      // NOTE: You will need to add your logic here (or in a separate CSS/JS file) 
      // to actually toggle the accordion-content open and closed visually.
    }
  });
</script>

{% schema %}
{
  "name": "FAQ Section",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "faq_heading",
      "default": "FAQ'S",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "faq_description",
      "default": "Got questions? We've got answers. Here's everything you need to know about earning, redeeming, and making the most of your rewards.",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "faq_question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "faq_answer",
          "label": "Answer",
          "default": "<p>Enter your answer here. You can use rich text formatting including lists, links, and basic styling.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Section",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "faq_question": "What is your return policy?",
            "faq_answer": "<p>We offer a 30-day return policy for all unused items in their original packaging.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "faq_question": "How long does shipping take?",
            "faq_answer": "<p>Standard shipping takes 3-5 business days. Express shipping is available for 1-2 business days.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "faq_question": "Do you ship internationally?",
            "faq_answer": "<p>Yes, we ship to most countries worldwide. International shipping rates vary by location.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}