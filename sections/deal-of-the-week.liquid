{{ 'plp-product-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'product-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'component-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'component-slider.css' | asset_url | stylesheet_tag: preload: true }}

{%- style -%}
  /* ===== Skeleton Loading Styles ===== */
  .deal-week-skeleton-wrapper {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 12px;
    padding: 40px 0;
  }

  .deal-week-skeleton-card {
    height: 400px;
    border-radius: 8px;
    background: linear-gradient(
      90deg,
      #f0f0f0 25%,
      #f8f8f8 37%,
      #f0f0f0 63%
    );
    background-size: 400% 100%;
    animation: dealWeekShimmer 1.4s ease infinite;
  }

  @keyframes dealWeekShimmer {
    0% { background-position: 100% 0; }
    100% { background-position: -100% 0; }
  }

  .deal-week-content-wrapper {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .deal-week-skeleton-wrapper {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 15px;
      padding: 20px 0;
    }
    
    .deal-week-skeleton-card {
      height: 320px;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .deal-week-skeleton-wrapper {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    }
  }

  /* ===== Original Styles ===== */
  .deal-week-section-{{ section.id }} .card__media img { content-visibility:auto; contain-intrinsic-size: 380px 380px; display: block; width: 100%; height: auto; object-fit: cover; }
  .deal-week-section-{{ section.id }} .scroll-trigger { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .deal-week-section-{{ section.id }} .scroll-trigger.is-visible { opacity: 1; transform: translateY(0); }
  .deal-week-section-{{ section.id }} .card__inner { contain: layout inline-size style; }
  .product-card-link{ padding-right:2px !important; }
  .card__content .card__information{ padding-left: 10px !important; padding-right: 4px !important; }
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top}}px; padding-bottom: {{ section.settings.padding_bottom}}px; }
  .deal-week-section-{{ section.id }} * { box-sizing: border-box; }

  .deal-week-section-{{ section.id }} .iWishAddColl, .deal-week-section-{{ section.id }} .wishlist-app-links { display: block !important; visibility: visible !important; }
  .deal-week-section-{{ section.id }} .product-collection-card-icons { display: none !important; }
  
  @media screen and (max-width: 750px) {
    .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: 0px !important; }
  }
  
  .price--on-sale .price-item--regular{ padding-left:5px; color:black; }
  .card__content span.price-item.price-item--sale, .price-item{ color:black; }
  
  .deal-week-section-{{ section.id }} .color-variants-options { display: flex !important; }
  .deal-week-section-{{ section.id }} .product-collection-card-icons { display: none !important; }
  .deal-week-section-{{ section.id }} .carousel-container { display: flex !important; }
  .deal-week-section-{{ section.id }} .card__inner.ratio { height: 0; padding-bottom: var(--ratio-percent, 100%); }
  .deal-week-section-{{ section.id }} .card__media { overflow: hidden; position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
  .deal-week-section-{{ section.id }} .iWishAddColl, .deal-week-section-{{ section.id }} .wishlist-app-links { display: block !important; visibility: visible !important; }
  .deal-week-container {margin: 0 auto; padding: 0px 0px; background:white; }
  .section-template--20408693489882__deal_of_the_week_R34MA6-padding{background:white;}
  .iWishAddColl {z-index: 1 !important;}

  .deal-week-load-more-wrapper {
    display: none;
    text-align: center;
  }

  .deal-week-load-more-btn {
    border: 0;
    color: #b77766;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    border-radius: 12px;
    cursor: pointer;
    transition: background-color 0.3s ease;
    font-family: 'Futura Std', sans-serif;
    letter-spacing: 0.5px;
    background: transparent;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .deal-week-load-more-btn:hover {
    background-color:transparent;
  }

  @media screen and (max-width: 749px) {
    .card__media{ border:none !important; background:transparent; }
    .deal-week-container { padding: 0px 0px; }
    .card-content-wrapper{ padding: 0 8px; margin-bottom: 4px; margin-top: 15px; }
    .card__heading {font-size:13px !important;}
    .price-item--last{font-size:13px !important;}
    .deal-week-divider-top { position: absolute; top: 50%; left: 0; right: 0; height: 1px !important; z-index: 1; }
    .deal-week-divider-bottom { position: absolute; top: 50%; left: 0; right: 0; height: 1px !important; z-index: 1; }
    
    .deal-week-section-{{ section.id }} .deal-week-products-grid:not(.show-all) .grid__item:nth-child(n+5) {
      display: none !important;
    }
    
    .deal-week-section-{{ section.id }} .deal-week-products-grid.show-all .grid__item {
      display: block !important;
    }
    
    .deal-week-load-more-wrapper {
      display: block;
    }
  }

  @media screen and (min-width: 750px) {
    .deal-week-load-more-wrapper {
      display: none !important;
    }
  }

  .deal-week-header { text-align: center; margin-top: 40px; position: relative; margin-bottom: -20px; }
  .deal-week-title-wrapper { display: inline-block; border-top: 2px solid #b77766; border-left: 2px solid #b77766; border-right: 2px solid #b77766; border-radius: 60px 60px 0 0; padding: 20px 60px 0 60px; background-color: white; position: relative; z-index: 2; top: -41px; }
  .deal-week-title { font-size: 24px; font-family: 'Futura Std' !important; font-weight: 500; letter-spacing: 0.7px; margin: 0 0 0 0; color: #1a1a1a; text-transform: uppercase; }
  .deal-week-subtitle { font-size: 18px; color: #666; margin: 0; font-weight: 400; }
  .deal-week-divider-top { position: absolute; top: 50%; left: 0; right: 0; height: 1.5px; background: linear-gradient(to right, #b77766 0%, #b77766 45%, transparent 45%, transparent 55%, #b77766 55%, #b77766 100%); z-index: 1; }
  .deal-week-diamond { width: 40px; height: 40px; position: absolute; top: 50%; transform: translateY(-50%); display: flex; align-items: center; justify-content: center; padding: 5px; }
  .deal-week-diamond img { width: 100%; height: 100%; object-fit: contain; }
  .deal-week-diamond.left { left: -8px; }
  .deal-week-diamond.right { right: -8px; }
  .deal-week-products-grid { display: grid; grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr); gap: 12px;  list-style: none; padding: 0; }
  .deal-week-section-{{ section.id }} .card-wrapper { background-color: white; }

  @media screen and (max-width: 749px) {
    .deal-week-products-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 15px; }
    .deal-week-section-{{ section.id }} .grid__item { max-width: 100%; min-width: 0; }
    .deal-week-title-wrapper { top: -32.5px !important; position: relative; padding: 16px 20px 8px 20px; border-radius: 24px 24px 0 0; border-top: 1px solid #b77766; border-left: 1px solid #b77766; border-right: 1px solid #b77766; }
  }

  @media screen and (max-width: 989px) and (min-width: 750px) {
    .deal-week-products-grid { grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr); gap: var(--grid-mobile-horizontal-spacing); margin:0; }
  }

  .deal-week-products-grid .product-card-wrapper .label-amount{ position: absolute; top: 12px; left: 12px; background: #b77766; font-size: 12px; font-weight: 500; padding: 2px 12px; border-radius: 3rem; display: block; color:#fff; }
  .deal-week-section-{{ section.id }} .grid__item { width: 100%; max-width: 100%; }

  .deal-week-logo { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; min-height: 400px; background-color: white; border: 1px solid #b77766; border-radius: 10px; }
  .deal-week-logo-oval { width: 120px; height: 180px; border: 3px solid #b77766; border-radius: 60px; display: flex; align-items: center; justify-content: center; background-color: transparent; }
  .deal-week-logo-letter { font-size: 100px; font-weight: 600; color: #b77766; font-family: serif; line-height: 1; }
  .deal-week-logo-diamond { width: 10px; height: 10px; background-color: #b77766; transform: rotate(45deg); }
  .deal-week-footer { text-align: center; position: relative; margin-bottom: 50px;height: 20px; }
  .deal-week-countdown-wrapper { display: inline-block; border-bottom: 2px solid #b77766; border-left: 2px solid #b77766; border-right: 2px solid #b77766; border-radius: 0 0 60px 60px; padding: 0px 55px 10px 55px; background-color: white; position: relative; z-index: 2; bottom: -10px; }
  .deal-week-countdown-text { font-size: 18px; color: #222; margin: 0 0 0 0; }
  .deal-week-countdown-time { font-size: 24px; font-weight: 500; font-family: "Futura Std" !important; letter-spacing: 0.7px; margin: 0; color: #1a1a1a; text-transform: uppercase; }
  .deal-week-divider-bottom { position: absolute; top: 50%; left: 0; right: 0; height: 1.5px; background: linear-gradient(to right, #b77766 0%, #b77766 45%, transparent 45%, transparent 55%, #b77766 55%, #b77766 100%); z-index: 1; }

  @media screen and (min-width: 767px) and (max-width: 1199px) {
    .deal-week-divider-top {height: 1px;}
    .deal-week-title-wrapper { display: inline-block; border-top: 1.5px solid #b77766; border-left: 1.5px solid #b77766; border-right: 1.5px solid #b77766; border-radius: 60px 60px 0 0; padding: 20px 60px 0 60px; background-color: white; position: relative; z-index: 2; top: -41px; }
    .deal-week-divider-bottom {height: 1.5px;}
    .deal-week-countdown-wrapper { display: inline-block; border-bottom: 1.5px solid #b77766; border-left: 1.5px solid #b77766; border-right: 1.5px solid #b77766; border-radius: 0 0 60px 60px; padding: 0px 55px 10px 55px; background-color: white; position: relative; z-index: 2; bottom: -9px; }
  }
  @media screen and (min-width: 1199px) and (max-width: 2000px) {
    .deal-week-countdown-wrapper {
    bottom: -9px; 
    }
  }

  @media screen and (max-width: 749px) {
    .section-template--20425505374426__deal_of_the_week_zdPDRd-padding{ padding-bottom:0 !important; }
    .deal-week-countdown-wrapper { display: inline-block; border-bottom: 1px solid #b77766; border-left: 1px solid #b77766; border-right: 1px solid #b77766; border-radius: 0 0 24px 24px; background-color: white; position: relative; z-index: 2; bottom: -9.5px !important; }
    .deal-week-title { font-size: 16px; }
    .deal-week-subtitle { font-size: 12px; }
    .deal-week-countdown-wrapper{ padding: 8px 22px 12px 22px; }
    .deal-week-logo { min-height: 300px; }
    .deal-week-logo-oval { width: 80px; height: 120px; }
    .deal-week-logo-letter { font-size: 60px; }
    .deal-week-diamond { width: 30px; height: 30px; }
    .deal-week-diamond.left { left: -10px; }
    .deal-week-diamond.right { right: -10px; }
    .deal-week-countdown-time { font-size: 16px !important; }
    .deal-week-countdown-text { font-size: 12px !important; }
    .deal-week-products-grid .product-card-wrapper .label-amount{ position: absolute; top: 12px; left: 12px; background: #b77766; font-size: 10px; font-weight: 500; padding: 2px 10px; border-radius: 3rem; display: block; color:#fff; }
  }

  @media screen and (min-width: 404px) and (max-width: 441px) {
    .deal-week-title-wrapper {  top: -32px !important; }
    .deal-week-countdown-wrapper{ bottom: -10px !important; }
    .section-template--20425505374426__deal_of_the_week_zdPDRd-padding{ padding-bottom:0 !important; }
  }

  .section-template--20425505374426__deal_of_the_week_zdPDRd-padding{ padding-bottom: 30px ; }
{%- endstyle -%}

{%- liquid
  assign products_to_display = section.blocks.size
  assign skip_card_product_styles = false
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign columns_desktop_int = section.settings.columns_desktop | plus: 0

  assign max_columns_to_show = columns_mobile_int
  if columns_desktop_int > columns_mobile_int
    assign max_columns_to_show = columns_desktop_int
  endif

  assign start_date = section.settings.deal_start_date
  assign total_days = section.settings.days_remaining

  if start_date != blank
    assign current_timestamp = 'now' | date: '%s' | plus: 0
    assign start_timestamp = start_date | date: '%s' | plus: 0
    assign seconds_elapsed = current_timestamp | minus: start_timestamp
    assign days_elapsed = seconds_elapsed | divided_by: 86400
    assign calculated_days = total_days | minus: days_elapsed

    if calculated_days < 0
      assign calculated_days = 0
    endif
  else
    assign calculated_days = total_days
  endif
-%}

<div
  class="color-{{ section.settings.color_scheme }} isolate gradient deal-week-section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-deal-week-lazy
>
  <div class="section-{{ section.id }}-padding">
    <div class="page-width">
      <div class="deal-week-container">
        
        <!-- ===== SKELETON LOADER ===== -->
        <div class="deal-week-skeleton-wrapper">
          {%- for i in (1..8) -%}
            <div class="deal-week-skeleton-card"></div>
          {%- endfor -%}
        </div>

        <!-- ===== ACTUAL CONTENT ===== -->
        <div class="deal-week-content-wrapper">
          {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
            <div class="deal-week-header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
              <div class="deal-week-divider-top">
                <div class="deal-week-diamond left">
                  <svg width="30" height="30">
                    <use href="#icon-lucira-circle"></use>
                  </svg>
                </div>
                <div class="deal-week-diamond right">
                  <svg width="30" height="30">
                    <use href="#icon-lucira-circle"></use>
                  </svg>
                </div>
              </div>
              <div class="deal-week-title-wrapper">
                {%- if section.settings.title != blank -%}
                  <h2 class="deal-week-title inline-richtext {{ section.settings.heading_size }}">
                    {{ section.settings.title }}
                  </h2>
                {%- endif -%}
                {%- if section.settings.subtitle != blank -%}
                  <p class="deal-week-subtitle">{{ section.settings.subtitle }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          <ul
            id="deal-week-grid-{{ section.id }}"
            class="deal-week-products-grid grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down"
            role="list"
          >
            {%- for block in section.blocks -%}
              {% assign lazy_load = false %}
              {% if skip_card_product_styles == false and forloop.index > max_columns_to_show %}
                {% assign lazy_load = true %}
              {% endif %}

              <li
                class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {%- if block.settings.product != blank -%}
                  {%- assign product = block.settings.product -%}
                  {% capture di_values %}
                    {% render 'di-discount-calc' %}
                  {% endcapture %}

                  {% assign di_parts = di_values | strip | split: '|' %}
                  {% assign diamond_percent = di_parts[0] | plus: 0 %}
                  {% assign mc_percent = di_parts[1] | plus: 0 %}
                  {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    image_shape: section.settings.image_shape,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    lazy_load: lazy_load,
                    skip_styles: skip_card_product_styles,
                    section_id: section.id,
                    quick_add: section.settings.quick_add,
                    diamond_percent: diamond_percent,
                    mc_percent: mc_percent
                  %}
                  {%- assign skip_card_product_styles = true -%}
                {%- else -%}
                  <div class="deal-week-logo">
                    <div class="deal-week-logo-oval">
                      <span class="deal-week-logo-letter">{{ block.settings.logo_letter }}</span>
                    </div>
                    <div class="deal-week-logo-diamond"></div>
                  </div>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>

          {%- if section.blocks.size > 4 -%}
            <div class="deal-week-load-more-wrapper" id="load-more-wrapper-{{ section.id }}">
              <button 
                class="deal-week-load-more-btn" 
                id="load-more-btn-{{ section.id }}"
                type="button"
                aria-label="Load more products"
              >
                Load More
              </button>
            </div>
          {%- endif -%}

          {%- if section.settings.show_countdown -%}
            <div class="deal-week-footer{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
              <div class="deal-week-divider-bottom">
                <div class="deal-week-diamond left">
                  <svg width="30" height="30">
                    <use href="#icon-lucira-circle"></use>
                  </svg>
                </div>
                <div class="deal-week-diamond right">
                  <svg width="30" height="30">
                    <use href="#icon-lucira-circle"></use>
                  </svg>
                </div>
              </div>
              <div class="deal-week-countdown-wrapper">
                {%- if section.settings.countdown_text != blank -%}
                  <p class="deal-week-countdown-text">{{ section.settings.countdown_text }}</p>
                {%- endif -%}
                {%- if calculated_days > 0 -%}
                  <p class="deal-week-countdown-time">
                    ENDS IN {{ calculated_days }} DAY{% if calculated_days > 1 %}S{% endif %}
                  </p>
                {%- else -%}
                  <p class="deal-week-countdown-time">DEAL EXPIRED</p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
        <!-- ===== END ACTUAL CONTENT ===== -->

      </div>
    </div>
  </div>
</div>

<script>
  // ===== SKELETON INTERSECTION OBSERVER =====
  (function () {
    const dealWeekSection = document.querySelector('[data-deal-week-lazy]');
    if (!dealWeekSection) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const skeleton = dealWeekSection.querySelector('.deal-week-skeleton-wrapper');
          const content = dealWeekSection.querySelector('.deal-week-content-wrapper');

          if (skeleton && content) {
            // Show content with fade-in
            content.style.display = 'block';
            content.style.opacity = '0';
            content.style.transition = 'opacity 0.5s ease';

            requestAnimationFrame(() => {
              content.style.opacity = '1';
              // Remove skeleton after animation
              setTimeout(() => {
                skeleton.remove();
              }, 500);
            });
          }

          observer.disconnect();
        }
      });
    }, {
      rootMargin: '200px' // Preload 200px before section enters viewport
    });

    observer.observe(dealWeekSection);
  })();

  // ===== LOAD MORE FUNCTIONALITY =====
  (function () {
    const sectionId = '{{ section.id }}';

    function initLoadMore() {
      const loadMoreBtn = document.getElementById(`load-more-btn-${sectionId}`);
      const productGrid = document.getElementById(`deal-week-grid-${sectionId}`);
      const loadMoreWrapper = document.getElementById(`load-more-wrapper-${sectionId}`);

      if (!loadMoreBtn || !productGrid || !loadMoreWrapper) {
        return;
      }

      function isMobile() {
        return window.innerWidth <= 749;
      }

      if (!isMobile() || productGrid.children.length <= 4) {
        loadMoreWrapper.style.display = 'none';
        return;
      }

      loadMoreWrapper.style.display = 'block';

      loadMoreBtn.addEventListener('click', function (e) {
        e.preventDefault();
        
        productGrid.classList.add('show-all');
        loadMoreWrapper.style.display = 'none';

        const promoData = {
          event: 'promoClick',
          promoClick: {
            promo_id: 'deal_of_week_load_more',
            creative_name: 'Deal of the Week',
            promo_name: 'Load More Button',
          },
        };

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push(promoData);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLoadMore);
    } else {
      initLoadMore();
    }

    window.addEventListener('resize', function () {
      const loadMoreWrapper = document.getElementById(`load-more-wrapper-${sectionId}`);
      const productGrid = document.getElementById(`deal-week-grid-${sectionId}`);

      if (loadMoreWrapper && productGrid) {
        if (window.innerWidth > 749) {
          loadMoreWrapper.style.display = 'none';
          productGrid.classList.remove('show-all');
        } else if (productGrid.children.length > 4 && !productGrid.classList.contains('show-all')) {
          loadMoreWrapper.style.display = 'block';
        }
      }
    });
  })();

  // ===== ANALYTICS TRACKING =====
  document.addEventListener('DOMContentLoaded', () => {
    const sectionId = '{{ section.id }}';
    const dealWeekSection = document.querySelector(`.deal-week-section-${sectionId}`);
    if (!dealWeekSection) return;

    // Product Click Tracking
    dealWeekSection.querySelectorAll('.card-wrapper').forEach((card, index) => {
      const clickableElements = card.querySelectorAll(
        'a.card-link, a.card__heading, a.card__title, .product-card-link, .card__media img'
      );

      clickableElements.forEach((el) => {
        el.addEventListener('click', (event) => {
          const productTitle = card.querySelector('.card__heading, .card__title')?.textContent.trim() || '';
          const productSku = card.querySelector('[data-sku]')?.dataset.sku || '';

          const promoData = {
            event: 'promoClick',
            promoClick: {
              promo_id: productSku || `deal_of_week_product_${index + 1}`,
              creative_name: 'Deal of the Week',
              promo_name: productTitle,
            },
          };

          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push(promoData);
        });
      });
    });

    // Color Option Change Tracking
    dealWeekSection.querySelectorAll('.color-option').forEach((button) => {
      button.addEventListener('click', (event) => {
        const targetButton = event.currentTarget;
        const productId = targetButton.dataset.productId;
        const newImageSrc = targetButton.dataset.imageSrc;
        const newImageAlt = targetButton.dataset.imageAlt;
        const newVariantId = targetButton.dataset.variantId;

        const mainImage = document.getElementById(`product-image-${productId}`);
        if (mainImage && newImageSrc) {
          mainImage.setAttribute('src', newImageSrc);
          mainImage.setAttribute('srcset', newImageSrc);
          mainImage.setAttribute('alt', newImageAlt);

          const productCard = targetButton.closest('.card-wrapper');
          if (productCard) {
            productCard.querySelectorAll('.color-option').forEach((btn) => btn.classList.remove('active'));
            targetButton.classList.add('active');

            if (newVariantId) {
              const variantInput = productCard.querySelector('input[name="id"]');
              if (variantInput) variantInput.value = newVariantId;
            }
          }
        }
      });
    });

    // Video Click Tracking
    dealWeekSection.querySelectorAll('.product-video-icon-wrapper').forEach((wrapper) => {
      wrapper.addEventListener('click', (event) => {
        const productId = event.currentTarget.dataset.productId;
        const videoId = event.currentTarget.dataset.videoId;
        const card = wrapper.closest('.card-wrapper');
        const productTitle = card?.querySelector('.card__heading, .card__title')?.textContent.trim() || '';
        const productSku = card?.querySelector('[data-sku]')?.dataset.sku || '';

        const promoData = {
          event: 'promoClick',
          promoClick: {
            promo_id: productSku || productId,
            creative_name: 'Deal of the Week - Video',
            promo_name: productTitle,
          },
        };

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push(promoData);
      });
    });
  });
</script>

