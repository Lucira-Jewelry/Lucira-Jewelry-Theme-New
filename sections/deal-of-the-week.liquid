          if (form) productId = form.dataset.productId;
        }
        
        const productPrice = card.querySelector('.price-item--sale, .price-item, .price__regular .price-item, .price')?.textContent.trim() || '';
        
        // Determine what was clicked
        let clickedElement = 'card';
        if (event.target.closest('.card__media, .media, img')) {
          clickedElement = 'image';
        } else if (event.target.closest('.card__heading, .card__title, .card__information')) {
          clickedElement = 'title';
        } else if (event.target.closest('.price, .card__badge, .price__container')) {
          clickedElement = 'price';
        }

        // Push to dataLayer
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "promoClick",
          promoClick: {
            promo_id: productId || `deal_of_week_product_${index + 1}`,
            creative_name: `Deal_of_the_Week_${productTitle.replace(/\s+/g, '_')}`,
            promo_position: `deal_of_week_position_${index + 1}`,
            product_name: productTitle,
            product_price: productPrice,
            clicked_element: clickedElement
          },
          ecommerce: {
            promoClick: {
              promotions: [{
                id: productId || `deal_of_week_product_${index + 1}`,
                name: productTitle,
                creative: "Deal of the Week Section",
                position: `slot_${index + 1}`
              }]
            }
          }
        });

        console.log('✅ Deal of Week Click Tracked:', {
          product: productTitle,
          clickedOn: clickedElement,
          navigatingTo: productUrl
        });

        // Navigate to product page after a small delay to allow dataLayer push
        setTimeout(() => {
          window.location.href = productUrl;
        }, 100);
      });

      // Make the cursor pointer for better UX
      gridItem.style.cursor = 'pointer';
    });

    // Track color variant clicks (with navigation)
    dealWeekSection.querySelectorAll('.color-option').forEach((button) => {
      button.addEventListener('click', (event) => {
        event.stopPropagation(); // Prevent card click
        
        const targetButton = event.currentTarget;
        const productId = targetButton.dataset.productId;
        const newImageSrc = targetButton.dataset.imageSrc;
        const newImageAlt = targetButton.dataset.imageAlt;
        const newVariantId = targetButton.dataset.variantId;
        const colorName = targetButton.getAttribute('title') || targetButton.dataset.colorName || '';

        // Original color swap functionality
        const mainImage = document.getElementById(`product-image-${productId}`);

        if (mainImage && newImageSrc) {
          mainImage.setAttribute('src', newImageSrc);
          mainImage.setAttribute('srcset', newImageSrc);
          mainImage.setAttribute('alt', newImageAlt);

          const productCard = targetButton.closest('.card-wrapper');
          if (productCard) {
            productCard.querySelectorAll('.color-option').forEach((btn) => {
              btn.classList.remove('active');
            });
            targetButton.classList.add('active');
          }

          if (newVariantId) {
            const variantInput = productCard.querySelector('input[name="id"]');
            if (variantInput) {
              variantInput.value = newVariantId;
            }
          }

          // Track color variant selection
          const productTitle = productCard?.querySelector('.card__heading, .card__title')?.textContent.trim() || '';
          
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: "promoClick",
            promoClick: {
              promo_id: productId,
              creative_name: `Deal_Color_Change_${colorName}`,
              promo_position: "deal_of_week_color_variant",
              action_type: "color_selection",
              variant_id: newVariantId,
              color: colorName,
              product_name: productTitle
            }
          });

          console.log('✅ Color Variant Changed:', {
            product: productTitle,
            color: colorName
          });
        }
      });
    });

    // Track video icon clicks (with navigation)
    dealWeekSection.querySelectorAll('.product-video-icon-wrapper').forEach((wrapper) => {
      wrapper.addEventListener('click', (event) => {
        event.stopPropagation(); // Prevent card click
        
        const productId = event.currentTarget.dataset.productId;
        const videoId = event.currentTarget.dataset.videoId;
        const card = wrapper.closest('.card-wrapper');
        const productTitle = card?.querySelector('.card__heading, .card__title')?.textContent.trim() || '';

        // Get product URL
        const productLink = card?.querySelector('a[href*="/products/"]');
        const productUrl = productLink ? productLink.href : null;

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "promoClick",
          promoClick: {
            promo_id: productId,
            creative_name: `Deal_Video_Click_${productTitle.replace(/\s+/g, '_')}`,
            promo_position: "deal_of_week_video",
            action_type: "video_play",
            video_id: videoId
          }
        });

        console.log('✅ Video Icon Clicked:', {
          product: productTitle,
          videoId: videoId,
          navigatingTo: productUrl
        });

        // Navigate to product page with video parameter
        if (productUrl) {
          setTimeout(() => {
            window.location.href = productUrl + (productUrl.includes('?') ? '&' : '?') + 'video=' + videoId;
          }, 100);
        }
      });
    });

    // Track Quick Add button clicks
    dealWeekSection.querySelectorAll('.quick-add__submit, [name="add"]').forEach((button, index) => {
      button.addEventListener('click', (event) => {
        event.stopPropagation(); // Prevent card click
        
        const card = button.closest('.card-wrapper');
        const productTitle = card?.querySelector('.card__heading, .card__title')?.textContent.trim() || '';
        const productId = card?.querySelector('[data-product-id]')?.dataset.productId || '';
        
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "promoClick",
          promoClick: {
            promo_id: productId || `deal_quick_add_${index + 1}`,
            creative_name: `Deal_Quick_Add_${productTitle.replace(/\s+/g, '_')}`,
            promo_position: `deal_of_week_quick_add_${index + 1}`,
            action_type: "quick_add"
          }
        });

        console.log('✅ Quick Add Clicked:', {
          product: productTitle
        });
      });
    });
  });
</script> {% endcomment %}


