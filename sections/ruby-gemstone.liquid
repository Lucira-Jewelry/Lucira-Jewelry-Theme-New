{% comment %}
  Section: image-content-blocks.liquid
  Place in: sections/image-content-blocks.liquid
{% endcomment %}

<section
  id="image-content-blocks-{{ section.id }}"
  class="image-content-section"
  style="
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
    background-color: {{ section.settings.section_bg_color }};
  "
>
  <div class="image-content-section__container">

    {% comment %} Section Header {% endcomment %}
    {% if section.settings.title != blank or section.settings.subtitle != blank %}
      <div class="image-content-section__header">
        {% if section.settings.title != blank %}
          <{{ section.settings.title_tag }} class="image-content-section__title">
            {{ section.settings.title }}
          </{{ section.settings.title_tag }}>
        {% endif %}
        {% if section.settings.subtitle != blank %}
          <p class="image-content-section__subtitle">
            {{ section.settings.subtitle }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    {% comment %} Blocks {% endcomment %}
    {% for block in section.blocks %}
      {% assign is_reversed = block.settings.reverse_layout %}
      <div
        class="image-content-block {% if is_reversed %}image-content-block--reversed{% endif %}"
        style="
          background-color: {{ block.settings.block_bg_color }};
          margin-bottom: {{ section.settings.block_gap }}px;
        "
        {{ block.shopify_attributes }}
      >

        {% comment %} Image Side {% endcomment %}
        <div class="image-content-block__image-wrapper">
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                widths: '400, 600, 900',
                sizes: '(max-width: 767px) 100vw, 50vw',
                class: 'image-content-block__image',
                alt: block.settings.image.alt | escape
            }}
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag: 'image-content-block__image image-content-block__image--placeholder' }}
          {% endif %}
        </div>

        {% comment %} Content Side {% endcomment %}
        <div
          class="image-content-block__content"
          style="padding: 20px 0;"
        >
          {% if block.settings.eyebrow != blank %}
            <p class="image-content-block__eyebrow">{{ block.settings.eyebrow }}</p>
          {% endif %}

          {% if block.settings.heading != blank %}
            <h3 class="image-content-block__heading">{{ block.settings.heading }}</h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <div class="image-content-block__description">{{ block.settings.description }}</div>
          {% endif %}

          {% comment %} Specs / Key-Value List {% endcomment %}
          {% if block.settings.show_specs %}
            <div class="image-content-block__specs">
              {% for i in (1..5) %}
                {% assign label_key = 'spec_label_' | append: i %}
                {% assign value_key = 'spec_value_' | append: i %}
                {% assign label = block.settings[label_key] %}
                {% assign value = block.settings[value_key] %}
                {% if label != blank and value != blank %}
                  <div class="image-content-block__spec-row">
                    <span class="image-content-block__spec-label">{{ label }}</span>
                    <span class="image-content-block__spec-value">{{ value }}</span>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}

          {% if block.settings.button_label != blank and block.settings.button_link != blank %}
            <a
              href="{{ block.settings.button_link }}"
              class="image-content-block__button {% if block.settings.button_style == 'outline' %}image-content-block__button--outline{% endif %}"
            >
              {{ block.settings.button_label }}
            </a>
          {% endif %}
        </div>

      </div>
    {% endfor %}

  </div>
</section>

<style>
  /* =========================================================
     CSS CUSTOM PROPERTIES (override in settings_schema.json
     or theme editor if needed)
     ========================================================= */
  #image-content-blocks-{{ section.id }} {
    --ic-font-family: {{ section.settings.font_family }};
    --ic-title-size: {{ section.settings.title_font_size }}px;
    --ic-subtitle-size: {{ section.settings.subtitle_font_size }}px;
    --ic-heading-size: {{ section.settings.block_heading_size }}px;
    --ic-body-size: {{ section.settings.body_font_size }}px;
    --ic-spec-label-size: {{ section.settings.spec_label_size }}px;
    --ic-text-color: {{ section.settings.text_color }};
    --ic-heading-color: {{ section.settings.heading_color }};
    --ic-image-height: {{ section.settings.image_min_height }}px;
    --ic-border-color: {{ section.settings.spec_border_color }};
    --ic-max-width: {{ section.settings.max_content_width }}px;
    --ic-letter-spacing: {{ section.settings.title_letter_spacing | divided_by: 100.0 }}em;
  }

  /* =========================================================
     SECTION WRAPPER
     ========================================================= */
  .image-content-section {
    width: 100%;
  }

  .image-content-section__container {
    max-width: var(--ic-max-width);
    margin: 0 auto;
    padding: 0 20px;
  }

  /* =========================================================
     SECTION HEADER
     ========================================================= */
  .image-content-section__header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto {{ section.settings.header_bottom_gap }}px;
  }

  .image-content-section__title {
    font-family: var(--ic-font-family);
    font-size: var(--ic-title-size);
    font-weight: {{ section.settings.title_font_weight }};
    color: var(--ic-heading-color);
    letter-spacing: var(--ic-letter-spacing);
    text-transform: {{ section.settings.title_text_transform }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .image-content-section__subtitle {
    font-family: var(--ic-font-family);
    font-size: var(--ic-subtitle-size);
    color: var(--ic-text-color);
    line-height: 1.7;
    margin: 0;
  }

  /* =========================================================
     BLOCK LAYOUT — DEFAULT: image left, content right
     ========================================================= */
  .image-content-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    overflow: hidden;
  }

  /* REVERSED: image right, content left */
  .image-content-block--reversed {
    direction: rtl; /* flip column order */
  }

  .image-content-block--reversed > * {
    direction: ltr; /* reset inner content direction */
  }

  /* =========================================================
     IMAGE
     ========================================================= */
  .image-content-block__image-wrapper {
    position: relative;
    overflow: hidden;
    min-height: var(--ic-image-height);
  }

  .image-content-block__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .image-content-block__image--placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: #f0f0f0;
  }

  /* =========================================================
     CONTENT
     ========================================================= */
  .image-content-block__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
    background:white;
  }

  .image-content-block__eyebrow {
    font-family: var(--ic-font-family);
    font-size: var(--ic-spec-label-size);
    color: var(--ic-text-color);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
    opacity: 0.7;
  }

  .image-content-block__heading {
    font-family: var(--ic-font-family);
    font-size: var(--ic-heading-size);
    font-weight: {{ section.settings.title_font_weight }};
    color: var(--ic-heading-color);
    letter-spacing: var(--ic-letter-spacing);
    text-transform: {{ section.settings.title_text_transform }};
    margin: 0;
    line-height: 1.2;
  }

  .image-content-block__description {
    font-family: var(--ic-font-family);
    font-size: var(--ic-body-size);
    color: var(--ic-text-color);
    line-height: 1.7;
    margin: 0;
  }

  /* =========================================================
     SPECS TABLE
     ========================================================= */
  .image-content-block__specs {
    margin-top: 8px;
    border-top: 1px solid var(--ic-border-color);
  }

  .image-content-block__spec-row {
    display: grid;
    grid-template-columns: {{ section.settings.spec_label_width }}px 1fr;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--ic-border-color);
    align-items: baseline;
  }

  .image-content-block__spec-label {
    font-family: var(--ic-font-family);
    font-size: var(--ic-spec-label-size);
    font-weight: 600;
    color: var(--ic-heading-color);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .image-content-block__spec-value {
    font-family: var(--ic-font-family);
    font-size: var(--ic-body-size);
    color: var(--ic-text-color);
  }

  /* =========================================================
     BUTTON
     ========================================================= */
  .image-content-block__button {
    display: inline-block;
    margin-top: 8px;
    padding: 12px 28px;
    background-color: var(--ic-heading-color);
    color: #fff;
    font-family: var(--ic-font-family);
    font-size: var(--ic-body-size);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.2s ease;
    align-self: flex-start;
  }

  .image-content-block__button:hover {
    opacity: 0.8;
  }

  .image-content-block__button--outline {
    background-color: transparent;
    border: 1px solid var(--ic-heading-color);
    color: var(--ic-heading-color);
  }

  .image-content-block__button--outline:hover {
    background-color: var(--ic-heading-color);
    color: #fff;
    opacity: 1;
  }

  /* =========================================================
     RESPONSIVE — TABLET
     ========================================================= */
  @media screen and (max-width: 1024px) {
    .image-content-block__content {
      gap: 12px;
    }
  }

  /* =========================================================
     RESPONSIVE — MOBILE
     image stacks on top, content below
     ========================================================= */
  @media screen and (max-width: 767px) {
    .image-content-block {
      grid-template-columns: 1fr;
      direction: ltr; /* reset RTL for reversed blocks on mobile */
    }

    .image-content-block--reversed > * {
      direction: ltr;
    }

    .image-content-block__image-wrapper {
      min-height: {{ section.settings.mobile_image_height }}px;
    }

    .image-content-section__title {
      font-size: calc(var(--ic-title-size) * 0.75);
    }

    .image-content-block__heading {
      font-size: calc(var(--ic-heading-size) * 0.65);
      font-weight:500;
    }

    .image-content-section__header {
      margin-bottom: 40px;
    }
  }
</style>

{% schema %}
{
  "name": "Image Content Blocks",
  "tag": "section",
  "class": "shopify-section-image-content-blocks",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "WHAT IS RUBY"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Title HTML Tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle / Description",
      "default": "Ruby is a rare variety of the mineral corundum, belonging to the prestigious family of cardinal gemstones."
    },
    {
      "type": "range",
      "id": "header_bottom_gap",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Header to Blocks Gap",
      "default": 60
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "range",
      "id": "max_content_width",
      "min": 800,
      "max": 1600,
      "step": 40,
      "unit": "px",
      "label": "Max Container Width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Section Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Section Padding Bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "block_gap",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Gap Between Blocks",
      "default": 0
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font Family",
      "options": [
        { "value": "inherit", "label": "Theme Default" },
        { "value": "'Times New Roman', serif", "label": "Times New Roman" },
        { "value": "Georgia, serif", "label": "Georgia" },
        { "value": "'Arial', sans-serif", "label": "Arial" },
        { "value": "'Helvetica Neue', Helvetica, sans-serif", "label": "Helvetica Neue" },
        { "value": "'Futura', 'Century Gothic', sans-serif", "label": "Futura / Century Gothic" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "title_text_transform",
      "label": "Title Text Transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Title / Heading Font Weight",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi Bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "title_letter_spacing",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "em",
      "label": "Title Letter Spacing",
      "default": 10,
      "info": "Divided by 100 internally. E.g. 10 = 0.10em letter-spacing"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 18,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Section Title Font Size",
      "default": 28
    },
    {
      "type": "range",
      "id": "subtitle_font_size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Subtitle Font Size",
      "default": 14
    },
    {
      "type": "range",
      "id": "block_heading_size",
      "min": 14,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Block Heading Font Size",
      "default": 22
    },
    {
      "type": "range",
      "id": "body_font_size",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Body / Value Font Size",
      "default": 13
    },
    {
      "type": "range",
      "id": "spec_label_size",
      "min": 9,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Spec Label Font Size",
      "default": 11
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading / Label Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Image Settings"
    },
    {
      "type": "range",
      "id": "image_min_height",
      "min": 200,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Image Min Height (desktop)",
      "default": 480
    },
    {
      "type": "range",
      "id": "mobile_image_height",
      "min": 200,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Image Height (mobile)",
      "default": 300
    },
    {
      "type": "header",
      "content": "Specs Table"
    },
    {
      "type": "color",
      "id": "spec_border_color",
      "label": "Spec Row Border Color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "spec_label_width",
      "min": 80,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Spec Label Column Width",
      "default": 140
    }
  ],
  "blocks": [
    {
      "type": "image_content",
      "name": "Image + Content Block",
      "settings": [
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "type": "checkbox",
          "id": "reverse_layout",
          "label": "Reverse Layout (Image Right, Content Left)",
          "default": false
        },
        {
          "type": "color",
          "id": "block_bg_color",
          "label": "Block Background Color",
          "default": "#ffffff"
        },
        {
          "type": "range",
          "id": "content_padding",
          "min": 20,
          "max": 100,
          "step": 4,
          "unit": "px",
          "label": "Content Inner Padding",
          "default": 48
        },
        {
          "type": "header",
          "content": "Image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow Text (small label above heading)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "RUBY'S SPECS AND CHARACTERISTICS"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Ruby is a corundum gemstone made of aluminum oxide, prized for its exceptional hardness.</p>"
        },
        {
          "type": "header",
          "content": "Specs / Key-Value Rows"
        },
        {
          "type": "checkbox",
          "id": "show_specs",
          "label": "Show Specs Table",
          "default": true
        },
        {
          "type": "text",
          "id": "spec_label_1",
          "label": "Spec 1 — Label",
          "default": "COLOR"
        },
        {
          "type": "text",
          "id": "spec_value_1",
          "label": "Spec 1 — Value",
          "default": "Red, Orange-Red, Purplish Red, Pinkish-Red"
        },
        {
          "type": "text",
          "id": "spec_label_2",
          "label": "Spec 2 — Label",
          "default": "CRYSTAL STRUCTURE"
        },
        {
          "type": "text",
          "id": "spec_value_2",
          "label": "Spec 2 — Value",
          "default": "Trigonal"
        },
        {
          "type": "text",
          "id": "spec_label_3",
          "label": "Spec 3 — Label",
          "default": "LUSTER"
        },
        {
          "type": "text",
          "id": "spec_value_3",
          "label": "Spec 3 — Value",
          "default": "Sub adamantine, Vitreous"
        },
        {
          "type": "text",
          "id": "spec_label_4",
          "label": "Spec 4 — Label",
          "default": "TRANSPARENCY"
        },
        {
          "type": "text",
          "id": "spec_value_4",
          "label": "Spec 4 — Value",
          "default": "Transparent to Translucent"
        },
        {
          "type": "text",
          "id": "spec_label_5",
          "label": "Spec 5 — Label",
          "default": "REFRACTIVE INDEX"
        },
        {
          "type": "text",
          "id": "spec_value_5",
          "label": "Spec 5 — Value",
          "default": "1.757-1.779"
        },
        {
          "type": "header",
          "content": "Button (Optional)"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "info": "Leave empty to hide button"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button Style",
          "options": [
            { "value": "filled", "label": "Filled" },
            { "value": "outline", "label": "Outline" }
          ],
          "default": "outline"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Content Blocks",
      "blocks": [
        {
          "type": "image_content",
          "settings": {
            "heading": "RUBY'S SPECS AND CHARACTERISTICS",
            "reverse_layout": false,
            "show_specs": true
          }
        },
        {
          "type": "image_content",
          "settings": {
            "heading": "RUBY'S HISTORY",
            "reverse_layout": true,
            "show_specs": false,
            "block_bg_color": "#111111"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["*"]
  }
}
{% endschema %}
