  "settings": [
    {
      "type": "paragraph",
      "content": "This section automatically loads content from your Primary Tab metaobjects. To manage content, go to: Settings → Custom data → Metaobjects → Primary Tab"
    },
    {
      "type": "header",
      "content": "Design Settings"
    },
    {
      "type": "color",
      "id": "cta_button_color",
      "label": "CTA Button Color",
      "default": "#c9a05f"
    },
    {
      "type": "color",
      "id": "active_tab_color",
      "label": "Secondary Active Tab Color",
      "default": "#2c2c2c"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#2c2c2c"
    }
  ],
  "presets": [
    {
      "name": "Nested Information Page"
    }
  ]
}
{% endschema %}
