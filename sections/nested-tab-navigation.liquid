{% comment %} {% assign primary_tabs = shop.metaobjects.primary_tab.values | where: 'is_active', true | sort: 'tab_order' %}

{% comment %} Set initial active tabs {% endcomment %}
{% assign initial_primary = primary_tabs.first %}

{% comment %} ==================== SECTION SETTINGS ==================== {% endcomment %}

<div class="nip-nested-info-page" data-section-id="{{ section.id }}">
  {% comment %} ==================== MAIN CONTENT WRAPPER ==================== {% endcomment %}

  {% for primary_tab in primary_tabs %}
    <div
      class="nip-tab-content-wrapper{% if forloop.first %} nip-active{% endif %}"
      data-primary-content="{{ primary_tab.tab_key.value }}"
    >
      {% comment %} ==================== BANNER SECTION ==================== {% endcomment %}

      <div
        class="nip-banner-section"
        {% if primary_tab.banner_image.value %}
          style="background-image: url('{{ primary_tab.banner_image.value | image_url: width: 2000 }}');"
        {% endif %}
      >
        <div class="nip-banner-content">
          <div class="nip-container">
            <h2 class="nip-banner-title">{{ primary_tab.banner_title.value }}</h2>
            {% if primary_tab.banner_subtitle.value != blank %}
              <p class="nip-banner-subtitle">{{ primary_tab.banner_subtitle.value }}</p>
            {% endif %}
          </div>
        </div>
      </div>

      {% comment %} PRIMARY NAVIGATION BELOW BANNER {% endcomment %}
      <nav class="nip-primary-nav">
        <div class="nip-container">
          <div class="nip-primary-nav-wrapper">
            {% for p_tab in primary_tabs %}
              <button
                class="nip-primary-nav-item{% if p_tab.tab_key.value == primary_tab.tab_key.value %} nip-active{% endif %}"
                data-primary-tab="{{ p_tab.tab_key.value }}"
                data-tab-index="{{ forloop.index0 }}"
              >
                {{ p_tab.display_label.value }}
              </button>
            {% endfor %}
            {% comment %} <a href="/collections/all" class="nip-browse-btn">Browse</a> {% endcomment %}
          </div>
        </div>
      </nav>

      {% comment %} ==================== SECONDARY NAVIGATION (Sticky below Primary) ==================== {% endcomment %}

      {% assign secondary_tabs = primary_tab.secondary_tabs.value | where: 'is_active', true | sort: 'tab_order' %}

      <nav class="nip-secondary-nav nip-sticky-nav">
        <div class="nip-container">
          <div class="nip-secondary-nav-wrapper">
            {% for secondary_tab in secondary_tabs %}
              <button
                class="nip-secondary-nav-item{% if forloop.first %} nip-active{% endif %}"
                data-secondary-tab="{{ secondary_tab.tab_key.value }}"
                data-parent="{{ primary_tab.tab_key.value }}"
                data-tab-index="{{ forloop.index0 }}"
              >
                {{ secondary_tab.display_label.value }}
              </button>
            {% endfor %}
          </div>
        </div>
      </nav>

      {% comment %} ==================== CONTENT SECTIONS ==================== {% endcomment %}

      {% for secondary_tab in secondary_tabs %}
        <section
          class="nip-content-section{% if forloop.first %} nip-active{% endif %}"
          data-secondary-content="{{ secondary_tab.tab_key.value }}"
          data-parent="{{ primary_tab.tab_key.value }}"
        >
          <div class="nip-container">
            <div class="nip-content-grid">
              {% comment %} Left: Product Image + CTA {% endcomment %}
              <div class="nip-product-wrapper">
                {% if secondary_tab.product_image.value %}
                  <img
                    src="{{ secondary_tab.product_image.value | image_url: width: 800 }}"
                    srcset="
                      {{ secondary_tab.product_image.value | image_url: width: 400 }} 400w,
                      {{ secondary_tab.product_image.value | image_url: width: 800 }} 800w
                    "
                    sizes="(max-width: 768px) 100vw, 400px"
                    alt="{{ secondary_tab.content_title.value }}"
                    class="nip-product-image"
                    loading="lazy"
                  >
                {% endif %}

                {% if secondary_tab.cta_text.value and secondary_tab.cta_link.value %}
                  <a
                    href="{{ secondary_tab.cta_link.value }}"
                    class="nip-cta-button"
                  >
                    {{ secondary_tab.cta_text.value }}
                  </a>
                {% endif %}
              </div>

              {% comment %} Right: Content Info {% endcomment %}
              <div class="nip-content-info">
                <h2 class="nip-content-title">{{ secondary_tab.content_title.value }}</h2>

                {% if secondary_tab.content_description.value %}
                  <div class="nip-content-description nip-rte">
                    {{ secondary_tab.content_description.value }}
                  </div>
                {% endif %}

                {% comment %} Related Topics {% endcomment %}
                {% if secondary_tab.related_topics.value.size > 0 %}
                  <div class="nip-related-topics">
                    <h3 class="nip-related-topics-title">RELATED TOPICS</h3>
                    <ul class="nip-related-topics-list">
                      {% assign topics = secondary_tab.related_topics.value | sort: 'topic_order' %}
                      {% for topic in topics %}
                        <li class="nip-related-topic-item">
                          <a
                            href="{{ topic.topic_link.value }}"
                            class="nip-related-topic-link"
                          >
                            {{ topic.topic_text.value }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        </section>
      {% endfor %}
    </div>
  {% endfor %}
</div>

{% comment %} ==================== JAVASCRIPT ==================== {% endcomment %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const nestedInfoPage = document.querySelector('.nip-nested-info-page');
    if (!nestedInfoPage) return;

    // ========== MOBILE DETECTION ==========
    function isMobile() {
      return window.innerWidth <= 768;
    }

    // ========== ADD MOBILE NAVIGATION ARROWS ==========
    function addMobileNavigationArrows() {
      const primaryNavWrappers = nestedInfoPage.querySelectorAll('.nip-primary-nav-wrapper');

      primaryNavWrappers.forEach((wrapper) => {
        if (wrapper.querySelector('.nip-primary-nav-arrow')) return;

        const prevArrow = document.createElement('button');
        prevArrow.className = 'nip-primary-nav-arrow nip-prev';
        prevArrow.innerHTML = '‹';
        prevArrow.setAttribute('aria-label', 'Previous tab');

        const nextArrow = document.createElement('button');
        nextArrow.className = 'nip-primary-nav-arrow nip-next';
        nextArrow.innerHTML = '›';
        nextArrow.setAttribute('aria-label', 'Next tab');

        wrapper.appendChild(prevArrow);
        wrapper.appendChild(nextArrow);
      });
    }

    // ========== REMOVE MOBILE NAVIGATION ARROWS ==========
    function removeMobileNavigationArrows() {
      const arrows = nestedInfoPage.querySelectorAll('.nip-primary-nav-arrow');
      arrows.forEach((arrow) => arrow.remove());
    }

    // ========== PRIMARY TAB NAVIGATION (CAROUSEL FOR MOBILE) ==========
    function navigatePrimaryTab(direction) {
      if (!isMobile()) return;

      const allPrimaryNavItems = Array.from(nestedInfoPage.querySelectorAll('.nip-primary-nav-item'));
      const currentActive = allPrimaryNavItems.find((item) => item.classList.contains('nip-active'));
      const currentIndex = allPrimaryNavItems.indexOf(currentActive);

      let newIndex;
      if (direction === 'next') {
        newIndex = (currentIndex + 1) % allPrimaryNavItems.length;
      } else {
        newIndex = (currentIndex - 1 + allPrimaryNavItems.length) % allPrimaryNavItems.length;
      }

      allPrimaryNavItems[newIndex].click();
    }

    // ========== PRIMARY TAB SWITCHING ==========
    const primaryNavItems = nestedInfoPage.querySelectorAll('.nip-primary-nav-item');

    primaryNavItems.forEach((item) => {
      item.addEventListener('click', function () {
        const targetTab = this.dataset.primaryTab;

        const allPrimaryNavItems = nestedInfoPage.querySelectorAll('.nip-primary-nav-item');
        allPrimaryNavItems.forEach((nav) => {
          if (nav.dataset.primaryTab === targetTab) {
            nav.classList.add('nip-active');
          } else {
            nav.classList.remove('nip-active');
          }
        });

        const allPrimaryContent = nestedInfoPage.querySelectorAll('[data-primary-content]');
        allPrimaryContent.forEach((content) => {
          if (content.dataset.primaryContent === targetTab) {
            content.classList.add('nip-active');

            const firstSecondaryNav = content.querySelector('.nip-secondary-nav-item');
            const firstSecondaryContent = content.querySelector('.nip-content-section');

            if (firstSecondaryNav) {
              content.querySelectorAll('.nip-secondary-nav-item').forEach((nav) => nav.classList.remove('nip-active'));
              firstSecondaryNav.classList.add('nip-active');
            }

            if (firstSecondaryContent) {
              content
                .querySelectorAll('.nip-content-section')
                .forEach((section) => section.classList.remove('nip-active'));
              firstSecondaryContent.classList.add('nip-active');
            }
          } else {
            content.classList.remove('nip-active');
          }
        });

        // REMOVED: Auto-scroll behavior to keep page position stable
      });
    });

    // ========== SECONDARY TAB SWITCHING ==========
    const secondaryNavItems = nestedInfoPage.querySelectorAll('.nip-secondary-nav-item');

    secondaryNavItems.forEach((item) => {
      item.addEventListener('click', function () {
        const targetTab = this.dataset.secondaryTab;
        const parentTab = this.dataset.parent;

        const siblingNavs = nestedInfoPage.querySelectorAll(`.nip-secondary-nav-item[data-parent="${parentTab}"]`);
        siblingNavs.forEach((nav) => nav.classList.remove('nip-active'));
        this.classList.add('nip-active');

        const allSecondaryContent = nestedInfoPage.querySelectorAll(`.nip-content-section[data-parent="${parentTab}"]`);
        allSecondaryContent.forEach((content) => {
          if (content.dataset.secondaryContent === targetTab) {
            content.classList.add('nip-active');
          } else {
            content.classList.remove('nip-active');
          }
        });

        // REMOVED: Auto-scroll behavior to keep page position stable
      });
    });

    // ========== MOBILE ARROW CLICK HANDLERS ==========
    function setupMobileArrows() {
      const prevArrows = nestedInfoPage.querySelectorAll('.nip-primary-nav-arrow.nip-prev');
      const nextArrows = nestedInfoPage.querySelectorAll('.nip-primary-nav-arrow.nip-next');

      prevArrows.forEach((arrow) => {
        arrow.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          navigatePrimaryTab('prev');
        });
      });

      nextArrows.forEach((arrow) => {
        arrow.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          navigatePrimaryTab('next');
        });
      });
    }

    // ========== HANDLE RESPONSIVE CHANGES ==========
    function handleResponsive() {
      if (isMobile()) {
        addMobileNavigationArrows();
        setupMobileArrows();
      } else {
        removeMobileNavigationArrows();
      }
    }

    handleResponsive();

    let resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(handleResponsive, 250);
    });

    // ========== KEYBOARD NAVIGATION ==========
    document.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
        const activeNav = document.activeElement;

        if (activeNav.classList.contains('nip-primary-nav-item')) {
          if (isMobile()) {
            if (e.key === 'ArrowRight') {
              navigatePrimaryTab('next');
            } else if (e.key === 'ArrowLeft') {
              navigatePrimaryTab('prev');
            }
          } else {
            const allNavs = Array.from(primaryNavItems);
            const currentIndex = allNavs.indexOf(activeNav);

            if (e.key === 'ArrowRight' && currentIndex < allNavs.length - 1) {
              allNavs[currentIndex + 1].focus();
              allNavs[currentIndex + 1].click();
            } else if (e.key === 'ArrowLeft' && currentIndex > 0) {
              allNavs[currentIndex - 1].focus();
              allNavs[currentIndex - 1].click();
            }
          }
        }
      }
    });

    // ========== TOUCH SWIPE SUPPORT ==========
    let touchStartX = 0;
    let touchEndX = 0;

    const primaryNav = nestedInfoPage.querySelector('.nip-primary-nav');
    if (primaryNav) {
      primaryNav.addEventListener(
        'touchstart',
        function (e) {
          touchStartX = e.changedTouches[0].screenX;
        },
        { passive: true }
      );

      primaryNav.addEventListener(
        'touchend',
        function (e) {
          touchEndX = e.changedTouches[0].screenX;
          handleSwipe();
        },
        { passive: true }
      );
    }

    function handleSwipe() {
      if (!isMobile()) return;

      const swipeThreshold = 50;
      const diff = touchStartX - touchEndX;

      if (Math.abs(diff) > swipeThreshold) {
        if (diff > 0) {
          navigatePrimaryTab('next');
        } else {
          navigatePrimaryTab('prev');
        }
      }
    }

    // ========== STICKY NAVIGATION OBSERVER ==========
    const observer = new IntersectionObserver(
      ([e]) => {
        const target = e.target;
        target.classList.toggle('nip-is-pinned', e.intersectionRatio < 1);
      },
      { threshold: [1], rootMargin: '-1px 0px 0px 0px' }
    );

    const stickyElements = nestedInfoPage.querySelectorAll('.nip-sticky-nav');
    stickyElements.forEach((el) => observer.observe(el));
  });
</script>

{% comment %} ==================== STYLES ==================== {% endcomment %}

<style>
  /* ========== CSS VARIABLES ========== */
  .nip-nested-info-page {
    --nip-color-primary: #2c2c2c;
    --nip-color-secondary: #c9a05f;
    --nip-color-text: #1a1a1a;
    --nip-color-text-light: white;
    --nip-color-text-lighter: #999;
    --nip-color-bg: #f2f2f2;
    --nip-color-white: #fff;
    --nip-color-border: #e0e0e0;
    --nip-color-border-light: #f2f2f2;

    --nip-header-height: 60px;
    --nip-primary-nav-height: 60px;
    --nip-secondary-nav-height: 56px;

    --nip-font-heading: 'Futura Std';
    --nip-font-body:'Futura Std';
  }

  /* ========== RESET & BASE ========== */
  .nip-nested-info-page * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .nip-nested-info-page {
    font-family: var(--nip-font-body);
    color: var(--nip-color-text);
    background: var(--nip-color-bg);
  }

  .nip-container {
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ========== HEADER ========== */
  .nip-nested-info-header {
    background: var(--nip-color-primary);
    color: var(--nip-color-white);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    height: var(--nip-header-height);
    display: flex;
    align-items: center;
  }

  .nip-header-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .nip-site-logo {
    font-size: 1.5rem;
    font-weight: 300;
    letter-spacing: 2px;
    margin: 0;
    font-family: var(--nip-font-heading);
  }

  .nip-site-logo a {
    color: var(--nip-color-white);
    text-decoration: none;
  }

  .nip-header-search {
    flex: 1;
    max-width: 400px;
  }

  .nip-search-input {
    width: 100%;
    padding: 0.6rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: var(--nip-color-white);
    border-radius: 4px;
    font-size: 0.9rem;
  }

  .nip-search-input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .nip-header-nav {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nip-header-nav a {
    color: var(--nip-color-white);
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    transition: opacity 0.3s;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nip-header-nav a:hover {
    opacity: 0.7;
  }

  .nip-header-nav svg {
    stroke: currentColor;
  }

  /* ========== TAB CONTENT WRAPPER VISIBILITY ========== */
  .nip-tab-content-wrapper {
    display: none;
  }

  .nip-tab-content-wrapper.nip-active {
    display: block;
  }

  /* ========== BANNER SECTION ========== */
  .nip-banner-section {
    height: 500px;
    background-size: cover;
    background-position: center;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
  }

  .nip-banner-content {
    text-align: center;
    color: var(--nip-color-white);
    padding: 2rem;
  }

  .nip-banner-title {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: 2px;
    margin-bottom: 1rem;
    font-family: var(--nip-font-heading);
    text-transform: uppercase;
    color: white;
  }

  .nip-banner-subtitle {
    font-size: 18px;
    font-weight: 400;
    letter-spacing: 1px;
    line-height: 1.6;
  }

  /* ========== STICKY NAVIGATION SHARED STYLES ========== */
  .nip-sticky-nav {
    background: var(--nip-color-white);
    {% comment %} border-bottom: 1px solid var(--nip-color-border); {% endcomment %}
    position: sticky;
    z-index: 900;
    transition: box-shadow 0.3s ease;
  }

  .nip-sticky-nav.nip-is-pinned {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  /* ========== PRIMARY NAVIGATION (Below Banner) ========== */
  .nip-primary-nav {
    background: black;
    position: relative;
    z-index: 10;
    height: 75px;
  }

  .nip-primary-nav-wrapper {
    display: flex;
    gap: 2.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    align-items: center;
    height: var(--nip-primary-nav-height);
    padding: 0.5rem 0;
    top: 25px;
    position: relative;
  }

  .nip-primary-nav-wrapper::-webkit-scrollbar {
    display: none;
  }

  .nip-primary-nav-item {
    background: none;
    border: none;
    padding: 0.75rem 1.5rem;
    font-size: 14px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--nip-color-text-light);
    cursor: pointer;
    position: relative;
    white-space: nowrap;
    transition: all 0.3s ease;
    font-family: var(--nip-font-heading);
    font-weight: 500;
    border-right:1px solid;
  }

  .nip-primary-nav-item:hover {
    color: var(--nip-color-text);
    background: rgba(255, 255, 255, 0.5);
    border-radius: 8px 8px 0 0;
    height: 60px;
  }

  .nip-primary-nav-item.nip-active {
    color: var(--nip-color-text);
    font-weight: 500;
    background: var(--nip-color-white);
    box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.1);
    height: 60px;
    border-radius:8px 8px 0 0 ;
  }

  .nip-browse-btn {
    background: none;
    border: 1px solid var(--nip-color-primary);
    padding: 0.5rem 1.5rem;
    font-size: 0.8rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    margin-left: auto;
    transition: all 0.3s ease;
    text-decoration: none;
    color: var(--nip-color-primary);
    display: inline-block;
    border-radius: 4px;
    font-family: var(--nip-font-heading);
  }

  .nip-browse-btn:hover {
    background: var(--nip-color-primary);
    color: var(--nip-color-white);
  }

  /* ========== SECONDARY NAVIGATION ========== */
  .nip-secondary-nav {
    top: 55px;
    height: var(--nip-secondary-nav-height);
    z-index: 998;
    background: white;
  }

  .nip-secondary-nav-wrapper {
    display: flex;
    gap: 100px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    align-items: center;
    height: 100%;
    top: 25px;
    position: relative;
    justify-content: center;
  }

  .nip-secondary-nav-wrapper::-webkit-scrollbar {
    display: none;
  }

  .nip-secondary-nav-item {
    background: none;
    border: none;
    padding: 0;
    font-size: 14px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--nip-color-text-lighter);
    cursor: pointer;
    position: relative;
    white-space: nowrap;
    transition: color 0.3s ease;
    font-family: var(--nip-font-heading);
    font-weight: 400;
    border-bottom: 2px solid transparent;
  }

  .nip-secondary-nav-item:hover {
    color:#1a1a1a;
  }

  .nip-secondary-nav-item.nip-active {
    color: #1a1a1a;
    border-bottom-color: var(--nip-color-text);
    font-weight: 500;
    padding-bottom:5px;
  }

  /* ========== CONTENT SECTION ========== */
  .nip-content-section {
    display: none;
    padding: 4rem 0;
    background: var(--nip-color-white);
    animation: nipFadeIn 0.5s ease-in;
  }

  .nip-content-section.nip-active {
    display: block;
  }

  @keyframes nipFadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .nip-content-grid {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ========== PRODUCT IMAGE + CTA ========== */
  .nip-product-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: calc(var(--nip-header-height) + var(--nip-secondary-nav-height) + 2rem);
  }

  .nip-product-image {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 4px;
  }

  .nip-cta-button {
    background: #A68380;
    color: var(--nip-color-white);
    border: none;
    padding: 1rem 2rem;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    text-align: center;
    display: inline-block;
    font-family: var(--nip-font-heading);
    border-radius: 8px;
    width:50%;
    left:25%;
    position:relative;
  }

  .nip-cta-button:hover {
    background: #b38f4f;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(201, 160, 95, 0.3);
  }

  /* ========== CONTENT INFO ========== */
  .nip-content-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .nip-content-title {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: 2px;
    color: var(--nip-color-text);
    font-family: var(--nip-font-heading);
    text-transform: uppercase;
  }

  .nip-content-description {
    font-size: 16px;
    line-height: 1.5;
    color: #000000;
    font-family: 'Futura Std';
    font-weight:300;
  }

  .nip-content-description p {
    margin-bottom: 1rem;
  }

  .nip-content-description p:last-child {
    margin-bottom: 0;
  }

  /* ========== RELATED TOPICS ========== */
  .nip-related-topics {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--nip-color-border-light);
  }

  .nip-related-topics-title {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 2px;
    color: #1a1a1a;
    margin-bottom: 1.5rem;
    font-family: 'Futura Std';
  }

  .nip-related-topics-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .nip-related-topic-item {
    background: var(--nip-color-bg);
    padding: 1rem 1.5rem;
    border-radius: 12px;
    transition: all 0.3s ease;
    border: 1px solid transparent;
  }

  .nip-related-topic-item:hover {
    background: var(--nip-color-border-light);
    border-color: var(--nip-color-border);
    transform: translateX(4px);
  }

  .nip-related-topic-link {
    color: #1a1a1a;
    text-decoration: none;
    font-size: 15px;
    letter-spacing: 1px;
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 1024px) {
    .nip-content-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .nip-product-wrapper {
      max-width: 500px;
      margin: 0 auto;
      position: relative;
      top: auto;
    }
  }

  @media (max-width: 768px) {
    .nip-nested-info-page {
      --nip-header-height: auto;
      --nip-primary-nav-height: 60px;
      --nip-secondary-nav-height: 50px;
    }

    .nip-header-wrapper {
      flex-wrap: wrap;
    }

    .nip-header-search {
      order: 3;
      max-width: 100%;
      flex-basis: 100%;
    }

    .nip-nested-info-header {
      position: relative;
      height: auto;
    }

    .nip-banner-title {
      font-size: 16px;
      letter-spacing: 2px;
      margin-bottom: 0.5rem;
    }

    .nip-banner-subtitle {
      font-size: 12px;
      line-height: 1.5;
    }

    /* ========== PRIMARY NAVIGATION (CAROUSEL STYLE) ========== */
    .nip-primary-nav {
      background: black;
      height: var(--nip-primary-nav-height);
    }

    .nip-primary-nav-wrapper {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0;
      overflow: visible;
      padding: 0;
      top: 0;
      height: 100%;
    }

    .nip-primary-nav-item {
      display: none;
      font-size: 14px;
      letter-spacing: 1.5px;
      padding: 0.75rem 1rem;
      border: none;
      color: var(--nip-color-white);
      background: transparent;
      height: auto;
      border-radius: 0;
    }

    .nip-primary-nav-item.nip-active {
      display: block;
      color: var(--nip-color-white);
      background: transparent;
      box-shadow: none;
      font-weight: 500;
      height: auto;
      border-radius: 0;
    }

    .nip-primary-nav-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: transparent;
      border: none;
      color: var(--nip-color-white);
      font-size: 32px;
      font-weight: 300;
      cursor: pointer;
      padding: 0.5rem;
      z-index: 10;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.2s ease;
    }

    .nip-primary-nav-arrow.nip-prev {
      left: 1rem;
    }

    .nip-primary-nav-arrow.nip-next {
      right: 1rem;
    }

    .nip-primary-nav-arrow:active {
      opacity: 0.6;
    }

    .nip-browse-btn {
      display: none;
    }

    /* ========== SECONDARY NAVIGATION (HORIZONTAL SCROLL) ========== */
    .nip-secondary-nav {
      top: 0;
      height: var(--nip-secondary-nav-height);
      background: #f8f8f8;
    }

    .nip-secondary-nav-wrapper {
      display: flex;
      gap: 2rem;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      justify-content: center;
      padding: 0 1rem;
      top: 0;
      height: 100%;
    }

    .nip-secondary-nav-wrapper::-webkit-scrollbar {
      display: none;
    }

    .nip-secondary-nav-item {
      font-size: 12px;
      letter-spacing: 1px;
      padding: 0 0.5rem 0.75rem 0.5rem;
      white-space: nowrap;
      flex-shrink: 0;
      color: var(--nip-color-text-lighter);
      border-bottom: 2px solid transparent;
    }

    .nip-secondary-nav-item.nip-active {
      color: #1a1a1a;
      border-bottom-color: #1a1a1a;
      font-weight: 500;
    }

    /* ========== CONTENT SECTION ========== */
    .nip-content-section {
      padding: 2rem 0;
    }

    .nip-container {
      padding: 0 2rem;
      padding-top: 12px;
    }

    .nip-content-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .nip-product-wrapper {
      position: relative;
      top: auto;
      max-width: 100%;
      gap: 1.5rem;
    }

    .nip-product-image {
      border-radius: 8px;
    }

    .nip-cta-button {
      padding: 0.9rem 2rem;
      font-size: 11px;
      letter-spacing: 1.5px;
      width: 50%;
      left: 25%;
      position: relative;
    }

    .nip-content-info {
      gap: 1.5rem;
    }

    .nip-content-title {
      font-size: 20px;
      letter-spacing: 1.5px;
    }

    .nip-content-description {
      font-size: 14px;
      line-height: 1.6;
      font-weight:300;
    }

    .nip-related-topics {
      margin-top: 1.5rem;
      padding-top: 1.5rem;
    }

    .nip-related-topics-title {
      font-size: 14px;
      letter-spacing: 1.5px;
      margin-bottom: 1rem;
    }

    .nip-related-topic-item {
      padding: 0.8rem 1rem;
    }

    .nip-related-topic-link {
      font-size: 13px;
      letter-spacing: 0.5px;
    }
  }

  @media (max-width: 480px) {
    .nip-banner-title {
      font-size: 14px;
    }

    .nip-banner-subtitle {
      font-size: 11px;
    }

    .nip-primary-nav-arrow {
      font-size: 28px;
    }

    .nip-primary-nav-arrow.nip-prev {
      left: 0.5rem;
    }

    .nip-primary-nav-arrow.nip-next {
      right: 0.5rem;
    }

    .nip-secondary-nav-wrapper {
      gap: 1.5rem;
    }

    .nip-content-section {
      padding: 1.5rem 0;
    }
  }
</style>

{% comment %} ==================== SECTION SCHEMA ==================== {% endcomment %}

{% schema %}
{
  "name": "Nested Information Page",
  "settings": [
    {
      "type": "paragraph",
      "content": "This section automatically loads content from your Primary Tab metaobjects. To manage content, go to: Settings → Custom data → Metaobjects → Primary Tab"
    },
    {
      "type": "header",
      "content": "Design Settings"
    },
    {
      "type": "color",
      "id": "cta_button_color",
      "label": "CTA Button Color",
      "default": "#c9a05f"
    },
    {
      "type": "color",
      "id": "active_tab_color",
      "label": "Secondary Active Tab Color",
      "default": "#2c2c2c"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#2c2c2c"
    }
  ],
  "presets": [
    {
      "name": "Nested Information Page"
    }
  ]
}
{% endschema %} {% endcomment %}


{% comment %} ==================== FETCH DATA FROM METAOBJECTS ==================== {% endcomment %}

{% comment %} Get all active primary tabs, sorted by order {% endcomment %}
{% assign primary_tabs = shop.metaobjects.primary_tab.values | where: 'is_active', true | sort: 'tab_order' %}

{% comment %} Set initial active tabs {% endcomment %}
{% assign initial_primary = primary_tabs.first %}

{% comment %} ==================== SECTION SETTINGS ==================== {% endcomment %}

<div class="nip-nested-info-page" data-section-id="{{ section.id }}">
  {% comment %} ==================== MAIN CONTENT WRAPPER ==================== {% endcomment %}

  {% for primary_tab in primary_tabs %}
    <div
      class="nip-tab-content-wrapper{% if forloop.first %} nip-active{% endif %}"
      data-primary-content="{{ primary_tab.tab_key.value }}"
    >
      {% comment %} ==================== BANNER SECTION ==================== {% endcomment %}

      <div
        class="nip-banner-section"
        {% if primary_tab.banner_image.value %}
          style="background-image: url('{{ primary_tab.banner_image.value | image_url: width: 2000 }}');"
        {% endif %}
      >
        <div class="nip-banner-content">
          <div class="nip-container">
            <h2 class="nip-banner-title">{{ primary_tab.banner_title.value }}</h2>
            {% if primary_tab.banner_subtitle.value != blank %}
              <p class="nip-banner-subtitle">{{ primary_tab.banner_subtitle.value }}</p>
            {% endif %}
          </div>
        </div>
      </div>

      {% comment %} PRIMARY NAVIGATION BELOW BANNER {% endcomment %}
      <nav class="nip-primary-nav">
        <div class="nip-container">
          <div class="nip-primary-nav-wrapper">
            {% for p_tab in primary_tabs %}
              <button
                class="nip-primary-nav-item{% if p_tab.tab_key.value == primary_tab.tab_key.value %} nip-active{% endif %}"
                data-primary-tab="{{ p_tab.tab_key.value }}"
                data-tab-index="{{ forloop.index0 }}"
              >
                {{ p_tab.display_label.value }}
              </button>
            {% endfor %}
          </div>
        </div>
      </nav>

      {% comment %} ==================== SECONDARY NAVIGATION (Sticky below Primary) ==================== {% endcomment %}

      {% assign secondary_tabs = primary_tab.secondary_tabs.value | where: 'is_active', true | sort: 'tab_order' %}

      <nav class="nip-secondary-nav nip-sticky-nav">
        <div class="nip-container">
          <div class="nip-secondary-nav-wrapper">
            {% for secondary_tab in secondary_tabs %}
              <button
                class="nip-secondary-nav-item{% if forloop.first %} nip-active{% endif %}"
                data-secondary-tab="{{ secondary_tab.tab_key.value }}"
                data-parent="{{ primary_tab.tab_key.value }}"
                data-tab-index="{{ forloop.index0 }}"
              >
                {{ secondary_tab.display_label.value }}
              </button>
            {% endfor %}
          </div>
        </div>
      </nav>

      {% comment %} ==================== CONTENT SECTIONS ==================== {% endcomment %}

      {% for secondary_tab in secondary_tabs %}
        <div
          class="nip-secondary-content-wrapper{% if forloop.first %} nip-active{% endif %}"
          data-secondary-content="{{ secondary_tab.tab_key.value }}"
          data-parent="{{ primary_tab.tab_key.value }}"
        >
          {% comment %} Get all active content sections for this secondary tab {% endcomment %}
          {% assign content_sections = secondary_tab.content_sections.value | where: 'is_active', true | sort: 'section_order' %}

          {% for content_section in content_sections %}
            <section class="nip-content-section" data-section-key="{{ content_section.section_key.value }}">
              <div class="nip-container">
                <div class="nip-content-grid">
                  {% comment %} Left: Product Image + CTA {% endcomment %}
                  <div class="nip-product-wrapper">
                    {% if content_section.product_image.value %}
                      <img
                        src="{{ content_section.product_image.value | image_url: width: 800 }}"
                        srcset="
                          {{ content_section.product_image.value | image_url: width: 400 }} 400w,
                          {{ content_section.product_image.value | image_url: width: 800 }} 800w
                        "
                        sizes="(max-width: 768px) 100vw, 400px"
                        alt="{{ content_section.content_title.value }}"
                        class="nip-product-image"
                        loading="lazy"
                      >
                    {% endif %}

                    {% if content_section.cta_text.value and content_section.cta_link.value %}
                      <a
                        href="{{ content_section.cta_link.value }}"
                        class="nip-cta-button"
                      >
                        {{ content_section.cta_text.value }}
                      </a>
                    {% endif %}
                  </div>

                  {% comment %} Right: Content Info {% endcomment %}
                  <div class="nip-content-info">
                    <h2 class="nip-content-title">{{ content_section.content_title.value }}</h2>

                    {% if content_section.content_description.value %}
                      <div class="nip-content-description nip-rte">
                        {{ content_section.content_description.value }}
                      </div>
                    {% endif %}

                    {% comment %} Related Topics {% endcomment %}
                    {% if content_section.related_topics.value.size > 0 %}
                      <div class="nip-related-topics">
                        <h3 class="nip-related-topics-title">RELATED TOPICS</h3>
                        <ul class="nip-related-topics-list">
                          {% assign topics = content_section.related_topics.value | sort: 'topic_order' %}
                          {% for topic in topics %}
                            <li class="nip-related-topic-item">
                              <a
                                href="{{ topic.topic_link.value }}"
                                class="nip-related-topic-link"
                              >
                                {{ topic.topic_text.value }}
                              </a>
                            </li>
                          {% endfor %}
                        </ul>
                      </div>
                    {% endif %}
                  </div>
                </div>
              </div>
            </section>

            {% comment %} Add separator between content sections (except last one) {% endcomment %}
            {% unless forloop.last %}
              <div class="nip-section-separator"></div>
            {% endunless %}
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  {% endfor %}
</div>

{% comment %} ==================== JAVASCRIPT ==================== {% endcomment %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const nestedInfoPage = document.querySelector('.nip-nested-info-page');
    if (!nestedInfoPage) return;

    // ========== MOBILE DETECTION ==========
    function isMobile() {
      return window.innerWidth <= 768;
    }

    // ========== ADD MOBILE NAVIGATION ARROWS ==========
    function addMobileNavigationArrows() {
      const primaryNavWrappers = nestedInfoPage.querySelectorAll('.nip-primary-nav-wrapper');

      primaryNavWrappers.forEach((wrapper) => {
        if (wrapper.querySelector('.nip-primary-nav-arrow')) return;

        const prevArrow = document.createElement('button');
        prevArrow.className = 'nip-primary-nav-arrow nip-prev';
        prevArrow.innerHTML = '‹';
        prevArrow.setAttribute('aria-label', 'Previous tab');

        const nextArrow = document.createElement('button');
        nextArrow.className = 'nip-primary-nav-arrow nip-next';
        nextArrow.innerHTML = '›';
        nextArrow.setAttribute('aria-label', 'Next tab');

        wrapper.appendChild(prevArrow);
        wrapper.appendChild(nextArrow);
      });
    }

    // ========== REMOVE MOBILE NAVIGATION ARROWS ==========
    function removeMobileNavigationArrows() {
      const arrows = nestedInfoPage.querySelectorAll('.nip-primary-nav-arrow');
      arrows.forEach((arrow) => arrow.remove());
    }

    // ========== PRIMARY TAB NAVIGATION (CAROUSEL FOR MOBILE) ==========
    function navigatePrimaryTab(direction) {
      if (!isMobile()) return;

      const allPrimaryNavItems = Array.from(nestedInfoPage.querySelectorAll('.nip-primary-nav-item'));
      const currentActive = allPrimaryNavItems.find((item) => item.classList.contains('nip-active'));
      const currentIndex = allPrimaryNavItems.indexOf(currentActive);

      let newIndex;
      if (direction === 'next') {
        newIndex = (currentIndex + 1) % allPrimaryNavItems.length;
      } else {
        newIndex = (currentIndex - 1 + allPrimaryNavItems.length) % allPrimaryNavItems.length;
      }

      allPrimaryNavItems[newIndex].click();
    }

    // ========== PRIMARY TAB SWITCHING ==========
    const primaryNavItems = nestedInfoPage.querySelectorAll('.nip-primary-nav-item');

    primaryNavItems.forEach((item) => {
      item.addEventListener('click', function () {
        const targetTab = this.dataset.primaryTab;

        const allPrimaryNavItems = nestedInfoPage.querySelectorAll('.nip-primary-nav-item');
        allPrimaryNavItems.forEach((nav) => {
          if (nav.dataset.primaryTab === targetTab) {
            nav.classList.add('nip-active');
          } else {
            nav.classList.remove('nip-active');
          }
        });

        const allPrimaryContent = nestedInfoPage.querySelectorAll('[data-primary-content]');
        allPrimaryContent.forEach((content) => {
          if (content.dataset.primaryContent === targetTab) {
            content.classList.add('nip-active');

            const firstSecondaryNav = content.querySelector('.nip-secondary-nav-item');
            const firstSecondaryContent = content.querySelector('.nip-secondary-content-wrapper');

            if (firstSecondaryNav) {
              content.querySelectorAll('.nip-secondary-nav-item').forEach((nav) => nav.classList.remove('nip-active'));
              firstSecondaryNav.classList.add('nip-active');
            }

            if (firstSecondaryContent) {
              content
                .querySelectorAll('.nip-secondary-content-wrapper')
                .forEach((section) => section.classList.remove('nip-active'));
              firstSecondaryContent.classList.add('nip-active');
            }
          } else {
            content.classList.remove('nip-active');
          }
        });
      });
    });

    // ========== SECONDARY TAB SWITCHING ==========
    const secondaryNavItems = nestedInfoPage.querySelectorAll('.nip-secondary-nav-item');

    secondaryNavItems.forEach((item) => {
      item.addEventListener('click', function () {
        const targetTab = this.dataset.secondaryTab;
        const parentTab = this.dataset.parent;

        const siblingNavs = nestedInfoPage.querySelectorAll(`.nip-secondary-nav-item[data-parent="${parentTab}"]`);
        siblingNavs.forEach((nav) => nav.classList.remove('nip-active'));
        this.classList.add('nip-active');

        const allSecondaryContent = nestedInfoPage.querySelectorAll(`.nip-secondary-content-wrapper[data-parent="${parentTab}"]`);
        allSecondaryContent.forEach((content) => {
          if (content.dataset.secondaryContent === targetTab) {
            content.classList.add('nip-active');
          } else {
            content.classList.remove('nip-active');
          }
        });
      });
    });

    // ========== MOBILE ARROW CLICK HANDLERS ==========
    function setupMobileArrows() {
      const prevArrows = nestedInfoPage.querySelectorAll('.nip-primary-nav-arrow.nip-prev');
      const nextArrows = nestedInfoPage.querySelectorAll('.nip-primary-nav-arrow.nip-next');

      prevArrows.forEach((arrow) => {
        arrow.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          navigatePrimaryTab('prev');
        });
      });

      nextArrows.forEach((arrow) => {
        arrow.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          navigatePrimaryTab('next');
        });
      });
    }

    // ========== HANDLE RESPONSIVE CHANGES ==========
    function handleResponsive() {
      if (isMobile()) {
        addMobileNavigationArrows();
        setupMobileArrows();
      } else {
        removeMobileNavigationArrows();
      }
    }

    handleResponsive();

    let resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(handleResponsive, 250);
    });

    // ========== KEYBOARD NAVIGATION ==========
    document.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
        const activeNav = document.activeElement;

        if (activeNav.classList.contains('nip-primary-nav-item')) {
          if (isMobile()) {
            if (e.key === 'ArrowRight') {
              navigatePrimaryTab('next');
            } else if (e.key === 'ArrowLeft') {
              navigatePrimaryTab('prev');
            }
          } else {
            const allNavs = Array.from(primaryNavItems);
            const currentIndex = allNavs.indexOf(activeNav);

            if (e.key === 'ArrowRight' && currentIndex < allNavs.length - 1) {
              allNavs[currentIndex + 1].focus();
              allNavs[currentIndex + 1].click();
            } else if (e.key === 'ArrowLeft' && currentIndex > 0) {
              allNavs[currentIndex - 1].focus();
              allNavs[currentIndex - 1].click();
            }
          }
        }
      }
    });

    // ========== TOUCH SWIPE SUPPORT ==========
    let touchStartX = 0;
    let touchEndX = 0;

    const primaryNav = nestedInfoPage.querySelector('.nip-primary-nav');
    if (primaryNav) {
      primaryNav.addEventListener(
        'touchstart',
        function (e) {
          touchStartX = e.changedTouches[0].screenX;
        },
        { passive: true }
      );

      primaryNav.addEventListener(
        'touchend',
        function (e) {
          touchEndX = e.changedTouches[0].screenX;
          handleSwipe();
        },
        { passive: true }
      );
    }

    function handleSwipe() {
      if (!isMobile()) return;

      const swipeThreshold = 50;
      const diff = touchStartX - touchEndX;

      if (Math.abs(diff) > swipeThreshold) {
        if (diff > 0) {
          navigatePrimaryTab('next');
        } else {
          navigatePrimaryTab('prev');
        }
      }
    }

    // ========== STICKY NAVIGATION OBSERVER ==========
    const observer = new IntersectionObserver(
      ([e]) => {
        const target = e.target;
        target.classList.toggle('nip-is-pinned', e.intersectionRatio < 1);
      },
      { threshold: [1], rootMargin: '-1px 0px 0px 0px' }
    );

    const stickyElements = nestedInfoPage.querySelectorAll('.nip-sticky-nav');
    stickyElements.forEach((el) => observer.observe(el));
  });
</script>

{% comment %} ==================== STYLES ==================== {% endcomment %}

<style>
  /* ========== CSS VARIABLES ========== */
  .nip-nested-info-page {
    --nip-color-primary: #2c2c2c;
    --nip-color-secondary: #c9a05f;
    --nip-color-text: #1a1a1a;
    --nip-color-text-light: white;
    --nip-color-text-lighter: #999;
    --nip-color-bg: #f2f2f2;
    --nip-color-white: #fff;
    --nip-color-border: #e0e0e0;
    --nip-color-border-light: #f2f2f2;

    --nip-header-height: 60px;
    --nip-primary-nav-height: 60px;
    --nip-secondary-nav-height: 56px;

    --nip-font-heading: 'Futura Std';
    --nip-font-body:'Futura Std';
  }

  /* ========== RESET & BASE ========== */
  .nip-nested-info-page * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .nip-nested-info-page {
    font-family: var(--nip-font-body);
    color: var(--nip-color-text);
    background: var(--nip-color-bg);
  }

  .nip-container {
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ========== TAB CONTENT WRAPPER VISIBILITY ========== */
  .nip-tab-content-wrapper {
    display: none;
  }

  .nip-tab-content-wrapper.nip-active {
    display: block;
  }

  /* ========== BANNER SECTION ========== */
  .nip-banner-section {
    height: 500px;
    background-size: cover;
    background-position: center;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
  }

  .nip-banner-content {
    text-align: center;
    color: var(--nip-color-white);
    padding: 2rem;
  }

  .nip-banner-title {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: 2px;
    margin-bottom: 1rem;
    font-family: var(--nip-font-heading);
    text-transform: uppercase;
    color: white;
  }

  .nip-banner-subtitle {
    font-size: 18px;
    font-weight: 400;
    letter-spacing: 1px;
    line-height: 1.6;
  }

  /* ========== STICKY NAVIGATION SHARED STYLES ========== */
  .nip-sticky-nav {
    background: var(--nip-color-white);
    position: sticky;
    z-index: 900;
    transition: box-shadow 0.3s ease;
  }

  .nip-sticky-nav.nip-is-pinned {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  /* ========== PRIMARY NAVIGATION (Below Banner) ========== */
  .nip-primary-nav {
    background: black;
    position: relative;
    z-index: 10;
    height: 75px;
  }

  .nip-primary-nav-wrapper {
    display: flex;
    gap: 2.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    align-items: center;
    height: var(--nip-primary-nav-height);
    padding: 0.5rem 0;
    top: 25px;
    position: relative;
  }

  .nip-primary-nav-wrapper::-webkit-scrollbar {
    display: none;
  }

  .nip-primary-nav-item {
    background: none;
    border: none;
    padding: 0.75rem 1.5rem;
    font-size: 16px;
    line-height:10px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--nip-color-text-light);
    cursor: pointer;
    position: relative;
    white-space: nowrap;
    transition: all 0.3s ease;
    font-family: var(--nip-font-heading);
    font-weight: 500;
    border-right:1px solid;
  }

  .nip-primary-nav-item:hover {
    color: var(--nip-color-text);
    background: rgba(255, 255, 255, 0.5);
    border-radius: 8px 8px 0 0;
    height: 60px;
  }

  .nip-primary-nav-item.nip-active {
    color: var(--nip-color-text);
    font-weight: 500;
    background: var(--nip-color-white);
    box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.1);
    height: 60px;
    border-radius:8px 8px 0 0 ;
  }

  /* ========== SECONDARY NAVIGATION ========== */
  .nip-secondary-nav {
    top: 55px;
    height: var(--nip-secondary-nav-height);
    z-index: 998;
    background: white;
  }

  .nip-secondary-nav-wrapper {
    display: flex;
    gap: 100px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    align-items: center;
    height: 100%;
    top: 25px;
    position: relative;
    justify-content: center;
  }

  .nip-secondary-nav-wrapper::-webkit-scrollbar {
    display: none;
  }

  .nip-secondary-nav-item {
    background: none;
    border: none;
    padding: 0;
    font-size: 14px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--nip-color-text-lighter);
    cursor: pointer;
    position: relative;
    white-space: nowrap;
    transition: color 0.3s ease;
    font-family: var(--nip-font-heading);
    font-weight: 400;
    border-bottom: 2px solid transparent;
  }

  .nip-secondary-nav-item:hover {
    color:#1a1a1a;
  }

  .nip-secondary-nav-item.nip-active {
    color: #1a1a1a;
    border-bottom-color: var(--nip-color-text);
    font-weight: 500;
    padding-bottom:5px;
  }

  /* ========== SECONDARY CONTENT WRAPPER ========== */
  .nip-secondary-content-wrapper {
    display: none;
  }

  .nip-secondary-content-wrapper.nip-active {
    display: block;
  }

  /* ========== CONTENT SECTION ========== */
  .nip-content-section {
    padding: 4rem 0;
    background: var(--nip-color-white);
    animation: nipFadeIn 0.5s ease-in;
  }

  @keyframes nipFadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .nip-content-grid {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ========== SECTION SEPARATOR ========== */
  .nip-section-separator {
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--nip-color-border) 20%,
      var(--nip-color-border) 80%,
      transparent
    );
    margin: 0 auto;
    max-width: 1200px;
  }

  /* ========== PRODUCT IMAGE + CTA ========== */
  .nip-product-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: calc(var(--nip-header-height) + var(--nip-secondary-nav-height) + 2rem);
  }

  .nip-product-image {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 4px;
  }

  .nip-cta-button {
    background: #A68380;
    color: var(--nip-color-white);
    border: none;
    padding: 1rem 2rem;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    text-align: center;
    display: inline-block;
    font-family: var(--nip-font-heading);
    border-radius: 8px;
    width:50%;
    left:25%;
    position:relative;
  }

  .nip-cta-button:hover {
    background: #b38f4f;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(201, 160, 95, 0.3);
  }

  /* ========== CONTENT INFO ========== */
  .nip-content-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .nip-content-title {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: 2px;
    color: var(--nip-color-text);
    font-family: var(--nip-font-heading);
    text-transform: uppercase;
  }

  .nip-content-description {
    font-size: 16px;
    line-height: 1.5;
    color: #000000;
    font-family: 'Futura Std';
    font-weight:300;
  }

  .nip-content-description p {
    margin-bottom: 1rem;
  }

  .nip-content-description p:last-child {
    margin-bottom: 0;
  }

  /* ========== RELATED TOPICS ========== */
  .nip-related-topics {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--nip-color-border-light);
  }

  .nip-related-topics-title {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 2px;
    color: #1a1a1a;
    margin-bottom: 1.5rem;
    font-family: 'Futura Std';
  }

  .nip-related-topics-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .nip-related-topic-item {
    background: var(--nip-color-bg);
    padding: 1rem 1.5rem;
    border-radius: 12px;
    transition: all 0.3s ease;
    border: 1px solid transparent;
  }

  .nip-related-topic-item:hover {
    background: var(--nip-color-border-light);
    border-color: var(--nip-color-border);
    transform: translateX(4px);
  }

  .nip-related-topic-link {
    color: #1a1a1a;
    text-decoration: none;
    font-size: 15px;
    letter-spacing: 1px;
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 1024px) {
    .nip-content-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .nip-product-wrapper {
      max-width: 500px;
      margin: 0 auto;
      position: relative;
      top: auto;
    }
  }

  @media (max-width: 768px) {
    .nip-nested-info-page {
      --nip-header-height: auto;
      --nip-primary-nav-height: 60px;
      --nip-secondary-nav-height: 50px;
    }

    .nip-banner-title {
      font-size: 16px;
      letter-spacing: 2px;
      margin-bottom: 0.5rem;
    }

    .nip-banner-subtitle {
      font-size: 12px;
      line-height: 1.5;
    }

    /* ========== PRIMARY NAVIGATION (CAROUSEL STYLE) ========== */
    .nip-primary-nav {
      background: black;
      height: var(--nip-primary-nav-height);
    }

    .nip-primary-nav-wrapper {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0;
      overflow: visible;
      padding: 0;
      top: 0;
      height: 100%;
    }

    .nip-primary-nav-item {
      display: none;
      font-size: 14px;
      letter-spacing: 1.5px;
      padding: 0.75rem 1rem;
      border: none;
      color: var(--nip-color-white);
      background: transparent;
      height: auto;
      border-radius: 0;
    }

    .nip-primary-nav-item.nip-active {
      display: block;
      color: var(--nip-color-white);
      background: transparent;
      box-shadow: none;
      font-weight: 500;
      height: auto;
      border-radius: 0;
    }

    .nip-primary-nav-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: transparent;
      border: none;
      color: var(--nip-color-white);
      font-size: 32px;
      font-weight: 300;
      cursor: pointer;
      padding: 0.5rem;
      z-index: 10;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.2s ease;
    }

    .nip-primary-nav-arrow.nip-prev {
      left: 1rem;
    }

    .nip-primary-nav-arrow.nip-next {
      right: 1rem;
    }

    .nip-primary-nav-arrow:active {
      opacity: 0.6;
    }

    /* ========== SECONDARY NAVIGATION (HORIZONTAL SCROLL) ========== */
    .nip-secondary-nav {
      top: 0;
      height: var(--nip-secondary-nav-height);
      background: #f8f8f8;
    }

    .nip-secondary-nav-wrapper {
      display: flex;
      gap: 2rem;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      justify-content: center;
      padding: 0 1rem;
      top: 0;
      height: 100%;
    }

    .nip-secondary-nav-wrapper::-webkit-scrollbar {
      display: none;
    }

    .nip-secondary-nav-item {
      font-size: 12px;
      letter-spacing: 1px;
      padding: 0 0.5rem 0.75rem 0.5rem;
      white-space: nowrap;
      flex-shrink: 0;
      color: var(--nip-color-text-lighter);
      border-bottom: 2px solid transparent;
    }

    .nip-secondary-nav-item.nip-active {
      color: #1a1a1a;
      border-bottom-color: #1a1a1a;
      font-weight: 500;
    }

    /* ========== CONTENT SECTION ========== */
    .nip-content-section {
      padding: 2rem 0;
    }

    .nip-section-separator {
      margin: 2rem auto;
    }

    .nip-container {
      padding: 0 2rem;
      padding-top: 12px;
    }

    .nip-content-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .nip-product-wrapper {
      position: relative;
      top: auto;
      max-width: 100%;
      gap: 1.5rem;
    }

    .nip-product-image {
      border-radius: 8px;
    }

    .nip-cta-button {
      padding: 0.9rem 2rem;
      font-size: 11px;
      letter-spacing: 1.5px;
      width: 50%;
      left: 25%;
      position: relative;
    }

    .nip-content-info {
      gap: 1.5rem;
    }

    .nip-content-title {
      font-size: 20px;
      letter-spacing: 1.5px;
    }

    .nip-content-description {
      font-size: 14px;
      line-height: 1.6;
      font-weight:300;
    }

    .nip-related-topics {
      margin-top: 1.5rem;
      padding-top: 1.5rem;
    }

    .nip-related-topics-title {
      font-size: 14px;
      letter-spacing: 1.5px;
      margin-bottom: 1rem;
    }

    .nip-related-topic-item {
      padding: 0.8rem 1rem;
    }

    .nip-related-topic-link {
      font-size: 13px;
      letter-spacing: 0.5px;
    }
  }

  @media (max-width: 480px) {
    .nip-banner-title {
      font-size: 14px;
    }

    .nip-banner-subtitle {
      font-size: 11px;
    }

    .nip-primary-nav-arrow {
      font-size: 28px;
    }

    .nip-primary-nav-arrow.nip-prev {
      left: 0.5rem;
    }

    .nip-primary-nav-arrow.nip-next {
      right: 0.5rem;
    }

    .nip-secondary-nav-wrapper {
      gap: 1.5rem;
    }

    .nip-content-section {
      padding: 1.5rem 0;
    }
  }
</style>

