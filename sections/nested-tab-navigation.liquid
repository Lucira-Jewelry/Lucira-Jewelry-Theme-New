{% comment %} {% assign primary_tabs = shop.metaobjects.primary_tab.values 
  | where: "is_active", true 
  | sort: "tab_order" %}

{% comment %} Set initial active tabs {% endcomment %}
{% assign initial_primary = primary_tabs.first %}

{% comment %} ==================== SECTION SETTINGS ==================== {% endcomment %}

<div class="nested-info-page" data-section-id="{{ section.id }}">
  


  {% comment %} ==================== MAIN CONTENT WRAPPER ==================== {% endcomment %}
  
  {% for primary_tab in primary_tabs %}
    <div 
      class="tab-content-wrapper{% if forloop.first %} active{% endif %}"
      data-primary-content="{{ primary_tab.tab_key.value }}"
    >
      
      {% comment %} ==================== BANNER SECTION ==================== {% endcomment %}
      
      <div class="banner-section" 
        {% if primary_tab.banner_image.value %}
          style="background-image: url('{{ primary_tab.banner_image.value | image_url: width: 2000 }}');"
        {% endif %}
      >
        <div class="banner-content">
          <div class="container">
            <h2 class="banner-title">{{ primary_tab.banner_title.value }}</h2>
            {% if primary_tab.banner_subtitle.value != blank %}
              <p class="banner-subtitle">{{ primary_tab.banner_subtitle.value }}</p>
            {% endif %}
          </div>
        </div>
      </div>
      
      {% comment %} PRIMARY NAVIGATION BELOW BANNER {% endcomment %}
      <nav class="primary-nav">
        <div class="container">
          <div class="primary-nav-wrapper">
            {% for p_tab in primary_tabs %}
              <button 
                class="primary-nav-item{% if p_tab.tab_key.value == primary_tab.tab_key.value %} active{% endif %}"
                data-primary-tab="{{ p_tab.tab_key.value }}"
                data-tab-index="{{ forloop.index0 }}"
              >
                {{ p_tab.display_label.value }}
              </button>
            {% endfor %}
            {% comment %} <a href="/collections/all" class="browse-btn">Browse</a> {% endcomment %}
          </div>
        </div>
      </nav>

      {% comment %} ==================== SECONDARY NAVIGATION (Sticky below Primary) ==================== {% endcomment %}
      
      {% assign secondary_tabs = primary_tab.secondary_tabs.value 
        | where: "is_active", true 
        | sort: "tab_order" %}
      
      <nav class="secondary-nav sticky-nav">
        <div class="container">
          <div class="secondary-nav-wrapper">
            {% for secondary_tab in secondary_tabs %}
              <button 
                class="secondary-nav-item{% if forloop.first %} active{% endif %}"
                data-secondary-tab="{{ secondary_tab.tab_key.value }}"
                data-parent="{{ primary_tab.tab_key.value }}"
                data-tab-index="{{ forloop.index0 }}"
              >
                {{ secondary_tab.display_label.value }}
              </button>
            {% endfor %}
          </div>
        </div>
      </nav>

      {% comment %} ==================== CONTENT SECTIONS ==================== {% endcomment %}
      
      {% for secondary_tab in secondary_tabs %}
        <section 
          class="content-section{% if forloop.first %} active{% endif %}"
          data-secondary-content="{{ secondary_tab.tab_key.value }}"
          data-parent="{{ primary_tab.tab_key.value }}"
        >
          <div class="container">
            <div class="content-grid">
              
              {% comment %} Left: Product Image + CTA {% endcomment %}
              <div class="product-wrapper">
                {% if secondary_tab.product_image.value %}
                  <img 
                    src="{{ secondary_tab.product_image.value | image_url: width: 800 }}"
                    srcset="{{ secondary_tab.product_image.value | image_url: width: 400 }} 400w,
                            {{ secondary_tab.product_image.value | image_url: width: 800 }} 800w"
                    sizes="(max-width: 768px) 100vw, 400px"
                    alt="{{ secondary_tab.content_title.value }}"
                    class="product-image"
                    loading="lazy"
                  >
                {% endif %}
                
                {% if secondary_tab.cta_text.value and secondary_tab.cta_link.value %}
                  <a 
                    href="{{ secondary_tab.cta_link.value }}" 
                    class="cta-button"
                  >
                    {{ secondary_tab.cta_text.value }}
                  </a>
                {% endif %}
              </div>

              {% comment %} Right: Content Info {% endcomment %}
              <div class="content-info">
                <h2 class="content-title">{{ secondary_tab.content_title.value }}</h2>
                
                {% if secondary_tab.content_description.value %}
                  <div class="content-description rte">
                    {{ secondary_tab.content_description.value }}
                  </div>
                {% endif %}

                {% comment %} Related Topics {% endcomment %}
                {% if secondary_tab.related_topics.value.size > 0 %}
                  <div class="related-topics">
                    <h3 class="related-topics-title">RELATED TOPICS</h3>
                    <ul class="related-topics-list">
                      {% assign topics = secondary_tab.related_topics.value | sort: "topic_order" %}
                      {% for topic in topics %}
                        <li class="related-topic-item">
                          <a 
                            href="{{ topic.topic_link.value }}" 
                            class="related-topic-link"
                          >
                            {{ topic.topic_text.value }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              </div>

            </div>
          </div>
        </section>
      {% endfor %}

    </div>
  {% endfor %}

</div>

{% comment %} ==================== JAVASCRIPT ==================== {% endcomment %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  const nestedInfoPage = document.querySelector('.nested-info-page');
  if (!nestedInfoPage) return;

  // ========== PRIMARY TAB SWITCHING ==========
  const primaryNavItems = nestedInfoPage.querySelectorAll('.primary-nav-item');
  
  primaryNavItems.forEach(item => {
    item.addEventListener('click', function() {
      const targetTab = this.dataset.primaryTab;
      
      // Update active primary nav
      primaryNavItems.forEach(nav => nav.classList.remove('active'));
      this.classList.add('active');
      
      // Show corresponding content wrapper
      const allPrimaryContent = nestedInfoPage.querySelectorAll('[data-primary-content]');
      allPrimaryContent.forEach(content => {
        if (content.dataset.primaryContent === targetTab) {
          content.classList.add('active');
          
          // Activate first secondary tab
          const firstSecondaryNav = content.querySelector('.secondary-nav-item');
          const firstSecondaryContent = content.querySelector('.content-section');
          
          if (firstSecondaryNav) {
            content.querySelectorAll('.secondary-nav-item').forEach(nav => 
              nav.classList.remove('active')
            );
            firstSecondaryNav.classList.add('active');
          }
          
          if (firstSecondaryContent) {
            content.querySelectorAll('.content-section').forEach(section => 
              section.classList.remove('active')
            );
            firstSecondaryContent.classList.add('active');
          }
        } else {
          content.classList.remove('active');
        }
      });
      
      // Scroll to banner
      const banner = nestedInfoPage.querySelector('.tab-content-wrapper.active .banner-section');
      if (banner) {
        const headerHeight = document.querySelector('.nested-info-header')?.offsetHeight || 0;
        const scrollPosition = banner.getBoundingClientRect().top + window.pageYOffset - headerHeight;
        window.scrollTo({ top: scrollPosition, behavior: 'smooth' });
      }
    });
  });

  // ========== SECONDARY TAB SWITCHING ==========
  const secondaryNavItems = nestedInfoPage.querySelectorAll('.secondary-nav-item');
  
  secondaryNavItems.forEach(item => {
    item.addEventListener('click', function() {
      const targetTab = this.dataset.secondaryTab;
      const parentTab = this.dataset.parent;
      
      // Update active secondary nav (only within same parent)
      const siblingNavs = nestedInfoPage.querySelectorAll(
        `.secondary-nav-item[data-parent="${parentTab}"]`
      );
      siblingNavs.forEach(nav => nav.classList.remove('active'));
      this.classList.add('active');
      
      // Show corresponding content
      const allSecondaryContent = nestedInfoPage.querySelectorAll(
        `.content-section[data-parent="${parentTab}"]`
      );
      allSecondaryContent.forEach(content => {
        if (content.dataset.secondaryContent === targetTab) {
          content.classList.add('active');
        } else {
          content.classList.remove('active');
        }
      });
      
      // Smooth scroll to content
      const activeContent = nestedInfoPage.querySelector(
        `.content-section[data-secondary-content="${targetTab}"][data-parent="${parentTab}"]`
      );
      if (activeContent) {
        const headerHeight = document.querySelector('.nested-info-header')?.offsetHeight || 0;
        const secondaryNavHeight = document.querySelector('.secondary-nav')?.offsetHeight || 0;
        const totalStickyHeight = headerHeight + secondaryNavHeight;
        
        const scrollPosition = activeContent.getBoundingClientRect().top + window.pageYOffset - totalStickyHeight;
        window.scrollTo({ top: scrollPosition, behavior: 'smooth' });
      }
    });
  });

  // ========== KEYBOARD NAVIGATION ==========
  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
      const activeNav = document.activeElement;
      
      if (activeNav.classList.contains('primary-nav-item')) {
        const allNavs = Array.from(primaryNavItems);
        const currentIndex = allNavs.indexOf(activeNav);
        
        if (e.key === 'ArrowRight' && currentIndex < allNavs.length - 1) {
          allNavs[currentIndex + 1].focus();
          allNavs[currentIndex + 1].click();
        } else if (e.key === 'ArrowLeft' && currentIndex > 0) {
          allNavs[currentIndex - 1].focus();
          allNavs[currentIndex - 1].click();
        }
      }
    }
  });

  // ========== STICKY NAVIGATION OBSERVER ==========
  const observer = new IntersectionObserver(
    ([e]) => {
      const target = e.target;
      target.classList.toggle('is-pinned', e.intersectionRatio < 1);
    },
    { threshold: [1], rootMargin: '-1px 0px 0px 0px' }
  );

  const stickyElements = nestedInfoPage.querySelectorAll('.sticky-nav');
  stickyElements.forEach(el => observer.observe(el));
});
</script>

{% comment %} ==================== STYLES ==================== {% endcomment %}

<style>
/* ========== CSS VARIABLES ========== */
:root {
  --color-primary: #2c2c2c;
  --color-secondary: #c9a05f;
  --color-text: #2c2c2c;
  --color-text-light: #666;
  --color-text-lighter: #999;
  --color-bg: #fafafa;
  --color-white: #fff;
  --color-border: #e0e0e0;
  --color-border-light: #f0f0f0;
  
  --header-height: 60px;
  --primary-nav-height: 60px;
  --secondary-nav-height: 56px;
  
  --font-heading: 'Helvetica Neue', Arial, sans-serif;
  --font-body: Georgia, serif;
}

/* ========== RESET & BASE ========== */
.nested-info-page * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.nested-info-page {
  font-family: var(--font-body);
  color: var(--color-text);
  background: var(--color-bg);
}

.container {
  margin: 0 auto;
  padding: 0 2rem;
}

/* ========== HEADER ========== */
.nested-info-header {
  background: var(--color-primary);
  color: var(--color-white);
  padding: 1rem 0;
  position: sticky;
  top: 0;
  z-index: 1000;
  height: var(--header-height);
  display: flex;
  align-items: center;
}

.header-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}

.site-logo {
  font-size: 1.5rem;
  font-weight: 300;
  letter-spacing: 2px;
  margin: 0;
  font-family: var(--font-heading);
}

.site-logo a {
  color: var(--color-white);
  text-decoration: none;
}

.header-search {
  flex: 1;
  max-width: 400px;
}

.search-input {
  width: 100%;
  padding: 0.6rem 1rem;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: var(--color-white);
  border-radius: 4px;
  font-size: 0.9rem;
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.header-nav {
  display: flex;
  gap: 1.5rem;
  align-items: center;
}

.header-nav a {
  color: var(--color-white);
  text-decoration: none;
  font-size: 0.85rem;
  letter-spacing: 0.5px;
  transition: opacity 0.3s;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.header-nav a:hover {
  opacity: 0.7;
}

.header-nav svg {
  stroke: currentColor;
}

/* ========== TAB CONTENT WRAPPER VISIBILITY ========== */
.tab-content-wrapper {
  display: none;
}

.tab-content-wrapper.active {
  display: block;
}

/* ========== BANNER SECTION ========== */
.banner-section {
  height: 500px;
  background-size: cover;
  background-position: center;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}

.banner-content {
  text-align: center;
  color: var(--color-white);
  padding: 2rem;
}

.banner-title {
  font-size: 24px;
  font-weight: 500;
  letter-spacing: 2px;
  margin-bottom: 1rem;
  font-family: var(--font-heading);
  text-transform: uppercase;
  color: white;
}

.banner-subtitle {
  font-size: 18px;
  font-weight: 400;
  letter-spacing: 1px;
  line-height: 1.6;
}

/* ========== STICKY NAVIGATION SHARED STYLES ========== */
.sticky-nav {
  background: var(--color-white);
  border-bottom: 1px solid var(--color-border);
  position: sticky;
  z-index: 900;
  transition: box-shadow 0.3s ease;
}

.sticky-nav.is-pinned {
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

/* ========== PRIMARY NAVIGATION (Below Banner) ========== */
.primary-nav {
  background: black;
  position: relative;
  z-index: 10;
  height: 80px;
}

.primary-nav-wrapper {
  display: flex;
  gap: 2.5rem;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  align-items: center;
  height: var(--primary-nav-height);
  padding: 0.5rem 0;
  top: 25px;
  position: relative;
}

.primary-nav-wrapper::-webkit-scrollbar {
  display: none;
}

.primary-nav-item {
  background: none;
  border: none;
  padding: 0.75rem 1.5rem;
  font-size: 12px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--color-text-light);
  cursor: pointer;
  position: relative;
  white-space: nowrap;
  transition: all 0.3s ease;
  font-family: var(--font-heading);
  font-weight: 400;
  border-radius: 8px 8px 0 0;
}

.primary-nav-item:hover {
  color: var(--color-text);
  background: rgba(255, 255, 255, 0.5);
}

.primary-nav-item.active {
  color: var(--color-text);
  font-weight: 500;
  background: var(--color-white);
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.1);
  height: 60px;
}

.browse-btn {
  background: none;
  border: 1px solid var(--color-primary);
  padding: 0.5rem 1.5rem;
  font-size: 0.8rem;
  letter-spacing: 1px;
  text-transform: uppercase;
  cursor: pointer;
  margin-left: auto;
  transition: all 0.3s ease;
  text-decoration: none;
  color: var(--color-primary);
  display: inline-block;
  border-radius: 4px;
  font-family: var(--font-heading);
}

.browse-btn:hover {
  background: var(--color-primary);
  color: var(--color-white);
}

/* ========== SECONDARY NAVIGATION ========== */
.secondary-nav {
  top: 55px;
  height: var(--secondary-nav-height);
  z-index: 998;
  background: #f8f8f8;
}

.secondary-nav-wrapper {
  display: flex;
  gap: 50px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  align-items: center;
  height: 100%;
  top: 25px;
  position: relative;
  justify-content: center;
}

.secondary-nav-wrapper::-webkit-scrollbar {
  display: none;
}

.secondary-nav-item {
  background: none;
  border: none;
  padding: 0;
  font-size: 12px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--color-text-lighter);
  cursor: pointer;
  position: relative;
  white-space: nowrap;
  transition: color 0.3s ease;
  font-family: var(--font-heading);
  font-weight: 400;
  border-bottom: 2px solid transparent;
}

.secondary-nav-item:hover {
  color: var(--color-text-light);
}

.secondary-nav-item.active {
  color: var(--color-text);
  border-bottom-color: var(--color-text);
  font-weight: 500;
}

/* ========== CONTENT SECTION ========== */
.content-section {
  display: none;
  padding: 4rem 0;
  background: var(--color-white);
  animation: fadeIn 0.5s ease-in;
}

.content-section.active {
  display: block;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.content-grid {
  display: grid;
  grid-template-columns: 400px 1fr;
  gap: 4rem;
  align-items: start;
}

/* ========== PRODUCT IMAGE + CTA ========== */
.product-wrapper {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  position: sticky;
  top: calc(var(--header-height) + var(--secondary-nav-height) + 2rem);
}

.product-image {
  width: 100%;
  height: auto;
  object-fit: cover;
  border-radius: 4px;
}

.cta-button {
  background: #A68380;
  color: var(--color-white);
  border: none;
  padding: 1rem 2rem;
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.3s ease;
  text-decoration: none;
  text-align: center;
  display: inline-block;
  font-family: var(--font-heading);
  border-radius: 4px;
}

.cta-button:hover {
  background: #b38f4f;
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(201, 160, 95, 0.3);
}

/* ========== CONTENT INFO ========== */
.content-info {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.content-title {
  font-size: 24px;
  font-weight: 500;
  letter-spacing: 2px;
  color: var(--color-text);
  font-family: var(--font-heading);
  text-transform: uppercase;
}

.content-description {
  font-size: 16px;
  line-height: 1.5;
  color: #000000;
  font-family: 'Futura Std';
}

.content-description p {
  margin-bottom: 1rem;
}

.content-description p:last-child {
  margin-bottom: 0;
}

/* ========== RELATED TOPICS ========== */
.related-topics {
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border-light);
}

.related-topics-title {
  font-size: 20px;
  font-weight: 500;
  letter-spacing: 2px;
  color: #1a1a1a;
  margin-bottom: 1.5rem;
  font-family: 'Futura Std';
}

.related-topics-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.related-topic-item {
  background: var(--color-bg);
  padding: 1rem 1.5rem;
  border-radius: 4px;
  transition: all 0.3s ease;
  border: 1px solid transparent;
}

.related-topic-item:hover {
  background: var(--color-border-light);
  border-color: var(--color-border);
  transform: translateX(4px);
}

.related-topic-link {
  color: #1a1a1a;
  text-decoration: none;
  font-size: 15px;
  letter-spacing: 1px;
}

/* ========== RESPONSIVE ========== */
@media (max-width: 1024px) {
  .content-grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .product-wrapper {
    max-width: 500px;
    margin: 0 auto;
    position: relative;
    top: auto;
  }
}

@media (max-width: 768px) {
  :root {
    --header-height: auto;
    --primary-nav-height: 50px;
    --secondary-nav-height: 48px;
  }

  .header-wrapper {
    flex-wrap: wrap;
  }

  .header-search {
    order: 3;
    max-width: 100%;
    flex-basis: 100%;
  }

  .nested-info-header {
    position: relative;
    height: auto;
  }

  .banner-section {
    height: 400px;
  }

  .banner-title {
    font-size: 1.8rem;
    letter-spacing: 2px;
  }

  .banner-subtitle {
    font-size: 0.9rem;
  }

  .secondary-nav {
    top: 0;
  }

  .primary-nav-wrapper,
  .secondary-nav-wrapper {
    gap: 1.5rem;
  }

  .primary-nav-item {
    font-size: 0.75rem;
    padding: 0.6rem 1.2rem;
  }

  .secondary-nav-item {
    font-size: 0.8rem;
  }

  .content-section {
    padding: 2rem 0;
  }

  .container {
    padding: 0 1rem;
  }

  .content-title {
    font-size: 1.5rem;
  }

  .product-wrapper {
    top: calc(var(--secondary-nav-height) + 1rem);
  }
}

@media (max-width: 480px) {
  .banner-section {
    height: 300px;
  }

  .banner-title {
    font-size: 1.5rem;
  }

  .primary-nav-item.active {
    padding: 0.6rem 1rem;
  }
}
</style>

{% comment %} ==================== SECTION SCHEMA ==================== {% endcomment %}

{% schema %}
{
  "name": "Nested Information Page",
  "settings": [
    {
      "type": "paragraph",
      "content": "This section automatically loads content from your Primary Tab metaobjects. To manage content, go to: Settings → Custom data → Metaobjects → Primary Tab"
    },
    {
      "type": "header",
      "content": "Design Settings"
    },
    {
      "type": "color",
      "id": "cta_button_color",
      "label": "CTA Button Color",
      "default": "#c9a05f"
    },
    {
      "type": "color",
      "id": "active_tab_color",
      "label": "Secondary Active Tab Color",
      "default": "#2c2c2c"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#2c2c2c"
    }
  ],
  "presets": [
    {
      "name": "Nested Information Page"
    }
  ]
}
{% endschema %} {% endcomment %}


{% comment %} ==================== FETCH DATA FROM METAOBJECTS ==================== {% endcomment %}

{% comment %} Get all active primary tabs, sorted by order {% endcomment %}
{% assign primary_tabs = shop.metaobjects.primary_tab.values 
  | where: "is_active", true 
  | sort: "tab_order" %}

{% comment %} Set initial active tabs {% endcomment %}
{% assign initial_primary = primary_tabs.first %}

{% comment %} ==================== SECTION SETTINGS ==================== {% endcomment %}

<div class="nested-info-page" data-section-id="{{ section.id }}">
  


  {% comment %} ==================== MAIN CONTENT WRAPPER ==================== {% endcomment %}
  
  {% for primary_tab in primary_tabs %}
    <div 
      class="tab-content-wrapper{% if forloop.first %} active{% endif %}"
      data-primary-content="{{ primary_tab.tab_key.value }}"
    >
      
      {% comment %} ==================== BANNER SECTION ==================== {% endcomment %}
      
      <div class="banner-section" 
        {% if primary_tab.banner_image.value %}
          style="background-image: url('{{ primary_tab.banner_image.value | image_url: width: 2000 }}');"
        {% endif %}
      >
        <div class="banner-content">
          <div class="container">
            <h2 class="banner-title">{{ primary_tab.banner_title.value }}</h2>
            {% if primary_tab.banner_subtitle.value != blank %}
              <p class="banner-subtitle">{{ primary_tab.banner_subtitle.value }}</p>
            {% endif %}
          </div>
        </div>
      </div>
      
      {% comment %} PRIMARY NAVIGATION BELOW BANNER {% endcomment %}
      <nav class="primary-nav">
        <div class="container">
          <div class="primary-nav-wrapper">
            {% for p_tab in primary_tabs %}
              <button 
                class="primary-nav-item{% if p_tab.tab_key.value == primary_tab.tab_key.value %} active{% endif %}"
                data-primary-tab="{{ p_tab.tab_key.value }}"
                data-tab-index="{{ forloop.index0 }}"
              >
                {{ p_tab.display_label.value }}
              </button>
            {% endfor %}
            {% comment %} <a href="/collections/all" class="browse-btn">Browse</a> {% endcomment %}
          </div>
        </div>
      </nav>

      {% comment %} ==================== SECONDARY NAVIGATION (Sticky below Primary) ==================== {% endcomment %}
      
      {% assign secondary_tabs = primary_tab.secondary_tabs.value 
        | where: "is_active", true 
        | sort: "tab_order" %}
      
      <nav class="secondary-nav sticky-nav">
        <div class="container">
          <div class="secondary-nav-wrapper">
            {% for secondary_tab in secondary_tabs %}
              <button 
                class="secondary-nav-item{% if forloop.first %} active{% endif %}"
                data-secondary-tab="{{ secondary_tab.tab_key.value }}"
                data-parent="{{ primary_tab.tab_key.value }}"
                data-tab-index="{{ forloop.index0 }}"
              >
                {{ secondary_tab.display_label.value }}
              </button>
            {% endfor %}
          </div>
        </div>
      </nav>

      {% comment %} ==================== CONTENT SECTIONS ==================== {% endcomment %}
      
      {% for secondary_tab in secondary_tabs %}
        <section 
          class="content-section{% if forloop.first %} active{% endif %}"
          data-secondary-content="{{ secondary_tab.tab_key.value }}"
          data-parent="{{ primary_tab.tab_key.value }}"
        >
          <div class="container">
            <div class="content-grid">
              
              {% comment %} Left: Product Image + CTA {% endcomment %}
              <div class="product-wrapper">
                {% if secondary_tab.product_image.value %}
                  <img 
                    src="{{ secondary_tab.product_image.value | image_url: width: 800 }}"
                    srcset="{{ secondary_tab.product_image.value | image_url: width: 400 }} 400w,
                            {{ secondary_tab.product_image.value | image_url: width: 800 }} 800w"
                    sizes="(max-width: 768px) 100vw, 400px"
                    alt="{{ secondary_tab.content_title.value }}"
                    class="product-image"
                    loading="lazy"
                  >
                {% endif %}
                
                {% if secondary_tab.cta_text.value and secondary_tab.cta_link.value %}
                  <a 
                    href="{{ secondary_tab.cta_link.value }}" 
                    class="cta-button"
                  >
                    {{ secondary_tab.cta_text.value }}
                  </a>
                {% endif %}
              </div>

              {% comment %} Right: Content Info {% endcomment %}
              <div class="content-info">
                <h2 class="content-title">{{ secondary_tab.content_title.value }}</h2>
                
                {% if secondary_tab.content_description.value %}
                  <div class="content-description rte">
                    {{ secondary_tab.content_description.value }}
                  </div>
                {% endif %}

                {% comment %} Related Topics {% endcomment %}
                {% if secondary_tab.related_topics.value.size > 0 %}
                  <div class="related-topics">
                    <h3 class="related-topics-title">RELATED TOPICS</h3>
                    <ul class="related-topics-list">
                      {% assign topics = secondary_tab.related_topics.value | sort: "topic_order" %}
                      {% for topic in topics %}
                        <li class="related-topic-item">
                          <a 
                            href="{{ topic.topic_link.value }}" 
                            class="related-topic-link"
                          >
                            {{ topic.topic_text.value }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              </div>

            </div>
          </div>
        </section>
      {% endfor %}

    </div>
  {% endfor %}

</div>

{% comment %} ==================== JAVASCRIPT ==================== {% endcomment %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  const nestedInfoPage = document.querySelector('.nested-info-page');
  if (!nestedInfoPage) return;

  // ========== PRIMARY TAB SWITCHING ==========
  const primaryNavItems = nestedInfoPage.querySelectorAll('.primary-nav-item');
  
  primaryNavItems.forEach(item => {
    item.addEventListener('click', function() {
      const targetTab = this.dataset.primaryTab;
      
      // Update active primary nav - need to update ALL primary nav items across all tab wrappers
      const allPrimaryNavItems = nestedInfoPage.querySelectorAll('.primary-nav-item');
      allPrimaryNavItems.forEach(nav => {
        if (nav.dataset.primaryTab === targetTab) {
          nav.classList.add('active');
        } else {
          nav.classList.remove('active');
        }
      });
      
      // Show corresponding content wrapper
      const allPrimaryContent = nestedInfoPage.querySelectorAll('[data-primary-content]');
      allPrimaryContent.forEach(content => {
        if (content.dataset.primaryContent === targetTab) {
          content.classList.add('active');
          
          // Activate first secondary tab
          const firstSecondaryNav = content.querySelector('.secondary-nav-item');
          const firstSecondaryContent = content.querySelector('.content-section');
          
          if (firstSecondaryNav) {
            content.querySelectorAll('.secondary-nav-item').forEach(nav => 
              nav.classList.remove('active')
            );
            firstSecondaryNav.classList.add('active');
          }
          
          if (firstSecondaryContent) {
            content.querySelectorAll('.content-section').forEach(section => 
              section.classList.remove('active')
            );
            firstSecondaryContent.classList.add('active');
          }
        } else {
          content.classList.remove('active');
        }
      });
      
      // Scroll to banner
      const banner = nestedInfoPage.querySelector('.tab-content-wrapper.active .banner-section');
      if (banner) {
        const headerHeight = document.querySelector('.nested-info-header')?.offsetHeight || 0;
        const scrollPosition = banner.getBoundingClientRect().top + window.pageYOffset - headerHeight;
        window.scrollTo({ top: scrollPosition, behavior: 'smooth' });
      }
    });
  });

  // ========== SECONDARY TAB SWITCHING ==========
  const secondaryNavItems = nestedInfoPage.querySelectorAll('.secondary-nav-item');
  
  secondaryNavItems.forEach(item => {
    item.addEventListener('click', function() {
      const targetTab = this.dataset.secondaryTab;
      const parentTab = this.dataset.parent;
      
      // Update active secondary nav (only within same parent)
      const siblingNavs = nestedInfoPage.querySelectorAll(
        `.secondary-nav-item[data-parent="${parentTab}"]`
      );
      siblingNavs.forEach(nav => nav.classList.remove('active'));
      this.classList.add('active');
      
      // Show corresponding content
      const allSecondaryContent = nestedInfoPage.querySelectorAll(
        `.content-section[data-parent="${parentTab}"]`
      );
      allSecondaryContent.forEach(content => {
        if (content.dataset.secondaryContent === targetTab) {
          content.classList.add('active');
        } else {
          content.classList.remove('active');
        }
      });
      
      // Smooth scroll to content
      const activeContent = nestedInfoPage.querySelector(
        `.content-section[data-secondary-content="${targetTab}"][data-parent="${parentTab}"]`
      );
      if (activeContent) {
        const headerHeight = document.querySelector('.nested-info-header')?.offsetHeight || 0;
        const secondaryNavHeight = document.querySelector('.secondary-nav')?.offsetHeight || 0;
        const totalStickyHeight = headerHeight + secondaryNavHeight;
        
        const scrollPosition = activeContent.getBoundingClientRect().top + window.pageYOffset - totalStickyHeight;
        window.scrollTo({ top: scrollPosition, behavior: 'smooth' });
      }
    });
  });

  // ========== KEYBOARD NAVIGATION ==========
  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
      const activeNav = document.activeElement;
      
      if (activeNav.classList.contains('primary-nav-item')) {
        const allNavs = Array.from(primaryNavItems);
        const currentIndex = allNavs.indexOf(activeNav);
        
        if (e.key === 'ArrowRight' && currentIndex < allNavs.length - 1) {
          allNavs[currentIndex + 1].focus();
          allNavs[currentIndex + 1].click();
        } else if (e.key === 'ArrowLeft' && currentIndex > 0) {
          allNavs[currentIndex - 1].focus();
          allNavs[currentIndex - 1].click();
        }
      }
    }
  });

  // ========== STICKY NAVIGATION OBSERVER ==========
  const observer = new IntersectionObserver(
    ([e]) => {
      const target = e.target;
      target.classList.toggle('is-pinned', e.intersectionRatio < 1);
    },
    { threshold: [1], rootMargin: '-1px 0px 0px 0px' }
  );

  const stickyElements = nestedInfoPage.querySelectorAll('.sticky-nav');
  stickyElements.forEach(el => observer.observe(el));
});
</script>

{% comment %} ==================== STYLES ==================== {% endcomment %}

<style>
/* ========== CSS VARIABLES ========== */
:root {
  --color-primary: #2c2c2c;
  --color-secondary: #c9a05f;
  --color-text: #2c2c2c;
  --color-text-light: #666;
  --color-text-lighter: #999;
  --color-bg: #fafafa;
  --color-white: #fff;
  --color-border: #e0e0e0;
  --color-border-light: #f0f0f0;
  
  --header-height: 60px;
  --primary-nav-height: 60px;
  --secondary-nav-height: 56px;
  
  --font-heading: 'Helvetica Neue', Arial, sans-serif;
  --font-body: Georgia, serif;
}

/* ========== RESET & BASE ========== */
.nested-info-page * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.nested-info-page {
  font-family: var(--font-body);
  color: var(--color-text);
  background: var(--color-bg);
}

.container {
  margin: 0 auto;
  padding: 0 2rem;
}

/* ========== HEADER ========== */
.nested-info-header {
  background: var(--color-primary);
  color: var(--color-white);
  padding: 1rem 0;
  position: sticky;
  top: 0;
  z-index: 1000;
  height: var(--header-height);
  display: flex;
  align-items: center;
}

.header-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}

.site-logo {
  font-size: 1.5rem;
  font-weight: 300;
  letter-spacing: 2px;
  margin: 0;
  font-family: var(--font-heading);
}

.site-logo a {
  color: var(--color-white);
  text-decoration: none;
}

.header-search {
  flex: 1;
  max-width: 400px;
}

.search-input {
  width: 100%;
  padding: 0.6rem 1rem;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: var(--color-white);
  border-radius: 4px;
  font-size: 0.9rem;
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.header-nav {
  display: flex;
  gap: 1.5rem;
  align-items: center;
}

.header-nav a {
  color: var(--color-white);
  text-decoration: none;
  font-size: 0.85rem;
  letter-spacing: 0.5px;
  transition: opacity 0.3s;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.header-nav a:hover {
  opacity: 0.7;
}

.header-nav svg {
  stroke: currentColor;
}

/* ========== TAB CONTENT WRAPPER VISIBILITY ========== */
.tab-content-wrapper {
  display: none;
}

.tab-content-wrapper.active {
  display: block;
}

/* ========== BANNER SECTION ========== */
.banner-section {
  height: 500px;
  background-size: cover;
  background-position: center;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}

.banner-content {
  text-align: center;
  color: var(--color-white);
  padding: 2rem;
}

.banner-title {
  font-size: 24px;
  font-weight: 500;
  letter-spacing: 2px;
  margin-bottom: 1rem;
  font-family: var(--font-heading);
  text-transform: uppercase;
  color: white;
}

.banner-subtitle {
  font-size: 18px;
  font-weight: 400;
  letter-spacing: 1px;
  line-height: 1.6;
}

/* ========== STICKY NAVIGATION SHARED STYLES ========== */
.sticky-nav {
  background: var(--color-white);
  border-bottom: 1px solid var(--color-border);
  position: sticky;
  z-index: 900;
  transition: box-shadow 0.3s ease;
}

.sticky-nav.is-pinned {
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

/* ========== PRIMARY NAVIGATION (Below Banner) ========== */
.primary-nav {
  background: black;
  position: relative;
  z-index: 10;
  height: 80px;
}

.primary-nav-wrapper {
  display: flex;
  gap: 2.5rem;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  align-items: center;
  height: var(--primary-nav-height);
  padding: 0.5rem 0;
  top: 25px;
  position: relative;
}

.primary-nav-wrapper::-webkit-scrollbar {
  display: none;
}

.primary-nav-item {
  background: none;
  border: none;
  padding: 0.75rem 1.5rem;
  font-size: 12px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--color-text-light);
  cursor: pointer;
  position: relative;
  white-space: nowrap;
  transition: all 0.3s ease;
  font-family: var(--font-heading);
  font-weight: 400;
  border-radius: 8px 8px 0 0;
}

.primary-nav-item:hover {
  color: var(--color-text);
  background: rgba(255, 255, 255, 0.5);
  border-radius: 8px 8px 0 0;
  height: 60px;
}

.primary-nav-item.active {
  color: var(--color-text);
  font-weight: 500;
  background: var(--color-white);
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.1);
  height: 60px;
}

.browse-btn {
  background: none;
  border: 1px solid var(--color-primary);
  padding: 0.5rem 1.5rem;
  font-size: 0.8rem;
  letter-spacing: 1px;
  text-transform: uppercase;
  cursor: pointer;
  margin-left: auto;
  transition: all 0.3s ease;
  text-decoration: none;
  color: var(--color-primary);
  display: inline-block;
  border-radius: 4px;
  font-family: var(--font-heading);
}

.browse-btn:hover {
  background: var(--color-primary);
  color: var(--color-white);
}

/* ========== SECONDARY NAVIGATION ========== */
.secondary-nav {
  top: 55px;
  height: var(--secondary-nav-height);
  z-index: 998;
  background: #f8f8f8;
}

.secondary-nav-wrapper {
  display: flex;
  gap: 50px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  align-items: center;
  height: 100%;
  top: 25px;
  position: relative;
  justify-content: center;
}

.secondary-nav-wrapper::-webkit-scrollbar {
  display: none;
}

.secondary-nav-item {
  background: none;
  border: none;
  padding: 0;
  font-size: 12px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--color-text-lighter);
  cursor: pointer;
  position: relative;
  white-space: nowrap;
  transition: color 0.3s ease;
  font-family: var(--font-heading);
  font-weight: 400;
  border-bottom: 2px solid transparent;
}

.secondary-nav-item:hover {
  color: var(--color-text-light);
}

.secondary-nav-item.active {
  color: var(--color-text);
  border-bottom-color: var(--color-text);
  font-weight: 500;
}

/* ========== CONTENT SECTION ========== */
.content-section {
  display: none;
  padding: 4rem 0;
  background: var(--color-white);
  animation: fadeIn 0.5s ease-in;
}

.content-section.active {
  display: block;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.content-grid {
  display: grid;
  grid-template-columns: 400px 1fr;
  gap: 4rem;
  align-items: start;
}

/* ========== PRODUCT IMAGE + CTA ========== */
.product-wrapper {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  position: sticky;
  top: calc(var(--header-height) + var(--secondary-nav-height) + 2rem);
}

.product-image {
  width: 100%;
  height: auto;
  object-fit: cover;
  border-radius: 4px;
}

.cta-button {
  background: #A68380;
  color: var(--color-white);
  border: none;
  padding: 1rem 2rem;
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.3s ease;
  text-decoration: none;
  text-align: center;
  display: inline-block;
  font-family: var(--font-heading);
  border-radius: 4px;
}

.cta-button:hover {
  background: #b38f4f;
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(201, 160, 95, 0.3);
}

/* ========== CONTENT INFO ========== */
.content-info {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.content-title {
  font-size: 24px;
  font-weight: 500;
  letter-spacing: 2px;
  color: var(--color-text);
  font-family: var(--font-heading);
  text-transform: uppercase;
}

.content-description {
  font-size: 16px;
  line-height: 1.5;
  color: #000000;
  font-family: 'Futura Std';
}

.content-description p {
  margin-bottom: 1rem;
}

.content-description p:last-child {
  margin-bottom: 0;
}

/* ========== RELATED TOPICS ========== */
.related-topics {
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border-light);
}

.related-topics-title {
  font-size: 20px;
  font-weight: 500;
  letter-spacing: 2px;
  color: #1a1a1a;
  margin-bottom: 1.5rem;
  font-family: 'Futura Std';
}

.related-topics-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.related-topic-item {
  background: var(--color-bg);
  padding: 1rem 1.5rem;
  border-radius: 4px;
  transition: all 0.3s ease;
  border: 1px solid transparent;
}

.related-topic-item:hover {
  background: var(--color-border-light);
  border-color: var(--color-border);
  transform: translateX(4px);
}

.related-topic-link {
  color: #1a1a1a;
  text-decoration: none;
  font-size: 15px;
  letter-spacing: 1px;
}

/* ========== RESPONSIVE ========== */
@media (max-width: 1024px) {
  .content-grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .product-wrapper {
    max-width: 500px;
    margin: 0 auto;
    position: relative;
    top: auto;
  }
}

@media (max-width: 768px) {
  :root {
    --header-height: auto;
    --primary-nav-height: 50px;
    --secondary-nav-height: 48px;
  }

  .header-wrapper {
    flex-wrap: wrap;
  }

  .header-search {
    order: 3;
    max-width: 100%;
    flex-basis: 100%;
  }

  .nested-info-header {
    position: relative;
    height: auto;
  }

  .banner-section {
    height: 400px;
  }

  .banner-title {
    font-size: 1.8rem;
    letter-spacing: 2px;
  }

  .banner-subtitle {
    font-size: 0.9rem;
  }

  .secondary-nav {
    top: 0;
  }

  .primary-nav-wrapper,
  .secondary-nav-wrapper {
    gap: 1.5rem;
  }

  .primary-nav-item {
    font-size: 0.75rem;
    padding: 0.6rem 1.2rem;
  }

  .secondary-nav-item {
    font-size: 0.8rem;
  }

  .content-section {
    padding: 2rem 0;
  }

  .container {
    padding: 0 1rem;
  }

  .content-title {
    font-size: 1.5rem;
  }

  .product-wrapper {
    top: calc(var(--secondary-nav-height) + 1rem);
  }
}

@media (max-width: 480px) {
  .banner-section {
    height: 300px;
  }

  .banner-title {
    font-size: 1.5rem;
  }

  .primary-nav-item.active {
    padding: 0.6rem 1rem;
  }
}
</style>

{% comment %} ==================== SECTION SCHEMA ==================== {% endcomment %}

