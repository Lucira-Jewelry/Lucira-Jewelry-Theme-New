<section class="zoom-reveal">
  <div class="zoom-stage">

    <!-- GRID -->
    <div class="zoom-grid">

      {% assign total = section.blocks.size %}
      {% assign center_index = total | divided_by: 2 %}

      {% for block in section.blocks %}

        {% if forloop.index0 == center_index %}
          
          <!-- CENTER CELL WITH BANNER -->
          <div class="grid-item center-cell">

            <div class="zoom-banner" id="zoomBanner">
              {% if section.settings.banner_image %}
                <img src="{{ section.settings.banner_image | image_url: width: 2000 }}">
              {% endif %}
            </div>

          </div>

        {% endif %}

        <div class="grid-item">
          {% if block.settings.image %}
            <img src="{{ block.settings.image | image_url: width: 800 }}">
          {% endif %}
        </div>

      {% endfor %}

    </div>

  </div>
</section>

<style>

.zoom-reveal{
  height:200vh;
}

.zoom-stage{
  position:sticky;
  top:0;
  height:100vh;
  width:100%;
  overflow:hidden;
}

/* GRID */

.zoom-grid{
  position:absolute;
  inset:0;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  grid-template-rows:repeat(3,1fr);
  gap:16px;
  padding:20px;
}

.grid-item{
  position:relative;
}

.grid-item img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

/* CENTER CELL */

.center-cell{
  position:relative;
  overflow:hidden;
}

/* BANNER */

.zoom-banner{
  position:absolute;
  top:50%;
  left:50%;
  width:120vw;
  height:120vh;
  transform:translate(-50%,-50%);
  z-index:5;
  transition:width 0.08s linear,height 0.08s linear;
}

.zoom-banner img{
  width:100%;
  height:100%;
  object-fit:cover;
}

</style>

<script>

document.addEventListener("scroll", () => {

  const banner = document.getElementById("zoomBanner");
  if(!banner) return;

  const section = banner.closest(".zoom-reveal");
  const rect = section.getBoundingClientRect();

  const scrollProgress = Math.min(
    Math.max(-rect.top / window.innerHeight, 0),
    1
  );

  const startWidth = 120;
  const endWidth = 100;

  const startHeight = 120;
  const endHeight = 100;

  const width = startWidth - (startWidth - endWidth) * scrollProgress;
  const height = startHeight - (startHeight - endHeight) * scrollProgress;

  banner.style.width = width + "%";
  banner.style.height = height + "%";

});

</script>

{% schema %}
{
  "name": "Zoom Reveal Gallery",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Grid Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zoom Reveal Gallery"
    }
  ]
}
{% endschema %}