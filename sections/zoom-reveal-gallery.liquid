<section class="zoom-reveal">

  <div class="zoom-wrapper">

    <!-- GRID -->
    <div class="zoom-grid">
      {% for block in section.blocks %}
        <div class="grid-item grid-item-{{ forloop.index }}">
          {% if block.settings.image %}
            <img src="{{ block.settings.image | image_url: width: 900 }}" loading="lazy">
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <!-- BANNER -->
    <div class="zoom-banner" id="zoomBanner">
      {% if section.settings.banner_image %}
        <img src="{{ section.settings.banner_image | image_url: width: 2000 }}" loading="lazy">
      {% endif %}
    </div>

  </div>

</section>


<style>

.zoom-reveal{
  height:200vh;
  position:relative;
}

.zoom-wrapper{
  position:sticky;
  top:0;
  height:100vh;
  overflow:hidden;
}

/* GRID */

.zoom-grid{
  position:absolute;
  inset:0;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  grid-template-rows:repeat(3,1fr);
  gap:18px;
  padding:20px;
  z-index:1;
}

.grid-item{
  overflow:hidden;
}

.grid-item img{
  width:100%;
  height:100%;
  object-fit:cover;
  opacity:0;
  transform:scale(1.15);
}

/* POSITION IMAGES (SKIP CENTER) */

.grid-item-1{grid-area:1/1;}
.grid-item-2{grid-area:1/2;}
.grid-item-3{grid-area:1/3;}

.grid-item-4{grid-area:2/1;}
.grid-item-5{grid-area:2/3;}

.grid-item-6{grid-area:3/1;}
.grid-item-7{grid-area:3/2;}
.grid-item-8{grid-area:3/3;}


/* BANNER */

.zoom-banner{
  position:absolute;
  top:50%;
  left:50%;
  width:100vw;
  height:100vh;
  transform:translate(-50%,-50%);
  z-index:5;
  will-change:transform;
}

.zoom-banner img{
  width:100%;
  height:100%;
  object-fit:cover;
}

</style>


<!-- GSAP -->
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>

<script>

document.addEventListener("DOMContentLoaded", function(){

  gsap.registerPlugin(ScrollTrigger);

  const banner = document.querySelector("#zoomBanner");
  const centerCell = document.querySelector(".zoom-grid").getBoundingClientRect();
  const grid = document.querySelector(".zoom-grid");
  const gridImages = document.querySelectorAll(".grid-item img");

  function getCenterPosition(){

    const gridRect = grid.getBoundingClientRect();

    const cellWidth = (gridRect.width - 36) / 3;
    const cellHeight = (gridRect.height - 36) / 3;

    const centerX = gridRect.left + cellWidth + 18;
    const centerY = gridRect.top + cellHeight + 18;

    return {
      x: centerX + cellWidth/2 - window.innerWidth/2,
      y: centerY + cellHeight/2 - window.innerHeight/2,
      scaleX: cellWidth / window.innerWidth,
      scaleY: cellHeight / window.innerHeight
    };
  }

  const pos = getCenterPosition();

  const tl = gsap.timeline({
    scrollTrigger:{
      trigger:".zoom-reveal",
      start:"top top",
      end:"+=120%",
      scrub:true,
      pin:true
    }
  });

  /* Banner moves + scales into center cell */

  tl.to(banner,{
    x:pos.x,
    y:pos.y,
    scaleX:pos.scaleX,
    scaleY:pos.scaleY,
    ease:"power2.out"
  });

  /* Grid images appear */

  tl.to(gridImages,{
    opacity:1,
    scale:1,
    stagger:0.07,
    ease:"power2.out"
  },0.35);

});

</script>


{% schema %}
{
  "name": "Zoom Reveal Gallery",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Grid Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Zoom Reveal Gallery"
    }
  ]
}
{% endschema %}