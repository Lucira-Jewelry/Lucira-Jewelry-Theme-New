<section class="zoom-reveal">
  <div class="zoom-stage">
    <!-- Surrounding Grid -->
    <div class="zoom-grid">
      {% for block in section.blocks %}
        <div class="grid-item">
          {% if block.settings.image %}
            <img src="{{ block.settings.image | image_url: width: 800 }}">
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <!-- Center Banner -->
    <div class="zoom-banner" id="zoomBanner">
      {% if section.settings.banner_image %}
        <img src="{{ section.settings.banner_image | image_url: width: 2000 }}">
      {% endif %}
    </div>
  </div>
</section>

<style>
.zoom-reveal{
  height:200vh;
}

.zoom-stage{
  position:sticky;
  top:0;
  height:100vh;
  width:100%;
  overflow:hidden;
}

/* GRID */

.zoom-grid{
  position:absolute;
  inset:0;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  grid-template-rows:repeat(3,1fr);
  gap:16px;
  padding:20px;
}

.grid-item img{
  width:100%;
  height:100%;
  object-fit:cover;
}

/* CENTER BANNER */

.zoom-banner{
  position:absolute;
  top:50%;
  left:50%;
  width:120vw;
  height:120vh;
  transform:translate(-50%,-50%) scale(1.4);
  z-index:3;
  transition:transform 0.1s linear;
}

.zoom-banner img{
  width:100%;
  height:100%;
  object-fit:cover;
}</style>

<script>
document.addEventListener("scroll", () => {

  const banner = document.getElementById("zoomBanner");
  if(!banner) return;

  const scroll = window.scrollY;
  const max = window.innerHeight;

  let progress = scroll / max;

  if(progress > 1) progress = 1;

  const scale = 1.4 - (progress * 0.7);

  banner.style.transform =
    `translate(-50%, -50%) scale(${scale})`;

});
</script>

{% schema %}
{
  "name": "Zoom Reveal Gallery",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DIAMOND EDUCATION"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Learn everything about diamonds"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Grid Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zoom Reveal Gallery"
    }
  ]
}
{% endschema %}
