<section class="zoom-reveal">

  <div class="zoom-wrapper">

    <!-- GRID -->
    <div class="zoom-grid">
      {% for block in section.blocks %}
        <div class="grid-item">
          {% if block.settings.image %}
            <img src="{{ block.settings.image | image_url: width: 900 }}" loading="lazy" alt="">
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <!-- BANNER -->
    <div class="zoom-banner" id="zoomBanner">
      {% if section.settings.banner_image %}
        <img src="{{ section.settings.banner_image | image_url: width: 2000 }}" loading="lazy" alt="">
      {% endif %}
    </div>

  </div>

</section>

<style>

.zoom-reveal{
  height:200vh;
  position:relative;
}

.zoom-wrapper{
  position:sticky;
  top:0;
  height:100vh;
  overflow:hidden;
}

/* GRID */

.zoom-grid{
  position:absolute;
  inset:0;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  grid-template-rows:repeat(3,1fr);
  gap:18px;
  padding:20px;
  z-index:1;
}

.grid-item{
  overflow:hidden;
  aspect-ratio: 16 / 9;
}

.grid-item img{
  width:100%;
  height:100%;
  object-fit:cover;
  opacity:0;
  transform:scale(1.15);
}

/* BANNER */

.zoom-banner{
  position:absolute;
  top:50%;
  left:50%;
  width:100vw;
  height:100vh;
  transform:translate(-50%,-50%) scale(1);
  z-index:5;
  will-change:transform;
}

.zoom-banner img{
  width:100%;
  height:100%;
  object-fit:cover;
}

/* RESPONSIVE */

@media (max-width: 1024px) {
  .zoom-grid {
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: auto;
    gap: 12px;
    padding: 15px;
  }
}

@media (max-width: 640px) {
  .zoom-grid {
    grid-template-columns: 1fr;
    grid-template-rows: auto;
    gap: 10px;
    padding: 10px;
  }
}

</style>

<!-- GSAP -->
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>

<script>

document.addEventListener("DOMContentLoaded", function(){

  gsap.registerPlugin(ScrollTrigger);

  const banner = document.querySelector("#zoomBanner");
  const gridImages = document.querySelectorAll(".grid-item img");

  const tl = gsap.timeline({
    scrollTrigger:{
      trigger:".zoom-reveal",
      start:"top top",
      end:"+=120%",
      scrub:true,
      pin:true
    }
  });

  /* Step 1 — Banner zooms out from center */

  tl.to(banner,{
    scale:0.35,
    ease:"power2.out"
  });

  /* Step 2 — Grid images appear */

  tl.to(gridImages,{
    opacity:1,
    scale:1,
    stagger:0.07,
    ease:"power2.out"
  },0.35);

});

</script>

{% schema %}
{
  "name": "Zoom Reveal Gallery",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Grid Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zoom Reveal Gallery"
    }
  ]
}
{% endschema %}