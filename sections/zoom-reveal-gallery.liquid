<section class="zoom-reveal">

  <div class="zoom-stage">

    <!-- Surrounding Grid -->
    <div class="zoom-grid">
      {% for block in section.blocks %}
        <div class="grid-item">
          {% if block.settings.image %}
            <img src="{{ block.settings.image | image_url: width: 800 }}">
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <!-- Center Banner -->
    <div class="zoom-banner" id="zoomBanner">
      {% if section.settings.banner_image %}
        <img src="{{ section.settings.banner_image | image_url: width: 2000 }}">
      {% endif %}
    </div>

  </div>

</section>

<style>

.zoom-reveal-section{
  position:relative;
  overflow:hidden;
}

.zoom-reveal-wrapper{
  position:relative;
  height:200vh;
}

/* GRID */

.zoom-grid{
  position:sticky;
  top:0;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
  padding:40px;
  height:100vh;
}

.zoom-grid-item img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

/* BANNER */

.zoom-banner{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  transform:scale(1.6);
  transition:transform 0.1s linear;
  z-index:5;
}

.zoom-banner img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.zoom-banner-text{
  position:absolute;
  text-align:center;
  color:white;
}

.zoom-banner-text h2{
  font-size:40px;
  letter-spacing:2px;
}

</style>

<script>

document.addEventListener("scroll", function(){

  const banner = document.querySelector(".zoom-banner");

  if(!banner) return;

  const scroll = window.scrollY;
  const maxScroll = window.innerHeight;

  let scale = 1.6 - (scroll / maxScroll);

  if(scale < 1) scale = 1;

  banner.style.transform = "scale("+scale+")";

});

</script>

{% schema %}
{
  "name": "Zoom Reveal Gallery",
  "settings": [
    {
      "type":"image_picker",
      "id":"banner_image",
      "label":"Banner Image"
    },
    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"DIAMOND EDUCATION"
    },
    {
      "type":"text",
      "id":"subtext",
      "label":"Subtext",
      "default":"Learn everything about diamonds"
    }
  ],
  "blocks":[
    {
      "type":"image",
      "name":"Grid Image",
      "settings":[
        {
          "type":"image_picker",
          "id":"image",
          "label":"Image"
        }
      ]
    }
  ],
  "presets":[
    {
      "name":"Zoom Reveal Gallery"
    }
  ]
}
{% endschema %}