{% schema %}
{
  "name": "Zoom Out Scroll Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    }
  ],
  "presets": [
    {
      "name": "Zoom Out Scroll Banner"
    }
  ]
}
{% endschema %}

<section class="zoom-banner-section">
  <div class="zoom-banner-sticky">
    <div class="zoom-banner-inner">
      {% if section.settings.banner_image %}
        <img
          src="{{ section.settings.banner_image | image_url: width: 2000 }}"
          alt="Banner"
          class="zoom-banner-image"
          loading="lazy"
        >
      {% endif %}
    </div>
  </div>
</section>

<style>

.zoom-banner-section{
  height:200vh;
  position:relative;
}

.zoom-banner-sticky{
  position:sticky;
  top:0;
  height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
}

.zoom-banner-inner{
  width:80vw;
  transform:scale(1.6);
  transition:transform 0.1s linear;
  will-change:transform;
}

.zoom-banner-image{
  width:100%;
  height:auto;
  display:block;
}

</style>

<script>

document.addEventListener("DOMContentLoaded", function(){

  const banner = document.querySelector(".zoom-banner-inner");
  const section = document.querySelector(".zoom-banner-section");

  window.addEventListener("scroll", function(){

    const rect = section.getBoundingClientRect();
    const windowHeight = window.innerHeight;

    const progress = Math.min(
      Math.max((windowHeight - rect.top) / (rect.height + windowHeight), 0),
      1
    );

    const scale = 1.6 - (progress * 0.6);

    banner.style.transform = "scale(" + scale + ")";

  });

});

</script>