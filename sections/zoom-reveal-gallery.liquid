<section class="zoom-reveal">

  <div class="zoom-wrapper">

    <div class="zoom-grid">

      {% for block in section.blocks limit:4 %}
        <div class="grid-item">
          <img src="{{ block.settings.image | image_url: width: 900 }}">
        </div>
      {% endfor %}

      <!-- CENTER CELL -->
      <div class="grid-item center-cell">

        <div class="zoom-banner" id="zoomBanner">
          {% if section.settings.banner_image %}
            <img src="{{ section.settings.banner_image | image_url: width: 2000 }}">
          {% endif %}
        </div>

      </div>

      {% for block in section.blocks offset:4 %}
        <div class="grid-item">
          <img src="{{ block.settings.image | image_url: width: 900 }}">
        </div>
      {% endfor %}

    </div>

  </div>

</section>

<style>

.zoom-reveal{
  height:200vh;
}

.zoom-wrapper{
  position:sticky;
  top:0;
  height:100vh;
}

/* GRID */

.zoom-grid{
  position:absolute;
  inset:0;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  grid-template-rows:repeat(3,1fr);
  gap:16px;
  padding:20px;
}

/* GRID ITEMS */

.grid-item{
  overflow:hidden;
  position:relative;
}

.grid-item img{
  width:100%;
  height:100%;
  object-fit:cover;
  opacity:0;
  transform:scale(1.1);
}

/* CENTER CELL */

.center-cell{
  position:relative;
}

/* BANNER */

.zoom-banner{
  position:absolute;
  top:50%;
  left:50%;
  width:120vw;
  height:120vh;
  transform:translate(-50%,-50%);
  z-index:5;
}

.zoom-banner img{
  width:100%;
  height:100%;
  object-fit:cover;
}

</style>

<script>

document.addEventListener("DOMContentLoaded", function(){

  gsap.registerPlugin(ScrollTrigger);

  const banner = document.querySelector("#zoomBanner");
  const gridImages = document.querySelectorAll(".grid-item img");

  const tl = gsap.timeline({
    scrollTrigger:{
      trigger:".zoom-reveal",
      start:"top top",
      end:"+=120%",
      scrub:true,
      pin:true
    }
  });

  /* Banner shrinks into center cell */

  tl.to(banner,{
    width:"100%",
    height:"100%",
    ease:"power2.out"
  });

  /* Reveal grid images */

  tl.to(gridImages,{
    opacity:1,
    scale:1,
    stagger:0.05
  },0.3);

});

</script>

{% schema %}
{
  "name": "Zoom Reveal Gallery",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Grid Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zoom Reveal Gallery"
    }
  ]
}
{% endschema %}