<section class="zoom-reveal">

  <div class="zoom-wrapper">

    <!-- GRID -->
    <div class="zoom-grid">
      {% for block in section.blocks %}
        <div class="grid-item">
          {% if block.settings.image %}
            <img src="{{ block.settings.image | image_url: width: 900 }}">
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <!-- BANNER -->
    <div class="zoom-banner" id="zoomBanner">

      {% if section.settings.banner_image %}
        <img src="{{ section.settings.banner_image | image_url: width: 2000 }}">
      {% endif %}

      <div class="banner-content">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.subtext }}</p>
      </div>

    </div>

  </div>

</section>

<style>

.zoom-reveal{
  height:200vh;
  position:relative;
}

.zoom-wrapper{
  position:sticky;
  top:0;
  height:100vh;
  overflow:hidden;
}

/* GRID */

.zoom-grid{
  position:absolute;
  inset:0;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  grid-template-rows:repeat(3,1fr);
  gap:18px;
  padding:20px;
}

.grid-item img{
  width:100%;
  height:100%;
  object-fit:cover;
  opacity:0;
  transform:scale(1.15);
}

/* BANNER */

.zoom-banner{
  position:absolute;
  top:50%;
  left:50%;
  width:120vw;
  height:120vh;
  transform:translate(-50%,-50%);
  z-index:5;
}

.zoom-banner img{
  width:100%;
  height:100%;
  object-fit:cover;
}

/* TEXT */

.banner-content{
  position:absolute;
  inset:0;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-direction:column;
  color:white;
  text-align:center;
}

.banner-content h2{
  font-size:42px;
  letter-spacing:2px;
}

</style>

<script>

document.addEventListener("DOMContentLoaded", function(){

  gsap.registerPlugin(ScrollTrigger);

  const banner = document.querySelector("#zoomBanner");
  const gridImages = document.querySelectorAll(".grid-item img");

  const tl = gsap.timeline({
    scrollTrigger:{
      trigger:".zoom-reveal",
      start:"top top",
      end:"+=120%",
      scrub:true,
      pin:true
    }
  });

  /* STEP 1 — Banner shrinks */

  tl.to(banner,{
    width:"35vw",
    height:"35vh",
    ease:"power2.out"
  });

  /* STEP 2 — Grid appears */

  tl.to(gridImages,{
    opacity:1,
    scale:1,
    stagger:0.06,
    ease:"power2.out"
  });

});

</script>

{% schema %}
{
  "name": "Zoom Reveal Gallery",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Diamond Education"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Learn everything about diamonds"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Grid Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zoom Reveal Gallery"
    }
  ]
}
{% endschema %}