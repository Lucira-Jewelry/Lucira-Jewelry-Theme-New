{% schema %}
{
  "name": "Why Choose Section",
  "settings": [
    {
      "type": "text",
      "id": "header",
      "label": "Header",
      "default": "WHY CHOOSE LUCIRA JEWELRY?"
    },
    {
      "type": "text",
      "id": "subheader",
      "label": "Subheader",
      "default": "Lorem ipsum dolor sit amet, consectetur"
    },
    {
      "type": "text",
      "id": "gtm-prefix",
      "label": "GTM Prefix",
      "default": "why-choose-tile"
    }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card Background Image"
        },
        {
          "type": "image_picker",
          "id": "card_image_mobile",
          "label": "Card Background Image (Mobile)"
        },
        {
          "type": "url",
          "id": "card_link",
          "label": "Card Link"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "card_subtitle",
          "label": "Card Subtitle",
          "default": "Feature subtitle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Section"
    }
  ],
  "max_blocks": 4
}
{% endschema %}



<section class="lucira-wc-section">
<div class="page-width">
  <div class="page-width-wc-section">
    <div class="lucira-wc-container">
      <h2 class="lucira-wc-header">{{ section.settings.header }}</h2>
      <p class="lucira-wc-subheader">{{ section.settings.subheader }}</p>
      <div class="lucira-wc-grid swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="lucira-wc-column swiper-slide" {{ block.shopify_attributes }}>
              <a 
                href="{{ block.settings.card_link }}" 
                class="lucira-wc-card why-choose-tile"
                data-info="tile-{{ forloop.index }}"
                data-desktop-img="{{ block.settings.card_image | img_url: '800x' }}"
                aria-label="{{ block.settings.card_title }}: {{ block.settings.card_subtitle }}"
                data-mobile-img="{{ block.settings.card_image_mobile | img_url: '800x' }}"
                style="background-repeat:no-repeat;background-size:cover;background-position:center;display:block"
              >
                <div class="lucira-wc-card-content">
                  <h3 class="lucira-wc-card-title">{{ block.settings.card_title }}</h3>
                  <p class="lucira-wc-card-subtitle">{{ block.settings.card_subtitle }}</p>
                </div>
              </a>
            </div>
          {% endfor %}
        </div>
        <div class="swiper-pagination"></div>
      </div>
    </div>
  </div>
</div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const prefix = '{{ section.settings.gtm-prefix }}';
  
  // Wait a bit for Swiper to initialize
  setTimeout(function() {
    const tiles = document.querySelectorAll('.why-choose-tile');
    
    tiles.forEach((tile) => {
      tile.addEventListener('click', function(e) {
        const tileIndex = this.getAttribute('data-info');
        const title = this.querySelector('.lucira-wc-card-title')?.textContent.trim() || 'Unknown Feature';
        
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'promoClick',
          promoClick: {
            promo_id: `${prefix}-${tileIndex}`,
            creative_name: 'why_choose_feature',
            promo_name: title,
          },
        });
      });
    });
  }, 500);
});
</script>
<script>
document.addEventListener('DOMContentLoaded',function(){let s=null;function r(){document.querySelectorAll('.lucira-wc-card').forEach(function(c){const m=window.innerWidth<=768,d=c.getAttribute('data-desktop-img'),i=c.getAttribute('data-mobile-img');if(m&&i){c.style.backgroundImage=`url('${i}')`}else if(d){c.style.backgroundImage=`url('${d}')`}})}function init(){if(window.innerWidth<=768){if(!s){s=new Swiper('.lucira-wc-section .swiper',{slidesPerView:'auto',spaceBetween:15,loop:true,centeredSlides:false,pagination:{el:'.swiper-pagination',clickable:true},speed:300,touchRatio:1,threshold:5})}}else{if(s){s.destroy(true,true);s=null}}}r();init();let t;window.addEventListener('resize',function(){clearTimeout(t);t=setTimeout(function(){r();init()},250)})});
</script>
