{% schema %}
{
  "name": "Why Choose Section",
  "settings": [
    {
      "type": "text",
      "id": "header",
      "label": "Header",
      "default": "WHY CHOOSE LUCIRA JEWELRY?"
    },
    {
      "type": "text",
      "id": "subheader",
      "label": "Subheader",
      "default": "Lorem ipsum dolor sit amet, consectetur"
    },
    {
      "type": "text",
      "id": "gtm-prefix",
      "label": "GTM Prefix",
      "default": "why-choose-tile"
    }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card Background Image"
        },
        {
          "type": "image_picker",
          "id": "card_image_mobile",
          "label": "Card Background Image (Mobile)"
        },
        {
          "type": "url",
          "id": "card_link",
          "label": "Card Link"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "card_subtitle",
          "label": "Card Subtitle",
          "default": "Feature subtitle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Section"
    }
  ],
  "max_blocks": 4
}
{% endschema %}

<section class="lucira-wc-section">
  <div class="page-width-wc-section">
  <div class="lucira-wc-container">
    <h2 class="lucira-wc-header">{{ section.settings.header }}</h2>
    <p class="lucira-wc-subheader">{{ section.settings.subheader }}</p>

    <div class="lucira-wc-grid owl-carousel">
      {% for block in section.blocks %}
        <div class="lucira-wc-column" {{ block.shopify_attributes }}>
          <a 
            href="{{ block.settings.card_link }}" 
            class="lucira-wc-card {{ section.settings.gtm-prefix }}"
            data-info="tile-{{ forloop.index }}"
            data-desktop-img="{{ block.settings.card_image | img_url: '800x' }}"
            data-mobile-img="{{ block.settings.card_image_mobile | img_url: '800x' }}"
            style="background-repeat: no-repeat; background-size: cover; background-position: center; display: block;"
          >
            <div class="lucira-wc-card-content">
              <h3 class="lucira-wc-card-title">{{ block.settings.card_title }}</h3>
              <p class="lucira-wc-card-subtitle">{{ block.settings.card_subtitle }}</p>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {

  function setResponsiveImages() {
    const cards = document.querySelectorAll('.lucira-wc-card');
    const isMobile = window.innerWidth <= 768;
    cards.forEach(card => {
      const desktopImg = card.getAttribute('data-desktop-img');
      const mobileImg = card.getAttribute('data-mobile-img');
      card.style.backgroundImage = isMobile && mobileImg ? `url('${mobileImg}')` : `url('${desktopImg}')`;
    });
  }

  function initLuciraWCCarousel() {
    const $grid = $('.lucira-wc-grid');
    if (window.innerWidth <= 768) {
      if (!$grid.hasClass('owl-loaded')) {
        $grid.owlCarousel({
          loop: true,
          margin: 15,
          nav: false,
          dots: true,
          items: 1,
          autoplay: false,
          stagePadding: 30,
          touchDrag: true,
          mouseDrag: true,
          pullDrag: true,
        });

        // --- Reliable Click Fix ---
        let startX, startY, isDragging = false;

        $grid.on('mousedown touchstart', '.lucira-wc-card', function(e) {
          const evt = e.type === 'touchstart' ? e.touches[0] : e;
          startX = evt.clientX;
          startY = evt.clientY;
          isDragging = false;
        });

        $grid.on('mousemove touchmove', '.lucira-wc-card', function(e) {
          const evt = e.type === 'touchmove' ? e.touches[0] : e;
          if (Math.abs(evt.clientX - startX) > 5 || Math.abs(evt.clientY - startY) > 5) {
            isDragging = true;
          }
        });

        $grid.on('click', '.lucira-wc-card', function(e) {
          if (isDragging) {
            e.preventDefault(); // Ignore accidental clicks after drag
            return;
          }
          const link = $(this).attr('href');
          if (link && link !== '#') {
            window.location.href = link;
          }
        });
      }
    } else {
      if ($grid.hasClass('owl-loaded')) {
        $grid.trigger('destroy.owl.carousel');
        $grid.removeClass('owl-carousel owl-loaded owl-drag');
        $grid.find('.owl-stage-outer').children().unwrap();
      }
    }
  }

  // --- Init ---
  setResponsiveImages();
  initLuciraWCCarousel();

  let resizeTimer;
  $(window).on('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      setResponsiveImages();
      initLuciraWCCarousel();
    }, 250);
  });

  // --- GTM Tracking ---
  const prefix = '{{ section.settings.gtm-prefix }}';
  const tiles = document.querySelectorAll('.' + prefix);
  tiles.forEach((tile, i) => {
    tile.addEventListener('click', function() {
      const title = tile.querySelector('.lucira-wc-card-title')?.textContent.trim() || 'Unknown Feature';
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'promoClick',
        promoClick: {
          promo_id: `${prefix}-${i + 1}`,
          creative_name: 'why_choose_feature',
          promo_name: title,
        },
      });
    });
  });
});
</script>


