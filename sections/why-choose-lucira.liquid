{% schema %}
{
  "name": "Why Choose Section",
  "settings": [
    {
      "type": "text",
      "id": "header",
      "label": "Header",
      "default": "WHY CHOOSE LUCIRA JEWELRY?"
    },
    {
      "type": "text",
      "id": "subheader",
      "label": "Subheader",
      "default": "Lorem ipsum dolor sit amet, consectetur"
    },
    {
      "type": "text",
      "id": "gtm-prefix",
      "label": "GTM Prefix",
      "default": "why-choose-tile"
    }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card Background Image"
        },
        {
          "type": "image_picker",
          "id": "card_image_mobile",
          "label": "Card Background Image (Mobile)"
        },
        {
          "type": "url",
          "id": "card_link",
          "label": "Card Link"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "card_subtitle",
          "label": "Card Subtitle",
          "default": "Feature subtitle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Section"
    }
  ],
  "max_blocks": 4
}
{% endschema %}

<section class="lucira-wc-section">
  <div class="page-width-wc-section">
  <div class="lucira-wc-container">
    <h2 class="lucira-wc-header">{{ section.settings.header }}</h2>
    <p class="lucira-wc-subheader">{{ section.settings.subheader }}</p>

    <div class="lucira-wc-grid owl-carousel">
      {% for block in section.blocks %}
        <div class="lucira-wc-column" {{ block.shopify_attributes }}>
          <a 
            href="{{ block.settings.card_link }}" 
            class="lucira-wc-card {{ section.settings.gtm-prefix }}"
            data-info="tile-{{ forloop.index }}"
            data-desktop-img="{{ block.settings.card_image | img_url: '800x' }}"
            data-mobile-img="{{ block.settings.card_image_mobile | img_url: '800x' }}"
            style="background-repeat: no-repeat; background-size: cover; background-position: center; display: block;"
          >
            <div class="lucira-wc-card-content">
              <h3 class="lucira-wc-card-title">{{ block.settings.card_title }}</h3>
              <p class="lucira-wc-card-subtitle">{{ block.settings.card_subtitle }}</p>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  function setResponsiveImages() {
    const cards = document.querySelectorAll('.lucira-wc-card');
    const isMobile = window.innerWidth <= 768;
    
    cards.forEach(function(card) {
      const desktopImg = card.getAttribute('data-desktop-img');
      const mobileImg = card.getAttribute('data-mobile-img');
      
      if (isMobile && mobileImg && mobileImg !== '') {
        card.style.backgroundImage = `url('${mobileImg}')`;
      } else if (desktopImg && desktopImg !== '') {
        card.style.backgroundImage = `url('${desktopImg}')`;
      }
    });
  }

  function initLuciraWCCarousel() {
    const $grid = $('.lucira-wc-grid');
    
    if (window.innerWidth <= 768) {
      if (!$grid.hasClass('owl-loaded')) {
        // Destroy any existing instances first
        if ($grid.hasClass('owl-carousel')) {
          $grid.trigger('destroy.owl.carousel');
          $grid.removeClass('owl-carousel owl-loaded owl-drag');
          $grid.find('.owl-stage-outer').children().unwrap();
        }
        
        // Initialize with better touch settings
        $grid.owlCarousel({
          loop: false, // Changed to false to prevent duplication issues
          margin: 15,
          nav: false,
          dots: true,
          items: 1,
          autoplay: false,
          stagePadding: 30,
          center: false,
          touchDrag: true,
          mouseDrag: true,
          pullDrag: true,
          freeDrag: false,
          touchThreshold: 5,
          responsive: {
            0: {
              items: 1,
              stagePadding: 30
            }
          },
          onInitialized: function() {
            console.log('Owl Carousel initialized');
            // Force links to be clickable
            setTimeout(enableMobileClicks, 100);
          }
        });
      }
    } else {
      if ($grid.hasClass('owl-loaded')) {
        $grid.trigger('destroy.owl.carousel');
        $grid.removeClass('owl-carousel owl-loaded owl-drag');
        $grid.find('.owl-stage-outer').children().unwrap();
      }
    }
  }

  // Special function to handle mobile clicks
  function enableMobileClicks() {
    const cards = document.querySelectorAll('.lucira-wc-card');
    
    cards.forEach(function(card) {
      // Remove any existing listeners
      card.removeEventListener('click', handleCardClick);
      card.addEventListener('click', handleCardClick);
    });
  }

  function handleCardClick(e) {
    if (window.innerWidth > 768) return; // Only handle mobile
    
    e.preventDefault();
    e.stopPropagation();
    
    const link = this.getAttribute('href');
    const titleElement = this.querySelector('.lucira-wc-card-title');
    const promoName = titleElement ? titleElement.textContent.trim() : 'Unknown Feature';
    const index = Array.from(document.querySelectorAll('.lucira-wc-card')).indexOf(this) + 1;
    const promoId = `why-choose-${index}`;
    
    // GTM Tracking
    const promoData = {
      event: 'promoClick',
      promoClick: {
        promo_id: promoId,
        creative_name: 'why_choose_feature',
        promo_name: promoName,
      }
    };
    
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push(promoData);
    
    // Navigate to link
    if (link && link !== '#' && link !== '') {
      console.log('Navigating to:', link);
      window.location.href = link;
    }
  }

  // Initialize
  setResponsiveImages();
  initLuciraWCCarousel();
  
  let resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      setResponsiveImages();
      initLuciraWCCarousel();
    }, 250);
  });

  // Desktop click handlers
  if (window.innerWidth > 768) {
    const whyChooseTiles = document.querySelectorAll('.why-choose-tile');
    whyChooseTiles.forEach(function(tile) {
      tile.addEventListener('click', function(e) {
        const titleElement = tile.querySelector('.lucira-wc-card-title');
        const promoName = titleElement ? titleElement.textContent.trim() : 'Unknown Feature';
        const index = Array.from(whyChooseTiles).indexOf(tile) + 1;
        const promoId = `why-choose-${index}`;
        
        const promoData = {
          event: 'promoClick',
          promoClick: {
            promo_id: promoId,
            creative_name: 'why_choose_feature',
            promo_name: promoName,
          }
        };
        
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push(promoData);
      });
    });
  }
});
</script>

