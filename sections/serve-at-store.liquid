<style>
.services-at-store {
  padding-bottom:40px;
  padding-top:40px;
  text-align: center;
  
}
.services-at-store .service-header  h2 {
  font-size: 28px;
  margin-bottom: 12px;
  margin-top:0;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.services-at-store .service-header  p {
  max-width: 700px;
  margin: 0 auto 40px;
  color: #555;
  font-size:18px;
}

/* Desktop Flex Layout */
.services-grid {
  display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: 15px;
    {% comment %} width: 100%; {% endcomment %}
    margin: 20px;
}

.service-card {
  position: relative;
  border-radius: 8px;
  overflow: hidden;
  background: #000;
  width: 23%;
  min-width: 220px;
  color: #fff;
}
.service-card img {
  width: 100%;
  height: 518px;
  object-fit: cover;
  display: block;
  opacity: 0.9;
}
.service-title {
  position: absolute;
  bottom: 10px;
  left: 0;
  width: 100%;
  text-align: center;
  padding: 10px;
}
.service-title h3 {
  font-size: 16px;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin: 0;
  color: white;
}

/* Mobile: Horizontal Scroll */
@media (max-width: 768px) {
  .services-grid {
    flex-wrap: nowrap;
    overflow-x: auto;
    justify-content:unset;
    scroll-snap-type: x mandatory;
    gap: 15px;
    width:100%;
   margin-bottom:0;
    padding-right: 34px!important;
    margin-right: -16px;
    -webkit-overflow-scrolling: touch;
     -ms-overflow-style: none;
    scrollbar-width: none; 
    
  
  }
  .services-at-store {
    width: 100%;
    overflow: hidden;
   

}
  .services-at-store .service-header  p{
  font-size:12px;
  max-width:500px!important;
  margin-bottom:24px;
  padding: 10px;
  padding-top:0;
        padding-bottom: 0;
 
}
  .service-card {
    flex: 0 0 70%;
    scroll-snap-align: start;
  }
  .services-at-store .service-header  h2 {
  font-size:18px;
  margin-top:0;
  
 
}
.services-at-store{
padding-bottom:20px;
padding-top:20px;
}
.service-card img {
 height:374px;

}
.services-at-store {
  padding-right:unset;
}
  /* Hide scrollbar */
  .services-grid::-webkit-scrollbar {
    display: none;
  }

}
</style>

<section class="services-at-store">
  <div>
    <!-- Heading + Subtext -->
    <div class="service-header center">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.subtext != blank %}
        <p>{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    <!-- Services Flex -->
    <div class="services-grid">
      {% for block in section.blocks %}
        <div class="service-card">
          {% if block.settings.image != blank %}
            <div class="service-image">
              <img src="{{ block.settings.image | image_url: width: 600 }}" width="auto" height="auto" loading="lazy" title="{{ block.settings.title | escape }}"alt="{{ block.settings.title | escape }}">
            </div>
          {% endif %}
          <div class="service-title">
            <h3>{{ block.settings.title }}</h3>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>



{% schema %}
{
  "name": "Services at Store",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SERVICES AT STORE"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Service Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Service Title",
          "default": "Service Title"
        }
      ]
    }
  ],
 
  "presets": [
    {
      "name": "Services at Store",
      "category": "Custom",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "title": "Ring Resizer"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Jewelry Consultation"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Ear Piercing"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Bespoke"
          }
        }
      ]
    }
  ]
}
{% endschema %}
