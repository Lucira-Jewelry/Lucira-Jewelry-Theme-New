{% comment %}
  Dawn-compatible Facets (Filter + Sort)
{% endcomment %}

{{ 'component-show-more.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'component-swatch-input.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'component-swatch.css' | asset_url | stylesheet_tag: preload: true }}

{%- liquid
  assign sort_by = results.sort_by | default: results.default_sort_by
  assign results_url = results.url | default: '?sort_by=' | append: sort_by
-%}

<div class="facets-container">

  <!-- ================= DESKTOP FILTERS + SORT ================= -->
  <facet-filters-form class="facets small-hide">
    <form id="FacetFiltersForm" class="facets__form">

      {% if results.terms %}
        <input type="hidden" name="q" value="{{ results.terms | escape }}">
        <input type="hidden" name="options[prefix]" value="last">
      {% endif %}

      {% if enable_filtering %}
        <div id="FacetsWrapperDesktop">

          {% for filter in results.filters %}
            {% case filter.type %}

              {% when 'list', 'boolean' %}
                <details class="facets__disclosure js-filter" open>
                  <summary class="facets__summary">
                    {{ filter.label | escape }}
                    {{ 'icon-caret.svg' | inline_asset_content }}
                  </summary>

                  <fieldset class="facets-wrap">
                    <ul class="facets__list list-unstyled">
                      {% for value in filter.values %}
                        <li class="facets__item">
                          <label class="facets__label">
                            <input
                              type="checkbox"
                              name="{{ value.param_name }}"
                              value="{{ value.value }}"
                              {% if value.active %}checked{% endif %}
                              {% if value.count == 0 and value.active == false %}disabled{% endif %}
                            >
                            {{ value.label }} ({{ value.count }})
                          </label>
                        </li>
                      {% endfor %}
                    </ul>
                  </fieldset>
                </details>

              {% when 'price_range' %}
                <details class="facets__disclosure js-filter">
                  <summary class="facets__summary">
                    {{ filter.label | escape }}
                    {{ 'icon-caret.svg' | inline_asset_content }}
                  </summary>

                  <price-range class="facets__price">
                    {% render 'price-facet', filter: filter %}
                  </price-range>
                </details>

            {% endcase %}
          {% endfor %}
        </div>
      {% endif %}

      {% if enable_sorting %}
        <div class="facet-filters sorting">
          <label for="SortBy">Sort by</label>
          <div class="select">
            <select
              name="sort_by"
              id="SortBy"
              class="select__select"
              aria-describedby="a11y-refresh-page-message"
            >
              {% for option in results.sort_options %}
                <option
                  value="{{ option.value }}"
                  {% if option.value == sort_by %}selected{% endif %}
                >
                  {{ option.name }}
                </option>
              {% endfor %}
            </select>
            {{ 'icon-caret.svg' | inline_asset_content }}
          </div>
        </div>
      {% endif %}

      <div class="product-count" role="status">
        <span id="ProductCountDesktop">
          {{ results.products_count }} products
        </span>
        {% render 'loading-spinner' %}
      </div>

    </form>
  </facet-filters-form>

  <!-- ================= MOBILE FILTERS ================= -->
  <menu-drawer class="mobile-facets__wrapper medium-hide large-up-hide">
    <details class="mobile-facets__disclosure">
      <summary class="mobile-facets__open">
        {{ 'icon-filter.svg' | inline_asset_content }}
        Filter & Sort
      </summary>

      <facet-filters-form>
        <form id="FacetFiltersFormMobile" class="mobile-facets">

          {% for filter in results.filters %}
            <details class="mobile-facets__details">
              <summary class="mobile-facets__summary">
                {{ filter.label }}
              </summary>

              {% if filter.type == 'price_range' %}
                {% render 'price-facet', filter: filter %}
              {% else %}
                {% for value in filter.values %}
                  <label class="mobile-facets__label">
                    <input
                      type="checkbox"
                      name="{{ value.param_name }}"
                      value="{{ value.value }}"
                      {% if value.active %}checked{% endif %}
                    >
                    {{ value.label }}
                  </label>
                {% endfor %}
              {% endif %}
            </details>
          {% endfor %}

          {% if enable_sorting %}
            <label for="SortBy-mobile">Sort by</label>
            <select name="sort_by" id="SortBy-mobile">
              {% for option in results.sort_options %}
                <option
                  value="{{ option.value }}"
                  {% if option.value == sort_by %}selected{% endif %}
                >
                  {{ option.name }}
                </option>
              {% endfor %}
            </select>
          {% endif %}

          <button type="submit" class="button button--primary">
            Apply
          </button>

        </form>
      </facet-filters-form>
    </details>
  </menu-drawer>

</div>
