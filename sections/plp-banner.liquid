{% assign show_banner = true %}
{% if section.settings.exclude_from_collections %}
  {% for collection_item in section.settings.excluded_collections %}
    {% if collection_item.handle == collection.handle %}
      {% assign show_banner = false %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if show_banner %}
  {{ 'plp-banner.css' | asset_url | stylesheet_tag: preload: true }}

  {% assign drawer_content = collection.metafields.custom.plp_banner_content %}
  {% assign drawer_image = collection.metafields.custom.plp_drawer_image %}
  {% assign current_sort = collection.sort_by | default: collection.default_sort_by %}

  <section class="curved-slider-section">
    <div class="curve-bg page-width">
      <div class="plp-collection-banner__content">
        <div class="plp-strap-wrapper">
          {% if section.settings.show_breadcrumbs %}
            <nav
              class="plp-collection-banner__breadcrumbs"
              itemscope
              itemtype="https://schema.org/BreadcrumbList">
              <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                <a href="{{ shop.url }}" itemprop="item" class="plp-collection-banner__breadcrumb-link">
                  <span itemprop="name">Home</span>
                </a>
                <meta itemprop="position" content="1">
              </span>

              <span class="plp-collection-banner__breadcrumb-separator">/</span>

              <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                <a
                  href="https://www.lucirajewelry.com/collections/all"
                  itemprop="item"
                  class="plp-collection-banner__breadcrumb-link"
                >
                  <span itemprop="name">Collections</span>
                </a>
                <meta itemprop="position" content="2">
              </span>

              <span class="plp-collection-banner__breadcrumb-separator">/</span>

              <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                {% if collection.handle == 'all' %}
                  <span itemprop="name" class="plp-collection-banner__breadcrumb-current">All Products</span>
                  <meta itemprop="item" content="{{ shop.url }}/collections/all">
                {% else %}
                  <span itemprop="name" class="plp-collection-banner__breadcrumb-current">
                    {{ collection.title }}
                  </span>
                  <meta itemprop="item" content="{{ shop.url }}{{ collection.url }}">
                {% endif %}
                <meta itemprop="position" content="3">
              </span>
            </nav>
          {% endif %}

          <div class="plp-collection-banner__header">
            <h1 class="plp-collection-banner__title">
              {{ collection.title | default: 'All Products' }}

              {% if drawer_content != blank and drawer_image != blank %}
                <span class="plp-banner__cta_btn">
                  <a
                    href="javascript:void(0)"
                    class="plp-banner__cta-button open-drawer-btn"
                  >
                    <img
                      src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Info.svg?v=1751958261"
                      width="14"
                      height="14"
                      loading="lazy"
                      alt="info"
                      title="info"
                    >
                  </a>
                </span>
              {% endif %}
            </h1>
            {% if section.settings.show_product_count %}
            <p class="plp-collection-banner__count" id="ProductCount">
                <small>
                  <span data-product-count>
                    {{ collection.products_count | default: collection.all_products_count }}
                  </span>
                  designs
                </small>
              </p>
            {% endif %}

          </div>
        </div>
        <div class="plp-collection-banner__right">
          <form
            method="get"
            action="{{ collection.url }}"
            class="plp-sort-form"
          >
            {% if search.terms %}
              <input type="hidden" name="q" value="{{ search.terms | escape }}">
              <input type="hidden" name="options[prefix]" value="last">
            {% endif %}

            {% if collection.current_vendor %}
              <input type="hidden" name="q" value="{{ collection.current_vendor }}">
            {% endif %}

            {% if collection.current_type %}
              <input type="hidden" name="q" value="{{ collection.current_type }}">
            {% endif %}

            <label for="SortBy" class="sort-by-label-plp-banner">Sort by:</label>

            <select
              name="sort_by"
              id="SortBy"
              class="plp-sort-select"
              aria-describedby="a11y-refresh-page-message"
            >
              {% for option in collection.sort_options %}
                <option
                  value="{{ option.value }}"
                  {% if option.value == current_sort %}
                    selected
                  {% endif %}
                >
                  {{ option.name }}
                </option>
              {% endfor %}
            </select>

          </form>
        </div>
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "PLP Collection Banner",
  "tag": "section",
  "class": "plp-collection-banner",
  "settings": [
    { "type": "header", "content": "Banner Settings" },
    { "type": "image_picker", "id": "banner_image", "label": "Banner Background Image" },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner Height (Desktop)",
      "min": 300,
      "max": 800,
      "step": 50,
      "default": 500
    },
    {
      "type": "range",
      "id": "banner_height_mobile",
      "label": "Banner Height (Mobile)",
      "min": 200,
      "max": 500,
      "step": 50,
      "default": 300
    },
    {
      "type": "checkbox",
      "id": "exclude_from_collections",
      "label": "Exclude from specific collections",
      "default": false
    },
    { "type": "collection_list", "id": "excluded_collections", "label": "Collections to exclude" },
    { "type": "header", "content": "Content Settings" },
    { "type": "checkbox", "id": "show_breadcrumbs", "default": true, "label": "Show Breadcrumbs" },
    { "type": "checkbox", "id": "show_product_count", "default": true, "label": "Show Product Count" }
  ],
  "presets": [{ "name": "PLP Collection Banner" }]
}
{% endschema %}

<!-- DRAWER -->
<div id="plp-drawer-wrapper" class="drawer-wrapper hidden">
  <div class="drawer-overlay"></div>
  <div class="collection-drawer">
    <div class="drawer-image-wrapper">
      <img
        src="{{ drawer_image | img_url: 'master' }}"
        loading="lazy"
        class="drawer-image"
      >
      <button class="drawer-close">✕</button>
    </div>
    <div class="drawer-body">
      <p class="drawer-title">{{ collection.title }}</p>
      <div class="drawer-description">
        {{ drawer_content }}
      </div>
    </div>
    <div class="shopping_button">
      <a href="#" class="continue-button">Continue Shopping</a>
    </div>
  </div>
</div>
<script>
  document.addEventListener("DOMContentLoaded", function () {
      const openBtns = document.querySelectorAll(".open-drawer-btn");
      const wrapper = document.getElementById("plp-drawer-wrapper");
      const overlay = wrapper?.querySelector(".drawer-overlay");
      const closeBtn = wrapper?.querySelector(".drawer-close");
      const continueBtn = wrapper?.querySelector(".continue-button");
  
      const openDrawer = () => {
        wrapper.classList.remove("hidden");
        document.body.classList.add("drawer-open");
      };
  
      const closeDrawer = () => {
        wrapper.classList.add("hidden");
        document.body.classList.remove("drawer-open");
      };
  
      openBtns.forEach(btn => {
        btn.addEventListener("click", openDrawer);
      });
  
      closeBtn?.addEventListener("click", closeDrawer);
      overlay?.addEventListener("click", closeDrawer);
      continueBtn?.addEventListener("click", function (e) {
        e.preventDefault();
        closeDrawer();
      });
  });
</script>
<script>
  function initWishlist() {
    try {
      if (
        typeof iWish !== "undefined" &&
        typeof iWish.init === "function"
      ) {
        iWish.init();
      }

      document.dispatchEvent(new CustomEvent("iwish:reload"));
      document.dispatchEvent(new CustomEvent("wishlist:init"));

      if (typeof iWishCounter === "function") {
        iWishCounter();
      }
    } catch (e) {
      console.log("Wishlist init error", e);
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    const sortSelect = document.getElementById('SortBy');
    const productGrid = document.getElementById('ProductGridContainer');

    if (!sortSelect || !productGrid) return;

    sortSelect.addEventListener('change', function () {
      const url = new URL(window.location.href);

      // Update sort value
      url.searchParams.set('sort_by', this.value);

      // Remove pagination on sort
      url.searchParams.delete('page');

      fetch(url.toString(), {
        method: 'GET',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
        },
      })
        .then((response) => response.text())
        .then((html) => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');

          const newGrid = doc.getElementById('ProductGridContainer');
          if (!newGrid) return;

          // Replace product grid only
          productGrid.innerHTML = newGrid.innerHTML;

          // 🔥 Re-init wishlist after DOM update
          initWishlist();

          // Update URL without reload
          window.history.pushState({}, '', url.toString());
        })
        .catch((err) => {
          console.error('Sort failed', err);
        });
    });
  });
</script>
