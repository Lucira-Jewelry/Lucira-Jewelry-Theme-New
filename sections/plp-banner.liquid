{% assign show_banner = true %}

{% if section.settings.exclude_from_collections %}
  {% for collection_item in section.settings.excluded_collections %}
    {% if collection_item.handle == collection.handle %}
      {% assign show_banner = false %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if show_banner %}
  {{ 'plp-banner.css' | asset_url | stylesheet_tag: preload: true }}

  {% assign drawer_content = collection.metafields.custom.plp_banner_content %}
  {% assign drawer_image = collection.metafields.custom.plp_drawer_image %}

  <section class="curved-slider-section">
    <div class="curve-bg page-width">
      <div class="plp-collection-banner__content">
        {% if section.settings.show_breadcrumbs %}
          <nav
            class="plp-collection-banner__breadcrumbs"
            itemscope
            itemtype="https://schema.org/BreadcrumbList"
          >
            <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a href="{{ shop.url }}" itemprop="item" class="plp-collection-banner__breadcrumb-link">
                <span itemprop="name">Home</span>
              </a>
              <meta itemprop="position" content="1">
            </span>

            <span class="plp-collection-banner__breadcrumb-separator">/</span>

            <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a
                href="{{ shop.url }}/collections"
                itemprop="item"
                class="plp-collection-banner__breadcrumb-link"
                style="pointer-events: none;"
              >
                <span itemprop="name">Collections</span>
              </a>
              <meta itemprop="position" content="2">
            </span>

            <span class="plp-collection-banner__breadcrumb-separator">/</span>

            <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              {% if collection.handle == 'all' %}
                <span itemprop="name" class="plp-collection-banner__breadcrumb-current">All Products</span>
                <meta itemprop="item" content="{{ shop.url }}/collections/all">
              {% else %}
                <span itemprop="name" class="plp-collection-banner__breadcrumb-current">{{ collection.title }}</span>
                <meta itemprop="item" content="{{ shop.url }}{{ collection.url }}">
              {% endif %}
              <meta itemprop="position" content="3">
            </span>
          </nav>
        {% endif %}
        <div class="plp-collection-banner__header">
          <h1 class="plp-collection-banner__title">
            {{ collection.title | default: 'All Products' }}
            {% if drawer_content != blank and drawer_image != blank %}
              <span class="plp-banner__cta_btn">
                <a href="javascript:void(0)" class="plp-banner__cta-button open-drawer-btn">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Info.svg?v=1751958261"
                    width="14"
                    height="14"
                    loading="lazy"
                    alt="info"
                    title="info"
                  >
                </a>
              </span>
            {% endif %}
          </h1>

          {% if section.settings.show_product_count %}
            <p class="plp-collection-banner__count">
              <small>{{ collection.all_products_count | default: 0 }} designs</small>
            </p>
          {% endif %}
        </div>
      </div>

      <div class="facet-filters sorting caption">
        <div class="facet-filters__field">
          <h2 class="facet-filters__label caption-large text-body">
            <label for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>
          </h2>
          <div class="select">
            {%- assign sort_by = results.sort_by | default: results.default_sort_by -%}
            <select
              name="sort_by"
              class="facet-filters__sort select__select caption-large"
              id="SortBy"
              aria-describedby="a11y-refresh-page-message"
            >
              {%- for option in results.sort_options -%}
                <option
                  value="{{ option.value | escape }}"
                  {% if option.value == sort_by %}
                    selected="selected"
                  {% endif %}
                >
                  {{ option.name | escape }}
                </option>
              {%- endfor -%}
            </select>
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "PLP Collection Banner",
  "tag": "section",
  "class": "plp-collection-banner",
  "settings": [
    {
      "type": "header",
      "content": "Banner Settings"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Background Image",
      "info": "Recommended size: 1920x600px"
    },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner Height (Desktop)",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "banner_height_mobile",
      "label": "Banner Height (Mobile)",
      "min": 200,
      "max": 500,
      "step": 50,
      "unit": "px",
      "default": 300
    },
    {
      "type": "checkbox",
      "id": "exclude_from_collections",
      "label": "Exclude from specific collections",
      "default": false,
      "info": "When enabled, this banner won't appear on collections selected below"
    },
    {
      "type": "collection_list",
      "id": "excluded_collections",
      "label": "Collections to exclude",
      "info": "Select collections where this banner should not appear"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show Breadcrumbs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show Product Count",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show Collection Description",
      "default": true
    },
    {
      "type": "header",
      "content": "Carousel Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_carousel",
      "label": "Enable Curved Carousel",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "carousel_autoplay",
      "label": "Enable Carousel Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay Speed (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "carousel_item",
      "name": "Carousel Item",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Carousel Image",
          "info": "Recommended size: 400x400px"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Custom Label",
          "info": "Leave empty to use collection title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PLP Collection Banner",
      "blocks": [
        {
          "type": "carousel_item"
        },
        {
          "type": "carousel_item"
        },
        {
          "type": "carousel_item"
        },
        {
          "type": "carousel_item"
        },
        {
          "type": "carousel_item"
        }
      ]
    }
  ]
}
{% endschema %}

<div id="plp-drawer-wrapper" class="drawer-wrapper hidden">
  <!-- Overlay -->
  <div class="drawer-overlay"></div>
  <!-- Drawer -->
  <div class="collection-drawer">
    <div class="drawer-image-wrapper">
      <img
        src="{{ collection.metafields.custom.plp_drawer_image | img_url: 'master' }}"
        width="auto"
        height="auto"
        loading="lazy"
        alt="Banner Image"
        title="Banner Image"
        class="drawer-image"
      >
      <button class="drawer-close">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none">
          <mask id="mask0_1461_3497" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="40"
            height="40">
            <rect width="40" height="40" fill="#D9D9D9" />
          </mask>
          <g mask="url(#mask0_1461_3497)">
            <path
              d="M20 21.7563L11.545 30.2117C11.3142 30.4422 11.024 30.5603 10.6746 30.5659C10.3254 30.5711 10.03 30.4531 9.78835 30.2117C9.54696 29.97 9.42627 29.6772 9.42627 29.3334C9.42627 28.9895 9.54696 28.6967 9.78835 28.455L18.2438 20L9.78835 11.545C9.5578 11.3142 9.43974 11.024 9.43419 10.6746C9.42891 10.3254 9.54696 10.03 9.78835 9.78835C10.03 9.54696 10.3228 9.42627 10.6667 9.42627C11.0106 9.42627 11.3034 9.54696 11.545 9.78835L20 18.2438L28.455 9.78835C28.6859 9.5578 28.976 9.43974 29.3254 9.43419C29.6746 9.42891 29.97 9.54696 30.2117 9.78835C30.4531 10.03 30.5738 10.3228 30.5738 10.6667C30.5738 11.0106 30.4531 11.3034 30.2117 11.545L21.7563 20L30.2117 28.455C30.4422 28.6859 30.5603 28.976 30.5659 29.3254C30.5711 29.6746 30.4531 29.97 30.2117 30.2117C29.97 30.4531 29.6772 30.5738 29.3334 30.5738C28.9895 30.5738 28.6967 30.4531 28.455 30.2117L20 21.7563Z"
              fill="white" />
          </g>
        </svg>
      </button>
    </div>

    <div class="drawer-body">
      <p class="drawer-title">{{ collection.title }}</p>
      <div class="drawer-description">
        {{ collection.metafields.custom.plp_banner_content }}
      </div>
    </div>
    <div class="shopping_button">
      <a href="javascript:void(0);" class="Shopbutton continue-button">Continue Shopping</a>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const openBtns = document.querySelectorAll('.open-drawer-btn');
    const wrapper = document.getElementById('plp-drawer-wrapper');
    const overlay = wrapper?.querySelector('.drawer-overlay');
    const closeBtn = wrapper?.querySelector('.drawer-close');
    const continueBtn = wrapper?.querySelector('.continue-button');

    const openDrawer = () => {
      wrapper.classList.remove('hidden');
      document.body.classList.add('drawer-open');
    };

    const closeDrawer = () => {
      wrapper.classList.add('hidden');
      document.body.classList.remove('drawer-open');
    };

    openBtns.forEach((btn) => {
      btn.addEventListener('click', openDrawer);
    });

    closeBtn?.addEventListener('click', closeDrawer);
    overlay?.addEventListener('click', closeDrawer);
    continueBtn?.addEventListener('click', function (e) {
      e.preventDefault();
      closeDrawer();
    });
  });
</script>
