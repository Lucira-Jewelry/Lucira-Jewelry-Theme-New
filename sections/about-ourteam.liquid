{% schema %}
{
  "name": "Full Width Team Photo",
  "tag": "section",
  "class": "section-team-full-width",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "team_logos_image_mobile",
      "label": "Team Image for Mobile"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Section Height",
      "default": 600
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Sub Heading (Top Text)",
      "default": "OUR TEAM, OUR FAMILY"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Main Heading (Large Text)",
      "default": "The people behind the passion."
    },
    {
      "type": "text",
      "id": "body_text",
      "label": "Body Text (Small Text)",
      "default": "We are a diverse group united by a single goal: to deliver excellence."
    }
  ],
  "presets": [
    {
      "name": "Full Width Team Hero"
    }
  ]
}
{% endschema %}

<div class="team-hero-section">
  
  {% if section.settings.bg_image != blank or section.settings.team_logos_image_mobile != blank %}
    
    {% comment %} Set the desktop and mobile image URLs {% endcomment %}
    {%- assign desktop_img_url = section.settings.bg_image | img_url: '2000x' -%}
    {%- assign mobile_img_url = section.settings.team_logos_image_mobile | img_url: '800x' -%}
    
    <div 
      class="team-hero-content"
      style="background-image: url('{{ desktop_img_url }}'); min-height: {{ section.settings.min_height }}px; "
    >
      
      <div class="team-text-overlay">
        {% if section.settings.main_heading != blank %}
          <p class="team-subheading">{{ section.settings.main_heading | escape }}</p>
        {% endif %}

        {% if section.settings.sub_heading != blank %}
          <h1 class="team-main-heading">{{ section.settings.sub_heading | escape }}</h1>
        {% endif %}

        {% if section.settings.body_text != blank %}
          <p class="team-body-text">{{ section.settings.body_text | escape }}</p>
        {% endif %}
      </div>
      
      {% comment %} Mobile-only image overlay {% endcomment %}
      {% if section.settings.team_logos_image_mobile != blank %}
        <div class="team-mobile-image" style="
  
">
          <img src="{{ mobile_img_url }}" alt="Team Mobile Image" title="Team moblile app">
        </div>
      {% endif %}
      
    </div>
    
  {% else %}
    <div class="team-hero-placeholder" style="min-height: {{ section.settings.min_height }}px;">
      <h1>Team Hero Image Placeholder</h1>
      <p>Please select an image in the theme editor.</p>
    </div>
  {% endif %}

</div>

<style>

  .team-mobile-image{
  display:none;}
.team-hero-content {
  /* Image display properties */
  background-size: contain;
  background-position: center center;
  background-repeat: no-repeat;
  width: 100%;
  height: auto;
  position: relative;
  /* Flexbox for centering text */
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border-radius: 10px;
  max-width:1200px;
  margin: 0 auto;
}

.team-text-overlay {
  /* Creates a dark overlay for contrast */
  background: rgba(246, 238, 238, 0); /* 30% black opacity */
  position: absolute;
  top: 0;
  right: 0;
  bottom: 10px;
  left: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end; /* Pushes content to the bottom */
  align-items: center;
  padding: 20px 20px;
  color: #fff;
}

.team-main-heading {
  font-size: 3em;
  font-weight: 700;
  margin-top: 5px;
  margin-bottom: 5px;
  text-transform: uppercase;
  letter-spacing: 2px;
}

.team-subheading {
  font-size: 24px;
  font-weight: 400;
  margin: 0;
  opacity: 0.8;
}

.team-body-text {
  font-size: 18px;
  max-width: 800px;
  margin-top: 10px;
  line-height: 1.4;
}

/* Placeholder Style */
.team-hero-placeholder {
  text-align: center;
  padding: 150px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

 .team-hero-section {
  padding: -50px;
} 

/* Mobile image styles */
.team-mobile-image {
  display: none;
}

@media (max-width: 768px) {
  .team-hero-content {
    background-image: url('{{ mobile_img_url }}');
     background-image: none !important;
         min-height: 500px !important;
  }

 .team-hero-content {
    background-size: contain;
    background-position: center center;
    background-repeat: no-repeat;
    width: 96%;
    MARGIN: 0 AUTO;
    height: auto;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    border-radius: 10px;
}


.timeline-wrapper{
padding:0;}
  .team-mobile-image {
    display: block;
    width: 100%;
    height: auto;
  }
 .team-hero-section {
    padding: 0;
}
.team-subheading {
  font-size: 18px;
  font-weight: 400;
  margin: 0;
  opacity: 0.8;
         position: absolute;
        bottom: 80px;
}

.team-body-text {
  font-size: 14px;
  max-width: 800px;
  margin-top: -100px;
  line-height: 1.4;
  {% comment %} padding-bottom: 30%;  {% endcomment %}
}
.team-mobile-image img { width:100%; }

}
</style>
