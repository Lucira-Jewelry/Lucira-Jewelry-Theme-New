{% schema %}
{
  "name": "Metal Education",
  "tag": "section",
  "class": "metal-education-wrapper",
  "settings": [],
  "blocks": [],
  "presets": [
    {
      "name": "Metal Education"
    }
  ]
}
{% endschema %}

{% style %}
  <style>
      
    .metal-education-wrapper {
      font-family: 'FuturaStd', sans-serif;
      background-color: #fafafa;
      padding: 60px 0;
      color: #333;
    }

    .metal-education-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .metal-education-wrapper h1.page-title {
      text-align: center;
      font-weight: 600;
      font-size: 32px;
      margin-bottom: 40px;
      line-height: 1.3;
      position: relative;
      padding-bottom: 15px;
      color: #222;
    }

    .metal-education-wrapper h1.page-title:after {
      content: "";
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 80px;
      height: 3px;
      background: linear-gradient(to right, #A68380, #d4b8b6);
    }

    .metal-intro {
      /* text-align: center;
      max-width: 800px; */
      margin: 0 auto 50px;
    }

    .metal-intro p {
      font-size: 18px;
      line-height: 1.6;
      margin-bottom: 20px;
    }

    .metal-section {
      margin-bottom: 60px;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
      background-color: #fff;
      transition: transform 0.3s ease;
    }

    .metal-section:hover {
      transform: translateY(-5px);
    }

    .metal-section-header {
      background: linear-gradient(to right, #A68380, #c9b0ae);
      padding: 20px 30px;
      color: white;
    }

    .metal-section-header h2 {
      font-size: 24px;
      font-weight: 500;
      margin: 0;
      position: relative;
      color: #fff;
    }

    .metal-section-content {
      padding: 30px;
      display: flex;
      flex-wrap: wrap;
      gap: 30px;
    }

    .metal-image {
      flex: 1;
      min-width: 280px;
      max-width: 350px;
    }

    .metal-image img {
      width: 100%;
      height: 350px;
      object-fit: cover;
      border-radius: 8px;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
      transition: transform 0.3s ease;
    }

    .metal-image img:hover {
      transform: scale(1.02);
    }

    .metal-text {
      flex: 2;
      min-width: 280px;
    }

    .metal-text h3 {
      font-size: 20px;
      color: #A68380;
      margin: 0 0 15px;
      padding-bottom: 10px;
      padding-top: 16px;
      border-bottom: 1px solid #eee;
    }

    .metal-text p {
      font-size: 16px;
      line-height: 1.7;
      margin-bottom: 16px;
      color: #555;
    }

    .metal-features {
      background-color: #f8f5f5;
      border-radius: 8px;
      padding: 20px 25px;
      margin: 20px 0;
    }

    .metal-features h4 {
      margin: 0 0 15px;
      font-size: 18px;
      color: #333;
    }

    .metal-features ul {
      margin: 0;
      padding-left: 20px;
    }

    .metal-features li {
      margin-bottom: 10px;
      position: relative;
      padding-left: 15px;
      list-style-type: none;
    }

    .metal-features li:before {
      content: "•";
      color: #A68380;
      font-weight: bold;
      position: absolute;
      left: 0;
    }

    .pro-tip {
      background-color: #f0e9e8;
      border-left: 4px solid #A68380;
      padding: 15px 20px;
      margin: 25px 0;
      border-radius: 0 8px 8px 0;
    }

    .pro-tip h4 {
      margin: 0 0 10px;
      color: #A68380;
      font-size: 18px;
    }

    .pro-tip p {
      margin: 0;
    }

    .cta-container {
      text-align: center;
      margin: 20px 0;
    }

    .discover {
      display: inline-block;
      font-size: 16px;
      font-weight: 500;
      border-radius: 30px;
      color: white;
      text-decoration: none;
      text-transform: uppercase;
      background: linear-gradient(to right, #A68380, #c9b0ae);
      padding: 14px 32px;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(166, 131, 128, 0.3);
      letter-spacing: 1px;
    }

    .discover:hover {
      transform: translateY(-3px);
      box-shadow: 0 7px 20px rgba(166, 131, 128, 0.4);
      background: linear-gradient(to right, #96756f, #A68380);
    }

    .comparison-table {
      width: 100%;
      border-collapse: collapse;
      margin: 40px 0;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
      border-radius: 8px;
      overflow: hidden;
    }

    .comparison-table thead {
      background: linear-gradient(to right, #A68380, #c9b0ae);
      color: white;
    }

    .comparison-table th {
      padding: 15px;
      text-align: left;
      font-weight: 500;
    }

    .comparison-table td {
      padding: 15px;
      border-bottom: 1px solid #eee;
    }

    .comparison-table tbody tr:nth-child(even) {
      background-color: #f9f5f5;
    }

    .comparison-table tbody tr:hover {
      background-color: #f0e9e8;
    }

    /* Responsive styles */
    @media (max-width: 992px) {
      .metal-education-wrapper h1.page-title {
        font-size: 28px;
      }
      
      .metal-intro p {
        font-size: 16px;
      }
      
      .metal-section-content {
        flex-direction: column;
      }
      
      .metal-image {
        max-width: 100%;
      }
    }

    @media (max-width: 768px) {
      .metal-education-wrapper {
        padding: 20px 0;
      }
      
      .metal-education-container {
        padding: 0 16px;
      }
      
      .metal-education-wrapper h1.page-title {
        font-size: 24px;
        margin-bottom: 30px;
      }
      
      .metal-section {
        margin-bottom: 40px;
      }
      
      .metal-section-header h2 {
        font-size: 20px;
      }
      
      .metal-section-content {
        padding: 20px;
      }
      
      .metal-text h3 {
        font-size: 18px;
      }
      
      .comparison-table {
        display: block;
        overflow-x: auto !important;
        white-space: normal;
      }
    }

    @media (max-width: 480px) {
      .metal-education-wrapper h1.page-title {
        font-size: 22px;
      }
      
      .metal-section-header {
        padding: 15px 20px;
      }
      
      .metal-section-content {
        padding: 15px;
        gap: 20px;
      }
      
      .metal-image img {
        height: 250px;
      }
      
      .discover {
        padding: 12px 24px;
        font-size: 14px;
      }
    }



/* Responsive Table Base Styles */
.comparison-table {
  width: 100%;
  border-collapse: collapse;
  margin: 40px 0;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
  border-radius: 8px;
  overflow: hidden;
}

.comparison-table thead {
  background: linear-gradient(to right, #A68380, #c9b0ae);
  color: white;
}

.comparison-table th {
  padding: 15px;
  text-align: left;
  font-weight: 500;
}

.comparison-table td {
  padding: 15px;
  border-bottom: 1px solid #eee;
}

.comparison-table tbody tr:nth-child(even) {
  background-color: #f9f5f5;
}

/* .comparison-table tbody tr:hover {
  background-color: #f0e9e8;
}
 */
/* Enhanced Mobile Responsive Styles */
@media (max-width: 768px) {
  .comparison-table {
    box-shadow: none;
    border: none;
  }
  
  .comparison-table thead {
    display: none; /* Hide table headers on mobile */
  }
  
  .comparison-table, 
  .comparison-table tbody, 
  .comparison-table tr {
    display: block;
    width: 100%;
  }
  
  .comparison-table tr {
    margin-bottom: 20px;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    overflow: hidden;
    background-color: #fff;
  }
  
  .comparison-table td {
    display: flex;
    padding: 12px 15px;
    border-bottom: 1px solid #f0f0f0;
    text-align: left;
    min-height: 24px;
  }
  
  /* Add header titles for each cell using data attributes */
  .comparison-table td:before {
    content: attr(data-label);
    font-weight: 500;
    color: #A68380;
    width: 40%;
    min-width: 120px;
    padding-right: 15px;
  }
  
  /* Metal name styling (first cell in each row) */
  .comparison-table td:first-child {
    background: linear-gradient(to right, #A68380, #c9b0ae);
    color: white;
    font-weight: 500;
    font-size: 16px;
    border-radius: 8px 8px 0 0;
    padding: 15px;
    justify-content: center;
  }
  
  /* Remove the label for the metal name cell */
  .comparison-table td:first-child:before {
    display: none;
  }
  
  /* Even row styling adjustment */
  .comparison-table tbody tr:nth-child(even) {
    background-color: #fff;
  }
  
  .comparison-table tbody tr:nth-child(even) td:not(:first-child) {
    background-color: #f9f5f5;
  }

  /* Last cell in each row */
  .comparison-table td:last-child {
    border-bottom: none;
    border-radius: 0 0 8px 8px;
  }
  
  /* Additional spacing for content after label */
  .comparison-table td span {
    flex: 1;
  }
}

/* Small mobile screens */
@media (max-width: 480px) {
  .comparison-table td:before {
    width: 35%;
    min-width: 100px;
  }
  
  .comparison-table td {
    padding: 10px 12px;
    font-size: 14px;
  }
  
  .comparison-table td:first-child {
    font-size: 15px;
    padding: 12px;
  }
}
  </style>
{% endstyle %}

<section class="metal-education-wrapper">
  <div class="metal-education-container">
    <h1 class="page-title">Gold, Silver or Platinum? The Ultimate Guide to Choosing the Best Metal for Your Jewelry</h1>

    <div class="metal-intro">
      <p>At <a href="https://www.lucirajewelry.com/" target="_blank">Lucira Jewelry</a>, we meticulously source our metals to ensure exceptional quality, longevity, and comfort, so every piece remains as timeless as the moments it represents. Jewellery is not just a product, but a lifelong connection with the milestones achieved and the occasions celebrated.</p>
      <p>The metal you choose decides the overall look, feel and the longevity of your jewellery. Let's break down the characteristics of the best metals to help you make the best buying decision.</p>
    </div>

    <!-- Gold Section -->
    <div class="metal-section">
      <div class="metal-section-header">
        <h2>Why Choose Gold</h2>
      </div>
      <div class="metal-section-content">
        <div class="metal-image">
          <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/LJ-R00165YG_1F.webp?v=1745852482" title="Gold Jewelry"alt="Gold Jewelry" />
        </div>
        <div class="metal-text">
          <p>Gold has been treasured for centuries and continues to be a symbol of prosperity and elegance in jewelry design.</p>
          
          <div class="metal-features">
            <h4>Benefits of Gold</h4>
            <ul>
              <li>Resistant to corrosion</li>
              <li>Most people are not allergic to gold</li>
              <li>Vast variety in intricate jewellery designs because gold is malleable</li>
              <li>Used for generations</li>
              <li>Associated with grand occasions, prosperity and status</li>
            </ul>
          </div>
          
          <h3>24k Gold (Pure Gold)</h3>
          <p>99.9% gold, highly soft, and not ideal for daily wear.</p>
          
          <h3>22k Gold</h3>
          <p>91.6% pure gold, has a rich yellow hue and is durable. If you are wearing a traditional outfit, a 22K gold jewellery is ideal! If you are choosing based on skin tone, 22K gold complements olive and brown skin.</p>
          
          <h3>18K Gold</h3>
          <p>75% gold, offering a perfect balance of purity and durability. The color is the perfect color of yellow and radiates a more luxurious appeal.</p>
          
          <h3>14K Gold</h3>
          <p>58.3% gold, more resistant to scratches, perfect for active lifestyles. It looks perfect on fair to medium skin tones as the subdued gold complements cooler undertones.</p>
          
          <div class="pro-tip">
            <h4>Pro Tip to Buy Gold</h4>
            <p>Always check for a hallmark or a karat stamp to ensure authenticity. Choose 18K or 14K for daily wear.</p>
          </div>
          
          <div class="cta-container">
            <a href="https://lucirajewelry.com/collections/engagement-rings-yellow-gold" class="discover" target="_blank">Browse Gold</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Silver Section -->
    <div class="metal-section">
      <div class="metal-section-header">
        <h2>Sterling Silver For You to Wear Everyday</h2>
      </div>
      <div class="metal-section-content">
        <div class="metal-image">
          <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/LJ-R00341WG_1.webp?v=1745490226"title="Sterling Silver Jewelry"  alt="Sterling Silver Jewelry" />
        </div>
        <div class="metal-text">
          <p>Just like pure gold, pure silver is too soft to ensure durability. With a brilliant white sheen, sterling silver (92.5% silver and 7.5% alloy) provides an elegant look without costing a fortune, and is the go-to stylish choice for daily wear! It is lightweight, affordable and has a reflective finish.</p>
          <p>One disadvantage that it does have is that silver has a tendency to tarnish. However, with proper care this process can be slowed down drastically! If the silver has turned black, a professional jeweller can clean it and it will look brand new.</p>
          
          <div class="metal-features">
            <h4>Why Choose Sterling Silver?</h4>
            <ul>
              <li>Affordable & stylish</li>
              <li>Easy to shape into intricate designs</li>
              <li>Lightweight and comfortable for daily wear</li>
              <li>Hypoallergenic and has health benefits</li>
              <li>Best for fashion-forward jewellery and budget-conscious buyers</li>
            </ul>
          </div>
          
          <div class="pro-tip">
            <h4>Pro Tip to Buy Sterling Silver</h4>
            <p>Look for '925' stamp to ensure genuine sterling silver.</p>
          </div>
          
          <div class="cta-container">
            <a target="_blank" href="" class="discover">Browse Silver</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Platinum Section -->
    <div class="metal-section">
      <div class="metal-section-header">
        <h2>Platinum: Why Is It The Most Desired Choice of Metal</h2>
      </div>
      <div class="metal-section-content">
        <div class="metal-image">
          <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/LJ-R00245PLT_1.webp?v=1745823338" title="Platinum Jewelry"alt="Platinum Jewelry" />
        </div>
        <div class="metal-text">
          <p>If you are someone seeking luster, luxury and longevity, platinum is your answer. It is prized for its prestige and purity. Its presence is felt as it enhances the diamonds of your fine jewelry. Unlike white gold, it doesn't require a rhodium plating because of its natural whiteness.</p>
          
          <p>Its low maintenance helps retain the shine and beauty forever. Most high-end jewellery are made out of platinum and it's perfect for sensitive skin. When paired with diamonds, it's neutral color enhances the shine and elevates the entire look.</p>
          
          <div class="metal-features">
            <h4>Why Choose Platinum?</h4>
            <ul>
              <li>It is denser and more durable than gold</li>
              <li>It is hypoallergenic</li>
              <li>It is valued higher than most metals</li>
              <li>Best for jewellery and fashion lovers because of its exclusivity (Up to 30 times rarer than gold)</li>
            </ul>
          </div>
          
          <div class="pro-tip">
            <h4>Pro Tip to Buy Platinum</h4>
            <p>Ensure it is certified by a reliable jeweller and has a purity stamp such as "PT950"</p>
          </div>
          
          <div class="cta-container">
            <a href="https://lucirajewelry.com/collections/engagement-rings-platinum" class="discover">Browse Platinum</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Gold Colors Section -->
    <div class="metal-section">
      <div class="metal-section-header">
        <h2>Which Color Gold Looks Best?</h2>
      </div>
      <div class="metal-section-content">
        <div class="metal-text">
          <p>Our fine gold accessories come in three colors - yellow, white and rose gold, each offering its own finesse and lasting durability.</p>
          
          <h3>Yellow Gold</h3>
          <p>Yellow Gold is a warm-colored metal and a classic favourite for engagement rings. By nature, gold is yellow, but in its purest form, it can look garish. The warm hue of yellow gold creates an aesthetic, sunny hue.</p>
          
          <h3>White Gold</h3>
          <p>White gold is a 24K gold alloyed with 'white' metals such as palladium or silver to give a white appearance while the gold may still show a little yellow hue. For this, some pieces of jewellery have a rhodium plating to make it appear entirely white. The less yellow a gold jewellery piece is, the more durable and so, white gold is chosen by most because of the luxurious appeal it holds while also having the desired longevity.</p>
          
          <h3>Rose Gold</h3>
          <p>Rose gold jewelry is trending and for a reason - its vintage appeal with the ability to stand out with all kinds of outfits makes it versatile. It has garnered the attention of fashion lovers because of its feminine and luxurious touch. The rosy look gives a romantic tone and is common in engagement rings.</p>
        </div>
      </div>
    </div>

    <!-- Comparison Table Section -->
    <div class="metal-section">
      <div class="metal-section-header">
        <h2>Metal Comparison Guide</h2>
      </div>
      <div class="metal-section-content">
        <div class="metal-text">
          <p>To make it easier for you to pick the perfect one, we have created this quick metal comparison table for your jewelry that breaks down the key features of each metal, based on durability, color, purity, and your lifestyle. Bookmark this guide for future reference to make jewellery shopping feel like a breeze!</p>
          
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Metal</th>
              <th>Composition</th>
              <th>Durability</th>
              <th>Color</th>
              <th>Common Use</th>
              <th>Notes</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td data-label="Metal">22K Gold</td>
              <td data-label="Composition">91.6% gold, mixed with alloys</td>
              <td data-label="Durability">More durable than 24K</td>
              <td data-label="Color">Rich yellow</td>
              <td data-label="Common Use">Traditional wear, olive & brown skin tones</td>
              <td data-label="Notes">Retains high value & cultural significance</td>
            </tr>
            <tr>
              <td data-label="Metal">18K Gold</td>
              <td data-label="Composition">75% gold, mixed with stronger alloys</td>
              <td data-label="Durability">Balanced durability & purity</td>
              <td data-label="Color">Warm yellow</td>
              <td data-label="Common Use">Luxury jewellery, daily wear</td>
              <td data-label="Notes">Perfect balance of elegance & strength</td>
            </tr>
            <tr>
              <td data-label="Metal">14K Gold</td>
              <td data-label="Composition">58.3% gold, higher alloy content</td>
              <td data-label="Durability">Highly durable, scratch-resistant</td>
              <td data-label="Color">Subdued yellow</td>
              <td data-label="Common Use">Active lifestyles, fair to medium skin tones</td>
              <td data-label="Notes">More affordable, great for engagement rings</td>
            </tr>
            <tr>
              <td data-label="Metal">White Gold</td>
              <td data-label="Composition">14K or 18K gold mixed with palladium/silver</td>
              <td data-label="Durability">Durable, requires rhodium plating</td>
              <td data-label="Color">Silvery-white</td>
              <td data-label="Common Use">Modern & timeless jewellery</td>
              <td data-label="Notes">Needs occasional re-plating for brightness</td>
            </tr>
            <tr>
              <td data-label="Metal">Rose Gold</td>
              <td data-label="Composition">14K or 18K gold mixed with copper</td>
              <td data-label="Durability">Strong due to copper content</td>
              <td data-label="Color">Pinkish hue</td>
              <td data-label="Common Use">Romantic, vintage-style jewellery</td>
              <td data-label="Notes">Feminine and unique appearance</td>
            </tr>
            <tr>
              <td data-label="Metal">Sterling Silver</td>
              <td data-label="Composition">92.5% silver, 7.5% alloy (usually copper)</td>
              <td data-label="Durability">Can tarnish but easily cleaned</td>
              <td data-label="Color">Bright white</td>
              <td data-label="Common Use">Affordable & stylish daily wear</td>
              <td data-label="Notes">Lightweight and hypoallergenic</td>
            </tr>
            <tr>
              <td data-label="Metal">Platinum</td>
              <td data-label="Composition">95% pure platinum</td>
              <td data-label="Durability">Most durable, retains shine forever</td>
              <td data-label="Color">Naturally white</td>
              <td data-label="Common Use">High-end, diamond jewellery</td>
              <td data-label="Notes">Hypoallergenic, rare, & prestigious</td>
            </tr>
          </tbody>
        </table>
                </div>
      </div>
    </div>
  </div>
</section>