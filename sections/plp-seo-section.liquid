{% schema %}
{
  "name": "PLP Seo Section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "links_to_show",
      "label": "Links To Show",
      "min": 5,
      "max": 12,
      "default": 7,
      "step": 1
    }
  ],
  "presets": [{ "name": "PLP SEO Section" }]
}
{% endschema %}

<section class="plp-seo">
  <div class="plp-seo-contents">
    <div class="plp-seo-tab-content" id="plp-seo-content2">
      <div id="plp-seo-overview-content">
        <div class="faq-wrapper">
          {% assign faq_heading = collection.metafields.custom.faq_heading %}
          {% if faq_heading != blank %}
            <h2 class="faq-heading">{{ faq_heading }}</h2>
          {% endif %}

          {% assign questions = collection.metafields.custom.faqquestion.value %}
          {% assign answers = collection.metafields.custom.faqanswers.value %}

          {% if questions and answers %}
            <div itemscope itemtype="https://schema.org/FAQPage">
              <h2>FAQ</h2>
              {% for question in questions %}
                {% assign answer = answers[forloop.index0] %}
                <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                  <button
                    class="faq-question"
                    onclick="this.classList.toggle('active'); this.nextElementSibling.classList.toggle('show');"
                  >
                    <span itemprop="name">{{ question }}</span>
                    <span class="arrow">+</span>
                  </button>
                  <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                    <div itemprop="text">{{ answer }}</div>
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <div class="plp-seo-links-section">
          {% assign featured_collection = collection.metafields.custom.bestseller_products.value %}
          {% if featured_collection %}
            <div class="seo-table" style="color: #000">
              <div class="seo-header">
                <h2 class="product-title">PRODUCT NAME</h2>
                <h2 class="product-price">PRICE</h2>
              </div>
              {% for product in featured_collection.products limit: section.settings.links_to_show %}
                <div class="seo-row">
                  <a class="product-title" href="{{ product.url }}">{{ product.title }}</a>
                  <span class="product-price">{{ product.price | money_without_trailing_zeros }}</span>
                </div>
              {% endfor %}
            </div>
            <p class="last-updated">Last Updated: {{ 'now' | date: '%d %B %Y' }}</p>
          {% endif %}
        </div>
      </div>
      {% assign seo_content = collection.metafields.custom.seocontent %}

      {% if seo_content != blank %}
        <div class="richtext-toggle-section">
          <div class="richtext-content">
            <!-- Preview (plain text, no formatting) -->
            <div class="richtext-preview">
              {{ seo_content | metafield_tag | strip_html | truncatewords: 40 }}
              <span class="read-more-dots">...</span>
            </div>

            <!-- Full Rich Text (formatted) -->
            <div class="richtext-full" style="display: none;">
              {{ seo_content | metafield_tag }}
            </div>

            <!-- Toggle Button -->
            <button class="toggle-read-more">READ MORE</button>
          </div>
        </div>

        <script>
          document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.toggle-read-more').forEach(function (btn) {
              btn.addEventListener('click', function () {
                var parent = this.closest('.richtext-content');
                var preview = parent.querySelector('.richtext-preview');
                var full = parent.querySelector('.richtext-full');
                var dots = parent.querySelector('.read-more-dots');

                if (full.style.display === 'none') {
                  full.style.display = 'block';
                  preview.style.display = 'none';
                  this.textContent = 'READ LESS';
                } else {
                  full.style.display = 'none';
                  preview.style.display = 'block';
                  this.textContent = 'READ MORE';
                }
              });
            });
          });
        </script>

        <style>
          .richtext-preview{font-size:14px;color:#000;font-family:futura,sans-serif;padding:40px 0;padding-bottom:0}
          .richtext-full{font-size:14px;color:#000;padding:0px;text-align:left}
          .toggle-read-more{padding-left:0px;padding-bottom:40px;color:#d9272e;background:0 0;border:none;font-weight:700;font-family:futura,sans-serif;margin-top:10px;cursor:pointer}
          .richtext-toggle-section{width:100%;margin:0 auto}
          @media screen only and (max-width:480px){
          .richtext{padding-top:20px}
          }
        </style>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .faq-wrapper{width:100%;margin:20px auto;font-family:sans-serif}
  .faq-question{width:100%;padding:20px 20px 20px 0;font-family:futura,sans-serif;border:none;font-size:18px;background:0 0;text-align:left;cursor:pointer;border-bottom:1px solid #ddd;position:relative;color:#000}
  .faq-question .arrow{position:absolute;right:5px;font-size:18px;transition:transform .2s ease}
  .faq-question.active .arrow{transform:rotate(45deg)}
  .faq-answer{display:none;padding:34px;font-family:futura,sans-serif;padding-left:20px;background:#fff;font-size:14px;border-bottom:1px solid #ddd}
  .faq-answer.show{display:block}
  .faq-heading{text-align:center;padding-bottom:20px}
  .metafield-rich_text_field h2{color:#000}
  #plp-seo-tab1:checked~.plp-seo-tab-labels label[for=plp-seo-tab1],#plp-seo-tab2:checked~.plp-seo-tab-labels label[for=plp-seo-tab2],#plp-seo-tab3:checked~.plp-seo-tab-labels label[for=plp-seo-tab3]{background-color:#fff}
  #plp-seo-tab1:checked~.plp-seo-contents #plp-seo-content1,#plp-seo-tab2:checked~.plp-seo-contents #plp-seo-content2,#plp-seo-tab3:checked~.plp-seo-contents #plp-seo-content3{display:block}
  .plp-seo-tab-content{padding:2rem;width:92%;margin:0 auto}
  #plp-seo-overview-content{width:100%;display:flex;gap: 6rem;align-items:flex-start}
  #plp-seo-overview-content>div{flex:1}
  .plp-main-seo-section h1{font-size:24px;margin:0}
  .plp-main-seo-section h2{font-size:18px;margin:0}
  .plp-main-seo-section h3{font-size:14px;margin:0}
  .plp-main-seo-section p{font-size:12px;margin:0}
  .seo-table{display:flex;flex-direction:column;gap:8px;padding-top:25px}
  .seo-header,.seo-row{display:flex;justify-content:space-between;font-size:18px}
  .seo-header{font-weight:700;margin-bottom:8px}
  .seo-header .product-price,.seo-header .product-title{font-size:14px;font-weight:500;letter-spacing: 1.2px;}
  .seo-row .product-title{color:initial;text-decoration:none;font-size:16px;flex:1;text-align:left}
  .seo-row .product-title:hover{text-decoration:underline}
  .seo-row .product-price{font-size: 14px; width: 100px; font-weight: 600; color: #1A1A1A; text-align: right; white-space: nowrap;}
  @media screen and (max-width:48em){
  .plp-seo-tab-content{width:90%;padding:0;padding-top:2rem}
  .plp-seo-tab-content h2{margin-left:0}
  #plp-seo-overview-content{flex-direction:column-reverse;align-items:stretch}
  }
</style>
