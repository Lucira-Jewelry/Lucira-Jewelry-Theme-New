{% stylesheet %}
  .craftsmanship-section {
    width: 100%;
    padding: 60px 40px;
    background-color: #ffffff;
  }

  .craftsmanship-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .craftsmanship-grid {
    display: grid;
    grid-template-columns: 500px 1fr;
    gap: 40px;
    align-items: start;
  }

  /* LEFT COLUMN */
  .craftsmanship-left {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 500px;
  }

  .image-top-left {
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    border-radius: 4px;
  }

  .image-top-left img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-bottom-left {
    width: 260px;
    aspect-ratio: 1/1;
    overflow: hidden;
    border-radius: 4px;
    margin-left: 0;
  }

  .image-bottom-left img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* RIGHT COLUMN */
  .craftsmanship-right {
    display: flex;
    flex-direction: column;
    gap: 35px;
  }

  /* Content Block 1 */
  .content-block-1 {
    padding-bottom: 25px;
    border-bottom: 1px solid #e0e0e0;
  }

  .content-block-1 h3 {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 1.5px;
    margin: 0 0 12px 0;
    text-transform: uppercase;
    color: #000;
  }

  .content-block-1 p {
    font-size: 13px;
    line-height: 1.6;
    color: #666;
    margin: 0;
  }

  /* Images Grid in Right Column */
  .images-grid-right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .image-top-right {
    aspect-ratio: 1/1;
    overflow: hidden;
    border-radius: 4px;
  }

  .image-top-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-bottom-right {
    aspect-ratio: 1/1;
    overflow: hidden;
    border-radius: 4px;
  }

  .image-bottom-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Content Block 2 */
  .content-block-2 {
    padding-top: 10px;
    grid-column: 1 / -1;
  }

  .content-block-2 h3 {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 1.5px;
    margin: 0 0 12px 0;
    text-transform: uppercase;
    color: #000;
  }

  .content-block-2 p {
    font-size: 13px;
    line-height: 1.6;
    color: #666;
    margin: 0;
  }

  /* Wrapper for right column content */
  .right-content-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    align-items: start;
  }

  /* BOTTOM SECTION - FULL WIDTH */
  .craftsmanship-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    padding-top: 50px;
    margin-top: 30px;
    border-top: 1px solid #e0e0e0;
  }

  .image-bottom-full {
    aspect-ratio: 5/3;
    overflow: hidden;
    border-radius: 4px;
  }

  .image-bottom-full img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Content Block 3 */
  .content-block-3 {
    padding: 0;
  }

  .content-block-3 h3 {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 1.5px;
    margin: 0 0 12px 0;
    text-transform: uppercase;
    color: #000;
  }

  .content-block-3 p {
    font-size: 13px;
    line-height: 1.6;
    color: #666;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .craftsmanship-section {
      padding: 40px 20px;
    }

    .craftsmanship-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .image-bottom-left {
      width: 60%;
    }

    .craftsmanship-bottom {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .images-grid-right {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

<div class="craftsmanship-section">
  <div class="craftsmanship-container">
    <!-- TOP SECTION - 2 COLUMNS -->
    <div class="craftsmanship-grid">
      <!-- LEFT COLUMN - LARGE IMAGE + SMALL SQUARE IMAGE -->
      <div class="craftsmanship-left">
        <!-- Top Left Image: 3:4 Aspect Ratio (Portrait) -->
        <div class="image-top-left">
          {% if section.settings.image_1 != blank %}
            <img 
              src="{{ section.settings.image_1 | img_url: '400x533' }}" 
              alt="Craftsmanship"
              loading="lazy"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>

        <!-- Bottom Left Image: 1:1 with Blue Border -->
        <div class="image-bottom-left">
          {% if section.settings.image_2 != blank %}
            <img 
              src="{{ section.settings.image_2 | img_url: '300x300' }}" 
              alt="Craftsmanship Detail"
              loading="lazy"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      </div>

      <!-- RIGHT COLUMN - CONTENT + IMAGES -->
      <div class="craftsmanship-right">
        <!-- Content Block 1 -->
        <div class="content-block-1">
          <h3>{{ section.settings.heading_1 }}</h3>
          <p>{{ section.settings.content_1 }}</p>
        </div>

        <!-- Wrapper for images and content block 2 in row -->
        <div class="right-content-wrapper">
          <!-- Images Grid: Two 1:1 Images -->
          <div class="images-grid-right">
            <div class="image-top-right">
              {% if section.settings.image_3 != blank %}
                <img 
                  src="{{ section.settings.image_3 | img_url: '300x300' }}" 
                  alt="Bespoke Creations"
                  loading="lazy"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>

            <div class="image-bottom-right">
              {% if section.settings.image_4 != blank %}
                <img 
                  src="{{ section.settings.image_4 | img_url: '300x300' }}" 
                  alt="Bespoke Creations Detail"
                  loading="lazy"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
          </div>

          <!-- Content Block 2 -->
          <div class="content-block-2">
            <h3>{{ section.settings.heading_2 }}</h3>
            <p>{{ section.settings.content_2 }}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- BOTTOM SECTION - FULL WIDTH: 2 COLUMNS (IMAGE + CONTENT) -->
    <div class="craftsmanship-bottom">
      <!-- Image: 5:3 Aspect Ratio -->
      <div class="image-bottom-full">
        {% if section.settings.image_5 != blank %}
          <img 
            src="{{ section.settings.image_5 | img_url: '600x360' }}" 
            alt="Expert Consultation"
            loading="lazy"
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      <!-- Content Block 3 -->
      <div class="content-block-3">
        <h3>{{ section.settings.heading_3 }}</h3>
        <p>{{ section.settings.content_3 }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Craftsmanship Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Top Left Image (3:4 Portrait Aspect Ratio)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Bottom Left Image (1:1 Square with Blue Border)"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "First Heading",
      "default": "OUR CRAFTSMANSHIP"
    },
    {
      "type": "textarea",
      "id": "content_1",
      "label": "First Content Block",
      "default": "Every home piece is shaped by skilled artisans who understand you're more at the microscopic level. From ideal villas to historic settings, we're dedicated to delivering outstanding beauty."
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Top Right Image (1:1 Square)"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Bottom Right Image (1:1 Square)"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Second Heading",
      "default": "BESPOKE CREATIONS"
    },
    {
      "type": "textarea",
      "id": "content_2",
      "label": "Second Content Block",
      "default": "From stone selection to final design, our bespoke process brings timeless visions to life. Each custom piece is thoughtfully designed, engineered, and handcrafted to reflect individual taste and vision."
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Bottom Full Image (5:3 Aspect Ratio)"
    },
    {
      "type": "text",
      "id": "heading_3",
      "label": "Third Heading",
      "default": "EXPERT CONSULTATION"
    },
    {
      "type": "textarea",
      "id": "content_3",
      "label": "Third Content Block",
      "default": "Our world-expert guide you through every detail. We cast expectations built by transparency, education and genuine expertise."
    }
  ],
  "presets": [
    {
      "name": "Craftsmanship Section"
    }
  ]
}
{% endschema %}