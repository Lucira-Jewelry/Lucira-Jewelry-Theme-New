{% stylesheet %}
  .craftsmanship-section {
    width: 100%;
    padding: 80px 40px;
    background-color: #ffffff;
  }

  .craftsmanship-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .craftsmanship-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
    margin-bottom: 80px;
  }

  /* LEFT COLUMN - IMAGES STACK */
  .craftsmanship-left {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* Top left image - 3:4 aspect ratio */
  .image-top-left {
    width: 100%;
    height: 600px;
    overflow: hidden;
  }

  .image-top-left img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Bottom left image - square */
  .image-bottom-left {
    width: 80%;
    aspect-ratio: 1/1;
    overflow: hidden;
    margin-left: auto;
    margin-right: 0;
  }

  .image-bottom-left img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* RIGHT COLUMN - CONTENT + IMAGES */
  .craftsmanship-right {
    display: flex;
    flex-direction: column;
    gap: 60px;
    padding-top: 40px;
  }

  /* Content Block 1 - OUR CRAFTSMANSHIP */
  .content-block-1 {
    padding-bottom: 30px;
    border-bottom: 1px solid #e0e0e0;
  }

  .content-block-1 h3 {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 2px;
    margin: 0 0 20px 0;
    text-transform: uppercase;
    color: #000;
  }

  .content-block-1 p {
    font-size: 16px;
    line-height: 1.8;
    color: #333;
    margin: 0;
    font-weight: 300;
  }

  /* Images Grid in Right Column */
  .images-grid-right {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .image-top-right {
    width: 100%;
    aspect-ratio: 1/1;
    overflow: hidden;
  }

  .image-top-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-bottom-right {
    width: 100%;
    aspect-ratio: 1/1;
    overflow: hidden;
  }

  .image-bottom-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Content Block 2 - BESPOKE CREATIONS */
  .content-block-2 {
    padding-top: 30px;
    border-top: 1px solid #e0e0e0;
  }

  .content-block-2 h3 {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 2px;
    margin: 0 0 20px 0;
    text-transform: uppercase;
    color: #000;
  }

  .content-block-2 p {
    font-size: 16px;
    line-height: 1.8;
    color: #333;
    margin: 0;
    font-weight: 300;
  }

  /* BOTTOM SECTION - FULL WIDTH */
  .craftsmanship-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
    padding-top: 60px;
    border-top: 1px solid #e0e0e0;
  }

  /* Image on left in bottom section */
  .image-bottom-full {
    width: 100%;
    aspect-ratio: 3/2;
    overflow: hidden;
  }

  .image-bottom-full img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Content Block 3 - EXPERT CONSULTATION */
  .content-block-3 {
    padding-top: 40px;
  }

  .content-block-3 h3 {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 2px;
    margin: 0 0 20px 0;
    text-transform: uppercase;
    color: #000;
  }

  .content-block-3 p {
    font-size: 16px;
    line-height: 1.8;
    color: #333;
    margin: 0;
    font-weight: 300;
  }

  /* Divider lines - common to all content blocks */
  .content-block-1::after,
  .content-block-2::before,
  .craftsmanship-bottom::before {
    content: '';
    display: block;
    height: 1px;
    background-color: #e0e0e0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .craftsmanship-section {
      padding: 60px 30px;
    }
    
    .craftsmanship-grid {
      gap: 40px;
      margin-bottom: 60px;
    }
    
    .craftsmanship-right {
      gap: 40px;
    }
    
    .craftsmanship-bottom {
      gap: 40px;
      padding-top: 40px;
    }
  }

  @media (max-width: 768px) {
    .craftsmanship-section {
      padding: 40px 20px;
    }

    .craftsmanship-grid {
      grid-template-columns: 1fr;
      gap: 40px;
      margin-bottom: 40px;
    }

    .image-bottom-left {
      width: 70%;
      margin-left: auto;
      margin-right: auto;
    }

    .craftsmanship-right {
      padding-top: 0;
      gap: 40px;
    }

    .craftsmanship-bottom {
      grid-template-columns: 1fr;
      gap: 30px;
      padding-top: 40px;
    }

    .content-block-3 {
      padding-top: 0;
    }
    
    .image-top-left {
      height: 400px;
    }
  }
  
  @media (max-width: 480px) {
    .content-block-1 h3,
    .content-block-2 h3,
    .content-block-3 h3 {
      font-size: 13px;
      letter-spacing: 1.5px;
      margin-bottom: 15px;
    }
    
    .content-block-1 p,
    .content-block-2 p,
    .content-block-3 p {
      font-size: 15px;
      line-height: 1.6;
    }
    
    .image-bottom-left {
      width: 100%;
    }
  }
{% endstylesheet %}

<div class="craftsmanship-section">
  <div class="craftsmanship-container">
    <!-- TOP SECTION - 2 COLUMNS -->
    <div class="craftsmanship-grid">
      <!-- LEFT COLUMN - TWO STACKED IMAGES -->
      <div class="craftsmanship-left">
        <!-- Top Left Image: Portrait -->
        <div class="image-top-left">
          {% if section.settings.image_1 != blank %}
            <img 
              src="{{ section.settings.image_1 | img_url: '800x1066', scale: 2 }}" 
              alt="{{ section.settings.image_1.alt | escape }}"
              loading="lazy"
              width="800"
              height="1066"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>

        <!-- Bottom Left Image: Square -->
        <div class="image-bottom-left">
          {% if section.settings.image_2 != blank %}
            <img 
              src="{{ section.settings.image_2 | img_url: '600x600', scale: 2 }}" 
              alt="{{ section.settings.image_2.alt | escape }}"
              loading="lazy"
              width="600"
              height="600"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      </div>

      <!-- RIGHT COLUMN - CONTENT + IMAGES -->
      <div class="craftsmanship-right">
        <!-- Content Block 1: OUR CRAFTSMANSHIP -->
        <div class="content-block-1">
          <h3>{{ section.settings.heading_1 | default: "OUR CRAFTSMANSHIP" }}</h3>
          <p>{{ section.settings.content_1 | default: "Every lucia piece is shaped by skilled artisans who understand precision of the microscopic level. From ideal cuts to flawless settings, our craftsmanship maximizes brilliance, symmetry, and longevity." }}</p>
        </div>

        <!-- Images Grid: Two Square Images -->
        <div class="images-grid-right">
          <div class="image-top-right">
            {% if section.settings.image_3 != blank %}
              <img 
                src="{{ section.settings.image_3 | img_url: '600x600', scale: 2 }}" 
                alt="{{ section.settings.image_3.alt | escape }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>

          <div class="image-bottom-right">
            {% if section.settings.image_4 != blank %}
              <img 
                src="{{ section.settings.image_4 | img_url: '600x600', scale: 2 }}" 
                alt="{{ section.settings.image_4.alt | escape }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
        </div>

        <!-- Content Block 2: BESPOKE CREATIONS -->
        <div class="content-block-2">
          <h3>{{ section.settings.heading_2 | default: "BESPOKE CREATIONS" }}</h3>
          <p>{{ section.settings.content_2 | default: "From store selection to final design, our bespoke process brings personal stories to life. Each custom piece is thoughtfully designed, engineered, and handcrafted to reflect individual style and intent." }}</p>
        </div>
      </div>
    </div>

    <!-- BOTTOM SECTION - FULL WIDTH: 2 COLUMNS (IMAGE + CONTENT) -->
    <div class="craftsmanship-bottom">
      <!-- Image: Landscape -->
      <div class="image-bottom-full">
        {% if section.settings.image_5 != blank %}
          <img 
            src="{{ section.settings.image_5 | img_url: '800x533', scale: 2 }}" 
            alt="{{ section.settings.image_5.alt | escape }}"
            loading="lazy"
            width="800"
            height="533"
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      <!-- Content Block 3: EXPERT CONSULTATION -->
      <div class="content-block-3">
        <h3>{{ section.settings.heading_3 | default: "EXPERT CONSULTATION" }}</h3>
        <p>{{ section.settings.content_3 | default: "Our jewelry experts guide you through every detail, cut, cast, clarity and setting, ensuring confident decisions backed by transparency, education and genuine expertise." }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Craftsmanship Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Top Left Image (Portrait - 3:4 Ratio)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Bottom Left Image (Square - 1:1 Ratio)"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "First Heading",
      "default": "OUR CRAFTSMANSHIP"
    },
    {
      "type": "textarea",
      "id": "content_1",
      "label": "First Content Block",
      "default": "Every lucia piece is shaped by skilled artisans who understand precision of the microscopic level. From ideal cuts to flawless settings, our craftsmanship maximizes brilliance, symmetry, and longevity."
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Top Right Image (Square - 1:1 Ratio)"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Bottom Right Image (Square - 1:1 Ratio)"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Second Heading",
      "default": "BESPOKE CREATIONS"
    },
    {
      "type": "textarea",
      "id": "content_2",
      "label": "Second Content Block",
      "default": "From store selection to final design, our bespoke process brings personal stories to life. Each custom piece is thoughtfully designed, engineered, and handcrafted to reflect individual style and intent."
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Bottom Full Image (Landscape - 3:2 Ratio)"
    },
    {
      "type": "text",
      "id": "heading_3",
      "label": "Third Heading",
      "default": "EXPERT CONSULTATION"
    },
    {
      "type": "textarea",
      "id": "content_3",
      "label": "Third Content Block",
      "default": "Our jewelry experts guide you through every detail, cut, cast, clarity and setting, ensuring confident decisions backed by transparency, education and genuine expertise."
    }
  ],
  "presets": [
    {
      "name": "Craftsmanship Section",
      "category": "Image"
    }
  ]
}
{% endschema %}