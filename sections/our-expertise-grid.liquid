{% stylesheet %}
  .craftsmanship-section {
    width: 100%;
    padding: {{ section.settings.section_padding_mobile }}px 20px;
    max-width: 1400px;
    margin: 0 auto;
  }

  @media (min-width: 769px) {
    .craftsmanship-section {
      padding: {{ section.settings.section_padding_desktop }}px 20px;
    }
  }

  .section-heading {
    font-size: {{ section.settings.heading_font_size_mobile }}px;
    font-weight: 600;
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: {{ section.settings.heading_color }};
  }

  @media (min-width: 769px) {
    .section-heading {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
    }
  }

  .section-description {
    font-size: {{ section.settings.description_font_size }}px;
    color: {{ section.settings.description_color }};
    margin-bottom: 30px;
    line-height: 1.6;
    max-width: 500px;
  }

  .grid-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: auto auto;
    gap: {{ section.settings.grid_gap_desktop }}px;
    margin-bottom: 40px;
  }

  @media (max-width: 768px) {
    .grid-container {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto auto;
      gap: {{ section.settings.grid_gap_mobile }}px;
    }
  }

  .grid-item {
    position: relative;
    overflow: hidden;
    background: #f5f5f5;
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  .grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .grid-item:hover img {
    transform: scale(1.05);
  }

  .grid-item-1 {
    grid-column: 1;
    grid-row: 1 / 3;
    aspect-ratio: 1 / 1.3;
  }

  .grid-item-2 {
    grid-column: 2;
    grid-row: 1;
    aspect-ratio: 1 / 0.8;
  }

  .grid-item-3 {
    grid-column: 2;
    grid-row: 2;
    aspect-ratio: 1 / 0.8;
  }

  .grid-item-4 {
    grid-column: 1;
    grid-row: 1;
    aspect-ratio: 1 / 0.8;
  }

  @media (max-width: 768px) {
    .grid-item-1,
    .grid-item-2,
    .grid-item-3,
    .grid-item-4 {
      grid-column: 1 !important;
      grid-row: auto !important;
      aspect-ratio: 1 / 1 !important;
    }
  }

  .image-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.95);
    padding: {{ section.settings.image_content_padding }}px;
    backdrop-filter: blur(5px);
  }

  .image-content h3 {
    font-size: {{ section.settings.image_title_font_size }}px;
    font-weight: 600;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ section.settings.image_title_color }};
  }

  .image-content p {
    font-size: {{ section.settings.image_text_font_size }}px;
    color: {{ section.settings.image_text_color }};
    line-height: 1.5;
  }

  .bottom-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.bottom_section_gap }}px;
    align-items: center;
    background: {{ section.settings.bottom_section_bg_color }};
    padding: {{ section.settings.bottom_section_padding }}px;
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  @media (max-width: 768px) {
    .bottom-section {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 30px 20px;
    }
  }

  .bottom-image {
    overflow: hidden;
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  .bottom-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .bottom-content h2 {
    font-size: {{ section.settings.bottom_heading_font_size }}px;
    font-weight: 600;
    margin-bottom: 15px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ section.settings.bottom_heading_color }};
  }

  .bottom-content p {
    font-size: {{ section.settings.bottom_text_font_size }}px;
    color: {{ section.settings.bottom_text_color }};
    line-height: 1.8;
  }
{% endstylesheet %}

<section class="craftsmanship-section">
  <!-- Header -->
  <h1 class="section-heading">{{ section.settings.main_heading }}</h1>
  <p class="section-description">{{ section.settings.main_description }}</p>

  <!-- Image Grid - 4 Images -->
  <div class="grid-container">
    <!-- Grid Item 1 -->
    {% if section.settings.image_1 %}
      <div class="grid-item grid-item-1">
        {% if section.settings.image_1_link %}
          <a href="{{ section.settings.image_1_link }}">
        {% endif %}
        {{ section.settings.image_1 | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.image_1_alt }}
        {% if section.settings.image_1_link %}
          </a>
        {% endif %}
        {% if section.settings.image_1_show_content %}
          <div class="image-content">
            <h3>{{ section.settings.image_1_title }}</h3>
            <p>{{ section.settings.image_1_text }}</p>
          </div>
        {% endif %}
      </div>
    {% endif %}

    <!-- Grid Item 2 -->
    {% if section.settings.image_2 %}
      <div class="grid-item grid-item-2">
        {% if section.settings.image_2_link %}
          <a href="{{ section.settings.image_2_link }}">
        {% endif %}
        {{ section.settings.image_2 | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.image_2_alt }}
        {% if section.settings.image_2_link %}
          </a>
        {% endif %}
        {% if section.settings.image_2_show_content %}
          <div class="image-content">
            <h3>{{ section.settings.image_2_title }}</h3>
            <p>{{ section.settings.image_2_text }}</p>
          </div>
        {% endif %}
      </div>
    {% endif %}

    <!-- Grid Item 3 -->
    {% if section.settings.image_3 %}
      <div class="grid-item grid-item-3">
        {% if section.settings.image_3_link %}
          <a href="{{ section.settings.image_3_link }}">
        {% endif %}
        {{ section.settings.image_3 | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.image_3_alt }}
        {% if section.settings.image_3_link %}
          </a>
        {% endif %}
        {% if section.settings.image_3_show_content %}
          <div class="image-content">
            <h3>{{ section.settings.image_3_title }}</h3>
            <p>{{ section.settings.image_3_text }}</p>
          </div>
        {% endif %}
      </div>
    {% endif %}

    <!-- Grid Item 4 -->
    {% if section.settings.image_4 %}
      <div class="grid-item grid-item-4">
        {% if section.settings.image_4_link %}
          <a href="{{ section.settings.image_4_link }}">
        {% endif %}
        {{ section.settings.image_4 | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.image_4_alt }}
        {% if section.settings.image_4_link %}
          </a>
        {% endif %}
        {% if section.settings.image_4_show_content %}
          <div class="image-content">
            <h3>{{ section.settings.image_4_title }}</h3>
            <p>{{ section.settings.image_4_text }}</p>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>

  <!-- Bottom Section -->
  {% if section.settings.bottom_image %}
    <div class="bottom-section">
      <div class="bottom-image">
        {% if section.settings.bottom_image_link %}
          <a href="{{ section.settings.bottom_image_link }}">
        {% endif %}
        {{ section.settings.bottom_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.bottom_image_alt }}
        {% if section.settings.bottom_image_link %}
          </a>
        {% endif %}
      </div>
      <div class="bottom-content">
        <h2>{{ section.settings.bottom_heading }}</h2>
        <p>{{ section.settings.bottom_description }}</p>
      </div>
    </div>
  {% endif %}
</section>

