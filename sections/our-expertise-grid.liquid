{% stylesheet %}
  @font-face {
    font-family: 'Futura Std';
    src: url('https://cdn.jsdelivr.net/npm/futura-std@1.0.0/futura-std.woff2') format('woff2'),
         url('https://cdn.jsdelivr.net/npm/futura-std@1.0.0/futura-std.woff') format('woff');
    font-weight: normal;
    font-style: normal;
  }

  * {
    font-family: 'Futura Std', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  }

  .craftsmanship-section {
    width: 100%;
    padding: {{ section.settings.section_padding_mobile }}px 20px;
    max-width: 1400px;
    margin: 0 auto;
    font-family: 'Futura Std', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  @media (min-width: 769px) {
    .craftsmanship-section {
      padding: {{ section.settings.section_padding_desktop }}px 20px;
    }
  }

  /* Header with Text */
  .header-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.grid_gap_desktop }}px;
    align-items: flex-start;
    margin-bottom: 40px;
  }

  @media (max-width: 768px) {
    .header-wrapper {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-bottom: 30px;
    }
  }

  .header-content h1 {
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    font-weight: 600;
    margin-bottom: 15px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: {{ section.settings.heading_color }};
  }

  @media (max-width: 768px) {
    .header-content h1 {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
  }

  .header-content p {
    font-size: {{ section.settings.description_font_size }}px;
    color: {{ section.settings.description_color }};
    line-height: 1.6;
  }

  .header-image {
    overflow: hidden;
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  .header-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Main Grid Layout */
  .grid-wrapper {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: {{ section.settings.grid_gap_desktop }}px;
    margin-bottom: 40px;
  }

  @media (max-width: 768px) {
    .grid-wrapper {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  /* Left Column - 2 images stacked */
  .left-column {
    display: grid;
    grid-template-rows: auto auto;
    gap: {{ section.settings.grid_gap_desktop }}px;
  }

  @media (max-width: 768px) {
    .left-column {
      grid-template-rows: auto auto;
      gap: 16px;
    }
  }

  .grid-item {
    position: relative;
    overflow: hidden;
    background: #f5f5f5;
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  .grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Image 1 & 2 on left */
  .image-1 {
    aspect-ratio: 1 / 0.9;
  }

  .image-2 {
    aspect-ratio: 1 / 0.7;
  }

  /* Right Column - 2 images */
  .right-column {
    display: grid;
    grid-template-rows: auto auto;
    gap: {{ section.settings.grid_gap_desktop }}px;
  }

  @media (max-width: 768px) {
    .right-column {
      grid-template-rows: auto auto;
      gap: 16px;
    }
  }

  /* Image 3 & 4 on right */
  .image-3 {
    aspect-ratio: 1.2 / 0.8;
  }

  .image-4 {
    aspect-ratio: 1.2 / 0.8;
  }

  /* Content Overlay */
  .image-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.95);
    padding: {{ section.settings.image_content_padding }}px;
    backdrop-filter: blur(5px);
  }

  .image-content h3 {
    font-size: {{ section.settings.image_title_font_size }}px;
    font-weight: 600;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ section.settings.image_title_color }};
  }

  .image-content p {
    font-size: {{ section.settings.image_text_font_size }}px;
    color: {{ section.settings.image_text_color }};
    line-height: 1.5;
    margin: 0;
  }

  /* Bottom Section */
  .bottom-section {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: {{ section.settings.bottom_section_gap }}px;
    align-items: center;
    background: {{ section.settings.bottom_section_bg_color }};
    padding: {{ section.settings.bottom_section_padding }}px;
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  @media (max-width: 768px) {
    .bottom-section {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 30px 20px;
    }
  }

  .bottom-image {
    overflow: hidden;
    border-radius: {{ section.settings.image_border_radius }}px;
    order: 2;
  }

  @media (max-width: 768px) {
    .bottom-image {
      order: 1;
    }
  }

  .bottom-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .bottom-content {
    order: 1;
  }

  @media (max-width: 768px) {
    .bottom-content {
      order: 2;
    }
  }

  .bottom-content h2 {
    font-size: {{ section.settings.bottom_heading_font_size }}px;
    font-weight: 600;
    margin-bottom: 15px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ section.settings.bottom_heading_color }};
  }

  .bottom-content p {
    font-size: {{ section.settings.bottom_text_font_size }}px;
    color: {{ section.settings.bottom_text_color }};
    line-height: 1.8;
  }
{% endstylesheet %}

<section class="craftsmanship-section">
  <!-- Header Section with Image and Text -->
  <div class="header-wrapper">
    <div class="header-content">
      <h1>{{ section.settings.main_heading }}</h1>
      <p>{{ section.settings.main_description }}</p>
    </div>
    {% if section.settings.header_image %}
      <div class="header-image">
        {{ section.settings.header_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.header_image_alt }}
      </div>
    {% endif %}
  </div>

  <!-- Main Grid Section - 4 Images -->
  <div class="grid-wrapper">
    <!-- Left Column -->
    <div class="left-column">
      <!-- Image 1 -->
      {% if section.settings.image_1 %}
        <div class="grid-item image-1">
          {% if section.settings.image_1_link %}
            <a href="{{ section.settings.image_1_link }}">
          {% endif %}
          {{ section.settings.image_1 | image_url: width: 300 | image_tag: loading: 'lazy', alt: section.settings.image_1_alt }}
          {% if section.settings.image_1_link %}
            </a>
          {% endif %}
        </div>
      {% endif %}

      <!-- Image 2 -->
      {% if section.settings.image_2 %}
        <div class="grid-item image-2">
          {% if section.settings.image_2_link %}
            <a href="{{ section.settings.image_2_link }}">
          {% endif %}
          {{ section.settings.image_2 | image_url: width: 500 | image_tag: loading: 'lazy', alt: section.settings.image_2_alt }}
          {% if section.settings.image_2_link %}
            </a>
          {% endif %}
          {% if section.settings.image_2_show_content %}
            <div class="image-content">
              <h3>{{ section.settings.image_2_title }}</h3>
              <p>{{ section.settings.image_2_text }}</p>
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <!-- Right Column -->
    <div class="right-column">
      <!-- Image 3 -->
      {% if section.settings.image_3 %}
        <div class="grid-item image-3">
          {% if section.settings.image_3_link %}
            <a href="{{ section.settings.image_3_link }}">
          {% endif %}
          {{ section.settings.image_3 | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.image_3_alt }}
          {% if section.settings.image_3_link %}
            </a>
          {% endif %}
        </div>
      {% endif %}

      <!-- Image 4 -->
      {% if section.settings.image_4 %}
        <div class="grid-item image-4">
          {% if section.settings.image_4_link %}
            <a href="{{ section.settings.image_4_link }}">
          {% endif %}
          {{ section.settings.image_4 | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.image_4_alt }}
          {% if section.settings.image_4_link %}
            </a>
          {% endif %}
          {% if section.settings.image_4_show_content %}
            <div class="image-content">
              <h3>{{ section.settings.image_4_title }}</h3>
              <p>{{ section.settings.image_4_text }}</p>
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>

  <!-- Bottom Section -->
  {% if section.settings.bottom_image %}
    <div class="bottom-section">
      <div class="bottom-content">
        <h2>{{ section.settings.bottom_heading }}</h2>
        <p>{{ section.settings.bottom_description }}</p>
      </div>
      <div class="bottom-image">
        {% if section.settings.bottom_image_link %}
          <a href="{{ section.settings.bottom_image_link }}">
        {% endif %}
        {{ section.settings.bottom_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.bottom_image_alt }}
        {% if section.settings.bottom_image_link %}
          </a>
        {% endif %}
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
