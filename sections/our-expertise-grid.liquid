{% stylesheet %}
.page-our-expertise-template-page .craftsmanship-section{padding-top:40px;padding-bottom:40px}
.craftsmanship-section{width:100%;background-color:#fff}
.craftsmanship-container{margin:0 auto}
.craftsmanship-grid{display:grid;grid-template-columns:calc(30% - 10px) calc(70% - 10px);gap:20px;align-items:start}
.craftsmanship-left{display:flex;flex-direction:column;gap:20px;align-items:end;width:100%}
.image-top-left{overflow:hidden;border-radius:4px}
.image-top-left img{width:100%;height:100%;object-fit:cover;display:block}
.image-top-left-mobile{width:500px;height:500px;overflow:hidden;border-radius:4px;display:none}
.image-top-left-mobile img{width:100%;height:100%;object-fit:cover}
.image-bottom-left{width:260px;aspect-ratio:1/1;overflow:hidden;border-radius:4px;margin-left:0}
.image-bottom-left img{width:100%;height:100%;object-fit:cover}
.image-bottom-left-mobile{width:260px;aspect-ratio:1/1;overflow:hidden;border-radius:4px;margin-left:0;display:none}
.image-bottom-left-mobile img{width:100%;height:100%;object-fit:cover}
.craftsmanship-right{display:flex;flex-direction:column;gap:20px}
.content-block-1{width:50%}
.content-block-1 h3{font-size:24px;font-weight:500;letter-spacing:1.5px;margin:0 0 12px 0;text-transform:uppercase;color:#1a1a1a}
.content-block-1 p{font-size:14px;line-height:1.6;color:#666;margin:0}
.images-grid-right{display:grid;grid-template-columns:1fr;gap:20px}
.image-top-right{width:100%;height:425px;overflow:hidden;border-radius:4px}
.image-top-right img{width:100%;height:100%;object-fit:cover}
.image-top-right-mobile{width:100%;height:425px;overflow:hidden;border-radius:4px;display:none}
.image-top-right-mobile img{width:100%;height:100%;object-fit:cover}
.image-bottom-right{width:100%;height:550px;overflow:hidden;border-radius:4px}
.image-bottom-right img{width:100%;height:100%;object-fit:cover}
.image-bottom-right-mobile{width:424px;height:550px;overflow:hidden;border-radius:4px;display:none}
.image-bottom-right-mobile img{width:100%;height:100%;object-fit:cover}
.content-block-2{width:100%}
.content-block-2 h3{font-size:24px;font-weight:500;letter-spacing:1.5px;margin:0 0 12px 0;text-transform:uppercase;color:#1a1a1a}
.content-block-2 p{font-size:14px;line-height:1.6;color:#666;margin:0}
.image-bottom-full{aspect-ratio:5/3;overflow:hidden;border-radius:4px}
.image-bottom-full img{width:100%;height:100%;object-fit:cover}
.image-bottom-full-mobile{aspect-ratio:5/3;overflow:hidden;border-radius:4px;display:none}
.image-bottom-full-mobile img{width:100%;height:100%;object-fit:cover}
.content-block-3{padding:0}
.content-block-3 h3{font-size:16px;font-weight:500;letter-spacing:1.5px;margin:0 0 12px 0;text-transform:uppercase;color:#000}
.content-block-3 p{font-size:13px;line-height:1.6;color:#666;margin:0}
@media (max-width:768px){
.content-block-1{width:100%}
.page-our-expertise-template-page .craftsmanship-section{padding-top:25px;padding-bottom:25px}
.craftsmanship-section{padding:40px 0}
.craftsmanship-grid{grid-template-columns:1fr;gap:30px}
.image-bottom-left{width:60%;display:none}
.image-bottom-left-mobile{display:block}
.image-top-left{display:none}
.image-top-left-mobile{display:block}
.image-top-right{display:none}
.image-top-right-mobile{display:block}
.image-bottom-right{display:none}
.image-bottom-right-mobile{display:block}
.image-bottom-full{display:none}
.image-bottom-full-mobile{display:block}
.images-grid-right{grid-template-columns:1fr}
}
.bottom-grid-expertise{display:flex;flex-direction:row-reverse;gap:20px}
@media (max-width:768px){
.craftsmanship-section{padding:40px 20px}
.craftsmanship-grid{grid-template-columns:1fr;gap:30px}
.craftsmanship-left{width:100%;align-items:center}
.image-top-left,.image-top-left-mobile{width:100%;max-width:400px;height:400px}
.image-bottom-left,.image-bottom-left-mobile{width:100%;align-self:flex-start;margin-left:0}
.right-content-wrapper{grid-template-columns:1fr;gap:30px}
.images-grid-right{width:100%}
.image-top-right,.image-top-right-mobile{width:100%;height:300px}
.bottom-grid-expertise{flex-direction:column-reverse;gap:30px;margin-top:30px}
.image-bottom-right,.image-bottom-right-mobile{width:100%;height:530px}
.content-block-2{width:100%;padding-top:0}
.content-block-1,.content-block-2,.content-block-3{padding:0 0 20px 0}
.content-block-1{padding-top:0}
.craftsmanship-right{gap:20px}
.content-block-1 h3,.content-block-2 h3{font-size:18px}
}
@media (min-width:340px) and (max-width:380px){
.page-our-expertise-template-page .craftsmanship-section{padding-top:25px;padding-bottom:25px}
.craftsmanship-section{padding:25px 20px!important}
.craftsmanship-grid{grid-template-columns:1fr;gap:30px}
.craftsmanship-left{width:100%;align-items:flex-start}
.image-top-left,.image-top-left-mobile{width:100%;max-width:100%;height:315px}
.image-bottom-left,.image-bottom-left-mobile{max-width:100%;align-self:flex-start;margin-left:0}
.right-content-wrapper{grid-template-columns:1fr;gap:30px}
.images-grid-right{width:100%}
.image-top-right,.image-top-right-mobile{width:100%;height:190px}
.bottom-grid-expertise{flex-direction:column-reverse;gap:30px;margin-top:30px}
.image-bottom-right,.image-bottom-right-mobile{width:100%;height:500px}
.content-block-1,.content-block-2{width:100%;padding:0 0 20px 0}
.content-block-1{padding-top:0}
.content-block-2{padding-top:0}
.craftsmanship-right{gap:20px}
}
{% endstylesheet %}

<div class="page-width craftsmanship-section">
  <div class="craftsmanship-container">
    <!-- TOP SECTION - 2 COLUMNS -->
    <div class="craftsmanship-grid">
      <!-- LEFT COLUMN - LARGE IMAGE + SMALL SQUARE IMAGE -->
      <div class="craftsmanship-left">
        <!-- Top Left Image: Desktop -->
        <div class="image-top-left">
          {% if section.settings.image_1 != blank %}
            <img
              src="{{ section.settings.image_1 | img_url: '400x533' }}"
              alt="Craftsmanship"
              loading="lazy"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>

        <!-- Top Left Image: Mobile -->
        <div class="image-top-left-mobile">
          {% if section.settings.image_1_mobile != blank %}
            <img
              src="{{ section.settings.image_1_mobile | img_url: '400x533' }}"
              alt="Craftsmanship"
              loading="lazy"
            >
          {% elsif section.settings.image_1 != blank %}
            <img
              src="{{ section.settings.image_1 | img_url: '400x533' }}"
              alt="Craftsmanship"
              loading="lazy"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>

        <!-- Bottom Left Image: Desktop -->
        <div class="image-bottom-left">
          {% if section.settings.image_2 != blank %}
            <img
              src="{{ section.settings.image_2 | img_url: '300x300' }}"
              alt="Craftsmanship Detail"
              loading="lazy"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>

        <!-- Bottom Left Image: Mobile -->
        <div class="image-bottom-left-mobile">
          {% if section.settings.image_2_mobile != blank %}
            <img
              src="{{ section.settings.image_2_mobile | img_url: '300x300' }}"
              alt="Craftsmanship Detail"
              loading="lazy"
            >
          {% elsif section.settings.image_2 != blank %}
            <img
              src="{{ section.settings.image_2 | img_url: '300x300' }}"
              alt="Craftsmanship Detail"
              loading="lazy"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      </div>

      <!-- RIGHT COLUMN - CONTENT + IMAGES -->
      <div class="craftsmanship-right">
        <!-- Content Block 1 -->
        <div class="content-block-1">
          <h3>{{ section.settings.heading_1 }}</h3>
          <p>{{ section.settings.content_1 }}</p>
        </div>
        <!-- Wrapper for images and content block 2 in row -->
        <div class="right-content-wrapper">
          <!-- Images Grid: Two 1:1 Images -->
          <div class="images-grid-right">
            <!-- Top Right Image: Desktop -->
            <div class="image-top-right">
              {% if section.settings.image_3 != blank %}
                <img
                  src="{{ section.settings.image_3 | img_url: '300x300' }}"
                  alt="Bespoke Creations"
                  loading="lazy"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>

            <!-- Top Right Image: Mobile -->
            <div class="image-top-right-mobile">
              {% if section.settings.image_3_mobile != blank %}
                <img
                  src="{{ section.settings.image_3_mobile | img_url: '300x300' }}"
                  alt="Bespoke Creations"
                  loading="lazy"
                >
              {% elsif section.settings.image_3 != blank %}
                <img
                  src="{{ section.settings.image_3 | img_url: '300x300' }}"
                  alt="Bespoke Creations"
                  loading="lazy"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>

            <div class="bottom-grid-expertise">
              <!-- Bottom Right Image: Desktop -->
              <div class="image-bottom-right">
                {% if section.settings.image_4 != blank %}
                  <img
                    src="{{ section.settings.image_4 | img_url: '300x300' }}"
                    alt="Bespoke Creations Detail"
                    loading="lazy"
                  >
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>

              <!-- Bottom Right Image: Mobile -->
              <div class="image-bottom-right-mobile">
                {% if section.settings.image_4_mobile != blank %}
                  <img
                    src="{{ section.settings.image_4_mobile | img_url: '300x300' }}"
                    alt="Bespoke Creations Detail"
                    loading="lazy"
                  >
                {% elsif section.settings.image_4 != blank %}
                  <img
                    src="{{ section.settings.image_4 | img_url: '300x300' }}"
                    alt="Bespoke Creations Detail"
                    loading="lazy"
                  >
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>

              <!-- Content Block 2 -->
              <div class="content-block-2">
                <h3>{{ section.settings.heading_2 }}</h3>
                <p>{{ section.settings.content_2 }}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    </div>
  </div>


{% schema %}
{
  "name": "Craftsmanship Section",
  "settings": [
    {
      "type": "header",
      "content": "Top Left Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Top Left Image - Desktop (3:4 Portrait)"
    },
    {
      "type": "image_picker",
      "id": "image_1_mobile",
      "label": "Top Left Image - Mobile (3:4 Portrait)",
      "info": "Optional. If not provided, desktop image will be used as fallback"
    },
    {
      "type": "header",
      "content": "Bottom Left Images"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Bottom Left Image - Desktop (1:1 Square)"
    },
    {
      "type": "image_picker",
      "id": "image_2_mobile",
      "label": "Bottom Left Image - Mobile (1:1 Square)",
      "info": "Optional. If not provided, desktop image will be used as fallback"
    },
    {
      "type": "header",
      "content": "First Content Block"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "First Heading",
      "default": "OUR CRAFTSMANSHIP"
    },
    {
      "type": "textarea",
      "id": "content_1",
      "label": "First Content Block",
      "default": "Every home piece is shaped by skilled artisans who understand you're more at the microscopic level. From ideal villas to historic settings, we're dedicated to delivering outstanding beauty."
    },
    {
      "type": "header",
      "content": "Top Right Images"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Top Right Image - Desktop (1:1 Square)"
    },
    {
      "type": "image_picker",
      "id": "image_3_mobile",
      "label": "Top Right Image - Mobile (1:1 Square)",
      "info": "Optional. If not provided, desktop image will be used as fallback"
    },
    {
      "type": "header",
      "content": "Bottom Right Images"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Bottom Right Image - Desktop (1:1 Square)"
    },
    {
      "type": "image_picker",
      "id": "image_4_mobile",
      "label": "Bottom Right Image - Mobile (1:1 Square)",
      "info": "Optional. If not provided, desktop image will be used as fallback"
    },
    {
      "type": "header",
      "content": "Second Content Block"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Second Heading",
      "default": "BESPOKE CREATIONS"
    },
    {
      "type": "textarea",
      "id": "content_2",
      "label": "Second Content Block",
      "default": "From stone selection to final design, our bespoke process brings timeless visions to life. Each custom piece is thoughtfully designed, engineered, and handcrafted to reflect individual taste and vision."
    },
    {
      "type": "header",
      "content": "Bottom Full Images"
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Bottom Full Image - Desktop (5:3 Aspect Ratio)"
    },
    {
      "type": "image_picker",
      "id": "image_5_mobile",
      "label": "Bottom Full Image - Mobile (5:3 Aspect Ratio)",
      "info": "Optional. If not provided, desktop image will be used as fallback"
    },
    {
      "type": "header",
      "content": "Third Content Block"
    },
    {
      "type": "text",
      "id": "heading_3",
      "label": "Third Heading",
      "default": "EXPERT CONSULTATION"
    },
    {
      "type": "textarea",
      "id": "content_3",
      "label": "Third Content Block",
      "default": "Our world-expert guide you through every detail. We cast expectations built by transparency, education and genuine expertise."
    }
  ],
  "presets": [
    {
      "name": "Craftsmanship Section"
    }
  ]
}
{% endschema %}