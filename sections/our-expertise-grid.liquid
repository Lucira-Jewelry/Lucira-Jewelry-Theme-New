{% stylesheet %}
  .craftsmanship-section {
    width: 100%;
    padding: 60px 40px;
    background-color: #f5f5f5;
  }

  .craftsmanship-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .craftsmanship-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    grid-template-areas: 
      "left right"
      "bottom bottom";
  }

  /* Left Column - Two Images Stacked */
  .craftsmanship-left {
    grid-area: left;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .image-top-left {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: 8px;
  }

  .image-top-left img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-bottom-left {
    width: 100%;
    aspect-ratio: 1/1;
    overflow: hidden;
    border-radius: 8px;
    border: 4px solid #0066ff;
  }

  .image-bottom-left img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Right Column - Content & Images */
  .craftsmanship-right {
    grid-area: right;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .content-block-1 {
    padding-bottom: 20px;
    border-bottom: 1px solid #ddd;
  }

  .content-block-1 h3 {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 2px;
    margin: 0 0 15px 0;
    text-transform: uppercase;
    color: #000;
  }

  .content-block-1 p {
    font-size: 14px;
    line-height: 1.6;
    color: #555;
    margin: 0;
  }

  .images-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .image-top-right {
    aspect-ratio: 1/1;
    overflow: hidden;
    border-radius: 8px;
  }

  .image-top-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-bottom-right {
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: 8px;
  }

  .image-bottom-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .content-block-2 {
    padding-top: 20px;
  }

  .content-block-2 h3 {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 2px;
    margin: 0 0 15px 0;
    text-transform: uppercase;
    color: #000;
  }

  .content-block-2 p {
    font-size: 14px;
    line-height: 1.6;
    color: #555;
    margin: 0;
  }

  /* Bottom Section - Full Width */
  .craftsmanship-bottom {
    grid-area: bottom;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    padding-top: 40px;
    border-top: 1px solid #ddd;
  }

  .image-bottom-full {
    aspect-ratio: 3/2;
    overflow: hidden;
    border-radius: 8px;
  }

  .image-bottom-full img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .content-block-3 {
    padding: 20px;
  }

  .content-block-3 h3 {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 2px;
    margin: 0 0 15px 0;
    text-transform: uppercase;
    color: #000;
  }

  .content-block-3 p {
    font-size: 14px;
    line-height: 1.6;
    color: #555;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .craftsmanship-section {
      padding: 40px 20px;
    }

    .craftsmanship-grid {
      grid-template-columns: 1fr;
      grid-template-areas: 
        "left"
        "right"
        "bottom";
    }

    .craftsmanship-bottom {
      grid-template-columns: 1fr;
    }

    .images-container {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

<div class="craftsmanship-section">
  <div class="craftsmanship-container">
    <div class="craftsmanship-grid">
      <!-- LEFT COLUMN -->
      <div class="craftsmanship-left">
        <!-- Top Left Image: 4:3 Aspect Ratio -->
        <div class="image-top-left">
          {% if section.settings.image_1 != blank %}
            <img 
              src="{{ section.settings.image_1 | img_url: '600x450' }}" 
              alt="Craftsmanship"
              loading="lazy"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>

        <!-- Bottom Left Image: 1:1 Aspect Ratio (with blue border) -->
        <div class="image-bottom-left">
          {% if section.settings.image_2 != blank %}
            <img 
              src="{{ section.settings.image_2 | img_url: '400x400' }}" 
              alt="Craftsmanship Detail"
              loading="lazy"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      </div>

      <!-- RIGHT COLUMN -->
      <div class="craftsmanship-right">
        <!-- Content Block 1 -->
        <div class="content-block-1">
          <h3>{{ section.settings.heading_1 }}</h3>
          <p>{{ section.settings.content_1 }}</p>
        </div>

        <!-- Images Container: 1:1 and 4:3 -->
        <div class="images-container">
          <div class="image-top-right">
            {% if section.settings.image_3 != blank %}
              <img 
                src="{{ section.settings.image_3 | img_url: '400x400' }}" 
                alt="Bespoke Creations"
                loading="lazy"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>

          <div class="image-bottom-right">
            {% if section.settings.image_4 != blank %}
              <img 
                src="{{ section.settings.image_4 | img_url: '400x300' }}" 
                alt="Bespoke Creations Detail"
                loading="lazy"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
        </div>

        <!-- Content Block 2 -->
        <div class="content-block-2">
          <h3>{{ section.settings.heading_2 }}</h3>
          <p>{{ section.settings.content_2 }}</p>
        </div>
      </div>
    </div>

    <!-- BOTTOM SECTION - FULL WIDTH -->
    <div class="craftsmanship-bottom">
      <!-- Image: 3:2 Aspect Ratio -->
      <div class="image-bottom-full">
        {% if section.settings.image_5 != blank %}
          <img 
            src="{{ section.settings.image_5 | img_url: '600x400' }}" 
            alt="Expert Consultation"
            loading="lazy"
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      <!-- Content Block 3 -->
      <div class="content-block-3">
        <h3>{{ section.settings.heading_3 }}</h3>
        <p>{{ section.settings.content_3 }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Craftsmanship Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Top Left Image (4:3 Aspect Ratio)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Bottom Left Image (1:1 Aspect Ratio - Square with Blue Border)"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "First Heading",
      "default": "OUR CRAFTSMANSHIP"
    },
    {
      "type": "textarea",
      "id": "content_1",
      "label": "First Content Block",
      "default": "Every home piece is shaped by skilled artisans who understand you're more at the microscopic level. From ideal villas to historic settings, we're dedicated to delivering outstanding beauty."
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Top Right Image (1:1 Aspect Ratio - Square)"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Bottom Right Image (4:3 Aspect Ratio)"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Second Heading",
      "default": "BESPOKE CREATIONS"
    },
    {
      "type": "textarea",
      "id": "content_2",
      "label": "Second Content Block",
      "default": "From stone selection to final design, our bespoke process brings timeless visions to life. Each custom piece is thoughtfully designed, engineered, and handcrafted to reflect individual taste and vision."
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Bottom Full Image (3:2 Aspect Ratio)"
    },
    {
      "type": "text",
      "id": "heading_3",
      "label": "Third Heading",
      "default": "EXPERT CONSULTATION"
    },
    {
      "type": "textarea",
      "id": "content_3",
      "label": "Third Content Block",
      "default": "Our world-expert guide you through every detail. We cast expectations built by transparency, education and genuine expertise."
    }
  ],
  "presets": [
    {
      "name": "Craftsmanship Section"
    }
  ]
}
{% endschema %}