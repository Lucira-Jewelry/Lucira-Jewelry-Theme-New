{% schema %}
{
  "name": "How to Wear",
  "tag": "section",
  "class": "how-to-wear-wrapper",
  "settings": [],
  "blocks": [],
  "presets": [
    {
      "name": "How to Wear Section"
    }
  ]
}
{% endschema %}

{% style %}
  <style>
    .how-to-wear-wrapper {
      font-family: 'Futura Std', 'Futura', sans-serif;
      background-color: #f9f9f9;
    }

      .how-to-wear-wrapper {
    
      padding: 40px 16px;
      margin: 0 80px;

    }

    .how-to-wear-wrapper h1.page-title {
      text-align: center;
      font-weight: 500;
      font-size: 24px;
      margin-bottom: 32px;
      line-height: 150%;
    }

    .how-to-wear-wrapper .section {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      flex-wrap: wrap;
      /* gap: 20px; */
      margin-bottom: 40px;
    }

    .how-to-wear-wrapper .section-content {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 170px;
      width: 100%;
      align-items: center;
    }

    .how-to-wear-wrapper .section img {
      width: 300px;
      max-width: 100%;
      height: 270px;
      border-radius: 10px;
      object-fit: cover;
      flex-shrink: 0;
    }

    .how-to-wear-wrapper .text-content {
      flex: 1;
      min-width: 250px;
    }

    .how-to-wear-wrapper .section h2 {
      font-size: 20px;
      font-weight: 500;
      margin: 0 0 12px;
      line-height: 150%;
    }

    .how-to-wear-wrapper .text-content p {
      font-weight: 300;
      font-size: 16px;
      line-height: 150%;
      text-align: justify;
      margin: 0 0 12px;
      word-break: break-word;
    }

    .how-to-wear-wrapper .no-image .section-content {
      flex-direction: column;
    }

    .how-to-wear-wrapper .no-image h2 {
      margin-bottom: 12px;
    }

    @media (max-width: 768px) {
      .how-to-wear-wrapper {
        padding: 24px 0px;
        margin: 16px;
      }

      .how-to-wear-wrapper h1.page-title {
        font-size: 20px;
      }

      .how-to-wear-wrapper .section {
        flex-direction: column;
        gap: 16px;
      }

      .how-to-wear-wrapper .section-content {
        flex-direction: column;
        gap: 12px;
      }

      .how-to-wear-wrapper .section img {
        width: 100%;
        height: auto;
      }

      .how-to-wear-wrapper .section h2 {
        font-size: 18px;
      }

      .how-to-wear-wrapper .text-content {
        width: 100%;
      }

      .how-to-wear-wrapper .text-content p {
        font-size: 14px;
      }
    }
  </style>
{% endstyle %}

<section class="how-to-wear-wrapper">
  <h1 class="page-title">HOW TO WEAR</h1>

  <!-- Section without image -->
  <div class="no-image">
    <div class="section">
      <div class="section-content">
        <div class="text-content">
          <h2>Bracelet Styling Guide</h2>
          <p>Bracelets are versatile pieces of jewelry that elevate your elegance. It's a statement of personality. May it be a party you are hosting, a regular office day, or an international trip, a bracelet is a must-have.</p>
        </div>
      </div>
    </div>
  </div>

