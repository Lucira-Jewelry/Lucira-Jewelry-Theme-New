<div id="login-popup" class="login-pop-overlay" onclick="closeloginPopup('login-popup')">
  <div class="otp-login-form-wrapper">
    <button class="close-button" onclick="closeloginPopup('login-popup')">
      {{- 'icon-login-close.svg' | inline_asset_content -}}
    </button>
    <form id="otp-login-form" class="otp-form-wrapper">
      <h2>WELCOME TO LUCIRA</h2>
      <p>Welcome To The Jewelry World Of Lucira! Find Exclusive Designs At Unbelievable Prices.</p>
      <div class="otp-number-wrapper">
        <label>Phone Number</label>
        <div class="mobile-wrap">
          <span class="country-code">+91</span>
          <input
            type="tel"
            id="loginMobile"
            placeholder="Enter Phone Number"
            maxlength="10"
            required
          >
        </div>
      </div>
      <button type="button" id="sendOtp" class="btn-primary">REQUEST OTP</button>

      <div id="otpSection" style="display:none">
        <label>Enter OTP</label>

        <div class="otp-inputs">
          <input maxlength="1" inputmode="numeric">
          <input maxlength="1" inputmode="numeric">
          <input maxlength="1" inputmode="numeric">
          <input maxlength="1" inputmode="numeric">
        </div>

        <button type="button" id="verifyOtp" class="btn-primary">VERIFY OTP</button>

        <p id="otp-timer">Resend OTP in 02:00</p>
      </div>

      <div class="signupSection" style="display:none">
        {%- form 'create_customer', novalidate: 'novalidate' -%}
          <label>First Name</label>
          <input
            type="text"
            name="customer[first_name]"
            placeholder="First Name"
            class="field-input"
            required
          >
          <label>Last Name</label>
          <input
            type="text"
            name="customer[last_name]"
            placeholder="Last Name"
            class="field-input"
            required
          >
          <label>Email Address</label>
          <input
            type="email"
            name="customer[email]"
            placeholder="Email"
            class="field-input"
            required
          >
          <label>Phone Number</label>
          <div class="mobile-wrap">
            <span class="country-code">+91</span>
            <input
              type="tel"
              name="customer[phone]"
              id="signupMobile"
              placeholder="Enter Phone Number"
              maxlength="10"
              required
            >
          </div>
          
          <!-- Hidden field to store spin wheel result -->
          <input type="hidden" name="customer[note][spin_result]" id="spinResultField" value="">
          
          <button class="btn-primary">CREATE ACCOUNT</button>
          <p class="switch-link">
            Already a member?
            <a href="javascript:void(0)" onclick="switchToLogin()">LOGIN</a>
          </p>
        {%- endform -%}
      </div>

      <!-- Spin Wheel Section -->
      <div class="spinWheelSection" style="display:none">
        <h2>SPIN TO WIN!</h2>
        <p>Spin the wheel to get your exclusive discount!</p>
        
        <div class="wheel-container">
          <canvas id="wheelCanvas" width="300" height="300"></canvas>
          <button class="spin-button" id="spinButton">SPIN</button>
        </div>
        
        <div id="spinResultDisplay" style="display:none; text-align:center; margin-top:20px;">
          <h3 id="resultText"></h3>
          <button class="btn-primary" id="claimReward">CLAIM REWARD & LOGIN</button>
        </div>
      </div>
    </form>
  </div>
</div>

<form id="shopify-auto-login-form" action="/account/login" method="post" style="display:none;">
  <input type="hidden" name="form_type" value="customer_login">
  <input type="hidden" name="utf8" value="✓">
  <input type="email" name="customer[email]" id="ShopifyEmail">
  <input type="password" name="customer[password]" id="ShopifyPassword">
</form>

<script>
  // Spin Wheel Configuration - YOU CAN EDIT THESE PERCENTAGES
  const wheelSegments = [
    { text: '10% OFF', percent: 30, color: '#FF6B6B' },
    { text: '5% OFF', percent: 25, color: '#4ECDC4' },
    { text: '15% OFF', percent: 15, color: '#FFD93D' },
    { text: 'FREE SHIPPING', percent: 20, color: '#95E1D3' },
    { text: '20% OFF', percent: 5, color: '#F38181' },
    { text: 'TRY AGAIN', percent: 5, color: '#AA96DA' }
  ];

  let spinWheelData = {
    email: '',
    password: '',
    result: ''
  };

  function openloginPopup(id) {
    document.getElementById(id).style.display = 'flex';
  }

  function closeloginPopup(e, id) {
    if (typeof id === 'undefined') id = e;
    document.getElementById(id).style.display = 'none';
  }

  document.querySelectorAll('.otp-login-form-wrapper').forEach((el) => {
    el.addEventListener('click', (e) => e.stopPropagation());
  });

  function switchToLogin() {
    document.querySelector('.signupSection').style.display = 'none';
    document.querySelector('.otp-number-wrapper').style.display = 'block';
    document.getElementById('sendOtp').style.display = 'block';
  }

  const sendBtn = document.getElementById('sendOtp');
  if (sendBtn) {
    sendBtn.addEventListener('click', async () => {
      const mobile = document.getElementById('loginMobile').value.replace(/\s+/g, '').trim();
      if (mobile.length < 10) return alert("Enter valid mobile number");

      const res = await fetch('https://login-otp-385594025448.asia-south1.run.app', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mobile })
      });

      const data = await res.json();
      if (data.type === 'success') {
        document.querySelector('.otp-number-wrapper').style.display = 'none';
        document.getElementById('sendOtp').style.display = 'none';
        document.getElementById('otpSection').style.display = 'block';
        startTimer(); // Starts the 30s timer
        alert('OTP Sent');
      } else {
        alert(data.message || 'Failed to send OTP');
      }
    });
  }

  const verifyBtn = document.getElementById('verifyOtp');
  if (verifyBtn) {
    verifyBtn.addEventListener('click', async () => {
      const otp = [...document.querySelectorAll('.otp-inputs input')].map(i => i.value).join('');
      const mobile = document.getElementById('loginMobile').value.replace(/\s+/g, '').trim();

      if (otp.length !== 4) return alert('Enter valid 4-digit OTP');

      verifyBtn.textContent = 'Verifying...';
      verifyBtn.disabled = true;

      try {
        const res = await fetch('https://otp-verification-385594025448.asia-south1.run.app', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ otp, mobile, action: 'verify_otp' })
        });

        const data = await res.json();

        if (data.type === 'success' && data.credentials) {
          shopifyAutoLogin(data.credentials.email, data.credentials.password);
        } 
        else if (data.type === 'register') {
          document.getElementById('otpSection').style.display = 'none';
          document.querySelector('.signupSection').style.display = 'block';
          document.getElementById('signupMobile').value = mobile;
          document.getElementById('signupMobile').readOnly = true;
        } 
        else {
          alert(data.msg || 'Invalid OTP');
          verifyBtn.textContent = 'VERIFY OTP';
          verifyBtn.disabled = false;
        }
      } catch (error) {
        alert('Error during verification.');
        verifyBtn.disabled = false;
      }
    });
  }

  const registrationForm = document.querySelector('.signupSection form');
  if (registrationForm) {
    registrationForm.addEventListener('submit', async (e) => {
      e.preventDefault(); // Stop standard Shopify submission

      const submitBtn = registrationForm.querySelector('button');
      const originalBtnText = submitBtn.innerText;
      submitBtn.innerText = "Creating Account...";
      submitBtn.disabled = true;

      const formData = {
        action: 'register_customer',
        first_name: registrationForm.querySelector('[name="customer[first_name]"]').value,
        last_name: registrationForm.querySelector('[name="customer[last_name]"]').value,
        email: registrationForm.querySelector('[name="customer[email]"]').value,
        mobile: document.getElementById('signupMobile').value
      };

      try {
        const res = await fetch('https://otp-verification-385594025448.asia-south1.run.app', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        });
        const data = await res.json();

        if (data.type === 'success' && data.credentials) {
          // Store credentials for later login after spin
          spinWheelData.email = data.credentials.email;
          spinWheelData.password = data.credentials.password;
          
          // Show spin wheel instead of auto login
          document.querySelector('.signupSection').style.display = 'none';
          document.querySelector('.spinWheelSection').style.display = 'block';
          
          // Initialize and draw the wheel
          initializeWheel();
        } else {
          alert(data.msg || "Registration failed. Email/Phone might be taken.");
          submitBtn.innerText = originalBtnText;
          submitBtn.disabled = false;
        }
      } catch (err) {
        alert("Registration error. Please try again.");
        submitBtn.disabled = false;
      }
    });
  }

  // Spin Wheel Functionality
  let currentRotation = 0;
  let isSpinning = false;

  function initializeWheel() {
    drawWheel();
  }

  function drawWheel() {
    const canvas = document.getElementById('wheelCanvas');
    const ctx = canvas.getContext('2d');
    const centerX = canvas.width / 2;
    const centerY = canvas.height / 2;
    const radius = 140;

    ctx.clearRect(0, 0, canvas.width, canvas.height);

    let startAngle = currentRotation;
    
    wheelSegments.forEach((segment, index) => {
      const sliceAngle = (segment.percent / 100) * 2 * Math.PI;
      const endAngle = startAngle + sliceAngle;

      // Draw segment
      ctx.beginPath();
      ctx.moveTo(centerX, centerY);
      ctx.arc(centerX, centerY, radius, startAngle, endAngle);
      ctx.closePath();
      ctx.fillStyle = segment.color;
      ctx.fill();
      ctx.strokeStyle = '#fff';
      ctx.lineWidth = 3;
      ctx.stroke();

      // Draw text
      ctx.save();
      ctx.translate(centerX, centerY);
      ctx.rotate(startAngle + sliceAngle / 2);
      ctx.textAlign = 'center';
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 14px Arial';
      ctx.fillText(segment.text, radius / 1.5, 5);
      ctx.restore();

      startAngle = endAngle;
    });

    // Draw center circle
    ctx.beginPath();
    ctx.arc(centerX, centerY, 20, 0, 2 * Math.PI);
    ctx.fillStyle = '#333';
    ctx.fill();
    ctx.strokeStyle = '#fff';
    ctx.lineWidth = 3;
    ctx.stroke();

    // Draw pointer at right side
    ctx.beginPath();
    ctx.moveTo(centerX + radius + 10, centerY);
    ctx.lineTo(centerX + radius - 10, centerY - 15);
    ctx.lineTo(centerX + radius - 10, centerY + 15);
    ctx.closePath();
    ctx.fillStyle = '#FF0000';
    ctx.fill();
    ctx.strokeStyle = '#fff';
    ctx.lineWidth = 2;
    ctx.stroke();
  }

  function getRandomSegment() {
    const rand = Math.random() * 100;
    let cumulative = 0;
    
    for (let segment of wheelSegments) {
      cumulative += segment.percent;
      if (rand <= cumulative) {
        return segment;
      }
    }
    return wheelSegments[0];
  }

  const spinButton = document.getElementById('spinButton');
  if (spinButton) {
    spinButton.addEventListener('click', () => {
      if (isSpinning) return;
      
      isSpinning = true;
      spinButton.disabled = true;
      spinButton.textContent = 'SPINNING...';

      const selectedSegment = getRandomSegment();
      
      // Calculate target rotation
      let targetIndex = wheelSegments.indexOf(selectedSegment);
      let segmentAngle = 0;
      for (let i = 0; i < targetIndex; i++) {
        segmentAngle += (wheelSegments[i].percent / 100) * 360;
      }
      
      // Add randomness within the segment
      const segmentSize = (selectedSegment.percent / 100) * 360;
      const randomOffset = Math.random() * segmentSize;
      
      // Calculate final rotation (multiple full spins + target)
      const spins = 5 + Math.random() * 3; // 5-8 full rotations
      const finalRotation = (spins * 360) + segmentAngle + randomOffset;
      
      animateWheel(finalRotation, selectedSegment);
    });
  }

  function animateWheel(targetRotation, selectedSegment) {
    const duration = 4000; // 4 seconds
    const startTime = Date.now();
    const startRotation = currentRotation;

    function animate() {
      const now = Date.now();
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);

      // Easing function for smooth deceleration
      const easeOut = 1 - Math.pow(1 - progress, 3);
      
      currentRotation = startRotation + (targetRotation * easeOut);
      
      // Convert to radians for drawing
      const rotationInRadians = (currentRotation * Math.PI) / 180;
      currentRotation = currentRotation % 360;
      
      drawWheel();

      if (progress < 1) {
        requestAnimationFrame(animate);
      } else {
        // Spin complete
        isSpinning = false;
        showResult(selectedSegment);
      }
    }

    animate();
  }

  function showResult(segment) {
    spinWheelData.result = segment.text;
    
    // Update hidden field
    document.getElementById('spinResultField').value = segment.text;
    
    // Show result
    document.getElementById('resultText').textContent = `Congratulations! You won ${segment.text}!`;
    document.getElementById('spinResultDisplay').style.display = 'block';
    document.getElementById('spinButton').style.display = 'none';
  }

  const claimRewardBtn = document.getElementById('claimReward');
  if (claimRewardBtn) {
    claimRewardBtn.addEventListener('click', () => {
      // Auto login with stored credentials
      shopifyAutoLogin(spinWheelData.email, spinWheelData.password);
    });
  }

  function shopifyAutoLogin(email, password) {
    document.getElementById("ShopifyEmail").value = email;
    document.getElementById("ShopifyPassword").value = password;
    document.getElementById("shopify-auto-login-form").submit();
  }

  let timerInterval;
  function startTimer() {
    let timer = 30;
    clearInterval(timerInterval);
    
    timerInterval = setInterval(() => {
      let sec = timer % 60;
      document.getElementById('otp-timer').innerText = `Resend OTP in 00:${sec < 10 ? '0' + sec : sec}`;
      
      if (timer <= 0) {
        clearInterval(timerInterval);
        document.getElementById('otp-timer').innerHTML = `<a href="javascript:void(0)" onclick="resendOtp()">Resend OTP</a>`;
      }
      timer--;
    }, 1000);
  }

  async function resendOtp() {
    const mobile = document.getElementById('loginMobile').value.trim();
    document.getElementById('otp-timer').innerText = "Sending...";

    const res = await fetch('https://login-otp-385594025448.asia-south1.run.app', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mobile })
    });
    
    startTimer();
  }

  const otpInputs = document.querySelectorAll('.otp-inputs input');
  otpInputs.forEach((input, index) => {
    input.addEventListener('input', e => {
      const value = e.target.value.replace(/\D/g, '');
      e.target.value = value;
      if (value && index < otpInputs.length - 1) otpInputs[index + 1].focus();
    });
    input.addEventListener('keydown', e => {
      if (e.key === 'Backspace' && !e.target.value && index > 0) otpInputs[index - 1].focus();
    });
  });
</script>

<style>
  .otp-login-form-wrapper {background-color: #FFFEFC; padding: 20px; border-radius: 12px; box-shadow: 0 0 10px #0000004d; max-width: 850px; width: 90%; text-align: left; position: relative;}
   .login-pop-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);display:none;justify-content:center;align-items:center;z-index:9999999}
  .otp-login-form-wrapper { width: 900px; display: flex; border-radius: 12px; overflow: hidden; align-items: center;}
  .otp-login-form-wrapper::before{content:"";width:60%;background:url(https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Lucira_model_day_1_32568_copy_2_1_1.jpg?v=1768388597) center/cover no-repeat; height: 460px; border-radius: 8px;}
  .otp-form-wrapper{width: 40%; padding: 0; margin-left: 20px;}
  .mobile-wrap { display: flex; align-items: center; border: 1px solid #e2e2e2; border-radius: 8px; padding: 10px 16px; background: #ffffff; }
  .country-code { font-weight: 400; font-size: 14px; line-height: 1.6; text-transform: capitalize; margin-right: 10px; padding-right: 12px; border-right: 1px solid #d0d0d0; }
  .mobile-wrap input{border:0;outline:0;width:100%}
  .otp-inputs{display:flex;gap:8px;margin:15px 0}
  .otp-inputs input{width:40px;height:40px;border:1px solid #ddd;border-radius:6px;text-align:center;font-size:16px}
  .otp-login-form-wrapper .btn-primary {width: 100%; background: rgb(183, 119, 102); color: #fff; padding: 16px; border: 0; margin-top: 20px; font-family: Futura Std; font-weight: 400; line-height: 100%; letter-spacing: inherit; text-align: center; text-transform: uppercase; font-size: 13px; border-radius: 8px; cursor: pointer;}
  .otp-login-form-wrapper .btn-primary:disabled {opacity: 0.6; cursor: not-allowed;}
  #otp-timer{text-align:center;margin-top:10px;font-size:13px}
  .login-image-wrapper img {width: 100%; height: auto;}
  .otp-login-form-wrapper h2 { font-weight: 500; font-size: 18px; line-height: 150%; text-transform: uppercase; text-align: center; margin: 0; margin-bottom: 14px; }
  .otp-login-form-wrapper p {font-weight: 500; font-size: 12px; line-height: 1.7; letter-spacing: 1px; text-align: center; text-transform: capitalize; color: #5B5B5B; margin: 0 0 0px; max-width: 280px; margin-left: auto; margin-right: auto; margin-top: 12px; margin-bottom: 28px;}
  .otp-form-wrapper label { font-family: Futura Std; font-weight: 400; font-size: 12px; line-height: 12px; letter-spacing: normal; margin-bottom: 10px; display: block; color: #666666; }
  .mobile-wrap input { border: 0; outline: 0; width: 100%; font-family: Futura Std; font-weight: 400; font-size: 14px; line-height: 150%; letter-spacing: normal; text-transform: capitalize; }
  .otp-login-form-wrapper button svg {display: block;}
  .otp-login-form-wrapper button.close-button { background: #fff; border-radius: 50%; padding: 4px; position: absolute; right: 20px; top: 20px; border: 0; cursor: pointer; }
  .otp-login-form-wrapper input.field-input {outline: 0; width: 100%; font-family: Futura Std; font-weight: 400; font-size: 14px; line-height: 150%; letter-spacing: normal; text-transform: capitalize; border: 1px solid #e2e2e2; border-radius: 8px; padding: 10px 16px; background: #ffffff; margin-bottom: 14px;}
  .switch-link a {color: #b77766; font-weight: 500; margin-bottom: 8px; cursor: pointer;}
  p.switch-link { margin-bottom: 0; }

  /* Spin Wheel Styles */
  .spinWheelSection { text-align: center; }
  .wheel-container { position: relative; display: inline-block; margin: 20px 0; }
  #wheelCanvas { display: block; }
  .spin-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: 4px solid #fff;
    font-weight: bold;
    font-size: 14px;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    transition: all 0.3s ease;
    z-index: 10;
  }
  .spin-button:hover:not(:disabled) {
    transform: translate(-50%, -50%) scale(1.1);
    box-shadow: 0 6px 20px rgba(0,0,0,0.4);
  }
  .spin-button:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
  #resultText {
    color: #b77766;
    font-size: 20px;
    margin-bottom: 20px;
  }

  @media only screen and (max-width:767px){
      .account-hover-card.active {display: block;}
      .account-wrapper .account-hover-card { position: fixed; top: 98px; left: 50%; right: inherit; transform: translateX(-50%); width: 320px; background: #fff; padding: 20px; border-radius: 14px; box-shadow: 0 10px 30px #00000026; z-index: 99; }
      .otp-form-wrapper { width: 100%; padding: 12px; }
      .otp-login-form-wrapper { width: 95%; background: #fff; display: flex; flex-direction: column; border-radius: 12px; overflow: hidden; }
      .otp-login-form-wrapper::before { content: ""; width: 100%; height: 175px; background: url(https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Lucira_model_day_1_32568_copy_2_1_1.jpg?v=1768388597) center / cover no-repeat; }
      .otp-form-wrapper {margin-left: 0;}
      #wheelCanvas { width: 250px; height: 250px; }
      .spin-button { width: 60px; height: 60px; font-size: 12px; }
  }
</style>