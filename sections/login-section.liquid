<script>
const spinPrizes = [
  { label: "₹1,500 OFF", value: "1500_off", chance: 15 },
  { label: "₹1,000 OFF", value: "1000_off", chance: 20 },
  { label: "₹750 OFF", value: "750_off", chance: 40 },
  { label: "Diamond Pendant", value: "diamond_pendant", chance: 2 },
  { label: "₹5,000 OFF", value: "5000_off", chance: 22 },
  { label: "₹10,000 OFF", value: "10000_off", chance: 1 }
];

const wheelSegments = [
  { label: "₹1,500 OFF", value: "1500_off" },        // Gold Coin
  { label: "₹1,000 OFF", value: "1000_off" },        // Gift
  { label: "₹750 OFF", value: "750_off" },            // Ring
  { label: "Diamond Pendant", value: "diamond_pendant" }, // Voucher
  { label: "₹5,000 OFF", value: "5000_off" },         // Pendant
  { label: "₹10,000 OFF", value: "10000_off" }        // Better Luck
];

function openloginPopup(id) {
  document.getElementById(id).style.display = 'flex';
}

function closeloginPopup(e, id) {
  if (typeof id === 'undefined') id = e;
  document.getElementById(id).style.display = 'none';
  resetToLoginView();
}

document.querySelectorAll('.otp-login-form-wrapper').forEach(el => {
  el.addEventListener('click', e => e.stopPropagation());
});

function showError(id, msg) {
  const el = document.getElementById(id);
  el.textContent = msg;
  el.style.display = 'block';
}

function hideError(id) {
  const el = document.getElementById(id);
  el.style.display = 'none';
}

function validateMobile(mobile) {
  if (!mobile) return 'Please enter phone number';
  if (!/^\d{10}$/.test(mobile)) return 'Enter valid 10 digit number';
  return null;
}

function validateEmail(email) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)
    ? null
    : 'Enter valid email';
}

function validateName(val, name) {
  if (!val) return `Enter ${name}`;
  if (val.length < 2) return `${name} too short`;
  return null;
}

document.getElementById('sendOtp')?.addEventListener('click', async () => {
  const mobile = loginMobile.value.trim();
  const err = validateMobile(mobile);
  if (err) return showError('mobileError', err);

  hideError('mobileError');

  const res = await fetch('https://login-otp-385594025448.asia-south1.run.app', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ mobile })
  });

  const data = await res.json();
  if (data.type === 'success') {
    document.querySelector('.otp-number-wrapper').style.display = 'none';
    sendOtp.style.display = 'none';
    otpSection.style.display = 'block';
    otpMobile.value = mobile;
    startTimer();
  }
});

document.getElementById('verifyOtp')?.addEventListener('click', async () => {
  const otp = [...document.querySelectorAll('.otp-inputs input')]
    .map(i => i.value).join('');

  if (otp.length !== 4) return showError('otpError', 'Invalid OTP');

  const mobile = otpMobile.value;

  const res = await fetch('https://otp-verification-385594025448.asia-south1.run.app', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ otp, mobile })
  });

  const data = await res.json();

  if (data.type === 'register') {
    signupMobile.value = mobile;
    showSignupWithSpinWheel();
    return;
  }

  if (data.type === 'success') {
    shopifyAutoLogin(data.credentials.email, data.credentials.password);
  }
});

function getWeightedPrize() {
  const total = spinPrizes.reduce((s, p) => s + p.chance, 0);
  let rand = Math.random() * total;

  for (let p of spinPrizes) {
    if (rand < p.chance) return p;
    rand -= p.chance;
  }
  return spinPrizes[0];
}

function getSegmentIndex(value) {
  return wheelSegments.findIndex(seg => seg.value === value);
}

document.getElementById('completeRegistration')?.addEventListener('click', async () => {
  const first = regFirstName.value.trim();
  const last = regLastName.value.trim();
  const email = regEmail.value.trim();

  if (validateName(first, 'First name')) return showError('firstNameError', validateName(first, 'First name'));
  if (validateName(last, 'Last name')) return showError('lastNameError', validateName(last, 'Last name'));
  if (validateEmail(email)) return showError('emailError', validateEmail(email));

  hideError('firstNameError');
  hideError('lastNameError');
  hideError('emailError');

  completeRegistration.textContent = 'Spinning...';
  completeRegistration.disabled = true;

  const prize = getWeightedPrize();
  const index = getSegmentIndex(prize.value);

  /* ---- FORCE WHEEL TO THAT SEGMENT ---- */
  const wheel = document.getElementById('spin-wheel-image');
  const slices = wheelSegments.length;
  const angle = 360 / slices;
  const offset = angle / 2;

  const rotation = 360 * 5 + index * angle + offset;

  wheel.style.transition = 'transform 4s cubic-bezier(0.17,0.67,0.12,0.99)';
  wheel.style.transform = `translate(-50%, -50%) rotate(-${rotation}deg)`;

  setTimeout(async () => {
    spinResult.value = prize.value;
    await processRegistration(first, last, email, prize);
  }, 4200);
});

async function processRegistration(first, last, email, prize) {
  const mobile = signupMobile.value;
  const otp = [...document.querySelectorAll('.otp-inputs input')]
    .map(i => i.value).join('');

  const res = await fetch('https://otp-verification-385594025448.asia-south1.run.app', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      mobile,
      otp,
      email,
      first_name: first,
      last_name: last,
      won_prize: prize.value,
      prize_label: prize.label
    })
  });

  const data = await res.json();

  if (data.type === 'success') {
    alert(`🎉 You won ${prize.label}`);
    shopifyAutoLogin(data.credentials.email, data.credentials.password);
  }
}

function shopifyAutoLogin(email, password) {
  loginReturnTo.value = location.pathname + location.search;
  ShopifyEmail.value = email;
  ShopifyPassword.value = password;
  document.getElementById('shopify-auto-login-form').submit();
}

function showSignupWithSpinWheel() {
  document.querySelector('.signupSection').style.display = 'block';
  document.querySelector('.otp-number-wrapper').style.display = 'none';
  document.getElementById('otpSection').style.display = 'none';
  document.querySelector('.otp-login-form-wrapper').classList.add('signup-active');
}

function resetToLoginView() {
  document.querySelector('.otp-login-form-wrapper').classList.remove('signup-active');
  document.querySelector('.signupSection').style.display = 'none';
  document.querySelector('.otp-number-wrapper').style.display = 'block';
  document.getElementById('otpSection').style.display = 'none';

  const wheel = document.getElementById('spin-wheel-image');
  wheel.style.transition = 'none';
  wheel.style.transform = 'translate(-50%, -50%) rotate(0deg)';
}

let timer = 30, interval;
function startTimer() {
  clearInterval(interval);
  interval = setInterval(() => {
    otpTimer.textContent = `Resend OTP in 00:${timer--}`;
    if (timer < 0) {
      clearInterval(interval);
      otpTimer.innerHTML = `<a onclick="resendOtp()">Resend OTP</a>`;
    }
  }, 1000);
}

async function resendOtp() {
  await fetch('https://login-otp-385594025448.asia-south1.run.app', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ mobile: otpMobile.value })
  });
  timer = 30;
  startTimer();
}
</script>

<style>
