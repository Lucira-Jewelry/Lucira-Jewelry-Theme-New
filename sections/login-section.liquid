<div id="login-popup" class="login-pop-overlay" onclick="closeloginPopup('login-popup')">
  <div class="otp-login-form-wrapper">
    <button class="close-button" onclick="closeloginPopup('login-popup')">
      {{ 'icon-login-close.svg' | inline_asset_content }}
    </button>

    <div class="spin-wheel-wrapper">
        <img 
            src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Spin_The_Wheel_Wheel_1.png?v=1769229974" 
            alt="Spin the Wheel"
            class="spin-wheel-image" id="spin-wheel-image" width="800" height="800" alt="Spin the Wheel"
        >
        <img 
            src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Spin_The_Wheel_Spinner_1.png?v=1769229971" 
            alt="Spin CTA"
            class="spin-wheel-cta" id="spin-wheel-cta" width="200" height="200" alt="Spin the Wheel Spinner"
        >
    </div>

    <form id="otp-login-form" class="otp-form-wrapper">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subtext }}</p>
      <div class="otp-number-wrapper">
        <label>{{ section.settings.phone_label }}</label>
        <div class="mobile-wrap">
          <span class="country-code">+91</span>
          <input
            type="tel"
            id="loginMobile"
            placeholder="{{ section.settings.phone_placeholder }}"
            maxlength="10"
            required
          >
        </div>
        <span class="error-message" id="mobileError"></span>
      </div>
      <button type="button" id="sendOtp" class="btn-primary">
        {{ section.settings.request_otp_text }}
      </button>
      <p class="register-link">
        New here? <a href="javascript:void(0)" id="registerNow">Register</a>
      </p>
      <div id="otpSection" style="display:none">
        <label>{{ section.settings.otp_label }}</label>
        <div class="mobile-wrap" style="margin-bottom:10px;">
          <span class="country-code">+91</span>
          <input
            type="tel"
            id="otpMobile"
            placeholder="{{ section.settings.phone_placeholder }}"
            maxlength="10"
            readonly
          >
          <button type="button" id="editMobile">
            ✎
          </button>
        </div>
        <div class="otp-inputs">
          <input maxlength="1">
          <input maxlength="1">
          <input maxlength="1">
          <input maxlength="1">
        </div>
        <span class="error-message" id="otpError"></span>
        <button type="button" id="verifyOtp" class="btn-primary">
          {{ section.settings.verify_otp_text }}
        </button>
        <p id="otp-timer">
          {{ section.settings.resend_text }}
        </p>
      </div>
      <div class="signupSection" style="display:none">
        <div class="registration-form-inputs">
          <label>First Name</label>
          <input
            type="text"
            id="regFirstName" 
            placeholder="First Name"
            class="field-input"
            required
          >
          <span class="error-message" id="firstNameError" style="display:none; color:red; font-size:12px; margin-top: 0; line-height: 1; margin-bottom: 16px;"></span>
          <label>Last Name</label>
          <input
            type="text"
            id="regLastName"
            placeholder="Last Name"
            class="field-input"
            required
          >
          <span class="error-message" id="lastNameError" style="display:none; color:red; font-size:12px; margin-top: 0; line-height: 1; margin-bottom: 16px;"></span>
          <label>Email Address</label>
          <input
            type="email"
            id="regEmail"
            placeholder="Email"
            class="field-input"
            required
          >
          <input type="hidden" id="spinResult" name="spin_result">
          <span class="error-message" id="emailError" style="display:none; color:red; font-size:12px; margin-top: 0; line-height: 1; margin-bottom: 16px;"></span>
          <label>Phone Number</label>
          <div class="mobile-wrap">
            <span class="country-code">+91</span>
            <input
              type="tel"
              id="signupMobile"
              placeholder="Enter Phone Number"
              readonly
            >
          </div>
          <button type="button" id="completeRegistration" class="btn-primary">CREATE ACCOUNT</button>
        </div>
      </div>
    </form>
    
  </div>
</div>
<form id="shopify-auto-login-form" action="/account/login" method="post" style="display:none;">
  <input type="hidden" name="form_type" value="customer_login">
  <input type="hidden" name="utf8" value="✓">
  <input type="hidden" name="return_to" id="loginReturnTo" value="">
  <input type="email" name="customer[email]" id="ShopifyEmail">
  <input type="password" name="customer[password]" id="ShopifyPassword">
</form>
<script>
/* ===============================
   POPUP CONTROLS
================================ */
function openloginPopup(id) {
  document.getElementById(id).style.display = 'flex';
}

function closeloginPopup(e, id) {
  if (typeof id === 'undefined') id = e;
  document.getElementById(id).style.display = 'none';
  resetToLoginView();
}

document.querySelectorAll('.otp-login-form-wrapper').forEach(el => {
  el.addEventListener('click', e => e.stopPropagation());
});

/* ===============================
   VALIDATION HELPERS
================================ */
function showError(id, msg) {
  const el = document.getElementById(id);
  el.textContent = msg;
  el.style.display = 'block';
}

function hideError(id) {
  const el = document.getElementById(id);
  el.style.display = 'none';
}

function validateMobile(m) {
  if (!m) return 'Please enter phone number';
  if (!/^\d{10}$/.test(m)) return 'Phone number must be 10 digits';
  return null;
}

function validateEmail(e) {
  if (!e) return 'Please enter email';
  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e)) return 'Invalid email';
  return null;
}

function validateName(v, f) {
  if (!v) return `Please enter ${f}`;
  if (v.length < 2) return `${f} must be at least 2 characters`;
  return null;
}

/* ===============================
   OTP SEND
================================ */
const sendBtn = document.getElementById('sendOtp');

sendBtn?.addEventListener('click', async () => {
  const mobile = document.getElementById('loginMobile').value.trim();
  const err = validateMobile(mobile);
  if (err) return showError('mobileError', err);

  hideError('mobileError');

  const res = await fetch(
    'https://login-otp-385594025448.asia-south1.run.app',
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mobile })
    }
  );

  const data = await res.json();

  if (data.type === 'success') {
    document.querySelector('.otp-number-wrapper').style.display = 'none';
    sendBtn.style.display = 'none';
    document.getElementById('otpSection').style.display = 'block';
    document.getElementById('otpMobile').value = mobile;
    document.querySelector('.register-link').style.display = 'block';
    startTimer();
  } else {
    showError('mobileError', data.message || 'OTP failed');
  }
});

/* ===============================
   OTP VERIFY
================================ */
const verifyBtn = document.getElementById('verifyOtp');

verifyBtn?.addEventListener('click', async () => {
  const otp = [...document.querySelectorAll('.otp-inputs input')]
    .map(i => i.value)
    .join('');

  const mobile = document.getElementById('otpMobile').value.trim();

  if (otp.length !== 4) return showError('otpError', 'Invalid OTP');
  hideError('otpError');

  const res = await fetch(
    'https://otp-verification-385594025448.asia-south1.run.app',
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ otp, mobile })
    }
  );

  const data = await res.json();

  if (data.type === 'success' && data.credentials) {
    shopifyAutoLogin(data.credentials.email, data.credentials.password);
    return;
  }

  if (data.type === 'register') {
    document.getElementById('signupMobile').value = mobile;
    showSignupWithSpinWheel();
  } else {
    showError('otpError', data.msg || 'OTP failed');
  }
});

/* ===============================
   SIGNUP VIEW
================================ */
function showSignupWithSpinWheel() {
  document.querySelector('.otp-number-wrapper')?.style.setProperty('display','none');
  document.getElementById('sendOtp')?.style.setProperty('display','none');
  document.getElementById('otpSection')?.style.setProperty('display','none');
  document.querySelector('.signupSection')?.style.setProperty('display','block');
  document.querySelector('.register-link')?.style.setProperty('display','none');
  document.querySelector('.otp-login-form-wrapper')?.classList.add('signup-active');
}

function resetToLoginView() {
  document.querySelector('.signupSection')?.style.setProperty('display','none');
  document.querySelector('.otp-number-wrapper')?.style.setProperty('display','block');
  document.getElementById('otpSection')?.style.setProperty('display','none');
  document.querySelector('.register-link')?.style.setProperty('display','none');
  document.getElementById('spinResult').value = '';
}

/* ===============================
   SPIN CONFIG (PERCENTAGE)
================================ */
const spinPrizes = [
  { label: "5% OFF", value: "5_percent", weight: 40 },
  { label: "10% OFF", value: "10_percent", weight: 25 },
  { label: "15% OFF", value: "15_percent", weight: 15 },
  { label: "Free Shipping", value: "free_shipping", weight: 10 },
  { label: "No Prize", value: "no_prize", weight: 10 }
];

function getWeightedPrize(prizes) {
  const total = prizes.reduce((s,p)=>s+p.weight,0);
  let rand = Math.random() * total;
  for (let p of prizes) {
    if (rand < p.weight) return p;
    rand -= p.weight;
  }
}

/* ===============================
   SPIN LOGIC (NO UI CHANGE)
================================ */
const wheel = document.getElementById('spin-wheel-image');
let isSpinning = false;

function spinWheelAndGetPrize(cb) {
  if (isSpinning) return;
  isSpinning = true;

  const prize = getWeightedPrize(spinPrizes);
  const index = spinPrizes.indexOf(prize);
  const slice = 360 / spinPrizes.length;
  const rotation = (360 * 6) + (slice * index) + (slice / 2);

  wheel.style.transition = 'transform 4s cubic-bezier(0.17,0.67,0.12,0.99)';
  wheel.style.transform = `rotate(${rotation}deg)`;

  setTimeout(() => {
    isSpinning = false;
    document.getElementById('spinResult').value = prize.value;
    cb(prize);
  }, 4200);
}

/* ===============================
   CREATE ACCOUNT (SPIN FIRST)
================================ */
const regBtn = document.getElementById('completeRegistration');

regBtn?.addEventListener('click', async () => {

  /* ---- SPIN FIRST ---- */
  if (!document.getElementById('spinResult').value) {
    regBtn.disabled = true;
    regBtn.textContent = 'Spinning...';

    spinWheelAndGetPrize(prize => {
      alert(`🎉 You won ${prize.label}`);
      regBtn.disabled = false;
      regBtn.textContent = 'CREATE ACCOUNT';
      regBtn.click();
    });

    return;
  }

  /* ---- VALIDATION ---- */
  const firstName = document.getElementById('regFirstName').value.trim();
  const lastName = document.getElementById('regLastName').value.trim();
  const email = document.getElementById('regEmail').value.trim();
  const mobile = document.getElementById('signupMobile').value.trim();
  const spinResult = document.getElementById('spinResult').value;

  const otp = [...document.querySelectorAll('.otp-inputs input')]
    .map(i => i.value)
    .join('');

  const fnErr = validateName(firstName, 'first name');
  if (fnErr) return showError('firstNameError', fnErr);

  const lnErr = validateName(lastName, 'last name');
  if (lnErr) return showError('lastNameError', lnErr);

  const emErr = validateEmail(email);
  if (emErr) return showError('emailError', emErr);

  regBtn.disabled = true;
  regBtn.textContent = 'Creating Account...';

  /* ---- REGISTER API ---- */
  try {
    const res = await fetch(
      'https://otp-verification-385594025448.asia-south1.run.app',
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          mobile,
          otp,                 // ✅ FIX ADDED
          email,
          first_name: firstName,
          last_name: lastName,
          spin_result: spinResult
        })
      }
    );

    const data = await res.json();

    if (data.type === 'success' && data.credentials) {
      shopifyAutoLogin(data.credentials.email, data.credentials.password);
    } else {
      showError('emailError', data.msg || 'Registration failed');
      regBtn.disabled = false;
      regBtn.textContent = 'CREATE ACCOUNT';
    }

  } catch (e) {
    console.error(e);
    showError('emailError', 'Something went wrong');
    regBtn.disabled = false;
    regBtn.textContent = 'CREATE ACCOUNT';
  }
});

/* ===============================
   SHOPIFY AUTO LOGIN
================================ */
function shopifyAutoLogin(email, password) {
  document.getElementById('ShopifyEmail').value = email;
  document.getElementById('ShopifyPassword').value = password;
  document.getElementById('shopify-auto-login-form').submit();
}

/* ===============================
   OTP TIMER
================================ */
let timer = 30;
let timerInterval;

function startTimer() {
  timer = 30;
  clearInterval(timerInterval);

  timerInterval = setInterval(() => {
    document.getElementById('otp-timer').innerText =
      `Resend OTP in 00:${timer < 10 ? '0'+timer : timer}`;

    if (--timer < 0) {
      clearInterval(timerInterval);
      document.getElementById('otp-timer').innerHTML =
        `<a href="javascript:void(0)" onclick="resendOtp()">Resend OTP</a>`;
    }
  }, 1000);
}

async function resendOtp() {
  const mobile = document.getElementById('otpMobile').value;
  await fetch(
    'https://login-otp-385594025448.asia-south1.run.app',
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mobile })
    }
  );
  startTimer();
}
</script>

