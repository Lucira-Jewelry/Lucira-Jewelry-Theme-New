<div id="login-popup" class="login-pop-overlay" onclick="closeloginPopup('login-popup')">
  <div class="otp-login-form-wrapper">
    <button class="close-button" onclick="closeloginPopup('login-popup')">
      {{ 'icon-login-close.svg' | inline_asset_content }}
    </button>

    <form id="otp-login-form" class="otp-form-wrapper">

      {% comment %} <div class="lucira-logo-popup">
        {% if section.settings.logo %}
          <img 
            src="{{ section.settings.logo | image_url }}" 
            width="120" 
            height="auto" 
            alt="logo">
        {% endif %}
      </div> {% endcomment %}

      <h2>{{ section.settings.heading }}</h2>

      <p>{{ section.settings.subtext }}</p>

      <div class="otp-number-wrapper">
        <label>{{ section.settings.phone_label }}</label>
        <div class="mobile-wrap">
          <span class="country-code">+91</span>
          <input
            type="tel"
            id="loginMobile"
            placeholder="{{ section.settings.phone_placeholder }}"
            maxlength="10"
            required
          >
        </div>
        <span class="error-message" id="mobileError"></span>
      </div>

      <button type="button" id="sendOtp" class="btn-primary">
        {{ section.settings.request_otp_text }}
      </button>

      <div id="otpSection" style="display:none">

        <label>{{ section.settings.otp_label }}</label>

        <div class="mobile-wrap" style="margin-bottom:10px;">
          <span class="country-code">+91</span>
          <input
            type="tel"
            id="otpMobile"
            placeholder="{{ section.settings.phone_placeholder }}"
            maxlength="10"
            readonly
          >
          <button type="button" id="editMobile">
            ✎
          </button>
        </div>

        <div class="otp-inputs">
          <input maxlength="1">
          <input maxlength="1">
          <input maxlength="1">
          <input maxlength="1">
        </div>

        <span class="error-message" id="otpError"></span>

        <button type="button" id="verifyOtp" class="btn-primary">
          {{ section.settings.verify_otp_text }}
        </button>

        <p id="otp-timer">
          {{ section.settings.resend_text }}
        </p>
      </div>

      <div class="signupSection" style="display:none">
        <div class="registration-form-inputs">

          <label>First Name</label>
          <input type="text" placeholder="First Name">

          <label>Last Name</label>
          <input type="text" placeholder="Last Name">

          <label>Email Address</label>
          <input type="email" placeholder="Email">

          <label>Phone Number</label>
          <div class="mobile-wrap">
            <span class="country-code">+91</span>
            <input type="tel" readonly>
          </div>

          <button type="button" class="btn-primary">
            {{ section.settings.create_account_text }}
          </button>

          <p class="switch-link">
            {{ section.settings.already_text }}
            <a href="javascript:void(0)">
              {{ section.settings.login_text }}
            </a>
          </p>

        </div>
      </div>

    </form>
  </div>
</div>

{% schema %}
{
  "name": "Login Popup Header",
  "tag": "header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Popup Logo"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WELCOME TO LUCIRA"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Welcome To The Jewelry World Of Lucira!"
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone Label",
      "default": "Phone Number"
    },
    {
      "type": "text",
      "id": "phone_placeholder",
      "label": "Phone Placeholder",
      "default": "Enter Phone Number"
    },
    {
      "type": "text",
      "id": "request_otp_text",
      "label": "Request OTP Button",
      "default": "REQUEST OTP"
    },
    {
      "type": "text",
      "id": "otp_label",
      "label": "OTP Label",
      "default": "Enter OTP"
    },
    {
      "type": "text",
      "id": "verify_otp_text",
      "label": "Verify OTP Button",
      "default": "VERIFY OTP"
    },
    {
      "type": "text",
      "id": "resend_text",
      "label": "Resend Timer Text",
      "default": "Resend OTP in 00:30"
    },
    {
      "type": "text",
      "id": "create_account_text",
      "label": "Create Account Button",
      "default": "CREATE ACCOUNT"
    },
    {
      "type": "text",
      "id": "already_text",
      "label": "Already Member Text",
      "default": "Already a member?"
    },
    {
      "type": "text",
      "id": "login_text",
      "label": "Login Text",
      "default": "LOGIN"
    }
  ],

  "presets": [
    {
      "name": "Login Popup (Header)"
    }
  ]
}
{% endschema %}
