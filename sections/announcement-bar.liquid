  <div class="page-width utility-bar__grid{% if announcement_bar and language_country_selector or section.settings.show_social and social_icons %} utility-bar__grid--3-col{% elsif language_country_selector or section.settings.show_social and social_icons %} utility-bar__grid--2-col{% endif %}">
    {%- if section.settings.show_social and social_icons -%}
      {%- render 'social-icons' -%}
    {%- endif -%}
    {%- if section.blocks.size == 1 -%}
      <div
        class="announcement-bar{% if section.settings.show_social %} announcement-bar--one-announcement{% endif %}"
        role="region"
        aria-label="{{ 'sections.header.announcement' | t }}"
        {{ section.blocks.first.shopify_attributes }}
      >
        {%- if section.blocks.first.type == 'countdown' -%}
          <div class="announcement-bar__message h5" 
               id="countdown-{{ section.blocks.first.id }}"
               data-timeslots='[
                 {%- if section.blocks.first.settings.slot1_start != blank and section.blocks.first.settings.slot1_end != blank -%}
                   {"start":"{{ section.blocks.first.settings.slot1_start }}","end":"{{ section.blocks.first.settings.slot1_end }}","message":"{{ section.blocks.first.settings.slot1_message | escape }}"}
                 {%- endif -%}
                 {%- if section.blocks.first.settings.slot2_start != blank and section.blocks.first.settings.slot2_end != blank -%}
                   ,{"start":"{{ section.blocks.first.settings.slot2_start }}","end":"{{ section.blocks.first.settings.slot2_end }}","message":"{{ section.blocks.first.settings.slot2_message | escape }}"}
                 {%- endif -%}
                 {%- if section.blocks.first.settings.slot3_start != blank and section.blocks.first.settings.slot3_end != blank -%}
                   ,{"start":"{{ section.blocks.first.settings.slot3_start }}","end":"{{ section.blocks.first.settings.slot3_end }}","message":"{{ section.blocks.first.settings.slot3_message | escape }}"}
                 {%- endif -%}
                 {%- if section.blocks.first.settings.slot4_start != blank and section.blocks.first.settings.slot4_end != blank -%}
                   ,{"start":"{{ section.blocks.first.settings.slot4_start }}","end":"{{ section.blocks.first.settings.slot4_end }}","message":"{{ section.blocks.first.settings.slot4_message | escape }}"}
                 {%- endif -%}
                 {%- if section.blocks.first.settings.slot5_start != blank and section.blocks.first.settings.slot5_end != blank -%}
                   ,{"start":"{{ section.blocks.first.settings.slot5_start }}","end":"{{ section.blocks.first.settings.slot5_end }}","message":"{{ section.blocks.first.settings.slot5_message | escape }}"}
                 {%- endif -%}
                 {%- if section.blocks.first.settings.slot6_start != blank and section.blocks.first.settings.slot6_end != blank -%}
                   ,{"start":"{{ section.blocks.first.settings.slot6_start }}","end":"{{ section.blocks.first.settings.slot6_end }}","message":"{{ section.blocks.first.settings.slot6_message | escape }}"}
                 {%- endif -%}
                 {%- if section.blocks.first.settings.slot7_start != blank and section.blocks.first.settings.slot7_end != blank -%}
                   ,{"start":"{{ section.blocks.first.settings.slot7_start }}","end":"{{ section.blocks.first.settings.slot7_end }}","message":"{{ section.blocks.first.settings.slot7_message | escape }}"}
                 {%- endif -%}
                 {%- if section.blocks.first.settings.slot8_start != blank and section.blocks.first.settings.slot8_end != blank -%}
                   ,{"start":"{{ section.blocks.first.settings.slot8_start }}","end":"{{ section.blocks.first.settings.slot8_end }}","message":"{{ section.blocks.first.settings.slot8_message | escape }}"}
                 {%- endif -%}
                 {%- if section.blocks.first.settings.slot9_start != blank and section.blocks.first.settings.slot9_end != blank -%}
                   ,{"start":"{{ section.blocks.first.settings.slot9_start }}","end":"{{ section.blocks.first.settings.slot9_end }}","message":"{{ section.blocks.first.settings.slot9_message | escape }}"}
                 {%- endif -%}
                 {%- if section.blocks.first.settings.slot10_start != blank and section.blocks.first.settings.slot10_end != blank -%}
                   ,{"start":"{{ section.blocks.first.settings.slot10_start }}","end":"{{ section.blocks.first.settings.slot10_end }}","message":"{{ section.blocks.first.settings.slot10_message | escape }}"}
                 {%- endif -%}
               ]'>
            <span class="countdown-text"></span>
            <span class="countdown-timer"></span>
          </div>
        {%- elsif section.blocks.first.settings.text != blank -%}
          {%- if section.blocks.first.settings.link != blank -%}
