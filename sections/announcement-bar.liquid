                  class="announcement-bar__announcement"
                  role="region"
                  aria-label="{{ 'sections.header.announcement' | t }}"
                >
                  {%- if block.type == 'countdown' -%}
                    <div class="announcement-bar__message h5" 
                         id="countdown-{{ block.id }}"
                         data-timeslots='[
                           {%- if block.settings.slot1_start != blank and block.settings.slot1_end != blank -%}
                             {"start":"{{ block.settings.slot1_start }}","end":"{{ block.settings.slot1_end }}","message":"{{ block.settings.slot1_message | escape }}"}
                           {%- endif -%}
                           {%- if block.settings.slot2_start != blank and block.settings.slot2_end != blank -%}
                             ,{"start":"{{ block.settings.slot2_start }}","end":"{{ block.settings.slot2_end }}","message":"{{ block.settings.slot2_message | escape }}"}
                           {%- endif -%}
                           {%- if block.settings.slot3_start != blank and block.settings.slot3_end != blank -%}
                             ,{"start":"{{ block.settings.slot3_start }}","end":"{{ block.settings.slot3_end }}","message":"{{ block.settings.slot3_message | escape }}"}
                           {%- endif -%}
                           {%- if block.settings.slot4_start != blank and block.settings.slot4_end != blank -%}
                             ,{"start":"{{ block.settings.slot4_start }}","end":"{{ block.settings.slot4_end }}","message":"{{ block.settings.slot4_message | escape }}"}
                           {%- endif -%}
                           {%- if block.settings.slot5_start != blank and block.settings.slot5_end != blank -%}
                             ,{"start":"{{ block.settings.slot5_start }}","end":"{{ block.settings.slot5_end }}","message":"{{ block.settings.slot5_message | escape }}"}
                           {%- endif -%}
                           {%- if block.settings.slot6_start != blank and block.settings.slot6_end != blank -%}
                             ,{"start":"{{ block.settings.slot6_start }}","end":"{{ block.settings.slot6_end }}","message":"{{ block.settings.slot6_message | escape }}"}
                           {%- endif -%}
                           {%- if block.settings.slot7_start != blank and block.settings.slot7_end != blank -%}
                             ,{"start":"{{ block.settings.slot7_start }}","end":"{{ block.settings.slot7_end }}","message":"{{ block.settings.slot7_message | escape }}"}
                           {%- endif -%}
                           {%- if block.settings.slot8_start != blank and block.settings.slot8_end != blank -%}
                             ,{"start":"{{ block.settings.slot8_start }}","end":"{{ block.settings.slot8_end }}","message":"{{ block.settings.slot8_message | escape }}"}
                           {%- endif -%}
                           {%- if block.settings.slot9_start != blank and block.settings.slot9_end != blank -%}
                             ,{"start":"{{ block.settings.slot9_start }}","end":"{{ block.settings.slot9_end }}","message":"{{ block.settings.slot9_message | escape }}"}
                           {%- endif -%}
                           {%- if block.settings.slot10_start != blank and block.settings.slot10_end != blank -%}
