              <h2 class="visually-hidden" id="AnnouncementLanguageLabel">{{ 'localization.language_label' | t }}</h2>
              {%- render 'language-localization', localPosition: 'AnnouncementLanguage' -%}
            </div>
          {%- endform -%}
        </localization-form>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
(function() {
  function parseTime(timeStr) {
    const [hours, minutes] = timeStr.split(':').map(Number);
    return hours * 60 + minutes;
  }

  function getCurrentTimeSlot(timeSlots) {
    const now = new Date();
    const currentMinutes = now.getHours() * 60 + now.getMinutes();

    for (const slot of timeSlots) {
      const startMinutes = parseTime(slot.start);
      const endMinutes = parseTime(slot.end);
      
      if (currentMinutes >= startMinutes && currentMinutes < endMinutes) {
        return slot;
      }
    }
    return null;
  }

  function getTimeUntilEnd(endTime) {
    const now = new Date();
    const [endHours, endMinutes] = endTime.split(':').map(Number);
    const end = new Date(now);
    end.setHours(endHours, endMinutes, 0, 0);

    const diff = end - now;
    if (diff < 0) return null;

    const hours = Math.floor(diff / (1000 * 60 * 60));
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((diff % (1000 * 60)) / 1000);

    return { hours, minutes, seconds };
  }

  function updateCountdown() {
    const countdownElements = document.querySelectorAll('[id^="countdown-"]');
    
    countdownElements.forEach(el => {
      const textEl = el.querySelector('.countdown-text');
      const timerEl = el.querySelector('.countdown-timer');
      
      if (!textEl || !timerEl) return;

      // Get time slots from data attribute
      const timeSlotsData = el.getAttribute('data-timeslots');
      let timeSlots = [];
      
      try {
        timeSlots = JSON.parse(timeSlotsData);
      } catch (e) {
        console.error('Error parsing time slots:', e);
        textEl.textContent = 'Configuration error';
        timerEl.innerHTML = '';
        return;
      }

      if (!timeSlots || timeSlots.length === 0) {
        textEl.textContent = 'No time slots configured';
        timerEl.innerHTML = '';
        return;
      }

      const currentSlot = getCurrentTimeSlot(timeSlots);
      
      if (!currentSlot) {
        textEl.textContent = 'No active muhurat';
        timerEl.innerHTML = '';
        return;
      }

      const timeLeft = getTimeUntilEnd(currentSlot.end);
      
      if (!timeLeft) {
        textEl.textContent = 'Muhurat ended';
        timerEl.innerHTML = '';
        return;
      }

      textEl.textContent = currentSlot.message + ' in ';
      
      timerEl.innerHTML = `
        <span class="countdown-timer__segment">
          <span class="countdown-timer__value">${String(timeLeft.hours).padStart(2, '0')}</span>
          <span class="countdown-timer__label">hrs</span>
        </span>
        <span class="countdown-timer__separator">:</span>
        <span class="countdown-timer__segment">
          <span class="countdown-timer__value">${String(timeLeft.minutes).padStart(2, '0')}</span>
          <span class="countdown-timer__label">min</span>
        </span>
        <span class="countdown-timer__separator">:</span>
        <span class="countdown-timer__segment">
          <span class="countdown-timer__value">${String(timeLeft.seconds).padStart(2, '0')}</span>
          <span class="countdown-timer__label">sec</span>
        </span>
      `;
    });
  }

  // Update immediately and then every second
  updateCountdown();
  setInterval(updateCountdown, 1000);
})();
</script>

