   .feature-btn-{{ section.id }} {
    width: 66px;
    height: 66px;
    border-radius: 50%;
    border: 5px solid rgba(218, 218, 218, 0.3);
    background: transparent;
    cursor: pointer;
    position: relative;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }


  .feature-btn-{{ section.id }}:hover {
    border-color: rgba(255, 255, 255, 0.5);
    transform: scale(1.05);
  }

  .feature-btn-{{ section.id }}.active {
    border-color: rgba(255, 255, 255, 0.6);
  }

  .feature-btn-{{ section.id }} img {
    width: 30px;
    height: 30px;
    object-fit: contain;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .feature-btn-{{ section.id }}.active img {
    opacity: 1;
  }

  .progress-ring-{{ section.id }} {
    position: absolute;
    top: -3px;
    left: -3px;
    width: 63px;
    height: 66px;
    transform: rotate(-90deg);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .feature-btn-{{ section.id }}.active .progress-ring-{{ section.id }} {
    opacity: 1;
  }

  .progress-ring-circle-{{ section.id }} {
    fill: none;
    stroke-width: 3;
    stroke-dasharray: 207.34;
    stroke-dashoffset: 207.34;
    transition: stroke-dashoffset 0.5s ease;
  }

  .percentage-label-{{ section.id }} {
    position: absolute;
    top: -28px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.3s ease;
    white-space: nowrap;
    pointer-events: none;
  }

  .feature-btn-{{ section.id }}.active .percentage-label-{{ section.id }} {
    opacity: 1;
