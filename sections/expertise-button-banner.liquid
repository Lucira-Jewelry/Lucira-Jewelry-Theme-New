<style>
  .sustainable-section-{{ section.id }} {
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
    max-width: 1400px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  .feature-container-{{ section.id }} {
    position: relative;
    background: {{ section.settings.overlay_color }};
    border-radius: 12px;
    overflow: hidden;
    min-height: 500px;
  }

  .feature-image-{{ section.id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
  }

  .feature-image-{{ section.id }}.active {
    opacity: 1;
  }

  .overlay-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .feature-content-{{ section.id }} {
    position: absolute;
    bottom: 30px;
    left: 30px;
    right: 30px;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .text-content-{{ section.id }} {
    max-width: 500px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease-in-out, transform 0.5s ease-in-out;
    position: absolute;
    bottom: 0;
    left: 0;
  }

  .text-content-{{ section.id }}.active {
    opacity: 1;
    transform: translateY(0);
  }

  .feature-title-{{ section.id }} {
    font-size: 32px;
    font-weight: 500;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color:white;
  }

  .feature-description-{{ section.id }} {
    font-size: 14px;
    line-height: 1.6;
    opacity: 0.9;
  }

  .feature-buttons-{{ section.id }} {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-left: auto;
  }

  {% comment %} .feature-btn-{{ section.id }} {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.3);
    background: transparent;
    cursor: pointer;
    position: relative;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  } {% endcomment %}



   .feature-btn-{{ section.id }} {
    width: 67px;
    height: 67px;
    border-radius: 50%;
    border: 5px solid rgba(218, 218, 218, 0.3);
    background: transparent;
    cursor: pointer;
    position: relative;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }


  .feature-btn-{{ section.id }}:hover {
    border-color: rgba(255, 255, 255, 0.5);
    transform: scale(1.05);
  }

  .feature-btn-{{ section.id }}.active {
    border-color: rgba(255, 255, 255, 0.6);
  }

  .feature-btn-{{ section.id }} img {
    width: 30px;
    height: 30px;
    object-fit: contain;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .feature-btn-{{ section.id }}.active img {
    opacity: 1;
  }

  .progress-ring-{{ section.id }} {
    position: absolute;
    top: -3px;
    left: -3px;
    width: 63px;
    height: 66px;
    transform: rotate(-90deg);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .feature-btn-{{ section.id }}.active .progress-ring-{{ section.id }} {
    opacity: 1;
  }

  .progress-ring-circle-{{ section.id }} {
    fill: none;
    stroke-width: 3;
    stroke-dasharray: 207.34;
    stroke-dashoffset: 207.34;
    transition: stroke-dashoffset 0.5s ease;
  }

  .percentage-label-{{ section.id }} {
    position: absolute;
    top: -28px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.3s ease;
    white-space: nowrap;
    pointer-events: none;
  }

  .feature-btn-{{ section.id }}.active .percentage-label-{{ section.id }} {
    opacity: 1;
  }

  /* Mobile Styles */
  {% comment %} @media (max-width: 768px) {
    .feature-container-{{ section.id }} {
      min-height: 600px;
    }

    .feature-content-{{ section.id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 30px;
      bottom: 20px;
      left: 20px;
      right: 20px;
    }

    .text-content-{{ section.id }} {
      max-width: 100%;
      position: static;
    }

    .feature-title-{{ section.id }} {
      font-size: 24px;
    }

    .feature-description-{{ section.id }} {
      font-size: 13px;
    }

    .feature-buttons-{{ section.id }} {
      gap: 12px;
      flex-wrap: wrap;
      margin-left: 0;
      width: 100%;
    }

    .feature-btn-{{ section.id }} {
      width: 50px;
      height: 50px;
    }

    .feature-btn-{{ section.id }} img {
      width: 24px;
      height: 24px;
    }

    .progress-ring-{{ section.id }} {
      width: 56px;
      height: 56px;
    }

    .percentage-label-{{ section.id }} {
      font-size: 10px;
      top: -24px;
    }
  } {% endcomment %}

  /* Mobile Styles - UPDATED */
@media (max-width: 768px) {
  .feature-container-{{ section.id }} {
    min-height: 500px; /* Reduced from 600px */
  }

  .feature-content-{{ section.id }} {
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    top: 20px; /* Changed from bottom: 20px */
    left: 20px;
    right: 20px;
    bottom: auto; /* Remove bottom positioning */
  }

  .text-content-{{ section.id }} {
    max-width: 100%;
    position: static;
  }

  .feature-title-{{ section.id }} {
    font-size: 24px;
    margin-bottom: 8px;
  }

  .feature-description-{{ section.id }} {
    font-size: 13px;
    line-height: 1.5;
  }

  .feature-buttons-{{ section.id }} {
    gap: 12px;
    flex-wrap: wrap;
    margin-left: 0;
    width: 100%;
    position: relative;
    z-index: 20;
    margin-top: 20px; /* Added spacing from text */
  }

  .feature-btn-{{ section.id }} {
    width: 50px;
    height: 50px;
    border-width: 3px;
  }

  .feature-btn-{{ section.id }} img {
    width: 24px;
    height: 24px;
  }

  /* Fix progress ring positioning */
  .progress-ring-{{ section.id }} {
    position: absolute;
    top: -2px;
    left: -2px;
    width: 54px;
    height: 54px;
    z-index: 1;
  }

  .progress-ring-circle-{{ section.id }} {
    cx: 27;
    cy: 27;
    r: 24;
  }

  /* Fix percentage label positioning */
  .percentage-label-{{ section.id }} {
    position: absolute;
    top: -25px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    font-weight: 600;
    white-space: nowrap;
    background: rgba(0, 0, 0, 0.7);
    padding: 2px 6px;
    border-radius: 3px;
    z-index: 30;
    pointer-events: none;
  }
}
</style>

<div class="sustainable-section-{{ section.id }}">
  <div class="feature-container-{{ section.id }}" id="featureContainer{{ section.id }}">
    
    {% comment %} Background Images {% endcomment %}
    {% for block in section.blocks %}
      {% if block.settings.background_image %}
        <img 
          src="{{ block.settings.background_image | image_url: width: 1400 }}"
          alt="{{ block.settings.title }}"
          class="feature-image-{{ section.id }} {% if forloop.first %}active{% endif %}"
          data-block-id="{{ block.id }}"
          loading="lazy"
        >
      {% endif %}
    {% endfor %}

    {% comment %} Overlay {% endcomment %}
    <div class="overlay-{{ section.id }}"></div>

    {% comment %} Content Overlay {% endcomment %}
    <div class="feature-content-{{ section.id }}">
      
      {% comment %} Text Content Container {% endcomment %}
      <div style="position: relative; flex: 1;">
        {% for block in section.blocks %}
          <div 
            class="text-content-{{ section.id }} {% if forloop.first %}active{% endif %}"
            data-block-id="{{ block.id }}"
            style="color: {{ block.settings.text_color }};"
          >
            <h2 class="feature-title-{{ section.id }}">{{ block.settings.title }}</h2>
            <p class="feature-description-{{ section.id }}">{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      </div>

      {% comment %} Feature Buttons {% endcomment %}
      <div class="feature-buttons-{{ section.id }}">
        {% for block in section.blocks %}
          <button 
            class="feature-btn-{{ section.id }} {% if forloop.first %}active{% endif %}"
            data-block-id="{{ block.id }}"
            data-progress="{{ block.settings.progress_percentage }}"
            type="button"
            aria-label="{{ block.settings.title }}"
          >
            <svg class="progress-ring-{{ section.id }}">
              <circle 
                class="progress-ring-circle-{{ section.id }}"
                cx="33" 
                cy="33" 
                r="33"
                style="stroke: {{ block.settings.progress_ring_color }};"
              ></circle>
            </svg>
            
            {% if block.settings.button_icon %}
              <img 
                src="{{ block.settings.button_icon | image_url: width: 64 }}" 
                alt="{{ block.settings.title }}"
              >
            {% endif %}
            
            <span 
              class="percentage-label-{{ section.id }}"
              style="color: {{ block.settings.text_color }};"
            >
              {{ block.settings.progress_percentage }}% {{ block.settings.progress_label }}
            </span>
          </button>
        {% endfor %}
      </div>

    </div>
  </div>
</div>
{% comment %} 
<script>
(function() {
  const sectionId = '{{ section.id }}';
  
  function switchFeature(blockId) {
    // Update images
    document.querySelectorAll(`.feature-image-${sectionId}`).forEach(img => {
      img.classList.toggle('active', img.dataset.blockId === blockId);
    });

    // Update text content
    document.querySelectorAll(`.text-content-${sectionId}`).forEach(text => {
      text.classList.toggle('active', text.dataset.blockId === blockId);
    });

    // Update buttons and progress rings
    document.querySelectorAll(`.feature-btn-${sectionId}`).forEach(btn => {
      const isActive = btn.dataset.blockId === blockId;
      btn.classList.toggle('active', isActive);
      
      // Update progress ring - only for active button
      const circle = btn.querySelector(`.progress-ring-circle-${sectionId}`);
      if (isActive) {
        const progress = btn.dataset.progress;
        const offset = 207.34 - (207.34 * progress / 100);
        circle.style.strokeDashoffset = offset;
      } else {
        // Reset non-active buttons
        circle.style.strokeDashoffset = 207.34;
      }
    });
  }

  // Add click event listeners to buttons
  function initializeButtons() {
    document.querySelectorAll(`.feature-btn-${sectionId}`).forEach(btn => {
      btn.addEventListener('click', function() {
        switchFeature(this.dataset.blockId);
      });
    });
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      initializeButtons();
      // Activate first feature
      const firstBtn = document.querySelector(`.feature-btn-${sectionId}.active`);
      if (firstBtn) {
        switchFeature(firstBtn.dataset.blockId);
      }
    });
  } else {
    initializeButtons();
    // Activate first feature
    const firstBtn = document.querySelector(`.feature-btn-${sectionId}.active`);
    if (firstBtn) {
      switchFeature(firstBtn.dataset.blockId);
    }
  }
})();
</script> {% endcomment %}

<script>
(function() {
  const sectionId = '{{ section.id }}';
  
  function switchFeature(blockId) {
    // Update images
    document.querySelectorAll(`.feature-image-${sectionId}`).forEach(img => {
      img.classList.toggle('active', img.dataset.blockId === blockId);
    });

    // Update text content
    document.querySelectorAll(`.text-content-${sectionId}`).forEach(text => {
      text.classList.toggle('active', text.dataset.blockId === blockId);
    });

    // Update buttons and progress rings
    document.querySelectorAll(`.feature-btn-${sectionId}`).forEach(btn => {
      const isActive = btn.dataset.blockId === blockId;
      btn.classList.toggle('active', isActive);
      
      // Update progress ring - only for active button
      const circle = btn.querySelector(`.progress-ring-circle-${sectionId}`);
      if (isActive) {
        const progress = btn.dataset.progress;
        // Calculate circumference based on screen size
        const radius = window.innerWidth <= 768 ? 24 : 33;
        const circumference = 2 * Math.PI * radius;
        const offset = circumference - (circumference * progress / 100);
        circle.style.strokeDashoffset = offset;
      } else {
        // Reset non-active buttons
        const radius = window.innerWidth <= 768 ? 24 : 33;
        const circumference = 2 * Math.PI * radius;
        circle.style.strokeDashoffset = circumference;
      }
    });
  }

  // Add click event listeners to buttons
  function initializeButtons() {
    document.querySelectorAll(`.feature-btn-${sectionId}`).forEach(btn => {
      btn.addEventListener('click', function() {
        switchFeature(this.dataset.blockId);
      });
      
      // Add touch events for mobile
      btn.addEventListener('touchstart', function(e) {
        e.preventDefault();
        switchFeature(this.dataset.blockId);
      }, { passive: false });
    });
  }

  // Handle responsive adjustments
  function handleResize() {
    const activeBtn = document.querySelector(`.feature-btn-${sectionId}.active`);
    if (activeBtn) {
      switchFeature(activeBtn.dataset.blockId);
    }
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      initializeButtons();
      // Activate first feature
      const firstBtn = document.querySelector(`.feature-btn-${sectionId}.active`);
      if (firstBtn) {
        switchFeature(firstBtn.dataset.blockId);
      }
      
      // Add resize listener
      window.addEventListener('resize', handleResize);
    });
  } else {
    initializeButtons();
    // Activate first feature
    const firstBtn = document.querySelector(`.feature-btn-${sectionId}.active`);
    if (firstBtn) {
      switchFeature(firstBtn.dataset.blockId);
    }
    
    // Add resize listener
    window.addEventListener('resize', handleResize);
  }
})();
</script>

