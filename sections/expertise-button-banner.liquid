<div class="sustainable-section-{{ section.id }}">
  <div class="feature-container-{{ section.id }}" id="featureContainer{{ section.id }}">
    
    {% comment %} Background Images {% endcomment %}
    {% for block in section.blocks %}
      {% if block.settings.background_image %}
        <img 
          src="{{ block.settings.background_image | image_url: width: 1400 }}"
          alt="{{ block.settings.title }}"
          class="feature-image-{{ section.id }} {% if forloop.first %}active{% endif %}"
          data-block-id="{{ block.id }}"
          loading="lazy"
        >
      {% endif %}
    {% endfor %}

    {% comment %} Overlay {% endcomment %}
    <div class="overlay-{{ section.id }}"></div>

    {% comment %} Content Overlay {% endcomment %}
    <div class="feature-content-{{ section.id }}">
      
      {% comment %} Text Content Container {% endcomment %}
      <div style="position: relative; flex: 1;">
        {% for block in section.blocks %}
          <div 
            class="text-content-{{ section.id }} {% if forloop.first %}active{% endif %}"
            data-block-id="{{ block.id }}"
            style="color: {{ block.settings.text_color }};"
          >
            <h2 class="feature-title-{{ section.id }}">{{ block.settings.title }}</h2>
            <p class="feature-description-{{ section.id }}">{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      </div>

      {% comment %} Feature Buttons {% endcomment %}
      <div class="feature-buttons-{{ section.id }}">
        {% for block in section.blocks %}
          <button 
            class="feature-btn-{{ section.id }} {% if forloop.first %}active{% endif %}"
            data-block-id="{{ block.id }}"
            data-progress="{{ block.settings.progress_percentage }}"
            type="button"
            aria-label="{{ block.settings.title }}"
          >
            <svg class="progress-ring-{{ section.id }}">
              <circle 
                class="progress-ring-circle-{{ section.id }}"
                cx="33" 
                cy="33" 
                r="33"
                style="stroke: {{ block.settings.progress_ring_color }};"
              ></circle>
            </svg>
            
            {% if block.settings.button_icon %}
              <img 
                src="{{ block.settings.button_icon | image_url: width: 64 }}" 
                alt="{{ block.settings.title }}"
              >
            {% endif %}
            
            <span 
              class="percentage-label-{{ section.id }}"
              style="color: {{ block.settings.text_color }};"
            >
              {{ block.settings.progress_percentage }}% {{ block.settings.progress_label }}
            </span>
          </button>
        {% endfor %}
      </div>

    </div>
  </div>
</div>
