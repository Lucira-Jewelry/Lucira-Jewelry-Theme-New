    filter: drop-shadow(0 0 2px rgba(0, 0, 0, 0.2));
  }

  .progress-ring-circle {
    fill: none;
    stroke-width: 5;
    stroke-dasharray: 207.34;
    stroke-dashoffset: 207.34;
    transition: stroke-dashoffset 0.5s ease;
    stroke: #ffffff;
  }

  .percentage-label {
    position: absolute;
    top: -28px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.3s ease;
    white-space: nowrap;
    pointer-events: none;
    color: white;
  }

  .feature-btn.active .percentage-label {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .feature-container {
      min-height: 600px;
    }

    .feature-content {
      flex-direction: column;
      align-items: flex-start;
      gap: 315px;
      top: 20px;
      left: 20px;
      right: 20px;
      bottom: auto;
      position: absolute;
      display: flex;
      justify-content: flex-start;
      height: 100%;
    }

    .text-content {
      max-width: 100%;
      position: relative !important;
      opacity: 1 !important;
      transform: translateY(0) !important;
      display: none;
    }

    .text-content.active {
      display: block;
    }

    .feature-title {
      font-size: 18px;
      margin-bottom: 12px;
    }

    .feature-description {
      font-size: 12px;
      line-height: 1.6;
    }

    .feature-buttons {
      gap: 12px;
      flex-wrap: wrap;
      margin-left: 0;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      margin-top: auto;
      position: absolute;
      bottom: 37px;
    }

    .feature-btn {
      width: 50px;
      height: 50px;
      border: 4px solid rgba(218, 218, 218, 0.3);
      position: relative;
    }

    .btn-icon {
      width: 24px;
      height: 24px;
    }

    .progress-ring-container {
      width: 50px;
      height: 50px;
    }

    .progress-ring-circle {
      stroke-width: 4;
    }

    .percentage-label {
      font-size: 9px;
      top: -20px;
    }
  }
</style>

