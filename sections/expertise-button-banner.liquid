<script>
(function() {
  const CONFIG = {
    AUTO_SWITCH_INTERVAL: 3000, // 3 seconds
    PROGRESS_ANIMATION_DURATION: 500,
    TOTAL_BUTTONS: 4
  };

  let currentButtonIndex = 0;
  let autoSwitchTimer = null;
  let isMobile = window.innerWidth <= 768;

  function updateMobileDetection() {
    isMobile = window.innerWidth <= 768;
  }

  function getCircumference(isMobileView) {
    const radius = isMobileView ? 23 : 28;
    return 2 * Math.PI * radius;
  }

  function switchFeature(blockId) {
    // Update images
    document.querySelectorAll('.feature-image').forEach(img => {
      img.classList.toggle('active', img.dataset.blockId === blockId);
    });

    // Update text content
    document.querySelectorAll('.text-content').forEach(text => {
      text.classList.toggle('active', text.dataset.blockId === blockId);
    });

    // Update buttons and progress rings
    document.querySelectorAll('.feature-btn').forEach(btn => {
      const isActive = btn.dataset.blockId === blockId;
      btn.classList.toggle('active', isActive);

      if (isActive) {
        const progress = parseInt(btn.dataset.progress);
        const circle = btn.querySelector('.progress-ring-circle');
        const circumference = getCircumference(isMobile);
        
        circle.style.strokeDasharray = circumference;
        const offset = circumference - (circumference * progress / 100);
        circle.style.strokeDashoffset = offset;
      }
    });

    // Reset auto-switch timer
    resetAutoSwitch();
  }

  function goToNextButton() {
    const buttons = document.querySelectorAll('.feature-btn');
    currentButtonIndex = (currentButtonIndex + 1) % buttons.length;
    const nextBlockId = buttons[currentButtonIndex].dataset.blockId;
    switchFeature(nextBlockId);
  }

  function resetAutoSwitch() {
    if (autoSwitchTimer) {
      clearInterval(autoSwitchTimer);
    }
    
    autoSwitchTimer = setInterval(goToNextButton, CONFIG.AUTO_SWITCH_INTERVAL);
  }

  function initializeProgressRings() {
    const circumference = getCircumference(isMobile);
    
    document.querySelectorAll('.progress-ring-circle').forEach((circle, index) => {
      circle.style.strokeDasharray = circumference;
      circle.style.strokeDashoffset = circumference;
    });

    // Activate first button's progress ring
    const firstBtn = document.querySelector('.feature-btn.active');
    if (firstBtn) {
      const progress = parseInt(firstBtn.dataset.progress);
      const firstCircle = firstBtn.querySelector('.progress-ring-circle');
      const offset = circumference - (circumference * progress / 100);
      firstCircle.style.strokeDashoffset = offset;
    }
  }

  function initializeButtons() {
    document.querySelectorAll('.feature-btn').forEach((btn, index) => {
      btn.removeEventListener('click', handleButtonClick);
      
      btn.addEventListener('click', function() {
        currentButtonIndex = index;
        switchFeature(this.dataset.blockId);
      });
    });
  }

  function handleResize() {
    const wasMobile = isMobile;
    updateMobileDetection();

    if (wasMobile !== isMobile) {
      initializeProgressRings();
      const activeBtn = document.querySelector('.feature-btn.active');
      if (activeBtn) {
        switchFeature(activeBtn.dataset.blockId);
      }
    }
  }

  function initialize() {
    updateMobileDetection();
    initializeProgressRings();
    initializeButtons();
    resetAutoSwitch();
    
    console.log('Sustainable Features initialized');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initialize);
  } else {
    initialize();
  }

  window.addEventListener('resize', handleResize);
})();
</script>


