{% comment %} <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sustainable Features</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #f5f5f5;
        }

        .sustainable-section {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }

        .feature-container {
            position: relative;
            background: #1a1a1a;
            border-radius: 12px;
            overflow: hidden;
            min-height: 500px;
        }

        .feature-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            top: 0;
            left: 0;
            opacity: 0;
            transition: opacity 0.5s ease-in-out;
        }

        .feature-image.active {
            opacity: 1;
        }

        .feature-content {
            position: absolute;
            bottom: 30px;
            left: 30px;
            right: 30px;
            z-index: 10;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .text-content {
            max-width: 500px;
            color: white;
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.5s ease-in-out, transform 0.5s ease-in-out;
        }

        .text-content.active {
            opacity: 1;
            transform: translateY(0);
        }

        .feature-title {
            font-size: 32px;
            font-weight: 600;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .feature-description {
            font-size: 14px;
            line-height: 1.6;
            color: rgba(255, 255, 255, 0.9);
        }

        .feature-buttons {
            display: flex;
            gap: 16px;
            align-items: center;
        }

        .feature-btn {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            border: none;
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(10px);
            cursor: pointer;
            position: relative;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .feature-btn:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: scale(1.05);
        }

        .feature-btn.active {
            background: rgba(255, 255, 255, 0.4);
        }

        .feature-btn img {
            width: 30px;
            height: 30px;
            filter: brightness(0) invert(1);
        }

        .progress-ring {
            position: absolute;
            top: -3px;
            left: -3px;
            width: 66px;
            height: 66px;
            transform: rotate(-90deg);
        }

        .progress-ring-circle {
            fill: none;
            stroke: white;
            stroke-width: 3;
            stroke-dasharray: 207.34;
            stroke-dashoffset: 207.34;
            transition: stroke-dashoffset 0.5s ease;
        }

        .feature-btn.active .progress-ring-circle {
            stroke-dashoffset: calc(207.34 - (207.34 * var(--progress)) / 100);
        }

        .percentage-label {
            position: absolute;
            top: -25px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 12px;
            font-weight: 600;
            color: white;
            opacity: 0;
            transition: opacity 0.3s ease;
            white-space: nowrap;
        }

        .feature-btn.active .percentage-label {
            opacity: 1;
        }

        /* Mobile Styles */
        @media (max-width: 768px) {
            .feature-container {
                min-height: 600px;
            }

            .feature-content {
                flex-direction: column;
                align-items: flex-start;
                gap: 30px;
                bottom: 20px;
                left: 20px;
                right: 20px;
            }

            .text-content {
                max-width: 100%;
            }

            .feature-title {
                font-size: 24px;
            }

            .feature-description {
                font-size: 13px;
            }

            .feature-buttons {
                gap: 12px;
                flex-wrap: wrap;
            }

            .feature-btn {
                width: 50px;
                height: 50px;
            }

            .feature-btn img {
                width: 24px;
                height: 24px;
            }

            .progress-ring {
                width: 56px;
                height: 56px;
            }

            .percentage-label {
                font-size: 10px;
                top: -22px;
            }
        }
    </style>
</head>
<body>
    <div class="sustainable-section">
        <div class="feature-container" id="featureContainer">
            <!-- Images will be inserted here -->
        </div>
    </div>

    <script>
        // SCHEMA - Edit this data to customize the section
        const featuresData = [
            {
                id: 1,
                title: "WATER RESPONSIBLE",
                description: "Lab grown diamonds significantly reduce water usage compared to traditional mining. Our process prioritizes conservation, ensuring beauty without depleting one of Earth's most vital resources.",
                image: "https://images.unsplash.com/photo-1505142468610-359e7d316be0?w=1200&h=800&fit=crop",
                icon: "https://api.iconify.design/mdi/water-outline.svg?color=white",
                progress: 75
            },
            {
                id: 2,
                title: "CARBON NEUTRAL",
                description: "Our lab-grown diamonds are created with renewable energy sources, achieving carbon neutrality. We're committed to reducing our environmental footprint while delivering exceptional quality.",
                image: "https://images.unsplash.com/photo-1473654729523-203e25dfda10?w=1200&h=800&fit=crop",
                icon: "https://api.iconify.design/mdi/leaf.svg?color=white",
                progress: 90
            },
            {
                id: 3,
                title: "ENERGY EFFICIENT",
                description: "Advanced technology allows us to create diamonds using 80% less energy than traditional mining. Sustainable luxury is now a reality with our innovative processes.",
                image: "https://images.unsplash.com/photo-1497436072909-60f360e1d4b1?w=1200&h=800&fit=crop",
                icon: "https://api.iconify.design/mdi/lightning-bolt.svg?color=white",
                progress: 80
            },
            {
                id: 4,
                title: "ETHICALLY SOURCED",
                description: "100% conflict-free and ethically created in controlled environments. Our diamonds represent a new era of conscious luxury without compromise on brilliance or beauty.",
                image: "https://images.unsplash.com/photo-1518834107812-67b0b7c58434?w=1200&h=800&fit=crop",
                icon: "https://api.iconify.design/mdi/heart-outline.svg?color=white",
                progress: 100
            }
        ];

        // Initialize the section
        function initializeSection() {
            const container = document.getElementById('featureContainer');
            
            // Create images
            featuresData.forEach((feature, index) => {
                const img = document.createElement('img');
                img.src = feature.image;
                img.alt = feature.title;
                img.className = `feature-image ${index === 0 ? 'active' : ''}`;
                img.dataset.id = feature.id;
                container.appendChild(img);
            });

            // Create content overlay
            const contentDiv = document.createElement('div');
            contentDiv.className = 'feature-content';
            
            // Create text content container
            const textContainer = document.createElement('div');
            textContainer.className = 'text-content-container';
            
            // Create text contents
            featuresData.forEach((feature, index) => {
                const textDiv = document.createElement('div');
                textDiv.className = `text-content ${index === 0 ? 'active' : ''}`;
                textDiv.dataset.id = feature.id;
                textDiv.innerHTML = `
                    <h2 class="feature-title">${feature.title}</h2>
                    <p class="feature-description">${feature.description}</p>
                `;
                textContainer.appendChild(textDiv);
            });
            
            contentDiv.appendChild(textContainer);

            // Create buttons container
            const buttonsDiv = document.createElement('div');
            buttonsDiv.className = 'feature-buttons';
            
            featuresData.forEach((feature, index) => {
                const button = document.createElement('button');
                button.className = `feature-btn ${index === 0 ? 'active' : ''}`;
                button.dataset.id = feature.id;
                button.style.setProperty('--progress', feature.progress);
                
                button.innerHTML = `
                    <svg class="progress-ring">
                        <circle class="progress-ring-circle" 
                                cx="33" 
                                cy="33" 
                                r="33">
                        </circle>
                    </svg>
                    <img src="${feature.icon}" alt="${feature.title}">
                    <span class="percentage-label">${feature.progress}% Saved</span>
                `;
                
                button.addEventListener('click', () => switchFeature(feature.id));
                buttonsDiv.appendChild(button);
            });
            
            contentDiv.appendChild(buttonsDiv);
            container.appendChild(contentDiv);
        }

        // Switch feature function
        function switchFeature(featureId) {
            // Update images
            document.querySelectorAll('.feature-image').forEach(img => {
                img.classList.toggle('active', img.dataset.id == featureId);
            });

            // Update text content
            document.querySelectorAll('.text-content').forEach(text => {
                text.classList.toggle('active', text.dataset.id == featureId);
            });

            // Update buttons
            document.querySelectorAll('.feature-btn').forEach(btn => {
                btn.classList.toggle('active', btn.dataset.id == featureId);
            });
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', initializeSection);
    </script>
</body>
</html>


