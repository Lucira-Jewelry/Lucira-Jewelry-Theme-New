{% comment %} <style>
  .sustainable-section-{{ section.id }} {
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
    max-width: 1400px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  .feature-container-{{ section.id }} {
    position: relative;
    background: {{ section.settings.overlay_color }};
    border-radius: 12px;
    overflow: hidden;
    min-height: 500px;
  }

  .feature-image-{{ section.id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
  }

  .feature-image-{{ section.id }}.active {
    opacity: 1;
  }

  .overlay-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .feature-content-{{ section.id }} {
    position: absolute;
    bottom: 30px;
    left: 30px;
    right: 30px;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .text-content-{{ section.id }} {
    max-width: 500px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease-in-out, transform 0.5s ease-in-out;
    position: absolute;
    bottom: 0;
    left: 0;
  }

  .text-content-{{ section.id }}.active {
    opacity: 1;
    transform: translateY(0);
  }

  .feature-title-{{ section.id }} {
