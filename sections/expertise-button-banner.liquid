<style>
  .sustainable-section-{{ section.id }} {
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  .feature-container-{{ section.id }} {
    position: relative;
    background: {{ section.settings.overlay_color }};
    border-radius: 12px;
    overflow: hidden;
    min-height: 600px;
  }

  .feature-image-{{ section.id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
  }

  .feature-image-{{ section.id }}.active {
    opacity: 1;
  }

  .feature-image-mobile-{{ section.id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
    display: none;
  }

  .feature-image-mobile-{{ section.id }}.active {
    opacity: 1;
  }

  .overlay-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .feature-content-{{ section.id }} {
    position: absolute;
    bottom: 30px;
    left: 30px;
    right: 30px;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .text-content-{{ section.id }} {
    max-width: 500px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease-in-out, transform 0.5s ease-in-out;
    position: absolute;
    bottom: 0;
    left: 0;
  }

  .text-content-{{ section.id }}.active {
    opacity: 1;
    transform: translateY(0);
  }

  .feature-title-{{ section.id }} {
    font-size: 24px;
    font-weight: 500;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: white;
  }

  .feature-description-{{ section.id }} {
    font-size: 14px;
    line-height: 1.6;
    opacity: 0.9;
  }

  .feature-buttons-{{ section.id }} {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-left: auto;
  }

  .feature-btn-{{ section.id }} {
    width: 78px;
    height: 78px;
    border-radius: 50%;
    border: 7px solid rgba(218, 218, 218, 0.3);
    background: transparent;
    cursor: pointer;
    position: relative;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .feature-btn-{{ section.id }}:hover {
    border-color: rgba(255, 255, 255, 0.5);
    transform: scale(1.05);
  }

  .feature-btn-{{ section.id }}.active {
    border-color: rgba(255, 255, 255, 0.6);
  }

  .feature-btn-{{ section.id }} img {
    width: 30px;
    height: 30px;
    object-fit: contain;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .feature-btn-{{ section.id }}.active img {
    opacity: 1;
  }

  .progress-ring-wrapper-{{ section.id }} {
    position: absolute;
    top: -7px;
    left: -7px;
    width: 78px;
    height: 78px;
    z-index: -1;
  }

  .progress-ring-{{ section.id }} {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .feature-btn-{{ section.id }}.active .progress-ring-{{ section.id }} {
    opacity: 1;
  }

  .progress-ring-circle-{{ section.id }} {
    fill: none;
    stroke-width: 5;
    stroke-dasharray: 188.5;
    stroke-dashoffset: 188.5;
    transition: stroke-dashoffset 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .percentage-label-{{ section.id }} {
    position: absolute;
    top: -28px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.3s ease;
    white-space: nowrap;
    pointer-events: none;
  }

  .feature-btn-{{ section.id }}.active .percentage-label-{{ section.id }} {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .feature-container-{{ section.id }} {
      min-height: 600px;
    }

    .feature-image-{{ section.id }} {
      display: none;
    }

    .feature-image-mobile-{{ section.id }} {
      display: block;
    }

    .feature-content-{{ section.id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 315px;
      top: 20px;
      left: 20px;
      right: 20px;
      bottom: auto;
      position: absolute;
      display: flex;
      justify-content: flex-start;
      height: 100%;
    }

    .text-content-{{ section.id }} {
      max-width: 100%;
      position: relative !important;
      opacity: 1 !important;
      transform: translateY(0) !important;
      display: none;
    }

    .text-content-{{ section.id }}.active {
      display: block;
    }

    .feature-title-{{ section.id }} {
      font-size: 18px;
      margin-bottom: 12px;
    }

    .feature-description-{{ section.id }} {
      font-size: 14px;
      line-height: 1.6;
    }

    .feature-buttons-{{ section.id }} {
      gap: 12px;
      flex-wrap: wrap;
      margin-left: 0;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      margin-top: auto;
      position: absolute;
      bottom: 37px;
    }

    .feature-btn-{{ section.id }} {
      width: 58px;
      height: 58px;
      border: 4px solid rgba(218, 218, 218, 0.3);
      position: relative;
    }

    .feature-btn-{{ section.id }} img {
      width: 24px;
      height: 24px;
    }

    .progress-ring-wrapper-{{ section.id }} {
      top: -4px;
      left: -4px;
      width: 58px;
      height: 58px;
    }

    .progress-ring-circle-{{ section.id }} {
      stroke-width: 4;
      stroke-dasharray: 157;
      stroke-dashoffset: 157;
    }

    .percentage-label-{{ section.id }} {
      font-size: 9px;
      top: -20px;
    }
  }

    @media (min-width: 1700px) {
    .feature-container-{{ section.id }} {
      min-height: 720px;
    }

    .content-block-2, .content-block-1 {
    max-width: 900px;
}


    }

</style>

<div class="page-width sustainable-section-{{ section.id }}">
  <div class="feature-container-{{ section.id }}" id="featureContainer{{ section.id }}">
    
    {% comment %} Desktop Background Images {% endcomment %}
    {% for block in section.blocks %}
      {% if block.settings.background_image %}
        <img 
          src="{{ block.settings.background_image | image_url: width: 1400 }}"
          alt="{{ block.settings.title }}"
          class="feature-image-{{ section.id }} {% if forloop.first %}active{% endif %}"
          data-block-id="{{ block.id }}"
          loading="lazy"
        >
      {% endif %}
    {% endfor %}

    {% comment %} Mobile Background Images {% endcomment %}
    {% for block in section.blocks %}
      {% if block.settings.background_image_mobile %}
        <img 
          src="{{ block.settings.background_image_mobile | image_url: width: 800 }}"
          alt="{{ block.settings.title }}"
          class="feature-image-mobile-{{ section.id }} {% if forloop.first %}active{% endif %}"
          data-block-id="{{ block.id }}"
          loading="lazy"
        >
      {% elsif block.settings.background_image %}
        <img 
          src="{{ block.settings.background_image | image_url: width: 800 }}"
          alt="{{ block.settings.title }}"
          class="feature-image-mobile-{{ section.id }} {% if forloop.first %}active{% endif %}"
          data-block-id="{{ block.id }}"
          loading="lazy"
        >
      {% endif %}
    {% endfor %}

    {% comment %} Overlay {% endcomment %}
    <div class="overlay-{{ section.id }}"></div>

    {% comment %} Content Overlay {% endcomment %}
    <div class="feature-content-{{ section.id }}">
      
      {% comment %} Text Content Container {% endcomment %}
      <div style="position: relative; flex: 1;">
        {% for block in section.blocks %}
          <div 
            class="text-content-{{ section.id }} {% if forloop.first %}active{% endif %}"
            data-block-id="{{ block.id }}"
            style="color: {{ block.settings.text_color }};"
          >
            <h2 class="feature-title-{{ section.id }}">{{ block.settings.title }}</h2>
            <p class="feature-description-{{ section.id }}">{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      </div>

      {% comment %} Feature Buttons {% endcomment %}
      <div class="feature-buttons-{{ section.id }}">
        {% for block in section.blocks %}
          <button 
            class="feature-btn-{{ section.id }} {% if forloop.first %}active{% endif %}"
            data-block-id="{{ block.id }}"
            data-progress="{{ block.settings.progress_percentage }}"
            data-index="{{ forloop.index0 }}"
            type="button"
            aria-label="{{ block.settings.title }}"
          >
            {% comment %} Progress Ring Container {% endcomment %}
            <div class="progress-ring-wrapper-{{ section.id }}">
              <svg class="progress-ring-{{ section.id }}" viewBox="0 0 66 66">
                <circle 
                  class="progress-ring-circle-{{ section.id }}"
                  cx="33" 
                  cy="33" 
                  r="30"
                  style="stroke: {{ block.settings.progress_ring_color }};"
                ></circle>
              </svg>
            </div>
            
            {% if block.settings.button_icon %}
              <img 
                src="{{ block.settings.button_icon | image_url: width: 64 }}" 
                alt="{{ block.settings.title }}"
              >
            {% endif %}
            
          </button>
        {% endfor %}
      </div>

    </div>
  </div>
</div>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  let isMobile = window.innerWidth <= 768;
  let autoSwitchInterval;
  let isAutoSwitching = true;
  let currentIndex = 0;
  const buttons = [];
  const totalFeatures = {{ section.blocks.size }};
  
  // Initialize buttons array
  function initButtonsArray() {
    buttons.length = 0;
    document.querySelectorAll(`.feature-btn-${sectionId}`).forEach(btn => {
      buttons.push(btn);
    });
  }
  
  // Update mobile detection on resize
  function updateMobileDetection() {
    isMobile = window.innerWidth <= 768;
  }
  
  // Calculate circumference based on screen size
  function getCircumference() {
    const radius = isMobile ? 28 : 34;
    return 2 * Math.PI * radius;
  }
  
  function switchFeature(blockId) {
    if (isMobile) {
      // Mobile: use mobile images
      document.querySelectorAll(`.feature-image-mobile-${sectionId}`).forEach(img => {
        img.classList.toggle('active', img.dataset.blockId === blockId);
      });
    } else {
      // Desktop: use desktop images
      document.querySelectorAll(`.feature-image-${sectionId}`).forEach(img => {
        img.classList.toggle('active', img.dataset.blockId === blockId);
      });
    }

    // Update text content
    document.querySelectorAll(`.text-content-${sectionId}`).forEach(text => {
      text.classList.toggle('active', text.dataset.blockId === blockId);
    });

    // Update buttons and progress rings
    document.querySelectorAll(`.feature-btn-${sectionId}`).forEach(btn => {
      const isActive = btn.dataset.blockId === blockId;
      btn.classList.toggle('active', isActive);
      
      // Update progress ring - only for active button
      const circle = btn.querySelector(`.progress-ring-circle-${sectionId}`);
      if (isActive) {
        const progress = parseInt(btn.dataset.progress);
        const circumference = getCircumference();
        const offset = circumference - (circumference * progress / 100);
        circle.style.strokeDasharray = circumference;
        circle.style.strokeDashoffset = offset;
        
        // Update current index
        currentIndex = parseInt(btn.dataset.index);
      } else {
        // Reset non-active buttons
        const circumference = getCircumference();
        circle.style.strokeDasharray = circumference;
        circle.style.strokeDashoffset = circumference;
      }
    });
  }

  // Switch to next feature automatically
  function switchToNextFeature() {
    if (!isAutoSwitching) return;
    
    currentIndex = (currentIndex + 1) % totalFeatures;
    const nextBtn = buttons[currentIndex];
    if (nextBtn) {
      switchFeature(nextBtn.dataset.blockId);
    }
  }

  // Initialize progress rings with correct dimensions
  function initializeProgressRings() {
    const circumference = getCircumference();
    
    document.querySelectorAll(`.progress-ring-circle-${sectionId}`).forEach(circle => {
      circle.style.strokeDasharray = circumference;
      circle.style.strokeDashoffset = circumference;
    });
    
    // Update active ring
    const activeBtn = document.querySelector(`.feature-btn-${sectionId}.active`);
    if (activeBtn) {
      const progress = parseInt(activeBtn.dataset.progress);
      const offset = circumference - (circumference * progress / 100);
      const circle = activeBtn.querySelector(`.progress-ring-circle-${sectionId}`);
      if (circle) {
        circle.style.strokeDashoffset = offset;
      }
    }
  }

  // Add click event listeners to buttons
  function initializeButtons() {
    initButtonsArray();
    
    document.querySelectorAll(`.feature-btn-${sectionId}`).forEach(btn => {
      // Remove existing listeners to avoid duplicates
      const newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);
    });
    
    // Re-query after cloning
    document.querySelectorAll(`.feature-btn-${sectionId}`).forEach(btn => {
      btn.addEventListener('click', handleButtonClick);
      btn.addEventListener('touchstart', handleButtonTouch, { passive: true });
      
      // Pause auto-switching on hover
      btn.addEventListener('mouseenter', () => {
        isAutoSwitching = false;
        clearInterval(autoSwitchInterval);
      });
      
      btn.addEventListener('mouseleave', () => {
        isAutoSwitching = true;
        startAutoSwitch();
      });
    });
    
    function handleButtonClick() {
      isAutoSwitching = false;
      clearInterval(autoSwitchInterval);
      switchFeature(this.dataset.blockId);
      
      // Restart auto-switch after 5 seconds of inactivity
      setTimeout(() => {
        isAutoSwitching = true;
        startAutoSwitch();
      }, 3000);
    }
    
    function handleButtonTouch(e) {
      e.preventDefault();
      isAutoSwitching = false;
      clearInterval(autoSwitchInterval);
      switchFeature(this.dataset.blockId);
      
      // Restart auto-switch after 5 seconds of inactivity
      setTimeout(() => {
        isAutoSwitching = true;
        startAutoSwitch();
      }, 3000);
    }
  }

  // Start auto-switch interval
  function startAutoSwitch() {
    if (autoSwitchInterval) {
      clearInterval(autoSwitchInterval);
    }
    
    autoSwitchInterval = setInterval(switchToNextFeature, 3000);
  }

  // Initialize everything
  function initializeFeatureSection() {
    updateMobileDetection();
    initializeProgressRings();
    initializeButtons();
    startAutoSwitch();
    
    // Activate first feature
    const firstBtn = document.querySelector(`.feature-btn-${sectionId}.active`);
    if (firstBtn) {
      currentIndex = parseInt(firstBtn.dataset.index);
      switchFeature(firstBtn.dataset.blockId);
    }
  }

  // Handle responsive adjustments
  function handleResize() {
    const wasMobile = isMobile;
    updateMobileDetection();
    
    if (wasMobile !== isMobile) {
      initializeProgressRings();
      // Switch feature to update image source
      const activeBtn = document.querySelector(`.feature-btn-${sectionId}.active`);
      if (activeBtn) {
        switchFeature(activeBtn.dataset.blockId);
      }
    }
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      initializeFeatureSection();
      window.addEventListener('resize', handleResize);
    });
  } else {
    initializeFeatureSection();
    window.addEventListener('resize', handleResize);
  }

  // Pause auto-switch when tab is not visible
  document.addEventListener('visibilitychange', function() {
    if (document.hidden) {
      clearInterval(autoSwitchInterval);
    } else {
      if (isAutoSwitching) {
        startAutoSwitch();
      }
    }
  });

  // Cleanup on page unload
  window.addEventListener('beforeunload', function() {
    clearInterval(autoSwitchInterval);
  });
})();
</script>

{% schema %}
{
  "name": "Sustainable Features",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Section Padding Top",
      "default": 50
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Section Padding Bottom",
      "default": 50
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "header",
          "content": "Feature Content"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "WATER RESPONSIBLE"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Lab grown diamonds significantly reduce water usage compared to traditional mining. Our process prioritizes conservation, ensuring beauty without depleting one of Earth's most vital resources."
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background Image (Desktop)"
        },
        {
          "type": "image_picker",
          "id": "background_image_mobile",
          "label": "Background Image (Mobile)",
          "info": "Optional. If not provided, desktop image will be used as fallback"
        },
        {
          "type": "header",
          "content": "Button Settings"
        },
        {
          "type": "image_picker",
          "id": "button_icon",
          "label": "Button Icon",
          "info": "Upload a PNG or SVG icon (recommended size: 64x64px)"
        },
        {
          "type": "range",
          "id": "progress_percentage",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "Progress Percentage",
          "default": 75
        },
        {
          "type": "text",
          "id": "progress_label",
          "label": "Progress Label",
          "default": "Saved",
          "info": "Text to display after percentage (e.g., 'Saved', 'Reduced', 'Less')"
        },
        {
          "type": "header",
          "content": "Style Settings"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button Background Color",
          "default": "#ffffff",
          "info": "Color with transparency applied"
        },
        {
          "type": "color",
          "id": "progress_ring_color",
          "label": "Progress Ring Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sustainable Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "WATER RESPONSIBLE",
            "description": "Lab grown diamonds significantly reduce water usage compared to traditional mining. Our process prioritizes conservation, ensuring beauty without depleting one of Earth's most vital resources.",
            "progress_percentage": 75,
            "progress_label": "Saved"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "CARBON NEUTRAL",
            "description": "Our lab-grown diamonds are created with renewable energy sources, achieving carbon neutrality. We're committed to reducing our environmental footprint while delivering exceptional quality.",
            "progress_percentage": 90,
            "progress_label": "Saved"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "ENERGY EFFICIENT",
            "description": "Advanced technology allows us to create diamonds using 80% less energy than traditional mining. Sustainable luxury is now a reality with our innovative processes.",
            "progress_percentage": 80,
            "progress_label": "Saved"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "ETHICALLY SOURCED",
            "description": "100% conflict-free and ethically created in controlled environments. Our diamonds represent a new era of conscious luxury without compromise on brilliance or beauty.",
            "progress_percentage": 100,
            "progress_label": "Saved"
          }
        }
      ]
    }
  ]
}
{% endschema %}