          "default": "#ffffff",
          "info": "Color with transparency applied"
        },
        {
          "type": "color",
          "id": "progress_ring_color",
          "label": "Progress Ring Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sustainable Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "WATER RESPONSIBLE",
            "description": "Lab grown diamonds significantly reduce water usage compared to traditional mining. Our process prioritizes conservation, ensuring beauty without depleting one of Earth's most vital resources.",
            "progress_percentage": 75,
            "progress_label": "Saved"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "CARBON NEUTRAL",
            "description": "Our lab-grown diamonds are created with renewable energy sources, achieving carbon neutrality. We're committed to reducing our environmental footprint while delivering exceptional quality.",
            "progress_percentage": 90,
            "progress_label": "Saved"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "ENERGY EFFICIENT",
            "description": "Advanced technology allows us to create diamonds using 80% less energy than traditional mining. Sustainable luxury is now a reality with our innovative processes.",
            "progress_percentage": 80,
            "progress_label": "Saved"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "ETHICALLY SOURCED",
            "description": "100% conflict-free and ethically created in controlled environments. Our diamonds represent a new era of conscious luxury without compromise on brilliance or beauty.",
            "progress_percentage": 100,
            "progress_label": "Saved"
          }
        }
      ]
    }
  ]
}
{% endschema %}
