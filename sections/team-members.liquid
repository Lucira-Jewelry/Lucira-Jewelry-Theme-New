<style>
.page-our-team-template-page .image-with-text-overlay__heading{color:#1a1a1a}
.page-our-team-template-page .image-with-text-overlay__content{margin-bottom:0}
.team-section{padding:60px;max-width:1400px;margin:0 auto}
.team-filters-desktop{display:flex;gap:10px;justify-content:left;flex-wrap:wrap;margin-bottom:40px}
.team-filters-mobile{display:none;margin-bottom:40px}
.filter-dropdown{width:100%;max-width:500px;margin:0 auto;position:relative}
.dropdown-selected{background:#f5f2ef;border:1px solid #d4cdc5;padding:16px 20px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-size:14px;text-transform:uppercase;letter-spacing:1px;font-weight:500;color:#1a1a1a;border-radius:4px}
.dropdown-selected svg.active::after{transform:rotate(200deg)}
.dropdown-options{position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid #d4cdc5;border-top:none;max-height:0;overflow:hidden;transition:max-height .3s ease;z-index:10;box-shadow:0 4px 6px rgba(0,0,0,.1)}
.dropdown-options.active{max-height:400px;border-top:1px solid #d4cdc5;margin-top:2px}
.dropdown-option{padding:16px 20px;cursor:pointer;font-size:14px;text-transform:uppercase;letter-spacing:1px;color:#1a1a1a;border-bottom:1px solid #f0f0f0;transition:background .2s ease}
.dropdown-option:last-child{border-bottom:none}
.dropdown-option:hover{background:#f5f2ef}
.filter-btn{padding:10px 24px;border:none;color:#a68380;text-transform:uppercase;font-size:12px;letter-spacing:1px;line-height:1.7;cursor:pointer;border-radius:12px;transition:all .3s ease;font-weight:500;background:0 0;border:solid 1px #a68380}
.filter-btn.active,.filter-btn:hover{background:#a68380;color:#fff}
.team-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px;margin-top:40px}
.team-member{transition:opacity .3s ease,transform .3s ease}
.team-member.hidden{display:none}
.team-member-card{position:relative;overflow:hidden;cursor:pointer}
.team-member-image{position:relative;width:100%;aspect-ratio:3/4;overflow:hidden}
.team-member-image img{width:100%;height:100%;object-fit:cover;transition:opacity .4s ease;border-top-left-radius:12px;border-top-right-radius:12px}
.team-member-image .image-primary{position:relative;z-index:1}
.team-member-image .image-hover{position:absolute;top:0;left:0;opacity:0;z-index:2}
.team-member-card:hover .image-hover{opacity:1}
.team-member-info{background:#eae2e1;color:#1a1a1a;padding:20px;text-align:center;border-bottom-right-radius:12px;border-bottom-left-radius:12px;position:relative;bottom:40px;z-index:2}
.team-member-name{font-size:16px;font-weight:500;text-transform:uppercase;letter-spacing:2px;margin:0 0 8px 0;color:#1a1a1a}
.team-member-title{font-size:12px;text-transform:uppercase;letter-spacing:.5px;font-weight:400;margin:0}
@media (max-width:768px){
.team-filters-desktop{display:none}
.team-filters-mobile{display:block}
.team-grid{grid-template-columns:repeat(2,2fr);gap:20px}
.team-section{padding:60px 20px}
}
</style>

<div class="team-section">
  <div class="team-filters-desktop">
    <button class="filter-btn active" data-filter="all">All</button>
    {% if section.settings.show_tech %}
      <button class="filter-btn" data-filter="tech">Tech</button>
    {% endif %}
    {% if section.settings.show_marketing %}
      <button class="filter-btn" data-filter="marketing">Marketing</button>
    {% endif %}
    {% if section.settings.show_social %}
      <button class="filter-btn" data-filter="social">Social</button>
    {% endif %}
    {% if section.settings.show_creative %}
      <button class="filter-btn" data-filter="creative">Creative</button>
    {% endif %}
    {% if section.settings.show_content %}
      <button class="filter-btn" data-filter="content">Content</button>
    {% endif %}
    {% if section.settings.show_finance %}
      <button class="filter-btn" data-filter="finance">Finance</button>
    {% endif %}
    {% if section.settings.show_product %}
      <button class="filter-btn" data-filter="product">Product</button>
    {% endif %}
    {% if section.settings.show_sales %}
      <button class="filter-btn" data-filter="sales">Sales</button>
    {% endif %}
  </div>

  {% comment %} Mobile Dropdown {% endcomment %}
  <div class="team-filters-mobile">
    <div class="filter-dropdown">
      <div class="dropdown-selected" id="dropdownSelected">
        ALL
        <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4.89456 3.93296L8.62814 0.199146C8.7551 0.0723403 8.91468 0.00740978 9.10687 0.00435422C9.29891 0.00145144 9.46139 0.066382 9.59431 0.199146C9.72708 0.332063 9.79346 0.49309 9.79346 0.682229C9.79346 0.871368 9.72708 1.0324 9.59431 1.16531L5.47458 5.28504C5.38872 5.37075 5.2982 5.43125 5.20302 5.46654C5.10784 5.50183 5.00502 5.51948 4.89456 5.51948C4.7841 5.51948 4.68128 5.50183 4.5861 5.46654C4.49092 5.43125 4.4004 5.37075 4.31454 5.28504L0.19481 1.16531C0.0680041 1.03835 0.00307386 0.878778 1.83049e-05 0.686583C-0.00288447 0.494541 0.0620457 0.332063 0.19481 0.199146C0.327726 0.066382 0.488754 0 0.677893 0C0.867032 0 1.02806 0.066382 1.16098 0.199146L4.89456 3.93296Z" fill="#666666"/>
        </svg>

      </div>
      <div class="dropdown-options" id="dropdownOptions">
        <div class="dropdown-option" data-filter="all">ALL</div>
        {% if section.settings.show_tech %}
          <div class="dropdown-option" data-filter="tech">TECH</div>
        {% endif %}
        {% if section.settings.show_marketing %}
          <div class="dropdown-option" data-filter="marketing">MARKETING</div>
        {% endif %}
        {% if section.settings.show_social %}
          <div class="dropdown-option" data-filter="social">SOCIAL</div>
        {% endif %}
        {% if section.settings.show_creative %}
          <div class="dropdown-option" data-filter="creative">CREATIVE</div>
        {% endif %}
        {% if section.settings.show_content %}
          <div class="dropdown-option" data-filter="content">CONTENT</div>
        {% endif %}
        {% if section.settings.show_finance %}
          <div class="dropdown-option" data-filter="finance">FINANCE</div>
        {% endif %}
        {% if section.settings.show_product %}
          <div class="dropdown-option" data-filter="product">PRODUCT</div>
        {% endif %}
        {% if section.settings.show_sales %}
          <div class="dropdown-option" data-filter="sales">SALES</div>
        {% endif %}
      </div>
    </div>
  </div>

  {% comment %} Team Members Grid {% endcomment %}
  <div class="team-grid" id="teamGrid">
    {% assign team_members = section.settings.team_members %}
    
    {% comment %} Sort by order field {% endcomment %}
    {% assign sorted_members = team_members | sort: 'order' %}
    
    {% if sorted_members.size > 0 %}
      {% for member in sorted_members %}
        <div class="team-member" data-department="{{ member.department | downcase }}">
          <div class="team-member-card">
            <div class="team-member-image">
              {% if member.image_primary %}
                <img 
                  class="image-primary" 
                  src="{{ member.image_primary | image_url: width: 500 }}" 
                  alt="{{ member.name }}"
                  loading="lazy"
                >
              {% endif %}
              
              {% if member.image_hover %}
                <img 
                  class="image-hover" 
                  src="{{ member.image_hover | image_url: width: 500 }}" 
                  alt="{{ member.name }} hover"
                  loading="lazy"
                >
              {% endif %}
            </div>
            
            <div class="team-member-info">
              <h3 class="team-member-name">{{ member.name }}</h3>
              <p class="team-member-title">{{ member.title }}</p>
            </div>
          </div>
        </div>
      {% endfor %}
    {% else %}
      <p style="text-align: center; grid-column: 1/-1; color: #666666;">
        OUR TEAM IS BUILDING 
      </p>
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const teamMembers = document.querySelectorAll('.team-member');
    const dropdownSelected = document.getElementById('dropdownSelected');
    const dropdownOptions = document.getElementById('dropdownOptions');
    const dropdownOptionItems = document.querySelectorAll('.dropdown-option');

    // Desktop filter buttons
    filterBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        const filter = this.getAttribute('data-filter');
        
        // Update active button
        filterBtns.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        
        // Filter team members
        filterTeamMembers(filter);
      });
    });

    // Mobile dropdown toggle
    dropdownSelected.addEventListener('click', function() {
      this.classList.toggle('active');
      dropdownOptions.classList.toggle('active');
    });

    // Mobile dropdown options
    dropdownOptionItems.forEach(option => {
      option.addEventListener('click', function() {
        const filter = this.getAttribute('data-filter');
        const text = this.textContent;
        
        // Update selected text
        dropdownSelected.textContent = text;
        
        // Close dropdown
        dropdownSelected.classList.remove('active');
        dropdownOptions.classList.remove('active');
        
        // Filter team members
        filterTeamMembers(filter);
      });
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', function(event) {
      if (!event.target.closest('.filter-dropdown')) {
        dropdownSelected.classList.remove('active');
        dropdownOptions.classList.remove('active');
      }
    });

    // Filter function
    function filterTeamMembers(filter) {
      teamMembers.forEach(member => {
        const department = member.getAttribute('data-department');
        
        if (filter === 'all' || department === filter) {
          member.classList.remove('hidden');
        } else {
          member.classList.add('hidden');
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Team Members",
  "settings": [
    {
      "type": "metaobject_list",
      "id": "team_members",
      "label": "Team Members",
      "metaobject_type": "team_member"
    },
    {
      "type": "header",
      "content": "Department Filters"
    },
    {
      "type": "checkbox",
      "id": "show_tech",
      "label": "Show Tech Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_marketing",
      "label": "Show Marketing Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_creative",
      "label": "Show Creative Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_content",
      "label": "Show Content Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_finance",
      "label": "Show Finance Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product",
      "label": "Show Product Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sales",
      "label": "Show Sales Filter",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Team Members"
    }
  ]
}
{% endschema %}