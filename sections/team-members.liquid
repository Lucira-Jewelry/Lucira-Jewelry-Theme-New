<style>

.page-our-team-template-page .image-with-text-overlay__heading{
color:#1a1a1a;
}
.page-our-team-template-page .image-with-text-overlay__content{
margin-bottom:0;
}

.team-section {
padding: 60px 20px;
max-width: 1400px;
margin: 0 auto;
}

.team-filters {
display: flex;
gap: 10px;
justify-content: center;
flex-wrap: wrap;
margin-bottom: 40px;
}

.filter-btn {
padding: 10px 24px;
border: none;
background: #9b8b7e;
color: white;
text-transform: uppercase;
font-size: 11px;
letter-spacing: 1px;
cursor: pointer;
border-radius: 4px;
transition: all 0.3s ease;
font-weight: 500;
}

.filter-btn:hover,
.filter-btn.active {
background: #7a6d63;
transform: translateY(-2px);
}

.team-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
gap: 30px;
margin-top: 40px;
}

.team-member {
transition: opacity 0.3s ease, transform 0.3s ease;
}

.team-member.hidden {
display: none;
}

.team-member-card {
position: relative;
overflow: hidden;
cursor: pointer;
}

.team-member-image {
position: relative;
width: 100%;
aspect-ratio: 3/4;
overflow: hidden;
}

.team-member-image img {
width: 100%;
height: 100%;
object-fit: cover;
transition: opacity 0.4s ease;
}

.team-member-image .image-primary {
position: relative;
z-index: 1;
}

.team-member-image .image-hover {
position: absolute;
top: 0;
left: 0;
opacity: 0;
z-index: 2;
}

.team-member-card:hover .image-hover {
opacity: 1;
}

.team-member-info {
background: #666;
color: white;
padding: 20px;
text-align: center;
}

.team-member-name {
font-size: 16px;
font-weight: 600;
text-transform: uppercase;
letter-spacing: 1px;
margin: 0 0 8px 0;
}

.team-member-title {
font-size: 12px;
text-transform: uppercase;
letter-spacing: 0.5px;
opacity: 0.9;
margin: 0;
}

@media (max-width: 768px) {
.team-grid {
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
}
}
</style>

<div class="team-section">
  <div class="team-filters">
    <button class="filter-btn active" data-filter="all">All</button>
    {% if section.settings.show_tech %}
      <button class="filter-btn" data-filter="tech">Tech</button>
    {% endif %}
    {% if section.settings.show_marketing %}
      <button class="filter-btn" data-filter="marketing">Marketing</button>
    {% endif %}
    {% if section.settings.show_social %}
      <button class="filter-btn" data-filter="social">Social</button>
    {% endif %}
    {% if section.settings.show_creative %}
      <button class="filter-btn" data-filter="creative">Creative</button>
    {% endif %}
    {% if section.settings.show_content %}
      <button class="filter-btn" data-filter="content">Content</button>
    {% endif %}
    {% if section.settings.show_finance %}
      <button class="filter-btn" data-filter="finance">Finance</button>
    {% endif %}
    {% if section.settings.show_product %}
      <button class="filter-btn" data-filter="product">Product</button>
    {% endif %}
    {% if section.settings.show_sales %}
      <button class="filter-btn" data-filter="sales">Sales</button>
    {% endif %}
  </div>

  {% comment %} Team Members Grid {% endcomment %}
  <div class="team-grid" id="teamGrid">
    {% assign team_members = section.settings.team_members %}
    
    {% comment %} Sort by order field {% endcomment %}
    {% assign sorted_members = team_members | sort: 'order' %}
    
    {% if sorted_members.size > 0 %}
      {% for member in sorted_members %}
        <div class="team-member" data-department="{{ member.department | downcase }}">
          <div class="team-member-card">
            <div class="team-member-image">
              {% if member.image_primary %}
                <img 
                  class="image-primary" 
                  src="{{ member.image_primary | image_url: width: 500 }}" 
                  alt="{{ member.name }}"
                  loading="lazy"
                >
              {% endif %}
              
              {% if member.image_hover %}
                <img 
                  class="image-hover" 
                  src="{{ member.image_hover | image_url: width: 500 }}" 
                  alt="{{ member.name }} hover"
                  loading="lazy"
                >
              {% endif %}
            </div>
            
            <div class="team-member-info">
              <h3 class="team-member-name">{{ member.name }}</h3>
              <p class="team-member-title">{{ member.title }}</p>
            </div>
          </div>
        </div>
      {% endfor %}
    {% else %}
      <p style="text-align: center; grid-column: 1/-1; color: #666666;">
        OUR TEAM IS BUILDING 
      </p>
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const teamMembers = document.querySelectorAll('.team-member');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        const filter = this.getAttribute('data-filter');
        
        // Update active button
        filterBtns.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        
        // Filter team members
        teamMembers.forEach(member => {
          const department = member.getAttribute('data-department');
          
          if (filter === 'all' || department === filter) {
            member.classList.remove('hidden');
          } else {
            member.classList.add('hidden');
          }
        });
      });
    });
  });
</script>

{% schema %}
{
  "name": "Team Members",
  "settings": [
    {
      "type": "metaobject_list",
      "id": "team_members",
      "label": "Team Members",
      "metaobject_type": "team_member"
    },
    {
      "type": "header",
      "content": "Department Filters"
    },
    {
      "type": "checkbox",
      "id": "show_tech",
      "label": "Show Tech Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_marketing",
      "label": "Show Marketing Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_creative",
      "label": "Show Creative Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_content",
      "label": "Show Content Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_finance",
      "label": "Show Finance Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product",
      "label": "Show Product Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sales",
      "label": "Show Sales Filter",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Team Members"
    }
  ]
}
{% endschema %}