{{ 'customer.css' | asset_url | stylesheet_tag: preload: true }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .order-status-meta{display:flex;align-items:center;gap:8px;margin-top:6px;flex-wrap:wrap}
  .order-status-text-label{font-size:12px;text-transform:uppercase;letter-spacing:.04em;color:#666;font-weight:500}
  .order-status-chip{display:inline-flex;align-items:center;gap:4px;padding:0;border-radius:999px;font-size:12px;line-height:1.2;font-weight:500;color:#333;white-space:nowrap}

  /* Mobile Drawer Styles */
  .order-timeline-drawer {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999999;
  }

  .order-timeline-drawer.is-open {
    display: block;
  }

  .drawer-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    animation: fadeIn 0.3s ease;
  }

  .drawer-content { 
    position: absolute; 
    bottom: 0; 
    left: 0; 
    width: 100%; 
    max-height: 85vh; 
    background: #fff; 
    border-radius: 20px 20px 0 0; 
    padding: 20px 20px 80px 20px; 
    overflow-y: auto; 
    animation: slideUp 0.3s ease; 
  }

  .drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    padding-bottom: 15px;
    border-bottom: 1px solid #e5e5e5;
  }

  .drawer-title { 
    font-size: 18px; 
    font-weight: 500; 
    color: #333; 
    font-family: 'Futura Std', sans-serif !important; 
  }

  .drawer-close { 
    border: none; 
    color: #666; 
    cursor: pointer; 
    padding: 0; 
    width: 32px; 
    height: 32px; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    background: #f0f0f0; 
    border-radius: 50%; 
    font-size: 24px; 
  }

  .drawer-timeline {
    position: relative;
    padding-left: 40px;
  }

  .drawer-step {
    position: relative;
    padding-bottom: 30px;
  }

  .drawer-step:last-child {
    padding-bottom: 0;
  }

  .drawer-step::before {
    content: '';
    position: absolute;
    left: -29px;
    top: 12px;
    bottom: -18px;
    width: 2px;
    background: #e5e5e5;
  }

  .drawer-step.is-complete::before {
    background: #b77766;
  }

  .drawer-step:last-child::before {
    display: none;
  }

  .drawer-step__dot {
    position: absolute;
    left: -36px;
    top: 0;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid #e5e5e5;
    background: #fff;
  }

  .drawer-step__dot::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #e5e5e5;
  }

  .drawer-step.is-complete .drawer-step__dot {
    border-color: #b77766;
    background: #b77766;
  }

  .drawer-step.is-complete .drawer-step__dot::after {
    background: #fff;
  }

  .drawer-step.is-current .drawer-step__dot {
    width: 20px;
    height: 20px;
    left: -38px;
    border-width: 3px;
    border-color: #b67766;
    background: #fff;
  }

  .drawer-step.is-current .drawer-step__dot::after {
    width: 8px;
    height: 8px;
    background: #b67766;
  }

  .drawer-step__label {
    font-size: 15px;
    font-weight: 500;
    color: #333;
    margin-bottom: 4px;
  }

  .drawer-step.is-complete .drawer-step__label {
    color: #b77766;
  }

  .drawer-step.is-current .drawer-step__label {
    color: #1a1a1a;
    font-weight: 500;
  }

  .drawer-step__date {
    font-size: 13px;
    color: #666;
  }

  .drawer-step.is-pending .drawer-step__label,
  .drawer-step.is-pending .drawer-step__date {
    color: #999;
  }

  .see-updates-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: #f5f5f5;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    font-size: 13px;
    color: #333;
    cursor: pointer;
    margin-top: 10px;
  }

  @media (min-width: 750px) {
    .see-updates-btn {
      display: none;
    }

    button.see-updates-btn {
      display: none !important;
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }
{%- endstyle -%}

{% assign is_in_stock = true %}
{% assign has_out_of_stock = false %}

{% for line_item in order.line_items %}
  {% assign variant = line_item.variant %}
  {% assign product = line_item.product %}
  
  {% if product.tags contains 'made-to-order' or product.tags contains 'preorder' or product.tags contains 'out-of-stock' %}
    {% assign has_out_of_stock = true %}
    {% break %}
  {% elsif product.tags contains 'in-stock' or product.tags contains 'quick-ship' %}
    {% continue %}
  {% endif %}
  
  {% if variant.inventory_management == "shopify" %}
    {% if variant.inventory_quantity <= 0 %}
      {% assign has_out_of_stock = true %}
      {% break %}
    {% endif %}
  {% endif %}
{% endfor %}

{% if has_out_of_stock %}
  {% assign is_in_stock = false %}
{% endif %}

{% if is_in_stock %}
  {% assign total_days = 4 %}
{% else %}
  {% assign total_days = 15 %}
{% endif %}

{% assign stages = "Order Confirmed|Processing|Manufacturing|Quality Control|Certification|Dispatch|In Transit|Delivery" | split: "|" %}

{% assign stage_days = "0|0|" %}
{% if is_in_stock %}
  {% assign stage_days = stage_days | append: "1|1|1|1|0|0" %}
{% else %}
  {% assign stage_days = stage_days | append: "5|3|3|2|1|1" %}
{% endif %}
{% assign stage_days_array = stage_days | split: "|" %}

{% assign current_stage_index = 0 %}
{% if order.cancelled %}
  {% assign current_stage_index = 0 %}
{% elsif order.fulfillment_status == 'fulfilled' %}
  {% assign current_stage_index = 7 %}
{% elsif order.fulfillments.size > 0 %}
  {% assign has_tracking = false %}
  {% for f in order.fulfillments %}
    {% if f.tracking_number or f.tracking_numbers.size > 0 or f.tracking_url %}
      {% assign has_tracking = true %}
    {% endif %}
  {% endfor %}
  {% if has_tracking %}
    {% assign current_stage_index = 6 %}
  {% else %}
    {% assign current_stage_index = 5 %}
  {% endif %}
{% elsif order.financial_status == 'paid' or order.financial_status == 'partially_paid' %}
  {% assign current_stage_index = 2 %}
{% elsif order.financial_status == 'authorized' or order.financial_status == 'pending' %}
  {% assign current_stage_index = 1 %}
{% else %}
  {% assign current_stage_index = 0 %}
{% endif %}

{% assign total_steps = stages.size | minus: 1 %}
{% assign percent = current_stage_index | times: 100 | divided_by: total_steps %}

{% assign current_stage_label = '' %}
{% for s in stages %}
  {% if forloop.index0 == current_stage_index %}
    {% assign current_stage_label = s %}
  {% endif %}
{% endfor %}

{% assign status_chip_class = '' %}
{% if order.cancelled %}
  {% assign status_chip_class = 'status-chip--cancelled' %}
{% elsif order.fulfillment_status == 'fulfilled' %}
  {% assign status_chip_class = 'status-chip--delivered' %}
{% else %}
  {% case current_stage_label %}
    {% when 'Order Confirmed' %}
      {% assign status_chip_class = 'status-chip--confirmed' %}
    {% when 'Processing' %}
      {% assign status_chip_class = 'status-chip--processing' %}
    {% when 'Manufacturing' %}
      {% assign status_chip_class = 'status-chip--manufacturing' %}
    {% when 'Quality Control' %}
      {% assign status_chip_class = 'status-chip--qc' %}
    {% when 'Certification' %}
      {% assign status_chip_class = 'status-chip--certification' %}
    {% when 'Dispatch' %}
      {% assign status_chip_class = 'status-chip--dispatch' %}
    {% when 'In Transit' %}
      {% assign status_chip_class = 'status-chip--in-transit' %}
    {% when 'Delivery' %}
      {% assign status_chip_class = 'status-chip--delivered' %}
  {% endcase %}
{% endif %}

<div class="customer order section-{{ section.id }}-padding order-view--modern">
  <div class="page-width">
    <div class="customer-back-to-account-details">
      <a href="{{ routes.account_url }}"><i class="fa-solid fa-angle-left"></i> Return to Account details</a>
    </div>
  </div>
  <div class="page-width">
    <div class="invoice-logo">
      <img src="https://www.lucirajewelry.com/cdn/shop/files/Website_Logo_N_180.svg?v=1759481962&width=240" alt="Company Logo" width="120" height="auto" />
    </div>
    <div class="customer-details-wrapper">
      <div class="order-head">
        <div class="order-head__left" style="display: none;">
          <h1 class="customer__title">{{ 'customer.account.title' | t }}</h1>
          <a class="order-back" href="{{ routes.account_url }}">{{ 'customer.account.return' | t }}</a>
        </div>
      </div>

      <div class="order-meta">
        <div class="order-no">
          <span>Order No:</span>
          <strong>{{ order.name | remove: '#' }}</strong>

          <div class="order-status-meta"
            data-status="{{ order.fulfillment_status | default: 'unfulfilled' | downcase }}"
            data-marketplace-order-id="{{ order.id }}"
            data-marketplace-item-id="{{ order.line_items.first.id }}">
            <span class="order-status-text-label">Status:</span>
            <span class="order-status-chip {{ status_chip_class }}">
              <span class="order-status-label-js">
                {% if order.cancelled %}
                  Cancelled
                {% elsif order.fulfillment_status == 'fulfilled' %}
                  Delivered
                {% else %}
                  {{ current_stage_label }}
                {% endif %}
              </span>
            </span>
          </div>

        </div>
        <button
          class="order-invoice-btn" 
          type="button">
          <span aria-hidden="true">
            {{- 'order-invoice.svg' | inline_asset_content -}}
          </span>
          Invoice
        </button>

      </div>

      <div class="order-details-wrapper">
        {% if order.cancelled %}
        {%- comment -%}
          Simplified timeline when order is cancelled:
          Only show "Order Confirmed" and "Cancelled".
        {%- endcomment -%}
        <div class="order-timeline order-timeline--cancelled" style="--progress: 100%;">
          <div class="order-steps" role="list" aria-label="Order progress">
            <div class="order-step is-complete" role="listitem" aria-current="false">
              <div class="order-step__label">Order Confirmed</div>
              <div class="order-step__dot"><span style="display:none;"></span></div>
              <div class="order-step__date">
                {{ order.created_at | date: "%a, %-d %b" }}
              </div>
            </div>

        <div class="order-step is-current is-cancelled" role="listitem" aria-current="step">
        <div class="order-step__label">Cancelled</div>
        <div class="order-step__dot"><span style="display:none;"></span></div>
        <div class="order-step__date">
          {% if order.cancelled_at %}
            {{ order.cancelled_at | date: "%a, %-d %b" }}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
        {% else %}
          <div class="order-timeline" style="--progress: {{ percent }}%;">
            <div class="order-steps" role="list" aria-label="Order progress">
              {% assign cumulative_days = 0 %}
              {% for s in stages %}
                {% assign idx = forloop.index0 %}
                
                {% if idx > 0 %}
                  {% assign days_to_add = stage_days_array[idx] | plus: 0 %}
                  {% assign cumulative_days = cumulative_days | plus: days_to_add %}
                {% endif %}
                
                {% assign expected_date = order.created_at | date: "%s" | plus: 0 %}
                {% assign seconds_to_add = cumulative_days | times: 86400 %}
                {% assign expected_date = expected_date | plus: seconds_to_add %}
                
                <div class="order-step {% if idx <= current_stage_index %}is-complete{% endif %}"
                    role="listitem"
                    aria-current="{% if idx == current_stage_index %}step{% else %}false{% endif %}">
                  <div class="order-step__label">{{ s }}</div>
                  <div class="order-step__dot"><span style="display: none;"></span></div>
                  <div class="order-step__date">
                    {% if idx <= current_stage_index %}
                      {% if idx == 0 %}
                        {{ order.created_at | date: "%a, %-d %b" }}
                      {% else %}
                        {{ order.created_at | date: "%a, %-d %b" }}
                      {% endif %}
                    {% elsif idx > current_stage_index %}
                      {{ expected_date | date: "%a, %-d %b" }}
                    {% endif %}
                  </div>
                </div>
              {% endfor %}
            </div>

            <button class="see-updates-btn" type="button" onclick="openTimelineDrawer()">
              <span>See Updates</span>
            </button>
            
            <div class="order-timeline__info">
              {% if is_in_stock %}
                <span class="stock-badge in-stock">✓ In Stock - Fast Delivery (4 days)</span>
              {% else %}
                <span class="stock-badge out-stock">⊙ Made to Order (15 days)</span>
              {% endif %}
            </div>
          </div>
        {% endif %}

        <div class="order-grid">
          <div class="order-pane">
            {% assign first_item = order.line_items.first %}
            <div class="order-item">
              <div class="order-item__thumb">
                {% if first_item.image %}
                  <img src="{{ first_item.image | image_url: width: 220 }}" width="110" height="110" alt="{{ first_item.title | escape }}">
                {% else %}
                  <div class="thumb-fallback" aria-hidden="true"></div>
                {% endif %}
              </div>
              <div class="order-item__meta">
                <div class="order-item__title">{{ first_item.title }}</div>
                <div class="order-item__qty">Quantity: {{ first_item.quantity }}</div>
              </div>
              <div class="order-item__amount">{{ order.total_net_amount | money }}</div>
            </div>
          </div>
          <div class="order-pane">
            <div class="order-box">
              <h3 class="order-pane__title">Payment</h3>
              <div class="pay-line">
                <span class="badge">{{ order.financial_status_label }}</span>
                {% if order.gateway %}
                  <span class="muted">via {{ order.gateway }}</span>
                {% endif %}
              </div>
            </div>
            <div class="order-box">
              <h3 class="order-pane__title">Delivery Address</h3>
              <div class="address">{{ order.shipping_address | format_address }}</div>
            </div>        
          </div>
          <div class="order-pane">
            <div class="order-help">
              <h3 class="order-pane__title">Need Help</h3>
              <ul class="help-links" role="list">
                <li>{{- 'order-issues.svg' | inline_asset_content -}} <a href="https://api.whatsapp.com/send/?phone=%2B919004435760&text=+Hi%21+I+have+an+issue+with+my+order.+Can+you+help+me%3F&type=phone_number&app_absent=0" target="_blank">Order Issues ↗</a></li>
                <li>{{- 'order-delivery-info.svg' | inline_asset_content -}} <a href="/pages/shipping-policy">Delivery Info ↗</a></li>
                <li>{{- 'order-returns.svg' | inline_asset_content -}} <a href="/apps/return_prime">Returns ↗</a></li>
              </ul>
            </div>
            <div class="order-box">
              <h3 class="order-pane__title">Order Summary</h3>
              <dl class="totals">
                <div class="row">
                  <dt>Price</dt>
                  <dd>{{ order.line_items_subtotal_price | money }}</dd>
                </div>

                {% assign discount_total = 0 %}
                {% if order.cart_level_discount_applications.size > 0 %}
                  {% for d in order.cart_level_discount_applications %}
                    {% assign discount_total = discount_total | plus: d.total_allocated_amount %}
                  {% endfor %}
                {% endif %}
                {% for li in order.line_items %}
                  {% for alloc in li.line_level_discount_allocations %}
                    {% assign discount_total = discount_total | plus: alloc.amount %}
                  {% endfor %}
                {% endfor %}
                {% if discount_total > 0 %}
                  <div class="row">
                    <dt>Discount</dt>
                    <dd>-{{ discount_total | money }}</dd>
                  </div>
                {% endif %}

                {% assign shipping_total = 0 %}
                {% for sm in order.shipping_methods %}
                  {% assign shipping_total = shipping_total | plus: sm.price %}
                {% endfor %}
                <div class="row">
                  <dt>Delivery</dt>
                  <dd>{{ shipping_total | money }}</dd>
                </div>

                <div class="row">
                  <dt>Tax</dt>
                  <dd>{{ order.total_tax | money }}</dd>
                </div>

                <div class="row total">
                  <dt>TOTAL</dt>
                  <dd>{{ order.total_net_amount | money }}</dd>
                </div>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Mobile Timeline Drawer -->
{% unless order.cancelled %}
<!-- Mobile Timeline Drawer -->
<div class="order-timeline-drawer" id="timelineDrawer">
  <div class="drawer-overlay" onclick="closeTimelineDrawer()"></div>
  <div class="drawer-content">
    <div class="drawer-header">
      <h2 class="drawer-title">Order Timeline</h2>
      <button class="drawer-close" onclick="closeTimelineDrawer()" aria-label="Close">×</button>
    </div>
    <div class="drawer-timeline">
      {% assign cumulative_days = 0 %}
      {% for s in stages %}
        {% assign idx = forloop.index0 %}
        
        {% if idx > 0 %}
          {% assign days_to_add = stage_days_array[idx] | plus: 0 %}
          {% assign cumulative_days = cumulative_days | plus: days_to_add %}
        {% endif %}
        
        {% assign expected_date = order.created_at | date: "%s" | plus: 0 %}
        {% assign seconds_to_add = cumulative_days | times: 86400 %}
        {% assign expected_date = expected_date | plus: seconds_to_add %}
        
        <div class="drawer-step {% if idx < current_stage_index %}is-complete{% elsif idx == current_stage_index %}is-current{% else %}is-pending{% endif %}">
          <div class="drawer-step__dot"><span style="display: none;">.</span></div>
          <div class="drawer-step__label">{{ s }}</div>
          <div class="drawer-step__date">
            {% if idx <= current_stage_index %}
              {{ order.created_at | date: "%a, %-d %b" }}
            {% else %}
              Expected: {{ expected_date | date: "%a, %-d %b" }}
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
{% endunless %}

<script>
function openTimelineDrawer() {
  document.getElementById('timelineDrawer').classList.add('is-open');
  document.body.style.overflow = 'hidden';
}

function closeTimelineDrawer() {
  document.getElementById('timelineDrawer').classList.remove('is-open');
  document.body.style.overflow = '';
}

document.addEventListener('DOMContentLoaded', function () {
  const meta = document.querySelector('.order-status-meta');
  if (!meta) return;

  const shopifyStatus = (meta.dataset.status || '').toLowerCase();
  const isCancelled = {{ order.cancelled | json }};

  if (shopifyStatus === 'fulfilled' || isCancelled) {
    return;
  }

  const marketplaceOrderId = meta.dataset.marketplaceOrderId;
  const marketplaceItemId  = meta.dataset.marketplaceItemId;
  const labelSpan = meta.querySelector('.order-status-label-js');
  const chip = meta.querySelector('.order-status-chip');

  if (!marketplaceOrderId || !marketplaceItemId || !labelSpan || !chip) return;

  const STATUS_STYLES = {
    1: { label: 'Order Confirmed',  className: 'status-chip--confirmed' },
    2: { label: 'Processing', className: 'status-chip--processing' },
    3: { label: 'Manufacturing',    className: 'status-chip--manufacturing' },
    13:{ label: 'Quality Control',  className: 'status-chip--qc' },
    4: { label: 'Certification',    className: 'status-chip--certification' },
    5: { label: 'Dispatch',         className: 'status-chip--dispatch' },
    6: { label: 'In Transit',       className: 'status-chip--in-transit' }
  };

  labelSpan.textContent = 'Fetching live status…';

  fetch('https://lucira-orders-api-385594025448.asia-south1.run.app', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      marketplace_order_id: Number(marketplaceOrderId),
      marketplace_item_id: Number(marketplaceItemId)
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    console.log('Ornaverse Live Status (order page):', data);

    if (!data || !data.success || !data.data || data.data.Error) {
      labelSpan.textContent = 'Status unavailable';
      return;
    }

    const statusId = Number(data.data.order_status_id);
    const info = STATUS_STYLES[statusId];

    if (!info) {
      labelSpan.textContent = 'Unknown Status';
      return;
    }

    chip.classList.remove(
      'status-chip--confirmed',
      'status-chip--processing',
      'status-chip--manufacturing',
      'status-chip--qc',
      'status-chip--certification',
      'status-chip--dispatch',
      'status-chip--in-transit'
    );
    chip.classList.add(info.className);
    labelSpan.textContent = info.label;
  })
  .catch(function(err) {
    console.error('Ornaverse error (order page)', err);
    labelSpan.textContent = 'Status unavailable';
  });
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const invoiceBtn = document.querySelector('.order-invoice-btn');
  const meta = document.querySelector('.order-status-meta');

  if (!invoiceBtn || !meta) return;

  const marketplaceOrderId = meta.dataset.marketplaceOrderId;
  const marketplaceItemId  = meta.dataset.marketplaceItemId;

  // store original button UI
  const originalHTML = invoiceBtn.innerHTML;

  invoiceBtn.addEventListener('click', function () {

    if (!marketplaceOrderId || !marketplaceItemId) {
      alert('Order data missing');
      return;
    }

    invoiceBtn.disabled = true;
    invoiceBtn.innerText = 'Generating...';

    // STEP 1: GET ORDER DATA FROM ORNAVERSE
    fetch('https://lucira-orders-api-385594025448.asia-south1.run.app', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        marketplace_order_id: Number(marketplaceOrderId),
        marketplace_item_id: Number(marketplaceItemId)
      })
    })
    .then(r => r.json())
    .then(orderData => {

      console.log('FULL ORDER API RESPONSE:', orderData);

      if (!orderData || !orderData.success || !orderData.data) {
        throw new Error('Invalid order API response');
      }

      // ✅ SAFELY EXTRACT document_no FROM ALL POSSIBLE LOCATIONS
      let documentNo = null;

      if (orderData.data.document_no) {
        documentNo = orderData.data.document_no;
      }
      else if (orderData.data.CustomData && orderData.data.CustomData.document_no) {
        documentNo = orderData.data.CustomData.document_no;
      }
      else if (typeof orderData.data.CustomData === 'string') {
        try {
          const parsed = JSON.parse(orderData.data.CustomData);
          if (parsed.document_no) {
            documentNo = parsed.document_no;
          }
        } catch(e) {}
      }

      if (!documentNo) {
        alert('Invoice is not generated yet. Please try again later.');
        throw new Error('document_no missing in API');
      }

      console.log('DOCUMENT NO:', documentNo);

      // STEP 2: CALL INVOICE API
      return fetch('https://invoice-api-385594025448.asia-south1.run.app', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ document_no: documentNo })
      });
    })
    .then(response => {
      if (!response.ok) throw new Error('Invoice PDF generation failed');
      return response.blob();
    })
    .then(blob => {

      // open PDF
      const url = window.URL.createObjectURL(blob);
      window.open(url, '_blank');

      // OR download (optional)
      /*
      const a = document.createElement('a');
      a.href = url;
      a.download = 'Invoice.pdf';
      document.body.appendChild(a);
      a.click();
      a.remove();
      */
    })
    .catch(err => {
      console.error('Invoice error:', err);
    })
    .finally(() => {
      invoiceBtn.disabled = false;
      invoiceBtn.innerHTML = originalHTML;
    });
  });
});
</script>




