<!-- certification-tabs.liquid -->

<div class="certification-tabs-wrapper">
  <div class="certification-tabs">

    <div class="cert-tabs-inner">
    <p>{{ section.settings.Our_title }}</p>
      
      <div class="tab-slider-bg"></div> <!-- Animated background -->

      {% for block in section.blocks %}
        <div class="cert-tab-logo{% if forloop.first %} active{% endif %}" data-tab="{{ forloop.index0 }}">
          {% if block.settings.logo %}
            <img src="{{ block.settings.logo | img_url: 'medium' }}" alt="{{ block.settings.title }}" title="{{ block.settings.title }}" width="auto" height="auto" loading="lazy">
          {% endif %}
          <p>{{ block.settings.title }}</p>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="certification-images-container">
    {% for block in section.blocks %}
      <div class="cert-images-set{% if forloop.first %} active{% endif %}" data-tab="{{ forloop.index0 }}">
        {% if block.settings.cert_image_1 %}
          <img src="{{ block.settings.cert_image_1 | img_url: 'master' }}" alt="Cert 1"  title="Cert 1" />
        {% endif %}
        {% if block.settings.cert_image_2 %}
          <img src="{{ block.settings.cert_image_2 | img_url: 'master' }}" alt="Cert 2" title="Cert 2" />
        {% endif %}
        {% if block.settings.cert_image_3 %}
          <img src="{{ block.settings.cert_image_3 | img_url: 'master' }}" alt="Cert 3" title="Cert 3" />
        {% endif %}
        {% if block.settings.cert_image_4 %}
          <img src="{{ block.settings.cert_image_4 | img_url: 'master' }}" alt="Cert 4" title="Cert 4" />
        {% endif %}
        {% if block.settings.cert_image_5 %}
            <img src="{{ block.settings.cert_image_5 | img_url: 'master' }}" alt="Cert 5" title="Cert 5" />
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
.certification-tabs-wrapper{padding:0 20px;text-align:center}
.certification-tabs>p{text-transform:uppercase;text-align:left}
.cert-tabs-inner{position:relative;display:flex;justify-content:center;gap:4vw;margin-top:0;align-items:center;background:#faf3ec;padding-top:25px}
.tab-slider-bg{position:absolute;top:22%;left:0;height:100%;background-color:#fff;border-radius:35px 35px 0 0;transition:all .4s ease-in-out;z-index:0;width:0;transform:translateX(0)}
.cert-tab-logo{cursor:pointer;display:flex;align-items:center;gap:15px;padding:20px 33px 11px;max-width:253px;position:relative;z-index:1;border-radius:35px 35px 0 0;background-color:transparent;transition:color .3s ease}
.cert-tab-logo img{max-height:60px;margin-bottom:8px}
.cert-tab-logo p{font-size:14px;line-height:20px;margin:0}
.certification-images-container{position:relative;width:100%;min-height:200px}
.cert-images-set{display:none;justify-content:center;flex-wrap:wrap;opacity:0;position:absolute;width:100%;top:0;left:0}
.cert-images-set.active{display:flex;opacity:1;position:relative}
.cert-images-set img{max-width:320px;width:100%;height:auto}
.cert-tabs-inner{text-align:left;text-transform:uppercase;font-size:13px}
@media (max-width:768px){
.cert-tabs-inner{flex-wrap:nowrap;gap:5px;padding:10px;padding-bottom:0;margin:unset;justify-content:unset}
.certification-tabs-wrapper{padding:unset}
.cert-tab-logo p{display:none}
.cert-tab-logo{padding:16px;border-radius:20px 20px 0 0}
.cert-tab-logo img{max-height:45px}
.cert-images-set{flex-direction:column;align-items:center}
.cert-images-set img{max-width:90%}
.tab-slider-bg{top:15%}
.tab-slider-bg{border-radius:19px 20px 0 0}
}
.cert-tab-logo.active{background:#fff}
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const tabs = document.querySelectorAll(".cert-tab-logo");
    const imageSets = document.querySelectorAll(".cert-images-set");
    const sliderBg = document.querySelector(".tab-slider-bg");

    function moveSliderBgToTab(tab) {
      const offsetLeft = tab.offsetLeft;
      const width = tab.offsetWidth;
      sliderBg.style.width = `${width}px`;
      sliderBg.style.transform = `translateX(${offsetLeft}px)`;
    }

    // On page load
    const activeTab = document.querySelector(".cert-tab-logo.active");
    if (activeTab) moveSliderBgToTab(activeTab);

    let currentIndex = 0;

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => {
        if (index === currentIndex) return;

        // Tabs
        tabs.forEach(t => t.classList.remove("active"));
        tab.classList.add("active");

        // Images
        imageSets.forEach(set => {
          set.classList.remove("active");
          set.style.display = "none";
        });

        const targetSet = imageSets[index];
        if (targetSet) {
          targetSet.style.display = "flex";
          setTimeout(() => {
            targetSet.classList.add("active");
          }, 20);
        }

        moveSliderBgToTab(tab);
        currentIndex = index;
      });
    });

    window.addEventListener("resize", () => {
      const currentTab = document.querySelector(".cert-tab-logo.active");
      if (currentTab) moveSliderBgToTab(currentTab);
    });
  });
</script>

{% schema %}
{
  "name": "Certifications Tabs",
  "settings": [
    {
      "type": "text",
      "id": "Our_title",
      "label": "Logo Text"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Certification Tab",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Logo Text"
        },
        {
          "type": "image_picker",
          "id": "cert_image_1",
          "label": "Certificate Image 1"
        },
        {
          "type": "image_picker",
          "id": "cert_image_2",
          "label": "Certificate Image 2"
        },
        {
          "type": "image_picker",
          "id": "cert_image_3",
          "label": "Certificate Image 3"
        },
        {
          "type": "image_picker",
          "id": "cert_image_4",
          "label": "Certificate Image 4"
        },
        {
          "type": "image_picker",
          "id": "cert_image_5",
          "label": "Certificate Image 5"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Certifications Tabs",
      "category": "Custom"
    }
  ]
}
{% endschema %}
