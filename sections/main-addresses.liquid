{{ 'customer.css' | asset_url | stylesheet_tag: preload: true }}
<script src="{{ 'customer.js' | asset_url }}" defer></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="customer-personal-tabs-wrapper section-{{ section.id }}-padding">
  <input type="hidden" id="customer_id" value="{{ customer.id }}">
  
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <h1>{{ 'customer.addresses.title' | t }}</h1>
    <a href="{{ routes.account_url }}">
      {{ 'customer.account.return' | t }}
    </a>
  </div>

  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <h2>ADDRESSES</h2>
    <button class="add-address-btn" onclick="openAddressModal()">{{ 'customer.addresses.add_new' | t }}</button>
  </div>

  {%- paginate customer.addresses by 10 -%}
    <div class="addresses-list">
      {%- for address in customer.addresses -%}
        <div class="address-card {% if address == customer.default_address %}default{% endif %}">
          <div class="address-card-header">
            <div>
              <div class="address-card-name">{{ address.first_name }} {{ address.last_name }}</div>
              {% if address.phone != blank %}
                <div class="address-card-phone">{{ address.phone }}</div>
              {% endif %}
            </div>
            {% if address == customer.default_address %}
              <span class="default-badge">{{ 'customer.addresses.default' | t }}</span>
            {% endif %}
          </div>

          <div class="address-card-content">
            {% if address.company != blank %}
              <div>{{ address.company }}</div>
            {% endif %}
            {% if address.address1 != blank %}
              <div>{{ address.address1 }}</div>
            {% endif %}
            {% if address.address2 != blank %}
              <div>{{ address.address2 }}</div>
            {% endif %}
            <div>
              {% if address.city %}{{ address.city }}{% if address.province or address.zip %}, {% endif %}{% endif %}
              {% if address.province %}{{ address.province }}{% if address.zip %}, {% endif %}{% endif %}
              {% if address.zip %}{{ address.zip }}{% endif %}
            </div>
            <div>{{ address.country }}</div>
          </div>

          <div class="address-card-actions">
            <button class="btn-edit" onclick='openEditModal({{ address.id | json }}, {{ address.first_name | json }}, {{ address.last_name | json }}, {{ address.company | json }}, {{ address.phone | json }}, {{ address.address1 | json }}, {{ address.address2 | json }}, {{ address.city | json }}, {{ address.province | json }}, {{ address.zip | json }}, {{ address.country | json }}, {{ address.url | json }})'>{{ 'customer.addresses.edit' | t }}</button>
            <button class="btn-delete" onclick="deleteAddress('{{ address.url }}')">{{ 'customer.addresses.delete' | t }}</button>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
        <ul role="list">
          {%- if paginate.previous -%}
            <li>
              <a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">
                <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
              </a>
            </li>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            <li>
              {%- if part.is_link -%}
                <a href="{{ part.url }}" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                  {{- part.title -}}
                </a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span aria-current="page" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                    {{- part.title -}}
                  </span>
                {%- else -%}
                  <span>{{ part.title }}</span>
                {%- endif -%}
              {%- endif -%}
            </li>
          {%- endfor -%}

          {%- if paginate.next -%}
            <li>
              <a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">
                <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
              </a>
            </li>
          {%- endif -%}
        </ul>
      </nav>
    {%- endif -%}
  {%- endpaginate -%}

  <!-- Add Address Modal -->
  <div class="address-modal-overlay" id="addAddressModal">
    <div class="address-modal">
      <div class="address-modal-header">
        <h2>{{ 'customer.addresses.add_new' | t }}</h2>
        <button class="address-modal-close" onclick="closeAddressModal()">
          <span>{{- 'icon-close-x.svg' | inline_asset_content -}}</span>
        </button>
      </div>

      {%- form 'customer_address', customer.new_address -%}
        <div class="address-form-row">
          <div class="address-form-group">
            <label for="AddressFirstNameNew">{{ 'customer.addresses.first_name' | t }}</label>
            <input
              type="text"
              id="AddressFirstNameNew"
              name="address[first_name]"
              value="{{ form.first_name }}"
              placeholder="{{ 'customer.addresses.first_name' | t }}"
              autocomplete="given-name"
            >
          </div>
          <div class="address-form-group">
            <label for="AddressLastNameNew">{{ 'customer.addresses.last_name' | t }}</label>
            <input
              type="text"
              id="AddressLastNameNew"
              name="address[last_name]"
              value="{{ form.last_name }}"
              placeholder="{{ 'customer.addresses.last_name' | t }}"
              autocomplete="family-name"
            >
          </div>
        </div>

        <div class="address-form-group">
          <label for="AddressCompanyNew">{{ 'customer.addresses.company' | t }}</label>
          <input
            type="text"
            id="AddressCompanyNew"
            name="address[company]"
            value="{{ form.company }}"
            placeholder="{{ 'customer.addresses.company' | t }}"
            autocomplete="organization"
          >
        </div>

        <div class="address-form-group">
          <label for="AddressPhoneNew">{{ 'customer.addresses.phone' | t }}</label>
          <input
            type="tel"
            id="AddressPhoneNew"
            name="address[phone]"
            value="{{ form.phone }}"
            placeholder="{{ 'customer.addresses.phone' | t }}"
            autocomplete="tel"
          >
        </div>

        <div class="address-form-group">
          <label for="AddressAddress1New">{{ 'customer.addresses.address1' | t }}</label>
          <input
            type="text"
            id="AddressAddress1New"
            name="address[address1]"
            value="{{ form.address1 }}"
            placeholder="{{ 'customer.addresses.address1' | t }}"
            autocomplete="address-line1"
          >
        </div>

        <div class="address-form-group">
          <label for="AddressAddress2New">{{ 'customer.addresses.address2' | t }}</label>
          <input
            type="text"
            id="AddressAddress2New"
            name="address[address2]"
            value="{{ form.address2 }}"
            placeholder="{{ 'customer.addresses.address2' | t }}"
            autocomplete="address-line2"
          >
        </div>

        <div class="address-form-row">
          <div class="address-form-group">
            <label for="AddressCityNew">{{ 'customer.addresses.city' | t }}</label>
            <input
              type="text"
              id="AddressCityNew"
              name="address[city]"
              value="{{ form.city }}"
              placeholder="{{ 'customer.addresses.city' | t }}"
              autocomplete="address-level2"
            >
          </div>
          <div class="address-form-group">
            <label for="AddressZipNew">{{ 'customer.addresses.zip' | t }}</label>
            <input
              type="text"
              id="AddressZipNew"
              name="address[zip]"
              value="{{ form.zip }}"
              placeholder="{{ 'customer.addresses.zip' | t }}"
              autocapitalize="characters"
              autocomplete="postal-code"
            >
          </div>
        </div>

        <div class="address-form-row">
          <div class="address-form-group">
            <label for="AddressCountryNew">{{ 'customer.addresses.country' | t }}</label>
            <select
              id="AddressCountryNew"
              name="address[country]"
              data-default="{{ form.country }}"
              autocomplete="country"
            >
              {{ all_country_option_tags }}
            </select>
          </div>
          <div class="address-form-group" id="AddressProvinceContainerNew" style="display: none">
            <label for="AddressProvinceNew">{{ 'customer.addresses.province' | t }}</label>
            <select
              id="AddressProvinceNew"
              name="address[province]"
              data-default="{{ form.province }}"
              autocomplete="address-level1"
            ></select>
          </div>
        </div>

        <div style="margin: 15px 0;">
          {{ form.set_as_default_checkbox }}
          <label for="address_default_address_new" style="display: inline; margin-left: 8px; cursor: pointer;">
            {{ 'customer.addresses.set_default' | t }}
          </label>
        </div>

        <div class="address-modal-actions">
          <button type="submit" class="btn-save">{{ 'customer.addresses.add' | t }}</button>
          <button type="button" class="btn-cancel" onclick="closeAddressModal()">{{ 'customer.addresses.cancel' | t }}</button>
        </div>
      {%- endform -%}
    </div>
  </div>

  <!-- Edit Address Modal -->
  <div class="address-modal-overlay" id="editAddressModal">
    <div class="address-modal">
      <div class="address-modal-header">
        <h2>{{ 'customer.addresses.edit_address' | t }}</h2>
        <button class="address-modal-close" onclick="closeEditModal()">
          <span>{{- 'icon-close-x.svg' | inline_asset_content -}}</span>
        </button>
      </div>

      <form id="editAddressForm" method="post">
        <input type="hidden" id="EditAddressUrl">
        
        <div class="address-form-row">
          <div class="address-form-group">
            <label for="EditAddressFirstName">{{ 'customer.addresses.first_name' | t }}</label>
            <input type="text" id="EditAddressFirstName" name="address[first_name]">
          </div>
          <div class="address-form-group">
            <label for="EditAddressLastName">{{ 'customer.addresses.last_name' | t }}</label>
            <input type="text" id="EditAddressLastName" name="address[last_name]">
          </div>
        </div>

        <div class="address-form-group">
          <label for="EditAddressCompany">{{ 'customer.addresses.company' | t }}</label>
          <input type="text" id="EditAddressCompany" name="address[company]">
        </div>

        <div class="address-form-group">
          <label for="EditAddressPhone">{{ 'customer.addresses.phone' | t }}</label>
          <input type="tel" id="EditAddressPhone" name="address[phone]">
        </div>

        <div class="address-form-group">
          <label for="EditAddressAddress1">{{ 'customer.addresses.address1' | t }}</label>
          <input type="text" id="EditAddressAddress1" name="address[address1]">
        </div>

        <div class="address-form-group">
          <label for="EditAddressAddress2">{{ 'customer.addresses.address2' | t }}</label>
          <input type="text" id="EditAddressAddress2" name="address[address2]">
        </div>

        <div class="address-form-row">
          <div class="address-form-group">
            <label for="EditAddressCity">{{ 'customer.addresses.city' | t }}</label>
            <input type="text" id="EditAddressCity" name="address[city]">
          </div>
          <div class="address-form-group">
            <label for="EditAddressZip">{{ 'customer.addresses.zip' | t }}</label>
            <input type="text" id="EditAddressZip" name="address[zip]">
          </div>
        </div>

        <div class="address-form-row">
          <div class="address-form-group">
            <label for="EditAddressCountry">{{ 'customer.addresses.country' | t }}</label>
            <select id="EditAddressCountry" name="address[country]">
              {{ all_country_option_tags }}
            </select>
          </div>
          <div class="address-form-group" id="EditAddressProvinceContainer" style="display: none">
            <label for="EditAddressProvince">{{ 'customer.addresses.province' | t }}</label>
            <select id="EditAddressProvince" name="address[province]"></select>
          </div>
        </div>

        <div class="address-modal-actions">
          <button type="submit" class="btn-save">{{ 'customer.addresses.update' | t }}</button>
          <button type="button" class="btn-cancel" onclick="closeEditModal()">{{ 'customer.addresses.cancel' | t }}</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function openAddressModal() {
    document.getElementById('addAddressModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeAddressModal() {
    document.getElementById('addAddressModal').classList.remove('active');
    document.body.style.overflow = 'auto';
  }

  function openEditModal(id, firstName, lastName, company, phone, address1, address2, city, province, zip, country, url) {
    document.getElementById('EditAddressUrl').value = url;
    document.getElementById('EditAddressFirstName').value = firstName || '';
    document.getElementById('EditAddressLastName').value = lastName || '';
    document.getElementById('EditAddressCompany').value = company || '';
    document.getElementById('EditAddressPhone').value = phone || '';
    document.getElementById('EditAddressAddress1').value = address1 || '';
    document.getElementById('EditAddressAddress2').value = address2 || '';
    document.getElementById('EditAddressCity').value = city || '';
    document.getElementById('EditAddressProvince').value = province || '';
    document.getElementById('EditAddressZip').value = zip || '';
    document.getElementById('EditAddressCountry').value = country || '';
    
    document.getElementById('editAddressModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeEditModal() {
    document.getElementById('editAddressModal').classList.remove('active');
    document.body.style.overflow = 'auto';
  }

  function deleteAddress(url) {
    if (!confirm('{{ 'customer.addresses.delete_confirm' | t }}')) return;

    const form = document.createElement('form');
    form.method = 'POST';
    form.action = url;

    const methodInput = document.createElement('input');
    methodInput.type = 'hidden';
    methodInput.name = '_method';
    methodInput.value = 'delete';
    form.appendChild(methodInput);

    document.body.appendChild(form);
    form.submit();
  }

  // Close modals when clicking outside
  document.getElementById('addAddressModal').addEventListener('click', function(e) {
    if (e.target === this) closeAddressModal();
  });

  document.getElementById('editAddressModal').addEventListener('click', function(e) {
    if (e.target === this) closeEditModal();
  });

  // Handle Edit Address Form Submission
  document.getElementById('editAddressForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const url = document.getElementById('EditAddressUrl').value;
    this.action = url;
    this.method = 'POST';
    
    const methodInput = document.createElement('input');
    methodInput.type = 'hidden';
    methodInput.name = '_method';
    methodInput.value = 'put';
    this.appendChild(methodInput);
    
    this.submit();
  });

  window.addEventListener('load', () => {
    typeof CustomerAddresses !== 'undefined' && new CustomerAddresses();
  });
</script>

{% schema %}
{
  "name": "t:sections.main-addresses.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}