{%- style -%}
  .jewelry-insurance-section{width:100%}
.insurance-hero{position:relative;height:400px;display:flex;align-items:center;justify-content:center;overflow:hidden}
.insurance-hero__image{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover}
.insurance-hero__overlay{position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.4)}
.insurance-hero__content{position:relative;z-index:2;text-align:center;color:#fff;padding:0 20px;top:150px}
.insurance-hero__title{font-size:30px;font-weight:300;letter-spacing:3px;margin:0 0 10px 0;text-transform:uppercase;color:#fff}
.insurance-hero__subtitle{font-size:16px;font-weight:300;margin:0;max-width:600px}
.insurance-content-section{padding:50px 40px;max-width:1400px;margin:0 auto}
.insurance-section-title{text-align:center;font-size:30px;font-weight:400;letter-spacing:2px;text-transform:uppercase;margin:0 0 15px 0;color:#333}
.insurance-section-description{text-align:center;color:#666;font-size:16px;line-height:1.6;max-width:800px;margin:0 auto 50px;font-weight:400}
.insurance-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:70px;margin-bottom:0}
.insurance-card{background:0 0;text-align:center}
.insurance-card__image-wrapper{aspect-ratio:1;margin-bottom:12px;overflow:hidden}
.insurance-card__image{width:100%;height:100%;object-fit:cover}
.insurance-card__title{font-size:15px;font-weight:400;margin:0;color:#333;text-transform:uppercase;letter-spacing:1px}
.documents-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:40px}
.document-card{background:0 0;text-align:center}
.document-card__image-wrapper{background:#e8e8e8;aspect-ratio:.7;margin-bottom:0;overflow:hidden}
.document-card__image{width:100%;height:100%;object-fit:cover}
.insurance-cta{text-align:center}
.insurance-cta__button { display: inline-block; background: {{ section.settings.button_color }}; color: #fff; padding: 12px 35px; text-decoration: none; text-transform: lowercase; letter-spacing: 0.5px; font-size: 14px; transition: opacity 0.3s ease; border-radius: 8px; text-transform: uppercase; }


.insurance-cta__button:hover{opacity:.85}
.documents-swiper-container{display:none;position:relative;padding-bottom:24px}
.documents-swiper{overflow:hidden}
.swiper-pagination{bottom:10px!important}
.swiper-pagination-bullet{width:8px;height:8px;background:#ccc;opacity:1}

.swiper-pagination-bullet-active { background: {{ section.settings.button_color }}; }
@media (max-width:1024px){
.insurance-grid{grid-template-columns:repeat(4,1fr)}
.documents-grid{grid-template-columns:repeat(3,1fr)}
}

  @media (max-width:768px){
.insurance-hero{height:300px}
.insurance-section-title{font-size:18px}
.insurance-section-description{font-size:12px}
.insurance-hero__title{font-size:1.5rem}
.insurance-content-section{padding:20px 20px}
.insurance-grid{grid-template-columns:repeat(3,1fr);gap:12px}
.documents-grid{display:none}
.documents-swiper-container{display:block}
.insurance-card__title{font-size:12px}
}
@media (max-width:480px){
.insurance-grid{grid-template-columns:repeat(2,1fr)}
}
{%- endstyle -%}

<div class="jewelry-insurance-section">


  <!-- What is Covered Section -->
  <div class="insurance-content-section" style="background: #fff;">
    <h2 class="insurance-section-title">{{ section.settings.covered_title }}</h2>
    <p class="insurance-section-description">{{ section.settings.covered_description }}</p>
    
    <div class="insurance-grid">
      {% for block in section.blocks %}
        {% if block.type == 'covered_item' %}
          <div class="insurance-card">
            <div class="insurance-card__image-wrapper">
              {% if block.settings.image %}
                <img 
                  src="{{ block.settings.image | img_url: '300x' }}" 
                  alt="{{ block.settings.title }}"
                  class="insurance-card__image"
                  loading="lazy"
                >
              {% endif %}
            </div>
            <h3 class="insurance-card__title">{{ block.settings.title }}</h3>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- What is Not Covered Section -->
  <div class="insurance-content-section" style="background: #fff;">
    <h2 class="insurance-section-title">{{ section.settings.not_covered_title }}</h2>
    <p class="insurance-section-description">{{ section.settings.not_covered_description }}</p>
    
    <div class="insurance-grid">
      {% for block in section.blocks %}
        {% if block.type == 'not_covered_item' %}
          <div class="insurance-card">
            <div class="insurance-card__image-wrapper">
              {% if block.settings.image %}
                <img 
                  src="{{ block.settings.image | img_url: '300x' }}" 
                  alt="{{ block.settings.title }}"
                  class="insurance-card__image"
                  loading="lazy"
                >
              {% endif %}
            </div>
            <h3 class="insurance-card__title">{{ block.settings.title }}</h3>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- Documents Required Section -->
  <div class="insurance-content-section" style="background: #fff;">
    <h2 class="insurance-section-title">{{ section.settings.documents_title }}</h2>
    <p class="insurance-section-description">{{ section.settings.documents_description }}</p>
    
    <!-- Desktop Grid -->
    <div class="documents-grid">
      {% for block in section.blocks %}
        {% if block.type == 'document_item' %}
          <div class="document-card">
            <div class="document-card__image-wrapper">
              {% if block.settings.image %}
                <img 
                  src="{{ block.settings.image | img_url: '400x' }}" 
                  alt="{{ block.settings.title }}"
                  class="document-card__image"
                  loading="lazy"
                >
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Mobile Swiper -->
    <div class="documents-swiper-container">
      <div class="swiper documents-swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            {% if block.type == 'document_item' %}
              <div class="swiper-slide">
                <div class="document-card">
                  <div class="document-card__image-wrapper">
                    {% if block.settings.image %}
                      <img 
                        src="{{ block.settings.image | img_url: '400x' }}" 
                        alt="{{ block.settings.title }}"
                        class="document-card__image"
                        loading="lazy"
                      >
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
         </div>
        {% comment %} <div class="swiper-pagination"></div> {% endcomment %}
      </div> 
    </div>

    <!-- CTA Button -->
    {% if section.settings.cta_text and section.settings.cta_link %}
      <div class="insurance-cta">
        <a href="{{ section.settings.cta_link }}" class="insurance-cta__button">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {% endif %}
  </div>

</div>

<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (window.innerWidth <= 768) {
      const swiper = new Swiper('.documents-swiper', {
        slidesPerView: 1.2,
        spaceBetween: 15,
        centeredSlides: false,
        pagination: {
          el: '.swiper-pagination',
          clickable: true,
        },
        breakpoints: {
          480: {
            slidesPerView: 2,
            spaceBetween: 15,
          }
        }
      });
    }
  });
</script>

