{{ 'product-card.css' | asset_url | stylesheet_tag: preload: true }}

<section class="featured-collections-tabs" data-section-observer>
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="section-title text-center">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="tabs">
      <!-- Mobile Dropdown -->
      <div class="tabs-dropdown mobile-only">
        <select class="collection-select" aria-label="Select collection">
          {% for block in section.blocks %}
            <option value="tab-{{ block.id }}"{% if forloop.first %} selected{% endif %}>
              {{ block.settings.collection_title | default: block.settings.collection.title }}
            </option>
          {% endfor %}
        </select>
      </div>

      <!-- Desktop Tabs -->
      <ul class="tabs-nav desktop-only">
        {% for block in section.blocks %}
          <li class="tab-link{% if forloop.first %} active{% endif %}" data-tab="tab-{{ block.id }}">
            {{ block.settings.collection_title | default: block.settings.collection.title }}
          </li>
        {% endfor %}
      </ul>

      <div class="tabs-content">
        {% for block in section.blocks %}
          {% assign collection = collections[block.settings.collection] %}
          <div class="tab-content{% if forloop.first %} active{% endif %}" id="tab-{{ block.id }}">
            
            {% if collection and collection.products_count > 0 %}
              <div class="grid grid--2-col grid--3-col-tablet grid--4-col-desktop">
                {% for product in collection.products limit: section.settings.products_limit %}
                  {% render 'card-product', card_product: product %}
                {% endfor %}
              </div>
            {% else %}
              <p>No products found in this collection.</p>
            {% endif %}
            
          </div>
        {% endfor %}
      </div>

    </div>
  </div>
</section>

{% render 'product-collection-card' %}

<style>
  /* Mobile styles */
  .mobile-only{display:block !important;}
  .desktop-only{display:none !important;}
  .collection-select{width:100%;padding:12px 16px;font-size:16px;border:1px solid #ddd;border-radius:4px;background-color:#fff;margin-bottom:20px;cursor:pointer}
  .collection-select { width: 100%; padding: 12px 14px; border: 1px solid #EAE2E1; border-radius: 4px; background-color: #EAE2E1; margin-bottom: 20px; cursor: pointer; font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 100%; letter-spacing: 1px; border-radius: 8px; }
  @media (min-width:768px){
  .mobile-only{display:none !important;}
  .desktop-only{display:flex !important;}
  
  }
</style>

<style>
.featured-collections-tabs{padding:30px 0}
.featured-collections-tabs .tabs-content { max-width: 100%; margin: 0 auto; }
.featured-collections-tabs h2{text-align:center;margin-top:0}
.featured-collections-tabs .tab-content .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.tabs-nav{display:flex;justify-content:center;gap:12px;margin-bottom:2rem;flex-wrap:wrap;list-style:none}
.tab-link{cursor: pointer; padding: 1rem 3.7rem; border: 1px solid #b67665; border-radius: 8px; transition: .3s ease; font-size: 14px; text-transform: uppercase; font-weight: 500;}
.tab-link.active,.tab-link:hover{background: #b67665; color: #fff; border-color: #b67665;}
.tab-content{display:none}
.tab-content.active{display:block}
.featured-collections-tabs h2 {margin-bottom: 28px;}
.featured-collections-tabs .card__inner.color-scheme-2.gradient.ratio {border: 0;}
.featured-collections-tabs .card-wrapper.product-card-wrapper {border: 1px solid #d9d9d9; overflow: hidden; padding: 8px 12px;}
.featured-collections-tabs .tab-content .grid::-webkit-scrollbar { height: 2px; background-color: #F5F5F5; }
.featured-collections-tabs .tab-content .grid::-webkit-scrollbar-thumb { background-color: #b67665; }
.featured-collections-tabs .tab-content .grid::-webkit-scrollbar-thumb { background-color: #b67665; }
.featured-collections-tabs .tab-content .grid::-webkit-scrollbar-track { background-color: #F5F5F5; }

/* Intersection Observer styles */
.featured-collections-tabs[data-section-observer] {
  visibility: hidden;
}

.featured-collections-tabs[data-section-observer].is-visible {
  visibility: visible;
}

@media (max-width:767px){
  .featured-collections-tabs .card-wrapper.product-card-wrapper { border: 1px solid #d9d9d9; overflow: hidden; width: 265px; }
  .featured-collections-tabs .tab-content .grid { display: grid ; grid-template-columns: repeat(4, 1fr); gap: 20px; overflow-x: scroll; }
  .tabs-nav { display: flex ; justify-content: center; gap: 0.8rem; margin-bottom: 2rem; flex-wrap: wrap; list-style: none; padding: 0; }
  .tab-link {padding: 1rem 2rem; font-size: 12px;}
  .featured-collections-tabs .tab-content .grid {gap: 12px;}
  .tab-content.active { display: block; padding: 0 0px; }
  .page-schemes-page-template-page .lucira-section .heading-wrapper p {margin: 0 auto; letter-spacing: 1px; vertical-align: middle; font-weight: 400; font-size: 12px; line-height: 150%; text-align: center;}
  .featured-collections-tabs {padding: 20px 0 !important;}
  .featured-collections-tabs .tab-content .grid { gap: 12px; padding-bottom: 30px; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const tabs = document.querySelectorAll('.tab-link');
  const contents = document.querySelectorAll('.tab-content');
  const select = document.querySelector('.collection-select');
  
  // Desktop tab functionality
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      contents.forEach(c => c.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(tab.dataset.tab).classList.add('active');
    });
  });
  
  // Mobile dropdown functionality
  if (select) {
    select.addEventListener('change', (e) => {
      contents.forEach(c => c.classList.remove('active'));
      const selectedTab = document.getElementById(e.target.value);
      if (selectedTab) {
        selectedTab.classList.add('active');
      }
    });
  }

  // Intersection Observer for lazy loading section
  const section = document.querySelector('[data-section-observer]');
  
  if (section && 'IntersectionObserver' in window) {
    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -100px 0px', // Trigger 100px before entering viewport
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target); // Stop observing once visible
        }
      });
    }, observerOptions);

    observer.observe(section);
  } else if (section) {
    // Fallback for browsers that don't support IntersectionObserver
    section.classList.add('is-visible');
  }
});
</script>

{% schema %}
{
  "name": "Featured Tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Featured Collections"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Number of products to show per tab",
      "default": 4,
      "min": 2,
      "max": 12,
      "step": 1
    }
  ],
  "blocks": [
    {
      "type": "collection_tab",
      "name": "Collection Tab",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "text",
          "id": "collection_title",
          "label": "Tab Title (optional)"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Featured Tabs",
      "category": "Products",
      "blocks": [
        { "type": "collection_tab" },
        { "type": "collection_tab" },
        { "type": "collection_tab" }
      ]
    }
  ]
}
{% endschema %}