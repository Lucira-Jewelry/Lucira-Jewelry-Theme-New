{% comment %}
Section: Featured Products with Collection Tabs
File: featured-collections-tabs.liquid
{% endcomment %}
{{ 'plp-product-card.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}

<section class="featured-collections-tabs">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="section-title text-center">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="tabs">
      <ul class="tabs-nav">
        {% for block in section.blocks %}
          <li class="tab-link{% if forloop.first %} active{% endif %}" data-tab="tab-{{ block.id }}">
            {{ block.settings.collection_title | default: block.settings.collection.title }}
          </li>
        {% endfor %}
      </ul>

      <div class="tabs-content">
        {% for block in section.blocks %}
          <div class="tab-content{% if forloop.first %} active{% endif %}" id="tab-{{ block.id }}">
            {% if block.settings.collection != blank %}
              {% assign collection = collections[block.settings.collection] %}
              <div class="grid grid--2-col grid--3-col-tablet grid--4-col-desktop">
                {% for product in collection.products limit: section.settings.products_limit %}
                  {% render 'card-product', card_product: product %}
                {% endfor %}
              </div>
            {% else %}
              <p>No collection selected.</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% render 'product-collection-card' %}

<style>
.featured-collections-tabs{padding:60px 0}
.featured-collections-tabs h2{text-align:center;margin-top:0}
.featured-collections-tabs .tab-content .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.tabs-nav{display:flex;justify-content:center;gap:1.5rem;margin-bottom:2rem;flex-wrap:wrap;list-style:none}
.tab-link{cursor:pointer;padding:.8rem 3.2rem;border:1px solid #a68380;border-radius:8px;transition:.3s ease;font-size:14px;color:#a68380}
.tab-link.active,.tab-link:hover{background:#a68380;color:#fff;border-color:#a68380}
.tab-content{display:none}
.tab-content.active{display:block}
.featured-collections-tabs h2 {margin-bottom: 28px;}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const tabs = document.querySelectorAll('.tab-link');
  const contents = document.querySelectorAll('.tab-content');
  
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      contents.forEach(c => c.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(tab.dataset.tab).classList.add('active');
    });
  });
});
</script>

{% schema %}
{
  "name": "Featured Tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Featured Collections"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Number of products to show per tab",
      "default": 4,
      "min": 2,
      "max": 12,
      "step": 1
    }
  ],
  "blocks": [
    {
      "type": "collection_tab",
      "name": "Collection Tab",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "text",
          "id": "collection_title",
          "label": "Tab Title (optional)"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Featured Tabs",
      "category": "Products",
      "blocks": [
        { "type": "collection_tab" },
        { "type": "collection_tab" },
        { "type": "collection_tab" }
      ]
    }
  ]
}
{% endschema %}