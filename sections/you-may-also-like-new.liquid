<div class="ymal-section page-width">
  <h2 class="ymal-h2">You May Also Like</h2>
  <p class="ymal-p">Other picks based on your interest</p>

  {% liquid
    assign LIMIT = 16
    assign count = 0
    assign rendered = ''
    assign primary = ''
    assign fallback = ''
    
    # Get all handles for the current product's collections into one string for easy checking
    assign product_col_handles = product.collections | map: 'handle' | join: ','
  %}

  {% liquid
    if product_col_handles contains 'sui-dhagas'
      assign primary = 'sui-dhagas'
      assign fallback = 'all-earrings'
    elsif product_col_handles contains 'earrings-gemstone'
      assign primary = 'earrings-gemstone'
      assign fallback = 'all-earrings'
    elsif product_col_handles contains 'solitaire-engagement-rings'
      assign primary = 'solitaire-engagement-rings'
      assign fallback = 'engagement-ring,all-rings'
    elsif product_col_handles contains 'halo-engagement-rings'
      assign primary = 'halo-engagement-rings'
      assign fallback = 'engagement-ring,all-rings'
    elsif product_col_handles contains 'side-stone-engagement-rings'
      assign primary = 'side-stone-engagement-rings'
      assign fallback = 'engagement-ring,all-rings'
    elsif product_col_handles contains 'toi-et-moi-engagement-rings'
      assign primary = 'toi-et-moi-engagement-rings'
      assign fallback = 'engagement-ring,all-rings'
    elsif product_col_handles contains 'trilogy-engagement-rings'
      assign primary = 'trilogy-engagement-rings'
      assign fallback = 'engagement-ring,all-rings'
    elsif product_col_handles contains 'engagement-rings-for-women'
      assign primary = 'engagement-rings-for-women'
      assign fallback = 'engagement-ring,all-rings'
    elsif product_col_handles contains 'mens-engagement-rings'
      assign primary = 'mens-engagement-rings'
      assign fallback = 'mens-ring,jewelry-mens-collection'
    elsif product_col_handles contains 'solitaire-rings'
      assign primary = 'solitaire-rings'
      assign fallback = 'all-rings'
    elsif product_col_handles contains 'eternity-rings'
      assign primary = 'eternity-rings'
      assign fallback = 'all-rings'
    elsif product_col_handles contains 'stackable-rings'
      assign primary = 'stackable-rings'
      assign fallback = 'all-rings'
    elsif product_col_handles contains 'casual-rings'
      assign primary = 'casual-rings'
      assign fallback = 'all-rings'
    elsif product_col_handles contains 'eternity-wedding-rings'
      assign primary = 'eternity-wedding-rings'
      assign fallback = 'wedding-rings,all-rings'
    elsif product_col_handles contains 'stackable-wedding-rings'
      assign primary = 'stackable-wedding-rings'
      assign fallback = 'wedding-rings,all-rings'
    elsif product_col_handles contains 'gemstone-wedding-rings'
      assign primary = 'gemstone-wedding-rings'
      assign fallback = 'wedding-rings,all-rings'
    elsif product_col_handles contains 'womens-wedding-rings'
      assign primary = 'womens-wedding-rings'
      assign fallback = 'wedding-rings,all-rings'
    elsif product_col_handles contains 'mens-wedding-rings'
      assign primary = 'mens-wedding-rings'
      assign fallback = 'mens-ring,jewelry-mens-collection'
    elsif product_col_handles contains 'mens-ring'
      assign primary = 'mens-ring'
      assign fallback = 'jewelry-mens-collection'
    elsif product_col_handles contains 'mens-stud'
      assign primary = 'mens-stud'
      assign fallback = 'all-earrings'
    elsif product_col_handles contains 'hoop-earrings'
      assign primary = 'hoop-earrings'
      assign fallback = 'all-earrings'
    elsif product_col_handles contains 'stud-earrings'
      assign primary = 'stud-earrings'
      assign fallback = 'all-earrings'
    elsif product_col_handles contains 'dangles'
      assign primary = 'dangles'
      assign fallback = 'all-earrings'
    elsif product_col_handles contains 'solitaires-earrings'
      assign primary = 'solitaires-earrings'
      assign fallback = 'all-earrings'
    elsif product_col_handles contains 'earrings-halo'
      assign primary = 'earrings-halo'
      assign fallback = 'all-earrings'
    elsif product_col_handles contains 'earrings-gemstone'
      assign primary = 'earrings-gemstone'
      assign fallback = 'all-earrings'
    elsif product_col_handles contains 'chain-bracelets'
      assign primary = 'chain-bracelets'
      assign fallback = 'all-bracelets'
    elsif product_col_handles contains 'tennis-bracelets'
      assign primary = 'tennis-bracelets'
      assign fallback = 'all-bracelets'
    elsif product_col_handles contains 'cuff-bracelets'
      assign primary = 'cuff-bracelets'
      assign fallback = 'all-bracelets'
    elsif product_col_handles contains 'mangalsutra-bracelets'
      assign primary = 'mangalsutra-bracelets'
      assign fallback = 'all-bracelets'
    elsif product_col_handles contains 'mens-bracelets'
      assign primary = 'mens-bracelets'
    elsif product_col_handles contains 'chain-necklaces'
      assign primary = 'chain-necklaces'
      assign fallback = 'all-necklaces'
    elsif product_col_handles contains 'pendant-necklaces'
      assign primary = 'pendant-necklaces'
      assign fallback = 'all-necklaces'
    elsif product_col_handles contains 'mangalsutra-necklaces'
      assign primary = 'mangalsutra-necklaces'
      assign fallback = 'all-necklaces'
    elsif product_col_handles contains 'tennis-necklaces'
      assign primary = 'tennis-necklaces'
      assign fallback = 'all-necklaces'
    elsif product_col_handles contains 'all-nosepins'
      assign primary = 'all-nosepins'
    endif
  %}

  {% if primary == blank %}
    {% assign primary = 'all-rings' %}
  {% endif %}

  <div class="ymal-grid">
    {% assign scan = primary | append: ',' | append: fallback | split: ',' | uniq %}

    {% for handle in scan %}
      {% assign col = collections[handle] %}
      {% if col and count < LIMIT %}
        {% for p in col.products %}
          {% if count >= LIMIT %}
            {% break %}
          {% endif %}
          {% if p.id != product.id %}
            {% unless rendered contains p.id %}
              {% render 'card-product', card_product: p %}
              {% assign rendered = rendered | append: p.id | append: ',' %}
              {% assign count = count | plus: 1 %}
            {% endunless %}
          {% endif %}
        {% endfor %}
      {% endif %}
    {% endfor %}
  </div>
</div>

<style>
    .ymal-section.page-width {padding-top: 40px;}
    .ymal-grid{display:grid;grid-template-columns: repeat(4,1fr);gap:15px;}
    h2.ymal-h2{text-align: center; font-size: 24px; margin-bottom: 0px; margin-top: 0px;}
    p.ymal-p{text-align:center;color: #535361; font-weight: 400; font-size: 18px; line-height: 2; text-align: center; margin: 0 auto 30px !important; display: block;}
    @media (max-width: 1080px) {
    .ymal-grid{display:grid;grid-template-columns: repeat(4,1fr);gap:10px;}
    h2.ymal-h2{text-align: center; font-size: 22px; margin-bottom: 0px; margin-top: 0px;}
  }
    @media (max-width: 768px) {
    .ymal-grid{display:grid;grid-template-columns: repeat(3,1fr);gap:10px;}
    h2.ymal-h2{text-align: center; font-size: 20px; margin-bottom: 0px; margin-top: 0px;}
  }
    @media (max-width: 428px) {

    .ymal-grid{display:grid;grid-template-columns: repeat(2,1fr);gap:10px;}
    h2.ymal-h2{text-align: center; font-size: 20px; margin-bottom: 0px; margin-top: 0px;}
    }
</style>


