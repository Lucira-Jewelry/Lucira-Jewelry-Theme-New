{% comment %}
  1. Define the type of the current product and initialization variables.
{% endcomment %}
{% assign current_product_type = product.type %}
{% assign max_products = 12 %}
{% assign suggested_products_handles = '' %}
{% assign current_product_handle = product.handle %}

{% comment %}
  2. DETERMINE TARGET COLLECTION: Construct the collection handle based on the product type.
  Handle specific exceptions for complex product type names, then use general 'all-' prefix logic.
{% endcomment %}

{% assign current_product_type_handle = current_product_type | handleize %}

{% comment %} Handle 'Charms & Pendants' -> 'all-charmspendants' (Removes '-and-') {% endcomment %}
{% if current_product_type_handle == 'charms-and-pendants' %}
  {% assign target_collection_handle = 'all-charmspendants' %}
  {% comment %} Handle 'Nose-pin' -> 'all-nosepins' (Removed '-pin's dash for consistency with 'all-') {% endcomment %}
{% elsif current_product_type_handle == 'nose-pin' %}
  {% assign target_collection_handle = 'all-nosepins' %}
{% else %}
  {% comment %} General case: 'all-' plus the standard handleized type {% endcomment %}
  {% assign target_collection_handle = 'all-' | append: current_product_type_handle %}
{% endif %}

{% assign target_collection = collections[target_collection_handle] %}

{% if target_collection != blank %}
  {% comment %}
    3. COLLECT ALL HANDLES from the collection, excluding the current product.
  {% endcomment %}
  {% for p in target_collection.products %}
    {% unless p.handle == current_product_handle %}
      {% assign suggested_products_handles = suggested_products_handles | append: p.handle | append: ',' %}
    {% endunless %}
  {% endfor %}

  {% assign product_handles_array = suggested_products_handles | split: ',' | compact %}
  {% assign total_related = product_handles_array.size %}

  {% comment %}
    4. APPLY ROTATION: Use the product ID to calculate an offset for a different product order.
  {% endcomment %}
  {% if total_related > 0 %}
    {% comment %} Use last 3 digits of product ID as a simple seed number for variation {% endcomment %}
    {% assign id_as_string = product.id | append: '' %}
    {% assign seed = id_as_string | slice: -3, 3 | plus: 0 %}

    {% comment %} Calculate the offset using modulo to ensure it's within the total count {% endcomment %}
    {% assign start_offset = seed | modulo: total_related %}

    {% comment %}
      Perform the circular slice (rotation) on the array of handles:
      1. Get the slice from the offset to the end.
      2. Get the slice from the beginning to the offset.
      3. Concatenate and slice the first 12.
    {% endcomment %}

    {% assign rotated_part_1 = product_handles_array | slice: start_offset, total_related %}
    {% assign rotated_part_2 = product_handles_array | slice: 0, start_offset %}

    {% assign rotated_handles = rotated_part_1 | concat: rotated_part_2 %}
    {% assign products_to_render = rotated_handles | slice: 0, max_products %}

  {% else %}
    {% assign products_to_render = product_handles_array %}
  {% endif %}
{% endif %}

{% comment %}
  *** CONDITIONAL RENDERING START ***
  The entire section only renders if we have products to show.
{% endcomment %}
{% if products_to_render.size > 0 %}
  <div class="you-may-also-like-section">
    <style>
            p.section-sub-heading{color: #535361; font-weight: 400; font-size: 14px; line-height: 2; text-align: center; margin: 0 auto 30px !important; display: block;}
            .card__information{padding:10px !important;}
            .card__inner.color-scheme-2.gradient.ratio{border: 1px solid #ffffff !important;}
            .you-may-also-like-section{padding:3rem 1rem;margin:0 auto;background-color:#f9f9f9}
            .you-may-also-like-section h2{text-align:center;font-size:20px;margin-bottom:0px}
            /* Mobile Default: 2 columns */
            .product-grid{display:grid;gap:1.5rem;grid-template-columns:repeat(2,1fr) !important}
            @media (max-width:768px){
            .product-grid{
            gap:12px !important;
            }
            .you-may-also-like-section{padding:3rem 0rem}
            .you-may-also-like-section h2{ margin-top:0px}
      }
            @media (min-width:768px){
                .you-may-also-like-section{padding-left:1.5rem;padding-right:1.5rem}
            .you-may-also-like-section h2{text-align:center;font-size:24px;margin-bottom:0px}
                        p.section-sub-heading{color: #535361; font-weight: 400; font-size: 18px; line-height: 2; text-align: center; margin: 0 auto 30px !important; display: block;}

                /* Tablet: 3 columns */
                .product-grid{grid-template-columns:repeat(3,1fr) !important;gap:2rem}
            }
            @media (min-width:1024px){
                .you-may-also-like-section{padding-left:2rem;padding-right:2rem}
                /* Desktop: 4 columns */
                .product-grid{grid-template-columns:repeat(4,1fr) !important}
            }
    </style>

    <div>
      <div class="page-width">
        <h2 class="section-heading">You May Also Like</h2>
        <p class="section-sub-heading">Other picks based on your interest</p>

        <div class="product-grid">
          {% comment %}
            Loop through the pre-calculated and rotated handles.
          {% endcomment %}
          {% for product_handle in products_to_render %}
            {% assign related_product = all_products[product_handle] %}

            {% comment %}Ensure the product exists before rendering{% endcomment %}
            {% if related_product != blank %}
              <div
                class="related-product-card"
                data-handle="{{ related_product.handle }}"
                data-name="{{ related_product.title | escape }}"
                data-id="{{ related_product.id }}"
                data-price="{{ related_product.price | divided_by: 100.0 }}"
                data-category="{{ related_product.type | escape }}"
                onclick="
                  window.dataLayer = window.dataLayer || []; window.dataLayer.push({
                    'event': 'promoClick',

                      'promoClick': {
                          'promo_id': '{{ related_product.selected_or_first_available_variant.sku }}',
                          'creative_name': '{{ related_product.title | escape }}',
                          'promo_name': 'You May Also Like',
                    },
                    'event_callback': function() {
                      window.location.href = '{{ related_product.url }}';
                    }
                  });
                "
              >
                {% render 'card-product', card_product: related_product %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
{% endif %}
