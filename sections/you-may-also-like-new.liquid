<div class="ymal-section page-width">
  <h2 class="ymal-h2">You May Also Like</h2>
  <p class="ymal-p">Other picks based on your interest</p>

  {% liquid
    assign LIMIT = 16
    assign count = 0
    assign rendered = ''
    assign primary = ''
    assign fallback = ''

    # Get all handles once to check for specific priority
    assign all_handles = product.collections | map: 'handle'
  %}
  
  {% for c in product.collections %}
    {% assign h = c.handle %}

    {% comment %} 
      FIX: If the product is a Sui Dhaga, we force the primary mapping immediately 
      to ensure it doesn't get skipped by other collections.
    {% endcomment %}
    {% if all_handles contains 'sui-dhagas' %}
       {% assign primary = 'sui-dhagas' %}
       {% break %}
    {% endif %}

    {% if h == 'solitaire-engagement-rings' %}
      {% assign primary = 'solitaire-engagement-rings' %}
      {% assign fallback = 'engagement-ring,all-rings' %}
      {% break %}
    {% elsif h == 'halo-engagement-rings' %}
      {% assign primary = 'halo-engagement-rings' %}
      {% assign fallback = 'engagement-ring,all-rings' %}
      {% break %}
    {% elsif h == 'side-stone-engagement-rings' %}
      {% assign primary = 'side-stone-engagement-rings' %}
      {% assign fallback = 'engagement-ring,all-rings' %}
      {% break %}
    {% elsif h == 'toi-et-moi-engagement-rings' %}
      {% assign primary = 'toi-et-moi-engagement-rings' %}
      {% assign fallback = 'engagement-ring,all-rings' %}
      {% break %}
    {% elsif h == 'trilogy-engagement-rings' %}
      {% assign primary = 'trilogy-engagement-rings' %}
      {% assign fallback = 'engagement-ring,all-rings' %}
      {% break %}
    {% elsif h == 'engagement-rings-for-women' %}
      {% assign primary = 'engagement-rings-for-women' %}
      {% assign fallback = 'engagement-ring,all-rings' %}
      {% break %}
    {% elsif h == 'mens-engagement-rings' %}
      {% assign primary = 'mens-engagement-rings' %}
      {% assign fallback = 'men-s-ring,jewelry-mens-collection' %}
      {% break %}

    {% elsif h == 'solitaire-rings' %}
      {% assign primary = 'solitaire-rings' %}
      {% assign fallback = 'all-rings' %}
      {% break %}
    {% elsif h == 'eternity-rings' %}
      {% assign primary = 'eternity-rings' %}
      {% assign fallback = 'all-rings' %}
      {% break %}
    {% elsif h == 'stackable-rings' %}
      {% assign primary = 'stackable-rings' %}
      {% assign fallback = 'all-rings' %}
      {% break %}
    {% elsif h == 'casual-rings' %}
      {% assign primary = 'casual-rings' %}
      {% assign fallback = 'all-rings' %}
      {% break %}

    {% elsif h == 'eternity-wedding-rings' %}
      {% assign primary = 'eternity-wedding-rings' %}
      {% assign fallback = 'wedding-rings,all-rings' %}
      {% break %}
    {% elsif h == 'stackable-wedding-rings' %}
      {% assign primary = 'stackable-wedding-rings' %}
      {% assign fallback = 'wedding-rings,all-rings' %}
      {% break %}
    {% elsif h == 'gemstone-wedding-rings' %}
      {% assign primary = 'gemstone-wedding-rings' %}
      {% assign fallback = 'wedding-rings,all-rings' %}
      {% break %}
    {% elsif h == 'womens-wedding-rings' %}
      {% assign primary = 'womens-wedding-rings' %}
      {% assign fallback = 'wedding-rings,all-rings' %}
      {% break %}
    {% elsif h == 'mens-wedding-rings' %}
      {% assign primary = 'mens-wedding-rings' %}
      {% assign fallback = 'men-s-ring,jewelry-mens-collection' %}
      {% break %}

    {% elsif h == 'men-s-ring' %}
      {% assign primary = 'men-s-ring' %}
      {% assign fallback = 'jewelry-mens-collection' %}
      {% break %}
    
    {% elsif h == 'hoop-earrings' %}
      {% assign primary = 'hoop-earrings' %}
      {% break %}
    {% elsif h == 'stud-earrings' %}
      {% assign primary = 'stud-earrings' %}
      {% break %}
    {% elsif h == 'sui-dhagas' %}
      {% assign primary = 'sui-dhagas' %}
      {% break %}
    {% elsif h == 'dangles' %}
      {% assign primary = 'dangles' %}
      {% break %}
    {% elsif h == 'solitaires-earrings' %}
      {% assign primary = 'solitaires-earrings' %}
      {% break %}
    {% elsif h == 'earrings-halo' %}
      {% assign primary = 'earrings-halo' %}
      {% break %}
    {% elsif h == 'earrings-gemstone' %}
      {% assign primary = 'earrings-gemstone' %}
      {% break %}
    {% elsif h == 'mens-stud' %}
      {% assign primary = 'mens-stud' %}
      {% break %}

    {% elsif h == 'chain-bracelets' %}
      {% assign primary = 'chain-bracelets' %}
      {% break %}
    {% elsif h == 'tennis-bracelets' %}
      {% assign primary = 'tennis-bracelets' %}
      {% break %}
    {% elsif h == 'cuff-bracelets' %}
      {% assign primary = 'cuff-bracelets' %}
      {% break %}
    {% elsif h == 'mangalsutra-bracelets' %}
      {% assign primary = 'mangalsutra-bracelets' %}
      {% break %}
    {% elsif h == 'mens-bracelets' %}
      {% assign primary = 'mens-bracelets' %}
      {% break %}

    {% elsif h == 'chain-necklaces' %}
      {% assign primary = 'chain-necklaces' %}
      {% break %}
    {% elsif h == 'pendant-necklaces' %}
      {% assign primary = 'pendant-necklaces' %}
      {% break %}
    {% elsif h == 'mangalsutra-necklaces' %}
      {% assign primary = 'mangalsutra-necklaces' %}
      {% break %}
    {% elsif h == 'tennis-necklaces' %}
      {% assign primary = 'tennis-necklaces' %}
      {% break %}
    {% elsif h == 'all-nosepins' %}
      {% assign primary = 'all-nosepins' %}
      {% assign fallback = '' %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if primary == blank %}
    {% assign primary = 'all-rings' %}
  {% endif %}

  <div class="ymal-grid">
    {% assign scan = primary | append: ',' | append: fallback | split: ',' | uniq %}

    {% for handle in scan %}
      {% assign col = collections[handle] %}
      {% if col and count < LIMIT %}
        {% for p in col.products %}
          {% if count >= LIMIT %}
            {% break %}
          {% endif %}
          {% if p.id != product.id %}
            {% unless rendered contains p.id %}
              {% render 'card-product', card_product: p %}
              {% assign rendered = rendered | append: p.id | append: ',' %}
              {% assign count = count | plus: 1 %}
            {% endunless %}
          {% endif %}
        {% endfor %}
      {% endif %}
    {% endfor %}
  </div>
</div>

<style>
    .ymal-section.page-width {padding-top: 40px;}
    .ymal-grid{display:grid;grid-template-columns: repeat(4,1fr);gap:15px;}
    h2.ymal-h2{text-align: center; font-size: 24px; margin-bottom: 0px; margin-top: 0px;}
    p.ymal-p{text-align:center;color: #535361; font-weight: 400; font-size: 18px; line-height: 2; text-align: center; margin: 0 auto 30px !important; display: block;}
    
    .ymal-grid{
      display: grid;
      grid-template-columns: repeat(4, 1fr); /* 🔥 force 4 always */
      gap: 15px;
    }

    @media (max-width: 768px) {
      .ymal-grid{
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 428px) {
      .ymal-grid{
        grid-template-columns: repeat(2, 1fr);
      }
    }


    @media (max-width: 1080px) {
    .ymal-grid{display:grid;grid-template-columns: repeat(4,1fr);gap:10px;}
    h2.ymal-h2{text-align: center; font-size: 22px; margin-bottom: 0px; margin-top: 0px;}
  }
    @media (max-width: 768px) {
    .ymal-grid{display:grid;grid-template-columns: repeat(3,1fr);gap:10px;}
    h2.ymal-h2{text-align: center; font-size: 20px; margin-bottom: 0px; margin-top: 0px;}
  }
    @media (max-width: 428px) {

    .ymal-grid{display:grid;grid-template-columns: repeat(2,1fr);gap:10px;}
    h2.ymal-h2{text-align: center; font-size: 20px; margin-bottom: 0px; margin-top: 0px;}
    }
</style>


