{% if product.metafields.custom.matching_product != blank %}
  
  {%- comment -%} 
    1. LOGIC: Count valid products (excluding the current one) 
    and calculate how many to show so we always have full rows of 4.
  {%- endcomment -%}
  {% assign raw_count = 0 %}
  {% for item in product.metafields.custom.matching_product.value %}
    {% unless item.id == product.id %}
      {% assign raw_count = raw_count | plus: 1 %}
    {% endunless %}
  {% endfor %}

  {% if raw_count < 4 %}
    {% assign products_to_display = raw_count %}
  {% else %}
    {% assign products_to_display = raw_count | divided_by: 4 | times: 4 %}
  {% endif %}

  {% if products_to_display > 0 %}
    <div class="ymal-section page-width" data-ymal-section>
      <h2 class="ymal-h2">You May Also Like</h2>
      <p class="ymal-p">Other picks based on your interest</p>

      <div class="ymal-grid">
        {% assign displayed_count = 0 %}
        {% for ymal_product in product.metafields.custom.matching_product.value %}
          
          {%- comment -%} Render only if it's not the current product AND we haven't hit the limit {%- endcomment -%}
          {% if ymal_product.id != product.id and displayed_count < products_to_display %}
            
            <div class="related-product-card"
              data-handle="{{ ymal_product.handle }}"
              data-name="{{ ymal_product.title | escape }}"
              data-id="{{ ymal_product.id }}"
              data-sku="{{ ymal_product.selected_or_first_available_variant.sku }}"
              data-url="{{ ymal_product.url }}"
            >
              {% capture di_values %}
                {% render 'di-discount-calc', product: ymal_product %}
              {% endcapture %}

              {% assign di_parts = di_values | strip | split: '|' %}
              
              {% render 'card-product',
                card_product: ymal_product,
                diamond_percent: di_parts[0] | plus: 0,
                mc_percent: di_parts[1] | plus: 0
              %}
            </div>
            
            {% assign displayed_count = displayed_count | plus: 1 %}
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <script>
      (function(){
        // PERFORMANCE FIX: Scope the listener to this section only
        const section = document.querySelector('[data-ymal-section]');
        if(!section) return;

        section.addEventListener('click', function (e) {
          // Check if the click happened on a link inside a product card
          const link = e.target.closest('a');
          const card = e.target.closest('.related-product-card');

          if (link && card) {
            const d = card.dataset;

            // UX FIX: Fire GTM event asynchronously without blocking navigation
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              event: "promoClick",
              promoClick: {
                promo_id: d.id,
                promo_name: d.name,
                creative_name: "You May Also Like",
                promo_position: "product_page_ymal"
              }
            });
            
            // The browser will now follow the link instantly.
            // No setTimeout needed.
          }
        });
      })();
    </script>

    <style>
      .ymal-section.page-width {padding-top: 40px;}
      .ymal-grid{display:grid;grid-template-columns: repeat(4,1fr);gap:15px;}
      h2.ymal-h2{text-align: center; font-size: 24px; margin-bottom: 0px; margin-top: 0px;}
      p.ymal-p{text-align:center;color: #535361; font-weight: 400; font-size: 18px; line-height: 2; text-align: center; margin: 0 auto 30px !important; display: block;}
      
      @media (max-width: 1080px) {
        .ymal-grid{gap:10px;}
        h2.ymal-h2{font-size: 22px;}
      }
      @media (max-width: 768px) {
        .ymal-grid{grid-template-columns: repeat(2,1fr);gap:10px;}
        h2.ymal-h2{font-size: 20px;}
        p.ymal-p {font-size: 14px;}
        .ymal-section.page-width { padding-top: 12px; }
      }
    </style>
  {% endif %}
{% endif %}