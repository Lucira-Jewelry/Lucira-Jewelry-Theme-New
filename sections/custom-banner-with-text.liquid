{% style %}
  .custom-banner-text-overlay { margin-top: {{ section.settings.margin_top_desktop }}px; margin-bottom: {{ section.settings.margin_bottom_desktop }}px; }
  .custom-banner-text-overlay__image{width:100%;display:block;object-fit:cover}
  .custom-banner-text-overlay__text{position:absolute;bottom:0;left:50%;transform:translateX(-50%);text-align:center;color:#fff;width:100%;z-index:2;display:flex;flex-direction:column;gap:12px;margin-bottom:40px}
  .text_heading_overlay{font-weight:500;font-style:Medium;font-size:32px;leading-trim:NONE;line-height:150%;letter-spacing:4%;text-align:center;vertical-align:middle;text-transform:uppercase;color:#fff;margin:0}
  .text_sub_heading_overlay{font-weight:400;font-style:Book;margin:0;font-size:18px;leading-trim:NONE;line-height:24px;letter-spacing:4%;text-align:center;color:#fff}
  .custom-banner-text-overlay__wrapper {position:relative;}
  @media screen and (min-width:750px){
  .custom-banner-text-overlay__image--mobile{display:none}
  }
  @media screen and (max-width:749px){
  .text_heading_overlay{font-size:18px}
  .text_sub_heading_overlay{font-size:12px}
  .custom-banner-text-overlay__image--desktop{display:none}
  .custom-banner-text-overlay__image{width:100%;height:360px;object-fit:cover;object-position:bottom}
  .custom-banner-text-overlay__text{gap:4px;margin-bottom:20px}
  .custom-banner-text-overlay__text {bottom: 0;}
  .custom-banner-text-overlay { margin-top: {{ section.settings.margin_top_mobile }}px; margin-bottom: {{ section.settings.margin_bottom_mobile }}px; }
  }

  @media only screen and (min-width: 0px) and (max-width: 767px) {
    .custom-banner-text-overlay__wrapper {
        position: relative;
    }
    
    .custom-banner-text-overlay__wrapper:after {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(180deg, #1f77db00 37.64%, #000000 81.77%);
    }


}
{% endstyle %}

<div class="custom-banner-text-overlay__wrapper">
  {% if section.settings.banner_image_desktop %}
    {% comment %}
      Show mobile image on mobile if set, otherwise fall back to desktop image.
    {% endcomment %}

    <img
      class="custom-banner-text-overlay__image custom-banner-text-overlay__image--desktop"
      src="{{ section.settings.banner_image_desktop | image_url: width: 1600 }}"
      alt="Banner Desktop"
      title="Banner Desktop"
      loading="lazy"
    >

    {% if section.settings.banner_image_mobile %}
      <img
        class="custom-banner-text-overlay__image custom-banner-text-overlay__image--mobile"
        src="{{ section.settings.banner_image_mobile | image_url: width: 800 }}"
        alt="Banner Mobile"
        title="Banner Mobile"
        loading="lazy"
      >
    {% else %}
      <img
        class="custom-banner-text-overlay__image custom-banner-text-overlay__image--mobile"
        src="{{ section.settings.banner_image_desktop | image_url: width: 800 }}"
        alt="Banner Desktop fallback"
        title="Bannner Desktop fallback"
        loading="lazy"
      >
    {% endif %}
    <div class="custom-banner-text-overlay__text">
      {% if section.settings.heading_1 != blank %}
        <h2 class="text_heading_overlay">{{ section.settings.heading_1 }}</h2>
      {% endif %}
      {% if section.settings.heading_2 != blank %}
        <h3 class="text_sub_heading_overlay">{{ section.settings.heading_2 }}</h3>
      {% endif %}
    </div>
  {% endif %}
</div>


{% schema %}
{
  "name": "Custom Txt Overlay Banner",
  "tag": "section",
  "class": "custom-banner-text-overlay",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image_desktop",
      "label": "Banner Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "banner_image_mobile",
      "label": "Banner Image (Mobile, optional)"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading 1",
      "default": "Your Main Heading"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading 2",
      "default": "Your Sub Heading"
    },
    {
      "type": "range",
      "id": "margin_top_desktop",
      "label": "Top Margin (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "label": "Bottom Margin (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Top Margin (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Bottom Margin (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Custom Banner Text Overlay"
    }
  ]
}
{% endschema %}
