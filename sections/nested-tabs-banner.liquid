{% comment %}
  Section: Nested Tabs Banner
  Description: Dynamic banner that changes with tabs
{% endcomment %}

{%- assign category_handle = page.handle -%}
{%- assign current_category = metaobjects.category_page[category_handle] -%}
{%- assign tab_slug = request.query.tab | default: current_category.default_tab_slug -%}

{%- assign current_tab = nil -%}
{% comment %} 
{%- assign category_tabs = metaobjects.tab_content.values | where: "parent_category.system.handle", current_category.system.handle -%} {% endcomment %}

{% comment %} NEW CODE (fixed) {% endcomment %}
{% assign category_tabs = metaobjects.tab_content.values %}
{% assign filtered_tabs = "" | split: "" %}

{% for tab in category_tabs %}
  {% assign parent_ref = tab.parent_category %}
  {% if parent_ref and parent_ref.system and parent_ref.system.handle == current_category.system.handle %}
    {% assign filtered_tabs = filtered_tabs | push: tab %}
  {% endif %}
{% endfor %}

{% assign category_tabs = filtered_tabs %}

{%- for tab in category_tabs -%}
  {%- if tab.tab_slug == tab_slug -%}
    {%- assign current_tab = tab -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if current_tab == nil and category_tabs.size > 0 -%}
  {%- assign current_tab = category_tabs.first -%}
{%- endif -%}

{%- assign banner_image = current_tab.banner_image | default: current_category.banner_image -%}
{%- assign banner_title = current_tab.banner_title | default: current_category.banner_title | default: current_category.title -%}
{%- assign banner_subtitle = current_tab.banner_subtitle | default: current_category.banner_subtitle -%}

<style>
  .nested-tabs-banner {
    position: relative;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    overflow: hidden;
  }
  
  .banner-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  
  .banner-background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .banner-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    z-index: 2;
  }
  
  .banner-content {
    position: relative;
    z-index: 3;
    text-align: center;
    max-width: 800px;
    padding: 2rem;
  }
  
  .banner-title {
    font-size: 3rem;
    font-weight: bold;
    margin-bottom: 1rem;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
  }
  
  .banner-subtitle {
    font-size: 1.25rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }
  
  @media (max-width: 768px) {
    .nested-tabs-banner {
      min-height: 300px;
    }
    
    .banner-title {
      font-size: 2rem;
    }
    
    .banner-subtitle {
      font-size: 1rem;
    }
  }
</style>

<div class="nested-tabs-banner">
  {%- if banner_image -%}
    <div class="banner-background">
      <img 
        src="{{ banner_image | image_url: width: 1920 }}" 
        alt="{{ banner_title | escape }}"
        loading="eager"
        width="1920"
        height="400"
      >
    </div>
  {%- endif -%}
  
  <div class="banner-overlay"></div>
  
  <div class="banner-content">
    <h1 class="banner-title">{{ banner_title }}</h1>
    {%- if banner_subtitle -%}
      <p class="banner-subtitle">{{ banner_subtitle }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Nested Tabs Banner",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "Nested Tabs Banner"
    }
  ]
}
{% endschema %}