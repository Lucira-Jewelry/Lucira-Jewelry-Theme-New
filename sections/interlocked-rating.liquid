<section
  class="interlocked-rating-section"
  style="
    margin-top: {{ section.settings.mt_desktop }}px;
    margin-bottom: {{ section.settings.mb_desktop }}px;
  "
>
  <div class="interlocked-container">
    
    <!-- LEFT IMAGE -->
    <div class="interlocked-left">
      {% if section.settings.left_image %}
        <img
          src="{{ section.settings.left_image | image_url: width: 900 }}"
          alt="interlocked-left-image"
          loading="lazy"
        >
      {% endif %}
    </div>

    <!-- RIGHT CONTENT -->
    <div class="interlocked-right">
      <h2 class="interlocked-heading">{{ section.settings.heading }}</h2>
      <p class="interlocked-subheading">{{ section.settings.subheading }}</p>

      <h3 class="rating-title">{{ section.settings.rating_heading }}</h3>

      <div class="rating-wrapper">

        {% for block in section.blocks %}
        <div class="rating-item">
          <div class="rating-circle" data-rating="{{ block.settings.rating_value }}">
            <svg width="90" height="90">
              <circle class="bg" cx="45" cy="45" r="40" stroke-width="6" />
              <circle class="progress" cx="45" cy="45" r="40" stroke-width="6" />
            </svg>
            <div class="rating-text">
              <span>{{ block.settings.rating_value }}</span>
              <small>out of 5</small>
            </div>
          </div>
          <p class="rating-sub">{{ block.settings.rating_subheading }}</p>
        </div>
        {% endfor %}

      </div>

      {% if section.settings.cta_text != blank %}
        <a href="#" class="rating-cta">{{ section.settings.cta_text }}</a>
      {% endif %}
    </div>

  </div>
</section>

<style>
.interlocked-rating-section {
  padding: 40px 0;
}

.interlocked-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 50px;
}

.interlocked-left img {
  width: 100%;
  max-width: 580px;
}

.interlocked-heading {
  font-size: 32px;
  margin-bottom: 10px;
  font-weight: 600;
}

.interlocked-subheading {
  max-width: 450px;
  margin-bottom: 25px;
  color: #6a6a6a;
}

.rating-title {
  font-size: 20px;
  margin-bottom: 20px;
  font-weight: 600;
}

.rating-wrapper {
  display: flex;
  gap: 35px;
  margin-bottom: 30px;
}

.rating-item {
  text-align: center;
}

/* CIRCULAR STROKE RING */
.rating-circle {
  width: 90px;
  height: 90px;
  position: relative;
}

.rating-circle svg {
  transform: rotate(-90deg);
}

.rating-circle circle {
  fill: none;
  stroke-linecap: round;
}

/* Background Ring */
.rating-circle .bg {
  stroke: #ddd;
}

/* Animated Border */
.rating-circle .progress {
  stroke: #a58885;
  stroke-dasharray: 251;
  stroke-dashoffset: 251;
  transition: stroke-dashoffset 1.2s ease;
}

.rating-circle.filled .progress {
  stroke-dashoffset: var(--progress-offset);
}

.rating-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -52%);
  text-align: center;
}

.rating-text span {
  font-size: 20px;
  font-weight: bold;
}

.rating-text small {
  font-size: 10px;
  display: block;
  margin-top: -3px;
}

.rating-sub {
  margin-top: 8px;
  font-size: 14px;
  color: #6a6a6a;
}

/* CTA */
.rating-cta {
  padding: 10px 25px;
  background: #a58885;
  color: white;
  border-radius: 5px;
  display: inline-block;
  text-decoration: none;
}

@media (max-width: 768px) {
  .interlocked-rating-section {
    margin-top: {{ section.settings.mt_mobile }}px !important;
    margin-bottom: {{ section.settings.mb_mobile }}px !important;
  }

  .interlocked-container {
    flex-direction: column;
    text-align: center;
  }

  .rating-wrapper {
    justify-content: center;
    flex-wrap: wrap;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          
          document.querySelectorAll(".rating-circle").forEach(circle => {
            let rating = parseFloat(circle.dataset.rating);
            let percentage = (rating / 5) * 251; // circumference

            circle.style.setProperty("--progress-offset", 251 - percentage);
            circle.classList.add("filled");
          });

          observer.disconnect();
        }
      });
    },
    { threshold: 0.3 }
  );

  observer.observe(document.querySelector(".interlocked-rating-section"));
});
</script>


{% schema %}
{
  "name": "Interlocked Rating",

  "settings": [
    {
      "type": "range",
      "id": "mt_desktop",
      "label": "Margin Top (Desktop)",
      "min": 0, "max": 100,
      "default": 40
    },
    {
      "type": "range",
      "id": "mb_desktop",
      "label": "Margin Bottom (Desktop)",
      "min": 0, "max": 100,
      "default": 40
    },
    {
      "type": "range",
      "id": "mt_mobile",
      "label": "Margin Top (Mobile)",
      "min": 0, "max": 100,
      "default": 20
    },
    {
      "type": "range",
      "id": "mb_mobile",
      "label": "Margin Bottom (Mobile)",
      "min": 0, "max": 100,
      "default": 20
    },

    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Image"
    },

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "INTERLOCKED RING SHANK"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Lorem ipsum dolor sit amet..."
    },

    {
      "type": "text",
      "id": "rating_heading",
      "label": "Rating Title",
      "default": "RECOMMENDED FOR"
    },

    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "EXPLORE SIMILAR DESIGN"
    }
  ],

  "blocks": [
    {
      "type": "rating",
      "name": "Rating Item",
      "settings": [
        {
          "type": "range",
          "id": "rating_value",
          "label": "Rating (0 - 5)",
          "min": 0,
          "max": 5,
          "step": 0.1,
          "default": 3.5
        },
        {
          "type": "text",
          "id": "rating_subheading",
          "label": "Rating Label",
          "default": "Party Wear"
        }
      ]
    }
  ],

  "max_blocks": 4,

  "presets": [
    {
      "name": "Interlocked Rating"
    }
  ]
}
{% endschema %}
