<section
  class="interlocked-rating-section"
  style="
    margin-top: {{ section.settings.mt_desktop }}px;
    margin-bottom: {{ section.settings.mb_desktop }}px;
  "
>
  <div class="interlocked-container">
    <div class="interlocked-left">
      {% if section.settings.left_image %}
        <img
          src="{{ section.settings.left_image | image_url: width: 900 }}"
          alt="rating-left-image"
          loading="lazy"
        >
      {% endif %}
    </div>

    <div class="interlocked-right">
      <h2 class="interlocked-heading">{{ section.settings.heading }}</h2>
      <p class="interlocked-subheading">{{ section.settings.subheading }}</p>

      <h3 class="rating-title">{{ section.settings.rating_heading }}</h3>

      <div class="rating-wrapper">
        {% for i in (1..4) %}
          <div class="rating-item">
            <div
              class="rating-circle"
              data-rating="{{ section.settings.rating_value }}"
            >
              <span class="rating-value">{{ section.settings.rating_value }}</span>
              <small>out of 5</small>
            </div>
            <p class="rating-sub">{{ section.settings.rating_subheading }}</p>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.cta_text != blank %}
        <a href="#" class="rating-cta">{{ section.settings.cta_text }}</a>
      {% endif %}
    </div>
  </div>
</section>

<style>
.interlocked-rating-section {
  padding: 40px 0;
}

.interlocked-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 50px;
}

.interlocked-left img {
  width: 100%;
  max-width: 550px;
}

.interlocked-heading {
  font-size: 32px;
  margin-bottom: 10px;
  font-weight: 600;
}

.interlocked-subheading {
  max-width: 450px;
  margin-bottom: 25px;
  color: #6a6a6a;
}

.rating-title {
  font-size: 20px;
  margin-bottom: 20px;
  font-weight: 600;
}

.rating-wrapper {
  display: flex;
  gap: 35px;
  margin-bottom: 30px;
}

.rating-item {
  text-align: center;
}

.rating-circle {
  width: 85px;
  height: 85px;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  font-size: 20px;
  background: conic-gradient(#ddd 0deg, #ddd 360deg);
  transition: background 1s ease;
}

.rating-circle.filled {
  /* Filled via JS dynamically */
}

.rating-circle span {
  font-size: 20px;
  font-weight: bold;
}

.rating-circle small {
  font-size: 10px;
  margin-top: -3px;
}

.rating-sub {
  margin-top: 8px;
  font-size: 14px;
  color: #6a6a6a;
}

.rating-cta {
  padding: 10px 25px;
  background: #a58885;
  color: white;
  border-radius: 5px;
  display: inline-block;
  text-decoration: none;
}

@media (max-width: 768px) {
  .interlocked-rating-section {
    margin-top: {{ section.settings.mt_mobile }}px !important;
    margin-bottom: {{ section.settings.mb_mobile }}px !important;
  }

  .interlocked-container {
    flex-direction: column;
    text-align: center;
  }

  .rating-wrapper {
    justify-content: center;
    flex-wrap: wrap;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const circles = document.querySelectorAll(".rating-circle");

          circles.forEach((circle) => {
            let rating = parseFloat(circle.dataset.rating);
            let percent = (rating / 5) * 360;

            circle.style.background =
              `conic-gradient(#a58885 ${percent}deg, #ddd ${percent}deg)`;

            circle.classList.add("filled");
          });

          observer.disconnect();
        }
      });
    },
    { threshold: 0.3 }
  );

  observer.observe(document.querySelector(".interlocked-rating-section"));
});
</script>


{% schema %}
{
  "name": "Interlocked Rating",
  "settings": [
    {
      "type": "range",
      "id": "mt_desktop",
      "label": "Margin Top (Desktop)",
      "min": 0,
      "max": 100,
      "default": 40
    },
    {
      "type": "range",
      "id": "mb_desktop",
      "label": "Margin Bottom (Desktop)",
      "min": 0,
      "max": 100,
      "default": 40
    },
    {
      "type": "range",
      "id": "mt_mobile",
      "label": "Margin Top (Mobile)",
      "min": 0,
      "max": 100,
      "default": 20
    },
    {
      "type": "range",
      "id": "mb_mobile",
      "label": "Margin Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "default": 20
    },

    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Image"
    },

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "INTERLOCKED RING SHANK"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Lorem ipsum dolor sit amet..."
    },

    {
      "type": "text",
      "id": "rating_heading",
      "label": "Rating Heading",
      "default": "RECOMMENDED FOR"
    },

    {
      "type": "range",
      "id": "rating_value",
      "label": "Rating Value (Out of 5)",
      "min": 0,
      "max": 5,
      "step": 0.1,
      "default": 3.5
    },

    {
      "type": "text",
      "id": "rating_subheading",
      "label": "Rating Subheading",
      "default": "Party Wear"
    },

    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "EXPLORE SIMILAR DESIGN"
    }
  ],
  "presets": [
    {
      "name": "Interlocked Rating"
    }
  ]
}
{% endschema %}
