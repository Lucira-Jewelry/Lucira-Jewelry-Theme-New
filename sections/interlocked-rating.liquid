<section 
  id="interlocked-rating-section_{{ section.id }}"
  class="interlocked-rating-section"
  style="
    margin-top: {{ section.settings.mt_desktop }}px;
    margin-bottom: {{ section.settings.mb_desktop }}px;
  "
>
  <div class="irs-container">

    <!-- LEFT IMAGE -->
    <div class="irs-left">
      {% if section.settings.left_image %}
        <img 
          src="{{ section.settings.left_image | image_url: width: 900 }}" 
          alt="rating image"
          class="irs-image"
        >
      {% endif %}
    </div>

    <!-- RIGHT CONTENT -->
    <div class="irs-right">

      <h2 class="irs-heading">{{ section.settings.heading }}</h2>

      <p class="irs-subheading">{{ section.settings.subheading }}</p>

      <h3 class="irs-rating-heading">{{ section.settings.rating_heading }}</h3>

      <!-- RATING CIRCLE -->
      <div class="irs-rating-wrapper">
        <div class="irs-rating-circle" data-rating="{{ section.settings.rating_value }}">
          <svg class="irs-svg" width="100" height="100">
            <circle class="irs-bg" cx="50" cy="50" r="45" />
            <circle class="irs-progress" cx="50" cy="50" r="45" />
          </svg>
          <div class="irs-rating-text">
            {{ section.settings.rating_value }}
            <span>out of 5</span>
          </div>
        </div>

        <p class="irs-rating-sub">{{ section.settings.rating_subheading }}</p>
      </div>

      {% if section.settings.cta_text %}
        <a class="irs-btn" href="#">{{ section.settings.cta_text }}</a>
      {% endif %}

    </div>

  </div>
</section>

<style>
/* Wrap all CSS inside unique parent ID */
#interlocked-rating-section_{{ section.id }} {
  width: 100%;
}

#interlocked-rating-section_{{ section.id }} .irs-container {
  display: flex;
  align-items: center;
  gap: 60px;
}

#interlocked-rating-section_{{ section.id }} .irs-left img {
  width: 100%;
  max-width: 500px;
}

#interlocked-rating-section_{{ section.id }} .irs-right {
  max-width: 550px;
}

#interlocked-rating-section_{{ section.id }} .irs-heading {
  font-size: 32px;
  margin-bottom: 10px;
}

#interlocked-rating-section_{{ section.id }} .irs-subheading {
  margin-bottom: 20px;
  color: #666;
}

#interlocked-rating-section_{{ section.id }} .irs-rating-heading {
  margin-bottom: 20px;
  font-size: 20px;
}

/* Rating circle */
#interlocked-rating-section_{{ section.id }} .irs-rating-wrapper {
  text-align: center;
  margin-bottom: 20px;
}

#interlocked-rating-section_{{ section.id }} .irs-svg {
  transform: rotate(-90deg);
}

#interlocked-rating-section_{{ section.id }} circle {
  fill: none;
  stroke-width: 8;
}

#interlocked-rating-section_{{ section.id }} .irs-bg {
  stroke: #e6e6e6;
}

#interlocked-rating-section_{{ section.id }} .irs-progress {
  stroke: #8a5b48;
  stroke-dasharray: 283;
  stroke-dashoffset: 283;
  transition: stroke-dashoffset 1.4s ease;
}

#interlocked-rating-section_{{ section.id }} .irs-rating-circle {
  position: relative;
  display: inline-block;
}

#interlocked-rating-section_{{ section.id }} .irs-rating-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 22px;
  font-weight: bold;
}

#interlocked-rating-section_{{ section.id }} .irs-rating-text span {
  display: block;
  font-size: 11px;
  color: #888;
}

#interlocked-rating-section_{{ section.id }} .irs-btn {
  padding: 12px 24px;
  background: #8b7066;
  color: #fff;
  text-decoration: none;
  border-radius: 4px;
  display: inline-block;
}

@media (max-width: 768px) {
  #interlocked-rating-section_{{ section.id }} {
    margin-top: {{ section.settings.mt_mobile }}px !important;
    margin-bottom: {{ section.settings.mb_mobile }}px !important;
  }

  #interlocked-rating-section_{{ section.id }} .irs-container {
    flex-direction: column;
    text-align: center;
  }

  #interlocked-rating-section_{{ section.id }} .irs-left img {
    max-width: 330px;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const sectionId = "interlocked-rating-section_{{ section.id }}";
  const section = document.getElementById(sectionId);

  if (!section) return;

  const circle = section.querySelector(".irs-progress");
  const ratingCircle = section.querySelector(".irs-rating-circle");
  const ratingValue = ratingCircle.getAttribute("data-rating");

  const total = 283;
  const offset = total - (ratingValue / 5) * total;

  const observer = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      circle.style.strokeDashoffset = offset;
    }
  });

  observer.observe(section);
});
</script>

{% schema %}
{
  "name": "Interlocked Rating",
  "settings": [
    { "type": "range", "id": "mt_desktop", "label": "Margin Top Desktop", "min": 0, "max": 100, "default": 20 },
    { "type": "range", "id": "mb_desktop", "label": "Margin Bottom Desktop", "min": 0, "max": 100, "default": 20 },

    { "type": "range", "id": "mt_mobile", "label": "Margin Top Mobile", "min": 0, "max": 100, "default": 10 },
    { "type": "range", "id": "mb_mobile", "label": "Margin Bottom Mobile", "min": 0, "max": 100, "default": 10 },

    { "type": "image_picker", "id": "left_image", "label": "Left Image" },

    { "type": "text", "id": "heading", "label": "Heading", "default": "INTERLOCKED RING SHANK" },
    { "type": "textarea", "id": "subheading", "label": "Sub Heading", "default": "Lorem ipsum dolor sit amet..." },

    { "type": "text", "id": "rating_heading", "label": "Rating Heading", "default": "RECOMMENDED FOR" },

    { "type": "range", "id": "rating_value", "label": "Rating Out of 5", "min": 0, "max": 5, "step": 0.1, "default": 3.5 },

    { "type": "text", "id": "rating_subheading", "label": "Rating Subheading", "default": "Party Wear / Bridal Wear" },

    { "type": "text", "id": "cta_text", "label": "CTA Button Text", "default": "EXPLORE SIMILAR DESIGN" }
  ],
  "presets": [
    { "name": "Interlocked Rating" }
  ]
}
{% endschema %}
