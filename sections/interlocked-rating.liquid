<section 
  id="interlocked-rating-section_{{ section.id }}"
  style="
    margin-top: {{ section.settings.mt_desktop }}px;
    margin-bottom: {{ section.settings.mb_desktop }}px;
  "
>
  <div class="irs-container page-width {% if section.settings.reverse_layout %}irs-reverse{% endif %}">

    <!-- LEFT IMAGE -->
    <div class="irs-left">
      {% if section.settings.left_image %}

        <img 
          src="{{ section.settings.left_image | image_url: width: 500 }}"
          alt="interlocked-left"
          class="irs-left-img"
        >
          
      {% endif %}
    </div>

    <!-- RIGHT CONTENT -->
    <div class="irs-right">

      <h2 class="irs-heading">{{ section.settings.heading }}</h2>
      <p class="irs-subheading">{{ section.settings.subheading }}</p>

      <h3 class="irs-rating-title">{{ section.settings.rating_heading }}</h3>

      <!-- BLOCKS -->
      <div class="irs-rating-blocks">
        {% for block in section.blocks %}
          <div class="irs-rating-item">

            <div class="irs-rating-circle" data-rating="{{ block.settings.rating_value }}">
              <svg class="irs-svg" width="100" height="100">
                <circle class="irs-bg" cx="50" cy="50" r="45" />
                <circle class="irs-progress" cx="50" cy="50" r="45" />
              </svg>

              <div class="irs-rating-text">
                {{ block.settings.rating_value }}
                <span>out of 5</span>
              </div>
            </div>

            <p class="irs-rating-sub">{{ block.settings.rating_subheading }}</p>
          </div>
        {% endfor %}
      </div>

      {% comment %} {% if section.settings.cta_text %}
        <a class="irs-btn" href="{{ section.settings.button_url }}" >{{ section.settings.cta_text }}</a>
      {% endif %} {% endcomment %}

    </div>

  </div>
</section>

<style>
#interlocked-rating-section_{{ section.id }} {
  width: 100%;
}

#interlocked-rating-section_{{ section.id }} .irs-container {
  display: flex;
  align-items: center;
  gap: 20px;
}

/* NEW — reverse layout */
#interlocked-rating-section_{{ section.id }} .irs-container.irs-reverse {
  flex-direction: row-reverse;
}

#interlocked-rating-section_{{ section.id }} .irs-left-img {
  width: 100%;
  height:auto;
}
#interlocked-rating-section_{{ section.id }} .irs-right{
  width:100%;
  }
#interlocked-rating-section_{{ section.id }} .irs-left {
  display: flex;
    align-items: center;
    justify-content: center;
}
#interlocked-rating-section_{{ section.id }} .irs-right {
  display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

#interlocked-rating-section_{{ section.id }} .irs-right {
  width: 50%;
}

#interlocked-rating-section_{{ section.id }} .irs-heading {
  font-weight: 500;
  font-size: 32px;
  line-height: 150%;
  text-align: center;
  vertical-align: middle;
  text-transform: uppercase;
  text-align:center;
  margin:0;
  margin-bottom:12px;
}

#interlocked-rating-section_{{ section.id }} .irs-subheading {
  margin:0;
  font-weight: 400;
    font-size: 18px;
    line-height: 24px;
    text-align: center;
    vertical-align: middle;
    margin-bottom:48px;
}

#interlocked-rating-section_{{ section.id }} .irs-rating-title {
  margin:0;
 font-weight: 500;
    font-size: 24px;
    line-height: 150%;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
    margin-bottom: 24px;
}

#interlocked-rating-section_{{ section.id }} .irs-rating-blocks {
  margin:0;
  display: flex;
  gap: 60px;
}

#interlocked-rating-section_{{ section.id }} .irs-rating-item {
  text-align: center;
}

/* Circle */
#interlocked-rating-section_{{ section.id }} .irs-rating-circle {
  position: relative;
  width: 100px;
  height: 100px;
}

#interlocked-rating-section_{{ section.id }} .irs-svg {
  transform: rotate(-90deg);
}

#interlocked-rating-section_{{ section.id }} circle {
  fill: none;
  stroke-width: 7;
}

#interlocked-rating-section_{{ section.id }} .irs-bg {
  stroke: #e6e6e6;
}

#interlocked-rating-section_{{ section.id }} .irs-progress {
  stroke: #666666;
  stroke-dasharray: 283;
  stroke-dashoffset: 283;
  transition: stroke-dashoffset 1.4s ease;
}

#interlocked-rating-section_{{ section.id }} .irs-rating-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 22px;
  font-weight: 600;
}

#interlocked-rating-section_{{ section.id }} .irs-rating-text span {
  display: block;
  font-size: 11px;
  color: #888;
  margin-top: -3px;
  font-weight: 400;
}

#interlocked-rating-section_{{ section.id }} .irs-rating-sub {
  margin: 0;
 font-weight: 400;
    font-size: 18px;  
    line-height: 24px;
    vertical-align: middle;
    margin-top: 16px;
    max-width:10ch;
}

#interlocked-rating-section_{{ section.id }} .irs-btn {
  background: #A68380;
  color: #fff;
  text-decoration: none;
  border-radius: 12px;
  padding: 22px 36px;
    margin-top: 70px;
    font-weight: 500;
    font-size: 16px;
    line-height: 100%;
    text-transform: uppercase;
}

@media (max-width: 1100px) {
#interlocked-rating-section_{{ section.id }} .irs-rating-blocks {
    column-gap: 10px;
  }
}
@media (max-width: 768px) {
  #interlocked-rating-section_{{ section.id }} {
    margin-top: {{ section.settings.mt_mobile }}px !important;
    margin-bottom: {{ section.settings.mb_mobile }}px !important;
  }

  #interlocked-rating-section_{{ section.id }} .irs-container {
    flex-direction: column !important;
    text-align: center;
  }
  #interlocked-rating-section_{{ section.id }} .irs-rating-blocks {
  display:grid;
  grid-template-columns:1fr 1fr;
  row-gap: 20px;
    column-gap: 60px;
  }
  #interlocked-rating-section_{{ section.id }} .irs-right{
  width:100%;
  }
  #interlocked-rating-section_{{ section.id }} .irs-right{
  width:100%;
  }
  #interlocked-rating-section_{{ section.id }} .irs-heading {
  font-size: 18px;
  margin-bottom:6px;
}
#interlocked-rating-section_{{ section.id }} .irs-subheading {
    font-size: 12px;
    margin-bottom:24px;
}
#interlocked-rating-section_{{ section.id }} .irs-rating-title {
    font-size: 14px;
}
#interlocked-rating-section_{{ section.id }} .irs-rating-sub {
    font-size: 14px;
    margin-top: 12px;
}
#interlocked-rating-section_{{ section.id }} .irs-btn {
    margin-top: 40px;
    padding: 18px 19px;
    font-size:14px;
}
#interlocked-rating-section_{{ section.id }} .irs-container{
gap:20px;
}
}
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const sec = document.getElementById("interlocked-rating-section_{{ section.id }}");
  if (!sec) return;

  const circles = sec.querySelectorAll(".irs-rating-circle");

  const observer = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) {

      circles.forEach(circle => {
        const progress = circle.querySelector(".irs-progress");
        const rating = parseFloat(circle.dataset.rating);
        const total = 283;
        const offset = total - (rating / 5) * total;

        progress.style.strokeDashoffset = offset;
      });

    }
  }, { threshold: 0.8 });

  observer.observe(sec);
});
</script>


{% schema %}
{
  "name": "Interlocked Rating",
  "settings": [
    { "type": "range", "id": "mt_desktop", "label": "Margin Top Desktop", "min": 0, "max": 100, "default": 20 },
    { "type": "range", "id": "mb_desktop", "label": "Margin Bottom Desktop", "min": 0, "max": 100, "default": 20 },

    { "type": "range", "id": "mt_mobile", "label": "Margin Top Mobile", "min": 0, "max": 100, "default": 10 },
    { "type": "range", "id": "mb_mobile", "label": "Margin Bottom Mobile", "min": 0, "max": 100, "default": 10 },

    { "type": "image_picker", "id": "left_image", "label": "Left Image" },

    { "type": "text", "id": "heading", "label": "Heading", "default": "INTERLOCKED RING SHANK" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Lorem ipsum dolor sit amet..." },
    { "type": "url", "id": "button_url", "label": "Button URL", "default": "/collections/all" },
    { "type": "text", "id": "rating_heading", "label": "Rating Heading", "default": "RECOMMENDED FOR" },

    { "type": "text", "id": "cta_text", "label": "CTA Button Text", "default": "EXPLORE SIMILAR DESIGN" },

    {
      "type": "checkbox",
      "id": "reverse_layout",
      "label": "Reverse Layout (Image Right, Content Left)",
      "default": false
    }
  ],

  "blocks": [
  {
    "type": "rating_block",
    "name": "Rating Item",
    "settings": [
      {
        "type": "range",
        "id": "rating_value",
        "label": "Rating (0–5)",
        "min": 0,
        "max": 5,
        "step": 0.1,
        "default": 4.5
      },
      {
        "type": "text",
        "id": "rating_subheading",
        "label": "Rating Sub Text",
        "default": "Bridal Wear"
      },
      {
        "type": "url",
        "id": "link",
        "label": "Click Link"
      }
    ]
  }
],

  "max_blocks": 4,

  "presets": [
    { "name": "Interlocked Rating" }
  ]
}
{% endschema %}
