<style>
  input[type="number"] {
	-webkit-appearance: textfield;
	-moz-appearance: textfield;
	appearance: textfield;
}

input[type=number]::-webkit-inner-spin-button,
input[type=number]::-webkit-outer-spin-button {
	-webkit-appearance: none;
}

#brad-contact-section {
	padding: 50px 0;
}

.contact-section {
	background-color: #f9f6f6;
	position: relative;
}

.contact-wrapper {
	display: flex;
	align-items: flex-start;
	justify-content: space-between;
}

.contact-left {
	flex: 1;
	padding-right: 40px;
}

.contact-left h2 {
	font-size: 20px;
	font-weight: 500;
	color: #1a1a1a;
	margin-bottom: 15px;
	text-transform: uppercase;
}

.contact-left p {
	font-size: 14px;
	color: #555;
	line-height: 1.6;
	max-width: 350px;
}

.contact-form {
	flex: 1.5;
}

.form-row {
	display: flex;
	justify-content: space-between;
	margin-bottom: 30px;
	gap: 30px;
}

.form-group {
	flex: 1;
}

.form-input,
.form-select,
.form-textarea {
	width: 100%;
	border: none;
	border-bottom: 1px solid #ccc;
	background: transparent;
	padding: 8px 0;
	font-size: 14px;
	box-shadow: none;
	font-family: 'Futura Std', sans-serif;
}

.form-input:focus,
.form-select:focus,
.form-textarea:focus {
	outline: none;

		{
		% comment %
	}

	border-color: #000;

		{
		% endcomment %
	}
}

.form-textarea {
	resize: none;
	min-height: 80px;
}

.send-button { margin-top: 20px; background: #a68380; color: #fff; padding: 12px 40px; border: none; cursor: pointer; font-size: 14px; border-radius: 12px; letter-spacing: 1.3px; transition: background 0.3s ease; font-family: 'Futura Std', sans-serif; }

.send-button:hover {
	background: #8e6e6b;
}

/* Background branding image */
.contact-bg-img {
	position: absolute;
	bottom: 20px;
	left: 0;
	width: 409px;
	pointer-events: none;
}
.map-section {margin-bottom: 0 !important;}
/* Responsive */
@media screen and (max-width: 768px) {
	.contact-wrapper {
		flex-direction: column;
	}

	.form-row {
		flex-direction: column;
		gap: 20px;
	}

	.contact-bg-img {
		display: none;
	}

	.contact-form {
		width: 100%;
	}

	.contact-section {
		padding: 30px;

	}

	.contact-left {
		text-align: center;
		padding-right: 0px;
	}

  #brad-contact-section { padding: 40px 0; }
  .contact-section {padding: 30px 0;}
  .contact-wrapper {align-items: center;}
  .contact-left p {margin-bottom: 30px; font-size: 12px;}
  .contact-section {padding: 0;}
  .map-section {margin-bottom: 0 !important;}
  .lucira-section.faq-section h2 { text-align: center; margin-bottom: 6px; margin-top: 0; }
  .contact-left h2 {margin-top: 0; margin-bottom: 12px;}
  .contact-left p { margin-bottom: 24px; margin-top: 12px; }
  .form-row {margin-bottom: 16px;}
  .form-row {gap: 16px;}
  .contact-left h2 {font-size: 18px;}
  .contact-form form {text-align: center;}

}

</style>


<div class="contact-section">
<div class="page-width" style="position: relative; padding: 50px 0;">

  <!-- Background Image from customization -->
  {% if section.settings.bg_logo %}
    <img src="{{ section.settings.bg_logo | image_url }}" alt="Branding Logo" title="Branding Logo" class="contact-bg-img">
  {% endif %}


  <div class="contact-wrapper">
    <!-- Left -->
    <div class="contact-left">
      <h2>Get In Touch</h2>
      <p>Please share your details below and our jewelry concierge will be in touch with you shortly.</p>
    </div>

    <!-- Right -->
    <div class="contact-form">
      <form action="/contact#contact-form" method="post">
        <input type="hidden" name="form_type" value="contact">
        <input type="hidden" name="utf8" value="✓">

        <div class="form-row">
          <div class="form-group">
            <input type="text" 
              name="contact[name]" 
              class="form-input" 
              placeholder="Your Name" 
              required 
              pattern="[A-Za-z\s]+" 
              title="Please enter letters and spaces only."
              oninput="this.value = this.value.replace(/[^A-Za-z\s]/g, '')">
          </div>
          <div class="form-group">
            <input type="email" name="contact[email]" class="form-input" placeholder="Your Email" required>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <input type="number" 
                  name="contact[phone]" 
                  class="form-input" 
                  placeholder="Phone Number" 
                  oninput="if(this.value.length > 10) this.value = this.value.slice(0, 10);" 
                  maxlength="10"
                  data-gtm-form-interact-field-id="0">          
            </div>
        </div>

        <div class="form-row">
          <div class="form-group" style="width: 100%;">
            <textarea name="contact[body]" class="form-textarea" placeholder="Message" required></textarea>
          </div>
        </div>

        <button type="submit" class="send-button">SUBMIT</button>
      </form>
    </div>
  </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact Form Minimal",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_logo",
      "label": "Background Logo Image"
    }
  ],
  "presets": [
    {
      "name": "Contact Form Minimal"
    }
  ]
}
{% endschema %}
