{% schema %}
{
  "name": "Lucira Size Guide - page",
  "tag": "section",
  "class": "lucira-size-guide-wrapper",
  "settings": [],
  "blocks": [],
  "presets": [
    {
      "name": "Lucira Size Guide Section - page"
    }
  ]
}
{% endschema %}

{% style %}
.lucira-size-guide-wrapper{font-family:'Futura Std',Futura,sans-serif;padding:40px clamp(12px,4vw,40px);margin:0 auto!important;max-width:1400px;width:100%;box-sizing:border-box;color:#333}
.section{margin-bottom:clamp(30px,5vw,40px)}
.section-content{width:100%}
.lucira-size-guide-wrapper h1.page-title{text-align:center;font-weight:500;font-size:clamp(20px,5vw,28px);margin-bottom:clamp(24px,4vw,32px);line-height:150%;color:#222}
.lucira-size-guide-wrapper .section h2{font-size:clamp(18px,4vw,20px);font-weight:500;margin:0 0 16px;line-height:150%;border-left:4px solid #b48c54;padding-left:12px;color:#333}
.container{display:flex;flex-wrap:wrap;padding:clamp(10px,3vw,20px);gap:clamp(15px,3vw,20px);max-width:1200px;margin:auto}
.text-column,.video-column{flex:1 1 300px}
.text-column{display:flex;flex-direction:column;justify-content:center;padding:clamp(15px,3vw,20px);background-color:#fff8e1;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.1)}
.custom-container{display:flex;flex-wrap:wrap;gap:clamp(15px,3vw,20px);max-width:1200px;margin:0 auto;padding:clamp(10px,3vw,20px)}
.custom-image-column,.custom-text-column{flex:1 1 300px}
.custom-text-column{display:flex;flex-direction:column;justify-content:center;background-color:#fff8e1;padding:clamp(15px,3vw,20px);border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.1)}
.custom-image-column img{width:100%;height:auto;max-height:600px;object-fit:contain;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.1)}
.video-column video{width:100%;height:auto;max-height:500px;object-fit:contain;border-radius:12px;box-shadow:0 2px 6px rgba(0,0,0,.1)}
.text-content{width:100%}
.text-content h1{font-size:clamp(18px,4vw,24px);font-weight:500;margin-bottom:16px;line-height:1.4}
.text-content li,.text-content p{font-weight:300;font-size:clamp(14px,3vw,16px);line-height:1.6;margin:0 0 12px;color:#333}
.text-content ol,.text-content ul{padding-left:20px;margin:0 0 16px}
.text-content li{margin-bottom:8px}
.ring-section-layout{display:flex;flex-direction:column;gap:clamp(1.5rem,3vw,2rem);max-width:1200px;margin:0 auto;width:100%}
.table-container{background-color:#fff;padding:clamp(16px,3vw,24px);border-radius:10px;box-shadow:0 0 10px rgba(0,0,0,.05)}
.video-container{background-color:#fff;padding:clamp(16px,3vw,24px);border-radius:10px;box-shadow:0 0 10px rgba(0,0,0,.05);display:flex;flex-direction:column;align-items:center}
.split-table-container{display:flex;flex-wrap:wrap;gap:clamp(15px,3vw,20px);justify-content:space-between}
.table-column{flex:1 1 280px;width:100%}
.two-column-layout{display:flex;flex-wrap:wrap;gap:clamp(1.5rem,3vw,2rem);justify-content:space-between;align-items:flex-start;max-width:1200px;margin:0 auto;width:100%}
.left-column{flex:1 1 300px;background-color:#fff;padding:clamp(16px,3vw,24px);border-radius:10px;box-shadow:0 0 10px rgba(0,0,0,.05)}
.right-column{flex:1 1 300px;background-color:#fff;padding:clamp(16px,3vw,24px);border-radius:10px;box-shadow:0 0 10px rgba(0,0,0,.05);display:flex;flex-direction:column;align-items:center}
.right-column video,.video-container video{width:100%;height:auto;max-width:500px;max-height:500px;object-fit:contain;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.1)}
.right-column h2,.video-container h2{width:100%;text-align:center;margin-bottom:16px;font-size:clamp(18px,4vw,20px)}
.table-wrapper{width:100%;overflow-x:auto;-webkit-overflow-scrolling:touch;margin-bottom:24px;background:#fff;border:1px solid #eee;border-radius:8px;padding:clamp(12px,2vw,16px);box-shadow:0 2px 5px rgba(0,0,0,.05)}
table{width:100%;border-collapse:collapse;font-size:clamp(12px,3vw,14px)}
td,th{border:1px solid #e0e0e0;padding:clamp(6px 4px,2vw,12px 8px);text-align:center}
th{background-color:#f9f9f9;font-weight:500}
.responsive-table{font-size:clamp(12px,3vw,14px);width:100%;min-width:300px}
.responsive-table-wrapper{width:100%;overflow-x:auto;-webkit-overflow-scrolling:touch;margin-bottom:20px;background:#fff;border-radius:8px;box-shadow:0 0 10px rgba(0,0,0,.05)}
.responsive-table td,.responsive-table th{white-space:nowrap;padding:clamp(6px 4px,2vw,10px 8px);text-align:center;border:1px solid #e0e0e0}
.responsive-table tr td:first-child,.responsive-table tr th:first-child{position:sticky;left:0;background-color:#f9f9f9;z-index:1;border-right:2px solid #ddd}
.discover{font-size:clamp(.9rem,3vw,1.2rem);border-radius:14px;color:#fff;text-decoration:none;text-transform:uppercase;background:#a68380;padding:.6rem 1.5rem;text-align:center;display:inline-block;margin:1rem 0;transition:all .3s ease;border:none;cursor:pointer;box-shadow:0 2px 5px rgba(0,0,0,.1);width:auto}
.discover:hover{background:#95736f;transform:translateY(-2px);box-shadow:0 4px 8px rgba(0,0,0,.15)}
.text-content a{text-decoration:none;transition:all .2s ease}
.ring-discover-btn{display:grid;justify-content:center}
@media (max-width:1200px){
.ring-discover-btn{display:grid;justify-content:center}
.lucira-size-guide-wrapper{padding:30px clamp(16px,4vw,24px)}
.discover{font-size:1.1rem;padding:.8rem 2rem}
}
@media (max-width:992px){
.two-column-layout{flex-direction:column}
.left-column,.right-column{flex:1 1 100%;width:100%;margin-bottom:2rem}
.table-column{flex:1 1 100%}
}
@media (max-width:768px){
.lucira-size-guide-wrapper{padding:24px clamp(12px,3vw,16px);margin:0!important}
.lucira-size-guide-wrapper h1.page-title{font-size:clamp(20px,5vw,22px);margin-bottom:24px}
.text-content h1{font-size:clamp(18px,4vw,20px)}
.section{margin-bottom:clamp(24px,4vw,30px)}
.responsive-table,.ring-size-table{font-size:13px}
.responsive-table td,.responsive-table th,.ring-size-table td,.ring-size-table th{padding:8px 6px}
.lucira-size-guide-wrapper .section h2{font-size:18px}
.text-content li,.text-content p{font-size:15px}
.discover{font-size:1rem;padding:.7rem 1.8rem;width:calc(100% - 20px);max-width:400px;margin:1rem auto;display:block}
}
@media (max-width:480px){
.container{padding:10px;gap:15px}
.lucira-size-guide-wrapper{padding:16px 12px;margin-left:0!important}
.lucira-size-guide-wrapper h1.page-title{font-size:20px}
.text-content h1{font-size:18px}
.table-wrapper{padding:10px}
td,th{font-size:12px;padding:8px 4px}
.responsive-table,.ring-size-table{font-size:12px}
.responsive-table td,.responsive-table th,.ring-size-table td,.ring-size-table th{padding:6px 4px}
.discover{font-size:.9rem;padding:.6rem 1.5rem;width:100%}
.text-content li,.text-content p{font-size:14px}
.left-column,.right-column,.table-container,.video-container{padding:16px}
.right-column video,.video-column video,.video-container video{max-height:300px}
}
{% endstyle %}

<section class="lucira-size-guide-wrapper">
