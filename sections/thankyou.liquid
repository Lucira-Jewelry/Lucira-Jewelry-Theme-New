<!DOCTYPE html>
<html>
<head>
  <title>Thank You</title>
  
  <!-- Auto download PDF -->
  <meta http-equiv="refresh" content="0; url=https://drive.google.com/uc?export=download&id=1qcSbGvT5CqVzTLeWJQeael_vg-KW5Llv">

  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: "Inter", Arial, sans-serif;
      background: #f6f9fc;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      text-align: center;
    }

    .container {
      background: #ffffff;
      padding: 40px 30px;
      width: 90%;
      max-width: 480px;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      animation: fadeIn 0.7s ease-out;
    }

    .checkmark {
      width: 90px;
      height: 90px;
      border-radius: 50%;
      border: 5px solid #4CAF50;
      display: flex;
      justify-content: center;
      align-items: center;
      margin: 0 auto 20px;
      animation: pop 0.4s ease-out forwards;
    }

    .checkmark svg {
      width: 50px;
      height: 50px;
      stroke: #4CAF50;
      stroke-width: 6;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 100;
      stroke-dashoffset: 100;
      animation: draw 0.8s ease forwards 0.3s;
    }

    h1 {
      font-size: 26px;
      margin-bottom: 10px;
      color: #222;
    }

    p {
      font-size: 16px;
      line-height: 1.6;
      color: #555;
      margin-bottom: 25px;
    }

    .download-btn {
      display: inline-block;
      padding: 14px 30px;
      background: #4CAF50;
      color: white;
      border-radius: 50px;
      text-decoration: none;
      font-size: 16px;
      transition: 0.25s;
    }

    .download-btn:hover {
      background: #43a047;
    }

    @keyframes draw {
      to { stroke-dashoffset: 0; }
    }

    @keyframes pop {
      0% { transform: scale(0.5); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>

<body>
  <div class="container">

    <!-- Animated Checkmark -->
    <div class="checkmark">
      <svg viewBox="0 0 52 52">
        <path d="M14 27l7 7 17-17"/>
      </svg>
    </div>

    <h1>Thank You!</h1>
    <p>Your submission has been received.<br>
       Our executive will contact you shortly.</p>

    <a class="download-btn" 
       href="https://drive.google.com/uc?export=download&id=1qcSbGvT5CqVzTLeWJQeael_vg-KW5Llv">
      Download Brochure
    </a>

  </div>

  <!-- Auto open PDF in new tab -->
  <script>
    window.onload = function () {
      window.open("https://drive.google.com/file/d/1qcSbGvT5CqVzTLeWJQeael_vg-KW5Llv/view", "_blank");
    };
  </script>

</body>
</html>
