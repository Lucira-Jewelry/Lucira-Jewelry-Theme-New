<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Thank You - {{ shop.name }}</title>
  
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: "Futura Std", "Inter", Arial, sans-serif;
      background: #f6f9fc;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      text-align: center;
    }

    .container {
      background: #ffffff;
      padding: 50px 40px;
      width: 90%;
      max-width: 520px;
      border-radius: 20px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
      animation: fadeIn 0.7s ease-out;
    }

    .checkmark {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      border: 5px solid #4CAF50;
      display: flex;
      justify-content: center;
      align-items: center;
      margin: 0 auto 30px;
      animation: pop 0.4s ease-out forwards;
    }

    .checkmark svg {
      width: 55px;
      height: 55px;
      stroke: #4CAF50;
      stroke-width: 6;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 100;
      stroke-dashoffset: 100;
      animation: draw 0.8s ease forwards 0.3s;
    }

    h1 {
      font-size: 32px;
      font-weight: 600;
      margin-bottom: 15px;
      color: #222;
      letter-spacing: 1px;
    }

    p {
      font-size: 17px;
      line-height: 1.7;
      color: #555;
      margin-bottom: 30px;
    }

    .download-btn {
      display: inline-block;
      padding: 16px 40px;
      background: #A68380;
      color: white;
      border-radius: 50px;
      text-decoration: none;
      font-size: 16px;
      font-weight: 500;
      letter-spacing: 1px;
      text-transform: uppercase;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(166, 131, 128, 0.3);
    }

    .download-btn:hover {
      background: #956e6b;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(166, 131, 128, 0.4);
    }

    .back-link {
      display: inline-block;
      margin-top: 25px;
      color: #A68380;
      text-decoration: none;
      font-size: 15px;
      transition: color 0.3s;
    }

    .back-link:hover {
      color: #956e6b;
      text-decoration: underline;
    }

    @keyframes draw {
      to { stroke-dashoffset: 0; }
    }

    @keyframes pop {
      0% { transform: scale(0.5); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 576px) {
      .container {
        padding: 40px 30px;
      }

      h1 {
        font-size: 26px;
      }

      p {
        font-size: 15px;
      }

      .download-btn {
        padding: 14px 35px;
        font-size: 14px;
      }

      .checkmark {
        width: 85px;
        height: 85px;
      }

      .checkmark svg {
        width: 45px;
        height: 45px;
      }
    }
  </style>
</head>

<body>
  <div class="container">

    <!-- Animated Checkmark -->
    <div class="checkmark">
      <svg viewBox="0 0 52 52">
        <path d="M14 27l7 7 17-17"/>
      </svg>
    </div>

    <h1>Thank You!</h1>
    <p>
      Your submission has been received.<br>
      Our executive will contact you shortly.
    </p>

    <a class="download-btn" 
       href="https://drive.google.com/uc?export=download&id=1qcSbGvT5CqVzTLeWJQeael_vg-KW5Llv"
       download>
      Download Brochure
    </a>

    <br>
    <a class="back-link" href="/">← Back to Home</a>

  </div>

  <!-- Auto open PDF in new tab -->
  <script>
    window.onload = function () {
      // Track thank you page view
      if (window.dataLayer) {
        window.dataLayer.push({
          event: 'thankYouPage',
          pageType: 'franchise_registration_success',
          timestamp: new Date().toISOString()
        });
      }

      // Open PDF in new tab
      setTimeout(function() {
        window.open("https://drive.google.com/file/d/1qcSbGvT5CqVzTLeWJQeael_vg-KW5Llv/view", "_blank");
      }, 500);
    };
  </script>

</body>
</html>