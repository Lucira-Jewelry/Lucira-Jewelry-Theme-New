      "default": "Rupesh Jain"
    },
    {
      "type": "text",
      "id": "founder_role",
      "label": "Role",
      "default": "Founder & CEO"
    },
    {
      "type": "textarea",
      "id": "founder_quote",
      "label": "Founder Quote",
      "default": "Jewelry runs in my blood—it's who I am. After building brands in India, I created Lucira to go beyond tradition and craft pieces that reflect elegance and meaning. For me, jewelry isn't just adornment—it's a celebration of moments, love, and legacy. Every piece we make is a promise."
    },
    {
      "type": "image_picker",
      "id": "signature_black",
      "label": "Signature (Black/Background)"
    },
    {
      "type": "image_picker",
      "id": "signature_white",
      "label": "Signature (White/Foreground)"
    }
  ]
}
{% endschema %}

