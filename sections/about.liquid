<section class="about-us">
  <div class="container">
    <!-- Black ABOUT US Image (background layer) -->
    <div class="about-heading about-heading-black">
      {% if section.settings.about_us_black != blank %}
        <img src="{{ section.settings.about_us_black | image_url: width: 1200 }}" 
          alt="About Us" class="about-heading-img">
      {% endif %}
    </div>
    
    <!-- White ABOUT US Image (foreground layer with overflow hidden) -->
    

    <div class="about-content">
      <!-- Founder Image with overlay and white text/signature wrapper -->
       <div class="founder-image">
        <!-- White ABOUT US Image wrapper with overflow hidden -->
        <div class="white-layer-wrapper">
          <div class="about-heading-white-inner">
            {% if section.settings.about_us_white != blank %}
              <img src="{{ section.settings.about_us_white | image_url: width: 1200 }}" 
                alt="About Us" class="about-heading-img-white">
            {% endif %}
          </div>
          {% comment %} <div class="about-heading about-heading-white">
      {% if section.settings.about_us_white != blank %}
        <img src="{{ section.settings.about_us_white | image_url: width: 1200 }}" 
          alt="About Us" class="about-heading-img">
      {% endif %}
    </div> {% endcomment %}
          <!-- White Signature inside wrapper -->
          {% if section.settings.signature_white != blank %}
            <img class="signature signature-white-inner" 
              src="{{ section.settings.signature_white | image_url: width: 200 }}"
              alt="Signature overlay">
          {% else %}
            <img class="signature signature-white-inner" 
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Group_1321315955-removebg-preview.png?v=1758787779"
              alt="Signature overlay">
          {% endif %}
        </div>
        
        {% if section.settings.founder_image != blank %}
          <img class="founder-photo"
            src="{{ section.settings.founder_image | image_url: width: 560, height: 700 }}" 
            alt="{{ section.settings.founder_name }}" width="560" height="700">
        {% else %}
          <!-- fallback if no image is picked -->
          <img class="founder-photo"
            src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Group_1321315953.png?v=1758787466"
            alt="Founder">
        {% endif %}

        <!-- Black Signature (background layer) -->
        {% if section.settings.signature_black != blank %}
          <img class="signature signature-black" 
            src="{{ section.settings.signature_black | image_url: width: 200 }}"
            alt="Signature">
        {% else %}
          <img class="signature signature-black" 
            src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Group_1321315955-removebg-preview.png?v=1758787779"
            alt="Signature">
        {% endif %}
        
        <div class="founder-details">
          <h3 class="founder-name">{{ section.settings.founder_name }}</h3>
          <p class="founder-role">{{ section.settings.founder_role }}</p>
        </div>
      </div>
                       


      <blockquote class="founder-quote">
        {{ section.settings.founder_quote }}
      </blockquote>
    </div>
  </div>
</section>

