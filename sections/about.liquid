{% schema %}
{
  "name": "About Lucira",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image_desktop",
      "label": "Hero Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Hero Background Image (Mobile)"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "We Are LUCIRA"
    },
    {
      "type": "textarea",
      "id": "main_text",
      "label": "Main Description",
      "default": "We believe jewelry is meant to be flaunted, not locked up. We believe it should accentuate and elevate our every day. And we believe that it's absolutely all right to go a bit extra when we want because life is meant to be squeezed the hell out of."
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title",
      "default": "Our Legacy of Excellence"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Hero Subtitle",
      "default": "Where timeless design meets unparalleled craftsmanship."
    },
    {
      "type": "image_picker",
      "id": "founder_image",
      "label": "Founder Image"
    },
    {
      "type": "image_picker",
      "id": "team_image",
      "label": "Team Image"
    },
    {
      "type": "image_picker",
      "id": "sustainability_image",
      "label": "Sustainability Image"
    }
  ],
  "presets": [
    {
      "name": "About Lucira",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}

<style>
  /* Base styles */
  .about-page {
    width: 100%;
    overflow-x: hidden;
    color: #333;
    font-family: Futura, "Trebuchet MS", Arial, sans-serif;
  }
  
  .about-container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 20px;
  }
  
  img {
    max-width: 100%;
    height: auto;
  }
  
  p {
    margin-bottom: 15px;
    line-height: 1.6;
    font-size: 15px;
    font-family: Futura, "Trebuchet MS", Arial, sans-serif;
    letter-spacing: 0.01em;
  }
  
  /* Updated heading styles with medium weight */
  .section-title, .hero-title, .feature-title {
    font-family: Futura, "Trebuchet MS", Arial, sans-serif;
    font-weight: 500;
    text-transform: uppercase;
    color: #1a1a1a;
    letter-spacing: 0.03em;
  }
  
  .section-subtitle {
    font-family: Futura, "Trebuchet MS", Arial, sans-serif;
    font-weight: 500;
    color: #1a1a1a;
    margin-bottom: 12px;
    letter-spacing: 0.02em;
  }
  
  /* Hero section */
  .hero {
    position: relative;
    background-color: #333;
    color: white;
    text-align: center;
    padding: 50px 20px;
    margin-bottom: 30px;
    background-size: cover;
    background-position: center;
    height: 500px;
    overflow: hidden;
  }
  
  .hero-desktop {
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  
  .hero-mobile {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  
  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    z-index: 1;
  }
  
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
  }
  
  /* Main heading section */
  .main-heading-section {
    text-align: center;
    max-width: 1000px;
    margin: 0 auto 30px;
    padding: 0 20px;
  }

  .main-heading-section .section-title {
    font-family: 'Futura', "Trebuchet MS", Arial, sans-serif;
    font-size: 42px;
    font-weight: 400;
    color: #4A4A4A;
    letter-spacing: 0.01em;
    text-transform: none;
    margin-bottom: 10px;
    margin-top: 0;
  }

  .main-heading-section .section-subtitle {
    font-family: 'Futura', "Trebuchet MS", Arial, sans-serif;
    font-size: 32px;
    font-weight: 400;
    color: #4A4A4A;
    letter-spacing: 0.01em;
    text-transform: none;
    margin-bottom: 25px;
    margin-top: 0;
  }

  .main-heading-section p {
    font-family: 'Futura', "Trebuchet MS", Arial, sans-serif;
    font-size: 18px;
    line-height: 1.8;
    color: #4A4A4A;
    max-width: 900px;
    text-align: center;
    margin: 0 auto 20px;
  }

  .main-heading-section p:last-child {
    margin-bottom: 30px;
  }
  
  /* About section */
  .about-section {
    margin-bottom: 20px;
  }
  
  /* Founder Section - Updated to match the image */
  .founder-section {
    margin-bottom: 30px;
    display: flex;
    flex-direction: row;
    border-bottom: 1px solid #eee;
    padding-bottom: 30px;
  }
  
  .founder-image {
    width: 400px;
    flex-shrink: 0;
  }
  
  .founder-image img {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .founder-content {
    padding-left: 30px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  .founder-name {
    font-size: 22px;
    font-weight: 600;
    color: #333;
    margin-bottom: 5px;
    text-transform: uppercase;
  }
  
  .founder-position {
    font-size: 14px;
    color: #666;
    margin-bottom: 0px;
    text-transform: uppercase;
  }
  
  .founder-bio {
    color: #555;
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 15px;
  }
  
  /* Promise section */
  .promise-section {
    margin-bottom: 30px;
  }
  
  /* Features grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
    margin-top: 20px;
    margin-bottom: 30px;
  }
  
  .feature-card {
    background-color: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 25px 18px;
    text-align: center;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .feature-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  }
  
  .feature-icon {
    width: auto;
    height: 40px;
    margin-bottom: 15px;
    display: block;
  }
  
  .feature-title {
    margin-bottom: 10px;
    font-family: Futura, "Trebuchet MS", Arial, sans-serif;
  }
  
  .feature-text {
    font-size: 14px;
    line-height: 1.4;
    color: #4d4d4d;
    font-family: Futura, "Trebuchet MS", Arial, sans-serif;
  }
  
  /* Sustainability section */
  .sustainability-section {
    margin-bottom: 30px;
  }
  
  .sustainability-content {
    display: flex;
    gap: 30px;
    align-items: flex-start;
    background-color: #f9f9f9;
    border-radius: 8px;
    overflow: hidden;
  }
  
  .sustainability-image {
    flex: 1;
    min-width: 200px;
  }
  
  .sustainability-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  
  .sustainability-text {
    flex: 1.2;
    padding: 25px;
  }
  
  /* Desktop-specific styles */
  @media screen and (min-width: 992px) {
    .about-container {
      padding-left: 50px;
    }
    
    .hero {
      height: 500px;
      display: flex;
      align-items: center;
    }
    
    .hero-desktop {
      display: block;
    }
    
    .hero-mobile {
      display: none;
    }
    
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    
    .sustainability-image img {
      min-height: 300px;
    }
  }

  .lucira-promise{
    margin-bottom:0px;
  }
  
  /* Mobile responsiveness */
  @media screen and (max-width: 991px) {
    .about-container {
      padding: 0 15px;
    }
    
    .hero {
      height: 350px;
    }
    
    .sustainability-content {
      flex-direction: column;
    }
    
    .sustainability-image {
      width: 100%;
      min-height: 250px;
    }
    
    .hero-desktop {
      display: none;
    }
    
    .hero-mobile {
      display: block;
    }
    
    .founder-section {
      flex-direction: column;
    }
    
    .founder-image {
      width: 100%;
      margin-bottom: 20px;
    }
    
    .founder-content {
      padding-left: 0;
    }
  }
  
  @media screen and (max-width: 768px) {
    .hero {
      height: 300px;
    }
    
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .section-title {
      font-size: 22px;
    }
    
    .section-subtitle {
      font-size: 18px;
    }
  }
  
  @media screen and (max-width: 480px) {
    .hero {
      padding: 50px 15px;
      height: 250px;
    }
    
    .features-grid {
      grid-template-columns: 1fr;
    }
    
    .feature-card {
      padding: 20px 15px;
    }
    
    .sustainability-text {
      padding: 15px;
    }
  }
  
  /* MOBILE STYLES - LEFT ALIGNED HEADINGS */
  @media screen and (max-width: 767px) {
    .main-heading-section {
      text-align: left;
      padding: 20px 15px;
      margin-bottom: 20px;
    }
    
    .main-heading-section .section-title {
      font-size: 26px;
      text-align: left;
      font-weight: 500;
      letter-spacing: 0.02em;
    }
    
    .main-heading-section .section-subtitle {
      font-size: 20px;
      text-align: left;
      margin-bottom: 15px;
      line-height: 1.3;
      letter-spacing: 0.02em;
    }
    
    .main-heading-section p {
      text-align: left;
      font-size: 16px;
      line-height: 1.6;
    }
    
    .founder-name {
      font-size: 18px;
    }
    
    .founder-position {
      font-size: 12px;
      margin-bottom: 15px;
    }
    
    .founder-bio {
      font-size: 14px;
      line-height: 1.5;
    }
  }

     /* Mobile-First Follow Us Section */
  .follow-us-section {
    display: flex;
    flex-direction: row; /* Stack vertically on mobile */
    padding: 15px 0;
    gap:20px;
    border-top: 1px solid #e6e6e6;
    border-bottom: 1px solid #e6e6e6;
    width: 110%;
  }
  .follow-us-heading {
    font-family: 'Futura', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    color: #1a1a1a;
    white-space: nowrap;
  }

  .social-icons-container {
    display: flex;
    flex-direction: row; /* Force horizontal layout */
    flex-wrap: wrap; /* Allow wrapping if needed */
    gap: 16px;
    align-items: center;
  }

  .social-icon {
    display: block;
    width: 24px;
    height: 24px;
    transition: transform 0.2s ease;
  }

  .social-icon img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  /* Tablet (768px) and above */
  @media (min-width: 768px) {
    .follow-us-section {
      flex-direction: row; /* Horizontal layout on larger screens */
      align-items: center;
      gap: 20px;
    }

    .social-icon {
      width: 20px;
      height: 20px;
    }
  }

  /* Desktop (1024px) and above */
  @media (min-width: 1024px) {
    .social-icon {
      width: 22px;
      height: 22px;
    }
  }

</style>

<!-- Hero Section with Desktop/Mobile Images -->
<div class="hero">
  <div class="hero-desktop">
    {% if section.settings.hero_image_desktop %}
      <img src="{{ section.settings.hero_image_desktop | img_url: 'master' }}" alt="About Lucira" style="width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0;">
    {% else %}
      <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/About-Us-Desktop-Banner_1.jpg?v=1743163400" alt="About Lucira" style="width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0;">
    {% endif %}
  </div>
  
  <div class="hero-mobile">
    {% if section.settings.hero_image_mobile %}
      <img src="{{ section.settings.hero_image_mobile | img_url: 'master' }}" alt="About Lucira" style="width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0;">
    {% else %}
      <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/About-Us-Mobile-Banner_1.jpg?v=1743164472" alt="About Lucira" style="width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0;">
    {% endif %}
  </div>
  
  <div class="hero-overlay"></div>
  <div class="hero-content"></div>
</div>

<div class="about-page">
  <!-- Main Heading Section (About Lucira) -->
  <div class="main-heading-section">
    <h2 class="section-title">About Lucira (Lu-see-ra)</h2>
    <h3 class="section-subtitle">Crafted For Extraordinary</h3>
    <div class="main-description">
      <p>
        Some shine because it wishes to seek attention, Lucira shines because it was crafted to effortlessly own it. No 
        matter where you are in the world, with Lucira, you get the finest and ethically sourced luxury jewelry. With 
        our founder's rich background in the jewelry industry, we are redefining the fine jewelry segment and 
        elevating the customer experience like never before.
      </p>
      <p>
        At <a href= https://www.lucirajewelry.com/ target="_blank">Lucira Jewelry</a>, excellence is non-negotiable. From Lab Grown Diamonds to intricate craftsmanship, every detail is 
        precisely created. We create heirlooms not for safekeeping, but with the glint so loud that it's a story - our pieces whisper, "I was here, and I dared."
      </p>
    </div>
  </div>
  
  <!-- About Container -->
  <div class="about-container">
    <!-- Founder Section - Updated to match the reference image -->
    <div class="founder-section">
      <div class="founder-image">
        {% if section.settings.founder_image %}
          <img src="{{ section.settings.founder_image | img_url: 'master' }}" alt="Rupesh Jain" loading="lazy">
        {% else %}
          <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/image_2_1.png?v=1743060630" alt="Rupesh Jain" loading="lazy">
        {% endif %}
      </div>
      <div class="founder-content">
        <div class="section-title">Meet Our Founder</div>
        <h3 class="founder-name">RUPESH JAIN</h3>
        <h4 class="founder-position">FOUNDER & CEO</h4>
          <section class="follow-us-section">
              <div class="follow-us-heading">FOLLOW ME ON:</div>
              <div class="social-icons-container">
                <a href="https://www.linkedin.com/in/rupeshjain85/" target="_blank" class="social-icon">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/linkedin.svg?v=1750316611"
                    alt="LinkedIn"
                    width="20"
                    height="20" loading="lazy"
                  >
                </a>
                
                <a href="https://www.instagram.com/rupeshjane/" target="_blank" class="social-icon">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/instagram_02e880b0-664e-4f9e-8cbe-3c56298a4b3e.svg?v=1750316612"
                    alt="Instagram"
                    width="20"
                    height="20" loading="lazy"
                  >
                </a>

                
              </div>
            </section>
        <p class="founder-bio">
          Hi, I'm Rupesh. Crafting jewelry is a part of my DNA, an extension of who I am. I was born into a family of jewelers. After building successful jewelry brands in India, I wanted to go beyond tradition and create something that screams elegance while being a reflection of what a customer needs. That's why I founded Lucira - to cater to every jewelry-related need.
        </p>
        <p class="founder-bio">
          For me, jewelry is more than an accessory. It is about a shining time capsule of the moments they carry and these moments deserve nothing less than perfection. When you choose Lucira, you invite me and my team into your story - a privilege and a responsibility I take to heart.
        </p>
        <p class="founder-bio">
         Each piece we create carries with it the heritage of generations of craftsmanship, reimagined for the modern connoisseur. Our artisans spend countless hours ensuring that every curve, every setting, and every finish meets our exacting standards.</p>
        <p class="founder-bio">We perfect every detail and are dedicated to making your journey effortless and your milestones unforgettable. Lucira isn't just jewelry - it's a celebration of love, legacy, and lasting brilliance.</p>
      </div>
    </div>

    <!-- Promise Section -->
    <div class="promise-section">
      <h2 class="section-title lucira-promise">The Lucira Promise</h2>
      <p>
        Our name itself is a promise. Derived from the Latin word <em>lucirá</em>, meaning 'shine', the name embodies 
        exactly what Lucira will be to you - uncompromising brilliance, timeless elegance, and the confidence that comes 
        with wearing something truly exceptional. With our pieces, the jewelry isn't in the keepsake, your moments are.
      </p>
      
      <!-- Features Grid -->
      <div class="features-grid">
        <!-- Craftsmanship -->
        <div class="feature-card">
          <img class="feature-icon" src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/diamond_3285794.svg?v=1743072943" alt="Craftsmanship Icon" loading="lazy">
          <h4 class="feature-title">Craftsmanship</h4>
          <p class="feature-text">
            Great things aren't rushed. At Lucira, our artisans perfect every detail, crafting each piece with precision 
            and purpose-as if it was always meant to be worn by you in that exact moment.
          </p>
        </div>
        
        <!-- Bespoke Experience -->
        <div class="feature-card">
          <img class="feature-icon" src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/smartphone_448669.svg?v=1743074118" alt="Bespoke Experience Icon" loading="lazy">
          <h4 class="feature-title">Bespoke Experience</h4>
          <p class="feature-text">
            Our experts guide you every step of the way, ensuring every question mark is a joyous exclamation mark in no time 
            because you deserve nothing less than certainty.
          </p>
        </div>
        
        <!-- Certified Excellence -->
        <div class="feature-card">
          <img class="feature-icon" src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/quality_7438031_1.svg?v=1743072943" alt="Certification Icon" loading="lazy">
          <h4 class="feature-title">Certified Excellence</h4>
          <p class="feature-text">
            We meet the highest quality standards. Certified by IGI and SGL, our lab-grown diamonds are meticulously graded 
            for brilliance, purity, and craftsmanship.
          </p>
        </div>
        
        <!-- Fast & Reliable Shipping -->
        <div class="feature-card">
          <img class="feature-icon" src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_427322803_1.svg?v=1743072943" alt="Shipping Icon" style="height: 40px; width: auto; object-fit: contain;" loading="lazy">
          <h4 class="feature-title">Fast &amp; Reliable Shipping</h4>
          <p class="feature-text">
            Our 100% insured shipping is reliable for your piece to show up at the promised time. Lucira aims to deliver 
            your exquisite piece with unmatched speed and precision.
          </p>
        </div>
      </div>
    </div>

    <!-- Sustainability Section -->
    <div class="sustainability-section">
      <h2 class="section-title">Sustainability and Packaging</h2>
      <div class="sustainability-content">
        <div class="sustainability-image">
          {% if section.settings.sustainability_image %}
            <img src="{{ section.settings.sustainability_image | img_url: 'master' }}" alt="Sustainable Packaging">
          {% else %}
            <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/lucira_couple_shoot_35113-min_1_1.jpg?v=1743075933" alt="Sustainable Packaging" loading="lazy">
          {% endif %}
        </div>
        <div class="sustainability-text">
          <p>
            You feel the luxury before you even reach your piece. As the ribbon effortlessly falls aside as you pull the silky 
            ends over the matte finish of the box, a magnetic clasp stands elegantly between you and your awe at the piece 
            waiting for you inside.
          </p>
          <p>
            Wrapped to provide you with a luxurious feel, our packaging is sustainable. We do not take our environmental impact 
            lightly. We are constantly making efforts to reduce our footprint to exist so seamlessly that nature remains unaware 
            of our presence. While we work towards that aim, we plant one tree per purchase helping us work towards restoring 
            our planet's beauty.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>