{% schema %}
{
  "name": "Featured Blogs",
  "tag": "section",
  "class": "homepage-blogs",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Select blog"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "LUCIRA BLOGS"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Where Craft Inspires Conversation"
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "label": "Number of articles to show",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured Blogs",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<div class="lucira-blog-section">
  <div class="page-width">
    <div class="blog-header">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>

    {% assign blog = blogs[section.settings.blog] %}
    {% if blog.articles.size > 0 %}
      <div class="blog-grid">
        {% for article in blog.articles limit: section.settings.articles_to_show %}
          <div class="blog-card">
            <a href="{{ article.url }}" class="blog-image">
              {% if article.image %}
                <img
                  srcset="
                    {%- if article.image.width >= 165 -%}{{ article.image | image_url: width: 165 }} 165w,{%- endif -%}
                    {%- if article.image.width >= 360 -%}{{ article.image | image_url: width: 360 }} 360w,{%- endif -%}
                    {%- if article.image.width >= 535 -%}{{ article.image | image_url: width: 535 }} 535w,{%- endif -%}
                    {%- if article.image.width >= 750 -%}{{ article.image | image_url: width: 750 }} 750w,{%- endif -%}
                    {%- if article.image.width >= 1070 -%}{{ article.image | image_url: width: 1070 }} 1070w,{%- endif -%}
                    {%- if article.image.width >= 1500 -%}{{ article.image | image_url: width: 1500 }} 1500w,{%- endif -%}
                    {{ article.image | image_url }} {{ article.image.width }}w
                  "
                  src="{{ article.image | image_url: width: 1500 }}"
                  sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)"
                  alt="{{ article.image.alt  | escape }}"
                  title="{{ article.image.alt  | escape }}"
                  loading="lazy"
                  class="card-image"
                  width="415"
                  height="480"
                >
              {% endif %}
            </a>
            <a href="{{ article.url }}" class="arrow-link">
              <div class="blog-content">
                {% if article.tags.size > 0 %}
                  <p class="blog-tag">{{ article.tags.first }}</p>
                {% endif %}
                <div class="des-arrow-div">
                  <p class="blog-title">{{ article.title | truncatewords: 6 }}</p>

                  <img
                    src="{{ 'arrow.svg' | asset_url }}"
                    alt="Arrow"
                    title="Arrow"
                    class="blog-card-avatar"
                    loading="lazy"
                    width="40"
                    height="40"
                  >
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      <div class="load-more-wrap">
        <a href="{{ blog.url }}" class="load-more-btn" aria-label="Read more blog stories">Read more blogs</a>
      </div>
    {% endif %}
  </div>
</div>

<style>
  {% comment %} .blog-card {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.blog-card.visible {
  opacity: 1;
  transform: translateY(0);
} {% endcomment %}
  .des-arrow-div{display:flex;align-items:center}
  .lucira-blog-section{margin:0 auto;padding:30px 0 30px 0;text-align:center}
  .blog-header h2{font-size:24px;letter-spacing:1px;text-transform:uppercase;color:#1a1a1a;margin-top: 0; margin-bottom:6px!important}
  .blog-header p{max-width:600px;margin:0 auto 40px;font-size:18px;color:#555}
  .blog-grid{display:grid;grid-template-columns:repeat(4,1fr);flex-wrap:wrap;gap:20px;position:relative;max-width:85%;margin:0 auto;margin-bottom:2rem}
  .blog-card{text-align:left;display:flex;flex-direction:column;gap:1.5rem;margin-bottom:2rem;cursor:pointer;transition:transform .3s ease}
  .blog-image img{border-radius:8px;width:100%;transition:transform .5s ease;display:block; height: auto;}
  .lucira-blog-section .blog-card .blog-card-avatar{transition:transform .3s ease-in-out}
  .lucira-blog-section .blog-nav a:hover{color:#a68380}
  .lucira-blog-section a:hover .card-image{transform:scale(1.05)}
  .lucira-blog-section .blog-card:hover .blog-card-title{color:#a68380}
  .lucira-blog-section .blog-card:hover .blog-card-avatar-container{background-color:rgba(166,131,128,.1)}
  .lucira-blog-section .blog-card:hover{transform:translateY(-5px)}
  .lucira-blog-section .blog-card:hover .blog-title{color:#a68380}
  .lucira-blog-section .a-anchor:hover .blog-card-avatar,.lucira-blog-section .blog-card:hover .blog-card-avatar{transform:rotate(-45deg)}
  .blog-tag{margin-top:10px;margin-bottom:5px;text-transform:uppercase;color:#666;text-align:left;letter-spacing:.04em;font-size:12px;font-weight:500}
  .blog-title{font-size:18px;font-weight:500;color:#000;text-transform:uppercase;margin-right:20px;margin-top:0}
  .arrow-link{font-size:18px;color:#000;font-weight:700;text-decoration:none;display:inline-block;transition:transform .3s}
  .load-more-wrap{margin-top:0}
  .load-more-btn{color:#fff;background:#a68380;text-decoration:none;padding:16px 60px;display:inline-block;max-width:max-content;width:100%;text-align:center;border-radius:12px;font-weight:500;font-size:14px;line-height:1.2;text-transform:uppercase}
  img.blog-card-avatar{width:30px}
  @media screen and (max-width:768px){
  .blog-grid{max-width:100%}
  .lucira-blog-section{padding:20px 0 40px 0}
  .blog-grid{grid-template-columns:repeat(2,1fr);margin-bottom:0}
  .blog-card{width:100%}
  .blog-image img{width:100%;height:100%}
  .blog-title{font-size:12px;margin-right:8px}
  .des-arrow-div a.arrow-link img{width:17px}
  .load-more-btn{font-size:9px}
  .blog-header h2{font-size:18px;margin-bottom:0}
  .blog-header p{font-size:12px;margin-top:6px;margin-bottom:20px}
  .blog-tag{font-size:8px}
  img.blog-card-avatar{width:25px}
  }
  @media only screen and (min-width:1024px) and (max-width:1500px){
  .blog-grid{max-width:100%}
  }
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {

  // ===== Blog Card Click Tracking =====
  document.querySelectorAll(".blog-card a").forEach((link, index) => {
    link.addEventListener("click", function() {
      const blogTitle = this.closest(".blog-card")?.querySelector(".blog-title")?.innerText || "Blog Article";
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: "promoClick",
        promoClick: {
          promo_id: "Blog Card " + (index + 1),
          promo_name: blogTitle,
          creative_name: "Featured Blogs Section",
          location_id: this.getAttribute("href") || "N/A"
        }
      });
    });
  });



}); 
</script>
