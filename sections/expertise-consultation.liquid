{% stylesheet %}
  .expert-section {
    width: 100%;
    padding: 80px 0;
    position: relative;
  }

  .expert-container {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .expert-content-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  /* Background Strip */
  .expert-background-strip {
    position: absolute;
    left: 0;
    right: 0;
    height: 60%;
    background-color: #f8f8f8; /* Light gray background */
    z-index: 1;
    bottom: 20%;
  }

  /* Left Column - Image */
  .expert-image-container {
    position: relative;
    z-index: 3;
    padding-right: 40px;
  }

  .expert-image {
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .expert-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Right Column - Text Content */
  .expert-text-container {
    position: relative;
    z-index: 3;
    padding-left: 40px;
  }

  .expert-heading {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 2px;
    margin: 0 0 20px 0;
    text-transform: uppercase;
    color: #000;
  }

  .expert-content {
    font-size: 16px;
    line-height: 1.8;
    color: #333;
    margin: 0;
    font-weight: 300;
  }

  /* Responsive Design */
  @media (max-width: 1200px) {
    .expert-container {
      max-width: 100%;
      padding: 0 40px;
    }
    
    .expert-content-wrapper {
      gap: 40px;
    }
    
    .expert-image-container {
      padding-right: 20px;
    }
    
    .expert-text-container {
      padding-left: 20px;
    }
  }

  @media (max-width: 992px) {
    .expert-section {
      padding: 60px 0;
    }
    
    .expert-content-wrapper {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    
    .expert-background-strip {
      height: 70%;
      bottom: 15%;
    }
    
    .expert-image-container {
      padding-right: 0;
    }
    
    .expert-text-container {
      padding-left: 0;
    }
    
    .expert-image {
      max-width: 500px;
      margin: 0 auto;
    }
  }

  @media (max-width: 768px) {
    .expert-section {
      padding: 40px 0;
    }
    
    .expert-container {
      padding: 0 20px;
    }
    
    .expert-background-strip {
      height: 75%;
      bottom: 12.5%;
    }
    
    .expert-heading {
      font-size: 13px;
      letter-spacing: 1.5px;
      margin-bottom: 15px;
    }
    
    .expert-content {
      font-size: 15px;
      line-height: 1.6;
    }
  }

  @media (max-width: 576px) {
    .expert-background-strip {
      height: 80%;
      bottom: 10%;
    }
    
    .expert-image {
      aspect-ratio: 4/5;
    }
  }
{% endstylesheet %}

<div class="expert-section">
  <!-- Background Strip -->
  <div class="expert-background-strip"></div>
  
  <div class="expert-container">
    <div class="expert-content-wrapper">
      <!-- Left Column - Image -->
      <div class="expert-image-container">
        <div class="expert-image">
          {% if section.settings.expert_image != blank %}
            <img 
              src="{{ section.settings.expert_image | img_url: '800x1066', scale: 2 }}" 
              alt="{{ section.settings.expert_image.alt | escape }}"
              loading="lazy"
              width="800"
              height="1066"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      </div>
      
      <!-- Right Column - Text Content -->
      <div class="expert-text-container">
        <h2 class="expert-heading">{{ section.settings.expert_heading | default: "EXPERT CONSULTATION" }}</h2>
        <p class="expert-content">{{ section.settings.expert_content | default: "Our jewelry experts guide you through every detail, cut, carat, clarity and setting, ensuring confident decisions backed by transparency, education and genuine expertise." }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Expert Consultation",
  "settings": [
    {
      "type": "image_picker",
      "id": "expert_image",
      "label": "Expert Consultation Image (Portrait - 3:4 Ratio)"
    },
    {
      "type": "text",
      "id": "expert_heading",
      "label": "Heading",
      "default": "EXPERT CONSULTATION"
    },
    {
      "type": "textarea",
      "id": "expert_content",
      "label": "Content",
      "default": "Our jewelry experts guide you through every detail, cut, carat, clarity and setting, ensuring confident decisions backed by transparency, education and genuine expertise."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Strip Color",
      "default": "#f8f8f8"
    }
  ],
  "presets": [
    {
      "name": "Expert Consultation Section",
      "category": "Image with Text"
    }
  ]
}
{% endschema %}