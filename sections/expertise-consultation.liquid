<section class="expert-consultation">
  <div class="expert-container">

    <!-- Image -->
    <div class="expert-image">
      {% if section.settings.main_image != blank %}
        <img
          src="{{ section.settings.main_image | image_url: width: 1000 }}"
          alt="{{ section.settings.heading | escape }}"
          loading="lazy"
        >
      {% endif %}
    </div>

    <!-- Grey Content Strip -->
    <div class="expert-content">
      <h2 class="expert-title">{{ section.settings.heading }}</h2>
      <p class="expert-description">{{ section.settings.description }}</p>
    </div>

  </div>
</section>



{% style %}
.expert-consultation{padding:5px 0 50px 0;background:#fff}
.expert-container{margin:0 auto;position:relative}
.expert-image{position:absolute;left:0;top:-206px;z-index:2;width:870px}
.expert-image img{width:100%;height:auto;display:block}
.expert-content{background:#e6e6e6;padding:10px 20px 0 830px;min-height:250px}
.expert-title{font-size:24px;font-weight:500;margin-bottom:20px;color:#1a1a1a}
.expert-description{font-size:14px;line-height:1.6;color:#333;max-width:400px}
@media (max-width:768px){
.expert-image{position:static;width:100%;margin-bottom:0}
.expert-content{margin-left:0;padding:40px 24px}
.expert-consultation{padding:0;background:#fff}
.expert-title{font-size:18px}
}
{% endstyle %}


{% schema %}
{
  "name": "Expert Consultation",
  "settings": [
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Expert Consultation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "EXPERT CONSULTATION"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Our jewellery experts guide you through every detail, cut, carat, clarity and setting, ensuring confident decisions backed by transparency, education and genuine expertise."
    }
  ],
  "presets": [
    {
      "name": "Expert Consultation"
    }
  ]
}
{% endschema %}
