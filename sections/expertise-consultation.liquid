{% stylesheet %}
  .expert-section {
    width: 100%;
    padding: 100px 0;
    position: relative;
  }

  .expert-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
  }

  .expert-content-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  /* The Background Strip behind both columns */
  .expert-content-wrapper::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 100vw;
    height: 300px;
    background-color: {{ section.settings.background_color | default: '#f5f5f5' }};
    z-index: 0;
  }

  /* Left Column - Image with background strip */
  .expert-image-container {
    position: relative;
    z-index: 1;
  }

  /* Create a pseudo-element for image background extension */
  .expert-image-container::before {
    content: '';
    position: absolute;
    left: -40px;
    top: -40px;
    right: -40px;
    bottom: -40px;
    background-color: white;
    z-index: -1;
  }

  .expert-image {
    width: 100%;
    height: 500px;
    overflow: hidden;
    position: relative;
    background-color: #f0f0f0;
  }

  .expert-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Right Column - Text Content with background */
  .expert-text-container {
    position: relative;
    z-index: 1;
  }

  /* Create a pseudo-element for text background */
  .expert-text-container::before {
    content: '';
    position: absolute;
    left: -40px;
    top: -40px;
    right: -40px;
    bottom: -40px;
    background-color: white;
    z-index: -1;
  }

  .expert-heading {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 2px;
    margin: 0 0 25px 0;
    text-transform: uppercase;
    color: #000;
  }

  .expert-content {
    font-size: 16px;
    line-height: 1.8;
    color: #333;
    margin: 0;
    font-weight: 300;
  }

  /* Responsive Design */
  @media (max-width: 1200px) {
    .expert-content-wrapper {
      gap: 60px;
    }
    
    .expert-image {
      height: 450px;
    }
  }

  @media (max-width: 992px) {
    .expert-section {
      padding: 80px 0;
    }
    
    .expert-content-wrapper {
      grid-template-columns: 1fr;
      gap: 50px;
    }
    
    .expert-content-wrapper::before {
      height: 400px;
      width: 100vw;
    }
    
    .expert-image {
      height: 400px;
      max-width: 500px;
      margin: 0 auto;
    }
    
    /* Adjust pseudo-elements for mobile */
    .expert-image-container::before,
    .expert-text-container::before {
      left: -20px;
      right: -20px;
      top: -20px;
      bottom: -20px;
    }
  }

  @media (max-width: 768px) {
    .expert-section {
      padding: 60px 0;
    }
    
    .expert-container {
      padding: 0 20px;
    }
    
    .expert-content-wrapper::before {
      height: 350px;
    }
    
    .expert-image {
      height: 350px;
    }
    
    .expert-heading {
      font-size: 13px;
      letter-spacing: 1.5px;
      margin-bottom: 20px;
    }
    
    .expert-content {
      font-size: 15px;
      line-height: 1.6;
    }
    
    .expert-image-container::before,
    .expert-text-container::before {
      left: -15px;
      right: -15px;
      top: -15px;
      bottom: -15px;
    }
  }

  @media (max-width: 576px) {
    .expert-image {
      height: 300px;
    }
    
    .expert-content-wrapper::before {
      height: 300px;
    }
  }
{% endstylesheet %}

<div class="expert-section">
  <div class="expert-container">
    <div class="expert-content-wrapper">
      <!-- Left Column - Image -->
      <div class="expert-image-container">
        <div class="expert-image">
          {% if section.settings.expert_image != blank %}
            <img 
              src="{{ section.settings.expert_image | img_url: '800x500', scale: 2, crop: 'center' }}" 
              alt="{{ section.settings.expert_image.alt | escape }}"
              loading="lazy"
              width="800"
              height="500"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      </div>
      
      <!-- Right Column - Text Content -->
      <div class="expert-text-container">
        <h2 class="expert-heading">{{ section.settings.expert_heading | default: "EXPERT CONSULTATION" }}</h2>
        <p class="expert-content">{{ section.settings.expert_content | default: "Our jewelry experts guide you through every detail, cut, carat, clarity and setting, ensuring confident decisions backed by transparency, education and genuine expertise." }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Expert Consultation",
  "settings": [
    {
      "type": "image_picker",
      "id": "expert_image",
      "label": "Expert Consultation Image"
    },
    {
      "type": "text",
      "id": "expert_heading",
      "label": "Heading",
      "default": "EXPERT CONSULTATION"
    },
    {
      "type": "textarea",
      "id": "expert_content",
      "label": "Content",
      "default": "Our jewelry experts guide you through every detail, cut, carat, clarity and setting, ensuring confident decisions backed by transparency, education and genuine expertise."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Strip Background Color",
      "default": "#f5f5f5"
    }
  ],
  "presets": [
    {
      "name": "Expert Consultation with Background Strip",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}