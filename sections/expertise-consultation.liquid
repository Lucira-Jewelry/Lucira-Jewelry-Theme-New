{% stylesheet %}
  .expert-consultation-section {
    width: 100%;
    padding: 0;
    background-color: #ffffff;
  }

  .expert-consultation-container {
    max-width: 100%;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    min-height: 500px;
  }

  /* LEFT COLUMN - LARGE IMAGE */
  .consultation-image-left {
    width: 100%;
    height: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .consultation-image-left img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* RIGHT COLUMN - CONTENT + SMALL IMAGE */
  .consultation-right {
    display: flex;
    flex-direction: column;
    padding: 60px 50px;
    background-color: #ffffff;
    height: 100%;
    justify-content: center;
    gap: 30px;
  }

  /* Small Image Top Right - with Blue Border */
  .small-image-top {
    width: 220px;
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: 8px;
    border: 4px solid #0066ff;
    align-self: flex-end;
    margin-bottom: 20px;
  }

  .small-image-top img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Content Block */
  .consultation-content {
    flex: 1;
  }

  .consultation-content h2 {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 2px;
    margin: 0 0 20px 0;
    text-transform: uppercase;
    color: #000;
  }

  .consultation-content p {
    font-size: 14px;
    line-height: 1.7;
    color: #555;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .expert-consultation-container {
      grid-template-columns: 1fr;
    }

    .consultation-image-left {
      aspect-ratio: 4/3;
    }

    .consultation-right {
      padding: 50px 40px;
    }

    .small-image-top {
      align-self: flex-start;
      margin-bottom: 30px;
    }
  }

  @media (max-width: 768px) {
    .expert-consultation-section {
      padding: 0;
    }

    .consultation-right {
      padding: 40px 30px;
    }

    .consultation-content h2 {
      font-size: 18px;
      letter-spacing: 1.5px;
    }

    .consultation-content p {
      font-size: 13px;
    }

    .small-image-top {
      width: 180px;
    }
  }
{% endstylesheet %}

<div class="expert-consultation-section">
  <div class="expert-consultation-container">
    <!-- LEFT COLUMN - MAIN IMAGE -->
    <div class="consultation-image-left">
      {% if section.settings.main_image != blank %}
        <img 
          src="{{ section.settings.main_image | img_url: '800x600' }}" 
          alt="Expert Consultation"
          loading="lazy"
        >
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>

    <!-- RIGHT COLUMN - CONTENT + SMALL IMAGE -->
    <div class="consultation-right">
      <!-- Small Image Top Right with Blue Border -->
      <div class="small-image-top">
        {% if section.settings.detail_image != blank %}
          <img 
            src="{{ section.settings.detail_image | img_url: '220x165' }}" 
            alt="Consultation Detail"
            loading="lazy"
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      <!-- Content Block -->
      <div class="consultation-content">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.description }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Expert Consultation",
  "settings": [
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image (Left - 16:9 Aspect Ratio)"
    },
    {
      "type": "image_picker",
      "id": "detail_image",
      "label": "Detail Image (Top Right - 4:3 Aspect Ratio with Blue Border)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "EXPERT CONSULTATION"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Our jewelry experts guide you through every detail, cut, carat, clarity and setting, ensuring confident decisions backed by transparency, education and genuine expertise."
    }
  ],
  "presets": [
    {
      "name": "Expert Consultation Section"
    }
  ]
}
{% endschema %}