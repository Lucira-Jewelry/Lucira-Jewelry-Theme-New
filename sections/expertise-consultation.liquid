<section class="expert-consultation">
  <div class="expert-container">

    <!-- Image -->
    <div class="expert-image">
      {% if section.settings.main_image != blank %}
        <img
          src="{{ section.settings.main_image | image_url: width: 1000 }}"
          alt="{{ section.settings.heading | escape }}"
          loading="lazy"
        >
      {% endif %}
    </div>

    <!-- Grey Content Strip -->
    <div class="expert-content">
      <h2 class="expert-title">{{ section.settings.heading }}</h2>
      <p class="expert-description">{{ section.settings.description }}</p>
    </div>

  </div>
</section>



{% style %}
.expert-consultation {
  padding: 120px 20px;
  background: #fff;
}

.expert-container {
  margin: 0 auto;
  position: relative;
}

/* IMAGE */
.expert-image {
  position: absolute;
  left: 0;
  top: -60px;
  z-index: 2;
  width: 520px;
}

.expert-image img {
  width: 100%;
  height: auto;
  display: block;
}

/* GREY STRIP */
.expert-content {
  background: #f3f3f3;
  margin-left: 420px; /* pushes content to the right of image */
  padding: 10px 20px 0px 310px;
  min-height: 250px;
}

/* TEXT */
.expert-title {
  font-size: 32px;
  font-weight: 600;
  margin-bottom: 20px;
  color: #111;
}

.expert-description {
  font-size: 16px;
  line-height: 1.7;
  color: #333;
  max-width: 520px;
}

/* RESPONSIVE */
@media (max-width: 900px) {
  .expert-image {
    position: static;
    width: 100%;
    margin-bottom: 40px;
  }

  .expert-content {
    margin-left: 0;
    padding: 40px 24px;
  }
}

{% endstyle %}


{% schema %}
{
  "name": "Expert Consultation",
  "settings": [
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Expert Consultation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "EXPERT CONSULTATION"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Our jewellery experts guide you through every detail, cut, carat, clarity and setting, ensuring confident decisions backed by transparency, education and genuine expertise."
    }
  ],
  "presets": [
    {
      "name": "Expert Consultation"
    }
  ]
}
{% endschema %}
