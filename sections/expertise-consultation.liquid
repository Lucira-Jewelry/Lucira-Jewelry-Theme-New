<section class="expert-consultation">
  <div class="expert-container">

    <!-- Image Wrapper (overlapping) -->
    <div class="expert-image">
      {% if section.settings.main_image != blank %}
        <img
          src="{{ section.settings.main_image | image_url: width: 900 }}"
          alt="{{ section.settings.heading | escape }}"
          loading="lazy"
        >
      {% endif %}
    </div>

    <!-- Content Strip -->
    <div class="expert-content">
      <h3 class="expert-subtitle">
        {{ section.settings.subtitle }}
      </h3>

      <h2 class="expert-title">
        {{ section.settings.heading }}
      </h2>

      <p class="expert-description">
        {{ section.settings.description }}
      </p>
    </div>

  </div>
</section>


{% style %}
.expert-consultation {
  padding: 80px 20px;
  background: #ffffff;
}

.expert-container {
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
}

/* Image overlaps the content strip */
.expert-image {
  position: relative;
  z-index: 2;
  margin-bottom: -205px; /* THIS creates the overlap */
}

.expert-image img {
  width: 100%;
  max-width: 600px;
  display: block;
}

/* Content strip */
.expert-content {
  background: #f5f5f5;
  padding: 160px 60px 60px;
  margin-left: auto;
  max-width: 100%;
}

.expert-subtitle {
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 12px;
  color: #555;
}

.expert-title {
  font-size: 28px;
  font-weight: 600;
  margin-bottom: 16px;
  color: #111;
}

.expert-description {
  font-size: 16px;
  line-height: 1.6;
  color: #333;
}

/* Responsive */
@media (max-width: 768px) {
  .expert-image {
    margin-bottom: -60px;
  }

  .expert-content {
    padding: 100px 24px 40px;
    max-width: 100%;
  }
}
{% endstyle %}


{% schema %}
{
  "name": "Expert Consultation",
  "settings": [
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Expert Consultation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "EXPERT CONSULTATION"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Our jewellery experts guide you through every detail, cut, carat, clarity and setting, ensuring confident decisions backed by transparency, education and genuine expertise."
    }
  ],
  "presets": [
    {
      "name": "Expert Consultation"
    }
  ]
}
{% endschema %}
