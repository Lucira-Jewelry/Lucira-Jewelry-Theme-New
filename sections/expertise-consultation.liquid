{% stylesheet %}
  .expert-section {
    width: 100%;
    padding: 100px 0;
    position: relative;
    overflow: hidden;
  }

  .expert-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
  }

  .expert-content-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
    position: relative;
  }

  /* The Background Strip/Band */
  .background-strip {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%; /* Start from the middle of the container */
    transform: translateY(-50%);
    height: 300px; /* Height of the strip */
    background-color: #f5f5f5; /* Light background color */
    z-index: 1;
  }

  /* Left Column - Image */
  .expert-image-container {
    position: relative;
    z-index: 2;
    margin-top: 40px; /* Push image down so strip goes below it */
  }

  .expert-image {
    width: 100%;
    height: 500px;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .expert-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Right Column - Text Content */
  .expert-text-container {
    position: relative;
    z-index: 2;
    padding-top: 40px; /* Push text down so strip goes below it */
  }

  .expert-heading {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 2px;
    margin: 0 0 25px 0;
    text-transform: uppercase;
    color: #000;
  }

  .expert-content {
    font-size: 16px;
    line-height: 1.8;
    color: #333;
    margin: 0;
    font-weight: 300;
  }

  /* Responsive Design */
  @media (max-width: 1200px) {
    .expert-content-wrapper {
      gap: 60px;
    }
    
    .expert-image {
      height: 450px;
    }
  }

  @media (max-width: 992px) {
    .expert-section {
      padding: 80px 0;
    }
    
    .expert-content-wrapper {
      grid-template-columns: 1fr;
      gap: 50px;
    }
    
    .background-strip {
      height: 400px; /* Taller on mobile to cover both stacked elements */
      top: 40%;
    }
    
    .expert-image-container {
      margin-top: 0;
    }
    
    .expert-text-container {
      padding-top: 0;
    }
    
    .expert-image {
      height: 400px;
      max-width: 500px;
      margin: 0 auto;
    }
  }

  @media (max-width: 768px) {
    .expert-section {
      padding: 60px 0;
    }
    
    .expert-container {
      padding: 0 20px;
    }
    
    .background-strip {
      height: 350px;
    }
    
    .expert-image {
      height: 350px;
    }
    
    .expert-heading {
      font-size: 13px;
      letter-spacing: 1.5px;
      margin-bottom: 20px;
    }
    
    .expert-content {
      font-size: 15px;
      line-height: 1.6;
    }
  }

  @media (max-width: 576px) {
    .expert-image {
      height: 300px;
    }
    
    .background-strip {
      height: 300px;
    }
  }
{% endstylesheet %}

<div class="expert-section">
  <!-- Background Strip that goes below image and text -->
  <div class="background-strip" style="background-color: {{ section.settings.background_color | default: '#f5f5f5' }};"></div>
  
  <div class="expert-container">
    <div class="expert-content-wrapper">
      <!-- Left Column - Image -->
      <div class="expert-image-container">
        <div class="expert-image">
          {% if section.settings.expert_image != blank %}
            <img 
              src="{{ section.settings.expert_image | img_url: '800x500', scale: 2, crop: 'center' }}" 
              alt="{{ section.settings.expert_image.alt | escape }}"
              loading="lazy"
              width="800"
              height="500"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      </div>
      
      <!-- Right Column - Text Content -->
      <div class="expert-text-container">
        <h2 class="expert-heading">{{ section.settings.expert_heading | default: "EXPERT CONSULTATION" }}</h2>
        <p class="expert-content">{{ section.settings.expert_content | default: "Our jewelry experts guide you through every detail, cut, carat, clarity and setting, ensuring confident decisions backed by transparency, education and genuine expertise." }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Expert Consultation",
  "settings": [
    {
      "type": "image_picker",
      "id": "expert_image",
      "label": "Expert Consultation Image"
    },
    {
      "type": "text",
      "id": "expert_heading",
      "label": "Heading",
      "default": "EXPERT CONSULTATION"
    },
    {
      "type": "textarea",
      "id": "expert_content",
      "label": "Content",
      "default": "Our jewelry experts guide you through every detail, cut, carat, clarity and setting, ensuring confident decisions backed by transparency, education and genuine expertise."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Strip Background Color",
      "default": "#f5f5f5"
    }
  ],
  "presets": [
    {
      "name": "Expert Consultation with Background Strip",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}