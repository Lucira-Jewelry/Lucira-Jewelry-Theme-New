<style>

.dp-column-heading-image {
  width: 100%;
  height: auto;
}
/* Container */
.diamond-process-section { width:100%; position:relative; }
.dp-main-heading { text-align:center; margin:0 0 12px 0; font-size:28px; font-weight:600; }
.dp-sub-heading { text-align:center; font-size:18px; margin:0 auto; max-width:700px; line-height:22px; color:#555; }
.dp-blocks-wrapper { width:70%; margin:0 auto; }

/* Image Set Block – sticky + bottom-to-top */
.dp-image-set {
  position: sticky;
  top: 120px;
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 75px;
  opacity: 0;
  transform: translateY(80px);
  transition: transform 0.6s ease-out, opacity 0.6s ease-out;
  z-index: 0;
  background: #fff;
}
.dp-image-set.active {
  opacity: 1;
  transform: translateY(0);
  z-index: 1;
  background: transparent;
}

/* Final Diamond Block */
.dp-final-block {
  position: relative;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  background: #fff;
  opacity: 1;
  transform: none;
  transition: none;
  z-index: 1;
  margin: 0 20px auto;
}

/* Columns */
.dp-column { display:flex; flex-direction:column; align-items:center; text-align:center; transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
.dp-column-heading {min-height: 25px; font-size:14px; font-weight:600; margin:0 0 12px 0; color:#666; text-transform:uppercase; letter-spacing:1px; }

/* Description styling */
.dp-description {min-height: 268px; max-height: unset; background: #fff; text-align:left; width: 100%; }
.dp-description h2 { font-size:22px; margin: unset; color: #333; margin-top: 30px; }
.dp-description p { margin: unset; margin-top:12px; color:#444; line-height:22px; }

/* Center image and dot/icon */
.dp-center-image-container { position: relative; width:110px; height:200px; }
.dp-center-image { object-fit:cover; height:400px; }

.dp-dot, .dp-icon {
  position: absolute;
  top: 28%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0);
  opacity: 0;
  transition: transform 0.6s ease-out, opacity 0.6s ease-out;
  will-change: transform, opacity, top, left;
  transform-origin: center center;
}

.dp-image-set.active .dp-dot,
.dp-image-set.active .dp-icon {
  transform: translate(-50%, -50%) scale(1);
  opacity: 1;
}

{% comment %} .dp-final-diamond-img { width:100%; height:auto; transform: scale(1); opacity: 1; } {% endcomment %}
.dp-final-column { text-align:left; }
.dp-final-diamond { position:relative; width:400px; height:400px; display:flex; align-items:center; justify-content:center; }

.diamond-dp-column-heading-image{
  width: unset;
  height: unset;
}

.hide-image-container {
  display: none;
}

/* CUSTOM DOTS FOR PROCESS STEPS */
.dp-points-list ul {
  list-style: none;
  padding-left: 0;
  margin-top: 12px;
}

.dp-points-list li {
  position: relative;
  max-width: 280px; 
  padding-left: 15px;
  margin-bottom: 15px;
  line-height: 1.4;
  text-align: left;
  font-size: 0.95rem;
  color: #444;
}

.dp-points-list li p {
    margin: 0;
    line-height: inherit;
}

.dp-points-list li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 6px;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background-color: var(--dot-color);
}

.dp-points-left { --dot-color: attr(data-dot-color); }
.dp-points-right { --dot-color: attr(data-dot-color); }

/* FINAL SECTION */
.dp-final-points ul {
  list-style: none; 
  padding-left: 0; 
  margin: 0;
}

.dp-final-points li {
  position: relative;
  max-width: 280px; 
  padding-left: 20px;
  margin-bottom: 15px;
  line-height:22px;
  font-size: 12px;
}

.dp-final-left h3{
 text-align: left;
    font-size: 28px;
    margin: 0 0 60px 0;
}
.dp-final-right h3{
 text-align: right;
    font-size: 28px;
    margin: 0 0 60px 0;
}

.dp-final-left .dp-final-points li {
  text-align: left;
}
.dp-final-left .dp-final-points li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 8px;
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background-color: #4CAF50;
}

.dp-final-right .dp-final-points li {
  text-align: right;
  padding-right: 20px;
  padding-left: 0;
}
.dp-final-right .dp-final-points li::before {
  content: '';
  position: absolute;
  right: 0;
  top: 8px;
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background-color: #F44336;
}

.dp-final-points li::before {
  list-type: none;
}

.dp-final-left .dp-final-points li,
.dp-final-right .dp-final-points li {
  margin-bottom: 15px;
}

ul.dp-final-points {
  list-style-type: none;
  margin: 0;
  padding: 0;
}

.dp-final-left .dp-final-points li:nth-child(1) { max-width: 70%; }
.dp-final-left .dp-final-points li:nth-child(2) { max-width: 80%; }
.dp-final-left .dp-final-points li:nth-child(3) { max-width: 90%; }
.dp-final-left .dp-final-points li:nth-child(4) { max-width: 100%; }

.dp-final-right .dp-final-points li:nth-child(1) { max-width: 70%; margin-left:auto; }
.dp-final-right .dp-final-points li:nth-child(2) { max-width: 80%; margin-left:auto; }
.dp-final-right .dp-final-points li:nth-child(3) { max-width: 90%; margin-left:auto; }
.dp-final-right .dp-final-points li:nth-child(4) { max-width: 100%; margin-left:auto; }

/* RESPONSIVE */
@media screen and (max-width: 768px) {
  .dp-image-set {
    gap: 10px;
  }
  .dp-center-image-container {
    position: absolute;
    width: 22%;
    height: 20%;
  }
  .dp-final-block {
    flex-direction: column;
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }
  .dp-final-column,
  .dp-final-diamond {
    order: 0;
  }
  img.dp-column-heading-image-container {
    width: 100%;
  }
  .dp-column-heading {
    min-height: 50px;
  }
  .dp-dot {
    top: 15%;
    width: 12px !important;
    height: 12px !important;
  }
  .dp-blocks-wrapper {
    width: 90%;  
  }
  .dp-center-image-container {
    width: 40px;
    bottom: 48%;
  }
  .dp-final-column:first-child {
    order: 2;
  }
  .dp-final-diamond {
    order: 1;
    width: 70%;
    height: auto;
  }
  .dp-final-column:last-child {
    order: 3;
  }
  .dp-points-list li,
  .dp-final-points li {
    max-width: 100%; 
  }
}

body { margin:0; padding:0; }

