<script>
  (function () {
    // Run only for desktop


    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
    const lerp = (a, b, t) => a + (b - a) * t;

    document.addEventListener("DOMContentLoaded", () => {
      const startElems = Array.from(
        document.querySelectorAll(".diamond-dp-column-heading-image")
      );
      const finalContainer = document.querySelector(".dp-final-diamond");
      const originalFinalImg = document.querySelector(".dp-final-diamond-img");

      if (!startElems.length || !finalContainer || !originalFinalImg) return;

      let startElem = null;
      let floating = null;
      let pos = {};
      let rafId = null;
      let natW = 0,
        natH = 0;

      let smoothX = 0,
        smoothY = 0,
        smoothW = 0,
        smoothH = 0;

      function createFloating() {
        if (floating) floating.remove();

        floating = originalFinalImg.cloneNode(true);
        floating.classList.add("dp-floating-diamond");
        floating.style.position = "fixed";
        floating.style.pointerEvents = "none";
        floating.style.zIndex = "2";
        floating.style.opacity = "0";
        document.body.appendChild(floating);

        originalFinalImg.style.visibility = "hidden";

        natW = floating.naturalWidth || 1;
        natH = floating.naturalHeight || 1;
      }

      function findVisibleStart() {
        for (const el of startElems) {
          const opacity = +window.getComputedStyle(el).opacity;
          const rect = el.getBoundingClientRect();
          if (opacity >= 1 && rect.top < window.innerHeight && rect.bottom > 0) {
            return el;
          }
        }
        return null;
      }

      function recalc() {
        if (!startElem) return;
        const s = startElem.getBoundingClientRect();
        const e = finalContainer.getBoundingClientRect();
        const scrollX = window.pageXOffset || document.documentElement.scrollLeft;
        const scrollY = window.pageYOffset || document.documentElement.scrollTop;

        pos = {
          startDocCenterX: s.left + s.width / 2 + scrollX,
          startDocCenterY: s.top + s.height / 2 + scrollY,
          startW: s.width,
          endDocCenterX: e.left + e.width / 2 + scrollX,
          endDocCenterY: e.top + e.height / 2 + scrollY,
          endW: e.width,
          ratio: natH / natW || s.height / s.width || 1,
        };

        smoothX = pos.startDocCenterX;
        smoothY = pos.startDocCenterY;
        smoothW = pos.startW;
        smoothH = smoothW * pos.ratio;
      }

      function render() {
        rafId = null;
        if (!floating || !startElem) return;

        const scrollY = window.pageYOffset || document.documentElement.scrollTop;
        const scrollX = window.pageXOffset || document.documentElement.scrollLeft;

        const startTrigger = pos.startDocCenterY - window.innerHeight * 0.6;
        const endTrigger = pos.endDocCenterY - window.innerHeight * 0.4;
        const denom = endTrigger - startTrigger || 1;

        let progress = (scrollY - startTrigger) / denom;
        progress = clamp(progress, 0, 1);

        const ease = progress * progress * (3 - 2 * progress);

        const targetW = lerp(pos.startW, pos.endW, ease);
        const targetH = targetW * pos.ratio;
        const targetX = lerp(pos.startDocCenterX, pos.endDocCenterX, ease);
        const targetY = lerp(pos.startDocCenterY, pos.endDocCenterY, ease);

        smoothW = lerp(smoothW, targetW, 0.2);
        smoothH = lerp(smoothH, targetH, 0.2);
        smoothX = lerp(smoothX, targetX, 0.2);
        smoothY = lerp(smoothY, targetY, 0.2);

        const viewportLeft = smoothX - scrollX - smoothW / 2;
        const viewportTop = smoothY - scrollY - smoothH / 2;

        floating.style.width = smoothW + "px";
        floating.style.height = smoothH + "px";
        floating.style.left = viewportLeft + "px";
        floating.style.top = viewportTop + "px";
        floating.style.opacity = progress > 0 && progress < 1 ? "1" : "0";

          {% comment %} console.log('795', progress, floating); {% endcomment %}
          if (progress == 0) {
            document.querySelector('.diamond-dp-column-heading-image').style.visibility = 'unset'
          }else{
            document.querySelector('.diamond-dp-column-heading-image').style.visibility = 'hidden'
          }

        if (progress >= 1 && floating) {
          originalFinalImg.style.visibility = "visible";
          floating.remove();
          floating = null;
        } else {
          originalFinalImg.style.visibility = "hidden";
        }
      }

      function onScrollThrottled() {
        if (!rafId) rafId = requestAnimationFrame(render);
      }

      function onResize() {
        recalc();
        render();
      }

      function initAnimation(forceStartElem = null) {
        const newStart = forceStartElem || findVisibleStart();
        if (!newStart) return;

        if (startElem !== newStart || !floating) {
          startElem = newStart;
          createFloating();
          recalc();
          render();

          window.addEventListener("scroll", onScrollThrottled, { passive: true });
          window.addEventListener("resize", onResize);
        }
      }

      // ✅ Updated observer — triggers smoothly in both scroll directions
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const opacity = +window.getComputedStyle(entry.target).opacity;
            const isFinalImg = entry.target.classList.contains("dp-final-diamond-img");
            const isStartImg = entry.target.classList.contains("diamond-dp-column-heading-image");

            // When start image is visible or final image re-enters viewport
            if ((isStartImg && opacity >= 1 && entry.isIntersecting) || (isFinalImg && entry.isIntersecting)) {
              // For final image, use the last visible start image for reference
              if (isFinalImg) {
                const lastStart = findVisibleStart() || startElems[startElems.length - 1];
                initAnimation(lastStart);
              } else {
                initAnimation(entry.target);
              }
            }
          });
        },
        { threshold: [0, 0.25, 0.5, 0.75, 1] }
      );

      // Observe both start and final images
      startElems.forEach((el) => observer.observe(el));
      observer.observe(originalFinalImg);

      initAnimation();
    });
  })();
</script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Select all containers
    const items = document.querySelectorAll('.dp-center-image-container');
    if (!items.length) return;

    // Get the last one
    const lastItem = items[items.length - 1];

    // Inject override CSS (only once)
    const styleId = 'dp-last-before-override';
    if (!document.getElementById(styleId)) {
      const style = document.createElement('style');
      style.id = styleId;
      style.textContent = `
        .dp-center-image-container.last-item::before {
          background-color: #fff !important;
          width: 6px;
        }
      `;
      document.head.appendChild(style);
    }

    // Add class to the last element
    lastItem.classList.add('last-item');
  });
</script>

