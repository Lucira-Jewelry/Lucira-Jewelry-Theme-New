<!-- 1. HTML -->
<div class="byoj-step2">
  <div class="page-width">
    <h2 class="byoj-heading">{{ section.settings.heading }}</h2>
    <div id="chain-list" class="byoj-chain-grid"></div>
  </div>
</div>

<!-- 2. Shopify Data Injection -->
<script>
  window.byojChains = [

  {% for block in section.blocks %}
    {% if block.type == 'collection' %}
      {% assign col = collections[block.settings.collection] %}
      {% if col != blank %}
        {% for product in col.products %}
        {
          id: "{{ product.id }}",
          title: {{ product.title | json }},
          type: "{{ block.settings.type }}",

          variants: [
            {% for variant in product.variants %}
            {
              id: "{{ variant.id }}",
              image: "{{ variant.featured_image | default: product.featured_image | image_url: width: 600 }}",
              price: "{{ variant.price | money_without_currency | replace: ',', '' }}",
              compare: "{{ variant.compare_at_price | money_without_currency | replace: ',', '' }}",
              options: {{ variant.options | json }}
            },
            {% endfor %}
          ]
        },
        {% endfor %}
      {% endif %}
    {% endif %}
  {% endfor %}

  {% for block in section.blocks %}
    {% if block.type == 'manual' and block.settings.product != blank %}
      {% assign product = block.settings.product %}
      {
        id: "{{ product.id }}",
        title: {{ product.title | json }},
        type: "{{ block.settings.type }}",

        variants: [
          {% for variant in product.variants %}
          {
            id: "{{ variant.id }}",
            image: "{{ variant.featured_image | default: product.featured_image | image_url: width: 600 }}",
            price: "{{ variant.price | money_without_currency | replace: ',', '' }}",
            compare: "{{ variant.compare_at_price | money_without_currency | replace: ',', '' }}",
            options: {{ variant.options | json }}
          },
          {% endfor %}
        ]
      },
    {% endif %}
  {% endfor %}

  ];
</script>

<!-- 3. Logic -->
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const type = new URLSearchParams(window.location.search).get('type') || localStorage.getItem('byoj_type');

    const allChains = window.byojChains || [];
    const container = document.getElementById('chain-list');

    const filtered = allChains.filter((c) => c.type === type);

    if (!filtered.length) {
      container.innerHTML = '<p>No chains found</p>';
      return;
    }

    function extractColor(options) {
      return options && options.length ? options[0] : null;
    }

    function getColorCode(name) {
      if (!name) return '#ccc';
      name = name.toLowerCase();

      if (name.includes('yellow')) return '#D4AF37';
      if (name.includes('gold')) return '#D4AF37';
      if (name.includes('rose')) return '#E6B7A9';
      if (name.includes('pink')) return '#E6B7A9';
      if (name.includes('white')) return '#D9D9D9';
      if (name.includes('silver')) return '#C0C0C0';

      return '#ccc';
    }

    filtered.forEach((chain) => {
      let usedColors = new Map();

      chain.variants.forEach((v) => {
        const color = extractColor(v.options);
        if (color && !usedColors.has(color)) {
          usedColors.set(color, v); // map color → variant
        }
      });

      const firstVariant = chain.variants[0];

      const div = document.createElement('div');
      div.className = 'byoj-chain-item';

      let swatchesHTML = '';

      usedColors.forEach((variant, color) => {
        swatchesHTML += `
        <span class="swatch"
              data-variant='${JSON.stringify(variant)}'
              style="background:${getColorCode(color)}"
              title="${color}">
        </span>
      `;
      });

      div.innerHTML = `
      <div class="chain-img-wrap">
        <img src="${firstVariant.image}" class="chain-img"/>
      </div>

      <div class="chain-info">
        <p class="chain-title">${chain.title}</p>

        <div class="chain-swatches">
          ${swatchesHTML}
        </div>

        <p class="chain-price">
          ₹<span class="price">${firstVariant.price}</span>
          ${
            firstVariant.compare && firstVariant.compare != '0'
              ? `<span class="compare">₹${firstVariant.compare}</span>`
              : ''
          }
        </p>
      </div>
    `;

      // SWATCH CLICK LOGIC
      div.querySelectorAll('.swatch').forEach((swatch) => {
        swatch.addEventListener('click', function (e) {
          e.stopPropagation();

          const variant = JSON.parse(this.dataset.variant);

          // Update image
          div.querySelector('.chain-img').src = variant.image;

          // Update price
          div.querySelector('.price').innerText = variant.price;

          const compareEl = div.querySelector('.compare');
          if (compareEl) {
            compareEl.innerText = '₹' + variant.compare;
          }

          // Active state
          div.querySelectorAll('.swatch').forEach((s) => s.classList.remove('active'));
          this.classList.add('active');

          // Save selected variant
          div.setAttribute('data-selected-variant', variant.id);
        });
      });

      // Default selected variant
      div.setAttribute('data-selected-variant', firstVariant.id);

      // CARD CLICK
      div.onclick = () => {
        const selectedVariant = div.getAttribute('data-selected-variant');

        // get selected variant object safely
        let variantData = null;

        const activeSwatch = div.querySelector('.swatch.active');

        if (activeSwatch) {
          try {
            variantData = JSON.parse(activeSwatch.dataset.variant);
          } catch (e) {
            console.error('Variant parse error', e);
          }
        }

        // fallback
        if (!variantData) {
          variantData = chain.variants[0];
        }

        console.log('Selected Variant:', variantData);

        // 🔥 SAVE DATA
        localStorage.setItem('byoj_chain_variant', selectedVariant);
        localStorage.setItem('byoj_chain_image', variantData.image);

        // DEBUG CHECK
        console.log('Saved Image:', variantData.image);

        window.location.href = '/pages/build-your-jewelry-step-3';
      };

      container.appendChild(div);
    });
  });
</script>

<!-- 4. CSS -->
<style>
  .byoj-heading {
    text-align: center;
    margin-bottom: 30px;
  }

  .byoj-chain-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .byoj-chain-item {
    text-align: center;
    cursor: pointer;
  }

  .chain-img-wrap img {
    width: 100%;
    max-width: 320px;
    margin: auto;
    display: block;
  }

  .chain-title {
    margin-top: 15px;
    font-size: 14px;
  }

  .chain-price {
    margin-top: 5px;
    font-weight: 600;
  }

  .chain-price .compare {
    text-decoration: line-through;
    color: #999;
    margin-left: 5px;
    font-weight: 400;
  }

  .chain-swatches {
    margin-top: 10px;
  }

  .swatch {
    display: inline-block;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    margin: 0 5px;
    border: 1px solid #ccc;
    cursor: pointer;
  }

  .swatch.active {
    border: 2px solid #000;
  }
</style>

<!-- 5. Schema -->
{% schema %}
{
  "name": "BYO Chains",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Select Your Chain"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection Chains",
      "settings": [
        {
          "type": "select",
          "id": "type",
          "label": "Jewelry Type",
          "options": [
            { "value": "bracelet", "label": "Bracelet" },
            { "value": "necklace", "label": "Necklace" },
            { "value": "anklet", "label": "Anklet" }
          ]
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    },
    {
      "type": "manual",
      "name": "Manual Chain",
      "settings": [
        {
          "type": "select",
          "id": "type",
          "label": "Jewelry Type",
          "options": [
            { "value": "bracelet", "label": "Bracelet" },
            { "value": "necklace", "label": "Necklace" },
            { "value": "anklet", "label": "Anklet" }
          ]
        },
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYO Chains"
    }
  ]
}
{% endschema %}
