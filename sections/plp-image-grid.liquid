{% schema %}
{
  "name": "Image card PLP",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Explore Our Features"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "label": "Section Description",
      "default": "Learn more about what makes us special."
    }
  ],
  "blocks": [
    {
      "type": "cardplp",
      "name": "Image card PLP",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card PLP Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card PLP Heading",
          "default": "Card PLP Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Card PLP Description",
          "default": "Short description for the Card PLP."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Image card PLP",
      "category": "Custom"
    }
  ]
}
  
{% endschema %}
<section class="image-cardplps-overlay page-width">
<div class="scroll-animated-header scroll-shrink-header">
  <h2 class="heading-animate">{{ section.settings.section_heading }}</h2>
   <p class="description-animate">{{ section.settings.section_description }}</p>
</div>

  <div class="cardplps-container">
    {% for block in section.blocks %}
      <div class="cardplp">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            alt="{{ block.settings.title }}"
            title="{{ block.settings.title }}"
            class="cardplp-img"
          />
        {% endif %}

        <!-- Always visible heading -->
        <div class="cardplp-title">
           <h3 class="fixed-h3-div">{{ block.settings.title }}</h3>
           <p class="heading-description-plp mobile-view-plp">{{ block.settings.description }}</p>
          <a href="{{ block.settings.button_link }}" class="cardplp-btn mobile-view-plp">
            {{ block.settings.button_label }}
          </a>
        </div>
        <!-- Hover content only -->
        <div class="cardplp-overlay-hover">
          
          <p class="heading-description-plp">{{ block.settings.description }}</p>
          <a href="{{ block.settings.button_link }}" class="cardplp-btn">
            {{ block.settings.button_label }}
          </a>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<style>
.heading-animate{font-size:2.5rem;transition:font-size .5s ease}
.heading-animate.grow{font-size:1rem}
.heading-animate.shrink{font-size:6rem}
.image-cardplps-overlay h2{font-size:3rem;text-transform:uppercase;color:#000}
.image-cardplps-overlay p{height:110px;max-width:800px;margin:0 auto;font-size:16px;margin-bottom:10px}
.cardplps-container::-webkit-scrollbar{display:none}
.cardplp{position:relative;width:400px;height:500px;overflow:hidden;display:flex;flex-direction:column;justify-content:flex-end;border-radius:12px}
.cardplp-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:1;transition:transform 1s ease}
.cardplp:hover .cardplp-img{transform:scale(1.2)}
.cardplp-title{position:relative;z-index:2;text-align:center}
.fixed-h3-div{font-size:26px;margin-bottom:10px;color:#fff;text-transform:uppercase}
.cardplp-overlay-hover{position:relative;z-index:2;text-align:center;color:#fff;padding:0 15px;opacity:0;transform:translateY(100px);transition:opacity .5s ease,transform .5s ease}
.cardplp:hover .cardplp-overlay-hover{opacity:1;transform:translateY(0);margin-bottom:35px}
.heading-description-plp{font-size:14px;margin-bottom:10px}
.cardplp-btn{background-color:transparent;color:#fff;text-transform:uppercase;text-decoration:underline;font-size:18px;font-weight:500}
.section-paragraph-head{font-size:1.7rem!important;letter-spacing:1px}
.cardplp:hover .cardplp-title{bottom:0}
section.image-cardplps-overlay.page-width{margin-bottom:5%}
.scroll-animated-header{text-align:center;padding-top:20px;padding-bottom:20px;overflow:hidden;position:relative}
.cardplps-container{display:flex;gap:20px;flex-direction:row;scroll-behavior:smooth;overflow-x:auto}
@media(min-width:769px){
.cardplps-container{height:500px;transition:height 2s ease,margin-top 2s ease;justify-content:center}
.cardplp-title{bottom:-60px}
.cardplps-container.shrink-container{height:0}
.mobile-view-plp{display:none}
.fixed-h3-div-mob{display:none}
.fixed-h3-div{margin-bottom:-10px;transform:translateY(25px);transition:transform 1s ease,opacity 1s ease}
.cardplp:hover .fixed-h3-div{transform:translateY(0);margin-bottom:10px}
p.description-animate{font-size:17px}
}
@media (max-width:768px){
.cardplp-title{margin-bottom:30px}
.cardplp-overlay-hover{display:none!important}
p.heading-description-plp.mobile-view-plp{color:#fff;padding:0 15px;margin-bottom:-15px}
.cardplp:hover .cardplp-overlay-hover{opacity:0!important}
.cardplp{height:400px;min-width:250px;margin-bottom:10%}
.image-cardplps-overlay p{max-width:600px}
.image-cardplps-overlay h2{font-size:20px;text-transform:uppercase;color:#000}
}
@media(max-width:428px){
.image-cardplps-overlay p{font-size:12px}
.fixed-h3-div{font-size:18px}
.cardplp-btn{font-size:14px}
.image-cardplps-overlay p {height: auto;}
p.heading-description-plp.mobile-view-plp {margin-bottom: 0;}
}
</style>