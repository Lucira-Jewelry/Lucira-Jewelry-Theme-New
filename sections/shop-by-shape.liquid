<style>
  /* ===== Skeleton Loading Styles ===== */
  .shop-by-shape-skeleton-wrapper {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    padding: 30px 0 60px;
  }

  .shop-by-shape-skeleton-item {
    text-align: center;
  }

  .shop-by-shape-skeleton-image {
    height: 120px;
    width: 120px;
    margin: 0 auto 10px;
    border-radius: 50%;
    background: linear-gradient(
      90deg,
      #f0f0f0 25%,
      #f8f8f8 37%,
      #f0f0f0 63%
    );
    background-size: 400% 100%;
    animation: shapeShimmer 1.4s ease infinite;
  }

  .shop-by-shape-skeleton-text {
    height: 14px;
    width: 60px;
    margin: 0 auto;
    background: linear-gradient(
      90deg,
      #f0f0f0 25%,
      #f8f8f8 37%,
      #f0f0f0 63%
    );
    background-size: 400% 100%;
    animation: shapeShimmer 1.4s ease infinite;
  }

  @keyframes shapeShimmer {
    0% { background-position: 100% 0; }
    100% { background-position: -100% 0; }
  }

  @media (max-width: 767px) {
    .shop-by-shape-skeleton-wrapper {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(2, 100px);
      gap: 10px;
      padding: 0 0 40px;
    }
    
    .shop-by-shape-skeleton-image {
      height: 60px;
      width: 60px;
    }
    
    .shop-by-shape-skeleton-text {
      height: 12px;
      width: 40px;
    }
  }

  /* ===== Original Styles ===== */
  .shop-by-shape-content-wrapper {
    display: none;
  }

  .shop-by-shape {
    content-visibility: auto;
    contain-intrinsic-size: 400px auto;
  }

  .shop-by-shape .page-width {
    padding: 30px 0 60px;
  }

  .shop-by-shape h2 {
    font-size: 24px;
    text-align: center;
    margin-bottom: 0;
    text-transform: uppercase;
    margin: 0;
  }

  .shape-item a {
    text-decoration: none;
  }

  .shop-by-shape p {
    max-width: 700px;
    margin: 0 auto 30px;
    font-size: 18px;
    text-align: center;
    color: #555;
  }

  .shape-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-around;
    gap: 0;
    content-visibility: auto;
    contain-intrinsic-size: 300px auto;
  }

  .shape-item img {
    transition: .3s;
  }

  .shape-item img:hover {
    transform: scale(1.1);
  }

  .shape-item img {
    height: 120px;
    object-fit: contain;
    display: block;
    margin: 0 auto 10px;
  }

  .shape-item p {
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    margin: 0;
  }

  .shape-item img {
    width: max-content !important;
  }

  /* Lazy reveal animation */
  .shape-item {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .shape-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (min-width: 1600px) {
    .shape-grid {
      max-width: 1400px;
      margin: 0 auto;
    }
  }

  @media (max-width: 767px) {
    .shop-by-shape .page-width {
      padding: 0 0 40px;
    }
    
    .shape-item p {
      font-size: 12px !important;
    }
    
    .shop-by-shape p {
      font-size: 14px;
    }
    
    .shop-by-shape h2 {
      font-size: 18px;
    }
    
    .shape-item {
      width: 100%;
    }
    
    .shape-item img {
      width: 100%;
      height: 60px;
    }
    
    .shape-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(2, 100px);
      gap: 10px;
    }
  }

  @media only screen and (min-width: 1600px) and (max-width: 2100px) {
    .shop-by-shape h2 {
      font-size: 28px;
    }
  }
</style>

<section class="shop-by-shape" data-shop-by-shape-lazy>
  <div class="page-width">
    <!-- ===== SKELETON LOADER ===== -->
    <div class="shop-by-shape-skeleton-wrapper">
      {%- for i in (1..8) -%}
        <div class="shop-by-shape-skeleton-item">
          <div class="shop-by-shape-skeleton-image"></div>
          <div class="shop-by-shape-skeleton-text"></div>
        </div>
      {%- endfor -%}
    </div>

    <!-- ===== ACTUAL CONTENT ===== -->
    <div class="shop-by-shape-content-wrapper">
      <div class="text-center">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.subtext }}</p>

        <div class="shape-grid">
          {% for block in section.blocks %}
          {%- assign lazy_load = false -%}
          {%- if forloop.index > 4 -%}
            {%- assign lazy_load = true -%}
          {%- endif -%}
          
          <div class="shape-item scroll-trigger">
            <a href="{{ block.settings.shape_link }}" class="shape-link" data-shape-title="{{ block.settings.shape_title }}">
              {% if block.settings.shape_image != blank %}
              <picture>
                <!-- Mobile: 60x60 -->
                <source media="(max-width: 767px)" srcset="{{ block.settings.shape_image | img_url: '200x200' }}">
                <!-- Desktop: 200x200 -->
                <source media="(min-width: 768px)" srcset="{{ block.settings.shape_image | img_url: '200x200' }}">
                <!-- Fallback with lazy loading -->
                <img src="{{ block.settings.shape_image | img_url: '120x120' }}" 
                     data-src="{{ block.settings.shape_image | img_url: '200x200' }}"
                     data-srcset="{{ block.settings.shape_image | img_url: '200x200' }}"
                     alt="{{ block.settings.shape_title }} cut diamond" 
                     title="{{ block.settings.shape_title }}" 
                     {% if lazy_load %}loading="lazy"{% endif %}
                     width="60" 
                     height="60" 
                     class="shape-img lazy-image">
              </picture>
              {% endif %}
              <p>{{ block.settings.shape_title }}</p>
            </a>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
    <!-- ===== END ACTUAL CONTENT ===== -->
  </div>
</section>

<script>
  // ===== SKELETON INTERSECTION OBSERVER =====
  (function () {
    const shopByShapeSection = document.querySelector('[data-shop-by-shape-lazy]');
    if (!shopByShapeSection) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const skeleton = shopByShapeSection.querySelector('.shop-by-shape-skeleton-wrapper');
          const content = shopByShapeSection.querySelector('.shop-by-shape-content-wrapper');

          if (skeleton && content) {
            // Show content with fade-in
            content.style.display = 'block';
            content.style.opacity = '0';
            content.style.transition = 'opacity 0.5s ease';

            requestAnimationFrame(() => {
              content.style.opacity = '1';
              // Remove skeleton after animation
              setTimeout(() => {
                skeleton.remove();
              }, 500);
            });
          }

          observer.disconnect();
        }
      });
    }, {
      rootMargin: '200px' // Preload 200px before section enters viewport
    });

    observer.observe(shopByShapeSection);
  })();

  // ===== LAZY REVEAL ANIMATION FOR SHAPE ITEMS =====
  (function () {
    const shapeItems = document.querySelectorAll('.shape-item.scroll-trigger');
    if (!shapeItems.length) return;

    const observerOptions = {
      root: null,
      rootMargin: '50px',
      threshold: 0.1
    };

    const shapeObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          shapeObserver.unobserve(entry.target);
        }
      });
    }, observerOptions);

    shapeItems.forEach(item => {
      shapeObserver.observe(item);
    });
  })();

  // ===== LAZY LOAD IMAGES FOR ITEMS BELOW FIRST ROW =====
  (function () {
    const lazyImages = document.querySelectorAll('.shape-img.lazy-image');
    if (!lazyImages.length) return;

    const imageObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const img = entry.target;
          img.src = img.dataset.src;
          img.srcset = img.dataset.srcset;
          img.classList.remove('lazy-image');
          imageObserver.unobserve(img);
        }
      });
    }, {
      rootMargin: '100px'
    });

    lazyImages.forEach(img => {
      // Only lazy load images beyond first 4 items
      const shapeItem = img.closest('.shape-item');
      const shapeGrid = document.querySelector('.shape-grid');
      if (shapeGrid && shapeItem) {
        const allItems = Array.from(shapeGrid.querySelectorAll('.shape-item'));
        const itemIndex = allItems.indexOf(shapeItem);
        
        if (itemIndex >= 4) {
          imageObserver.observe(img);
        }
      }
    });
  })();

  // ===== ANALYTICS TRACKING =====
  document.addEventListener("DOMContentLoaded", function() {
    document.querySelectorAll(".shape-link").forEach((link, index) => {
      link.addEventListener("click", function() {
        var shapeTitle = this.getAttribute("data-shape-title") || "Unknown Shape";
        var shapeHref = this.getAttribute("href") || "N/A";

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "promoClick",
          promoClick: {
            promo_id: shapeTitle, // ✅ Shape Title as ID
            promo_name: "Shop by Shape - " + shapeTitle,
            creative_name: "Shape Grid Click",
            location_id: shapeHref
          }
        });
      });
    });
  });
</script>