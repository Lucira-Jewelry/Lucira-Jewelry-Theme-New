{%- style -%}
  /* ===== Skeleton Loading Styles ===== */
  .shop-by-shape-skeleton-wrapper{display:grid;grid-template-columns:repeat(6,1fr);gap:20px;padding:40px 0 60px}
.shop-by-shape-skeleton-item{text-align:center}
.shop-by-shape-skeleton-image{width:120px;height:120px;border-radius:50%;margin:0 auto 10px;background:linear-gradient(90deg,#f0f0f0 25%,#f8f8f8 37%,#f0f0f0 63%);background-size:400% 100%;animation:shapeShimmer 1.4s ease infinite}
.shop-by-shape-skeleton-text{width:60px;height:16px;margin:0 auto;background:#f0f0f0;border-radius:4px}
@keyframes shapeShimmer{
0%{background-position:100% 0}
100%{background-position:-100% 0}
}
.shop-by-shape-content{display:none;opacity:0;transition:opacity .5s ease}
.shop-by-shape-content.loaded{opacity:1}
.shop-by-shape{padding:30px 0 60px;content-visibility:auto;contain-intrinsic-size:300px auto}
.shop-by-shape h2{font-size:24px;text-align:center;margin-bottom:0;text-transform:uppercase;margin:0}
.shop-by-shape p{max-width:700px;margin:0 auto 30px;font-size:18px;text-align:center;color:#555}
.shape-grid{display:flex;flex-wrap:wrap;justify-content:space-around;gap:0}
.shape-item{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease}
.shape-item.visible{opacity:1;transform:translateY(0)}
.shape-item a{text-decoration:none;display:block}
.shape-img{transition:transform .3s ease,opacity .3s ease;opacity:0;height:120px;object-fit:contain;display:block;margin:0 auto 10px;width:max-content!important}
.shape-img.loaded{opacity:1}
.shape-img:hover{transform:scale(1.1)}
.shape-item p{font-size:14px;font-weight:500;text-transform:uppercase;margin:0}
@media (min-width:1600px){
.shape-grid{max-width:1400px;margin:0 auto}
}
@media (max-width:767px){
.shop-by-shape-skeleton-wrapper{grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(2,100px);gap:10px;padding:0 0 40px}
.shop-by-shape-skeleton-image{width:60px;height:60px}
.shop-by-shape-skeleton-text{width:40px;height:12px}
.shop-by-shape{padding:0 0 40px}
.shape-item p{font-size:12px!important}
.shop-by-shape p{font-size:14px}
.shop-by-shape h2{font-size:18px}
.shape-item{width:100%}
.shape-img{width:100%;height:60px}
.shape-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(2,100px);gap:10px}
}
@media only screen and (min-width:1600px) and (max-width:2100px){
.shop-by-shape h2{font-size:28px}
}
@media (min-width:768px) and (max-width:1024px){
.shop-by-shape-skeleton-wrapper{grid-template-columns:repeat(4,1fr)}
.shape-grid{grid-template-columns:repeat(4,1fr)}
}
{%- endstyle -%}

<div class="shop-by-shape" data-shop-by-shape-lazy>
  <!-- ===== SKELETON LOADER ===== -->
  <div class="shop-by-shape-skeleton-wrapper">
    {% for i in (1..8) %}
      <div class="shop-by-shape-skeleton-item">
        <div class="shop-by-shape-skeleton-image"></div>
        <div class="shop-by-shape-skeleton-text"></div>
      </div>
    {% endfor %}
  </div>

  <!-- ===== ACTUAL CONTENT ===== -->
  <div class="shop-by-shape-content">
    <div class="page-width">
      <div class="text-center">
        {% if section.settings.heading != blank %}
          <h2 class="shop-by-shape-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        
        {% if section.settings.subtext != blank %}
          <p class="shop-by-shape-subtext">{{ section.settings.subtext }}</p>
        {% endif %}

        <div class="shape-grid">
          {% for block in section.blocks %}
            <div class="shape-item" 
                 data-index="{{ forloop.index0 }}"
                 {% if settings.animations_reveal_on_scroll %}
                   style="--animation-order: {{ forloop.index }};"
                 {% endif %}>
              {% if block.settings.shape_link %}
                <a href="{{ block.settings.shape_link }}" 
                   class="shape-link" 
                   data-shape-title="{{ block.settings.shape_title | escape }}"
                   aria-label="Shop {{ block.settings.shape_title }} shape">
              {% endif %}
                
                {% if block.settings.shape_image != blank %}
                  {% assign desktop_image = block.settings.shape_image | img_url: '200x200', crop: 'center' %}
                  {% assign mobile_image = block.settings.shape_image | img_url: '120x120', crop: 'center' %}
                  
                  <picture>
                    <!-- Mobile -->
                    <source media="(max-width: 767px)" 
                            srcset="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw=="
                            data-srcset="{{ mobile_image }} 1x,
                                        {{ mobile_image | img_url: '240x240' }} 2x"
                            data-sizes="(max-width: 767px) 60px">
                    
                    <!-- Desktop -->
                    <source media="(min-width: 768px)" 
                            srcset="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw=="
                            data-srcset="{{ desktop_image }} 1x,
                                        {{ desktop_image | img_url: '400x400' }} 2x"
                            data-sizes="120px">
                    
                    <!-- Fallback -->
                    <img src="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw=="
                         data-src="{{ desktop_image }}"
                         alt="{{ block.settings.shape_title }} cut diamond" 
                         title="{{ block.settings.shape_title }}" 
                         width="120"
                         height="120"
                         loading="lazy"
                         decoding="async"
                         class="shape-img">
                  </picture>
                {% else %}
                  <div class="shape-placeholder" style="width: 120px; height: 120px; background: #f5f5f5; border-radius: 50%; margin: 0 auto 10px;"></div>
                {% endif %}
                
                {% if block.settings.shape_title != blank %}
                  <p class="shape-title">{{ block.settings.shape_title }}</p>
                {% endif %}
                
              {% if block.settings.shape_link %}
                </a>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // ===== LAZY LOADING & SKELETON REMOVAL =====
  (function() {
    const shapeSection = document.querySelector('[data-shop-by-shape-lazy]');
    if (!shapeSection) return;

    const skeleton = shapeSection.querySelector('.shop-by-shape-skeleton-wrapper');
    const content = shapeSection.querySelector('.shop-by-shape-content');

    // Intersection Observer for lazy loading
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Load images first
          loadLazyImages();
          
          // Show content with fade-in
          content.style.display = 'block';
          requestAnimationFrame(() => {
            content.classList.add('loaded');
            
            // Initialize animation observers
            initAnimationObservers();
            
            // Remove skeleton after content is visible
            setTimeout(() => {
              if (skeleton) skeleton.remove();
            }, 300);
          });

          // Track view for analytics
          trackShapeGridView();
          
          observer.disconnect();
        }
      });
    }, {
      rootMargin: '200px'
    });

    observer.observe(shapeSection);

    // Lazy load images
    function loadLazyImages() {
      const lazyImages = shapeSection.querySelectorAll('img[data-src], source[data-srcset]');
      
      lazyImages.forEach(img => {
        if (img.tagName === 'SOURCE') {
          img.srcset = img.dataset.srcset;
        } else {
          img.src = img.dataset.src;
          
          // Add loaded class when image is loaded
          img.addEventListener('load', function() {
            this.classList.add('loaded');
          });
          
          // Fallback for error
          img.addEventListener('error', function() {
            console.warn('Failed to load shape image:', this.dataset.src);
            this.style.backgroundColor = '#f5f5f5';
          });
        }
        
        // Remove data attributes after setting src/srcset
        if (img.dataset.src) delete img.dataset.src;
        if (img.dataset.srcset) delete img.dataset.srcset;
        if (img.dataset.sizes) delete img.dataset.sizes;
      });
    }

    // Initialize scroll animations
    function initAnimationObservers() {
      const shapeItems = shapeSection.querySelectorAll('.shape-item');
      
      const itemObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            itemObserver.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: '50px'
      });
      
      shapeItems.forEach(item => itemObserver.observe(item));
    }

    // Analytics tracking for view
    function trackShapeGridView() {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: "promoView",
        promoView: {
          promo_id: "shop_by_shape_grid",
          promo_name: "Shop by Shape Grid",
          creative_name: "Shape Grid",
          location: "Home Page"
        }
      });
    }

    // Click tracking (delegated event listener)
    shapeSection.addEventListener('click', function(e) {
      const shapeLink = e.target.closest('.shape-link');
      if (shapeLink) {
        e.preventDefault();
        
        const shapeTitle = shapeLink.getAttribute('data-shape-title') || 'Unknown Shape';
        const shapeHref = shapeLink.getAttribute('href') || '#';
        
        // Analytics tracking
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "promoClick",
          promoClick: {
            promo_id: shapeTitle,
            promo_name: "Shop by Shape - " + shapeTitle,
            creative_name: "Shape Grid Click",
            location_id: shapeHref
          }
        });
        
        // Navigate after tracking
        setTimeout(() => {
          window.location.assign(shapeHref);
        }, 100);
      }
    });

    // Performance: Preconnect to image domain
    if (performance && performance.getEntriesByType) {
      const imageDomain = new URL('{{ 'image.png' | asset_url }}').origin;
      const link = document.createElement('link');
      link.rel = 'preconnect';
      link.href = imageDomain;
      link.crossOrigin = 'anonymous';
      document.head.appendChild(link);
    }
  })();
</script>

{% schema %}
{
  "name": "Shop by Shape",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP BY SHAPE"
