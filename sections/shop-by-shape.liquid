{% comment %} {% schema %}
{
  "name": "Shop by Shape",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP BY SHAPE"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    }
  ],
  "blocks": [
    {
      "type": "shape",
      "name": "Shape",
      "settings": [
        {
          "type": "image_picker",
          "id": "shape_image",
          "label": "Shape Image"
        },
        {
          "type": "text",
          "id": "shape_title",
          "label": "Shape Title",
          "default": "ROUND"
        },
        {
          "type": "url",
          "id": "shape_link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Shop by Shape",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<section class="shop-by-shape">
  <div class="page-width">
    <div class="text-center">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subtext }}</p>

      <div class="shape-grid">
        {% for block in section.blocks %}
        <div class="shape-item">
          <a href="{{ block.settings.shape_link }}" class="shape-link" data-shape-title="{{ block.settings.shape_title }}">
            {% if block.settings.shape_image != blank %}
            <picture>
              <!-- Mobile: 60x60 -->
              <source media="(max-width: 767px)" srcset="{{ block.settings.shape_image | img_url: '200x200' }}">
              <!-- Desktop: 200x200 -->
              <source media="(min-width: 768px)" srcset="{{ block.settings.shape_image | img_url: '200x200' }}">
              <!-- Fallback -->
              <img src="{{ block.settings.shape_image | img_url: '120x120' }}" 
                   alt="{{ block.settings.shape_title }} cut diamond" 
                   title="{{ block.settings.shape_title }}" 
                   loading="lazy" 
                   width="60" 
                   height="60" 
                   class="shape-img">
            </picture>
            {% endif %}
            <p>{{ block.settings.shape_title }}</p>
          </a>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>


<style>
  .shop-by-shape{padding:30px 0 60px;}
  .shop-by-shape h2{font-size:24px;text-align:center;margin-bottom:0;text-transform:uppercase;margin:0}
  .shape-item a{text-decoration:none}
  .shop-by-shape p{max-width:700px;margin:0 auto 30px;font-size:18px;text-align:center;color:#555}
  .shape-grid{display:flex;flex-wrap:wrap;justify-content:space-around;gap:0}
  .shape-item img{transition:.3s}
  .shape-item img:hover{transform:scale(1.1)}
  .shape-item img{height:120px;object-fit:contain;display:block;margin:0 auto 10px}
  .shape-item p{font-size:14px;font-weight:500;text-transform:uppercase;margin:0}
  .shape-item img {width: max-content !important;}

  /* Shop by Shape - Section Lazy Reveal */
.shop-by-shape,
.shape-link {
  content-visibility: auto;
  contain-intrinsic-size: 300px auto;
}

  @media(min-width:1600px){
  .shape-grid{max-width:1400px;margin:0 auto}
  }
  @media(max-width:767px){
  .shop-by-shape{padding:0 0 40px;}
  .shape-item p{font-size:12px!important}
  .shop-by-shape p{font-size:14px}
  .shop-by-shape h2{font-size:18px}
  .shape-item{width:100%}
  .shape-item img{width:100%;height:60px}
  .shape-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(2,100px);gap:10px}
  }
  @media only screen and (min-width:1600px) and (max-width:2100px){
  .shop-by-shape h2{font-size:28px}
  }
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  document.querySelectorAll(".shape-link").forEach((link, index) => {
    link.addEventListener("click", function() {
      var shapeTitle = this.getAttribute("data-shape-title") || "Unknown Shape";
      var shapeHref = this.getAttribute("href") || "N/A";

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: "promoClick",
        promoClick: {
          promo_id: shapeTitle, // ✅ Shape Title as ID
          promo_name: "Shop by Shape - " + shapeTitle,
          creative_name: "Shape Grid Click",
          location_id: shapeHref
        }
      });
    });
  });
});


document.addEventListener("DOMContentLoaded", function () {
  const shapeLinks = document.querySelectorAll(".shape-link");
  if (!shapeLinks.length) return;

  const observer = new IntersectionObserver((entries, obs) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add("visible");
        obs.unobserve(entry.target); // Stop observing once revealed
      }
    });
  }, { threshold: 0.2 });

  shapeLinks.forEach(link => observer.observe(link));
});

</script> {% endcomment %}

