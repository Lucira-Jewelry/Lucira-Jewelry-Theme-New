<style>
 .piercing-section{display:flex;align-items:center;padding-top:40px;gap:60px;width:65%;margin:0 auto;padding-bottom:40px}
.piercing-section.image-first{flex-direction:row}
.piercing-section.text-first{flex-direction:row-reverse}
.piercing-section__image-wrapper{flex:1;min-width:0}
.piercing-section__image{max-width:100%;display:block;object-fit:cover}
.piercing-section__content{flex:1;text-align:center}
.piercing-section__title{font-size:28px;margin-bottom:12px;text-transform:uppercase;MARGIN-TOP:0}
.piercing-section__text p{font-size:18px;margin:0;margin-bottom:32px;line-height:24px}
.piercing-section__button{text-decoration:underline;color:inherit;font-size:18px}
@media (max-width:768px){
.piercing-section{flex-direction:column!important;gap:24px;width:100%;padding:20px;padding-top:20px}
.piercing-section__title{font-size:20px;margin-bottom:6px}
.piercing-section__text p{font-size:12px;margin:0;margin-bottom:12px;line-height:18px}
.piercing-section__button{font-size:14px}
}
</style>

<section class="piercing-section {% if section.settings.layout_toggle == 'image_first' %}image-first{% else %}text-first{% endif %}">
  <div class="piercing-section__image-wrapper">
    {% if section.settings.image != blank %}
      <img
        src="{{ section.settings.image | image_url: width: 1000 }}"
        alt="{{ section.settings.image.alt | escape }}"
        title="{{ section.settings.image.alt | escape }}"
        loading="lazy"
        class="piercing-section__image"
        width="{{ section.settings.image.width }}"
        height="auto"
      >
    {% else %}
      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
  </div>

  <div class="piercing-section__content">
    {% if section.settings.title != blank %}
      <h2 class="piercing-section__title">{{ section.settings.title | escape }}</h2>
    {% endif %}
    {% if section.settings.text != blank %}
      <div class="piercing-section__text">
        
        <p>{{ section.settings.text }}</p>


      </div>
    {% endif %}
    {% if section.settings.button_text != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="piercing-section__button">{{ section.settings.button_text | escape }}</a>
    {% endif %}
  </div>
</section>

{% schema %}
  {
    "name": "Piercing Section",
    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Section Image"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Heading",
        "default": "PIERCING"
      },
      {
        "type": "richtext",
        "id": "text",
        "label": "Text",
        "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut alconsequat.</p>"
      },
      {
        "type": "text",
        "id": "button_text",
        "label": "Button Text",
        "default": "BOOK AN APPOINTMENT"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      },
      {
        "type": "radio",
        "id": "layout_toggle",
        "label": "Layout",
        "options": [
          { "value": "image_first", "label": "Image First, Text Second" },
          { "value": "text_first", "label": "Text First, Image Second" }
        ],
        "default": "image_first"
      }
    ],
    "presets": [
      {
        "name": "Piercing Section"
      }
    ]
  }
{% endschema %}