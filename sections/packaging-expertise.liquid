<section class="packaging-showcase">
  <div class="packaging-container">

    <!-- Grey Content Strip -->
    <div class="packaging-content">
      <h2 class="packaging-title">
        {{ section.settings.heading }}
      </h2>
      <p class="packaging-description">
        {{ section.settings.description }}
      </p>
    </div>

    <!-- Image -->
    <div class="packaging-image">
      {% if section.settings.main_image != blank %}
        <img
          src="{{ section.settings.main_image | image_url: width: 1200 }}"
          alt="{{ section.settings.heading | escape }}"
          loading="lazy"
        >
      {% endif %}
    </div>

  </div>
</section>

<style>
.packaging-showcase{padding:120px 0;background:#fff}
.packaging-container{position:relative;margin:0 auto}
.packaging-content{background:#e6e6e6;padding:40px 700px 40px 60px;min-height:180px}
.packaging-image{position:absolute;right:0;top:-295px;width:900px;z-index:2}
.packaging-image img{width:100%;height:auto;display:block}
.packaging-title{font-size:24px;font-weight:500;margin-bottom:12px;color:#1a1a1a;letter-spacing:.04em;text-transform:uppercase}
.packaging-description{font-size:14px;line-height:1.6;color:#333;max-width:420px}
@media (max-width:768px){
.packaging-image{position:static;width:100%;margin-bottom:20px}
.packaging-content{padding:40px 24px;background:0 0}
.packaging-showcase{padding:0 0 40px 0}
.packaging-container{display:flex;flex-direction:column-reverse}
.packaging-title{font-size:18px}
}
</style>

{% schema %}
{
  "name": "Packaging Showcase",
  "settings": [
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Packaging Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PACKAGING"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    }
  ],
  "presets": [
    {
      "name": "Packaging Showcase"
    }
  ]
}
{% endschema %}
