<style>
  .four-image-grid{padding:10px 0;background:#fff}
.section-header{text-align:center;margin-bottom:0}
.section-heading{font-size:28px;font-weight:400;color:#1a1a1a;margin-bottom:12px;letter-spacing:2px;text-transform:uppercase;font-family:"Futura Std",sans-serif!important}
.section-subheading{font-size:16px;color:#666;line-height:1.5;max-width:600px;margin:0 auto;allign:center}
.grid-container{display:grid;grid-template-columns:repeat(4,1fr);gap:0;max-width:1000px;margin:0 auto;padding:0 20px}
.grid-item{text-align:center;border-radius:8px}
.collection__title .title:not(:only-child){margin-bottom:1rem;font-size:25px}
.grid-item img{width:100%;height:auto;object-fit:cover;display:block;border-radius:8px;transition:transform .3s ease;padding:60px;margin-bottom:-32px}
.grid-item:hover img{transform:scale(1.02)}
.grid-item-content{padding:0}
.grid-item-title{font-size:16px;font-weight:500;margin-bottom:8px;color:#1a1a1a;font-family:"Futura Std",sans-serif!important}
.grid-item-description{font-size:14px;line-height:1.4;color:#666}
@media only screen and (max-width:767px){
.four-image-grid{padding:2px 0;padding-bottom:30px}
.section-header{margin-bottom:30px}
.section-heading{font-size:18px;font-weight:500;letter-spacing:1px}
.section-subheading{font-size:14px}
.grid-item img{padding:10px}
.grid-container{grid-template-columns:repeat(4,1fr);gap:15px;padding:0 15px}
.grid-item-title{font-size:10px;padding-top:40px;max-width:68px;margin:0 auto}
.grid-item-description{font-size:12px}
}
@media only screen and (min-width:768px) and (max-width:1023px){
.section-heading{font-size:24px}
.grid-item img{padding:10px}
.section-subheading{font-size:15px}
.grid-container{padding:0 30px;gap:15px}
.grid-item-title{font-size:15px}
.grid-item-description{font-size:13px}
}
@media only screen and (min-width:0) and (max-width:380px){
.grid-container{grid-template-columns:repeat(4,1fr);gap:15px;padding:0}
}
</style>

<div class="four-image-grid">
  <div class="page-width">
    <!-- Added Header Section -->
    <div class="section-header">
      {% if section.settings.heading != blank %}
        <h2 class="section-heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="section-subheading">{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </div>
    
    <div class="grid-container">
      {% for block in section.blocks %}
        <div class="grid-item" {{ block.shopify_attributes }}>
          {% if block.settings.grid_image %}
            {% if block.settings.grid_link %}
              <a href="{{ block.settings.grid_link }}">
            {% endif %}
            
            <img
              src="{{ block.settings.grid_image | image_url: width: 400 }}"
              alt="{{ block.settings.grid_alt | default: block.settings.grid_title | escape }}"
              loading="lazy"
              title="{{ block.settings.grid_alt | default: block.settings.grid_title | escape }}"
              width="400"
              height="250"
            >
            
            {% if block.settings.grid_link %}
              </a>
            {% endif %}
            
            {% if block.settings.grid_title != blank or block.settings.grid_description != blank %}
              <div class="grid-item-content">
                {% if block.settings.grid_title != blank %}
                  <div class="grid-item-title">{{ block.settings.grid_title | escape }}</div>
                {% endif %}
                {% if block.settings.grid_description != blank %}
                  <div class="grid-item-description">{{ block.settings.grid_description | escape }}</div>
                {% endif %}
              </div>
            {% endif %}
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Four Image Grid",
  "settings": [
  {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "LUCIRA PROMISE"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt"
    }
  ],
  "blocks": [
    {
      "type": "grid_item",
      "name": "Grid Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "grid_image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "grid_title",
          "label": "Image Title (optional)"
        },
        {
          "type": "textarea",
          "id": "grid_description",
          "label": "Image Description (optional)"
        },
        {
          "type": "url",
          "id": "grid_link",
          "label": "Image Link (optional)"
        },
        {
          "type": "text",
          "id": "grid_alt",
          "label": "Image Alt Text"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Four Image Grid",
      "category": "Image",
      "blocks": [
        {
          "type": "grid_item"
        },
        {
          "type": "grid_item"
        },
        {
          "type": "grid_item"
        },
        {
          "type": "grid_item"
        }
      ]
    }
  ]
}
{% endschema %}