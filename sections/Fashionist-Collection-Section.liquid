{% comment %}
  SECTION: Desktop Fashionist Collection
  Desktop-only layout matching provided design
{% endcomment %}

<section class="fashionist-section">
  <div class="fashionist-top">
    <p class="fashionist-intro">
      {{ section.settings.top_text }}
    </p>
  </div>

  <div class="fashionist-middle">
    <div class="fashionist-content">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
      <a href="{{ section.settings.collection_url }}" class="fashionist-link">
        {{ section.settings.link_text }}
      </a>
    </div>

    <div class="fashionist-image">
      {% if section.settings.main_image != blank %}
        <img src="{{ section.settings.main_image | img_url: '900x' }}" alt="Fashion image">
      {% endif %}
    </div>
  </div>

  <div class="fashionist-products">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}
      {% if product != blank %}
        <div class="fashionist-product-card">
          <a href="{{ product.url }}">
            <img src="{{ product.featured_image | img_url: '400x' }}" alt="{{ product.title }}">
            <p class="product-title">{{ product.title }}</p>
            <p class="product-price">{{ product.price | money }}</p>
          </a>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="fashionist-cta">
    <a href="{{ section.settings.collection_url }}" class="btn-explore">
      {{ section.settings.cta_text }}
    </a>
  </div>
</section>

<style>
/* Desktop only */
@media screen and (max-width: 1023px) {
  .fashionist-section { display: none; }
}

.fashionist-section {
  max-width: 1400px;
  margin: 0 auto;
  padding: 80px 40px;
  font-family: inherit;
}

.fashionist-top {
  text-align: center;
  max-width: 700px;
  margin: 0 auto 80px;
}

.fashionist-intro {
  font-size: 14px;
  line-height: 1.6;
  color: #222;
}

.fashionist-middle {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  margin-bottom: 80px;
}

.fashionist-content h2 {
  font-size: 24px;
  letter-spacing: 2px;
  margin-bottom: 20px;
}

.fashionist-content p {
  font-size: 14px;
  line-height: 1.6;
  margin-bottom: 20px;
}

.fashionist-link {
  font-size: 12px;
  text-decoration: underline;
  color: #000;
}

.fashionist-image img {
  width: 850px;
    border-radius: 12px;

}

.fashionist-products {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px;
  margin-bottom: 60px;
}

.fashionist-product-card img {
  width: 100%;
  margin-bottom: 15px;
}

.product-title {
  font-size: 13px;
  margin-bottom: 6px;
}

.product-price {
  font-size: 13px;
}

.fashionist-cta {
  text-align: center;
}

.btn-explore {
  display: inline-block;
  padding: 12px 36px;
  background: #9c7c73;
  color: #fff;
  font-size: 12px;
  letter-spacing: 1px;
  border-radius: 6px;
}
</style>

{% schema %}
{
  "name": "Fashionist Collection",
  "settings": [
    {
      "type": "textarea",
      "id": "top_text",
      "label": "Top Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FASHIONIST"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Right Image"
    },
    {
      "type": "url",
      "id": "collection_url",
      "label": "Collection Link"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Text Link",
      "default": "View Fashion Collection"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "EXPLORE MORE"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select product"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Fashionist Collection",
      "category": "Custom"
    }
  ]
}
{% endschema %}