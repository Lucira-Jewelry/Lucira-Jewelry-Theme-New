    /* Adjusted CTA Banner Styles for Full Width */
    .lucira-blogs .cta-banner {
        width: 100vw; /* Occupy full viewport width */
        position: relative; /* Needed for left: 50% and transform */
        left: 50%;
        right: 50%;
        margin-left: -50vw; /* Pull left by half viewport width */
        margin-right: -50vw; /* Pull right by half viewport width */
        padding: 150px 20px; /* Padding inside banner (adjust as needed) */
        box-sizing: border-box;
        /* Background image set via inline style from block setting */
        background-size: cover;
        background-repeat: no-repeat;
        background-position: top;
        text-align: center;
        color: #fff; /* White text */
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 30px; /* Space between elements */
        /* Removed border-radius as it might not look good edge-to-edge */
        margin-top: 20px; /* Space above */
        margin-bottom: 20px; /* Space below */
        font-family: 'Futura std', sans-serif; /* Ensure Futura Std */
    }

    .lucira-blogs .cta-title { /* Added section class prefix */
        font-size: 21px;
        letter-spacing: 0.04em; /* 4% */
        font-weight: 500; /* Medium */
        line-height: 1.4; /* Adjust line height */
    }

    .lucira-blogs .cta-description { /* Added section class prefix */
        font-size: 12px;
        letter-spacing: 0.04em; /* 4% */
        line-height: 18px;
        color: #e5e5e5; /* Light grey text */
        white-space: pre-wrap; /* Preserve line breaks from textarea */
    }

    .lucira-blogs .cta-button { /* Added section class prefix */
        display: inline-block;
        width: 188px; /* Button width */
        border-radius: 14px; /* Rounded corners */
        border: 1px solid #fff; /* White border */
        box-sizing: border-box;
        height: 36px; /* Button height */
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 9px 16px;
        text-decoration: none;
        color: #fff;
        text-transform: uppercase;
        font-weight: 500; /* Medium */
        font-size: 12px;
        cursor: pointer;
        transition: background-color 0.3s ease, color 0.3s ease; /* Smooth transition */
    }

     .lucira-blogs .cta-button:hover { /* Added section class prefix */
         background-color: rgba(255, 255, 255, 0.1); /* Slightly transparent white on hover */
         color: #fff;
     }


