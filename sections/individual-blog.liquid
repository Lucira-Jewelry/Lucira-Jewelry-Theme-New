<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sidebar = document.querySelector('.right-sidebar .toc-content');
    if (sidebar) {
      const links = sidebar.querySelectorAll('a[href^="#"]');
      links.forEach(link => {
        link.addEventListener('click', function(e) {
          const href = this.getAttribute('href');
          if (href && href.startsWith('#')) {
            e.preventDefault();
            const target = document.querySelector(href);
            if (target) {
              const y = target.getBoundingClientRect().top + window.pageYOffset - 20;
              window.scrollTo({ top: y, behavior: 'smooth' });
            }
          }
        });
      });

      const idToLink = {};
      links.forEach(a => {
        const href = a.getAttribute('href');
        if (href && href.startsWith('#')) {
          const id = href.slice(1);
          idToLink[id] = a;
        }
      });

      const observedIds = Object.keys(idToLink);
      if (observedIds.length) {
        const observerOptions = {
          root: null,
          rootMargin: '0px 0px -65% 0px',
          threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            const id = entry.target.id;
            if (!id) return;
            const link = idToLink[id];
            if (!link) return;
            if (entry.isIntersecting) {
              Object.values(idToLink).forEach(l => l.classList.remove('active'));
              link.classList.add('active');
            }
          });
        }, observerOptions);

        observedIds.forEach(id => {
          const el = document.getElementById(id);
          if (el) observer.observe(el);
        });
      }
    }
  });
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const tocHeader = document.querySelector('.toc-accordion-header');
  const originalTocContent = document.querySelector('.right-sidebar .toc-content');

  console.log('TOC header present:', !!tocHeader, 'Original TOC content present:', !!originalTocContent, 'viewport:', window.innerWidth);

  if (!tocHeader) return; // nothing to do without header element
  // if no original content, still create an empty mobile list so header doesn't break layout
  const mobileList = document.getElementById('toc-mobile-list') || document.createElement('div');
  mobileList.className = 'toc-mobile-list';
  mobileList.id = 'toc-mobile-list';
  mobileList.innerHTML = originalTocContent ? originalTocContent.innerHTML : '<p style="margin:0;color:#666;font-size:14px;">No contents added</p>';
  if (!document.getElementById('toc-mobile-list')) tocHeader.insertAdjacentElement('afterend', mobileList);

  function setExpanded(expanded){
    tocHeader.setAttribute('aria-expanded', expanded ? 'true' : 'false');
    if (expanded) mobileList.classList.add('is-open'); else mobileList.classList.remove('is-open');
  }

  tocHeader.addEventListener('click', function() { setExpanded(tocHeader.getAttribute('aria-expanded') !== 'true'); });
  tocHeader.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); tocHeader.click(); }
    if (e.key === 'Escape') setExpanded(false);
  });

  // Smooth scroll & close after click
  mobileList.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', function(e){
      const href = this.getAttribute('href');
      if (href && href.startsWith('#')) {
        e.preventDefault();
        const target = document.querySelector(href);
        if (target) {
          const y = target.getBoundingClientRect().top + window.pageYOffset - 20;
          window.scrollTo({ top: y, behavior: 'smooth' });
        }
        setExpanded(false);
      }
    });
  });

  // Close on outside click (mobile)
  document.addEventListener('click', function(e){
    if (window.innerWidth > 1023) return;
    if (!tocHeader.contains(e.target) && !mobileList.contains(e.target)) setExpanded(false);
  });

  // Hide mobile accordion if user resizes to desktop
  window.addEventListener('resize', function(){
    if (window.innerWidth >= 1024) setExpanded(false);
  });
});
</script>


<script>
(function() {
  const progressBar = document.getElementById('scrollProgressBar');
  
  if (!progressBar) return;
  
  function updateProgressBar() {
    const windowHeight = window.innerHeight;
    const documentHeight = document.documentElement.scrollHeight;
    const scrollTop = window.scrollY || window.pageYOffset;
    
    const scrollableHeight = documentHeight - windowHeight;
    const scrollProgress = (scrollTop / scrollableHeight) * 100;
    
    const progress = Math.min(Math.max(scrollProgress, 0), 100);
    
    progressBar.style.width = progress + '%';
    progressBar.setAttribute('aria-valuenow', Math.round(progress));
  }
  
  // Update on scroll
  window.addEventListener('scroll', updateProgressBar, { passive: true });
  
  // Update on page load and resize
  window.addEventListener('load', updateProgressBar);
  window.addEventListener('resize', updateProgressBar);
  
  // Initial update
  updateProgressBar();
})();
</script>




