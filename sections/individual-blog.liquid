  z-index: 9999;
}

.blog-progress-bar {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, #a68380 0%, #8c6f6d 100%);
  transition: width 0.1s ease-out;
}
.testimonial-header {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .testimonial-name {
    margin: 0;
  }

  .linkedin-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
  }

  .linkedin-icon:hover {
