{%- style -%}
  /* Custom Table Styles - Modernized */
    .custom-table{
      border: 2px;
    }
  .lucira-blogs a {
      text-decoration: underline;
      text-underline-offset: 3px;
      color: #a78481;
      font-weight: 500;
  }
  .custom-table-section {
    margin-bottom: 40px; /* Keep existing spacing */
    border: 2px solid black;

  }

  .custom-table-section h2.section-heading {
    font-size: 24px;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 150%;
    font-weight: 600;
    font-family: 'Futura std', sans-serif;
    color: #1a1a1a; /* Darker heading color for emphasis */
  }

  /* Style the table container for better visual */
  .table-container table {
    width: 100%;
    border-collapse: collapse;
    border-spacing: 0;
    border: 2px solid black;
    border-radius: 8px;
    overflow: hidden;
    font-family: 'Futura std', sans-serif;
    font-size: 14px;
    background-color: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }

  /* Style table headers */
  .table-container th {
    background-color: #f9f9f9;
    font-weight: 600;
    text-transform: uppercase;
    padding: 14px 16px;
    border-bottom: 2px solid #ddd;
    color: #333;
    position: relative;
    border: 2px solid black;
    border-collapse: collapse;

  }

  /* Style table cells */
  .table-container td {
    padding: 14px 16px;
    border-bottom: 2px solid #eee;
    color: #555;
    transition: background-color 0.3s, color 0.3s;
      border: 2px solid black;
    border-collapse: collapse;

  }

  /* Add hover effect for rows */
  .table-container tbody tr:hover {
    background-color: #f5f5f5;
  }

  /* Remove right border from last cells for cleaner look */
  .table-container th:last-child,
  .table-container td:last-child {
    border-right: none;
  }

  /* Optional: Add stripe effect for even rows */
  .table-container tbody tr:nth-child(even) {
    background-color: #fafafa;
  }

  .article table, .article th, .article td {
    border: 0px solid black;
  }



    /* CSS specific to this section starts here */
    .lucira-blogs {
        /* Apply some base styles to the section container itself */
        font-family: 'Futura std', sans-serif; /* Ensure Futura Std is loaded */
        color: #1a1a1a; /* Text Color */
        line-height: 1.5; /* Default line height */
        background-color: #fff; /* Default background */
    }

    .blog-internal-container {
        width: 100%;
        max-width: 1200px; /* Initial max-width for mobile/smaller screens */
        margin: 0 auto; /* Center the container */
        background-color: #fff;
        overflow: hidden; /* Prevent content overflow */
        position: relative;
        display: flex; /* Use flexbox for layout */
        flex-direction: column; /* Stack main content and sidebar on mobile */
        gap: 40px; /* Gap between sections (or main/sidebar on desktop) */
        padding: 0 20px; /* Add some padding on the sides for mobile */
        box-sizing: border-box; /* Include padding in width */
    }

    .main-content {
        width: 100%; /* Full width on mobile and tablet */
        /* On desktop, this will be adjusted by flex properties */
    }

    /* --- Header Section (Based on Figma header - if uncommented, make selectors specific) --- */
    /* If you uncomment the header HTML, you'll need to make these selectors specific
       to prevent conflicts with your theme's main header.
       Example: .lucira-blogs .off-on-diamond-price-wrapper { ... }
    */
    .off-on-diamond-price-wrapper {
        background-color: #a68380; /* Primary Brand Color */
        width: 100%;
        padding: 12px 20px;
        box-sizing: border-box;
        text-align: center;
        color: #fff;
        font-size: 12px;
        letter-spacing: 0.04em; /* 4% */
        line-height: 150%;
        font-weight: 500; /* Medium */
        font-family: 'Futura std', sans-serif; /* Ensure Futura Std */
    }

    .header {
        justify-content: space-between;
        align-items: center;

        box-sizing: border-box;
        width: 100%;
    }

    .button {
        width: 48px;
        height: 48px;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer; /* Indicate interactivity */
    }

    .shape {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border-radius: 8px; /* Rounded corners */
        background-color: transparent; /* No background */
    }

    .menu-icon {
        width: 32px;
        height: 32px;
        display: block; /* Ensure image is block */
    }

    .group-icon {
        width: 92.9px; /* Specific width from Figma */
        max-height: 100%;
        display: block; /* Ensure image is block */
    }

    .button-parent,
    .button-group {
        display: flex;
        align-items: center;
        gap: 8px; /* Space between icons */
    }

    .icon {
        width: 24px;
        height: 24px;
        max-width: 100%;
        overflow: hidden;
        max-height: 100%;
        display: block; /* Ensure image is block */
    }
    /* --- End Header Section Styles --- */


    /* --- Main Content Blocks --- */
    .lucira-blogs .hero-image { /* Added section class prefix */
        width: 100%;
        height: 228px; /* Specific height from Figma (Mobile) */
        object-fit: cover; /* Cover the area without distortion */
        display: block;
        margin-bottom: 20px; /* Space below image */
        border-radius: 8px; /* Rounded corners */
    }

    .lucira-blogs .article-metadata { /* Added section class prefix */
        display: flex;
        justify-content: space-between;
        padding: 0; /* Padding handled by .blog-internal-container */
        font-size: 12px;
        color: #666; /* Grey color */
        text-transform: uppercase;
        width: 100%;
        box-sizing: border-box;
        margin-bottom: 20px; /* Space below metadata */
        font-family: 'Futura std', sans-serif; /* Ensure Futura Std */
    }

    .lucira-blogs .metadata-item { /* Added section class prefix */
        display: flex;
        flex-direction: column;
        gap: 4px; /* Space between label and value */
    }

    .lucira-blogs .metadata-label { /* Added section class prefix */
        font-weight: 400; /* Regular */
    }

    .lucira-blogs .metadata-value { /* Added section class prefix */
        font-size: 16px;
        font-weight: 500; /* Medium */
        color: #1a1a1a; /* Dark Grey */
    }

    .lucira-blogs .separator { /* Added section class prefix */
        height: 1px;
        background-color: #e6e6e6; /* Light Grey */
        width: 100%;
        margin: 20px 0; /* Margin above and below */
    }

    .lucira-blogs .table-of-content-section { /* Added section class prefix */
        padding: 0; /* Padding handled by .blog-internal-container */
        width: 100%;
        box-sizing: border-box;
        margin-bottom: 20px; /* Space below TOC */
    }

    .lucira-blogs .section-heading { /* Added section class prefix */
        font-size: 18px;
        letter-spacing: 0.04em; /* 4% */
        line-height: 150%;
        font-weight: 500; /* Medium */
        margin-bottom: 12px; /* Space below heading */
        text-transform: uppercase;
        font-family: 'Futura std', sans-serif; /* Ensure Futura Std */
    }

    .lucira-blogs .table-of-content-list { /* Added section class prefix */
        list-style: none; /* Remove default bullets */
        padding: 0;
        margin: 0;
        font-size: 14px;
        letter-spacing: 0.04em; /* 4% */
        line-height: 20px;
        font-family: 'Futura std', sans-serif; /* Ensure Futura Std */
    }

    .lucira-blogs .table-of-content-list li { /* Added section class prefix */
        margin-bottom: 8px; /* Space between list items */
        padding-left: 19px; /* Space for custom bullet */
        position: relative;
    }

    .lucira-blogs .table-of-content-list li::before { /* Added section class prefix */
        content: '\2022'; /* Unicode for a bullet point */
        position: absolute;
        left: 0;
        color: #1a1a1a; /* Bullet color */
        font-size: 16px; /* Adjust bullet size */
        line-height: 20px; /* Align bullet vertically */
    }

   /* Mobile-First Follow Us Section */
  .follow-us-section {
    display: flex;
    flex-direction: row; /* Stack vertically on mobile */

    padding: 15px 0;
    margin-bottom: 35px;
    border-top: 1px solid #e6e6e6;
    border-bottom: 1px solid #e6e6e6;
    width: 110%;
  }

  h3.sidebar-heading + h2 {display: none;}

  .follow-us-heading {
    font-family: 'Futura std', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    color: #1a1a1a;
    white-space: nowrap;
  }

  .social-icons-container {
    display: flex;
    flex-direction: row; /* Force horizontal layout */
    flex-wrap: wrap; /* Allow wrapping if needed */
    gap: 16px;
    align-items: center;
  }

  .social-icon {
    display: block;
    width: 24px;
    height: 24px;
    transition: transform 0.2s ease;
  }

  .social-icon img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  /* Tablet (768px) and above */
  @media (min-width: 768px) {
    .follow-us-section {
      flex-direction: row; /* Horizontal layout on larger screens */
      align-items: center;
      gap: 20px;
    }

    .social-icon {
      width: 20px;
      height: 20px;
    }
  }

  /* Desktop (1024px) and above */
  @media (min-width: 1024px) {
    .social-icon {
      width: 22px;
      height: 22px;
    }
  }


