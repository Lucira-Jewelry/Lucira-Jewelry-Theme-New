  {% endcomment %}

  <div class="blog-internal-container">
    <div class="main-content">
      <!-- Render Blocks (excluding CTA Banner) -->
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'hero_image' %}
            {% if block.settings.image != blank %}
              <img
                class="hero-image"
                alt="{{ block.settings.image.alt }}"
                src="{{ block.settings.image | img_url: '1200x' }}"
                loading="lazy"
              >
            {% endif %}
          {% when 'article_metadata' %}
            <div class="article-metadata">
              <div class="metadata-item">
                <div class="metadata-label">Publication Date</div>
                <div class="metadata-value">{{- article.published_at | time_tag: format: 'date' -}}</div>
              </div>
              <div class="metadata-item">
                <div class="metadata-label">Category</div>
                <div class="metadata-value">{{ article.tags }}</div>
              </div>
              <div class="metadata-item">
                <div class="metadata-label">Read Time</div>
                <div class="metadata-value">{{ article.metafields.custom.read_time.value | default: 'N/A' }} Mins</div>
                {# Assuming a metafield for read time #}
              </div>
              <div class="metadata-item">
                <div class="metadata-label">Views</div>
                <div class="metadata-value">{{ article.metafields.custom.views | default: 'N/A' }}</div>
                {# Assuming a metafield for views #}
              </div>
            </div>
            <div class="separator"></div>
          {% when 'table_of_content' %}
            <section class="table-of-content-section">
              <h2 class="section-heading">{{ block.settings.heading | escape }}</h2>
              {{ block.settings.items }}
            </section>

            <div class="separator"></div>

          {% when 'follow_us' %}
            <section class="follow-us-section">
              <div class="follow-us-heading">FOLLOW US ON:</div>
              <div class="social-icons-container">
                <a
                  href="https://www.facebook.com/people/Lucira-Jewelry/61576273734243/"
                  target="_blank"
                  class="social-icon"
                >
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/facebook_f6e5f46a-590c-4b08-aa17-2e18f56da0ce.svg?v=1750316612"
                    alt="Facebook"
                    width="20"
                    height="20"
                  >
                </a>
                <a href="https://in.pinterest.com/Lucira_Jewelry/" target="_blank" class="social-icon">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/pinterest_06b64e5f-2b9d-4e5f-a136-67a9e60e91ac.svg?v=1750316612"
                    alt="Pinterest"
                    width="20"
                    height="20"
                  >
                </a>
                <a href="https://www.instagram.com/lucirajewelry/" target="_blank" class="social-icon">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/instagram_02e880b0-664e-4f9e-8cbe-3c56298a4b3e.svg?v=1750316612"
                    alt="Instagram"
                    width="20"
                    height="20"
                  >
                </a>
                <a href="https://www.linkedin.com/company/lucira-jewelry" target="_blank" class="social-icon">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/linkedin.svg?v=1750316611"
                    alt="LinkedIn"
                    width="20"
                    height="20"
                  >
                </a>
              </div>
            </section>
          {% when 'rich_text' %}
            <div
              class="article-content-block"
              {% if block.settings.custom_id != blank %}
                id="{{ block.settings.custom_id | escape }}"
              {% endif %}
            >
              {{ block.settings.content }}
            </div>
          {% when 'image' %}
            {% if block.settings.image != blank %}
              <div class="article-image-block">
                <img
                  alt="{{ block.settings.image.alt }}"
                  src="{{ block.settings.image | img_url: '1000x' }}"
                  loading="lazy"
                >
              </div>
            {% endif %}
          {% when 'quote' %}
            <blockquote
              class="article-quote-block"
              {% if block.settings.custom_id != blank %}
                id="{{ block.settings.custom_id | escape }}"
              {% endif %}
            >
              {% if block.settings.quote_text != blank %}
                <h6 class="quote-text">“{{ block.settings.quote_text | escape }}”</h6>
              {% endif %}


              {% if block.settings.author != blank %}
                <footer class="quote-author">— {{ block.settings.author | escape }}</footer>
              {% endif %}
            </blockquote>
            <div class="separator"></div>

          {% when 'image_with_text' %}
            <div
              class="image-with-text-block{% if block.settings.reverse_layout %} reverse{% endif %}"
              {% if block.settings.custom_id != blank %}
                id="{{ block.settings.custom_id | escape }}"
              {% endif %}
            >
              <div class="image-container-blog">
                {% if block.settings.image != blank %}
                  {% assign size_option = block.settings.image_size_option %}
                  {% case size_option %}
                    {% when 'small' %}
                      {% assign img_size = '300x' %}
                      {% assign style_attr = 'width: auto; height: auto; max-width: 100%;' %}
                    {% when 'medium' %}
                      {% assign img_size = '600x' %}
                      {% assign style_attr = 'width: auto; height: auto; max-width: 100%;' %}
                    {% when 'large' %}
                      {% assign img_size = '900x' %}
                      {% assign style_attr = 'width: auto; height: auto; max-width: 100%;' %}
                    {% when 'adaptive' %}
                      {% assign img_size = 'master' %}
                      {% assign style_attr = 'width: auto; height: auto; max-width: 100%;' %}
                  {% endcase %}

                  <img
                    alt="{{ block.settings.image.alt }}"
                    src="{{ block.settings.image | img_url: img_size }}"
                    loading="lazy"
                    style="{{ style_attr }}"
                  >
                {% endif %}
              </div>
              <div class="text-container">
                {{ block.settings.text }}
              </div>
            </div>

          {% when 'table-1' %}
            {% assign table_settings = block.settings %}

            {%- assign cell_texts = '' | split: '' -%}

            {%- for row in (1..table_settings.rows) -%}
              {%- assign rowData = '' | split: '' -%}
              {%- for column in (1..table_settings.columns) -%}
                {%- assign cellTextId = 'cell_text_' | append: row | append: '_' | append: column -%}
                {%- assign cellText = block.settings[cellTextId] -%}
                {%- assign rowData = rowData | push: cellText -%}
              {%- endfor -%}
              {%- assign cell_texts = cell_texts | push: rowData -%}
            {%- endfor %}
            <div
              class="table-container"
              style="margin-top: {{ table_settings.margin_top }}; margin-bottom: {{ table_settings.margin_bottom }};"
            >
              <table class="custom-table" style="border:2px; border-collapse: collapse; width: 100%;">
                <tbody>
                  {% for row in (1..table_settings.rows) %}
                    <tr>
                      {% for column in (1..table_settings.columns) %}
                        {% assign cellTextId = 'cell_text_' | append: row | append: '_' | append: column %}
                        {% assign cellText = block.settings[cellTextId] %}
                        {% assign alignment = table_settings.pc_alignment %}
                        {% if block.is_mobile %}
                          {% assign alignment = table_settings.mobile_alignment %}
                        {% endif %}
                        {% assign cellBorderStyle = table_settings.cell_border_style %}
                        {% case cellBorderStyle %}
                          {% when 'all_borders' %}
                            {% assign cellBorderStyleValue = 'border: 1px solid #000000;' %}
                          {% when 'outer_borders' %}
                            {% if row == 1 %}
                              {% assign cellBorderStyleValue = 'border-top: 1px solid #000000;' %}
                            {% elsif row == table_settings.rows %}
                              {% assign cellBorderStyleValue = 'border-bottom: 1px solid #000000;' %}
                            {% else %}
                              {% assign cellBorderStyleValue = '' %}
                            {% endif %}
                            {% if column == 1 %}
                              {% assign cellBorderStyleValue = cellBorderStyleValue
                                | append: 'border-left: 1px solid #000000;'
                              %}
                            {% elsif column == table_settings.columns %}
                              {% assign cellBorderStyleValue = cellBorderStyleValue
                                | append: 'border-right: 1px solid #000000;'
                              %}
                            {% endif %}
                          {% when 'inner_borders' %}
                            {% if row != 1 and row != table_settings.rows %}
                              {% assign cellBorderStyleValue = 'border-top: 1px solid #000000; border-bottom: 1px solid #000000;' %}
                            {% else %}
                              {% assign cellBorderStyleValue = '' %}
                            {% endif %}
                            {% if column != 1 and column != table_settings.columns %}
                              {% assign cellBorderStyleValue = cellBorderStyleValue
                                | append: 'border-left: 1px solid #000000; border-right: 1px solid #000000;'
                              %}
                            {% endif %}
                            {% if table_settings.columns == 2 and column == 1 %}
                              {% assign cellBorderStyleValue = cellBorderStyleValue
                                | append: 'border-right: 1px solid #000000;'
                              %}
                            {% endif %}
                          {% else %}
                            {% assign cellBorderStyleValue = '' %}
                        {% endcase %}
                        <td
                          style="text-align: {{ alignment }}; padding: {{ table_settings.cell_padding }}; {{ cellBorderStyleValue }}"
                          data-label="{{ table_settings.headers[column] }}"
                        >
                          {{ cellText }}
                        </td>
                      {% endfor %}
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>

          {% when 'comparison_table' %}
            <section class="comparison-table-section">
              <h2 class="section-heading">{{ block.settings.heading | escape }}</h2>
              {% if block.settings.description != blank %}
                <div class="in-the-glittering">{{ block.settings.description | escape }}</div>
              {% endif %}
              <div class="comparison-table-container">
                <table class="comparison-table">
                  <thead>
                    <tr>
                      <th>
                        <span>{{ block.settings.header_col1_text | escape }}</span>
                        {% if block.settings.header_col1_small_text != blank %}
                          <span class="small-text">{{ block.settings.header_col1_small_text | escape }}</span>
                        {% endif %}
                      </th>
                      <th>
                        <span>{{ block.settings.header_col2_text | escape }}</span>
                        {% if block.settings.header_col2_small_text != blank %}
                          <span class="small-text">{{ block.settings.header_col2_small_text | escape }}</span>
                        {% endif %}
                      </th>
                      <th>
                        <span>{{ block.settings.header_col3_text | escape }}</span>
                        {% if block.settings.header_col3_small_text != blank %}
                          <span class="small-text">{{ block.settings.header_col3_small_text | escape }}</span>
                        {% endif %}
                      </th>
                      <th>
                        <span>{{ block.settings.header_col4_text | escape }}</span>
                        {% if block.settings.header_col4_small_text != blank %}
                          <span class="small-text">{{ block.settings.header_col4_small_text | escape }}</span>
                        {% endif %}
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    {% comment %}
                      The richtext input for table_rows must be valid HTML table rows (<tr>) within a tbody.
                      Example: <tbody><tr><td>Cell 1</td><td>Cell 2</td></tr><tr><td>Cell 3</td><td>Cell 4</td></tr></tbody>
                    {% endcomment %}
                    {% assign table_html = block.settings.table_rows.html %}
                    {% comment %} Split the HTML by </tr> to get individual row strings {% endcomment %}
                    {% assign rows = table_html | split: '</tr>' %}

                    {% for row in rows %}
                      {% comment %} Clean up each row string and check if it contains a <tr> tag {% endcomment %}
                      {% assign cleaned_row = row | strip %}
                      {% if cleaned_row contains '<tr>' %}
                        {% comment %} Extract the content within the <tr> tags {% endcomment %}
                        {% assign row_content = cleaned_row | remove: '<tr>' | strip %}

                        {% comment %} Split the row content by </td> to get individual cell strings {% endcomment %}
                        {% assign cells = row_content | split: '</td>' %}

                        {% if cells.size > 0 %}
                          <tr>
                            {% for cell in cells %}
                              {% comment %} Clean up each cell string and check if it contains a <td> tag {% endcomment %}
                              {% assign cleaned_cell = cell | strip %}
                              {% if cleaned_cell contains '<td>' %}
                                {% comment %} Extract the content within the <td> tags {% endcomment %}
                                {% assign cell_content = cleaned_cell | remove: '<td>' | strip %}

                                {% comment %} Assign header text based on column index for mobile data-label {% endcomment %}
                                {% assign header_text = '' %}
                                {% if forloop.index == 1 %}
                                  {% assign header_text = block.settings.header_col1_text %}
                                {% elsif forloop.index == 2 %}
                                  {% assign header_text = block.settings.header_col2_text %}
                                {% elsif forloop.index == 3 %}
                                  {% assign header_text = block.settings.header_col3_text %}
                                {% elsif forloop.index == 4 %}
                                  {% assign header_text = block.settings.header_col4_text %}
                                {% endif %}

                                <td data-label="{{ header_text | escape }}">{{ cell_content }}</td>
                              {% endif %}
                            {% endfor %}
                          </tr>
                        {% endif %}
                      {% endif %}
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </section>
            <div class="separator"></div>
          {% when 'related_articles' %}
            <section class="related-articles-section">
              <h2 class="section-heading">{{ block.settings.heading | escape }}</h2>
              <div class="blog-card-list">
                {% for article in blogs[block.settings.blog].articles limit: block.settings.article_limit %}
                  <div class="blog-card">
                    {% if article.image != blank %}
                      <a href="{{ article.url }}">
                        <img
                          class="blog-card-image"
                          alt="{{ article.image.alt }}"
                          src="{{ article.image | img_url: '400x' }}"
                          loading="lazy"
                        >
                      </a>
                    {% endif %}
                    {% if article.blog.title != blank %}
                      <div class="blog-card-category">{{ article.blog.title | escape }}</div>
                    {% endif %}
                    <div class="blog-card-title-wrapper">
                      <a href="{{ article.url }}" class="blog-card-title">{{ article.title | escape }}</a>
                      <img class="icon" alt="" src="{{ 'Frame 427321511.png' | asset_url }}">
                    </div>
                  </div>
                {% endfor %}
              </div>
            </section>
            <div class="separator"></div>
        {% endcase %}
      {% endfor %}
    </div>

    <!-- Right Sidebar -->
    <aside class="right-sidebar">
      <div class="sidebar-section product-card-section">
        <section class="table-of-content-section">
          <h3 class="sidebar-heading">Table of Content</h3>
          {{ section.settings.table_of_content_point }}
        </section>

        <h3 class="sidebar-heading">Shop Now</h3>
        <div class="product-card-list">
          {% for product in section.settings.featured_products %}
            <div class="product-card">
              <div class="product-image-container">
                {% if product.featured_image != blank %}
                  <a href="{{ product.url }}">
                    <img
                      class="product-image"
                      alt="{{ product.featured_image.alt }}"
                      title="{{ product.featured_image.alt }}"
                      src="{{ product.featured_image | img_url: '400x' }}"
                      loading="lazy"
                    >
                  </a>
                {% endif %}
              </div>
              <div class="product-info">
                <div class="product-title">{{ product.title | escape }}</div>
                <div class="product-price">{{ product.price | money }}</div>
                <a href="{{ product.url }}" class="view-product-button">view product</a>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </aside>
  </div>

  <!-- CTA Banner (Moved outside the container) -->
  {% for block in section.blocks %}
    {% if block.type == 'cta_banner' %}
      <section
        class="cta-banner"
        {% if block.settings.background_image != blank %}
          style="background-image: url('{{ block.settings.background_image | img_url: '1200x' }}');"
        {% endif %}
      >
        {% if block.settings.title != blank %}
          <div class="cta-title">{{ block.settings.title | escape }}</div>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="cta-description">{{ block.settings.description | newline_to_br }}</div>
        {% endif %}
        {% if block.settings.button_label != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="cta-button">{{ block.settings.button_label | escape }}</a>
        {% endif %}
      </section>
    {% endif %}
  {% endfor %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Category navigation dropdown (if you decide to include header)
    // const dropdownToggle = document.querySelector('.lucira-blogs__nav-toggle');
    // const dropdownContent = document.querySelector('.lucira-blogs__nav-content');

    // if (dropdownToggle && dropdownContent) {
