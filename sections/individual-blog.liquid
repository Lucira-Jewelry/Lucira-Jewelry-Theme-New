{%- endstyle -%}

<div class="lucira-blogs color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
   {% comment %} for progress bar {% endcomment %}
          {% comment %} {% if article and article.blog and article.blog.handle == 'stories' %}
            <div class="blog-progress-wrapper" aria-hidden="false">
              <div id="scrollProgressBar" class="blog-progress-bar" role="progressbar"
                  aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"></div>
            </div>
          {% endif %} {% endcomment %}
        {%- comment -%} Sticky reading progress bar — render only for articles in blog handle 'stories' {%- endcomment -%}
     <!-- Add this right after the opening <div class="lucira-blogs"> tag -->


<div class="blog-progress-wrapper" aria-hidden="true">
  <div id="scrollProgressBar" 
       class="blog-progress-bar" 
       role="progressbar"
       aria-valuemin="0" 
       aria-valuemax="100" 
       aria-valuenow="0">
  </div>
</div>


       <div class="toc-accordion-header" role="button" tabindex="0" aria-expanded="false" aria-controls="toc-mobile-list">
    <span class="toc-accordion-title">Table of Content</span>
    <span class="toc-accordion-icon" aria-hidden="true">+</span>
  </div> 

  <div class="blog-internal-container">
    <!-- Main Content (70% on desktop) -->
    <div class="main-content">
      <!-- Custom Background Banner Section (MOVED INSIDE MAIN CONTENT) -->
      {%- if section.settings.banner_image != blank or section.settings.mobile_banner_image != blank -%}
        <div 
          id="Banner-{{ section.id }}" 
          class="banner banner--{{ section.settings.image_height }}{% if section.settings.show_text_below %} banner--mobile-bottom{% endif %}{% if section.settings.show_text_box == false %} banner--desktop-transparent{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
          
          {% comment %} {%- if section.settings.banner_image != blank -%}
            <img class="banner__image banner__image--desktop" 
                 src="{{ section.settings.banner_image | img_url: '2000x' }}" 
                 alt="{{ section.settings.banner_image.alt | escape }}" 
                 loading="lazy">
          {%- endif -%} {% endcomment %}
          
          {%- if section.settings.mobile_banner_image != blank -%}
            <img class="banner__image banner__image--mobile" 
                 src="{{ section.settings.mobile_banner_image | img_url: '800x' }}" 
                 alt="{{ section.settings.mobile_banner_image.alt | escape }}" 
                 loading="lazy">
          {%- endif -%}
          
          {% comment %} {%- if section.settings.image_overlay_opacity > 0 -%}
            <div class="banner__overlay" style="opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};"></div>
          {%- endif -%}
          
          <div class="banner__content banner__content--{{ section.settings.desktop_content_position }} page-width">
            <div class="banner__box content-container content-container--full-width-mobile color-{{ section.settings.color_scheme }} gradient">
              
              {%- for block in section.blocks -%}
                {%- case block.type -%}
                  {%- when 'banner_heading' -%}
                    <h2 class="banner__heading inline-richtext {{ block.settings.heading_size }}">
                      {{ block.settings.heading }}
                    </h2>

                  {%- when 'banner_text' -%}
                    <div class="banner__text rte {{ block.settings.text_style }}">
                      <p>{{ block.settings.text }}</p>
                    </div>

                  {%- when 'banner_buttons' -%}
                    <div class="banner__buttons{% if block.settings.button_label_1 != blank and block.settings.button_label_2 != blank %} banner__buttons--multiple{% endif %}">
                      {%- if block.settings.button_label_1 != blank -%}
                        <a href="{{ block.settings.button_link_1 | default: '#' }}" class="button{% if block.settings.button_style_secondary_1 %} button--secondary{% else %} button--primary{% endif %}">
                          {{ block.settings.button_label_1 }}
                        </a>
                      {%- endif -%}
                      {%- if block.settings.button_label_2 != blank -%}
                        <a href="{{ block.settings.button_link_2 | default: '#' }}" class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %}">
                          {{ block.settings.button_label_2 }}
                        </a>
                      {%- endif -%}
                    </div>
                {%- endcase -%}
              {%- endfor -%}

            </div>
          </div> {% endcomment %}
        </div>
      {%- endif -%}

      <!-- Render All Other Blocks -->
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'banner_heading', 'banner_text', 'banner_buttons', 'testimonial_card' %}
            {% comment %} Skip these - banner blocks already rendered, testimonial in sidebar {% endcomment %}
          
          {% when 'hero_image' %}
            {% if block.settings.image != blank %}
              <img class="hero-image" alt="{{ block.settings.image.alt }}" title="{{ block.settings.image.alt }}" src="{{ block.settings.image | img_url: '1200x' }}" loading="lazy">
            {% endif %}
            
          {% when 'article_metadata' %}
            <div class="article-metadata">
              <div class="metadata-item">
                <div class="metadata-label">Publication Date</div>
                <div class="metadata-value">{{- article.published_at | time_tag: format: 'date' -}}</div>
              </div>
              <div class="metadata-item">
                <div class="metadata-label">Category</div>
                <div class="metadata-value">{{ article.tags }}</div>
              </div>
              <div class="metadata-item">
                <div class="metadata-label">Read Time</div>
                <div class="metadata-value">{{ article.metafields.custom.read_time.value | default: 'N/A' }} Mins</div>
              </div>
              <div class="metadata-item">
                <div class="metadata-label">Views</div>
                <div class="metadata-value">{{ article.metafields.custom.views | default: 'N/A' }}</div>
              </div>
            </div>
            <div class="separator"></div>
            
          {% when 'table_of_content' %}
            <section class="table-of-content-section">
              <h2 class="section-heading">{{ block.settings.heading | escape }}</h2>
              {{ block.settings.items }}
            </section>
            <div class="separator"></div>

          {% when 'article_metadata_auto' %}
            <div class="article-metadata-auto">
              {% if block.settings.title != blank %}
                <h1 class="article-title">{{ block.settings.title | escape }}</h1>
              {% endif %}
              
              <div class="article-meta-info">
                <div class="meta-item">
                  <span class="meta-label">Publication Date</span>
                  <span class="meta-value">{{ article.published_at | time_tag: format: 'date' }}</span>
                </div>
                
                <div class="meta-item">
                  <span class="meta-label">Category</span>
                  <span class="meta-value">
                    {% if article.tags.size > 0 %}
                      {{ article.tags | join: ', ' }}
                    {% else %}
                      Uncategorized
                    {% endif %}
                  </span>
                </div>
                
                {% if block.settings.show_reading_time %}
                  <div class="meta-item">
                    <span class="meta-label">Read Time</span>
                    <span class="meta-value">
                      {% assign words = article.content | strip_html | split: ' ' | size %}
                      {% assign reading_time = words | divided_by: 200 | at_least: 1 %}
                      {{ reading_time }} Min{% if reading_time != 1 %}s{% endif %}
                    </span>
                  </div>
                {% endif %}
                
                {% if block.settings.show_views %}
                  <div class="meta-item">
                    <span class="meta-label">Views</span>
                    <span class="meta-value">
                      {% if article.metafields.custom.views %}
                        {{ article.metafields.custom.views }}
                      {% else %}
                        N/A
                      {% endif %}
                    </span>
                  </div>
                {% endif %}
              </div>
            </div>
            <div class="separator"></div>

            {% when 'follow_us' %}
              <div class="section-header">
                {% if block.settings.header_title != blank %}
                  <h2 id="{{ block.settings.header_id | default: '' }}">
                    {{ block.settings.header_title }}
                  </h2>
                {% endif %}
              </div>

              <div class="social-links">
                <!-- Your social icon/link HTML goes here -->
              </div>

            
          {% comment %} {% when 'rich_text' %}
            <div class="article-content-block" {% if block.settings.custom_id != blank %} id="{{ block.settings.custom_id | escape }}"{% endif %}>
              {{ block.settings.content }}
            </div> {% endcomment %}
            {% when 'rich_text' %}
            <div class="article-content-block" 
                style="text-align: {{ block.settings.text_alignment | default: 'left' }};"
                {% if block.settings.custom_id != blank %} id="{{ block.settings.custom_id | escape }}"{% endif %}>
              {{ block.settings.content }}
            </div>
                      
          {% when 'image' %}
            {% if block.settings.image != blank %}
              <div class="article-image-block">
                <img alt="{{ block.settings.image.alt }}" title="{{ block.settings.image.alt }}" src="{{ block.settings.image | img_url: '1000x' }}" loading="lazy">
              </div>
            {% endif %}
            
          {% when 'quote' %}
            <blockquote class="article-quote-block" {% if block.settings.custom_id != blank %} id="{{ block.settings.custom_id | escape }}"{% endif %}>
              {% if block.settings.quote_text != blank %}
                <h6 class="quote-text">"{{ block.settings.quote_text | escape }}"</h6>
              {% endif %}
              {% if block.settings.author != blank %}
                <footer class="quote-author">— {{ block.settings.author | escape }}</footer>
              {% endif %}
            </blockquote>
            <div class="separator"></div>
            
        


        {% when 'image_with_text' %}
          {% assign layout_class = 'layout-row' %}
          {% if block.settings.layout_direction == 'row' %}
            {% if block.settings.reverse_layout %}
              {% assign layout_class = 'layout-row-reverse' %}
            {% else %}
              {% assign layout_class = 'layout-row' %}
            {% endif %}
          {% elsif block.settings.layout_direction == 'column' %}
            {% if block.settings.reverse_layout %}
              {% assign layout_class = 'layout-column-reverse' %}
            {% else %}
              {% assign layout_class = 'layout-column' %}
            {% endif %}
          {% endif %}

          <div class="image-with-text-block {{ layout_class }}" 
              {% if block.settings.custom_id != blank %} id="{{ block.settings.custom_id | escape }}"{% endif %}>
            <div class="image-container-blog">
              {% if block.settings.image != blank %}
                {% assign size_option = block.settings.image_size_option %}
