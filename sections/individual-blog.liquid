
{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
#Banner-{{ section.id }} {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  border-radius:8px;
  min-height: {% if section.settings.image_height == "adapt" and section.settings.image != blank %}
    {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}vw
  {% elsif section.settings.image_height == "small" %}
    300px
  {% elsif section.settings.image_height == "medium" %}
    500px
  {% elsif section.settings.image_height == "large" %}
    700px
  {% else %}
    500px
  {% endif %};
}


@media screen and (min-width: 750px) {
  #Banner-{{ section.id }} {
    background-image: url('{{ section.settings.banner_image | image_url: width: 2000 }}');
  }
    .banner__image.banner__image--mobile{
    display:none;
  }
}

@media screen and (max-width: 749px) {
  #Banner-{{ section.id }} {
    background-image: url('{{ section.settings.mobilebannerimage | image_url: width: 1000 }}');
    min-height: {% if section.settings.image_height == "adapt" and section.settings.mobilebannerimage != blank %}
      {{ 1 | divided_by: section.settings.mobilebannerimage.aspect_ratio | times: 100 }}vw
    {% else %}
      0px
    {% endif %};
  }
.banner__image.banner__image--desktop{
  display:none;
}

.banner__image.banner__image--mobile{
    width:100%;
    height:auto;
    border-radius:8px;
  }

}



.banner__image.banner__image--desktop{
  max-width:100%;
  height:auto;
  border-radius:8px;
}

#Banner-{{ section.id }}::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 
    {% if template.name == 'article' %}
      0
    {% else %}
      {{ section.settings.image_overlay_opacity | divided_by: 100.0 }}
    {% endif %}
  );
  pointer-events: none;
  opacity: 0.7;
}

#Banner-{{ section.id }} .banner__content {
  position: relative;
  z-index: 2;
  text-align: {{ section.settings.desktop_content_alignment }};
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem;
}

@media screen and (max-width: 749px) {
  #Banner-{{ section.id }} .banner__content {
    text-align: {{ section.settings.mobile_content_alignment }};
  }
}
{%- endstyle -%}



{%- style -%}
.lucira-blogs{--primary-color:#a68380;--text-dark:#1a1a1a;--text-light:#666;--border-color:#e6e6e6;--font-family:'Futura std',sans-serif}
.lucira-blogs{font-family:var(--font-family);color:var(--text-dark);line-height:2;background-color:#fff}
.lucira-blogs a{text-decoration:underline;text-underline-offset:3px;color:var(--primary-color);font-weight:400;line-height:24px}
.lucira-blogs .blog-internal-container{width:100%;max-width:1400px;margin:0 auto;background-color:#fff;overflow:visible;position:relative;display:flex;flex-direction:column;gap:40px;padding:0 20px;box-sizing:border-box}
.lucira-blogs .main-content{width:100%;box-sizing:border-box}
.lucira-blogs .hero-image{width:100%;height:228px;object-fit:cover;display:block;margin-bottom:20px;border-radius:8px}
.lucira-blogs .separator{height:1px;background-color:var(--border-color);width:100%;margin:20px 0}
.lucira-blogs .section-heading{font-size:18px;letter-spacing:.04em;line-height:150%;font-weight:500;margin-bottom:12px;text-transform:uppercase;font-family:var(--font-family)}
.lucira-blogs .article-metadata-auto{width:100%;margin-bottom:30px}
.lucira-blogs .article-title{font-family:var(--font-family);font-size:28px;font-weight:600;line-height:1.3;text-transform:uppercase;color:var(--text-dark);margin-bottom:20px;text-align:center;letter-spacing:.04em}
.lucira-blogs .article-meta-info{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:20px;padding:0;font-family:var(--font-family)}
.lucira-blogs .meta-item{display:flex;flex-direction:column;align-items:center;text-align:center;flex:1;min-width:120px}
.lucira-blogs .meta-label{font-size:12px;color:var(--text-light);text-transform:uppercase;letter-spacing:.04em;margin-bottom:4px;font-weight:400}
.lucira-blogs .meta-value{font-size:16px;font-weight:500;color:var(--text-dark);letter-spacing:.04em}
.lucira-blogs .article-metadata{display:flex;justify-content:space-between;padding:0;font-size:12px;color:var(--text-light);text-transform:uppercase;width:100%;box-sizing:border-box;margin-bottom:20px;font-family:var(--font-family)}
.lucira-blogs .metadata-item{display:flex;flex-direction:column;gap:4px}
.lucira-blogs .metadata-label{font-weight:400}
.lucira-blogs .metadata-value{font-size:16px;font-weight:500;color:var(--text-dark)}
.lucira-blogs .table-of-content-section{padding:0;width:100%;box-sizing:border-box;margin-bottom:20px}
.lucira-blogs .table-of-content-list{list-style:none;padding:0;margin:0;font-size:14px;letter-spacing:.04em;line-height:20px;font-family:var(--font-family)}
.lucira-blogs .table-of-content-list li{margin-bottom:8px;padding-left:19px;position:relative}
.lucira-blogs .table-of-content-list li::before{content:'\2022';position:absolute;left:0;color:var(--text-dark);font-size:16px;line-height:20px}
.lucira-blogs .follow-us-section{display:flex;flex-direction:row;padding:15px 0;margin-bottom:35px;border:1px solid var(--border-color);width:110%}
.lucira-blogs .follow-us-heading{font-family:var(--font-family);font-size:14px;font-weight:500;text-transform:uppercase;color:var(--text-dark);white-space:nowrap}
.lucira-blogs .social-icons-container{display:flex;flex-direction:row;flex-wrap:wrap;gap:16px;align-items:center}
.lucira-blogs .social-icon{display:block;width:24px;height:24px;transition:transform .2s ease}
.lucira-blogs .social-icon img{width:100%;height:100%;display:block;object-fit:contain}
.lucira-blogs .article-content-block{padding:0;font-size:16px;letter-spacing:.04em;line-height:1.5;width:100%;box-sizing:border-box;margin-bottom:20px;font-family:var(--font-family)}
.lucira-blogs .article-content-block:first-child{padding-top:20px}
.lucira-blogs .article-content-block h1,.lucira-blogs .article-content-block h2,.lucira-blogs .article-content-block h3,.lucira-blogs .article-content-block h4,.lucira-blogs .article-content-block h5,.lucira-blogs .article-content-block h6{font-size:20px;letter-spacing:normal;line-height:150%;text-transform:uppercase;font-weight:500;margin-top:30px;margin-bottom:12px;margin-left:0;margin-right:0;font-family:var(--font-family);color:var(--text-dark);line-height:1.4}
.lucira-blogs .article-content-block strong{font-weight:600}
.lucira-blogs .article-content-block h1{margin-top:28px!important}
.lucira-blogs .article-content-block p{margin-bottom:18px}
.lucira-blogs .article-content-block h6{font-size:23px!important;text-transform:none;letter-spacing:.7px}
.lucira-blogs h6.quote-text{font-size:23px!important;font-weight:600}
.lucira-blogs .article-content-block ol,.lucira-blogs .article-content-block ul{list-style:disc;padding-left:16px;margin-bottom:18px}
.lucira-blogs .article-content-block ol{list-style:decimal}
.lucira-blogs .article-content-block li{margin-bottom:8px}
.lucira-blogs .article-image-block{width:100%;padding:0;box-sizing:border-box;margin-bottom:20px}
.lucira-blogs .article-image-block img{display:block;max-width:100%;height:auto;border-radius:8px;margin:0 auto}
.lucira-blogs .image-with-text-block{display:flex;flex-direction:column;gap:20px;margin-bottom:20px}
.lucira-blogs .image-with-text-block .image-container{width:100%}
.lucira-blogs .image-with-text-block .image-container img{display:block;max-width:100%;height:auto;border-radius:8px}
.lucira-blogs .image-with-text-block .text-container{width:100%;font-size:16px;letter-spacing:.04em;line-height:1.5;font-family:var(--font-family)}
.lucira-blogs .image-with-text-block .text-container h3{font-size:18px;letter-spacing:.04em;line-height:150%;text-transform:uppercase;font-weight:500;margin-top:0;margin-bottom:10px;font-family:var(--font-family)}
.lucira-blogs .image-with-text-block .text-container p{margin-bottom:15px;margin-top:0}
.lucira-blogs .comparison-table-section{padding:0;width:100%;box-sizing:border-box;margin-bottom:20px}
.lucira-blogs .comparison-table-container{overflow-x:auto;-webkit-overflow-scrolling:touch;border:1px solid #999;border-radius:8px;margin-top:30px}
.lucira-blogs .comparison-table{width:100%;border-collapse:collapse;min-width:600px;border:none}
.lucira-blogs .comparison-table thead tr{border-bottom:1px solid #999}
.lucira-blogs .comparison-table td,.lucira-blogs .comparison-table th{border:none;border:1px solid #999;padding:8px;text-align:left;vertical-align:top;font-family:var(--font-family)}
.lucira-blogs .comparison-table td:last-child,.lucira-blogs .comparison-table th:last-child{border-right:none}
.lucira-blogs .comparison-table th{font-weight:700;text-transform:uppercase;font-size:12px;text-align:center;color:var(--text-dark);padding-top:12px;padding-bottom:12px}
.lucira-blogs .comparison-table td{font-size:12px;letter-spacing:.04em;line-height:16px;color:var(--text-dark);padding-top:10px;padding-bottom:10px;border-bottom:1px solid var(--border-color)}
.lucira-blogs .comparison-table tbody tr:last-child td{border-bottom:none}
.lucira-blogs .comparison-table th span{display:block}
.lucira-blogs .comparison-table th .small-text{font-size:8px;font-weight:400}
.lucira-blogs .related-articles-section{padding:0;width:100%;box-sizing:border-box;margin-top:20px;margin-bottom:20px}
.lucira-blogs .blog-card-list{display:flex;flex-wrap:wrap;gap:20px}
.lucira-blogs .blog-card{width:calc(50% - 10px);display:flex;flex-direction:column;gap:12px;text-decoration:none;color:inherit;font-family:var(--font-family)}
.lucira-blogs .blog-card-image{width:100%;height:218px;object-fit:cover;border-radius:8px;display:block}
.lucira-blogs .blog-card-category{font-size:8px;letter-spacing:.04em;line-height:12px;text-transform:uppercase;text-align:center;color:var(--text-light)}
.lucira-blogs .blog-card-title{font-size:12px;letter-spacing:.04em;line-height:14px;text-transform:uppercase;font-weight:500;flex:1;color:var(--text-dark)}
.lucira-blogs .blog-card-title-wrapper{display:flex;align-items:center;gap:16px}
.lucira-blogs .blog-card-title-wrapper .icon{width:16px;height:16px;flex-shrink:0}
.lucira-blogs .cta-banner{width:100vw;position:relative;left:50%;right:50%;margin-left:-50vw;margin-right:-50vw;padding:150px 20px;box-sizing:border-box;background-size:cover;background-repeat:no-repeat;background-position:top;text-align:center;color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:30px;margin-top:20px;margin-bottom:20px;font-family:var(--font-family)}
.lucira-blogs .cta-title{font-size:21px;letter-spacing:.04em;font-weight:500;line-height:1.4}
.lucira-blogs .cta-description{font-size:12px;letter-spacing:.04em;line-height:18px;color:#e5e5e5;white-space:pre-wrap}
.lucira-blogs .cta-button{display:inline-block;width:188px;border-radius:14px;border:1px solid #fff;box-sizing:border-box;height:36px;display:flex;align-items:center;justify-content:center;padding:9px 16px;text-decoration:none;color:#fff;text-transform:uppercase;font-weight:500;font-size:12px;cursor:pointer;transition:background-color .3s ease,color .3s ease}
