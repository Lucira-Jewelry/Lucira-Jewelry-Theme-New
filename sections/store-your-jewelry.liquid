<style>
.jewelry-storage-section{text-align:center;max-width:1180px!important}
.storage-heading{margin:0 0 8px 0;font-weight:500;font-size:32px;line-height:150%;letter-spacing:.04em;text-transform:uppercase;color:#1a1a1a;text-align:center}
.storage-subheading{font-weight:400;font-size:18px;line-height:24px;letter-spacing:.04em;margin:0 0 40px 0;color:#1a1a1a;text-align:center}
.storage-grid{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:30px}
.storage-grid .storage-item img{width:100%;height:auto;border-radius:6px}
.storage-title{font-weight:500;font-size:24px;line-height:150%;letter-spacing:.04em;text-transform:uppercase;margin:20px 0 0 0;color:#1a1a1a;text-align:left}
.storage-description{font-weight:400;font-size:18px;line-height:24px;letter-spacing:.04em;margin-top:6px;color:#1a1a1a;text-align:left}
.storage-grid.one-per-row{grid-template-columns:1fr;max-width:850px;margin:0 auto}
.storage-grid.one-per-row .storage-item{display:flex;gap:20px}
.storage-grid.one-per-row .title_desc_main{display:flex;flex-direction:column;width:70%}
.storage-grid.one-per-row .storage-title{margin-top:0}
.jewelry-storage-section { margin-top: {{ section.settings.margin_top_desktop}}px !important; margin-bottom: {{ section.settings.margin_bottom_desktop}}px !important; }
@media screen and (max-width: 768px) {
.jewelry-storage-section { margin-top: {{ section.settings.margin_top_mobile}}px !important; margin-bottom: {{ section.settings.margin_bottom_mobile}}px !important; }
.storage-heading{font-size:21px;margin-bottom:12px}
.storage-subheading{font-size:16px;line-height:24px}
.storage-title{font-size:18px;margin-top:12px}
.storage-description{font-size:12px;line-height:18px}
.storage-grid{grid-template-columns:1fr;gap:12px!important}
.storage-item{display:flex;gap:12px!important}
.storage-image{width:50%}
.title_desc_main{display:flex;flex-direction:column;width:50%}
}
</style>

{% assign grid_class = section.settings.grid_changer | default: false %}

<div
  class="jewelry-storage-section page-width {% if grid_class %}one-per-row{% endif %}"
  style="
    
  "
>
  <div class="jewelry-storage-content">
    {% if section.settings.heading != blank %}
      <h2 class="storage-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="storage-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="storage-grid {% if grid_class %}one-per-row{% endif %}">
      {% for block in section.blocks %}
        <div class="storage-item">
          {% if block.settings.image %}
            <div class="storage-image">
              <img src="{{ block.settings.image | image_url: width: 500 }}" title="{{ block.settings.title | escape }}"alt="{{ block.settings.title | escape }}" loading="lazy">
            </div>
          {% endif %}
          <div class="title_desc_main">
            <h3 class="storage-title">{{ block.settings.title }}</h3>
            <p class="storage-description">{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>


{% schema %}
{
  "name": "Store Your Jewelry",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to store your jewelry the right way"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Protect your jewelry from the climate, the tangles and the tarnish by storing them the right way."
    },
    {
      "type": "checkbox",
      "id": "grid_changer",
      "label": "Layout Change (Show 1 in each row)",
      "default": false
    },
    {
      "type": "range",
      "id": "margin_top_desktop",
      "label": "Margin Top (Desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "label": "Margin Bottom (Desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Margin Top (Mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Margin Bottom (Mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "tip",
      "name": "Storage Tip",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Divide and Rule"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Store each piece separately in a soft pouch or a lined Jewelry Box."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Your Jewelry"
    }
  ]
}
{% endschema %}