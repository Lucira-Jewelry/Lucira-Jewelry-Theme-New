<style>
.metal-role-section{text-align:center;padding:40px 0 40px 0}
.metal-role-section .text-content h2{font-size:24px;margin:0 0 40px}
.metal-role-section .text-content p{max-width:65%;margin:0 auto 80px;font-size:18px;line-height:24px;color:#333}
.metal-role-section .cta-box{background-size:cover;background-position:center;border-radius:10px;padding:50px 20px;color:#fff;max-width:65%;margin:0 auto}
.metal-role-section .cta-content h3{font-size:24px;font-weight:500;letter-spacing:1px;margin:0 0 20px 0;color:#fff}
.metal-role-section .cta-content p{margin:0 auto 36px;font-size:18px;line-height:1.6;width:80%}
.metal-role-section .cta-button{display:inline-block;background:#a37b74;color:#fff;padding:10px 30px;border-radius:12px;text-transform:uppercase;font-size:16px;letter-spacing:.5px;text-decoration:none;width:20%}
.metal-role-section .cta-button:hover{background:#8e6b65}
@media(max-width:768px){
.metal-role-section .text-content h2{font-size:18px;margin:0 0 8px;text-align:left;margin-left:15px}
.metal-role-section .text-content p{max-width:95%;margin:0 auto 40px;font-size:12px;line-height:17px;color:#333;text-align:left}
.metal-role-section{text-align:center;padding:20px 0 20px 0}
.metal-role-section .cta-box{max-width:95%}
.metal-role-section .cta-content h3{font-size:18px;margin-bottom:8px}
.metal-role-section .cta-content p{margin:0 auto 24px;font-size:12px;line-height:1.6;width:100%}
.metal-role-section .cta-box{padding:40px 20px}
.metal-role-section .cta-button{width:145px;font-size:14px;margin-top:14px}
}
</style>

<section class="metal-role-section">
  <div class="metal-role-container">
    <div class="text-content">
      {% if section.settings.main_heading != blank %}
        <h2>{{ section.settings.main_heading }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <p>{{ section.settings.description }}</p>
      {% endif %}
    </div>

    <div
      class="cta-box"
      style="background-image: url({{ section.settings.bg_image | image_url: width: 1600 }});"
    >
      <div class="cta-content">
        {% if section.settings.cta_heading != blank %}
          <h3>{{ section.settings.cta_heading }}</h3>
        {% endif %}
        {% if section.settings.cta_text != blank %}
          <p>{{ section.settings.cta_text }}</p>
        {% endif %}
        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}" class="cta-button">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Metal Role Section",
  "settings": [
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "ROLE OF PLATINUM & OTHER METALS"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit..."
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA Heading",
      "default": "FIND YOUR PERFECT GEMSTONE JEWELRY"
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit..."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "PRIMARY"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Metal Role Section"
    }
  ]
}
{% endschema %}
