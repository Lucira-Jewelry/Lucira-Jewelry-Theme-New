<section class="store-locator-section brad_{{ section.id }}">
  <div class="page-width">
    <h2 class="store-locator-heading">LOCATE OUR NEARBY STORE</h2>
    <div class="store-locator-box">
      <label for="store-locator-input" class="store-locator-label">ENTER YOUR PINCODE</label>
      <div class="store-locator-input-wrapper">
        <input
          id="store-locator-input"
          type="text"
          placeholder="Enter your Pincode"
          class="store-locator-input"
          maxlength="6"
          pattern="\d{6}"
          inputmode="numeric"
        >
        <button id="store-locator-btn" class="store-locator-btn" type="button">
          <span class="btn-text">Locate Me</span>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .brad_{{ section.id }} { margin-top: {{ section.settings.padding_top_desktop }}px; margin-bottom: {{ section.settings.padding_bottom_desktop }}px; padding-top: 40px; padding-bottom: 40px; }
  .store-locator-section{text-align:center;background-color:#f7f5f4}
  .store-locator-box{padding:40px;max-width:576px;margin:0 auto;border-radius:6px;background:#fff}
  .store-locator-heading{font-weight:500;font-size:24px;line-height:1.7;text-align:center;vertical-align:middle;text-transform:uppercase;margin:0;margin-bottom:35px}
  .store-locator-label{display:block;text-align:left;margin-bottom:12px;color:#666;font-family:Futura Std;font-weight:400;font-size:12px;line-height:12px}

  /* Wrapper: row on desktop, column on mobile */
  .store-locator-input-wrapper{display:flex;align-items:stretch;border:1px solid #ddd;border-radius:6px;overflow:hidden;height:50px;flex-direction:row;gap:12px;border:none;border-radius:unset}

  .store-locator-input{flex:1;padding:16px;border:1px solid #ddd;border-radius:8px;outline:0;font-family:Futura Std;font-weight:400;font-size:16px;line-height:150%;text-transform:capitalize}
  .store-locator-btn{background-color:#e6e6e6;border:1px solid #ddd;border-radius:8px;cursor:pointer;display:flex;align-items:center;gap:6px;transition:background .3s;padding:12px 16px;justify-content:center;font-family:Futura Std;font-weight:400;font-size:16px;line-height:150%;text-align:right;text-transform:capitalize;color:#1a1a1a;min-width:160px;letter-spacing:1px}
  .store-locator-btn:hover{background-color:#d4d4d4}
  .store-locator-btn .btn-text::before{content:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 18 18' fill='none'><path d='M1.5 9H3.75' stroke='%231A1A1A' stroke-width='1.125' stroke-linecap='round' stroke-linejoin='round'/><path d='M14.25 9H16.5' stroke='%231A1A1A' stroke-width='1.125' stroke-linecap='round' stroke-linejoin='round'/><path d='M9 1.5V3.75' stroke='%231A1A1A' stroke-width='1.125' stroke-linecap='round' stroke-linejoin='round'/><path d='M9 14.25V16.5' stroke='%231A1A1A' stroke-width='1.125' stroke-linecap='round' stroke-linejoin='round'/><path d='M9 14.25C11.8995 14.25 14.25 11.8995 14.25 9C14.25 6.10051 11.8995 3.75 9 3.75C6.10051 3.75 3.75 6.10051 3.75 9C3.75 11.8995 6.10051 14.25 9 14.25Z' stroke='%231A1A1A' stroke-width='1.125' stroke-linecap='round' stroke-linejoin='round'/><path d='M9 11.25C10.2426 11.25 11.25 10.2426 11.25 9C11.25 7.75736 10.2426 6.75 9 6.75C7.75736 6.75 6.75 7.75736 6.75 9C6.75 10.2426 7.75736 11.25 9 11.25Z' stroke='%231A1A1A' stroke-width='1.125' stroke-linecap='round' stroke-linejoin='round'/></svg>");display:inline-block;vertical-align:middle;margin-right:4px}
  .store-locator-btn.submit .btn-text::before{content:""}

  @media (max-width:768px){
    .store-locator-input-wrapper{flex-direction:column;height:auto;gap:12px}
    .store-locator-btn{min-width:unset;width:100%}
    .store-locator-label{font-size:11px;margin-bottom:9px;letter-spacing:1px}
    .store-locator-input{font-size:12px;letter-spacing:1px}
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const input = document.getElementById('store-locator-input');
    const button = document.getElementById('store-locator-btn');
    const text = button.querySelector('.btn-text');

    // ✅ Allow only numeric input
    input.addEventListener('keypress', function (e) {
      if (!/[0-9]/.test(e.key)) {
        e.preventDefault();
      }
    });

    // ✅ Strip non-numeric on paste
    input.addEventListener('paste', function (e) {
      e.preventDefault();
      const pasted = (e.clipboardData || window.clipboardData).getData('text');
      const numeric = pasted.replace(/\D/g, '').slice(0, 6);
      input.value = numeric;
      input.dispatchEvent(new Event('input'));
    });

    // Detect typing → change button to Submit
    input.addEventListener('input', () => {
      // Remove any non-numeric characters that sneak in
      input.value = input.value.replace(/\D/g, '');

      if (input.value.trim() !== '') {
        button.classList.add('submit');
        text.textContent = 'Submit';
      } else {
        button.classList.remove('submit');
        text.textContent = 'Locate Me';
      }
    });

    // Locate Me / Submit logic
    button.addEventListener('click', () => {
      // If it's in submit mode
      if (button.classList.contains('submit')) {
        const pincode = input.value.trim();
        if (pincode.length === 6) {
          const event = new CustomEvent('pincodeDetected', { detail: { pincode } });
          document.dispatchEvent(event);
          console.log('Submitted pincode:', pincode);
        } else {
          alert('Please enter a valid 6-digit pincode.');
        }
        return;
      }

      // Locate Me mode
      if (!navigator.geolocation) {
        alert('Geolocation is not supported by your browser.');
        return;
      }

      text.textContent = 'Locating...';

      navigator.geolocation.getCurrentPosition(success, error);

      function success(position) {
        const latitude = position.coords.latitude;
        const longitude = position.coords.longitude;

        const geocodeUrl = `https://nominatim.openstreetmap.org/reverse?lat=${latitude}&lon=${longitude}&format=json`;

        fetch(geocodeUrl, {
          headers: {
            'User-Agent': 'ShopifyStoreLocator/1.0',
          },
        })
          .then((response) => response.json())
          .then((data) => {
            console.log('Geocode response:', data);

            if (data && data.address && data.address.postcode) {
              const pincode = data.address.postcode.replace(/\D/g, '').slice(0, 6);
              input.value = pincode;
              input.dispatchEvent(new Event('input'));

              const event = new CustomEvent('pincodeDetected', { detail: { pincode } });
              document.dispatchEvent(event);
            } else {
              alert('Could not detect your pincode. Please enter manually.');
            }

            text.textContent = 'Locate Me';
          })
          .catch((err) => {
            console.error('Geocode fetch failed:', err);
            alert('Failed to fetch location data.');
            text.textContent = 'Locate Me';
          });
      }

      function error() {
        alert('Unable to retrieve your location.');
        text.textContent = 'Locate Me';
      }
    });
  });
</script>

