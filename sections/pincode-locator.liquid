<div class="store-locator-section page-width">
  <div class="locator-header">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
  </div>

  <div class="locator-controls">
    <div class="search-input-group">
      <input type="text" id="store-search-input" placeholder="Search City, Pincode...">
      <button id="store-search-btn" type="button">Search</button>
    </div>

    <div class="divider">OR</div>

    <button id="use-location-btn" type="button">Find Nearest Stores</button>

    <p id="geo-status"></p>
  </div>

  <div id="store-results" class="locator-results-grid"></div>
</div>

<style>
  .store-locator-section { padding: 40px 20px; max-width: 1200px; margin: 0 auto; padding-top:60px; }
  .locator-header { text-align: center; margin-bottom: 30px; }
  .locator-controls { display: flex; flex-direction: column; align-items: center; gap: 15px; margin-bottom: 40px; }
  .search-input-group { display: flex; width: 100%; max-width: 500px; border: 1px solid #b76f79; border-radius: 8px; overflow: hidden; }
  .search-input-group input { flex-grow: 1; padding: 12px 18px; border: 0; font-size: 14px; letter-spacing: 1px; font-family: 'Futura Std', sans-serif; }
  .search-input-group button { padding: 12px 20px; background: #000; color: #fff; border: none; cursor: pointer; }

  .divider { font-size: 12px; color: #111111; font-weight: 500; }
  #use-location-btn {display: flex; align-items: center; gap: 8px; padding: 14px 28px; background: white; border: 1px solid #b76f79; color: #b76f79; cursor: pointer; transition: all 0.2s; font-family: 'Futura Std', sans-serif; letter-spacing: 0.9px; text-transform: none; font-weight: 500; border-radius: 8px;}
  #use-location-btn:hover { background: #fff; }
  #geo-status { font-size: 12px; color: #666; margin: 0; min-height: 18px; }
  .locator-results-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 20px; }
  .store-card {padding: 0px; border-radius: 6px; background: #f9f9f9; position: relative; }
  .store-card h3 { margin: 0 0 8px 0; font-size: 18px; }
  .store-card p { margin: 8px 0;color: #555; display: flex; align-items: flex-start; gap: 12px; font-size: 12px; line-height: 1.8;}
  .store-card .distance-badge {position: absolute; top: 15px; right: 15px; background: #e8f5e9; color: #2e7d32; padding: 4px 16px; border-radius: 3rem; font-size: 12px; font-weight: 600; z-index: 1;}
  .store-card .city-tag { display: inline-block; background: #eee; padding: 2px 6px; font-size: 11px; margin-bottom: 8px; border-radius: 3px; }
  .locator-header h2 {margin-top: 0; margin-bottom: 8px;}
  .locator-header p { margin-top: 0; font-weight: 400; font-size: 14px; line-height: 24px; text-align: center; vertical-align: middle; max-width: 660px; margin: 0 auto 40px;}
  .search-input-group button {padding: 12px 34px; background: #b76f79; color: #fff; border: none; cursor: pointer; font-family: 'Futura Std', sans-serif; font-size: 12px; letter-spacing: 1px; text-transform: uppercase; border-radius: 8px;}
  .store-card{border:0;border-radius:12px;background:#fff;overflow:hidden}
  .store-image-wrapper{position:relative}
  .store-image-wrapper img{width:100%;height:220px;object-fit:cover;display:block}
  .city-pill{color:#1A1A1A;font-size:12px;padding:0;border-radius:20px;font-weight:500}
  .distance-badge{position:absolute;top:12px;right:12px;background:#e9f6ec;color:#1b7d3c;font-size:12px;padding:4px 10px;border-radius:20px;font-weight:600}
  .store-card-content{padding:8px 0px 10px}
  .store-card h3 {margin: 0 0 8px 0; font-weight: 500; line-height: 24px; vertical-align: middle; text-transform: uppercase; font-size: 18px; letter-spacing: 1px; color: #1a1a1a; margin-bottom: 16px; margin-top: 8px;}
  .store-address svg { width: 40px; }
  .store-pincode {display: none !important;}
  .store-phone svg { width: 20px !important; }
  .store-image-wrapper img { width: 100% !important; height: 280px; object-fit: cover; display: block; --r: 16px; --s: 28px; --x: 20px; --y: 17px; aspect-ratio: 1; background: #F2F2F2; border-radius: var(--r); --_m: /calc(2*var(--r)) calc(2*var(--r)) radial-gradient(#000 70%,#0000 72%); --_g: conic-gradient(from 90deg at calc(100% - var(--r)) calc(100% - var(--r)), #0000 25%, #000 0); --_d: (var(--s) + var(--r)); mask: calc(100% - var(--_d) - var(--x)) 100% var(--_m), 100% calc(100% - var(--_d) - var(--y)) var(--_m), radial-gradient(var(--s) at 100% 100%, #0000 99%, #000 calc(100% + 1px)) calc(-1 * var(--r) - var(--x)) calc(-1 * var(--r) - var(--y)), var(--_g) calc(-1 * var(--_d) - var(--x)) 0, var(--_g) 0 calc(-1 * var(--_d) - var(--y)); mask-repeat: no-repeat; }
  .store-time svg {width: 20px; height: 20px;}
  .store-phone-time {display: grid; grid-template-columns: 1fr 1fr;}
  .store-card .main-image { position: relative; }
  .store-card .arrow-parent {position: absolute; right: 0; bottom: 0;}
  .arrow-parent .store-arrow svg { display: block; border: 1px solid #1a1a1a; border-radius: 50%; width: 50px; height: 50px; }
  .store-card .arrow-parent { position: absolute; right: 4px; bottom: 4px; }
  .store-actions a {font-weight: 500; font-size: 12px; line-height: 100%; letter-spacing: 1px; text-transform: uppercase; border: 1px solid #b76f79; width: 100% !important; display: block; text-align: center; color: #b76f79; padding: 12px 12px; border-radius: 8px; display: flex; align-items: center; justify-content: center; gap: 8px;}
  .store-actions a img {height: 20px; width: 20px;}
  .store-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 10px; }
  .store-actions a:last-child {background: #b76f79; color: #fff;}
  @media (max-width: 400px) {
    .locator-results-grid { grid-template-columns: 1fr; }
    .store-card { width: 100%; }
    .store-actions a {font-size: 11px ;gap: 6px;}
    .store-actions a img { height: 16px; width: 16px; }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {

  function setCookie(name, value, days = 30) {
    var expires = "";
    if (days) {
      var date = new Date();
      date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
      expires = "; expires=" + date.toUTCString();
    }
    document.cookie = name + "=" + String(value) + "; path=/" + expires;
  }

  function getCookie(name) {
    var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
    return match ? match[2] : null;
  }

  var allStores = [
    {% for block in section.blocks %}
    {
      name: {{ block.settings.store_name | json }},
      city: {{ block.settings.city | json }},
      pincode: {{ block.settings.pincode | json }},
      address: {{ block.settings.address | json }},
      phone: {{ block.settings.phone | json }},
      designs_url: {{ block.settings.store_url | json }},
      appointment_url: {{ block.settings.appointment_url | json }},
      image: {% if block.settings.store_image != blank %}
        {{ block.settings.store_image | image_url: width: 800 | json }}
      {% else %}
        null
      {% endif %},
      lat: {{ block.settings.latitude | default: 0 }},
      lng: {{ block.settings.longitude | default: 0 }},
      distance: null
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];

  var userLocation = null;

  var input = document.getElementById('store-search-input');
  var searchBtn = document.getElementById('store-search-btn');
  var geoBtn = document.getElementById('use-location-btn');
  var container = document.getElementById('store-results');
  var statusMsg = document.getElementById('geo-status');

  function renderStores(list) {
    container.innerHTML = '';

    if (!list.length) {
      container.innerHTML = '<p>No stores found.</p>';
      return;
    }

    list.forEach(function (store) {

      var distanceBadge = store.distance != null
        ? `<span class="distance-badge">${store.distance.toFixed(1)} km away</span>`
        : '';

      var card = document.createElement('div');
      card.className = 'store-card';

      card.innerHTML = `
        <div class="store-image-wrapper">
          ${distanceBadge}
          
          ${store.image ? `
            <div class='main-image'>
              <img src="${store.image}" alt="${store.name}" loading="lazy">

              <div class="arrow-parent">
                <a href="${store.designs_url || '#'}" class="store-arrow">
                  <svg width="60" height="60" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="60" height="60" rx="30" fill="white" fill-opacity="0.25"/>
                    <path d="M18.6428 31.0986L18.6428 28.3572L37.4409 28.3572L29.0209 19.9372L30.9791 17.9791L42.7279 29.7279L30.9791 41.4768L29.0209 39.5186L37.4409 31.0986L18.6428 31.0986Z" fill="black"/>
                    <rect x="0.5" y="0.5" width="59" height="59" rx="29.5" stroke="black"/>
                  </svg>
                </a>
              </div>
            </div>
          ` : ''}
          
        </div>

        <div class="store-card-content">
          <span class="city-pill">${store.city}</span>
          <h3>${store.name}</h3>
          <p class="store-address">${store.address}</p>
        </div>
      `;

      container.appendChild(card);
    });
  }

  function applyFilters(query) {
    query = query.toLowerCase().trim();

    var list = allStores;

    if (query && !/^\d{4,6}$/.test(query)) {
      list = list.filter(function (store) {
        return (
          store.name + store.city + store.address
        ).toLowerCase().includes(query);
      });
    }

    if (userLocation) {
      list = list
        .map(function (store) {
          if (!store.lat || !store.lng) return null;
          store.distance = getDistance(
            userLocation.lat,
            userLocation.lng,
            parseFloat(store.lat),
            parseFloat(store.lng)
          );
          return store;
        })
        .filter(function (store) {
          return store && store.distance <= 25;
        })
        .sort(function (a, b) {
          return a.distance - b.distance;
        });
    }

    renderStores(list);
  }

  function savePincodeToServer(pincode) {
  try {
    function attemptSend(retry = 0) {
      let customerId = window.customerId;

      if (!customerId || customerId === 'null') {
        if (retry < 5) {
          setTimeout(() => attemptSend(retry + 1), 300);
          return;
        } else {
          return;
        }
      }

      customerId = String(customerId)
        .replace('gid://shopify/Customer/', '');

      fetch('https://api.lucirajewelry.com/customers/pincode.php', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          customer_id: String(customerId),
          pincode: String(pincode)
        })
      });
    }

    attemptSend();
  } catch (e) {}
}

  function handleSearch() {
    var query = input.value.trim();

    if (/^\d{4,6}$/.test(query)) {
      fetch(`https://nominatim.openstreetmap.org/search?postalcode=${query}&country=India&format=json`)
        .then(r => r.json())
        .then(d => {
          if (d[0]) {
            setCookie('user_pincode', String(query));
            savePincodeToServer(query);

            userLocation = {
              lat: parseFloat(d[0].lat),
              lng: parseFloat(d[0].lon)
            };

            statusMsg.innerText = 'Showing stores near ' + query;
            applyFilters('');
          }
        });
      return;
    }

    applyFilters(query);
  }

  function handleLocateMe() {
    if (!navigator.geolocation) return;

    statusMsg.innerText = 'Locating you...';

    navigator.geolocation.getCurrentPosition(function (pos) {
      userLocation = {
        lat: pos.coords.latitude,
        lng: pos.coords.longitude
      };

      fetch(`https://nominatim.openstreetmap.org/reverse?lat=${userLocation.lat}&lon=${userLocation.lng}&format=json`)
        .then(r => r.json())
        .then(d => {
          if (d?.address?.postcode) {

            var pin = d.address.postcode.replace(/\s+/g, '');
            setCookie('user_pincode', String(pin));
            savePincodeToServer(savedPin);
            input.value = pin;
            statusMsg.innerText = 'Detected Pincode: ' + pin;

          } else {
            statusMsg.innerText = 'Showing nearby stores';
          }

          applyFilters('');
        });
    });
  }

  function getDistance(lat1, lon1, lat2, lon2) {
    var R = 6371;
    var dLat = (lat2 - lat1) * Math.PI / 180;
    var dLon = (lon2 - lon1) * Math.PI / 180;
    var a =
      Math.sin(dLat / 2) ** 2 +
      Math.cos(lat1 * Math.PI / 180) *
      Math.cos(lat2 * Math.PI / 180) *
      Math.sin(dLon / 2) ** 2;
    return R * (2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a)));
  }

  renderStores(allStores);

  searchBtn.addEventListener('click', handleSearch);
  geoBtn.addEventListener('click', handleLocateMe);

  input.addEventListener('keyup', function (e) {
    if (e.key === 'Enter') handleSearch();
    if (!this.value) applyFilters('');
  });

  var savedPin = String(getCookie('user_pincode') || '');

  if (savedPin && /^\d{6}$/.test(savedPin)) {
    input.value = savedPin;
    setTimeout(function () {
      handleSearch();
    }, 300);
  }

});
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.getElementById('store-search-btn').addEventListener('click', function () {
      var query = document.getElementById('store-search-input').value.trim();
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'promoClick',
        promoClick: {
          creative_name: 'Store Nearby Page',
          promo_name: 'Find Us - Search',
          search_term: query || undefined,
        },
      });
    });

    document.getElementById('use-location-btn').addEventListener('click', function () {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'promoClick',
        promoClick: {
          creative_name: 'Store Nearby Page',
          promo_name: 'Find Nearest Stores',
        },
      });
    });

    document.getElementById('store-results').addEventListener('click', function (e) {
      var anchor = e.target.closest('a');
      if (!anchor) return;

      var card = anchor.closest('.store-card');
      var storeName = card ? (card.querySelector('h3') ? card.querySelector('h3').innerText.trim() : '') : '';

      var promoName;

      if (anchor.closest('.arrow-parent')) {
        promoName = 'View Store - ' + storeName;
      } else if (anchor.closest('.store-actions')) {
        var allActions = Array.from(anchor.closest('.store-actions').querySelectorAll('a'));
        var idx = allActions.indexOf(anchor);

        if (idx === 0) {
          promoName = 'Connect With Us - ' + storeName;
        } else if (idx === 1) {
          promoName = 'View All Designs - ' + storeName;
        } else {
          promoName = anchor.innerText.trim() + ' - ' + storeName;
        }
      } else {
        promoName = anchor.innerText.trim() + ' - ' + storeName;
      }

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'promoClick',
        promoClick: {
          creative_name: 'Store Nearby Page',
          promo_name: promoName,
        },
      });
    });
  });
</script>

{% schema %}
{
  "name": "Store Locator",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find a Store"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Search or use your location"
    }
  ],
  "blocks": [
    {
      "type": "store",
      "name": "Store",
      "settings": [
        { "type": "image_picker", "id": "store_image", "label": "Store Image" },
        { "type": "text", "id": "store_name", "label": "Store Name" },
        { "type": "text", "id": "city", "label": "City" },
        { "type": "text", "id": "pincode", "label": "Pincode" },
        { "type": "textarea", "id": "address", "label": "Address" },
        { "type": "text", "id": "phone", "label": "Phone" },
        { "type": "url", "id": "store_url", "label": "Store / Designs URL" },
        { "type": "url", "id": "appointment_url", "label": "Book Appointment URL" },
        { "type": "text", "id": "latitude", "label": "Latitude" },
        { "type": "text", "id": "longitude", "label": "Longitude" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Locator"
    }
  ]
}
{% endschema %}
