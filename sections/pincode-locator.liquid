{% comment %}
  Section: Store Locator (Advanced with Reverse Geocoding)
  Description: Auto-detects user pincode using OpenStreetMap API.
{% endcomment %}

<div class="store-locator-section page-width">
  <div class="locator-header">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
  </div>

  <div class="locator-controls">
    <div class="search-input-group">
      <input type="text" id="store-search-input" placeholder="Search City, Pincode...">
      <button id="store-search-btn" type="button">Search</button>
    </div>

    <div class="divider">OR</div>

    <button id="use-location-btn" type="button">
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle>
      </svg>
      Find Nearest Stores
    </button>
    <p id="geo-status"></p>
  </div>

  <div id="store-results" class="locator-results-grid"></div>
</div>

<style>
  /* Layout */
  .store-locator-section { padding: 40px 20px; max-width: 1200px; margin: 0 auto; }
  .locator-header { text-align: center; margin-bottom: 30px; }

  /* Controls */
  .locator-controls { display: flex; flex-direction: column; align-items: center; gap: 15px; margin-bottom: 40px; }
  .search-input-group { display: flex; width: 100%; max-width: 500px; border: 1px solid #b76f79; border-radius: 8px; overflow: hidden; }
  .search-input-group input { flex-grow: 1; padding: 12px 18px; border: 0; font-size: 14px; letter-spacing: 1px; font-family: 'Futura Std', sans-serif; }
  .search-input-group button { padding: 12px 20px; background: #000; color: #fff; border: none; cursor: pointer; }
  
  .divider { font-size: 12px; color: #111111; font-weight: 500; }
  #use-location-btn {display: flex; align-items: center; gap: 8px; padding: 14px 28px; background: white; border: 1px solid #b76f79; color: #b76f79; cursor: pointer; transition: all 0.2s; font-family: 'Futura Std', sans-serif; letter-spacing: 0.9px; text-transform: none; font-weight: 500; border-radius: 8px;}
  #use-location-btn:hover { background: #f0f0f0; }
  #geo-status { font-size: 12px; color: #666; margin: 0; min-height: 18px; }

  /* Results Grid */
  .locator-results-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 20px; }

  /* Store Card */
  .store-card { border: 1px solid #e5e5e5; padding: 20px; border-radius: 6px; background: #f9f9f9; position: relative; }
  .store-card h3 { margin: 0 0 8px 0; font-size: 18px; }
  .store-card p { margin: 4px 0; font-size: 14px; color: #555; }
  .store-card .distance-badge { position: absolute; top: 15px; right: 15px; background: #e8f5e9; color: #2e7d32; padding: 4px 8px; border-radius: 12px; font-size: 11px; font-weight: bold; }
  .store-card .city-tag { display: inline-block; background: #eee; padding: 2px 6px; font-size: 11px; margin-bottom: 8px; border-radius: 3px; }
  .locator-header h2 {margin-top: 0; margin-bottom: 8px;}
  .locator-header p { margin-top: 0; }
  .search-input-group button {padding: 12px 34px; background: #b76f79; color: #fff; border: none; cursor: pointer; font-family: 'Futura Std', sans-serif; font-size: 12px; letter-spacing: 1px; text-transform: uppercase; border-radius: 8px;}

</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {

    var allStores = [
      {% for block in section.blocks %}
        {
          name: {{ block.settings.store_name | json }},
          city: {{ block.settings.city | json }},
          pincode: {{ block.settings.pincode | json }},
          address: {{ block.settings.address | json }},
          phone: {{ block.settings.phone | json }},
          lat: {{ block.settings.latitude | default: 0 }},
          lng: {{ block.settings.longitude | default: 0 }},
          distance: null
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];

    var userLocation = null;

    var input = document.getElementById('store-search-input');
    var searchBtn = document.getElementById('store-search-btn');
    var geoBtn = document.getElementById('use-location-btn');
    var container = document.getElementById('store-results');
    var statusMsg = document.getElementById('geo-status');

    function renderStores(list) {
      container.innerHTML = '';
      if (!list.length) {
        container.innerHTML = '<p style="grid-column:1/-1;text-align:center;">No stores found.</p>';
        return;
      }
      list.forEach(function (store) {
        var card = document.createElement('div');
        card.className = 'store-card';
        var dist = store.distance != null
          ? `<span class="distance-badge">${store.distance.toFixed(1)} km away</span>`
          : '';
        card.innerHTML = `
          ${dist}
          <span class="city-tag">${store.city}</span>
          <h3>${store.name}</h3>
          <p>${store.address}</p>
          <p><strong>Pincode:</strong> ${store.pincode}</p>
          <p>Phone: ${store.phone}</p>
        `;
        container.appendChild(card);
      });
    }

    function applyFilters(query) {
      query = query.toLowerCase().trim();
      var isPincode = /^\d{4,6}$/.test(query);

      var list = allStores;

      if (!isPincode && query) {
        list = list.filter(function (store) {
          var text = (
            store.name + ' ' +
            store.city + ' ' +
            store.address
          ).toLowerCase();
          return text.includes(query);
        });
      }

      if (userLocation) {
        list = list
          .map(function (store) {
            if (!store.lat || !store.lng) return null;

            store.distance = getDistance(
              userLocation.lat,
              userLocation.lng,
              parseFloat(store.lat),
              parseFloat(store.lng)
            );

            return store;
          })
          .filter(function (store) {
            return store && store.distance <= 25;
          })
          .sort(function (a, b) {
            return a.distance - b.distance;
          });
      }

      renderStores(list);
    }


    function handleSearch() {
      var query = input.value.trim();

      if (/^\d{4,6}$/.test(query)) {
        fetch(`https://nominatim.openstreetmap.org/search?postalcode=${query}&country=India&format=json`)
          .then(r => r.json())
          .then(d => {
            if (d[0]) {
              userLocation = {
                lat: parseFloat(d[0].lat),
                lng: parseFloat(d[0].lon)
              };
              statusMsg.innerText = 'Showing stores near ' + query;
              applyFilters('');
            }
          });
        return;
      }

      applyFilters(query);
    }

    function handleLocateMe() {
      if (!navigator.geolocation) return;

      statusMsg.innerText = 'Locating you...';

      navigator.geolocation.getCurrentPosition(function (pos) {
        userLocation = {
          lat: pos.coords.latitude,
          lng: pos.coords.longitude
        };

        fetch(`https://nominatim.openstreetmap.org/reverse?lat=${userLocation.lat}&lon=${userLocation.lng}&format=json`)
          .then(r => r.json())
          .then(d => {
            if (d?.address?.postcode) {
              input.value = d.address.postcode;
              statusMsg.innerText = 'Detected Pincode: ' + d.address.postcode;
            } else {
              statusMsg.innerText = 'Showing nearby stores';
            }
            applyFilters('');
          });
      });
    }

    function getDistance(lat1, lon1, lat2, lon2) {
      var R = 6371;
      var dLat = (lat2 - lat1) * Math.PI / 180;
      var dLon = (lon2 - lon1) * Math.PI / 180;
      var a =
        Math.sin(dLat / 2) ** 2 +
        Math.cos(lat1 * Math.PI / 180) *
        Math.cos(lat2 * Math.PI / 180) *
        Math.sin(dLon / 2) ** 2;
      return R * (2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a)));
    }

    renderStores(allStores);

    searchBtn.addEventListener('click', handleSearch);
    geoBtn.addEventListener('click', handleLocateMe);

    input.addEventListener('keyup', function (e) {
      if (e.key === 'Enter') handleSearch();
      if (!this.value) applyFilters('');
    });

  });
</script>


{% schema %}
{
  "name": "Store Locator",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find a Store" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Search or use your location." }
  ],
  "blocks": [
    {
      "type": "store",
      "name": "Store Location",
      "settings": [
        { "type": "header", "content": "Store Details" },
        { "type": "text", "id": "store_name", "label": "Store Name", "default": "Lucira Bandra" },
        { "type": "text", "id": "city", "label": "City", "default": "Mumbai" },
        { "type": "text", "id": "pincode", "label": "Pincode", "default": "400050" },
        { "type": "textarea", "id": "address", "label": "Address" },
        { "type": "text", "id": "phone", "label": "Phone" },
        { "type": "header", "content": "Map Coordinates" },
        { "type": "text", "id": "latitude", "label": "Latitude" },
        { "type": "text", "id": "longitude", "label": "Longitude" }
      ]
    }
  ],
  "presets": [{ "name": "Store Locator" }]
}
{% endschema %}
