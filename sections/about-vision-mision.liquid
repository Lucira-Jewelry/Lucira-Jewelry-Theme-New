{% schema %}
{
  "name": "Vision & Mission",
  "settings": [
    {
      "type": "header",
      "content": "Vision Section"
    },
    {
      "type": "image_picker",
      "id": "vision_image",
      "label": "Vision Image"
    },
    {
      "type": "text",
      "id": "vision_image_alt",
      "label": "Vision Image Alt Text",
      "default": "Our Vision"
    },
    {
      "type": "text",
      "id": "vision_title",
      "label": "Vision Title",
      "default": "OUR VISION"
    },
    {
      "type": "textarea",
      "id": "vision_text",
      "label": "Vision Text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    },
    {
      "type": "header",
      "content": "Mission Section"
    },
    {
      "type": "image_picker",
      "id": "mission_image",
      "label": "Mission Image"
    },
    {
      "type": "text",
      "id": "mission_image_alt",
      "label": "Mission Image Alt Text",
      "default": "Our Mission"
    },
    {
      "type": "text",
      "id": "mission_title",
      "label": "Mission Title",
      "default": "OUR MISSION"
    },
    {
      "type": "textarea",
      "id": "mission_text",
      "label": "Mission Text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    }
  ],
  "presets": [
    {
      "name": "Vision & Mission"
    }
  ]
}
{% endschema %}

<!-- Vision & Mission Section -->
<section class="vision-mission-section">
  <div class="vision-mission-container">
    
    <!-- Vision Block -->
    <div class="vision-block">
      <div class="block-image">
        <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Lucira_aug_2564003_1.png?v=1758796025" 
             alt="{{ section.settings.vision_image_alt | default: 'Our Vision' }}" 
             title="our vision"
             loading="lazy">
      </div>
    <div class="text-card">
        <h3>{{ section.settings.vision_title | default: 'OUR VISION' }}</h3>
        <p>{{ section.settings.vision_text | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquossoper. Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquas inoper. Lorem ipsum dolor sit amet, consectetur.' }}</p>
      </div>  
    </div>

    <!-- Mission Block -->
    <div class="mission-block">
      <div class="text-card">
        <h3>{{ section.settings.mission_title | default: 'OUR MISSION' }}</h3>
        <p>{{ section.settings.mission_text | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquosoper. Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquas isoper. Lorem ipsum dolor sit amet, consectetur.' }}</p>
      </div>
      <div class="block-image">
        <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Lucira_aug_2564090.png?v=1758796097"
            title="Our Mission" 
             alt="{{ section.settings.mission_image_alt | default: 'Our Mission' }}" 
             loading="lazy">
      </div>
    </div>
    
  </div>
</section>

<style>
.vision-mission-section{padding:4rem 0;background-color:#fff}
.mission-block .block-image{margin-top:400px}
.vision-mission-container{max-width:1400px;margin:0 auto;padding:0 2rem;display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start}
.vision-block{display:flex;flex-direction:column;gap:2rem;position:relative}
.mission-block{display:flex;flex-direction:column-reverse;gap:2rem;margin-top:4rem;position:relative}
.block-image{position:relative;overflow:hidden;border-radius:0;box-shadow:none}
.block-image img{width:100%;height:auto;object-fit:contain;display:block;padding:0}
.text-card{background:#f5f5f5;padding:2.5rem;border-radius:0;position:relative}
.text-card h3{font-family:"Futura Std",sans-serif;font-weight:500;font-style:normal;font-size:32px;line-height:150%;letter-spacing:.04em;text-transform:uppercase;color:#000;margin-bottom:1.5rem; margin-top: 0;}
.text-card p{font-family:"Futura Std",sans-serif;font-weight:300;font-style:normal;font-size:16px;line-height:24px;letter-spacing:.04em;color:#666;margin:0}
.vision-block .block-image{margin-bottom:0}
.vision-block .text-card { position: absolute; right: -460px; top: 14%; z-index: 2; max-width: 605px; height: auto; background: #f2f2f2; padding: 60px 40px; border-radius: 0; }
.mission-block .text-card{position: absolute; left: -460px; bottom: -70px; transform: translateY(-50%); z-index: 2; max-width: 605px; height: auto; background: #f2f2f2; padding: 60px 40px; border-radius: 0;}
.mission-block .block-image{order:1}
@media (max-width:1024px){
.vision-mission-container{gap:2rem}
.mission-block{margin-top:2rem}
.mission-block .text-card,.vision-block .text-card{margin-left:1rem;margin-right:1rem}
}
@media (max-width:768px){
.vision-mission-container{grid-template-columns:1fr;gap:4rem;padding:0 1rem}
.mission-block,.vision-block{position:relative;margin-top:0}
.vision-block{gap:0rem!important}
.mission-block .block-image,.vision-block .block-image{max-width:100%;height:auto;border-radius:0;margin-bottom:0;transform:none}
.block-image img{max-width:100%;height:auto;object-fit:contain;padding:0}
.text-card h3{font-size:24px;margin-bottom:1rem;color:#000; margin-top: 0px;}
.text-card p{font-size:14px;line-height:1.6;color:#666}
.vision-mission-section{padding:2rem 0}
.mission-block .text-card .block-image{bottom:200px}
.mission-block .text-card{margin: 0 auto !important; padding: 25px; position: absolute  !important; bottom: -80px; width: 94%; top: inherit; left: 50% !important; transform: translate(-50%);z-index: 1;}
.vision-block .text-card{margin: 0 auto !important; padding: 25px; position: absolute  !important; bottom: -80px; width: 94%; top: inherit; left: 50% !important; transform: translate(-50%);z-index: 1;}
.vision-block, .mission-block { margin-bottom: 72px; }
.mission-block .text-card, .vision-block .text-card {height: auto;}
}
@media (max-width:480px){
.mission-block .block-image{bottom:0;margin:0}
.mission-block .text-card,.vision-block .text-card{margin:-60px 15px 0 15px;padding:25px;position:relative}
.text-card h3{font-size:20px}
.text-card p{font-size:14px}
}
</style>