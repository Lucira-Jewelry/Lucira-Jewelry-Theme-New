      "id": "vision_image",
      "label": "Vision Image"
    },
    {
      "type": "text",
      "id": "vision_image_alt",
      "label": "Vision Image Alt Text",
      "default": "Our Vision"
    },
    {
      "type": "text",
      "id": "vision_title",
      "label": "Vision Title",
      "default": "OUR VISION"
    },
    {
      "type": "textarea",
      "id": "vision_text",
      "label": "Vision Text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    },
    {
      "type": "header",
      "content": "Mission Section"
    },
    {
      "type": "image_picker",
      "id": "mission_image",
      "label": "Mission Image"
    },
    {
      "type": "text",
      "id": "mission_image_alt",
      "label": "Mission Image Alt Text",
      "default": "Our Mission"
    },
    {
      "type": "text",
      "id": "mission_title",
      "label": "Mission Title",
      "default": "OUR MISSION"
    },
    {
      "type": "textarea",
