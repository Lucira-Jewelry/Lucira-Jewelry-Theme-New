    }
  ],
  "presets": [
    {
      "name": "Vision & Mission"
    }
  ]
}
{% endschema %}


<!-- Vision & Mission Section -->
<section class="vision-mission-section">
  <div class="vision-mission-container">
    
    <!-- Vision Block -->
    <div class="vision-block">
      <div class="block-image">
        <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Lucira_aug_2564003_1.png?v=1758796025" 
             alt="{{ section.settings.vision_image_alt | default: 'Our Vision' }}" 
             loading="lazy">
      </div>
      <div class="text-card">
        <h3>{{ section.settings.vision_title | default: 'OUR VISION' }}</h3>
        <p>{{ section.settings.vision_text | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquossoper. Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquas inoper. Lorem ipsum dolor sit amet, consectetur.' }}</p>
      </div>
    </div>

    <!-- Mission Block -->
    <div class="mission-block">
      <div class="text-card">
        <h3>{{ section.settings.mission_title | default: 'OUR MISSION' }}</h3>
        <p>{{ section.settings.mission_text | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquosoper. Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquas isoper. Lorem ipsum dolor sit amet, consectetur.' }}</p>
      </div>
      <div class="block-image">
        <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Lucira_aug_2564090.png?v=1758796097" 
             alt="{{ section.settings.mission_image_alt | default: 'Our Mission' }}" 
             loading="lazy">
      </div>
    </div>
    
  </div>
</section>

<style>

.vision-mission-section {
  padding: 4rem 0;
  background-color:rgb(255, 255, 255);
}

.vision-mission-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 2rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: start;
}

.vision-block {
  {% comment %} display: flex; {% endcomment %}
  flex-direction: column;
  gap: 2rem;
}

.mission-block {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  margin-top: 4rem; /* Offset to create asymmetrical layout */
}

.block-image {
  position: relative;
  overflow: hidden;
  border-radius: 12px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
}

.block-image img {
  width: 100%;
  height: auto;
  object-fit: cover;
  display: block;
  padding:60px;
}

.text-card {
  background: white;
  padding: 2.5rem;
  border-radius: 12px;
  {% comment %} box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08); {% endcomment %}
  position: relative;
}

.text-card h3 {
  {% comment %} font-size: 1.5rem;
  font-weight: 700;
  color: #2d3748;
  margin-bottom: 1.5rem;
  letter-spacing: 0.5px; {% endcomment %}
  font-family: "Futura Std", sans-serif; /* font family */
  font-weight: 500;                       /* Medium weight */
  font-style: normal;                      /* use normal; 'Medium' is not valid in CSS */
  font-size: 32px;                         /* font size */
  line-height: 150%;                       /* line height as percentage */
  letter-spacing: 0.04em;                  /* 4% letter spacing */
  vertical-align: middle;                  /* aligns inline content vertically */
  text-transform: uppercase;               /* uppercase letters */
  color: #2d3748;                          /* text color */
  margin-bottom: 1.5rem;    
}

.text-card p {
  color: #4a5568;
  line-height: 1.7;
  font-size: 1rem;
  margin: 0;
   font-family: "Futura Std", sans-serif;  /* font family */
  font-weight: 300;                        /* light weight */
  font-style: normal;                      /* use 'normal' for light style */
  font-size: 20px;                         /* text size */
  line-height: 28px;                       /* line height */
  letter-spacing: 0.04em;                  /* 4% letter spacing */
  vertical-align: middle;
  leading-trim: none;                       /* note: not standard CSS, may need Figma plugin only */
  margin: 0;
  color: #4a5568;      
}

/* Vision specific styling */
.vision-block .block-image {
  margin-bottom: 1rem;
}
{% comment %} .vision-block .text-card {
  margin-left: 2rem;
  transform: translateY(-2rem);
  z-index : 2;
  right:-20px;
  position: relative;
  transform: translateX(+20rem);
  height: 200px;
}  {% endcomment %}

.vision-block .text-card {
  position: relative;       /* keep relative for original transform */
  margin-left: 12rem;
  right: -20px;
  transform: translateX(20rem) translateY(-2rem); /* same as before */
  z-index: 2;
  height: 300px;            /* preserve height */
  max-width: 500px;         /* optional max width */
  background: white;
  padding: 5rem;
  border-radius: 0px;
  {% comment %} box-shadow: 0 8px 32px rgba(0,0,0,0.08); {% endcomment %}
  font-size: 1rem;          /* keep same font size */
  line-height: 1.7;
  color:rgb(228, 222, 222);
}

/* Mission specific styling */
{% comment %} .mission-block .text-card {
  order: -1; /* Place text above image */
  margin-right: 2rem;
  margin-bottom: 1rem;
  transform: translateX(-20rem);
  height: 200px;
} {% endcomment %}

.mission-block .text-card {
  order: -1;               /* place text above image */
  margin-right: 12rem;
  margin-bottom: 1rem;
  transform: translateX(-20rem); /* overlap horizontally */
  height: 300px;           /* fixed height */
  max-width: 500px;        /* optional max width */
  position: relative;       /* maintain stacking context */
  z-index: 2;              /* appear above image */
  background: white;
  padding: 5rem;
  border-radius: 0px;
  {% comment %} box-shadow: 0 8px 32px rgba(0,0,0,0.08); {% endcomment %}
  font-size: 1rem;         /* match font size */
  line-height: 1.7;
  color:rgb(228, 222, 222);
}

.vision-block {
  position: relative;
  
}


.mission-block .block-image {
  transform: translateX(-1rem);
}

/* Responsive Design */
@media (max-width: 1024px) {
  .vision-mission-container {
    gap: 2rem;
  }
  
  .mission-block {
    margin-top: 2rem;
  }
  
  .vision-block .text-card,
  .mission-block .text-card {
    margin-left: 1rem;
    margin-right: 1rem;
  }
}

@media (max-width: 768px) {
  .vision-mission-container {
    grid-template-columns: 1fr;
    gap: 3rem;
    padding: 0 1rem;
  }
  
  .mission-block {
    margin-top: 0;
    
  }
  
  .vision-block .text-card {
    margin-left: 0;
    transform: none;
      margin-bottom: 40px; /* space below the card before next content */
  padding: 2rem; 
  }
  
  .mission-block .text-card {
    margin-right: 0;
    order: 1; /* Reset order on mobile */
      margin-bottom: 40px; /* space below the card before next content */
  padding: 2rem; 
  }
  
  .mission-block .block-image {
    transform: none;
  }
  
  .block-image img {
    height: 300px;
    padding: 60px;
    padding-bottom: 80px;
  }
  
  .text-card {
    padding: 2rem;
  }
  
  .vision-mission-section {
    padding: 2rem 0;
  }
}

</style> {% endcomment %}


