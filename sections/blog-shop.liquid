<style>
  .hero-banner-{{ section.id }} {
    position: relative;
    padding: 60px 0;
    overflow: hidden;
  }

  .hero-banner-{{ section.id }} .background-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .hero-banner-{{ section.id }} .hero-content {
    position: relative;
    z-index: 2;

    margin: 0 auto;

    text-align: center;
    min-height: 450px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-banner-{{ section.id }} .hero-heading {
    font-size: 35px;
    color: #ffffff;
    font-weight: 400;
    margin: 0 0 20px 0;
    line-height: 1.2;
  }

  .hero-banner-{{ section.id }} .hero-subheading {
    font-size: 20px;
    color: #ffffff;
    font-weight: 400;
    margin: 0 0 30px 0;
    line-height: 1.6;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-banner-{{ section.id }} .hero-button {
    display: inline-block;
    padding: 15px 40px;
    font-size: 14px;
    font-weight: 600;
    color: #ffffff;
    background: rgba(255,255,255,0);
    border: 1px solid #ffffff;
    border-radius: 0;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .hero-banner-{{ section.id }} .hero-button:hover {
    color: #000000;
    background: #ffffff;
    border-color: #ffffff;
    transform: translateY(-2px);
  }

  /* Hide desktop image on mobile */
  .hero-banner-{{ section.id }} .background-image-desktop {
    display: block;
    padding-top: 60px;
    padding-bottom: 60px;
    border-radius:12px;
  }

  .hero-banner-{{ section.id }} .background-image-mobile {
    display: none;
    border-radius:12px;
  }

  @media (max-width: 768px) {
    .hero-banner-{{ section.id }} {
      padding: 40px 0;
    }

    .hero-banner-{{ section.id }} .background-image-desktop {
      display: none;
    }

    .hero-banner-{{ section.id }} .background-image-mobile {
      display: block;
      border-radius:12px;
    }

    .hero-banner-{{ section.id }} .hero-content {
      min-height: 450px;
    }

    .hero-banner-{{ section.id }} .hero-heading {
      font-size: 32px;
    }

    .hero-banner-{{ section.id }} .hero-subheading {
      font-size: 14px;
    }

    .hero-banner-{{ section.id }} .hero-button {
      font-size: 12px;
      padding: 12px 30px;
    }
  }
</style>

<div class="page-width hero-banner-{{ section.id }}">
  
  {% if section.settings.background_image_desktop %}
    <img 
      class="background-image background-image-desktop"
      src="{{ section.settings.background_image_desktop | image_url: width: 1920 }}"
      alt="{{ section.settings.background_image_desktop.alt | escape }}"
      loading="lazy"
    >
  {% else %}
    <img 
      class="background-image background-image-desktop"
      src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Req_from_Sanghani_20_black.png?v=1768481813"
      alt="Default hero banner image desktop"
      loading="lazy"
    >
  {% endif %}

  {% if section.settings.background_image_mobile %}
    <img 
      class="background-image background-image-mobile"
      src="{{ section.settings.background_image_mobile | image_url: width: 350 }}"
      alt="{{ section.settings.background_image_mobile.alt | escape }}"
      loading="lazy"
    >
  {% else %}
    <img 
      class="background-image background-image-mobile"
      src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Req_from_Sanghani_Mobile.png?v=1768483855"
      alt="Default hero banner image mobile"
      loading="lazy"
    >
  {% endif %}

  <div class="hero-content">
    <div>
      <h1 class="hero-heading">Shop Your First Lab Grown Diamond</h1>
      <p class="hero-subheading">Get pieces that speak to you.</p>
      <a href="{{ section.settings.button_link }}" class="hero-button"{% if section.settings.button_link == blank %}onclick="return false;"{% endif %}>{{ section.settings.button_text }}</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image_desktop",
      "label": "Background image - Desktop (1920x600px)"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image - Mobile (350x450px)"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Banner"
    }
  ]
}
{% endschema %}