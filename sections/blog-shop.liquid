{% comment %} 
<style>
  .hero-banner-{{ section.id }} {
    position: relative;
    padding: 60px 0;
    overflow: hidden;
      margin: 45px;
    border-radius: 30px;
    min-height:500px;
  }

  .hero-banner-{{ section.id }} .background-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .hero-banner-{{ section.id }} .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: center;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-banner-{{ section.id }} .hero-heading {
    font-size: 48px;
    color: #ffffff;
    font-weight: 400;
    margin: 0 0 20px 0;
    line-height: 1.2;
  }

  .hero-banner-{{ section.id }} .hero-subheading {
    font-size: 16px;
    color: #ffffff;
    font-weight: 400;
    margin: 0 0 30px 0;
    line-height: 1.6;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-banner-{{ section.id }} .hero-button {
    display: inline-block;
    padding: 15px 40px;
    font-size: 14px;
    font-weight: 600;
    color: #ffffff;
    background: rgba(255,255,255,0);
    border: 1px solid #ffffff;
    border-radius: 0;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .hero-banner-{{ section.id }} .hero-button:hover {
    color: #000000;
    background: #ffffff;
    border-color: #ffffff;
    transform: translateY(-2px);
  }

  /* Hide desktop image on mobile */
  .hero-banner-{{ section.id }} .background-image-desktop {
    display: block;
  }

  .hero-banner-{{ section.id }} .background-image-mobile {
    display: none;
  }

  @media (max-width: 768px) {
    .hero-banner-{{ section.id }} {
      padding: 40px 0;
      margin: 20px;
      border-radius: 20px;
    }

    .hero-banner-{{ section.id }} .background-image-desktop {
      display: none;
    }

    .hero-banner-{{ section.id }} .background-image-mobile {
      display: block;
    }

    .hero-banner-{{ section.id }} .hero-content {
      min-height: 450px;
    }

    .hero-banner-{{ section.id }} .hero-heading {
      font-size: 32px;
    }

    .hero-banner-{{ section.id }} .hero-subheading {
      font-size: 14px;
    }

    .hero-banner-{{ section.id }} .hero-button {
      font-size: 12px;
      padding: 12px 30px;
    }
  }
</style>

<div class="hero-banner-{{ section.id }}">
  {% if section.settings.background_image_desktop %}
    <img 
      class="background-image background-image-desktop"
      src="{{ section.settings.background_image_desktop | image_url: width: 1920 }}"
      alt="{{ section.settings.background_image_desktop.alt | escape }}"
      loading="lazy"
    >
  {% else %}
    <img 
      class="background-image background-image-desktop"
      src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Req_from_Sanghani_20_black.png?v=1768481813"
