{% comment %}
  Match & Shine: Picks one product per category.
  New Logic: If no product matches 20% price band, use a fallback product.
{% endcomment %}

{% assign gender_labels = product.metafields.shopify['target-gender'].value | map: 'label' %}
{% assign collection_handles_exclude = product.collections | map: 'handle' %}

{% unless gender_labels contains 'Male' or collection_handles_exclude contains 'nose-pins' %}
  {% assign current_variant_price = product.selected_or_first_available_variant.price | divided_by: 100.0 %}
  {% assign price_factor = section.settings.price_range | default: 20 %}

  {% assign range_value = current_variant_price | times: price_factor | divided_by: 100 %}
  {% assign lower_limit = current_variant_price | minus: range_value %}
  {% assign upper_limit = current_variant_price | plus: range_value %}

  {% assign max_products = section.settings.product_limit | default: 8 %}

  {% if product.tags contains 'Rings' %}
    {% assign categories = 'all-necklaces,all-earrings,all-bracelets' | split: ',' %}
  {% elsif product.tags contains 'Necklaces' %}
    {% assign categories = 'all-rings,all-earrings,all-bracelets' | split: ',' %}
  {% elsif product.tags contains 'Bracelets' %}
    {% assign categories = 'all-rings,all-earrings,all-necklaces' | split: ',' %}
  {% elsif product.tags contains 'Earrings' %}
    {% assign categories = 'all-rings,all-necklaces,all-bracelets' | split: ',' %}
  {% else %}
    {% assign categories = 'all-rings,all-necklaces,all-bracelets,all-earrings' | split: ',' %}
  {% endif %}

  {% assign displayed_products = '' | split: ',' %}

  <div class="match-and-shine">
    <h2 class="mas-title">Match & Shine</h2>
    <p class="mas-subheading">Designed to Complement, Meant to Shine</p>
    <div class="page-width">
      <div class="mas-image-features-product-wrapper">
        <div class="mas-image-features-product desktop-show">
          <img
            src="{{ product.featured_media | img_url: '500x500' }}"
            height="472"
            width="472"
            alt="{{ product.title }}"
            title="{{ product.title }}"
          >
        </div>

        <div class="mas-grid">
          {% assign counter = 0 %}

          {% for category in categories %}
            {% assign collection = collections[category] %}

            {% if collection != null %}
              {% assign items = collection.products %}

              {% assign found_product = false %}
              {% assign fallback_item = null %}

              {% for item in items %}
                {% assign item_price = item.selected_or_first_available_variant.price | divided_by: 100.0 %}

                {% if item.handle != product.handle %}
                  {% unless fallback_item %}
                    {% assign fallback_item = item %}
                  {% endunless %}

                  {% if item_price >= lower_limit and item_price <= upper_limit %}
                    {% assign found_product = item %}
                    {% break %}
                  {% endif %}
                {% endif %}
              {% endfor %}

              {% assign final_item = found_product | default: fallback_item %}

              {% if final_item %}
                <div
                  class="related-product-card"
                  data-handle="{{ final_item.handle }}"
                  data-name="{{ final_item.title | escape }}"
                  data-id="{{ final_item.id }}"
                  data-price="{{ final_item.price | divided_by: 100.0 }}"
                  data-category="{{ final_item.type | escape }}"
                  onclick="
                    window.dataLayer = window.dataLayer || [];
                    window.dataLayer.push({
                      'event': 'promoClick',
                      'promoClick': {
                        'promo_id': '{{ final_item.selected_or_first_available_variant.sku }}',
                        'promo_name': '{{ final_item.title | escape }}',
                        'creative_name': 'Match and shine',
                      },
                      'event_callback': function() {
                        window.location.href = '{{ final_item.url }}';
                      }
                    });
                  "
                >
                  {% render 'card-product', card_product: final_item %}
                </div>

                {% assign displayed_products = displayed_products | push: final_item.handle %}
                {% assign counter = counter | plus: 1 %}
              {% endif %}
            {% endif %}

            {% if counter >= max_products %}
              {% break %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  {% render 'product-collection-card' %}

  <style>
    .match-and-shine {
      padding: 40px 0px;
      background-color: transparent;
      text-align: center;
    }
    .mas-title {
      font-size: 24px;
      margin: 0;
      padding-top:10px;
    }
    .mas-subheading {
      color: #535361;
      font-weight: 400;
      font-size: 18px;
      line-height: 2;
      margin: 0 auto 40px;
    }
    .mas-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      justify-content: center;
      gap: 10px;
    }
    .mas-image-features-product-wrapper {
      display: grid;
      grid-template-columns: calc(36% - 10px) calc(64% - 10px);
      align-items: center;
      gap: 20px;
      background: #f2f2f2;
      padding: 45px;
      border-radius: 12px;
    }
    .mas-image-features-product img {
      border-radius: 12px;
      width: 100%;
    }
    @media (max-width: 768px) {
      .mas-image-features-product-wrapper { display: flex; padding:10px; }
      .match-and-shine { padding:20px 0; }
      .mas-title { font-size: 20px; }
      .mas-subheading { font-size: 14px; }
      .mas-grid {
        display: flex;
        gap: 10px;
        overflow-x: scroll;
        justify-content: flex-start;
      }
      .related-product-card{width:100%; flex: 0 0 calc(250px - 0px);}
      .related-product-card{width:100%; flex: 0 0 calc(250px - 0px);}
      .mas-grid::-webkit-scrollbar {
        height: 2px;
        background-color: #F5F5F5;
      }

      .mas-grid::-webkit-scrollbar-thumb {
        background-color: #b67665;
      }

      .mas-grid::-webkit-scrollbar-track {
        background-color: #F5F5F5;
      }
    }
    @media (max-width: 480px) {
      .mas-title { font-size: 20px; }
    }
  </style>
{% endunless %}

{% schema %}
{
  "name": "Match and Shine New",
  "settings": [
    {
      "type": "text",
      "id": "collection_handle",
      "label": "Base collection handle",
      "default": "jewelry"
    },
    {
      "type": "range",
      "id": "price_range",
      "label": "Price Range (%)",
      "default": 20,
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Number of products to show",
      "default": 8,
      "min": 3,
      "max": 20,
      "step": 1
    }
  ],
  "presets": [
    {
      "name": "Match and Shine",
      "category": "Cross-sell"
    }
  ]
}
{% endschema %}
