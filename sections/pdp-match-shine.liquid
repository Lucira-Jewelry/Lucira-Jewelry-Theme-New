{% assign hide_mas_section = false %}

{% comment %} --- 1. Centralized Logic to Hide Section --- {% endcomment %}
{% if product.metafields.custom.shop_for contains 'Men' or product.metafields.shopify['target-gender'].value contains 'Men' or product.metafields.ornaverse.shop_for contains 'Men' %}
  {% assign hide_mas_section = true %}
{% endif %}

{% if product.metafields.shopify--discovery--product_recommendation.complementary_products != blank and hide_mas_section == false %}
  <div class="mas-lazy" data-mas>
    
    <div class="mas-skeleton page-width">
      <div class="mas-skeleton-wrapper">
        <div class="mas-skeleton-image"></div>
        <div class="mas-skeleton-grid">
          {% for i in (1..3) %}
            <div class="mas-skeleton-card"></div>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="mas-content" style="display:none">
      <div class="match-and-shine">
        <h2 class="mas-title">Match & Shine</h2>
        <p class="mas-subheading">Designed to Complement, Meant to Shine</p>

        <div class="page-width">
          <div class="mas-image-features-product-wrapper">
            
            <div class="mas-image-features-product desktop-show">
              {{ product.featured_media | image_url: width: 500 | image_tag: 
                width: 500, 
                height: 500, 
                loading: 'lazy', 
                alt: product.title, 
                style: 'object-fit: cover;' 
              }}
            </div>

            <div class="mas-grid">
              {% comment %} Loop through recommendations with a Limit setting {% endcomment %}
              {% for mas_product in product.metafields.shopify--discovery--product_recommendation.complementary_products.value limit: section.settings.product_limit %}
                
                <div class="mas-product-card"
                     data-handle="{{ mas_product.handle }}"
                     data-name="{{ mas_product.title | escape }}"
                     data-id="{{ mas_product.id }}"
                     data-sku="{{ mas_product.selected_or_first_available_variant.sku }}"
                     data-url="{{ mas_product.url }}">
                  
                  {% comment %} Calculation Logic Preserved {% endcomment %}
                  {% capture di_values %}
                    {% render 'di-discount-calc', product: mas_product %}
                  {% endcapture %}

                  {% assign di_parts = di_values | strip | split: '|' %}
                  
                  {% render 'card-product',
                    card_product: mas_product,
                    diamond_percent: di_parts[0] | plus: 0,
                    mc_percent: di_parts[1] | plus: 0
                  %}

                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      'use strict';
      
      function initMatchAndShine() {
        const mas = document.querySelector('[data-mas]');
        if (!mas) return;
        
        // 1. Efficient Intersection Observer to load content
        const io = new IntersectionObserver((entries) => {
          if (entries[0].isIntersecting) {
            const skeleton = mas.querySelector('.mas-skeleton');
            const content = mas.querySelector('.mas-content');
            
            // Show content
            content.style.display = 'block';
            
            // Smooth fade-in
            requestAnimationFrame(() => {
              content.style.opacity = '1';
              if(skeleton) skeleton.remove();
            });
            
            // Stop observing and bind click events
            io.disconnect();
            bindDelegatedEvents(mas);
          }
        }, { rootMargin: '200px' });
        
        io.observe(mas);
      }
      
      // 2. Optimized Event Delegation (Faster Performance)
      function bindDelegatedEvents(container) {
        container.addEventListener('click', function(e) {
          const card = e.target.closest('.mas-product-card');
          const link = e.target.closest('a');
          
          if (card && link) {
            const data = card.dataset;
            
            // Non-blocking GTM push
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              event: 'promoClick',
              promoClick: {
                promo_id: data.sku,
                promo_name: data.name,
                creative_name: 'Match and shine',
                location_id: 'pdp_complementary'
              }
            });
            // Link follows naturally without JS delay
          }
        });
      }
      
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMatchAndShine);
      } else {
        initMatchAndShine();
      }
    })();
  </script>

  <style>
    .mas-skeleton-wrapper{display:grid;grid-template-columns:36% 1fr;gap:20px;background:#f2f2f2;padding:45px;border-radius:12px;min-height:500px}
    .mas-skeleton-image{height:472px;border-radius:12px;background:linear-gradient(90deg,#eee 25%,#f5f5f5 37%,#eee 63%);background-size:400% 100%;animation:shimmer 1.4s infinite}
    .mas-skeleton-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
    .mas-skeleton-card{height:360px;border-radius:8px;background:linear-gradient(90deg,#eee 25%,#f5f5f5 37%,#eee 63%);background-size:400% 100%;animation:shimmer 1.4s infinite}
    @keyframes shimmer{ 0%{background-position:200% 0} 100%{background-position:-200% 0} }
    
    .match-and-shine{padding:40px 0 0;text-align:center}
    .mas-title{font-size:24px;margin:10px 0 0}
    .mas-subheading{color:#535361;font-size:18px;margin:0 auto 25px;line-height:2}
    .mas-content{opacity:0;transition:opacity .4s ease}
    
    .mas-image-features-product-wrapper{display:grid;grid-template-columns:36% 1fr;align-items:center;gap:20px;background:#f2f2f2;padding:45px;border-radius:12px}
    .mas-image-features-product img{border-radius:12px;width:100%;height:auto;aspect-ratio:1/1}
    
    .mas-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
    
    /* Mobile Optimizations */
    @media(max-width:768px){
      .mas-skeleton-wrapper, .mas-image-features-product-wrapper{display:flex;flex-direction:column;padding:15px;min-height:auto}
      .mas-skeleton-image, .mas-image-features-product{display:none}
      .mas-skeleton-grid, .mas-grid{display:flex;gap:10px;overflow-x:auto;width:100%;padding-bottom:10px;scroll-snap-type:x mandatory}
      .mas-skeleton-card, .mas-product-card{flex:0 0 240px;scroll-snap-align:start}
      
      .mas-grid::-webkit-scrollbar { display: none; }
      .mas-grid { -ms-overflow-style: none; scrollbar-width: none; }
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "Match and Shine New",
  "settings": [
    {
      "type": "range",
      "id": "product_limit",
      "label": "Number of products to show",
      "default": 8,
      "min": 3,
      "max": 20,
      "step": 1
    }
  ],
  "presets": [
    {
      "name": "Match and Shine"
    }
  ]
}
{% endschema %}