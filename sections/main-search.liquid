<script>
  function handleClickToShowFacet() {
    const facetsWrapper = document.querySelector(".facets-wrapper");
    const container = document.querySelector(".custom-facets-container");
    const filterBtn = document.querySelector("details.mobile-facets__disclosure")
    console.log('click')

    facetsWrapper.classList.toggle("show-facet");
    container.classList.toggle("active");
    filterBtn.classList.toggle('menu-opening')
    filterBtn.setAttribute('open','open')
  }

  // Automatically show filter on page load
  document.addEventListener("DOMContentLoaded", function () {
    if (window.innerWidth >= 768) {
      handleClickToShowFacet();
    }
  });
</script>
