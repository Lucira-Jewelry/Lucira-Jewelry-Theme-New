<style>
  .template-search__header {
    margin-bottom: 3rem;
  }

  .template-search__header h1 {text-transform: uppercase;}

  .template-search__search {
    margin: 0 auto 3.5rem;
    max-width: 74.1rem;
  }

  .template-search__search .search {
    margin-top: 3rem;
  }

  .template-search--empty {
    padding-bottom: 18rem;
  }

  @media screen and (min-width: 750px) {
    .template-search__header {
      margin-bottom: 5rem;
    }
  }

  .search__button .icon {
    height: 1.8rem;
  }

  /* Custom Filter Styles from Collection */
  .brad-plp-pg-component {
    display: flex;
    width: 100%;
    flex-direction: column;
    align-items: center;
  }

  .brad-plp-pg-component-image-container {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 456px;
    overflow: hidden;
    gap:10px;
  }

  @media(max-width:1440px){
    .brad-plp-pg-component-image-container {
      height: 420px;
    }
  }
  @media(max-width:1280px){
    .brad-plp-pg-component-image-container {
      height: 380px;
    }
  }
  @media(max-width:1024px){
    .brad-plp-pg-component-image-container {
      height: 320px;
    }
  }
  @media(max-width:786px){
    .brad-plp-pg-component-image-container {
      height: 280px;
    }
  }

  .brad-plp-pg-component-image-wrapper {
    width: 100%;
    height: 20%;
    transition: height 0.5s ease-in-out;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius:12px;
  }

  .brad-plp-pg-component-image {
    width: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .brad-plp-pg-component-image-wrapper.active {
    height: 80%;
  }
  .brad-collec-sortby{
    font-size: 14px;
    margin-inline: 10px;
    color: #1a1a1a;
  }
  .brad-collec-banner{
    grid-column: span 2;
  }
  @media(max-width:786px){
    .brad-collec-sortby {
      font-size: 12px;
    }
    .brad-collec-banner{
      width:100% !important;
    }
  }
</style>

{%- liquid
  assign sort_by = search.sort_by | default: search.default_sort_by
  assign terms = search.terms | escape
  assign search_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% paginate search.results by 24 %}
  <div class="template-search{% unless search.performed and search.results_count > 0 %} template-search--empty{% endunless %} section-{{ section.id }}-padding">
    <div class="template-search__header page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      <h1 class="h2 center">
        {%- if search.performed -%}
          {{- 'templates.search.title' | t -}}
        {%- else -%}
          {{- 'general.search.search' | t -}}
        {%- endif -%}
      </h1>
      <div class="template-search__search">
        {%- if settings.predictive_search_enabled -%}
          <predictive-search data-loading-text="{{ 'accessibility.loading' | t }}">
        {%- endif -%}
        <main-search>
          <form action="{{ routes.search_url }}" method="get" role="search" class="search">
            <div class="field">
              <input
                class="search__input field__input"
                id="Search-In-Template"
                type="search"
                name="q"
                value="{{ search.terms | escape }}"
                placeholder="{{ 'general.search.search' | t }}"
                {%- if settings.predictive_search_enabled -%}
                  role="combobox"
                  aria-expanded="false"
                  aria-owns="predictive-search-results"
                  aria-controls="predictive-search-results"
                  aria-haspopup="listbox"
                  aria-autocomplete="list"
                  autocorrect="off"
                  autocomplete="off"
                  autocapitalize="off"
                  spellcheck="false"
                {%- endif -%}
              >
              <label class="field__label" for="Search-In-Template">{{ 'general.search.search' | t }}</label>
              <input name="options[prefix]" type="hidden" value="last">

              {%- if settings.predictive_search_enabled -%}
                <div class="predictive-search predictive-search--search-template" tabindex="-1" data-predictive-search>
                  {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}
                </div>

                <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
              {%- endif -%}

              <button
                type="reset"
                class="reset__button field__button{% if search.terms == blank %} hidden{% endif %}"
                aria-label="{{ 'general.search.reset' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-reset.svg' | inline_asset_content -}}
                </span>
              </button>
              <button type="submit" class="search__button field__button" aria-label="{{ 'general.search.search' | t }}">
                <span class="svg-wrapper">
                  {{- 'icon-search.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>
          </form>
        </main-search>
        {%- if settings.predictive_search_enabled -%}
          </predictive-search>
        {%- endif -%}
      </div>
      {%- if search.performed -%}
        {%- unless section.settings.enable_filtering or section.settings.enable_sorting -%}
          {%- if search.results_count > 0 -%}
            <p role="status">
              {{ 'templates.search.results_with_count_and_term' | t: terms: search.terms, count: search.results_count }}
            </p>
          {%- endif -%}
        {%- endunless -%}
      {%- if search.results_count == 0 and search.filters == empty -%}
  <div class="custom-no-results">

    {% if section.settings.no_results_image != blank %}
      <img src="{{ section.settings.no_results_image | img_url: 'master' }}" alt="No Gems Found" class="no-results-img" />
    {% endif %}

    {% if section.settings.no_results_heading != blank %}
      <h2>{{ section.settings.no_results_heading }}</h2>
    {% endif %}

    {% if section.settings.no_results_subtext != blank %}
    <p style="margin-bottom:0px;width:100%">{{ section.settings.no_results_subtext | replace: '[term]', search.terms }}</p>
    <p style="margin-top:0px;width:100%;">{{ section.settings.no_result_sub }}</p>
    {% endif %}

    <div class="custom-404-buttons">
      {% if section.settings.no_results_primary_url != blank and section.settings.no_results_primary_label != blank %}
        <a href="https://www.lucirajewelry.com/collections/jewelry" class="custom-404-btn primary">
          {{ section.settings.no_results_primary_label }}
        </a>
      {% endif %}
      {% if section.settings.no_results_secondary_url != blank and section.settings.no_results_secondary_label != blank %}
        <a href="{{ section.settings.no_results_secondary_url }}" class="custom-404-btn secondary">
          {{ section.settings.no_results_secondary_label }}
        </a>
      {% endif %}
    </div>
  </div>

  <style>
    .custom-no-results {
      text-align: center;
      padding: 40px 0;
    }

    .custom-no-results img.no-results-img {
      max-width: 270px;
      margin-bottom: 20px;
    }

    .custom-no-results h2 {
      font-size: 40px;
      margin: 10px 0;
    }

    .custom-no-results p {
      color: #666;
      font-size: 16px;
      width: 22%;
      text-align: center;
    }

    .custom-404-buttons {
      display: flex;
      justify-content: center;
      gap: 15px;
      flex-wrap: wrap;
    }

    .custom-404-btn {
      padding: 10px 20px;
      border: 1px solid #a68380;
      text-decoration: none;
      border-radius: 20px;
      font-size: 16px;
      width:25%;
    }

    .custom-404-btn.primary {
      background: #a68380;
      color: #fff;
    }

    .custom-404-btn.secondary {
      background: transparent;
      color: #a68380;
    }
    @media(max-width:767px){
      .custom-404-btn.primary {
        width:90%;
        margin:0 auto;
      }
      .custom-404-btn.secondary {
        width:90%;
        margin:auto;
      }
      .custom-no-results p {
        margin-top:60px;
        margin-bottom:80px;
        width: 83%;
      }
      .custom-404-btn {
        padding: 15px 20px;
      }
    }
    @media(min-width:768px) and (max-width:1000px){
      .custom-no-results p {
        width: 50%;
      }
    }
  </style>
{%- endif -%}

      {%- endif -%}
    </div>
    <style>
      .search-results-count__text {font-size: 14px; color: #1a1a1a; text-align: left; margin-bottom: 16px; margin-top: 0;}
    </style>
    {%- if search.performed and search.results_count > 0 -%}
      <div class="search-results-count page-width">
        <p class="search-results-count__text">
          Total Products found: {{ search.results_count }} results
        </p>
      </div>
    {%- endif -%}
    {%- if search.performed -%}
      {%- comment -%} Enhanced Filter Section with Custom Sorting {%- endcomment -%}
      {%- if section.settings.enable_sorting and section.settings.filter_type == 'vertical' and search.results_count > 0 -%}
        <facet-filters-form class="facets facets-vertical-sort page-width small-hide custom-facets">
          <div class="custom-facets-container" onclick="handleClickToShowFacet()">
            <span class="facet-label">Filter</span>
            <img class="facet-icon filter" src="{{ 'filter-icon.svg' | asset_url }}" height="20px" width="20px">
            <img class="facet-icon close" src="{{ 'close-icon.svg' | asset_url }}" height="20px" width="20px">
          </div>

          <!-- Remove filters options -->
          <div class="custom-remove-filters">
            {%- if section.settings.filter_type == 'vertical' -%}
              <div class="active-facets active-facets-desktop">
                {%- for filter in search.filters -%}
                  {%- for value in filter.active_values -%}
                    <facet-remove>
                      <a href="{{ value.url_to_remove }}" class="active-facets__button active-facets__button--light">
                        <span class="active-facets__button-inner button button--tertiary">
                          {{ filter.label | escape }}: {{ value.label | escape }}
                          <span class="svg-wrapper">
                            {{- 'icon-close-small.svg' | inline_asset_content -}}
                          </span>
                          <span class="visually-hidden">{{ 'products.facets.clear_filter' | t }}</span>
                        </span>
                      </a>
                    </facet-remove>
                  {%- endfor -%}
                  {% if filter.type == 'price_range' %}
                    {% assign min = filter.min_value.value %}
                    {% assign max = filter.max_value.value %}
                    {%- if min != null or max != null -%}
                      <facet-remove>
                        <a href="{{ filter.url_to_remove }}" class="active-facets__button active-facets__button--light">
                          <span class="active-facets__button-inner button button--tertiary">
                            {{ min | default: 0 | money }} - {{ max | default: filter.range_max | money }}
                            <span class="svg-wrapper">
                              {{- 'icon-close-small.svg' | inline_asset_content -}}
                            </span>
                            <span class="visually-hidden">{{ 'products.facets.clear_filter' | t }}</span>
                          </span>
                        </a>
                      </facet-remove>
                    {%- endif -%}
                  {% endif %}
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>

          <!-- Sort By filters -->
          <form class="facets-vertical-form" id="FacetSortForm">
            <div class="facet-filters sorting caption">
              <div class="facet-filters__field desk_filter">
                <span class="brad-collec-sortby" class="facet-filters__label caption-large text-body">
                  <label for="SortBy">{{ 'products.facets.sort_by_label' | t | upcase }}</label>
                </span>
                <div class="select">
                  {%- assign sort_by = search.sort_by | default: search.default_sort_by -%}
                  <select
                    name="sort_by"
                    class="facet-filters__sort select__select caption-large brad-sortby-filters"
                    id="SortBy"
                    aria-describedby="a11y-refresh-page-message"
                  >
                    {%- for option in search.sort_options -%}
                      <option
                        value="{{ option.value | escape }}"
                        {% if option.value == sort_by %}
                          selected="selected"
                        {% endif %}
                      >
                        {{ option.name | escape }}
                      </option>
                    {%- endfor -%}
                  </select>
                  <span class="svg-wrapper">
                    {{- 'icon-caret.svg' | inline_asset_content -}}
                  </span>
                </div>
              </div>
            </div>
          </form>
        </facet-filters-form>
      {%- endif -%}

      <div
        {% if section.settings.filter_type == 'vertical' %}
          class="facets-vertical page-width"
        {% endif %}
      >
        {%- if search.filters != empty -%}
          {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
            <aside
              aria-labelledby="verticalTitle"
              class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
              id="main-search-filters"
              data-id="{{ section.id }}"
            >
              {% render 'facets',
                results: search,
                enable_filtering: section.settings.enable_filtering,
                enable_sorting: section.settings.enable_sorting,
                filter_type: section.settings.filter_type,
                paginate: paginate
              %}
            </aside>
          {%- endif -%}
        {%- endif -%}
        <div class="product-grid-container" id="ProductGridContainer">
          {%- if search.results.size == 0 and search.filters != empty -%}
            <div
              class="template-search__results collection collection--empty{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
              id="product-grid"
              data-id="{{ section.id }}"
            >
              <div class="loading-overlay gradient"></div>
              <div class="title-wrapper center">
                <h2 class="title title--primary">
                  {{ 'sections.collection_template.empty' | t -}}
                  <br>
                  {{
                    'sections.collection_template.use_fewer_filters_html'
                    | t: link: search_url, class: 'underlined-link link'
                  }}
                </h2>
              </div>
            </div>
          {%- else -%}
            <div
              class="template-search__results collection{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
              id="product-grid"
              data-id="{{ section.id }}"
            >
              <div class="loading-overlay gradient"></div>
              <ul
                class="grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
                role="list"
              >
                {%- assign skip_card_product_styles = false -%}
                {%- for item in search.results -%}
                  {% assign lazy_load = false %}
                  {%- if forloop.index > 2 -%}
                    {%- assign lazy_load = true -%}
                  {%- endif -%}

                  {%- comment -%} Add Banner Component at Specified Position {%- endcomment -%}
                  {% if forloop.index0 == section.settings.banner_grid_position and section.settings.show_banner %}
                    <li
                      class="brad-collec-banner grid__item{% if settings.animations_reveal_on_scroll %}--span-2 scroll-trigger animate--slide-in{% endif %}"
                      {% if settings.animations_reveal_on_scroll %}
                        data-cascade
                        style="--animation-order: {{ forloop.index }};"
                      {% endif %}
                    >
                      <div class="brad-plp-pg-component">
                        <div class="brad-plp-pg-component-image-container">
                          <div id="brad-plp-img-1" class="brad-plp-pg-component-image-wrapper active">
                            <img
                              class="brad-plp-pg-component-image"
                              src="{{ section.settings.banner_image_1 | default: 'https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Rakhi-Inpage-2_1.jpg?v=1752751739' | img_url: 'master' }}"
                              alt="Banner Image 1"
                            >
                          </div>
                          <div id="brad-plp-img-2" class="brad-plp-pg-component-image-wrapper">
                            <img
                              class="brad-plp-pg-component-image"
                              src="{{ section.settings.banner_image_2 | default: 'https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Rakhi-Offer_1.jpg?v=1752751739' | img_url: 'master' }}"
                              alt="Banner Image 2"
                            >
                          </div>
                        </div>
                      </div>
                    </li>
                  {% endif %}

                  {%- comment -%} Add Filter Component at Specified Position {%- endcomment -%}
                  {% if forloop.index == section.settings.filter_grid_position and section.settings.show_inline_filters %}
                    <li
                      class="brad-collec-banner grid__item{% if settings.animations_reveal_on_scroll %}--span-2 scroll-trigger animate--slide-in{% endif %}"
                      {% if settings.animations_reveal_on_scroll %}
                        data-cascade
                        style="--animation-order: {{ forloop.index }};"
                      {% endif %}
                    >
                      <div style="border: 2px solid black;border-radius: 12px; height:100%; padding: 2rem; display: flex; flex-direction: column; position: relative;">
                        {%- assign material_filter = search.filters | where: 'label', 'Material Type' | first -%}
                        {%- assign price_filter = search.filters | where: 'label', 'Price' | first -%}
                        <form id="filter-form-id">
                          {% if price_filter %}
                            <div style="font-weight: bold;">Filter by Price</div>
                            <div>
                              <input
                                name="{{ price_filter.min_value.param_name }}"
                                id="filter-inside-grid-min-value"
                                type="number"
                                style="display: none;"
                                min="0"
                                max="{{ price_filter.range_max | money_without_currency | replace: ',', '' }}"
                              >
                              <input
                                name="{{ price_filter.max_value.param_name }}"
                                id="filter-inside-grid-max-value"
                                type="number"
                                style="display: none;"
                                min="0"
                                max="{{ price_filter.range_max | money_without_currency | replace: ',', '' }}"
                              >
                              <label onclick="handlePriceInputInsideGrid(0, 5000)">
                                {{- cart.currency.symbol }}5000 & under</label
                              >
                              <label onclick="handlePriceInputInsideGrid(5001, 10000)">
                                {{- cart.currency.symbol }}5001 - {{ cart.currency.symbol }}10000</label
                              >
                              <label onclick="handlePriceInputInsideGrid(10001, 15000)">
                                {{- cart.currency.symbol }}10001 - {{ cart.currency.symbol }}15000</label
                              >
                              <label onclick="handlePriceInputInsideGrid(15001, 20000)">
                                {{- cart.currency.symbol }}15001 - {{ cart.currency.symbol }}20000</label
                              >
                              <label onclick="handlePriceInputInsideGrid(20001, 30000)">
                                {{- cart.currency.symbol }}20001 - {{ cart.currency.symbol }}30000</label
                              >
                              <label onclick="handlePriceInputInsideGrid(30001, 40000)">
                                {{- cart.currency.symbol }}30001 - {{ cart.currency.symbol }}40000</label
                              >
                              <label onclick="handlePriceInputInsideGrid(40001, {{ price_filter.range_max | money_without_currency | replace: ',', '' }})">
                                {{- cart.currency.symbol }}40001 & above</label
                              >
                            </div>
                          {% endif %}

                          {% if material_filter %}
                            <div style="font-weight: bold;">Filter by {{ material_filter.label }}</div>
                            <div>
                              {% for filter_value in material_filter.values %}
                                <input
                                  type="checkbox"
                                  style="display: none;"
                                  name="{{ filter_value.param_name }}"
                                  value="{{ filter_value.value }}"
                                  id="filter-form-material-filter-{{ forloop.index }}"
                                  onChange="handleChangeInsideGrid()"
                                >
                                <label
                                  for="filter-form-material-filter-{{ forloop.index }}"
                                  style=""
                                >
                                  {{- filter_value.value -}}
                                </label>
