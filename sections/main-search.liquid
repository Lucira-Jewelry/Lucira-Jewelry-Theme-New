<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Create modal if it doesn't exist
    let modal = document.getElementById('VideoModal');
    if (!modal) {
      modal = document.createElement('div');
      modal.id = 'VideoModal';
      modal.className = 'video-modal hidden';
      modal.innerHTML = `
        <div class="video-modal__overlay">
          <div class="video-modal__content">
            <button class="video-modal__close"><i class="fa-solid fa-xmark"></i></button>
            <div class="video-modal__video-container"></div>
          </div>
        </div>
      `;
      document.body.appendChild(modal);

      // Add CSS styles for the modal
      const style = document.createElement('style');
      style.textContent = `
        .video-modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999; background: rgba(0, 0, 0, 0); backdrop-filter: blur(0px); opacity: 0; visibility: hidden; transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
        .video-modal:not(.hidden) { background: rgba(0, 0, 0, 0.8); backdrop-filter: blur(10px); opacity: 1; visibility: visible; }
        .video-modal__content { position: relative; max-width: 100vw; max-height: 90vh; margin: 0 auto; }
        .video-modal__close { position: absolute; top: -40px; right: 0; background: none; border: none; color: white; font-size: 24px; cursor: pointer; z-index: 10001; }
        .video-modal__video-container video { width: 100%; height: auto; max-height: 90vh; }
      `;
      document.head.appendChild(style);
    }

    const overlay = modal.querySelector('.video-modal__overlay');
    const closeBtn = modal.querySelector('.video-modal__close');
    const videoContainer = modal.querySelector('.video-modal__video-container');

    // Function to handle modal opening
    function openVideoModal(productHandle, videoId) {
      console.log('Opening Shopify video:', productHandle, videoId);
      videoContainer.innerHTML = '';

      fetch(`/products/${productHandle}.js`)
        .then((response) => response.json())
        .then((product) => {
          const video = product.media.find(
            (media) => media.media_type === 'video' && media.id.toString() === videoId.toString()
          );

          if (video && video.sources && video.sources.length > 0) {
            const videoUrl = video.sources[0].url;
            videoContainer.innerHTML = `
              <video controls autoplay muted playsinline loop>
                <source src="${videoUrl}" type="video/mp4">
                Your browser does not support the video tag.
              </video>
            `;

            modal.style.display = 'block';
            requestAnimationFrame(() => {
              modal.classList.remove('hidden');
            });
            document.body.style.overflow = 'hidden';
          }
        })
        .catch((error) => {
          console.error('Error fetching product data:', error);
        });
    }

    function closeModal() {
      modal.classList.add('hidden');
      setTimeout(() => {
        if (modal.classList.contains('hidden')) {
          modal.style.display = 'none';
          videoContainer.innerHTML = '';
        }
      }, 600);
      document.body.style.overflow = '';
    }

    // Event delegation - works for all current and future video icons
    document.addEventListener(
      'click',
      function (e) {
        const videoIcon = e.target.closest('.product-video-icon-wrapper');

        if (videoIcon) {
          e.preventDefault();
          e.stopPropagation();

          const productHandle = videoIcon.getAttribute('data-product-handle');
          const videoId = videoIcon.getAttribute('data-video-id');

          if (productHandle && videoId) {
            openVideoModal(productHandle, videoId);
          }
        }
      },
      true
    );

    // Modal close handlers
    if (overlay) {
      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) {
          closeModal();
        }
      });
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', closeModal);
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });
  });
</script>
<script>
  // Original functionality - expand clicked image wrapper and collapse others
  function handleImageWrapperClick(event) {
    // Get the clicked element
    const clickedWrapper = event.currentTarget;

    // Reset all wrappers
    document.querySelectorAll(".brad-plp-pg-component-image-wrapper").forEach((el) => {
      el.classList.remove("active");
      el.style.height = "20%"; // Reset all divs to 20%
    });

    // Expand the clicked wrapper
    clickedWrapper.classList.add("active");
    clickedWrapper.style.height = "80%";
  }

  // Function to attach click events to image wrappers
  function attachImageWrapperEvents() {
    // Find all image wrappers that don't have the event listener yet
    document.querySelectorAll(".brad-plp-pg-component-image-wrapper:not([data-event-attached])").forEach((div) => {
      // Mark element as having event attached
      div.setAttribute('data-event-attached', 'true');

      // Add click event listener
      div.addEventListener("click", handleImageWrapperClick);
    });
  }

  // Run once to attach events to existing elements
  attachImageWrapperEvents();

  // Create a MutationObserver to watch for newly added image wrappers
  const observer = new MutationObserver((mutations) => {
    let needsUpdate = false;

    // Check if any mutations added new image wrappers
    mutations.forEach(mutation => {
      if (mutation.addedNodes.length > 0) {
        needsUpdate = true;
      }
    });

    // Only run the attachment function if new nodes were added
    if (needsUpdate) {
      attachImageWrapperEvents();
    }
  });

  // Get the container where new elements will be loaded
  const productContainer = document.querySelector('.product-grid-container') || document.body;

  // Start observing the container for DOM changes
  observer.observe(productContainer, {
    childList: true, // Watch for changes to direct children
    subtree: true    // Watch for changes in the entire subtree
  });
</script>

