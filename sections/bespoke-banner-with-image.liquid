

<style>
.bespoke-section-{{ section.id }} { width: 100%; overflow: hidden; } 
.bespoke-block { display: flex; align-items: center; gap: 40px; max-width: 1400px; margin: 0 auto; padding: 60px 20px; } 
.bespoke-block.reverse { flex-direction: row-reverse; } 
.bespoke-image-wrapper { flex: 1; position: relative; min-width: 45%; } 
.bespoke-image { width: 100%; height: 525px; display: block; margin-left:100px; } 
.bespoke-image-mobile { display: none; } 
.bespoke-text-wrapper { flex: 1; position: relative; z-index: 2; background: #F2F2F2; padding: 40px; right: 105px; } 
.bespoke-heading { font-size: {{ section.settings.heading_size }}px; color: {{ section.settings.heading_color }}; font-weight: {{ section.settings.heading_weight }}; text-transform: {{ section.settings.heading_transform }}; letter-spacing: {{ section.settings.heading_letter_spacing }}px; margin: 0 0 20px 0; line-height: 1.3; } 
.bespoke-description { font-size: {{ section.settings.description_size }}px; color: {{ section.settings.description_color }}; line-height: 1.6; margin: 0 0 25px 0; } 
.bespoke-link { display: inline-block; color: {{ section.settings.link_color }}; font-size: {{ section.settings.link_size }}px; text-decoration: underline; font-weight: 500; transition: opacity 0.3s ease; } 
.bespoke-link:hover { opacity: 0.7; } 
.bespoke-video-section { position: relative; width: 100%; height: {{ section.settings.video_height }}px; overflow: hidden; background-color: #000; } 
.bespoke-video { position: absolute; top: 50%; left: 50%; width: 100%; height: 100%; object-fit: cover; transform: translate(-50%, -50%); } 
.bespoke-video-mobile { display: none; position: absolute; top: 50%; left: 50%; width: 100%; height: 100%; object-fit: cover; transform: translate(-50%, -50%); }
.bespoke-video-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: {{ section.settings.video_overlay_color }}; opacity: {{ section.settings.video_overlay_opacity }}; z-index: 1; } 
.bespoke-video-content { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 2; text-align: center; color: #fff; max-width: 800px; padding: 0 20px; } 
.bespoke-video-heading { font-size: {{ section.settings.video_heading_size }}px; font-weight: 600; margin: 0 0 15px 0; text-transform: uppercase; letter-spacing: 2px; } 
.bespoke-video-text { font-size: {{ section.settings.video_text_size }}px; line-height: 1.6; margin: 0; }

 
@media (max-width: 768px) { 
  .bespoke-block { flex-direction: column; padding: 40px 20px; gap: 30px; height:800px; } 
  .bespoke-block.reverse { flex-direction: column; } 
  .bespoke-image-wrapper { min-width: 100%; } 
  .bespoke-image{ margin-left:0; display: none; } 
  .bespoke-image-mobile { display: block; width: 100%; height: auto; } 
  .bespoke-heading { font-size: {{ section.settings.heading_size_mobile }}px; } 
  .bespoke-description { font-size: {{ section.settings.description_size_mobile }}px; } 
  .bespoke-link { font-size: {{ section.settings.link_size_mobile }}px; } 
  .bespoke-video-section { height: {{ section.settings.video_height_mobile }}px; } 
  .bespoke-video { display: none; }
  .bespoke-video-mobile { display: block; }
  .bespoke-video-heading { font-size: {{ section.settings.video_heading_size_mobile }}px; } 
  .bespoke-video-text { font-size: {{ section.settings.video_text_size_mobile }}px; } 
  .bespoke-text-wrapper { flex: 1; position: relative; z-index: 2; background: #F2F2F2; padding: 30px; right:0; bottom: 110px; width: 90%; } 
  .video-header { font-size: 18px !important; }
}

@media (max-width: 370px) { 
  .bespoke-block { flex-direction: column; padding: 40px 20px; gap: 30px; height: 790px; } 
  .bespoke-jewelry-overlay {  padding: 6px 8px !important;font-size:}
}



</style>

<div class="bespoke-section-{{ section.id }}"  >
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'image_text_block' %}
        <div class="bespoke-block {% if block.settings.image_position == 'right' %}reverse{% endif %}">
          <div class="bespoke-image-wrapper">
            {% if block.settings.image != blank %}
              <img 
                src="{{ block.settings.image | img_url: '800x' }}"
                srcset="{{ block.settings.image | img_url: '400x' }} 400w,
                        {{ block.settings.image | img_url: '600x' }} 600w,
                        {{ block.settings.image | img_url: '800x' }} 800w,
                        {{ block.settings.image | img_url: '1200x' }} 1200w"
                sizes="(max-width: 768px) 100vw, 50vw"
                alt="{{ block.settings.image.alt | escape }}"
                class="bespoke-image"
                loading="lazy"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'bespoke-image' }}
            {% endif %}

            {% if block.settings.mobile_image != blank %}
              <img 
                src="{{ block.settings.mobile_image | img_url: '800x' }}"
                srcset="{{ block.settings.mobile_image | img_url: '400x' }} 400w,
                        {{ block.settings.mobile_image | img_url: '600x' }} 600w,
                        {{ block.settings.mobile_image | img_url: '800x' }} 800w"
                sizes="100vw"
                alt="{{ block.settings.mobile_image.alt | escape }}"
                class="bespoke-image-mobile"
                loading="lazy"
              >
            {% elsif block.settings.image != blank %}
              <img 
                src="{{ block.settings.image | img_url: '800x' }}"
                srcset="{{ block.settings.image | img_url: '400x' }} 400w,
                        {{ block.settings.image | img_url: '600x' }} 600w,
                        {{ block.settings.image | img_url: '800x' }} 800w"
                sizes="100vw"
                alt="{{ block.settings.image.alt | escape }}"
                class="bespoke-image-mobile"
                loading="lazy"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'bespoke-image-mobile' }}
            {% endif %}
          </div>

          <div class="bespoke-text-wrapper">
            {% if block.settings.heading != blank %}
              <h2 class="bespoke-heading">{{ block.settings.heading }}</h2>
            {% endif %}

            {% if block.settings.description != blank %}
              <p class="bespoke-description">{{ block.settings.description }}</p>
            {% endif %}

            {% if block.settings.link_text != blank and block.settings.link_url != blank %}
              <a href="{{ block.settings.link_url }}" class="bespoke-link">
                {{ block.settings.link_text }}
              </a>
            {% endif %}
          </div>
         
        </div>
        <div class="video-header" style="
          text-align: center;
          font-weight: 500;
          font-size: 24px;
          color: #1a1a1a;
          letter-spacing:1px;
          padding-bottom: 20px;
          text-transform:uppercase;">
          THE MAKING OF YOUR JEWEL
        </div>

      {% when 'video_block' %}
        <div class="bespoke-video-section">
          {% comment %} Desktop Video {% endcomment %}
          {% if block.settings.video_url != blank %}
            <video 
              class="bespoke-video"
              {% if block.settings.video_poster %}poster="{{ block.settings.video_poster | img_url: '1920x' }}"{% endif %}
              {% if block.settings.video_autoplay %}autoplay{% endif %}
              {% if block.settings.video_loop %}loop{% endif %}
              {% if block.settings.video_muted %}muted{% endif %}
              playsinline
              disablePictureInPicture
            >
              <source src="{{ block.settings.video_url }}" type="video/mp4">
            </video>
          {% endif %}

          {% comment %} Mobile Video {% endcomment %}
          {% if block.settings.mobile_video_url != blank %}
            <video 
              class="bespoke-video-mobile"
              {% if block.settings.mobile_video_poster %}poster="{{ block.settings.mobile_video_poster | img_url: '1920x' }}"{% endif %}
              {% if block.settings.video_autoplay %}autoplay{% endif %}
              {% if block.settings.video_loop %}loop{% endif %}
              {% if block.settings.video_muted %}muted{% endif %}
              playsinline
              disablePictureInPicture
            >
              <source src="{{ block.settings.mobile_video_url }}" type="video/mp4">
            </video>
          {% elsif block.settings.video_url != blank %}
            <video 
              class="bespoke-video-mobile"
              {% if block.settings.video_poster %}poster="{{ block.settings.video_poster | img_url: '1920x' }}"{% endif %}
              {% if block.settings.video_autoplay %}autoplay{% endif %}
              {% if block.settings.video_loop %}loop{% endif %}
              {% if block.settings.video_muted %}muted{% endif %}
              playsinline
              disablePictureInPicture
            >
              <source src="{{ block.settings.video_url }}" type="video/mp4">
            </video>
          {% endif %}

          {% if block.settings.show_overlay %}
            <div class="bespoke-video-overlay"></div>
          {% endif %}

          {% if block.settings.show_video_content %}
            <div class="bespoke-video-content">
              {% if block.settings.video_text != blank %}
                <p class="bespoke-video-text">{{ block.settings.video_text }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
    {% endcase %}
  {% endfor %}
</div>

{% schema %}
{
  "name": "Bespoke Design Page",
  "settings": [
    {
      "type": "header",
      "content": "Text Styling"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size (desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 18,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading size (mobile)",
      "default": 24
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "500"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Heading letter spacing",
      "default": 1
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size (desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "description_size_mobile",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Description size (mobile)",
      "default": 14
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "link_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Link size (desktop)",
      "default": 14
    },
    {
      "type": "range",
      "id": "link_size_mobile",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Link size (mobile)",
      "default": 13
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Video Section Styling"
    },
    {
      "type": "range",
      "id": "video_height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Video height (desktop)",
      "default": 600
    },
    {
      "type": "range",
      "id": "video_height_mobile",
      "min": 250,
      "max": 500,
      "step": 25,
      "unit": "px",
      "label": "Video height (mobile)",
      "default": 400
    },
    {
      "type": "color",
      "id": "video_overlay_color",
      "label": "Video overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "video_overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Video overlay opacity",
      "default": 0.4
    },
    {
      "type": "range",
      "id": "video_heading_size",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Video heading size (desktop)",
      "default": 36
    },
    {
      "type": "range",
      "id": "video_heading_size_mobile",
      "min": 20,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Video heading size (mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "video_text_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Video text size (desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "video_text_size_mobile",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Video text size (mobile)",
      "default": 14
    }
  ],
  "blocks": [
    {
      "type": "image_text_block",
      "name": "Image + Text Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image",
          "info": "Optional. If not set, desktop image will be used on mobile"
        },
        {
          "type": "select",
          "id": "image_position",
          "label": "Image position",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "YOUR STORY, YOUR CHOICE"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text",
          "default": "View our Full Creations"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "video_block",
      "name": "Video Block",
      "settings": [
        {
          "type": "header",
          "content": "Desktop Video"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Desktop Video URL",
          "info": "Upload video to Shopify Files and paste URL here"
        },
        {
          "type": "image_picker",
          "id": "video_poster",
          "label": "Desktop Video poster image",
          "info": "Fallback image when video is loading"
        },
        {
          "type": "header",
          "content": "Mobile Video"
        },
        {
          "type": "text",
          "id": "mobile_video_url",
          "label": "Mobile Video URL",
          "info": "Optional. If not set, desktop video will be used on mobile. Upload video to Shopify Files and paste URL here"
        },
        {
          "type": "image_picker",
          "id": "mobile_video_poster",
          "label": "Mobile Video poster image",
          "info": "Optional. Fallback image for mobile video"
        },
        {
          "type": "header",
          "content": "Video Settings"
        },
        {
          "type": "checkbox",
          "id": "video_autoplay",
          "label": "Autoplay video",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "video_loop",
          "label": "Loop video",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "video_muted",
          "label": "Mute video",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_overlay",
          "label": "Show overlay",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_video_content",
          "label": "Show text content over video",
          "default": true
        },
        {
          "type": "text",
          "id": "video_heading",
          "label": "Video heading",
          "default": "OUR EXPERT STEPS"
        },
        {
          "type": "textarea",
          "id": "video_text",
          "label": "Video text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bespoke Design Page",
      "category": "Custom"
    }
  ]
}
{% endschema %}