{% comment %}
  Help Banner Section
  Support section with title, description, and dual CTAs
  Version: 1.0
{% endcomment %}

<style>
  .help-banner-section {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 20px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  }

  .help-banner-container {
    background: #f5f3f1;
    border-radius: 12px;
    padding: 50px 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
  }

  .help-banner-content {
    flex: 1;
    max-width: 600px;
  }

  .help-banner-title {
    font-size: 24px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #333;
    margin-bottom: 15px;
    line-height: 1.3;
  }

  .help-banner-description {
    font-size: 14px;
    line-height: 1.6;
    color: #666;
    margin: 0;
  }

  .help-banner-ctas {
    display: flex;
    gap: 15px;
    flex-shrink: 0;
    flex-direction:column;
  }

  .help-banner-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
    cursor: pointer;
    white-space: nowrap;
  }

  .help-banner-btn svg {
    width: 16px;
    height: 16px;
  }

  /* Primary CTA - Outlined */
  .help-banner-btn--primary {
    background: transparent;
    color: #A68380;
    border: 2px solid #A68380;
  }

  .help-banner-btn--primary:hover {
    background: #A68380;
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(155, 133, 121, 0.2);
  }

  /* Secondary CTA - Filled */
  .help-banner-btn--secondary {
    background: #A68380;
    color: #fff;
    border: 2px solid #A68380;
  }

  .help-banner-btn--secondary:hover {
    background: #A68380;
    border-color:#A68380;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(155, 133, 121, 0.3);
  }

  /* Responsive Design */
  @media (max-width: 968px) {
    .help-banner-container {
      flex-direction: column;
      text-align: center;
      padding: 40px 30px;
    }

    .help-banner-content {
      max-width: 100%;
    }

    .help-banner-ctas {
      justify-content: center;
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .help-banner-section {
      padding: 30px 15px;
    }

    .help-banner-container {
      padding: 30px 20px;
    }

    .help-banner-title {
      font-size: 18px;
    }

    .help-banner-description {
      font-size: 12px;
    }

    .help-banner-ctas {
      flex-direction: row;
      width: 100%;
    }

    .help-banner-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<div class="help-banner-section">
  <div class="help-banner-container">
    
    <!-- Content Side -->
    <div class="help-banner-content">
      {% if section.settings.title != blank %}
        <h2 class="help-banner-title">{{ section.settings.title }}</h2>
      {% endif %}
      
      {% if section.settings.description != blank %}
        <p class="help-banner-description">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    <!-- CTA Buttons -->
    <div class="help-banner-ctas">
      {% if section.settings.primary_button_text != blank %}
        <a 
          href="{{ section.settings.primary_button_link | default: '#' }}" 
          class="help-banner-btn help-banner-btn--primary"
          {% if section.settings.primary_button_link == blank %}onclick="return false;"{% endif %}
        >
          {% if section.settings.show_primary_icon %}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          {% endif %}
          {{ section.settings.primary_button_text }}
        </a>
      {% endif %}

      {% if section.settings.secondary_button_text != blank %}
        <a 
          href="{{ section.settings.secondary_button_link | default: 'tel:' }}" 
          class="help-banner-btn help-banner-btn--secondary"
        >
          {% if section.settings.show_secondary_icon %}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          {% endif %}
          {{ section.settings.secondary_button_text }}
        </a>
      {% endif %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Help Banner",
  "tag": "section",
  "class": "section-help-banner",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Still unsure about your ring size ?"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquasequat."
    },
    {
      "type": "header",
      "content": "Primary Button (Outlined)"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Button Text",
      "default": "Chat with Expert"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Button Link",
      "info": "Link to chat page, contact form, or external chat widget"
    },
    {
      "type": "checkbox",
      "id": "show_primary_icon",
      "label": "Show Chat Icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Secondary Button (Filled)"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Button Text",
      "default": "Call Us"
    },
    {
      "type": "text",
      "id": "secondary_button_link",
      "label": "Phone Number or Link",
      "info": "Format: tel:+1234567890 or any URL",
      "default": "tel:+1234567890"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_icon",
      "label": "Show Phone Icon",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Help Banner",
      "settings": {
        "title": "Still unsure about your ring size ?",
        "description": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, ut aliquasequat.",
        "primary_button_text": "Chat with Expert",
        "primary_button_link": "/pages/contact",
        "show_primary_icon": true,
        "secondary_button_text": "Call Us",
        "secondary_button_link": "tel:+1234567890",
        "show_secondary_icon": true
      }
    }
  ]
}
{% endschema %}
