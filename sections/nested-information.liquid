{% comment %}
Nested Information Page Section - Metaobject Version
Scalable architecture with unlimited nested content
Fully compatible with metaobject structure
{% endcomment %}

{% assign nested_page = shop.metaobjects.nested_info_page[section.settings.nested_page_metaobject] %}

{% if nested_page %}
  <div class="nested-info-wrapper" data-section-id="{{ section.id }}">
    <!-- BANNER SECTION -->
    <div class="banner-container">
      <!-- Desktop Banner -->
      <picture class="banner-image banner-desktop">
        {% if nested_page.banner_image_desktop %}
          {% assign img_url = nested_page.banner_image_desktop | image_url: width: 1920 %}
          <img 
            src="{{ img_url }}" 
            alt="{{ nested_page.banner_alt_text | default: 'Banner' }}" 
            loading="lazy"
            width="1920"
            height="600"
          >
        {% else %}
          <div class="placeholder">Desktop Banner (1920x600px)</div>
        {% endif %}
      </picture>

      <!-- Mobile Banner -->
      <picture class="banner-image banner-mobile">
        {% if nested_page.banner_image_mobile %}
          {% assign img_url = nested_page.banner_image_mobile | image_url: width: 768 %}
          <img 
            src="{{ img_url }}" 
            alt="{{ nested_page.banner_alt_text | default: 'Banner' }}" 
            loading="lazy"
            width="768"
            height="600"
          >
        {% else %}
          <div class="placeholder">Mobile Banner (768x600px)</div>
        {% endif %}
      </picture>

      <!-- Primary Tabs (Bottom of Banner) -->
      {% if nested_page.primary_tab %}
        <div class="primary-tabs-container">
          <div class="primary-tabs">
            {% for primary_tab in nested_page.primary_tab %}
              <button 
                class="primary-tab-btn {% if forloop.first %}active{% endif %}" 
                data-tab-id="{{ forloop.index0 }}"
                type="button"
              >
                {{ primary_tab.tab_name }}
              </button>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>

    <!-- CONTENT SECTION -->
    <div class="content-wrapper">
      {% if nested_page.primary_tab %}
        {% for primary_tab in nested_page.primary_tab %}
          <div 
            class="primary-tab-content {% if forloop.first %}active{% endif %}" 
            data-primary-index="{{ forloop.index0 }}"
          >
            
            <!-- Secondary Tabs (Info Tabs) -->
            {% if primary_tab.show_secondary_tabs and primary_tab.information_tab %}
              <div class="secondary-tabs">
                {% for info_tab in primary_tab.information_tab %}
                  <button 
                    class="secondary-tab-btn {% if forloop.first %}active{% endif %}" 
                    data-info-index="{{ forloop.index0 }}"
                    type="button"
                  >
                    {{ info_tab.info_tab_name }}
                  </button>
                {% endfor %}
              </div>
            {% endif %}

            <!-- Info Tabs Content -->
            {% if primary_tab.information_tab %}
              {% for info_tab in primary_tab.information_tab %}
                <div 
                  class="info-tab-content {% if forloop.first %}active{% endif %}" 
                  data-info-index="{{ forloop.index0 }}"
                >
                  
                  <div class="info-layout">
                    <!-- Image Column -->
                    <div class="info-image-col">
                      {% if info_tab.info_image %}
                        {% assign img_url = info_tab.info_image | image_url: width: 500 %}
                        <img 
                          src="{{ img_url }}" 
                          alt="{{ info_tab.info_image_alt | default: 'Product Image' }}" 
                          loading="lazy"
                          width="500"
                          height="600"
                        >
                      {% else %}
                        <div class="placeholder info-placeholder">Product Image (500x600px)</div>
                      {% endif %}

                      <!-- Info Tab Button -->
                      {% if info_tab.button_text and info_tab.button_link %}
                        <a href="{{ info_tab.button_link }}" class="info-btn">
                          {{ info_tab.button_text }}
                        </a>
                      {% endif %}
                    </div>

                    <!-- Content Column -->
                    <div class="info-content-col">
                      <h2 class="info-header">{{ info_tab.info_header }}</h2>
                      
                      {% if info_tab.info_description %}
                        <div class="info-description">
                          {{ info_tab.info_description }}
                        </div>
                      {% endif %}

                      <!-- Related Topics Section -->
                      {% if info_tab.show_related_topics and info_tab.related_topics %}
                        <div class="related-topics">
                          <h3>Related Topics</h3>
                          <div class="topics-list">
                            {% for topic in info_tab.related_topics %}
                              <div class="topic-item">
                                {% if topic.link_type == 'blog_post' and topic.blog_post %}
                                  <a href="{{ topic.blog_post.url }}">
                                    {{ topic.topic_title }}
                                  </a>
                                {% elsif topic.link_type == 'custom_url' and topic.custom_url %}
                                  <a href="{{ topic.custom_url }}" {% if topic.custom_url contains 'http' %}target="_blank" rel="noopener noreferrer"{% endif %}>
                                    {{ topic.topic_title }}
                                  </a>
                                {% else %}
                                  <span class="topic-text">{{ topic.topic_title }}</span>
                                {% endif %}
                              </div>
                            {% endfor %}
                          </div>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                </div>
              {% endfor %}
            {% endif %}
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>

  <style>
    .nested-info-wrapper {
      width: 100%;
    }

    /* Banner Styles */
    .banner-container {
      position: relative;
      overflow: hidden;
    }

    .banner-image {
      width: 100%;
      display: block;
      margin: 0;
      padding: 0;
    }

    .banner-desktop {
      display: block;
    }

    .banner-mobile {
      display: none;
    }

    .banner-image img {
      width: 100%;
      height: auto;
      display: block;
    }

    .placeholder {
      background: #f0f0f0;
      height: 400px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #999;
      font-size: 16px;
      text-align: center;
    }

    /* Primary Tabs */
    .primary-tabs-container {
      background: rgba(0, 0, 0, 0.8);
      padding: 0;
      position: relative;
    }

    .primary-tabs {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0;
    }

    .primary-tab-btn {
      padding: 16px 24px;
      background: transparent;
      color: #fff;
      border: none;
      cursor: pointer;
      font-size: 14px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      transition: all 0.3s ease;
      border-bottom: 3px solid transparent;
    }

    .primary-tab-btn:hover {
      background: rgba(255, 255, 255, 0.1);
    }

    .primary-tab-btn.active {
      background: #fff;
      color: #000;
    }

    /* Content Area */
    .content-wrapper {
      background: #fff;
    }

    .primary-tab-content {
      display: none;
      padding: 60px 40px;
      animation: fadeIn 0.3s ease;
    }

    .primary-tab-content.active {
      display: block;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    /* Secondary Tabs (Info Tabs) */
    .secondary-tabs {
      display: flex;
      gap: 8px;
      margin-bottom: 40px;
      border-bottom: 1px solid #e5e5e5;
      padding-bottom: 0;
      flex-wrap: wrap;
    }

    .secondary-tab-btn {
      padding: 12px 20px;
      background: transparent;
      border: none;
      color: #999;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.3px;
      border-bottom: 3px solid transparent;
      transition: all 0.3s ease;
    }

    .secondary-tab-btn:hover {
      color: #666;
    }

    .secondary-tab-btn.active {
      color: #000;
      border-bottom-color: #000;
    }

    /* Info Tab Content */
    .info-tab-content {
      display: none;
    }

    .info-tab-content.active {
      display: block;
      animation: fadeIn 0.3s ease;
    }

    .info-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: flex-start;
    }

    .info-image-col {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .info-image-col img {
      width: 100%;
      height: auto;
      display: block;
    }

    .info-placeholder {
      aspect-ratio: 4/5;
      background: #f0f0f0;
      border-radius: 4px;
    }

    .info-btn {
      display: inline-block;
      padding: 12px 32px;
      background: #8b7b7b;
      color: #fff;
      text-align: center;
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-radius: 4px;
      transition: background 0.3s ease;
      cursor: pointer;
      border: none;
    }

    .info-btn:hover {
      background: #6d5f5f;
    }

    .info-content-col {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .info-header {
      font-size: 28px;
      font-weight: 600;
      color: #000;
      margin: 0;
    }

    .info-description {
      font-size: 14px;
      line-height: 1.8;
      color: #333;
      margin: 0;
    }

    .info-description p {
      margin: 0;
    }

    .info-description h1,
    .info-description h2,
    .info-description h3,
    .info-description h4,
    .info-description h5,
    .info-description h6 {
      margin: 16px 0 8px 0;
      font-weight: 600;
    }

    .info-description ul,
    .info-description ol {
      margin: 12px 0;
      padding-left: 20px;
    }

    .info-description li {
      margin: 6px 0;
    }

    /* Related Topics */
    .related-topics {
      margin-top: 30px;
      padding-top: 30px;
      border-top: 1px solid #e5e5e5;
    }

    .related-topics h3 {
      font-size: 14px;
      font-weight: 600;
      text-transform: uppercase;
      color: #000;
      margin: 0 0 20px 0;
    }

    .topics-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .topic-item {
      padding: 12px 0;
      border-bottom: 1px solid #f0f0f0;
    }

    .topic-item a,
    .topic-item .topic-text {
      color: #333;
      text-decoration: none;
      font-size: 13px;
      transition: color 0.3s ease;
      display: block;
    }

    .topic-item a:hover {
      color: #666;
    }

    .topic-item:last-child {
      border-bottom: none;
    }

    /* Mobile Responsive */
    @media (max-width: 768px) {
      .banner-desktop {
        display: none;
      }

      .banner-mobile {
        display: block;
      }

      .primary-tabs {
        justify-content: flex-start;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        padding: 0 10px;
      }

      .primary-tab-btn {
        white-space: nowrap;
        flex-shrink: 0;
        padding: 14px 16px;
        font-size: 12px;
      }

      .content-wrapper {
        padding: 30px 20px;
      }

      .primary-tab-content {
        padding: 30px 0;
      }

      .secondary-tabs {
        flex-wrap: nowrap;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        margin-bottom: 30px;
        padding: 0 0 8px 0;
      }

      .info-layout {
        grid-template-columns: 1fr;
        gap: 30px;
      }

      .info-header {
        font-size: 22px;
      }

      .secondary-tab-btn {
        white-space: nowrap;
        flex-shrink: 0;
        padding: 10px 16px;
        font-size: 12px;
      }

      .info-description {
        font-size: 13px;
        line-height: 1.6;
      }
    }

    @media (max-width: 480px) {
      .primary-tab-content {
        padding: 20px 0;
      }

      .content-wrapper {
        padding: 20px 15px;
      }

      .info-header {
        font-size: 18px;
      }

      .info-layout {
        gap: 20px;
      }
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const wrapper = document.querySelector('[data-section-id="{{ section.id }}"]');
      
      if (!wrapper) return;

      // Primary Tab Click Handler
      const primaryTabBtns = wrapper.querySelectorAll('.primary-tab-btn');
      primaryTabBtns.forEach(btn => {
        btn.addEventListener('click', function() {
          const tabIndex = this.dataset.tabId;
          
          // Remove active from all primary tabs and content
          primaryTabBtns.forEach(b => b.classList.remove('active'));
          wrapper.querySelectorAll('.primary-tab-content').forEach(content => {
            content.classList.remove('active');
          });
          
          // Add active to clicked tab
          this.classList.add('active');
          const activeContent = wrapper.querySelector(`[data-primary-index="${tabIndex}"]`);
          if (activeContent) {
            activeContent.classList.add('active');
          }
          
          // Reset secondary tabs to first
          resetSecondaryTabs(tabIndex);
        });
      });

      // Secondary Tab (Info Tab) Click Handler
      const secondaryTabBtns = wrapper.querySelectorAll('.secondary-tab-btn');
      secondaryTabBtns.forEach(btn => {
        btn.addEventListener('click', function() {
          const infoIndex = this.dataset.infoIndex;
          const parent = this.closest('.primary-tab-content');
          
          if (!parent) return;
          
          // Remove active from all secondary tabs and content in this section
          parent.querySelectorAll('.secondary-tab-btn').forEach(b => {
            b.classList.remove('active');
          });
          parent.querySelectorAll('.info-tab-content').forEach(content => {
            content.classList.remove('active');
          });
          
          // Add active to clicked tab
          this.classList.add('active');
          const activeInfoContent = parent.querySelector(`[data-info-index="${infoIndex}"]`);
          if (activeInfoContent) {
            activeInfoContent.classList.add('active');
          }
        });
      });

      function resetSecondaryTabs(primaryTabIndex) {
        const parent = wrapper.querySelector(`[data-primary-index="${primaryTabIndex}"]`);
        if (parent) {
          const firstSecondaryBtn = parent.querySelector('.secondary-tab-btn');
          if (firstSecondaryBtn) {
            firstSecondaryBtn.click();
          } else {
            // If no secondary tabs, activate first info tab
            const firstInfoTab = parent.querySelector('.info-tab-content');
            if (firstInfoTab) {
              firstInfoTab.classList.add('active');
            }
          }
        }
      }

      // Click first tab on load
      if (primaryTabBtns.length > 0) {
        primaryTabBtns[0].click();
      }
    });
  </script>
{% else %}
  <div style="padding: 40px; background: #f9f9f9; text-align: center; border: 2px dashed #ddd; border-radius: 4px; margin: 20px;">
    <p style="color: #666; margin: 0; font-size: 14px;">
      ⚠️ Please select a <strong>Nested Information Page</strong> metaobject in section settings
    </p>
  </div>
{% endif %}

{% schema %}
{
  "name": "Nested Information Page",
  "settings": [
    {
      "type": "text",
      "id": "nested_page_metaobject",
      "label": "Nested Information Page Handle"
    }
  ],
  "presets": [
    {
      "name": "Nested Information Page"
    }
  ]
}
{% endschema %}