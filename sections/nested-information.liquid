      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      transition: all 0.3s ease;
      border-bottom: 3px solid transparent;
    }

    .primary-tab-btn:hover {
      background: rgba(255, 255, 255, 0.1);
    }

    .primary-tab-btn.active {
      background: #fff;
      color: #000;
    }

    /* Content Area */
    .content-wrapper {
      background: #fff;
    }

    .primary-tab-content {
      display: none;
      padding: 60px 40px;
      animation: fadeIn 0.3s ease;
    }

    .primary-tab-content.active {
      display: block;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    /* Secondary Tabs (Info Tabs) */
    .secondary-tabs {
      display: flex;
      gap: 8px;
      margin-bottom: 40px;
      border-bottom: 1px solid #e5e5e5;
      padding-bottom: 0;
      flex-wrap: wrap;
    }

    .secondary-tab-btn {
      padding: 12px 20px;
      background: transparent;
      border: none;
      color: #999;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.3px;
      border-bottom: 3px solid transparent;
      transition: all 0.3s ease;
    }

    .secondary-tab-btn:hover {
      color: #666;
    }

    .secondary-tab-btn.active {
      color: #000;
      border-bottom-color: #000;
    }

    /* Info Tab Content */
    .info-tab-content {
      display: none;
    }

    .info-tab-content.active {
      display: block;
      animation: fadeIn 0.3s ease;
    }

    .info-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: flex-start;
    }

    .info-image-col {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .info-image-col img {
      width: 100%;
      height: auto;
    }

    .info-placeholder {
      aspect-ratio: 4/5;
      background: #f0f0f0;
      border-radius: 4px;
    }

    .info-btn {
      display: inline-block;
      padding: 12px 32px;
      background: #8b7b7b;
      color: #fff;
      text-align: center;
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-radius: 4px;
      transition: background 0.3s ease;
      cursor: pointer;
      border: none;
    }

    .info-btn:hover {
      background: #6d5f5f;
    }

    .info-content-col {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .info-header {
      font-size: 28px;
      font-weight: 600;
      color: #000;
      margin: 0;
    }

    .info-description {
      font-size: 14px;
      line-height: 1.8;
      color: #333;
      margin: 0;
    }

    .info-description p {
      margin: 0;
    }

    /* Related Topics */
    .related-topics {
      margin-top: 30px;
      padding-top: 30px;
      border-top: 1px solid #e5e5e5;
    }

    .related-topics h3 {
      font-size: 14px;
      font-weight: 600;
      text-transform: uppercase;
      color: #000;
      margin: 0 0 20px 0;
    }

    .topics-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .topic-item {
      padding: 12px 0;
      border-bottom: 1px solid #f0f0f0;
    }

    .topic-item a,
    .topic-item span {
      color: #333;
      text-decoration: none;
      font-size: 13px;
      transition: color 0.3s ease;
    }

    .topic-item a:hover {
      color: #666;
    }

    .topic-item:last-child {
      border-bottom: none;
    }

    /* Mobile Responsive */
    @media (max-width: 768px) {
      .banner-desktop {
        display: none;
      }

      .banner-mobile {
        display: block;
      }

      .primary-tabs {
        justify-content: flex-start;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      .primary-tab-btn {
        white-space: nowrap;
        flex-shrink: 0;
      }

      .content-wrapper {
        padding: 30px 20px;
      }

      .primary-tab-content {
        padding: 30px 0;
      }

      .secondary-tabs {
        flex-wrap: nowrap;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        margin-bottom: 30px;
      }

      .info-layout {
        grid-template-columns: 1fr;
        gap: 30px;
      }

      .info-header {
        font-size: 22px;
      }

      .secondary-tab-btn {
        white-space: nowrap;
        flex-shrink: 0;
      }
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const wrapper = document.querySelector('[data-section-id="{{ section.id }}"]');
      
      if (!wrapper) return;

      // Primary Tab Click Handler
      const primaryTabBtns = wrapper.querySelectorAll('.primary-tab-btn');
      primaryTabBtns.forEach(btn => {
        btn.addEventListener('click', function() {
          const tabIndex = this.dataset.tabId;
          
          // Remove active from all primary tabs and content
          primaryTabBtns.forEach(b => b.classList.remove('active'));
          wrapper.querySelectorAll('.primary-tab-content').forEach(content => {
            content.classList.remove('active');
          });
          
          // Add active to clicked tab
          this.classList.add('active');
          wrapper.querySelector(`[data-primary-index="${tabIndex}"]`).classList.add('active');
          
          // Reset secondary tabs to first
          resetSecondaryTabs(tabIndex);
        });
      });

      // Secondary Tab (Info Tab) Click Handler
      const secondaryTabBtns = wrapper.querySelectorAll('.secondary-tab-btn');
      secondaryTabBtns.forEach(btn => {
        btn.addEventListener('click', function() {
          const infoIndex = this.dataset.infoIndex;
          const parent = this.closest('.primary-tab-content');
          
          if (!parent) return;
          
          // Remove active from all secondary tabs and content in this section
          parent.querySelectorAll('.secondary-tab-btn').forEach(b => {
            b.classList.remove('active');
          });
          parent.querySelectorAll('.info-tab-content').forEach(content => {
            content.classList.remove('active');
          });
          
          // Add active to clicked tab
          this.classList.add('active');
          parent.querySelector(`[data-info-index="${infoIndex}"]`).classList.add('active');
        });
      });

      function resetSecondaryTabs(primaryTabIndex) {
        const parent = wrapper.querySelector(`[data-primary-index="${primaryTabIndex}"]`);
        if (parent) {
          const firstSecondaryBtn = parent.querySelector('.secondary-tab-btn');
          if (firstSecondaryBtn) {
            firstSecondaryBtn.click();
          }
        }
      }

      // Click first tab on load
      if (primaryTabBtns.length > 0) {
        primaryTabBtns[0].click();
      }
    });
  </script>
{% else %}
  <div style="padding: 40px; background: #f9f9f9; text-align: center; border: 2px dashed #ddd; border-radius: 4px;">
    <p style="color: #666; margin: 0;">Please select a Nested Information Page metaobject in section settings</p>
  </div>
{% endif %}


