<div class="lucira-faq-blocks">
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'faq_block' %}
        <div class="faq-block-wrapper" {{ block.shopify_attributes }}>
          <div class="page-width">
            {% if block.settings.block_heading != blank or block.settings.block_description != blank %}
              <div class="faq-block-header">
                {% if block.settings.block_heading != blank %}
                  <h2 class="faq-block-title">{{ block.settings.block_heading }}</h2>
                {% endif %}
                {% if block.settings.block_description != blank %}
                  <p class="faq-block-description">{{ block.settings.block_description }}</p>
                {% endif %}
              </div>
            {% endif %}

            <div class="accordion accordion-block-{{ forloop.index }}">
              {% for i in (1..10) %}
                {% capture question_key %}faq_question_{{ i }}{% endcapture %}
                {% capture answer_key %}faq_answer_{{ i }}{% endcapture %}
                
                {% if block.settings[question_key] != blank and block.settings[answer_key] != blank %}
                  <div
                    itemscope
                    itemprop="mainEntity"
                    itemtype="https://schema.org/Question"
                    class="accordion-item"
                  >
                    <h3
                      itemprop="name"
                      class="accordion-title"
                      onclick="toggleAccordion(this, event)"
                      role="button"
                      tabindex="0"
                    >
                      {{ block.settings[question_key] }}
                      <span class="accordion-icon">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                          <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                    </h3>
                    <div
                      itemscope
                      itemprop="acceptedAnswer"
                      itemtype="https://schema.org/Answer"
                      class="accordion-content"
                    >
                      <div itemprop="text" class="accordion-text">
                        {{ block.settings[answer_key] }}
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
    {% endcase %}
  {% endfor %}
</div>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .lucira-faq-blocks {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    color: #333;
  }

  .faq-block-wrapper {
    padding: 60px 20px;
    border-bottom: 1px solid #f0f0f0;
  }

  .faq-block-wrapper:last-child {
    border-bottom: none;
  }

  .page-width {
    max-width: 1200px;
    margin: 0 auto;
  }

  .faq-block-header {
    margin-bottom: 50px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: flex-start;
  }

  .faq-block-title {
    font-size: 32px;
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .faq-block-description {
    font-size: 14px;
    line-height: 1.6;
    color: #666;
  }

  .accordion {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 0;
  }

  .accordion-item {
    border-bottom: 1px solid #e0e0e0;
  }

  .accordion-item:first-child .accordion-title {
    border-top: 1px solid #e0e0e0;
  }

  .accordion-title {
    background: #fff;
    border: none;
    padding: 20px 0;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.4;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s ease;
    color: #333;
    text-align: left;
    width: 100%;
    text-align: left;
  }

  .accordion-title:hover {
    color: #000;
  }

  .accordion-title:focus {
    outline: 2px solid #333;
    outline-offset: 2px;
  }

  .accordion-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: #999;
    margin-left: 12px;
  }

  .accordion-title.active .accordion-icon {
    transform: rotate(180deg);
    color: #333;
  }

  .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    background: #fafafa;
  }

  .accordion-content.active {
    max-height: 1000px;
  }

  .accordion-text {
    padding: 20px 0;
    font-size: 14px;
    line-height: 1.6;
    color: #666;
  }

  .accordion-text p {
    margin-bottom: 10px;
  }

  .accordion-text p:last-child {
    margin-bottom: 0;
  }

  .accordion-text ul,
  .accordion-text ol {
    margin-left: 20px;
    margin-bottom: 10px;
  }

  .accordion-text li {
    margin-bottom: 6px;
  }

  .accordion-text a {
    color: #333;
    text-decoration: underline;
  }

  .accordion-text a:hover {
    color: #000;
  }

  .accordion-text strong {
    font-weight: 600;
    color: #333;
  }

  .accordion-text em {
    font-style: italic;
  }

  /* Mobile Styles */
  @media (max-width: 768px) {
    .faq-block-wrapper {
      padding: 40px 16px;
    }

    .faq-block-header {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-bottom: 30px;
    }

    .faq-block-title {
      font-size: 24px;
    }

    .faq-block-description {
      font-size: 13px;
    }

    .accordion-title {
      padding: 16px 0;
      font-size: 14px;
    }

    .accordion-content.active {
      max-height: 1200px;
    }

    .accordion-text {
      padding: 16px 0;
      font-size: 13px;
    }

    .accordion-icon {
      width: 20px;
      height: 20px;
    }
  }

  @media (max-width: 480px) {
    .faq-block-wrapper {
      padding: 30px 12px;
    }

    .faq-block-title {
      font-size: 20px;
    }

    .faq-block-description {
      font-size: 12px;
    }

    .accordion-title {
      padding: 14px 0;
      font-size: 13px;
      gap: 8px;
    }

    .accordion-icon {
      width: 18px;
      height: 18px;
      margin-left: 8px;
    }
  }
</style>

<script>
  function toggleAccordion(element, event) {
    event.preventDefault();
    const content = element.nextElementSibling;
    const isActive = element.classList.contains('active');

    // Close all other accordions in the same group
    const accordion = element.closest('.accordion');
    accordion.querySelectorAll('.accordion-title').forEach(item => {
      if (item !== element) {
        item.classList.remove('active');
        if (item.nextElementSibling) {
          item.nextElementSibling.classList.remove('active');
        }
      }
    });

    // Toggle current accordion
    element.classList.toggle('active');
    if (content) {
      content.classList.toggle('active');
    }

    // Google Analytics event (optional)
    if (window.dataLayer) {
      window.dataLayer.push({
        event: 'faq_click',
        faq_question: element.textContent.trim(),
        location: 'faq_section'
      });
    }
  }

  // Allow keyboard navigation
  document.addEventListener('DOMContentLoaded', function() {
    const titles = document.querySelectorAll('.accordion-title');
    titles.forEach(title => {
      title.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          toggleAccordion(this, e);
        }
      });
    });
  });
</script>

