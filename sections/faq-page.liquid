      display: flex;
      justify-content: space-between;
      align-items: center;
      text-transform: uppercase;
    }

    .faq-block-description {
      font-size: 12px;
    }

    .header-right {
      position: relative;
      z-index: 1;
    }

    .faq-item {
      border-top: 1px solid #d8d8d8;
      padding: 16px 0;
      position: relative;
      z-index: 10;
    }

