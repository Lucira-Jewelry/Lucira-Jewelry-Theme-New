{% comment %} <div class="lucira-faq-blocks">
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'faq_block' %}
        <div class="faq-block-wrapper" {{ block.shopify_attributes }}>
          <div class="page-width">
            <div class="faq-block-header">
              <div class="header-left">
                {% if block.settings.block_heading != blank %}
                  <h2 class="faq-block-title">{{ block.settings.block_heading }}</h2>
                {% endif %}
                {% if block.settings.block_description != blank %}
                  <p class="faq-block-description">{{ block.settings.block_description }}</p>
                {% endif %}
              </div>

              <div class="header-right">
                {% for i in (1..10) %}
                  {% capture question_key %}faq_question_{{ i }}{% endcapture %}
                  {% capture answer_key %}faq_answer_{{ i }}{% endcapture %}
                  
                  {% if block.settings[question_key] != blank and block.settings[answer_key] != blank %}
                    <div class="faq-item">
                      <div class="faq-question-header" onclick="toggleFAQ(this, event)">
                        <p class="faq-question-text">{{ block.settings[question_key] }}</p>
                        <button class="faq-toggle-btn" aria-expanded="false" type="button">
                          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                            <path d="M6 9L12 15L18 9" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </button>
                      </div>
                      <div class="faq-answer">
                        <div class="faq-answer-text">{{ block.settings[answer_key] }}</div>
                      </div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
    {% endcase %}
  {% endfor %}
</div>

<style>
  @font-face {
    font-family: 'Futura Std';
    src: url('https://fonts.googleapis.com/css2?family=Futura:wght@400;500;600&display=swap');
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .lucira-faq-blocks {
    font-family: 'Futura Std', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
    color: #1a1a1a;
    background: #fff;
  }

  .faq-block-wrapper {
    padding: 60px 40px;
    {% comment %} border-bottom: 1px solid #e8e8e8; {% endcomment %}
  }

  .faq-block-wrapper:last-child {
    border-bottom: none;
  }

  .page-width {
    max-width: 1400px;
    margin: 0 auto;
  }

  .faq-block-header {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 60px;
    align-items: flex-start;
  }

  .header-left {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .header-right {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-block-title {
    font-size: 28px;
    font-weight: 500;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #000;
  }

  .faq-block-description {
    font-size: 13px;
    line-height: 1.7;
    color: #666;
    font-weight: 400;
  }

  .faq-item {
    border-top: 1px solid #d8d8d8;
    padding: 18px 0;
  }

  .faq-question-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
    cursor: pointer;
    width: 100%;
  }

  .faq-question-text {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.5;
    color: #1a1a1a;
    flex: 1;
    cursor: pointer;
  }

  .faq-toggle-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #999;
    transition: all 0.3s ease;
    width: 24px;
    height: 24px;
    min-width: 24px;
    min-height: 24px;
  }

  .faq-toggle-btn:hover {
    color: #333;
  }

  .faq-toggle-btn svg {
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-toggle-btn[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease, margin-top 0.4s ease;
    opacity: 0;
    margin-top: 0;
  }

  .faq-answer.active {
    max-height: 500px;
    opacity: 1;
    margin-top: 16px;
  }

  .faq-answer-text {
    font-size: 13px;
    line-height: 1.7;
    color: #666;
  }

  .faq-answer-text p {
    margin-bottom: 10px;
  }

  .faq-answer-text p:last-child {
    margin-bottom: 0;
  }

  .faq-answer-text ul,
  .faq-answer-text ol {
    margin-left: 20px;
    margin-bottom: 10px;
  }

  .faq-answer-text li {
    margin-bottom: 6px;
  }

  .faq-answer-text a {
    color: #1a1a1a;
    text-decoration: underline;
  }

  .faq-answer-text a:hover {
    color: #333;
  }

    .faq-item:nth-child(1) {
    border-top: none;
    }
  /* Tablet */
  @media (max-width: 1024px) {
    .faq-block-wrapper {
      padding: 50px 30px;
    }

    .faq-block-header {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .faq-block-title {
      font-size: 24px;
    }

    .faq-block-description {
      font-size: 12px;
    }

    .faq-question-text {
      font-size: 13px;
    }

    .faq-answer-text {
      font-size: 12px;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .faq-block-wrapper {
      padding: 40px 20px;
    }

    .faq-block-header {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .header-left {
      padding-bottom: 20px;
      border-bottom: 1px solid #d8d8d8;
    }

    .faq-block-title {
      font-size: 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      text-transform: uppercase;
    }

    {% comment %} .faq-block-title::after {
      content: '✕';
      font-size: 20px;
      cursor: pointer;
      color: #1a1a1a;
      font-weight: 400;
    } {% endcomment %}

    .faq-block-description {
      font-size: 12px;
      {% comment %} display: none; {% endcomment %}
    }

    .header-right {
      position: relative;
      z-index: 1;
    }

    .faq-item {
      border-top: 1px solid #d8d8d8;
      padding: 16px 0;
      position: relative;
      z-index: 10;
    }

    .faq-question-text {
      font-size: 13px;
    }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }

    .faq-answer.active {
      max-height: 1000px;
      margin-top: 16px;
      overflow: hidden;
    }

    .faq-answer-text {
      font-size: 12px;
      line-height: 1.6;
      color: #666;
    }

    .faq-toggle-btn {
      width: 20px;
      height: 20px;
      min-width: 20px;
      min-height: 20px;
    }

    .faq-toggle-btn svg {
      width: 20px;
      height: 20px;
    }
  }

  @media (max-width: 480px) {
    .faq-block-wrapper {
      padding: 30px 16px;
    }

    .faq-block-title {
      font-size: 18px;
    }

    .faq-block-title::after {
      font-size: 18px;
    }

    .faq-question-text {
      font-size: 12px;
    }

    .faq-toggle-btn {
      width: 18px;
      height: 18px;
      min-width: 18px;
      min-height: 18px;
    }

    .faq-toggle-btn svg {
      width: 18px;
      height: 18px;
    }
  }
</style>

<script>
  function toggleFAQ(header, event) {
    event.preventDefault();
    event.stopPropagation();
    
    const item = header.closest('.faq-item');
    const button = header.querySelector('.faq-toggle-btn');
    const answer = item.querySelector('.faq-answer');
    const isExpanded = button.getAttribute('aria-expanded') === 'true';

    // Close all other items in the same block
    const blockHeader = item.closest('.header-right');
    blockHeader.querySelectorAll('.faq-item').forEach(faqItem => {
      if (faqItem !== item) {
        const btn = faqItem.querySelector('.faq-toggle-btn');
        const ans = faqItem.querySelector('.faq-answer');
        btn.setAttribute('aria-expanded', 'false');
        ans.classList.remove('active');
      }
    });

    // Toggle current item
    button.setAttribute('aria-expanded', !isExpanded);
    answer.classList.toggle('active');

    // Analytics event
    if (window.dataLayer) {
      const question = item.querySelector('.faq-question-text').textContent;
      window.dataLayer.push({
        event: 'faq_click',
        faq_question: question,
        location: 'faq_section'
      });
    }
  }

  // Keyboard navigation
  document.addEventListener('DOMContentLoaded', function() {
    const buttons = document.querySelectorAll('.faq-toggle-btn');
    buttons.forEach((button) => {
      button.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          const header = this.closest('.faq-question-header');
          toggleFAQ(header, e);
        }
      });
    });
  });
</script>

