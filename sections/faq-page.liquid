</style>

<script>
  function toggleFAQ(header, event) {
    event.preventDefault();
    event.stopPropagation();
    
    const item = header.closest('.faq-item');
    const button = header.querySelector('.faq-toggle-btn');
    const answer = item.querySelector('.faq-answer');
    const isExpanded = button.getAttribute('aria-expanded') === 'true';

    // Close all other items in the same block
    const blockHeader = item.closest('.header-right');
    blockHeader.querySelectorAll('.faq-item').forEach(faqItem => {
      if (faqItem !== item) {
        const btn = faqItem.querySelector('.faq-toggle-btn');
        const ans = faqItem.querySelector('.faq-answer');
        btn.setAttribute('aria-expanded', 'false');
        jQuery(ans).slideUp(400);
      }
    });

    // Toggle current item with slideToggle
    button.setAttribute('aria-expanded', !isExpanded);
    jQuery(answer).slideToggle(400);

    // Analytics event
    if (window.dataLayer) {
      const question = item.querySelector('.faq-question-text').textContent;
      window.dataLayer.push({
        event: 'faq_click',
        faq_question: question,
        location: 'faq_section'
      });
    }
  }

  // Keyboard navigation
  document.addEventListener('DOMContentLoaded', function() {
    const buttons = document.querySelectorAll('.faq-toggle-btn');
    buttons.forEach((button) => {
      button.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          const header = this.closest('.faq-question-header');
          toggleFAQ(header, e);
        }
      });
    });
  });
</script>

