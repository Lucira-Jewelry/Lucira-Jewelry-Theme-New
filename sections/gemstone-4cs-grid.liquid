<section id="gem-4cs-{{ section.id }}" class="gem4cs">

  {% if section.settings.title != blank or section.settings.subtitle != blank %}
    <div class="gem4cs__header">
      {% if section.settings.title != blank %}
        <h2 class="gem4cs__title">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="gem4cs__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="gem4cs__grid">
    {% for block in section.blocks %}
      <div class="gem4cs__cell" {{ block.shopify_attributes }}>
        <div class="gem4cs__card" role="button" tabindex="0" aria-label="Tap to reveal {{ block.settings.title }}">

          {% comment %} FRONT — Image {% endcomment %}
          <div class="gem4cs__face gem4cs__face--front">
            {% if block.settings.image != blank or block.settings.image_mobile != blank %}
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 1000
                  | image_tag:
                    loading: 'lazy',
                    widths: '500, 800, 1000',
                    sizes: '(max-width: 767px) 100vw, 50vw',
                    class: 'gem4cs__img gem4cs-img--desktop',
                    alt: block.settings.image.alt | default: block.settings.title | escape
                }}
              {% endif %}
              {% if block.settings.image_mobile != blank %}
                {{
                  block.settings.image_mobile
                  | image_url: width: 1000
                  | image_tag:
                    loading: 'lazy',
                    widths: '500, 800, 1000',
                    sizes: '100vw',
                    class: 'gem4cs__img gem4cs-img--mobile',
                    alt: block.settings.image_mobile.alt | default: block.settings.title | escape
                }}
              {% endif %}
            {% else %}
              {{ 'collection-2' | placeholder_svg_tag: 'gem4cs__img gem4cs__img--placeholder' }}
            {% endif %}
            <div class="gem4cs__front-overlay">
              <p class="gem4cs__front-title">{{ block.settings.title }}</p>
              <p class="gem4cs__front-cta">
                <span class="gem4cs__cta-icon">&#8635;</span> Tap to Reveal
              </p>
            </div>
          </div>

          {% comment %} BACK — Content {% endcomment %}
          <div
            class="gem4cs__face gem4cs__face--back"
            style="background-color: {{ block.settings.back_color }};"
          >
            <div class="gem4cs__back-inner">
              <p class="gem4cs__back-title">{{ block.settings.title }}</p>
              {% if block.settings.description != blank %}
                <div class="gem4cs__back-desc">{{ block.settings.description }}</div>
              {% endif %}
            </div>
          </div>

        </div>
      </div>
    {% endfor %}
  </div>

</section>

<style>
  /* ─── TOKENS ─────────────────────────────────────────────── */
  #gem-4cs-{{ section.id }} {
    --gem-max-w:     94%;
    --gem-sec-py:     20px;
    --gem-sec-px:     20px;
    --gem-gap:        10px;
    --gem-cell-ratio: 1 / 1;           /* square cells */
    --gem-radius:     0px;
    --gem-title-size: {{ section.settings.title_size }}px;
    --gem-sub-size:   {{ section.settings.subtitle_size }}px;
    --gem-title-color: {{ section.settings.title_color }};
    --gem-sub-color:  {{ section.settings.subtitle_color }};
    --gem-front-title-size: {{ section.settings.card_title_size }}px;
    --gem-back-title-size:  {{ section.settings.card_title_size }}px;
    --gem-back-desc-size:   {{ section.settings.card_desc_size }}px;
    --gem-speed:0.5s;
  }

.gem4cs { padding: var(--gem-sec-py) var(--gem-sec-px); background: {{ section.settings.section_bg }}; }
.gem4cs__header { text-align: center; max-width: 620px; margin: 0 auto 40px; }

.gem4cs__title { font-size: 24px; color: var(--gem-title-color); letter-spacing: 0.12em; text-transform: uppercase; font-weight: 400; margin: 0 0 14px; line-height: 1.2; }

.gem4cs__subtitle { font-size: 16px; color: var(--gem-sub-color); line-height: 1.75; margin: 0; }


.gem4cs__grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gem-gap); max-width: var(--gem-max-w); margin: 0 auto; }

  /* ─── CELL ───────────────────────────────────────────────── */
.gem4cs__cell { aspect-ratio: var(--gem-cell-ratio); perspective: 1200px; cursor: pointer; }

  /* ─── CARD (3D wrapper) ──────────────────────────────────── */
.gem4cs__card { position: relative; width: 100%; height: 100%; transform-style: preserve-3d; transition: transform var(--gem-speed) cubic-bezier(0.45, 0, 0.55, 1); border-radius: var(--gem-radius); outline: none; }

.gem4cs__card.is-flipped { transform: rotateY(180deg); }

  /* ─── FACE (shared) ──────────────────────────────────────── */
.gem4cs__face { position: absolute; inset: 0; backface-visibility: hidden; -webkit-backface-visibility: hidden; overflow: hidden; border-radius: var(--gem-radius); }

  /* ─── FRONT ──────────────────────────────────────────────── */
.gem4cs__face--front { background: #111; }

.gem4cs__img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.6s ease; }
.gem4cs__img--placeholder { width: 100%; height: 100%; object-fit: cover; }

.gem4cs__cell:hover .gem4cs__img { transform: scale(1.04); }

.gem4cs__front-overlay { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; padding: 24px; background: linear-gradient( to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.0) 55% );
}

.gem4cs__front-title { color: #fff; font-size: var(--gem-front-title-size); letter-spacing: 0.15em; text-transform: uppercase; font-weight: 400; margin: 0 0 6px; text-align: center; }

.gem4cs__front-cta { color: rgba(255,255,255,0.75); font-size: 11px; letter-spacing: 0.08em; margin: 0; text-align: center; display: flex; align-items: center; gap: 5px; }

.gem4cs__cta-icon { font-size: 14px; display: inline-block; animation: gem-spin 2.5s linear infinite; }

  @keyframes gem-spin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* ─── BACK ───────────────────────────────────────────────── */
.gem4cs__face--back { transform: rotateY(180deg); display: flex; align-items: center; justify-content: center; }

.gem4cs__back-inner { padding: 32px; text-align: center; max-width: 520px; }

.gem4cs__back-title { color: #fff; font-size: var(--gem-back-title-size); letter-spacing: 0.18em; text-transform: uppercase; font-weight: 400; margin: 0 0 20px; }

.gem4cs__back-desc { color: rgba(255,255,255,0.88); font-size: var(--gem-back-desc-size); line-height: 1.75; }

  /* ─── FOCUS RING (accessibility) ────────────────────────── */
.gem4cs__card:focus-visible { box-shadow: 0 0 0 3px #fff, 0 0 0 5px rgba(0,0,0,0.4); }

  /* ─── MOBILE ─────────────────────────────────────────────── */
@media (max-width: 767px) {
.gem4cs__grid { grid-template-columns: 1fr; gap: 20px; }

.gem4cs__cell { aspect-ratio: 4 / 3; }

.gem4cs__back-inner { padding: 24px 20px; }

.gem4cs__back-title { font-size: calc(var(--gem-back-title-size) * 0.85); margin-bottom: 12px; }

.gem4cs__back-desc { font-size: calc(var(--gem-back-desc-size) * 0.95); }

.gem4cs__title { font-size: calc(var(--gem-title-size) * 0.78); }
}

/* Hide desktop card image on mobile only when a mobile variant exists */
#gem-4cs-{{ section.id }} .gem4cs__face--front:has(.gem4cs-img--mobile) .gem4cs-img--desktop {
  display: none;
}
@media (min-width: 768px) {
  #gem-4cs-{{ section.id }} .gem4cs-img--desktop { display: block !important; }
  #gem-4cs-{{ section.id }} .gem4cs-img--mobile  { display: none  !important; }
}
@media (max-width: 767px) {
  #gem-4cs-{{ section.id }} .gem4cs-img--mobile  { display: block !important; }
  /* gem4cs-img--desktop hidden via :has() above */
}
</style>

<script>
  (function () {
    var section = document.getElementById('gem-4cs-{{ section.id }}');
    if (!section) return;

    var cards = section.querySelectorAll('.gem4cs__card');

    cards.forEach(function (card) {
      // Click
      card.addEventListener('click', function () {
        toggleCard(card);
      });

      // Keyboard — Enter / Space
      card.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          toggleCard(card);
        }
      });
    });

    function toggleCard(card) {
      var isFlipped = card.classList.contains('is-flipped');

      // Close all others first
      cards.forEach(function (c) {
        c.classList.remove('is-flipped');
        c.setAttribute('aria-pressed', 'false');
      });

      if (!isFlipped) {
        card.classList.add('is-flipped');
        card.setAttribute('aria-pressed', 'true');
      }
    }
  })();
</script>

{% schema %}
{
  "name": "Gemstone 4C's Grid",
  "tag": "section",
  "class": "shopify-section-gem4cs",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "GEMSTONE 4C's"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Section Title Size",
      "min": 16,
      "max": 52,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtitle Size",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Card Title Size",
      "min": 12,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_desc_size",
      "label": "Card Description Size",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Grid Width",
      "min": 600,
      "max": 1600,
      "step": 40,
      "unit": "px",
      "default": 1200
    }
  ],
  "blocks": [
    {
      "type": "gem_card",
      "name": "Gem Card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image (Desktop)",
          "info": "Shown on screens ≥ 768px"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Card Image (Mobile)",
          "info": "Shown on screens < 768px. Falls back to desktop image if not set."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "CUT"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Reveal Description",
          "default": "<p>For most gems, a superior cut is marked by its ability to reflect light, symmetrical appearance and the luster of its polish. Excellent, very good, good, fair or poor is used to measure the quality of a gem's cut.</p>"
        },
        {
          "type": "color",
          "id": "back_color",
          "label": "Back Face Color",
          "default": "#6b6b6b"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gemstone 4C's Grid",
      "blocks": [
        {
          "type": "gem_card",
          "settings": {
            "title": "CUT",
            "back_color": "#6b6b6b"
          }
        },
        {
          "type": "gem_card",
          "settings": {
            "title": "CARAT",
            "back_color": "#5a7a6a"
          }
        },
        {
          "type": "gem_card",
          "settings": {
            "title": "COLOR",
            "back_color": "#7a6a8a"
          }
        },
        {
          "type": "gem_card",
          "settings": {
            "title": "CLARITY",
            "back_color": "#4a6a8a"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["*"]
  }
}
{% endschema %}
