{% comment %}
  Enhanced Price Guide Section for Dawn Theme
  Handles dynamic price breakdown based on variant metafields
  Optimized for PageSpeed Insights (lazy load, cached DOM, minimal reflows)
{% endcomment %}

{% capture 'variant_meta_fields' %}
{% for variant in product.variants %}
  {% if variant.metafields.DI-GoldPrice.variant_config != blank %}
    {{ variant.id | json }}: {{ variant.metafields.DI-GoldPrice.variant_config }}{% unless forloop.last %},{% endunless %}
  {% endif %}
{% endfor %}
{% endcapture %}

{% capture 'variants_data' %}
{% for variant in product.variants %}
  {{ variant.id }}: {{ variant | json }}{% unless forloop.last %},{% endunless %}
{% endfor %}
{% endcapture %}

<section id="price-guide-section" class="price-guide-section" style="display:none;">
  <div class="price-drawer-overlay" id="price-drawer-overlay"></div>
  <div class="price-drawer" id="price-drawer">
    <div class="price-drawer-wrapper">
      <!-- Header -->
      <div class="price-drawer-title-wrap">
        <div class="title-wrapper">
          {{ section.settings.price_breakup_title | default: 'Price Breakdown' }}
        </div>
        <div class="close-button" id="close-price-button" tabindex="0" role="button" aria-label="Close price breakdown">
          <i class="fa-solid fa-xmark"></i>
        </div>
      </div>

      <!-- Product Details -->
      <div class="price-breakup-product-details-wrapper">
        <div class="price-breakup-product-wrapper">
          <div class="price-breakup-rate-table-image-wrapper">
            <img
              id="price-drawer-image"
              src="{{ product.featured_image | img_url: '90x90' }}"
              width="90"
              height="90"
              alt="{{ product.title | escape }}"
              title="{{ product.title | escape }}"
              loading="lazy"
            />
          </div>
          <div class="rate-table-item-details">
            <p class="product-title" id="price-drawer-title">{{ product.title }}</p>
            <p class="product-sku" id="price-drawer-sku">SKU: {{ product.selected_or_first_available_variant.sku }}</p>
            <div class="product-prices" id="price-drawer-prices">
              {% if product.compare_at_price > product.price %}
                <span class="price sale" id="price-drawer-price" data-price="{{ product.price }}"></span>
                <del class="compare-price" id="price-drawer-compare-price" data-price="{{ product.compare_at_price }}"></del>
              {% else %}
                <span class="price" id="price-drawer-sale-price" data-price="{{ product.price }}"></span>
              {% endif %}
            </div>
          </div>
        </div>
      </div>

      <!-- Variant Details -->
      <div class="variant-details" id="price-drawer-variant-details">
        <div class="custom-rate-table">
          <div class="rate-table-variants">
            <div id="variant-titles" class="rate-table-variants-wrap"></div>
          </div>
          <div class="rate-table-breakdown">
            <!-- Metal Section -->
            <div class="rate-table-wrapper">
              <div class="summary">
                <div class="gpe-title">Metal</div>
                <div><span class="gpe-title" id="metal-price">-</span></div>
              </div>
              <table id="metal-table" class="table-responsive">
                <tr><td colspan="2">Loading...</td></tr>
              </table>
            </div>

            <!-- Diamond Section -->
            <div class="rate-table-wrapper" id="diamond-details" style="display: none;">
              <div class="summary">
                <div class="gpe-title">Diamond</div>
                <div><span class="gpe-title" id="diamond-price">-</span></div>
              </div>
              <table id="diamond-table" class="table-responsive">
                <tr><td colspan="3">Loading...</td></tr>
              </table>
            </div>

            <!-- Gemstone Section -->
            <div class="rate-table-wrapper" id="gemstone-details" style="display: none;">
              <div class="summary">
                <div class="gpe-title">Gemstone</div>
                <div><span class="gpe-title" id="gemstone-price">-</span></div>
              </div>
              <table id="gemstone-table" class="table-responsive">
                <tr><td colspan="4">Loading...</td></tr>
              </table>
            </div>

            <!-- Making Charges Section -->
            <div class="rate-table-wrapper">
              <div class="summary">
                <div class="gpe-title">Making Charges</div>
                <div><span class="gpe-title" id="making-price">-</span></div>
              </div>
              <table id="making-table" class="table-responsive">
                <tr><td colspan="2">Loading...</td></tr>
              </table>
            </div>

            <!-- Total Value Section -->
            <div class="rate-table-wrapper">
              <div class="summary">
                <div class="gpe-title">Total Value</div>
                <div><span class="gpe-title" id="total-price">-</span></div>
              </div>
              <table id="total-table" class="table-responsive">
                <tr><td colspan="2">Loading...</td></tr>
              </table>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // --- Cached DOM & Lazy Initialization ---
  const PriceGuideConfig = {
    variantConfigs: { {{ variant_meta_fields }} },
    variantsData: { {{ variants_data }} },
    metalPriceConfig: {% if shop.metafields.DI-GoldPrice.metal_prices %}{{ shop.metafields.DI-GoldPrice.metal_prices }}{% else %}{}{% endif %},
    shopStonePricings: {% if shop.metafields.DI-GoldPrice.stone_pricing %}{{ shop.metafields.DI-GoldPrice.stone_pricing }}{% else %}[]{% endif %},
    formulaDefaults: {% if shop.metafields.DI-GoldPrice.custom_fields %}{{ shop.metafields.DI-GoldPrice.custom_fields }}{% else %}null{% endif %},
    currentVariantId: {{ product.selected_or_first_available_variant.id }}
  };

  let priceGuideManager = null;
  function initializePriceGuide() {
    if (!priceGuideManager) {
      priceGuideManager = new PriceGuideManager(PriceGuideConfig);
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializePriceGuide);
  } else {
    initializePriceGuide();
  }
</script>

{% schema %}
{
  "name": "Price Breakup Drawer",
  "settings": [
    { "type": "text", "id": "price_breakup_title", "label": "Title", "default": "Price Breakup" }
  ],
  "presets": [ { "name": "Price Breakup Drawer" } ]
}
{% endschema %}