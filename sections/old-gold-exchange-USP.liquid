<style>
.brad_{{ section.id }} { padding-top: {{ section.settings.padding_top_desktop }}px; padding-bottom: {{ section.settings.padding_bottom_desktop }}px; }

@media (max-width: 767px) {
.brad_{{ section.id }} { padding-top: {{ section.settings.padding_top_mobile }}px; padding-bottom: {{ section.settings.padding_bottom_mobile }}px; }
}
.why-choose-old-gold{background-color:#fff;text-align:center}
.wcog-heading{margin:0;font-weight:500;font-size:24px;line-height:150%;text-align:center;vertical-align:middle;text-transform:uppercase;margin-bottom:0;line-height:1.7}
.wcog-subheading{margin:0;margin-bottom:40px;font-size:18px;font-weight:400;line-height:24px;text-align:center;vertical-align:middle}
.wcog-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.wcog_item_0{background-color:#f3e0cf}
.wcog_item_1{background-color:#f3dce0}
.wcog_item_2{background-color:#cce6cc}
.wcog_item_3{background-color:#d6eef4}
.wcog-item{border-radius:16px;padding:32px 24px;display:flex;flex-direction:column;align-items:center;justify-content:center}
.wcog-icon img{width:60px;height:60px}
.wcog-title{margin:0;font-weight:500;font-size:15px;line-height:1.7;vertical-align:middle;text-transform:uppercase;color:#1a1a1a;margin-top:12px}
.wcog-desc{font-weight:400;font-size:14px;line-height:1.7;text-align:center;vertical-align:middle;text-transform:capitalize;margin:0;margin-top:8px}
@media (max-width:1440px){
.wcog-heading{font-size:24px;margin-bottom:8px;line-height:1.7}
.wcog-subheading{font-size:18px;margin-bottom:45px}
}
@media (max-width:767px){
.wcog-grid{grid-template-columns:repeat(2,1fr);gap:12px}
.wcog-desc{font-size:10px}
.wcog-heading{font-size:18px;margin-bottom:0;line-height:1.7}
.wcog-subheading{margin-bottom:24px;font-size:12px}
.wcog-item{padding:20px 10px;border-radius:12px}
.wcog-icon img{width:40px;height:40px}
.wcog-title{margin-top:0;font-size:12px}
}
</style>

<section class="why-choose-old-gold brad_{{ section.id }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="wcog-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.subheading != blank %}
      <p class="wcog-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="wcog-grid">
      {% for block in section.blocks %}
        <div class="wcog-item wcog_item_{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="wcog-icon">
              <img src="{{ block.settings.icon | image_url: width: 100 }}" alt="{{ block.settings.title | escape }}">
            </div>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3 class="wcog-title">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3 class="wcog-desc">{{ block.settings.desc }}</h3>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>


{% schema %}
{
  "name": "Old Gold USP",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHY CHOOSE LUCIRA’S OLD GOLD EXCHANGE?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Lorem ipsum dolor sit amet, consectetur"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "default": 60,
      "min": 0,
      "max": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "default": 60,
      "min": 0,
      "max": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "default": 40,
      "min": 0,
      "max": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "default": 40,
      "min": 0,
      "max": 100,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Box",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Flexible Value"
        },
        {
          "type": "text",
          "id": "desc",
          "label": "Description",
          "default": "Perfect for gifts, weddings, and special milestones."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Old Gold USP",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}
