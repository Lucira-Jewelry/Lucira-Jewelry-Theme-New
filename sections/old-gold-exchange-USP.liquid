<style>
  .brad_{{ section.id }} {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  @media (max-width: 767px) {
    .brad_{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  .why-choose-old-gold {
    background-color: #fff;
    text-align: center;
  }

  .wcog-heading {
    margin: 0;
    font-weight: 500;
    font-size: 32px;
    line-height: 150%;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
    margin-bottom: 12px;
}

.wcog-subheading {
    margin: 0;
    margin-bottom: 40px;
    font-size: 32px;
    font-weight: 400;
    line-height: 24px;
    text-align: center;
    vertical-align: middle;    
  }

  .wcog-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  
  .wcog-item {
      background-color: #f7f3f2;
      border-radius: 16px;
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    
    .wcog-icon img {
        width: 60px;
        height: 60px;
    }
    
    .wcog-title {
        margin: 0;
        font-weight: 500;
        font-size: 24px;
        line-height: 150%;
        vertical-align: middle;
        text-transform: uppercase;
        color: #1A1A1A;
        margin-top: 16px;
    }
    @media (max-width: 767px) {
        .wcog-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }
        .wcog-heading {
            font-size: 18px;
            margin-bottom: 6px;
        }
        
        .wcog-subheading {
            margin-bottom: 24px;
            font-size: 12px;
        }
        .wcog-item {
      padding: 24px 11px;
      border-radius: 12px;

    }
    .wcog-icon img {
        width: 40px;
        height: 40px;
    }
    .wcog-title {
        margin-top: 12px;
        font-size: 16px;
    }
    }
</style>

<section class="why-choose-old-gold brad_{{ section.id }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="wcog-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.subheading != blank %}
      <p class="wcog-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="wcog-grid">
      {% for block in section.blocks %}
        <div class="wcog-item" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="wcog-icon">
              <img src="{{ block.settings.icon | image_url: width: 100 }}" alt="{{ block.settings.title | escape }}">
            </div>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3 class="wcog-title">{{ block.settings.title }}</h3>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>


{% schema %}
{
  "name": "Old Gold USP",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHY CHOOSE LUCIRA’S OLD GOLD EXCHANGE?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Lorem ipsum dolor sit amet, consectetur"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "default": 60,
      "min": 0,
      "max": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "default": 60,
      "min": 0,
      "max": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "default": 40,
      "min": 0,
      "max": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "default": 40,
      "min": 0,
      "max": 100,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Box",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Flexible Value"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Old Gold USP",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}
