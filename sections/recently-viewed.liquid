{%- endstyle -%}

{%- liquid
  assign products_to_display = 4
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_desktop_slider = section.settings.enable_desktop_slider
-%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient recently-viewed-products-{{ section.id }} rv-hidden">
  <div
    class="collection recently-viewed-products-container{% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %} section-{{ section.id }}-padding{% if section.settings.full_width %}  collection--full-width{% endif %}"
    id="recently-viewed-{{ section.id }}"
    data-id="{{ section.id }}"
  >
    <div class="collection__title title-wrapper title-wrapper--no-top-margin page-width title-wrapper--self-padded-tablet-down{% if show_desktop_slider %} collection__title--desktop-slider{% endif %}">
      {%- if section.settings.header != blank -%}
        <h2 class="title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.header }}
        </h2>
      {%- endif -%}
      {%- if section.settings.subheader != blank -%}
        <div class="collection__description{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <p>{{ section.settings.subheader }}</p>
        </div>
      {%- endif -%}
    </div>

    <div class="{% if section.settings.full_width %}slider-component-full-width{% endif %} page-width page-width-desktop{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      
      <!-- Mobile horizontal scroll container -->
      <div class="recently-viewed-mobile-scroll-{{ section.id }} mobile-only">
        <div class="recently-viewed-mobile-grid-{{ section.id }}" id="mobile-grid-{{ section.id }}">
          <!-- Products will be injected here by JavaScript -->
        </div>
      
      </div>

      <!-- Desktop grid container -->
      <ul
        id="desktop-grid-{{ section.id }}"
        data-id="{{ section.id }}"
        class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} recently-viewed-desktop-grid-{{ section.id }} desktop-only"
        role="list"
        aria-label="Recently viewed products"
      >
        <!-- Products will be injected here by JavaScript -->
      </ul>

      <!-- Placeholder: visible in editor or when explicitly shown -->
      <div class="recently-viewed-placeholder-{{ section.id }}" style="text-align:center; padding:40px; width:100%;">
        <p>Browse products to see your recently viewed items here.</p>
      </div>

    </div>

    {% if section.settings.image_shape == 'arch' %}
      {{ 'mask-arch.svg' | inline_asset_content }}
    {%- endif -%}
  </div>
</div>




<script>
document.addEventListener('DOMContentLoaded', function () {
  const SECTION_ID = '{{ section.id }}';
  const STORAGE_KEY = 'recentlyViewedProducts';
  const EXPIRY_DAYS = 30;
  const MAX_PRODUCTS = 4;
  const PRODUCTS_PER_PAGE = 2;
  const CURRENCY = '{{ shop.currency }}';
  const PLACEHOLDER_IMG = 'https://via.placeholder.com/400x500/ffffff/cccccc?text=Product+Image';
  const MIN_PRODUCTS_TO_SHOW = 1;
  // Use Liquid to pass the admin toggle into JS
  const SHOW_SECONDARY = {{ section.settings.show_secondary_image | json }};

  class RecentlyViewedProducts {
    constructor(sectionId) {
      this.sectionId = sectionId;
      this.storageKey = STORAGE_KEY;
      this.expiryMs = EXPIRY_DAYS * 24 * 60 * 60 * 1000;
      this.maxProducts = MAX_PRODUCTS;
      this.currency = CURRENCY;
      this.currentSlide = 0;
      this.totalSlides = 0;
      this.productsPerPage = PRODUCTS_PER_PAGE;
      this.currentHandle = this.getPageHandle();
      this.init();
    }

    getPageHandle() {
      if (!window.location.pathname) return null;
      const match = window.location.pathname.split('/products/')[1];
      if (!match) return null;
      return match.split('/')[0] || null;
    }

    init() {
      const container = document.getElementById(`recently-viewed-${this.sectionId}`);
      const wrap = container ? container.closest(`.recently-viewed-products-${this.sectionId}`) : null;

      if (wrap && !(window.Shopify && Shopify.designMode)) {
        wrap.classList.add('rv-hidden');
      } else if (wrap && window.Shopify && Shopify.designMode) {
        wrap.classList.remove('rv-hidden');
        wrap.classList.add('shopify-editor-visible');
      }

      this.checkAndDisplaySection();

      if (window.location.pathname.includes('/products/')) {
        setTimeout(() => this.trackCurrentProduct(), 600);
      }

      document.addEventListener('recentlyViewedUpdated', () => setTimeout(() => this.checkAndDisplaySection(), 100));
      document.addEventListener('shopify:section:load', () => this.checkAndDisplaySection());
    }

    checkAndDisplaySection() {
      const container = document.getElementById(`recently-viewed-${this.sectionId}`);
      if (!container) return;
      const topSection = container.closest(`.recently-viewed-products-${this.sectionId}`) || container;

      if (window.Shopify && Shopify.designMode) {
        topSection.classList.remove('rv-hidden');
        topSection.classList.add('shopify-editor-visible');
        const items = this.getRecentlyViewed();
        const itemsExcludingCurrent = this.excludeCurrent(items);
        if (itemsExcludingCurrent.length >= MIN_PRODUCTS_TO_SHOW) this.displayRecentlyViewed();
        else topSection.classList.add('rv-show-placeholder');
        return;
      }

      const items = this.getRecentlyViewed();
      const itemsExcludingCurrent = this.excludeCurrent(items);
      if (!itemsExcludingCurrent.length || itemsExcludingCurrent.length < MIN_PRODUCTS_TO_SHOW) {
        topSection.classList.add('rv-hidden');
        topSection.classList.remove('shopify-editor-visible', 'rv-show-placeholder');
      } else {
        topSection.classList.remove('rv-hidden', 'rv-show-placeholder');
        this.displayRecentlyViewed();
      }
    }

    excludeCurrent(items) {
      if (!this.currentHandle) return items;
      return items.filter(p => p.handle !== this.currentHandle);
    }

    trackCurrentProduct() {
      const handle = this.currentHandle;
      if (!handle) return;

      const fromShopify = (window.Shopify && Shopify.product) ? window.Shopify.product : null;
      const getVariantIdFromDOM = () => {
        const input = document.querySelector('form[action*="/cart/add"] [name="id"], form[action*="/cart/add"] input[name="id"]');
        if (input && input.value) return input.value;
        const urlVariantMatch = window.location.search.match(/variant=(\d+)/);
        if (urlVariantMatch) return urlVariantMatch[1];
        return null;
      };

      let data = null;

      if (fromShopify) {
        const selectedVariant = fromShopify.selected_or_first_available_variant || (fromShopify.variants && fromShopify.variants[0]) || null;
        const variantId = (selectedVariant && selectedVariant.id) || getVariantIdFromDOM() || null;
        data = {
          id: variantId || (fromShopify.id || `product_${Date.now()}`),
          handle: fromShopify.handle || handle,
          title: fromShopify.title || '',
          featured_image: this.getProductImageUrl(fromShopify.featured_image),
          price_text: this.getCurrentProductPrice(),
          vendor: fromShopify.vendor || '',
          url: `/products/${handle}`,
          timestamp: Date.now()
        };
      } else {
        const title = document.querySelector('h1.product__title, h1.product-title')?.textContent?.trim() || '';
        const variantId = document.querySelector('form[action*="/cart/add"] [name="id"]')?.value || getVariantIdFromDOM();
        data = {
          id: variantId || `product_${Date.now()}`,
          handle,
          title,
          featured_image: this.getProductImageFromDOM(),
          price_text: this.getCurrentProductPrice(),
          vendor: document.querySelector('.vendor, .product-vendor')?.textContent?.trim() || '',
          url: `/products/${handle}`,
          timestamp: Date.now()
        };
      }

      this.addToRecentlyViewed(data);
      document.dispatchEvent(new CustomEvent('recentlyViewedUpdated'));
    }

    getCurrentProductPrice() {
      const potentialSelectors = [
        '[data-product-price]',
        '[data-price]',
        '.price__regular .price-item',
        '.price-item--regular',
        '.product-price',
        '.price',
        '.money',
        '.price__sale',
        '.price__current'
      ];
      for (const selector of potentialSelectors) {
        const el = document.querySelector(selector);
        if (el) {
          const txt = el.getAttribute('data-price') || el.textContent?.trim();
          if (txt) return txt;
        }
      }
      const variantPriceEl = document.querySelector('[data-variant-price]') || document.querySelector('.variant-price');
      if (variantPriceEl) {
        const txt = variantPriceEl.textContent?.trim();
        if (txt) return txt;
      }
      return '';
    }

    getProductImageUrl(imageData) {
      if (!imageData) return '';
      if (typeof imageData === 'string') return imageData;
      if (imageData.src) return imageData.src;
      return '';
    }

    getProductImageFromDOM() {
      const img = document.querySelector('.product__media img, .product-image img, .product-featured-image img, img[alt*="product"], img[alt*="Product"]');
      return img?.src || '';
    }

    addToRecentlyViewed(product) {
      try {
        let items = this.getRecentlyViewed();
        // Ensure uniqueness by handle (move existing to front)
        items = items.filter(p => p.handle !== product.handle);
        items.unshift(product);
        if (items.length > 12) items = items.slice(0, 12);
        localStorage.setItem(this.storageKey, JSON.stringify(items));
      } catch (e) {
        console.warn('rv: addItem failed', e);
      }
    }

    getRecentlyViewed() {
      try {
        const raw = localStorage.getItem(this.storageKey);
        if (!raw) return [];
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return [];
        const now = Date.now();
        const items = parsed.filter(p => (now - (p.timestamp || now)) < this.expiryMs);
        localStorage.setItem(this.storageKey, JSON.stringify(items));
        return items;
      } catch (e) {
        console.warn('rv: parse error', e);
        return [];
      }
    }

   
    async enrichProduct(product) {
  const handle = product.handle;
  if (!handle) return product;

  const needs = (!product.title || !product.featured_image || !product.price_text);
  if (!needs) return product;

  try {
    const resp = await fetch(`/products/${handle}.js`, { credentials: 'same-origin' });
    if (!resp.ok) return null; // Return null if product not found or not accessible
    
    const data = await resp.json();
    
    // Check if product is published/live (not drafted)
    if (!data.published_at) return null; // Product is drafted/unpublished
    
    // Check if product is available (inventory status)
    const isAvailable = data.available || 
                       (data.variants && data.variants.some(v => v.available)) || 
                       true; // Fallback to true if availability info not present
    
    if (!isAvailable) return null; // Product is not available for purchase

    // Use first image as primary and second as secondary if available
    const imagePrimary = (data.images && data.images.length) ? data.images[0] : (product.featured_image || '');
    const imageSecondary = (data.images && data.images.length > 1) ? data.images[1] : (product.featured_image || '');

    let displayPrice = product.price_text || '';
    let comparePrice = product.compare_price_text || '';

    if (data.variants && data.variants.length) {
      const storedVariantId = String(product.id || '').replace(/[^0-9]/g, '');
      let matchedVariant = null;
      if (storedVariantId) {
        matchedVariant = data.variants.find(v => String(v.id) === storedVariantId);
      }

      if (matchedVariant) {
        if (typeof matchedVariant.price !== 'undefined') {
          displayPrice = this.formatPrice(Number(matchedVariant.price));
        }
        if (typeof matchedVariant.compare_at_price !== 'undefined' && Number(matchedVariant.compare_at_price) > Number(matchedVariant.price)) {
          comparePrice = this.formatPrice(Number(matchedVariant.compare_at_price));
        }
      } else {
        if (typeof data.price !== 'undefined') {
          displayPrice = this.formatPrice(Number(data.price));
        }
        if (typeof data.compare_at_price !== 'undefined' && Number(data.compare_at_price) > Number(data.price)) {
          comparePrice = this.formatPrice(Number(data.compare_at_price));
        }
      }
    } else {
      if (typeof data.price !== 'undefined') {
        displayPrice = this.formatPrice(Number(data.price));
      }
      if (typeof data.compare_at_price !== 'undefined' && Number(data.compare_at_price) > Number(data.price)) {
        comparePrice = this.formatPrice(Number(data.compare_at_price));
      }
    }

    return {
      ...product,
      id: product.id || data.id,
      title: data.title || product.title || 'Product',
      featured_image: imagePrimary,
      secondary_image: imageSecondary,
      price_text: displayPrice,
      compare_price_text: comparePrice,
      vendor: product.vendor || data.vendor || '',
      url: product.url || `/products/${handle}`
    };
  } catch (e) {
    console.warn('rv: enrich fail', handle, e);
    return null; // Return null on any error
  }
}

    formatPrice(price) {
      if (typeof price === 'number') {
        const normalized = price > 1000 ? price / 100 : price;
        try {
          return new Intl.NumberFormat('en-IN', {
            style: 'currency',
            currency: this.currency,
            minimumFractionDigits: 0,
            maximumFractionDigits: 0
          }).format(normalized);
        } catch (e) {
          return (this.currency === 'INR' ? '₹' : '') + Math.round(normalized).toLocaleString();
        }
      }
      return price;
    }

    
    async displayRecentlyViewed() {
    const container = document.getElementById(`recently-viewed-${this.sectionId}`);
    if (!container) return;

    const mobileGrid = container.querySelector(`#mobile-grid-${this.sectionId}`);
    const desktopGrid = container.querySelector(`#desktop-grid-${this.sectionId}`);
    const placeholder = container.querySelector(`.recently-viewed-placeholder-${this.sectionId}`);

    let items = this.getRecentlyViewed();
    if (!items.length) {
      const topSection = container.closest(`.recently-viewed-products-${this.sectionId}`) || container;
      topSection.classList.add('rv-hidden');
      return;
    }

    if (placeholder) placeholder.style.display = 'none';

    items = this.excludeCurrent(items);
    const toShow = items.slice(0, this.maxProducts);
    const enriched = await Promise.all(toShow.map(p => this.enrichProduct(p)));
    
    // Filter out null products (drafted/unavailable products)
    const liveProducts = enriched.filter(product => product !== null);

    if (mobileGrid) mobileGrid.innerHTML = '';
    if (desktopGrid) desktopGrid.innerHTML = '';

