        priceHTML = `<div class="recently-viewed-card__price"><span class="recently-viewed-card__current-price">${product.price_text}</span></div>`;
      } else {
        priceHTML = `<div class="recently-viewed-card__price"><span class="recently-viewed-card__current-price">—</span></div>`;
      }

      const imageHTML = this.createImageStackHTML(product.featured_image, product.secondary_image, title);

      const dataAttrs = `data-product-id="${product.id || ''}" data-product-handle="${product.handle || ''}" data-product-name="${title}" data-product-price="${product.price_text || ''}" data-index="${index}"`;

      return `
        <li class="grid__item">
          <a href="${url}" ${dataAttrs} class="card-wrapper product-card-wrapper recently-viewed-card-wrapper recently-viewed-product-${this.sectionId}-${index} recently-viewed-card-link" aria-label="View ${title}">
            <div class="recently-viewed-card" role="group" aria-label="${title}">
              ${imageHTML}
              <div class="recently-viewed-card__content">
                <h3 class="recently-viewed-card__title">${title}</h3>
                ${priceHTML}
                {% comment %} <span class="recently-viewed-card__link visually-hidden">View Details</span> {% endcomment %}
              </div>
            </div>
          </a>
        </li>
      `;
    }

    initMobilePagination() {
      const mobileGridParent = document.querySelector(`#mobile-grid-${this.sectionId}`)?.parentElement;
      const mobileGrid = document.querySelector(`#mobile-grid-${this.sectionId}`);
      const paginationContainer = document.querySelector(`#pagination-${this.sectionId}`);
      if (!mobileGrid || !paginationContainer || !mobileGridParent) return;

      const items = mobileGrid.querySelectorAll(`.recently-viewed-mobile-item-{{ section.id }}`);
      const totalProducts = items.length;
      this.totalSlides = Math.ceil(totalProducts / this.productsPerPage);
      paginationContainer.innerHTML = '';

      for (let i = 0; i < this.totalSlides; i++) {
        const dot = document.createElement('div');
        dot.className = `pagination-dot ${i === 0 ? 'active' : ''}`;
        dot.setAttribute('data-index', i);
        dot.setAttribute('aria-label', `Go to page ${i + 1}`);
        dot.setAttribute('tabindex', '0');
        dot.addEventListener('click', () => this.goToSlide(i));
        dot.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); this.goToSlide(i); }
        });
        paginationContainer.appendChild(dot);

        
      }

      mobileGridParent.addEventListener('scroll', () => this.updateActiveDot());
      this.updateActiveDot();
    }

    updateActiveDot() {
      const mobileGridParent = document.querySelector(`#mobile-grid-${this.sectionId}`)?.parentElement;
      const paginationDots = document.querySelectorAll(`#pagination-${this.sectionId} .pagination-dot`);
      if (!mobileGridParent || !paginationDots.length) return;

      const scrollLeft = mobileGridParent.scrollLeft;
      const containerWidth = mobileGridParent.offsetWidth;
      const newSlide = Math.round(scrollLeft / containerWidth);

      if (newSlide !== this.currentSlide && newSlide >= 0 && newSlide < this.totalSlides) {
        this.currentSlide = newSlide;
        paginationDots.forEach((dot, index) => dot.classList.toggle('active', index === this.currentSlide));
      }
    }

    goToSlide(slideIndex) {
      const mobileGridParent = document.querySelector(`#mobile-grid-${this.sectionId}`)?.parentElement;
      if (!mobileGridParent) return;
      const containerWidth = mobileGridParent.offsetWidth;
      const scrollPosition = slideIndex * containerWidth;
      mobileGridParent.scrollTo({ left: scrollPosition, behavior: 'smooth' });
    }

    attachClickTracking() {
      const container = document.getElementById(`recently-viewed-${this.sectionId}`);
      if (!container) return;

      container.querySelectorAll('.recently-viewed-card-link').forEach(anchor => {
        anchor.removeEventListener('click', anchor._rv_click_handler);
        const handler = (e) => {
          try {
            const a = e.currentTarget;
            const pid = a.getAttribute('data-product-id') || '';
            const handle = a.getAttribute('data-product-handle') || '';
            const pname = a.getAttribute('data-product-name') || a.title || '';
            const pprice = a.getAttribute('data-product-price') || '';
            const idx = parseInt(a.getAttribute('data-index') || '0', 10);

            window.dataLayer = window.dataLayer || [];
            const promoObj = {
              event: "promoClick",
              promoClick: {
                promo_id: pid || handle || `promo_${Date.now()}`,
                creative_name: `product_image_recently_viewed`,
                promo_position: `recently_viewed_position_${idx + 1}`,
                product_id: pid || '',
                product_name: pname || '',
                image_position: 1,
                total_images: 1,
                media_type: "image",
                interaction_type: "click"
              }
            };
            window.dataLayer.push(promoObj);
          } catch (err) {
            console.warn('rv: tracking push failed', err);
          }
        };
        anchor._rv_click_handler = handler;
        anchor.addEventListener('click', handler);
      });
    }
  }

  const sectionEl = document.getElementById(`recently-viewed-${SECTION_ID}`);
  if (sectionEl) new RecentlyViewedProducts(SECTION_ID);
});
</script>  {% endcomment %}




