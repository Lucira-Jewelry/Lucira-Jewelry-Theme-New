{%- style -%}
.section-{{ section.id }}-padding{padding-top:36px;padding-bottom:28px}.recently-viewed-card-link{display:block;color:inherit;text-decoration:none;position:relative}.recently-viewed-card-link:focus{outline:3px solid rgba(0,0,0,0.12);outline-offset:3px}.visually-hidden{position:absolute!important;height:1px;width:1px;overflow:hidden;clip:rect(1px,1px,1px,1px);white-space:nowrap;border:0;padding:0;margin:-1px}.recently-viewed-products-{{ section.id }} .collection__title--desktop-slider .title{text-align:center;font-weight:400;font-size:28px;margin-bottom:0!important}.recently-viewed-products-{{ section.id }} h2.title.inline-richtext.h1{text-align:center;font-size:24px;margin-bottom:0}.recently-viewed-products-{{ section.id }} .collection__description p{color:#535361;font-weight:400;font-size:18px;line-height:2;text-align:center;margin:0 auto 30px!important;display:block}.recently-viewed-products-{{ section.id }} .recently-viewed-card{background:transparent;border:none;position:relative}.recently-viewed-products-{{ section.id }} .recently-viewed-card__image-container{position:relative;overflow:hidden;border-radius:6px;margin-bottom:4px}.recently-viewed-products-{{ section.id }} .recently-viewed-card__image{width:100%;height:auto;display:block;transition:transform .3s ease}.recently-viewed-products-{{ section.id }} .recently-viewed-card:hover .recently-viewed-card__image{transform:scale(1.05)}.recently-viewed-products-{{ section.id }} .recently-viewed-card__title{font-size:13px;font-weight:400;line-height:1.4;color:#1a1a1a;margin:6px 0 6px 0;text-align:left;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical}.recently-viewed-products-{{ section.id }} .recently-viewed-card__price{display:flex;flex-direction:row;align-items:center;gap:8px;margin-bottom:8px;margin-top:8px;flex-wrap:wrap}.recently-viewed-products-{{ section.id }} .recently-viewed-card__current-price{font-size:18px;font-weight:600;color:#1a1a1a;line-height:1.2}.recently-viewed-products-{{ section.id }} .recently-viewed-card__original-price{font-size:14px;color:#999;text-decoration:line-through;line-height:1.2}.recently-viewed-products-{{ section.id }} .recently-viewed-card__link{font-size:12px;color:#1a1a1a;text-decoration:none;font-weight:500;border-bottom:1px solid #1a1a1a;padding-bottom:2px;transition:all .3s ease}.recently-viewed-products-{{ section.id }} .recently-viewed-card__link:hover{color:#666;border-bottom-color:#666}.recently-viewed-products-{{ section.id }} .recently-viewed-card__content{padding:0 4px}

