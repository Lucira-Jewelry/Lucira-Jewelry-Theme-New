          try {
            const a = e.currentTarget;
            const pid = a.getAttribute('data-product-id') || '';
            const handle = a.getAttribute('data-product-handle') || '';
            const pname = a.getAttribute('data-product-name') || a.title || '';
            const pprice = a.getAttribute('data-product-price') || '';
            const idx = parseInt(a.getAttribute('data-index') || '0', 10);

            window.dataLayer = window.dataLayer || [];
            const promoObj = {
              event: "promoClick",
              promoClick: {
                promo_id: pid || handle || `promo_${Date.now()}`,
                creative_name: `Recently Viewed`,
                promo_position: `recently_viewed_position_${idx + 1}`,
                promo_name: pname || '',
                location_id:'PDP Bottom'
              }
            };
            window.dataLayer.push(promoObj);
          } catch (err) {
            console.warn('rv: tracking push failed', err);
          }
        };
        anchor._rv_click_handler = handler;
        anchor.addEventListener('click', handler);
      });
    }
  }

  const sectionEl = document.getElementById(`recently-viewed-${SECTION_ID}`);
  if (sectionEl) new RecentlyViewedProducts(SECTION_ID);
});
