@media (max-width:749px){.recently-viewed-products-{{ section.id }} .collection__title--desktop-slider .title{font-size:18px;letter-spacing:1px}.recently-viewed-products-{{ section.id }} .collection__description p{margin:0 auto 20px!important;font-size:14px}.recently-viewed-products-{{ section.id }} .recently-viewed-card__content{padding:0 6px}.recently-viewed-products-{{ section.id }} .card-wrapper.product-card-wrapper{border:1px solid #d9d9d9;overflow:hidden}.recently-viewed-products-{{ section.id }} .recently-viewed-card__current-price{font-size:14px}.recently-viewed-products-{{ section.id }} .recently-viewed-card__original-price{font-size:12px}.recently-viewed-products-{{ section.id }} h2.title.inline-richtext.h1{text-align:center;font-size:20px;margin-bottom:0}}

