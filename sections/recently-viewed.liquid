@media (min-width:1700px){.recently-viewed-desktop-grid-{{ section.id }}{margin:0 auto;gap:20px;justify-content:center;align-items:flex-start}.recently-viewed-desktop-grid-{{ section.id }} .grid__item{flex:0 0 calc((100% - 3 * 36px) / 4);max-width:370px;box-sizing:border-box}.recently-viewed-desktop-grid-{{ section.id }} .card-wrapper.product-card-wrapper{background:#fff;border-radius:8px;display:flex;flex-direction:column;justify-content:flex-start}.recently-viewed-desktop-grid-{{ section.id }} .recently-viewed-card__image-container{width:100%;display:flex;align-items:center;justify-content:center;overflow:hidden;border-radius:8px}.recently-viewed-desktop-grid-{{ section.id }} .recently-viewed-card__image{max-width:380px!important;object-fit:contain;transition:transform .25s ease}.recently-viewed-desktop-grid-{{ section.id }} .recently-viewed-card__content{padding-left:10px;text-align:left}.recently-viewed-desktop-grid-{{ section.id }} .recently-viewed-card__title{font-size:14px;line-height:1.3;margin:12px 0 12px 0;-webkit-line-clamp:1}.recently-viewed-desktop-grid-{{ section.id }} .recently-viewed-card__current-price{font-size:20px;font-weight:600;line-height:1.1}.recently-viewed-desktop-grid-{{ section.id }} .recently-viewed-card__original-price{font-size:14px}.recently-viewed-products-{{ section.id }} .collection__title--desktop-slider .title,.recently-viewed-products-{{ section.id }} h2.title.inline-richtext.h1{font-size:24px}.recently-viewed-products-{{ section.id }} .collection__description p{font-size:18px;max-width:900px;margin:0 auto 30px}}

/* editor & visibility */
.rv-hidden{display:none!important}.shopify-editor-visible{display:block!important}.recently-viewed-placeholder-{{ section.id }}{display:none}.shopify-editor-visible .recently-viewed-placeholder-{{ section.id }},.rv-show-placeholder .recently-viewed-placeholder-{{ section.id }}{display:block}

/* tiny screens */
@media (max-width:360px){.recently-viewed-mobile-item-{{ section.id }}{flex:0 0 calc(50vw - 18px);min-width:calc(50vw - 18px)}.recently-viewed-products-{{ section.id }} .recently-viewed-card__title{font-size:11px}.recently-viewed-products-{{ section.id }} .recently-viewed-card__current-price{font-size:12px}.recently-viewed-products-{{ section.id }} .recently-viewed-card__original-price{font-size:10px}}

/* image hover stack */
.recently-viewed-card__image-container{position:relative;background:#fff}.rv-image-stack img{display:block;width:100%;height:auto;object-fit:contain;backface-visibility:hidden}.rv-image-stack img.primary{position:relative;z-index:2;opacity:1}.rv-image-stack img.secondary{position:absolute;top:0;left:0;z-index:1;opacity:0;transform:scale(1.03);width:100%}.recently-viewed-card:hover .rv-image-stack img.primary{opacity:0;transform:scale(0.98)}.recently-viewed-card:hover .rv-image-stack img.secondary{opacity:1;transform:scale(1)}@media (hover:none),(pointer:coarse){.recently-viewed-card:hover .rv-image-stack img.primary,.recently-viewed-card:hover .rv-image-stack img.secondary{opacity:1;transform:none}}

/* extra large breakpoints */
@media (min-width:1900px){.recently-viewed-desktop-grid-{{ section.id }} .grid__item{width:421px;max-width:421px}.recently-viewed-card__image-container{height:auto!important}}@media (min-width:1500px){.recently-viewed-desktop-grid-{{ section.id }} .grid__item{width:330px;max-width:330px}.recently-viewed-card__image-container{height:auto!important}}@media (min-width:1700px){.recently-viewed-desktop-grid-{{ section.id }} .grid__item{width:374x;max-width:374px}.recently-viewed-card__image-container{height:auto!important}}

/* show scrollbar interaction tweaks on small */
@media (max-width:749px){.recently-viewed-mobile-scroll-{{ section.id }}{-webkit-overflow-scrolling:touch;scroll-behavior:smooth}.recently-viewed-mobile-scroll-{{ section.id }}:active::-webkit-scrollbar-thumb,.recently-viewed-mobile-scroll-{{ section.id }}:focus::-webkit-scrollbar-thumb,.recently-viewed-mobile-scroll-{{ section.id }}:hover::-webkit-scrollbar-thumb{background-color:#b67665}}

  .mobile-only{display:block !important;}
