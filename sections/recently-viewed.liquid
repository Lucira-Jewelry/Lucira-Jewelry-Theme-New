@media (max-width:749px){.recently-viewed-mobile-scroll-{{ section.id }}{overflow-x:scroll;overflow-y:hidden;scroll-behavior:smooth;-webkit-overflow-scrolling:touch;padding-bottom:14px;position:relative}.recently-viewed-mobile-scroll-{{ section.id }}::-webkit-scrollbar{height:2px;background-color:#F5F5F5}.recently-viewed-mobile-scroll-{{ section.id }}::-webkit-scrollbar-thumb{background-color:#b67665}.recently-viewed-mobile-scroll-{{ section.id }}::-webkit-scrollbar-track{background-color:#F5F5F5}.recently-viewed-mobile-grid-{{ section.id }}{display:flex;gap:8px}.recently-viewed-mobile-item-{{ section.id }}{flex:0 0 calc(50vw - 32px)}}

/* desktop grid */
.recently-viewed-desktop-grid-{{ section.id }}{display:flex;flex-wrap:wrap;gap:18px;justify-content:center;align-items:flex-start;max-width:100%}.recently-viewed-desktop-grid-{{ section.id }} .grid__item{flex:0 0 auto;border:1px solid #d9d9d9;border-radius:8px;max-width:308px;box-sizing:border-box}.recently-viewed-desktop-grid-{{ section.id }} .card-wrapper.product-card-wrapper{width:100%;display:block;overflow:hidden;}.recently-viewed-desktop-grid-{{ section.id }} .recently-viewed-card__content{padding:0 8px 4px 12px;text-align:left}.recently-viewed-desktop-grid-{{ section.id }} .recently-viewed-card__title{-webkit-line-clamp:1;overflow:hidden;text-overflow:ellipsis}

/* mid breakpoints */
@media (min-width:750px) and (max-width:1024px){.recently-viewed-desktop-grid-{{ section.id }}{gap:16px;padding:0 16px}.recently-viewed-desktop-grid-{{ section.id }} .grid__item{width:240px;max-width:240px}}@media (min-width:1025px) and (max-width:1280px){.recently-viewed-desktop-grid-{{ section.id }}{gap:18px}.recently-viewed-desktop-grid-{{ section.id }} .grid__item{width:260px;max-width:260px}}

