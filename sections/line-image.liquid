<section class="single-image-section">
  {% if section.settings.main_image %}
    <img
      src="{{ section.settings.main_image | image_url: width: 2000 }}"
      alt="{{ section.settings.main_image.alt | escape }}"
      loading="lazy"
      class="single-image"
    >
  {% endif %}
</section>

<style>
.single-image-section{width:100%;max-width:37.86%;margin:0 auto}
.single-image{width:100%;height:auto;display:block;object-fit:cover}
</style>

{% schema %}
{
  "name": "Line Image",
  "settings": [
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Upload Image"
    }
  ],
  "presets": [
    {
      "name": "Line Image"
    }
  ]
}
{% endschema %}
