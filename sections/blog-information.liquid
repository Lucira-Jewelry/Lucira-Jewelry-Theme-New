              </svg>
            </span>
            <span class="blog-meta-value">{{ article.comments_count }}</span>
          </div>
        {% endif %}
      </div>
    </div>

    <!-- Follow Us Section -->
    <div class="blog-header-right">
  <span class="follow-us-label">Follow Us:</span>
  <div class="social-icons">
    <!-- Facebook -->
    {% if section.settings.facebook_url != blank %}
      <a href="https://www.facebook.com/lucirajewelry/" class="social-link" aria-label="Follow us on Facebook" target="_blank" rel="noopener noreferrer">
