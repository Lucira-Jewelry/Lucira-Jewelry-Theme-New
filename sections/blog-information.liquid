{% comment %} <style>
  .blog-header-wrapper {
    width: 100%;
    justify-content: center;
    padding: 40px 150px;
  }

  .blog-header-container {
    max-width: 1140px;
    width: 100%;
    gap: 60px;
    align-items: start;
  }

  .blog-header-left {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .blog-header-title {
    font-size: 28px;
    font-weight: 400;
    letter-spacing: 0.08em;
    margin: 0;
    text-transform: uppercase;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    line-height: 1.3;
  }

  .blog-header-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    align-items: center;
  }

  .blog-meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .blog-meta-icon {
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .blog-meta-icon svg {
    width: 100%;
    height: 100%;
    fill: #666;
  }

  .blog-meta-value {
    font-size: 13px;
    color: #000;
    font-weight: 400;
  }

  .blog-header-right {
    display: flex;
    align-items: start;
  }

  .blog-header-description {
    font-size: 13px;
    line-height: 1.7;
    color: #333;
    margin: 0;
  }

  @media screen and (max-width: 968px) {
    .blog-header-container {
      gap: 30px;
    }

    .blog-header-title {
      font-size: 26px;
    }
  }

  @media screen and (max-width: 768px) {
    .blog-header-title {
      font-size: 17px;
    }

    .blog-header-meta {
      flex-direction: row;
      align-items: flex-start;
      gap: 15px;
    }

    .blog-header-wrapper {
      padding: 30px 15px;
    }
  }
</style>

<div class="blog-header-wrapper">
  <div class="blog-header-container">
    <div class="blog-header-left">
      {% if article.title != blank %}
        <h1 class="blog-header-title">{{ article.title }}</h1>
      {% endif %}

      <div class="blog-header-meta">
        {% if article.author != blank %}
          <div class="blog-meta-item">
            <span class="blog-meta-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
              </svg>
            </span>
            <span class="blog-meta-value" itemprop="author" itemscope itemtype="http://schema.org/Person">
              <span itemprop="name">{{ article.author }}</span>
            </span>
          </div>
        {% endif %}

        {% if article.published_at != blank %}
          <div class="blog-meta-item">
            <span class="blog-meta-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>
              </svg>
            </span>
            <span class="blog-meta-value" itemprop="dateCreated pubdate datePublished">
              {{ article.published_at | time_tag: format: 'date' }}
            </span>
          </div>
        {% endif %}

        {% if section.settings.reading_time != blank %}
          <div class="blog-meta-item">
            <span class="blog-meta-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 4h5v8l-2.5-1.5L6 12V4z"/>
              </svg>
            </span>
            <span class="blog-meta-value">{{ section.settings.reading_time }}</span>
          </div>
        {% endif %}

        {% if article.comments_enabled and article.comments_count > 0 %}
          <div class="blog-meta-item">
            <span class="blog-meta-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
              </svg>
            </span>
            <span class="blog-meta-value">{{ article.comments_count }}</span>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Blog Header",
  "settings": [
    {
      "type": "text",
      "id": "blog_title",
      "label": "Blog Title",
      "default": "Lorem Ipsum Dolor Sit Amet"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author Name",
      "default": "First Last Name"
    },
    {
      "type": "text",
      "id": "publication_date",
      "label": "Publication Date",
      "default": "18 November 2025",
      "info": "Enter date in your preferred format"
    },
    {
      "type": "text",
      "id": "reading_time",
      "label": "Reading Time",
      "default": "5 Mins"
    },
    {
      "type": "text",
      "id": "category",
      "label": "Category",
      "default": "Diamond"
    },
    {
      "type": "textarea",
      "id": "blog_description",
      "label": "Blog Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat."
    }
  ],
  "presets": [
    {
      "name": "Blog Header"
    }
  ]
}
{% endschema %} {% endcomment %}

<style>
  .blog-header-wrapper {
    width: 100%;
    justify-content: center;
    padding: 40px 150px;
  }

  .blog-header-container {
    max-width: 1140px;
    width: 100%;
    display: flex;
    gap: 60px;
    align-items: start;
    justify-content: space-between;
  }

  .blog-header-left {
    display: flex;
    flex-direction: column;
    gap: 25px;
    flex: 1;
  }

  .blog-header-title {
    font-size: 28px;
    font-weight: 400;
    letter-spacing: 0.08em;
    margin: 0;
    text-transform: uppercase;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    line-height: 1.3;
  }

  .blog-header-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    align-items: center;
  }

  .blog-meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .blog-meta-icon {
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .blog-meta-icon svg {
    width: 100%;
    height: 100%;
    fill: #666;
  }

  .blog-meta-value {
    font-size: 13px;
    color: #000;
    font-weight: 400;
  }

  .blog-header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 20px;
  }

  .follow-us-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #666;
    text-transform: uppercase;
  }

  .social-links {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .social-link {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-color: transparent;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .social-link:hover {
    background-color: #f0f0f0;
  }

  .social-link svg {
    width: 18px;
    height: 18px;
    fill: #0066cc;
    transition: fill 0.3s ease;
  }

  .social-link:hover svg {
    fill: #0052a3;
  }

  .blog-header-description {
    font-size: 13px;
    line-height: 1.7;
    color: #333;
    margin: 0;
  }

  @media screen and (max-width: 968px) {
    .blog-header-container {
      gap: 30px;
      flex-direction: column;
      align-items: flex-start;
    }

    .blog-header-right {
      align-items: flex-start;
    }

    .blog-header-title {
      font-size: 26px;
    }
  }

  @media screen and (max-width: 768px) {
    .blog-header-title {
      font-size: 17px;
    }

    .blog-header-meta {
      flex-direction: row;
      align-items: flex-start;
      gap: 15px;
    }

    .blog-header-wrapper {
      padding: 30px 15px;
    }

    .blog-header-right {
      width: 100%;
      align-items: flex-start;
    }
  }
</style>

<div class="blog-header-wrapper">
  <div class="blog-header-container">
    <div class="blog-header-left">
      {% if article.title != blank %}
        <h1 class="blog-header-title">{{ article.title }}</h1>
      {% endif %}

      <div class="blog-header-meta">
        {% if article.author != blank %}
