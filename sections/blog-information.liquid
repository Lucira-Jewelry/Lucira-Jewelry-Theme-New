    <!-- LinkedIn -->
    {% if section.settings.linkedin_url != blank %}
      <a href="https://www.linkedin.com/company/lucira-jewelry" class="social-link" aria-label="Follow us on LinkedIn" target="_blank" rel="noopener noreferrer">
        <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/linkedin_1.svg?v=1768547178" alt="LinkedIn Icon" class="social-icon-img" style="
    width: 24px;
    height: 24px;
">
      </a>
    {% endif %}
  </div>
</div>
  </div>
</div>

