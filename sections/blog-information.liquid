<script type="application/ld+json">
{
  "name": "Follow Us Section",
  "settings": [
    {
      "type": "text",
      "id": "follow_label",
      "label": "Follow Us Label",
      "default": "FOLLOW US ON:"
    },
    {
      "type": "header",
      "content": "Social Media Links"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL",
      "placeholder": "https://facebook.com/yourprofile"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "Pinterest URL",
      "placeholder": "https://pinterest.com/yourprofile"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL",
      "placeholder": "https://instagram.com/yourprofile"
    },
    {
      "type": "url",
      "id": "linkedin_url",
      "label": "LinkedIn URL",
      "placeholder": "https://linkedin.com/in/yourprofile"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label Text Color",
      "default": "#333333"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Follow Us Section",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Follow Us Section",
      "settings": {
        "facebook_url": "https://facebook.com",
        "pinterest_url": "https://pinterest.com",
        "instagram_url": "https://instagram.com",
        "linkedin_url": "https://linkedin.com"
      }
    }
  ]
}
</script>