    <!-- Pinterest -->
    {% if section.settings.pinterest_url != blank %}
      <a href="https://in.pinterest.com/Lucira_Jewelry/" class="social-link" aria-label="Follow us on Pinterest" target="_blank" rel="noopener noreferrer">
