  /* Follow Us Section Styles */
  .follow-us-wrapper {
    width: 100%;
    padding: 30px 150px;
    border-top: 1px solid #e5e5e5;
    background-color: #f9f9f9;
  }

  .follow-us-container {
    max-width: 1140px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 25px;
  }

  .follow-us-label {
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #333;
    white-space: nowrap;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  }

  .follow-us-icons {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .social-icon-link {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-color: #fff;
    border: 1px solid #e0e0e0;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .social-icon-link:hover {
    background-color: #f0f0f0;
    border-color: #999;
    transform: translateY(-2px);
  }

  .social-icon-link svg {
    width: 18px;
    height: 18px;
  }

  .facebook svg { fill: #1877f2; }
  .pinterest svg { fill: #e60023; }
  .instagram svg { fill: #e1306c; }
  .linkedin svg { fill: #0077b5; }

  @media screen and (max-width: 968px) {
    .blog-header-container {
      gap: 30px;
    }

    .blog-header-title {
      font-size: 26px;
    }

    .follow-us-wrapper {
      padding: 25px 100px;
    }
  }

  @media screen and (max-width: 768px) {
    .blog-header-title {
      font-size: 17px;
    }

    .blog-header-meta {
      flex-direction: row;
      align-items: flex-start;
      gap: 15px;
    }

    .blog-header-wrapper {
      padding: 30px 15px;
    }

    .follow-us-wrapper {
      padding: 20px 15px;
    }

    .follow-us-container {
      gap: 15px;
    }

    .follow-us-label {
      font-size: 12px;
    }

    .follow-us-icons {
      gap: 15px;
    }

    .social-icon-link {
      width: 32px;
      height: 32px;
    }

    .social-icon-link svg {
      width: 16px;
      height: 16px;
    }
  }
</style>

