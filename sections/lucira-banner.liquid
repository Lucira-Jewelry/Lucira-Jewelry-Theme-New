{%- comment -%}
  Nectar Rewards Banner Section
{%- endcomment -%}

<section
  class="inner-banner-section"
  id="banner-{{ section.id }}"
>
  <div class="page-width">
    <div class="inner-banner-wrapper">
      <div class="grid-row">
        <div class="grid-column">
          <div class="nector-reward-banner-content-wrapper">
            {% if section.settings.banner_heading != blank %}
              <h1>{{ section.settings.banner_heading }}</h1>
            {% endif %}
            {% if section.settings.banner_description != blank %}
              <p>
                {{ section.settings.banner_description }}
              </p>
            {% endif %}
            {% if section.settings.banner_button_text != blank %}
              <a href="{{ section.settings.banner_button_link | default: '#refer-and-earn' }}" class="button-design">
                {{ section.settings.banner_button_text }}
              </a>
            {% endif %}
          </div>
        </div>
        <div class="grid-column"></div>
      </div>
    </div>
  </div>
</section>

<style>
  section.inner-banner-section {background: url('{{ section.settings.bg_image_desktop | image_url }}') !important; background-repeat: no-repeat !important; background-size: cover !important; background-position: right top; position: relative;}
  section.inner-banner-section .inner-banner-wrapper .grid-row {display: grid; grid-template-columns: calc(50% - 0px) calc(50% - 0px); gap: 0px; height: 100vh; align-items: flex-start;}
  section.inner-banner-section h1 {color: #ffffff; margin: 0; font-family: 'Futura', sans-serif; font-weight: 500; font-size: 40px; line-height: 100%; text-transform: uppercase; margin-bottom: 40px; line-height: 1.3; max-width: 505px;}
  section.inner-banner-section p {color: #ffffff; max-width: 600px;}
  section.inner-banner-section p { font-family: 'Futura', sans-serif; font-weight: 400; font-size: 16px; line-height: 1.5; margin: 0; margin-bottom: 80px; }
  section.inner-banner-section a.button-design { background: #A68380; color: #ffffff; text-decoration: none; padding: 16px 32px; display: inline-block; max-width: 360px; width: 100%; text-align: center; border-radius: 20px; font-family: 'Futura', sans-serif; font-weight: 500; font-size: 16px; line-height: 1.2; text-transform: uppercase; }
  .page-video_call_pdp-template-page section.inner-banner-section:after { content: ""; position: absolute; left: 0; top: 0; width: 100%; height: 100%; background: linear-gradient(270deg, rgba(0, 0, 0, 0) 50%, #000000 100%); }
  section.inner-banner-section .page-width {z-index: 2;position: relative;}
  body.collection section.inner-banner-section:after {content: none !important;}
  .page-store-locator-template-page .inner-banner-section:after { content: ""; position: absolute; left: 0; top: 0; width: 100%; height: 100%; background: linear-gradient(180deg, #1f77db00 50%, #000000 100%); }
  @media only screen and (min-width:1024px) and (max-width:1599px){
    section.inner-banner-section h1 {max-width: 505px;}
    section.inner-banner-section p {max-width: 405px;}
  }

  @media only screen and (min-width:0px) and (max-width:767px){
    section.inner-banner-section .inner-banner-wrapper .grid-row {grid-template-columns: 1fr; height: 535px; align-items: flex-end;}
    section.inner-banner-section h1 { margin: 0; font-family: 'Futura', sans-serif; line-height: 1.3; margin-bottom: 12px; font-weight: 400; font-size: 18px; line-height: 100%; text-align: center; text-transform: uppercase; color: #ffffff; margin: 0 auto;
        margin-bottom: 14px; max-width: 300px; line-height: 1.3 !important;}
    section.inner-banner-section p { font-family: 'Futura', sans-serif; margin: 0; color: #1A1A1A; margin-bottom: 32px; font-weight: 400; font-size: 12px; line-height: 1.3; text-align: center; color: #ffffff; }
    section.inner-banner-section .inner-banner-wrapper .grid-row .grid-column:nth-child(1) {grid-row: 2;}
    section.inner-banner-section .nector-reward-banner-content-wrapper { margin-bottom: 40px; text-align: center;}
    section.inner-banner-section a.button-design {padding: 16px 50px; max-width: max-content; font-size: 12px;}
    section.nector-reward-banner-sectisection.nector-reward-how-it-works-section {position: relative;}
    .page-video_call_pdp-template-page section.inner-banner-section:after {content: ""; position: absolute; left: 0; top: 0; width: 100%; height: 100%; background: linear-gradient(180deg, #1f77db00 37.64%, #000000 81.77%);}
    section.inner-banner-section .page-width {position: relative; z-index: 1 !important;}
    section.inner-banner-section { background: url('{{ section.settings.bg_image_mobile | image_url }}') !important; background-repeat: no-repeat; background-size: cover !important; background-position: right top; position: relative; height: 435px;}
    section.inner-banner-section .nector-reward-banner-content-wrapper { margin-bottom: 0; text-align: center; }
    .page-store-locator-template-page section.inner-banner-section {position: relative}
    .page-store-locator-template-page .inner-banner-section:after {content: ""; position: absolute; left: 0; top: 0; width: 100%; height: 100%; background: linear-gradient(180deg, #1f77db00 50%, #000000 100%);}
    
  }

  @media only screen and (min-width:1600px) and (max-width:2100px){
    section.inner-banner-section .inner-banner-wrapper .grid-row {height: 90vh !important;}
  }

     @media only screen and (min-width:300px) and (max-width:400px){
    section.inner-banner-section .inner-banner-wrapper .grid-row {grid-template-columns: 1fr; height: 490px; align-items: flex-end;}
   }
    @media only screen and (min-width:0px) and (max-width:370px){
    section.inner-banner-section .inner-banner-wrapper .grid-row {grid-template-columns: 1fr; height: 455px; align-items: flex-end;}
   }

   @media only screen and (min-width:0px) and (max-width:767px){
    .page-video_call_pdp-template-page .section.inner-banner-section {height: 575px !important;}
   }
   
</style>
{% schema %}
{
  "name": "Page Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background Images"
    },
    {
      "type": "image_picker",
      "id": "bg_image_desktop",
      "label": "Desktop Background Image",
      "info": "Recommended size: 1920x600px or larger"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Mobile Background Image",
      "info": "Recommended size: 768x600px or larger"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "banner_heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "banner_description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "banner_button_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "banner_button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Page Banner"
    }
  ]
}
{% endschema %}
