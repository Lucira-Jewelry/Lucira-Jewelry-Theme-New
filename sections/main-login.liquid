{% if customer %}
  <script>
    window.location.href = "/account";
  </script>
{% endif %}
<style>
.otp-login-form-wrapper .close-button{display:none}
.otp-login-form-wrapper button.close-button-only-account{border-radius:50%;padding:4px;position:absolute;right:20px;top:20px;border:0;z-index:1;background:#b77766;display:block}
.otp-login-form-wrapper button.close-button-only-account svg path{fill:#fff}
.otp-login-form-wrapper button svg{display:block;width:20px;height:20px}
.lucira-back-btn{display:inline-flex;align-items:center;gap:6px;background:0 0;font-size:16px;font-family:inherit;font-weight:400;letter-spacing:.5px;color:#240707;cursor:pointer;margin-bottom:20px;transition:background .2s,border-color .2s,color .2s;border-radius:50%;padding:4px;position:absolute;right:20px;top:20px;border:0;z-index:1;background:#ebebeb}
</style>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (window.location.pathname === '/account/login') {
      const popup = document.getElementById('login-popup');

      if (popup) {
        popup.style.display = 'flex';
        document.body.classList.add('overflow-hidden');
      }
    }
  });
</script>
<script>
function closeAndGoBack() {
  if (document.referrer && window.history.length > 1) {
    window.history.back();
  } else {
    window.location.href = '/';
  }
}
</script>


{% schema %}
{
  "name": "t:sections.main-login.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_shop_login_button",
      "label": "t:sections.main-login.shop_login_button.enable",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
