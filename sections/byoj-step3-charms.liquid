<!-- 1. HTML -->
<div class="byoj-step3">
  <div class="byoj-wrapper">
    <!-- LEFT: CHAIN PREVIEW -->
    <div class="byoj-left">
      <div class="chain-preview">
        <img id="chain-image">
        <div id="charms-container" class="charms-container"></div>
      </div>
    </div>

    <!-- RIGHT: CHARMS -->
    <div class="byoj-right">
      <h3 class="charms-heading">Select Your Charms</h3>
      <div id="charms-list" class="charms-list"></div>
    </div>
  </div>
</div>

<!-- 2. Inject Charms -->
<script>
  window.byojCharms = [

  {% for block in section.blocks %}
    {% if block.settings.product != blank %}
      {% assign product = block.settings.product %}
      {
        id: "{{ product.id }}",
        title: {{ product.title | json }},
        image: "{{ product.featured_image | image_url: width: 300 }}"
      },
    {% endif %}
  {% endfor %}

  ];
</script>

<!-- 3. Logic -->
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const selectedVariant = localStorage.getItem('byoj_chain_variant');

    // 🔥 Load chain image
    const chainImage = localStorage.getItem('byoj_chain_image');

    if (chainImage) {
      document.getElementById('chain-image').src = chainImage;
    }

    const charmsContainer = document.getElementById('charms-container');
    const charmsList = document.getElementById('charms-list');

    let selectedCharms = [];

    function renderCharms() {
      charmsContainer.innerHTML = '';

      const total = selectedCharms.length;

      selectedCharms.forEach((charm, index) => {
        const el = document.createElement('img');
        el.src = charm.image;
        el.className = 'charm';

        // Horizontal position
        const xPercent = ((index + 1) / (total + 1)) * 100;

        // 🔥 CURVE LOGIC (key part)
        const curveDepth = 30; // increase = deeper curve
        const xNormalized = (index + 1) / (total + 1); // 0 → 1
        
        // sine curve (center dips down)
        const baseY = Math.sin(xNormalized * Math.PI) * curveDepth;
        const randomY = (Math.random() * 6) - 3;
        const finalY = baseY + randomY;

        el.style.left = xPercent + '%';
        el.style.top = `calc(50% + ${finalY}px)`;
        el.style.transform = 'translate(-50%, -50%)';

        charmsContainer.appendChild(el);
      });
    }

    // Render charm options
    window.byojCharms.forEach((charm) => {
      const div = document.createElement('div');
      div.className = 'charm-item';

      div.innerHTML = `
      <img src="${charm.image}" />
      <p>${charm.title}</p>
    `;

      div.onclick = () => {
        selectedCharms.push(charm);
        renderCharms();
      };

      charmsList.appendChild(div);
    });
  });
</script>

<!-- 4. CSS -->
<style>
  /* Layout */
  .byoj-wrapper {
    display: flex;
    gap: 40px;
    align-items: flex-start;
  }

  .byoj-left {
    width: 60%;
  }

  .byoj-right {
    width: 40%;
  }

  /* Chain Preview */
  .chain-preview {
    position: relative;
    text-align: center;
    padding: 40px;
  }

  #chain-image {
    width: 100%;
    max-width: 600px;
  }

  /* Charms on chain */
  .charms-container {
    position: absolute;

    left: 0;
    width: 100%;
  }

  .charm {
    position: absolute;
    width: 45px;
    transition: all 0.3s ease;
  }

  /* Right Panel */
  .charms-heading {
    margin-bottom: 20px;
  }

  .charms-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 15px;
  }

  .charm-item {
    text-align: center;
    cursor: pointer;
    transition: 0.3s;
  }

  .charm-item:hover {
    transform: scale(1.05);
  }

  .charm-item img {
    width: 100%;
    max-width: 80px;
  }
</style>

<!-- 5. Schema -->
{% schema %}
{
  "name": "BYO Charms",
  "settings": [],
  "blocks": [
    {
      "type": "charm",
      "name": "Charm",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Charm Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYO Charms"
    }
  ]
}
{% endschema %}
