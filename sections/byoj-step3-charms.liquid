<!-- 1. LOAD KONVA -->
<script src="https://cdn.jsdelivr.net/npm/konva@9/konva.min.js"></script>

<!-- 2. HTML -->
<div class="byoj-step3">
  <div class="byoj-wrapper">

    <!-- LEFT: CANVAS -->
    <div class="byoj-left">
      <div id="konva-container"></div>
    </div>

    <!-- RIGHT: CHARMS -->
    <div class="byoj-right">
      <h3 class="charms-heading">Select Your Charms</h3>
      <div id="charms-list" class="charms-list"></div>
    </div>

  </div>
</div>


<!-- 3. INJECT CHARMS -->
<script>
window.byojCharms = [

{% for block in section.blocks %}
  {% if block.settings.product != blank %}
    {% assign product = block.settings.product %}
    {
      id: "{{ product.id }}",
      title: {{ product.title | json }},
      image: "{{ product.featured_image | image_url: width: 300 }}"
    },
  {% endif %}
{% endfor %}

];
</script>


<!-- 4. KONVA LOGIC -->
<script>
document.addEventListener("DOMContentLoaded", function () {

  const containerWidth = 600;
  const containerHeight = 300;

  const stage = new Konva.Stage({
    container: 'konva-container',
    width: containerWidth,
    height: containerHeight
  });

  const layer = new Konva.Layer();
  stage.add(layer);

  const chainImageSrc = localStorage.getItem("byoj_chain_image");

  if (!chainImageSrc) {
    console.error("No chain image found in localStorage");
  }

  // 🔥 LOAD CHAIN IMAGE
  const chainImg = new Image();
  chainImg.src = chainImageSrc;

  chainImg.onload = function () {
    const chain = new Konva.Image({
      image: chainImg,
      x: 0,
      y: 60,
      width: containerWidth,
      height: 150
    });

    layer.add(chain);
    layer.draw();
  };

  // 🔥 CURVE FUNCTION (necklace dip)
  function getCurveY(x) {
    const normalized = x / containerWidth;
    const curveDepth = 40;
    return 120 + Math.sin(normalized * Math.PI) * curveDepth;
  }

  let charms = [];

  // 🔥 ADD CHARM
  function addCharm(charmData) {

    const img = new Image();
    img.src = charmData.image;

    img.onload = function () {

      const startX = containerWidth / 2;

      const charm = new Konva.Image({
        image: img,
        x: startX,
        y: getCurveY(startX),
        width: 45,
        height: 45,
        offsetX: 22.5,
        offsetY: 22.5,
        draggable: true
      });

      // 🔥 DRAG ALONG CURVE
      charm.on('dragmove', function () {
        let newX = charm.x();

        // Keep inside bounds
        newX = Math.max(20, Math.min(containerWidth - 20, newX));

        charm.x(newX);
        charm.y(getCurveY(newX));
      });

      // 🔥 REMOVE ON DOUBLE CLICK
      charm.on('dblclick', function () {
        charm.destroy();
        layer.draw();
      });

      layer.add(charm);
      layer.draw();

      charms.push(charm);
    };
  }

  // 🔥 RENDER CHARMS LIST
  const charmsList = document.getElementById("charms-list");

  window.byojCharms.forEach(charm => {

    const div = document.createElement("div");
    div.className = "charm-item";

    div.innerHTML = `
      <img src="${charm.image}" />
      <p>${charm.title}</p>
    `;

    div.onclick = () => {
      addCharm(charm);
    };

    charmsList.appendChild(div);
  });

});
</script>


<!-- 5. CSS -->
<style>

/* Layout */
.byoj-wrapper {
  display: flex;
  gap: 40px;
}

.byoj-left {
  width: 60%;
}

.byoj-right {
  width: 40%;
}

/* Canvas */
#konva-container {
  width: 100%;
  max-width: 600px;
  margin: auto;
  border: 1px solid #eee;
}

/* Right Panel */
.charms-heading {
  margin-bottom: 20px;
}

.charms-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

.charm-item {
  text-align: center;
  cursor: pointer;
  transition: 0.3s;
}

.charm-item:hover {
  transform: scale(1.05);
}

.charm-item img {
  width: 100%;
  max-width: 80px;
}

</style>


<!-- 6. SCHEMA -->
{% schema %}
{
  "name": "BYO Charms",
  "settings": [],
  "blocks": [
    {
      "type": "charm",
      "name": "Charm",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Charm Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYO Charms"
    }
  ]
}
{% endschema %}