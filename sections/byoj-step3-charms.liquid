<!-- 1. LOAD KONVA -->
<script src="https://cdn.jsdelivr.net/npm/konva@9/konva.min.js"></script>

<!-- 2. HTML -->
<div class="byoj-wrapper">
  <div class="byoj-left">
    <div id="konva-container"></div>
  </div>

  <div class="byoj-right">
    <h3 class="charms-heading">Select Charms</h3>
    <div id="charms-list" class="charms-list"></div>
  </div>
</div>

<!-- 3. INJECT CHARMS -->
<script>
window.byojCharms = [
{% for block in section.blocks %}
  {% if block.settings.product != blank %}
    {% assign product = block.settings.product %}
    {
      id: "{{ product.id }}",
      title: {{ product.title | json }},
      image: "{{ product.featured_image | image_url: width: 300 }}"
    },
  {% endif %}
{% endfor %}
];
</script>

<!-- 4. KONVA LOGIC -->
<script>
document.addEventListener("DOMContentLoaded", function () {

  const size = 600;

  const stage = new Konva.Stage({
    container: 'konva-container',
    width: size,
    height: size
  });

  const layer = new Konva.Layer();
  stage.add(layer);

  const centerX = size / 2;

  const chainImageSrc = localStorage.getItem("byoj_chain_image");

  let chainWidth = 0;
  let chainHeight = 0;
  let centerY = 0;

  let charmCount = 0;

  // ===============================
  // 🔥 LOAD CHAIN IMAGE
  // ===============================
  const chainImg = new Image();
  chainImg.src = chainImageSrc;

  chainImg.onload = function () {

    const maxWidth = size * 0.9;
    const scale = maxWidth / chainImg.width;

    chainWidth = chainImg.width * scale;
    chainHeight = chainImg.height * scale;

    const chainX = centerX - chainWidth / 2;
    const chainY = (size - chainHeight) / 2;

    centerY = chainY + (chainHeight / 2);

    const chain = new Konva.Image({
      image: chainImg,
      x: chainX,
      y: chainY,
      width: chainWidth,
      height: chainHeight
    });

    layer.add(chain);
    layer.draw();

    initCharms();
  };

  // ===============================
  // 🔥 ANGLE → POSITION (ELLIPSE)
  // ===============================
  function getPositionFromAngle(angleDeg) {

    const a = chainWidth / 2;
    const b = chainHeight / 2;

    const angle = angleDeg * (Math.PI / 180);

    const x = centerX + a * Math.cos(angle);
    const y = centerY + b * Math.sin(angle) - (b * 0.2);

    return { x, y };
  }

  // ===============================
  // 🔥 AUTO POSITION LOGIC
  // ===============================
  function getNextAngle() {

    const step = 25; // spacing

    if (charmCount === 0) return 90;

    const index = Math.floor((charmCount + 1) / 2);

    if (charmCount % 2 === 1) {
      return 90 + (index * step); // LEFT
    } else {
      return 90 - (index * step); // RIGHT
    }
  }

  let charms = [];

  // ===============================
  // 🔥 ADD CHARM
  // ===============================
  function addCharm(charmData) {

    const img = new Image();
    img.src = charmData.image;

    img.onload = function () {

      const angle = getNextAngle();
      const pos = getPositionFromAngle(angle);

      const charm = new Konva.Image({
        image: img,
        x: pos.x,
        y: pos.y,
        width: 50,
        height: 50,
        offsetX: 25,
        offsetY: 25,
        draggable: true
      });

      // slight natural tilt
      charm.rotation((Math.random() * 6) - 3);

      // 🔥 DRAG ALONG CHAIN
      charm.on('dragmove', function () {

        let newX = charm.x();

        const minX = centerX - chainWidth / 2 + 20;
        const maxX = centerX + chainWidth / 2 - 20;

        newX = Math.max(minX, Math.min(maxX, newX));

        // convert X → closest angle
        const dx = (newX - centerX) / (chainWidth / 2);
        const angle = Math.acos(dx);

        const finalAngle = angle * (180 / Math.PI);

        const pos = getPositionFromAngle(finalAngle);

        charm.x(pos.x);
        charm.y(pos.y);
      });

      // remove on double click
      charm.on('dblclick', function () {
        charm.destroy();
        layer.draw();
      });

      layer.add(charm);
      layer.draw();

      charms.push(charm);

      charmCount++; // 🔥 increment
    };
  }

  // ===============================
  // 🔥 RENDER CHARMS LIST
  // ===============================
  function initCharms() {

    const charmsList = document.getElementById("charms-list");

    window.byojCharms.forEach(charm => {

      const div = document.createElement("div");
      div.className = "charm-item";

      div.innerHTML = `
        <img src="${charm.image}" />
        <p>${charm.title}</p>
      `;

      div.onclick = () => addCharm(charm);

      charmsList.appendChild(div);
    });
  }

});
</script>

<!-- 5. CSS -->
<style>

.byoj-wrapper {
  display: flex;
  gap: 40px;
}

.byoj-left {
  width: 60%;
}

/* ✅ WHITE CANVAS */
#konva-container {
  width: 100%;
  max-width: 600px;
  aspect-ratio: 1 / 1;
  margin: auto;
  border: 1px solid #eee;
  background: #ffffff;
}

.byoj-right {
  width: 40%;
}

.charms-heading {
  margin-bottom: 20px;
}

.charms-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

.charm-item {
  text-align: center;
  cursor: pointer;
  transition: 0.3s;
}

.charm-item:hover {
  transform: scale(1.05);
}

.charm-item img {
  max-width: 80px;
}

</style>

<!-- 6. SCHEMA -->
{% schema %}
{
  "name": "BYO Charms",
  "settings": [],
  "blocks": [
    {
      "type": "charm",
      "name": "Charm",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Charm Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYO Charms"
    }
  ]
}
{% endschema %}