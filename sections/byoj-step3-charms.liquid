<!-- 1. LOAD KONVA -->
<script src="https://cdn.jsdelivr.net/npm/konva@9/konva.min.js"></script>

<!-- 2. HTML -->
<div class="byoj-wrapper">
  <div class="byoj-left">
    <div id="konva-container"></div>
  </div>

  <div class="byoj-right">
    <h3>Select Charms</h3>
    <div id="charms-list" class="charms-list"></div>
  </div>
</div>

<!-- 3. INJECT CHARMS -->
<script>
window.byojCharms = [
{% for block in section.blocks %}
  {% if block.settings.product != blank %}
    {% assign product = block.settings.product %}
    {
      id: "{{ product.id }}",
      title: {{ product.title | json }},
      image: "{{ product.featured_image | image_url: width: 300 }}"
    },
  {% endif %}
{% endfor %}
];
</script>

<!-- 4. KONVA LOGIC -->
<script>
document.addEventListener("DOMContentLoaded", function () {

  const size = 600;

  const stage = new Konva.Stage({
    container: 'konva-container',
    width: size,
    height: size
  });

  const layer = new Konva.Layer();
  stage.add(layer);

  const centerX = size / 2;

  let chainWidth = 0;
  let chainHeight = 0;
  let centerY = 0;

  let charms = [];
  let slots = [];

  // ===============================
  // 🔥 LOAD CHAIN IMAGE
  // ===============================
  const chainImg = new Image();
  chainImg.src = localStorage.getItem("byoj_chain_image");

  chainImg.onload = function () {

    const scale = (size * 0.9) / chainImg.width;

    chainWidth = chainImg.width * scale;
    chainHeight = chainImg.height * scale;

    const chainX = centerX - chainWidth / 2;
    const chainY = (size - chainHeight) / 2;

    centerY = chainY + (chainHeight / 2);

    const chain = new Konva.Image({
      image: chainImg,
      x: chainX,
      y: chainY,
      width: chainWidth,
      height: chainHeight
    });

    layer.add(chain);

    generateSlots();
    initCharms();

    layer.draw();
  };

  // ===============================
  // 🔥 CREATE FIXED SLOTS
  // ===============================
  function generateSlots() {

    const step = 25;
    const max = 6; // number of slots per side

    slots.push({ angle: 90, occupied: null });

    for (let i = 1; i <= max; i++) {
      slots.push({ angle: 90 + (i * step), occupied: null }); // left
      slots.push({ angle: 90 - (i * step), occupied: null }); // right
    }
  }

  // ===============================
  // 🔥 ANGLE → POSITION
  // ===============================
  function getPos(angleDeg) {

    const a = chainWidth / 2;
    const b = chainHeight / 2;

    const angle = angleDeg * (Math.PI / 180);

    const x = centerX + a * Math.cos(angle);
    const y = centerY + b * Math.sin(angle) - (b * 0.2);

    return { x, y };
  }

  // ===============================
  // 🔥 FIND NEAREST SLOT
  // ===============================
  function getNearestSlot(x, y) {

    let minDist = Infinity;
    let closest = null;

    slots.forEach(slot => {
      const pos = getPos(slot.angle);

      const dist = Math.hypot(pos.x - x, pos.y - y);

      if (dist < minDist) {
        minDist = dist;
        closest = slot;
      }
    });

    return closest;
  }

  // ===============================
  // 🔥 PLACE IN SLOT
  // ===============================
  function placeCharm(charm, slot) {

    const pos = getPos(slot.angle);

    charm.position(pos);

    if (charm.slot) {
      charm.slot.occupied = null;
    }

    slot.occupied = charm;
    charm.slot = slot;
  }

  // ===============================
  // 🔥 ADD CHARM
  // ===============================
  function addCharm(data) {

    const img = new Image();
    img.src = data.image;

    img.onload = function () {

      const emptySlot = slots.find(s => !s.occupied);
      if (!emptySlot) return;

      const pos = getPos(emptySlot.angle);

      const charm = new Konva.Image({
        image: img,
        x: pos.x,
        y: pos.y,
        width: 50,
        height: 50,
        offsetX: 25,
        offsetY: 25,
        draggable: true
      });

      placeCharm(charm, emptySlot);

      // ===============================
      // 🔥 DRAG SWAP LOGIC
      // ===============================
      charm.on('dragend', function () {

        const targetSlot = getNearestSlot(charm.x(), charm.y());

        if (!targetSlot) return;

        if (targetSlot.occupied && targetSlot.occupied !== charm) {

          // swap
          const other = targetSlot.occupied;
          const currentSlot = charm.slot;

          placeCharm(other, currentSlot);
          placeCharm(charm, targetSlot);

        } else {

          placeCharm(charm, targetSlot);
        }

        layer.draw();
      });

      // remove
      charm.on('dblclick', function () {
        if (charm.slot) charm.slot.occupied = null;
        charm.destroy();
        layer.draw();
      });

      layer.add(charm);
      charms.push(charm);
      layer.draw();
    };
  }

  // ===============================
  // 🔥 RENDER LIST
  // ===============================
  function initCharms() {

    const list = document.getElementById("charms-list");

    window.byojCharms.forEach(c => {

      const div = document.createElement("div");
      div.className = "charm-item";

      div.innerHTML = `
        <img src="${c.image}" />
        <p>${c.title}</p>
      `;

      div.onclick = () => addCharm(c);

      list.appendChild(div);
    });
  }

});
</script>

<!-- 5. CSS -->
<style>

.byoj-wrapper {
  display: flex;
  gap: 40px;
}

#konva-container {
  width: 100%;
  max-width: 600px;
  aspect-ratio: 1 / 1;
  background: #fff;
  border: 1px solid #eee;
}

.charms-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

.charm-item {
  text-align: center;
  cursor: pointer;
}

.charm-item img {
  max-width: 80px;
}

</style>
<!-- 6. SCHEMA -->
{% schema %}
{
  "name": "BYO Charms",
  "settings": [],
  "blocks": [
    {
      "type": "charm",
      "name": "Charm",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Charm Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYO Charms"
    }
  ]
}
{% endschema %}