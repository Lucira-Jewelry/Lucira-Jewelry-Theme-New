<!-- 1. LOAD KONVA -->
<script src="https://cdn.jsdelivr.net/npm/konva@9/konva.min.js"></script>

<!-- 2. HTML -->
<div class="byoj-wrapper">
  <div class="byoj-left">
    <div id="konva-container"></div>
  </div>

  <div class="byoj-right">
    <h3 class="charms-heading">Select Charms</h3>
    <div id="charms-list" class="charms-list"></div>
  </div>
</div>

<!-- 3. INJECT CHARMS -->
<script>
window.byojCharms = [
{% for block in section.blocks %}
  {% if block.settings.product != blank %}
    {% assign product = block.settings.product %}
    {
      id: "{{ product.id }}",
      title: {{ product.title | json }},
      image: "{{ product.featured_image | image_url: width: 300 }}"
    },
  {% endif %}
{% endfor %}
];
</script>

<!-- 4. KONVA LOGIC -->
<script>
document.addEventListener("DOMContentLoaded", function () {

  const size = 600;

  const stage = new Konva.Stage({
    container: 'konva-container',
    width: size,
    height: size
  });

  const layer = new Konva.Layer();
  stage.add(layer);

  const centerX = size / 2;

  const chainImageSrc = localStorage.getItem("byoj_chain_image");

  // ===============================
  // 🔥 LOAD CHAIN IMAGE (NO DISTORTION)
  // ===============================
  const chainImg = new Image();
  chainImg.src = chainImageSrc;

  let chainTop = 0;
  let chainHeight = 0;
  let chainWidth = 0;

  chainImg.onload = function () {

    const maxWidth = size * 0.9;

    const scale = maxWidth / chainImg.width;

    chainWidth = chainImg.width * scale;
    chainHeight = chainImg.height * scale;

    chainTop = size * 0.25;

    const chain = new Konva.Image({
      image: chainImg,
      x: centerX - chainWidth / 2,
      y: chainTop,
      width: chainWidth,
      height: chainHeight
    });

    layer.add(chain);
    layer.draw();

    initCharms(); // load charms after chain
  };

  // ===============================
  // 🔥 MATCH IMAGE CURVE (ELLIPSE BASED ON IMAGE)
  // ===============================
  function getChainY(x) {

    const left = centerX - chainWidth / 2;
    const right = centerX + chainWidth / 2;

    const a = chainWidth / 2;
    const b = chainHeight / 2;

    const cx = centerX;
    const cy = chainTop + b;

    const dx = x - cx;

    const inside = 1 - (dx * dx) / (a * a);

    if (inside <= 0) return cy;

    const y = b * Math.sqrt(inside);

    return cy + y - (b * 0.15); // tweak for visual alignment
  }

  let charms = [];

  // ===============================
  // 🔥 ADD CHARM
  // ===============================
  function addCharm(charmData) {

    const img = new Image();
    img.src = charmData.image;

    img.onload = function () {

      const startX = centerX;

      const charm = new Konva.Image({
        image: img,
        x: startX,
        y: getChainY(startX),
        width: 50,
        height: 50,
        offsetX: 25,
        offsetY: 25,
        draggable: true
      });

      charm.rotation((Math.random() * 6) - 3);

      charm.on('dragmove', function () {

        let newX = charm.x();

        const minX = centerX - chainWidth / 2 + 20;
        const maxX = centerX + chainWidth / 2 - 20;

        newX = Math.max(minX, Math.min(maxX, newX));

        const newY = getChainY(newX);

        charm.x(newX);
        charm.y(newY);
      });

      charm.on('dblclick', function () {
        charm.destroy();
        layer.draw();
      });

      layer.add(charm);
      layer.draw();

      charms.push(charm);
    };
  }

  // ===============================
  // 🔥 RENDER CHARMS
  // ===============================
  function initCharms() {

    const charmsList = document.getElementById("charms-list");

    window.byojCharms.forEach(charm => {

      const div = document.createElement("div");
      div.className = "charm-item";

      div.innerHTML = `
        <img src="${charm.image}" />
        <p>${charm.title}</p>
      `;

      div.onclick = () => addCharm(charm);

      charmsList.appendChild(div);
    });
  }

});
</script>

<!-- 5. CSS -->
<style>

.byoj-wrapper {
  display: flex;
  gap: 40px;
}

.byoj-left {
  width: 60%;
}

#konva-container {
  width: 100%;
  max-width: 600px;
  aspect-ratio: 1 / 1;
  margin: auto;
  border: 1px solid #eee;
  background: #fafafa;
}

.byoj-right {
  width: 40%;
}

.charms-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

.charm-item {
  text-align: center;
  cursor: pointer;
}

.charm-item img {
  max-width: 80px;
}

</style>

<!-- 6. SCHEMA -->
{% schema %}
{
  "name": "BYO Charms",
  "settings": [],
  "blocks": [
    {
      "type": "charm",
      "name": "Charm",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Charm Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYO Charms"
    }
  ]
}
{% endschema %}