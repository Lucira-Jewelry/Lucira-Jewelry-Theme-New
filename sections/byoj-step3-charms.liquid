<!-- 1. LOAD KONVA -->
<script src="https://cdn.jsdelivr.net/npm/konva@9/konva.min.js"></script>

<!-- 2. HTML -->
<div class="byoj-wrapper">
  <div class="byoj-left">
    <div id="konva-container"></div>
  </div>

  <div class="byoj-right">
    <h3 class="charms-heading">Select Charms</h3>
    <div id="charms-list" class="charms-list"></div>
  </div>
</div>

<!-- 3. INJECT CHARMS -->
<script>
window.byojCharms = [
{% for block in section.blocks %}
  {% if block.settings.product != blank %}
    {% assign product = block.settings.product %}
    {
      id: "{{ product.id }}",
      title: {{ product.title | json }},
      image: "{{ product.featured_image | image_url: width: 300 }}"
    },
  {% endif %}
{% endfor %}
];
</script>

<!-- 4. KONVA LOGIC -->
<script>
document.addEventListener("DOMContentLoaded", function () {

  // ✅ SQUARE CANVAS
  const size = 600;

  const stage = new Konva.Stage({
    container: 'konva-container',
    width: size,
    height: size
  });

  const layer = new Konva.Layer();
  stage.add(layer);

  const centerX = size / 2;
  const centerY = size / 2;

  const chainImageSrc = localStorage.getItem("byoj_chain_image");

  if (!chainImageSrc) {
    console.error("No chain image found in localStorage");
  }

  // 🔥 LOAD CHAIN IMAGE (CENTERED)
  const chainImg = new Image();
  chainImg.src = chainImageSrc;

  chainImg.onload = function () {

    const chainWidth = size * 0.85;
    const chainHeight = size * 0.25;

    const chain = new Konva.Image({
      image: chainImg,
      x: centerX - chainWidth / 2,
      y: size * 0.25,
      width: chainWidth,
      height: chainHeight
    });

    layer.add(chain);
    layer.draw();
  };

  // 🔥 CURVE FOR SQUARE (BETTER U SHAPE)
  function getCurveY(x) {

    const a = size * 0.38;   // width spread
    const b = size * 0.18;   // depth

    const dx = x - centerX;

    const inside = 1 - (dx * dx) / (a * a);

    if (inside <= 0) return size * 0.45;

    const y = b * Math.sqrt(inside);

    return size * 0.42 + (b - y);
  }

  let charms = [];

  // 🔥 ADD CHARM
  function addCharm(charmData) {

    const img = new Image();
    img.src = charmData.image;

    img.onload = function () {

      const startX = centerX;

      const charm = new Konva.Image({
        image: img,
        x: startX,
        y: getCurveY(startX),
        width: 500,
        height: 500,
        offsetX: 25,
        offsetY: 25,
        draggable: true
      });

      // Slight natural tilt
      charm.rotation((Math.random() * 8) - 4);

      charm.on('dragmove', function () {

        let newX = charm.x();

        // keep inside bounds
        newX = Math.max(40, Math.min(size - 40, newX));

        const baseY = getCurveY(newX);

        charm.x(newX);
        charm.y(baseY);
      });

      charm.on('dblclick', function () {
        charm.destroy();
        layer.draw();
      });

      layer.add(charm);
      layer.draw();

      charms.push(charm);
    };
  }

  // 🔥 RENDER CHARMS LIST
  const charmsList = document.getElementById("charms-list");

  window.byojCharms.forEach(charm => {

    const div = document.createElement("div");
    div.className = "charm-item";

    div.innerHTML = `
      <img src="${charm.image}" />
      <p>${charm.title}</p>
    `;

    div.onclick = () => addCharm(charm);

    charmsList.appendChild(div);
  });

});
</script>

<!-- 5. CSS -->
<style>

/* Layout */
.byoj-wrapper {
  display: flex;
  gap: 40px;
  align-items: flex-start;
}

.byoj-left {
  width: 60%;
}

.byoj-right {
  width: 40%;
}

/* ✅ PERFECT SQUARE CANVAS */
#konva-container {
  width: 100%;
  max-width: 600px;
  aspect-ratio: 1 / 1;
  margin: auto;
  border: 1px solid #eee;
  background: #fafafa;
}

/* Right Panel */
.charms-heading {
  margin-bottom: 20px;
}

.charms-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

.charm-item {
  text-align: center;
  cursor: pointer;
  transition: 0.3s;
}

.charm-item:hover {
  transform: scale(1.05);
}

.charm-item img {
  width: 100%;
  max-width: 80px;
}

</style>

<!-- 6. SCHEMA -->
{% schema %}
{
  "name": "BYO Charms",
  "settings": [],
  "blocks": [
    {
      "type": "charm",
      "name": "Charm",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Charm Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYO Charms"
    }
  ]
}
{% endschema %}