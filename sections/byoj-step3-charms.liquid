<!-- 1. LOAD KONVA -->
<script src="https://cdn.jsdelivr.net/npm/konva@9/konva.min.js"></script>

<!-- 2. HTML -->
<div class="byoj-wrapper">
  <div class="byoj-left">
    <div id="konva-container"></div>
  </div>

  <div class="byoj-right">
    <h3 class="charms-heading">Select Charms</h3>
    <div id="charms-list" class="charms-list"></div>
  </div>
</div>

<!-- 3. INJECT CHARMS -->
<script>
window.byojCharms = [
{% for block in section.blocks %}
  {% if block.settings.product != blank %}
    {% assign product = block.settings.product %}
    {
      id: "{{ product.id }}",
      title: {{ product.title | json }},
      image: "{{ product.featured_image | image_url: width: 300 }}"
    },
  {% endif %}
{% endfor %}
];
</script>

<!-- 4. KONVA LOGIC -->
<script>
document.addEventListener("DOMContentLoaded", function () {

  const size = 600;

  const stage = new Konva.Stage({
    container: 'konva-container',
    width: size,
    height: size
  });

  const layer = new Konva.Layer();
  stage.add(layer);

  const centerX = size / 2;
  const centerY = size / 2;

  // ===============================
  // 🔥 PERFECT SEMI-CIRCLE CHAIN
  // ===============================
  const radius = size * 0.35;

  const chain = new Konva.Arc({
    x: centerX,
    y: size * 0.45,
    innerRadius: radius,
    outerRadius: radius + 2,
    angle: 180,
    rotation: 180,
    stroke: '#C9A36B',
    strokeWidth: 2
  });

  layer.add(chain);

  // ===============================
  // 🔥 CURVE FUNCTION (MATCH ARC)
  // ===============================
  function getCurveY(x) {
    const dx = x - centerX;

    if (Math.abs(dx) > radius) {
      return size * 0.45;
    }

    const y = Math.sqrt(radius * radius - dx * dx);

    return size * 0.45 + y;
  }

  let charms = [];

  // ===============================
  // 🔥 ADD CHARM
  // ===============================
  function addCharm(charmData) {

    const img = new Image();
    img.src = charmData.image;

    img.onload = function () {

      const startX = centerX;

      const charm = new Konva.Image({
        image: img,
        x: startX,
        y: getCurveY(startX),
        width: 50,
        height: 50,
        offsetX: 25,
        offsetY: 25,
        draggable: true
      });

      // Natural hanging tilt
      charm.rotation((Math.random() * 6) - 3);

      charm.on('dragmove', function () {

        let newX = charm.x();

        newX = Math.max(centerX - radius, Math.min(centerX + radius, newX));

        const newY = getCurveY(newX);

        charm.x(newX);
        charm.y(newY);
      });

      charm.on('dblclick', function () {
        charm.destroy();
        layer.draw();
      });

      layer.add(charm);
      layer.draw();

      charms.push(charm);
    };
  }

  // ===============================
  // 🔥 RENDER CHARMS LIST
  // ===============================
  const charmsList = document.getElementById("charms-list");

  window.byojCharms.forEach(charm => {

    const div = document.createElement("div");
    div.className = "charm-item";

    div.innerHTML = `
      <img src="${charm.image}" />
      <p>${charm.title}</p>
    `;

    div.onclick = () => addCharm(charm);

    charmsList.appendChild(div);
  });

});
</script>

<!-- 5. CSS -->
<style>

/* Layout */
.byoj-wrapper {
  display: flex;
  gap: 40px;
  align-items: flex-start;
}

.byoj-left {
  width: 60%;
}

/* Perfect Square Canvas */
#konva-container {
  width: 100%;
  max-width: 600px;
  aspect-ratio: 1 / 1;
  margin: auto;
  border: 1px solid #eee;
  background: #fafafa;
}

/* Right Panel */
.byoj-right {
  width: 40%;
}

.charms-heading {
  margin-bottom: 20px;
}

.charms-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

.charm-item {
  text-align: center;
  cursor: pointer;
  transition: 0.3s;
}

.charm-item:hover {
  transform: scale(1.05);
}

.charm-item img {
  width: 100%;
  max-width: 80px;
}

</style>

<!-- 6. SCHEMA -->
{% schema %}
{
  "name": "BYO Charms",
  "settings": [],
  "blocks": [
    {
      "type": "charm",
      "name": "Charm",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Charm Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYO Charms"
    }
  ]
}
{% endschema %}