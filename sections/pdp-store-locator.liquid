<div class="pdp-store-locator-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">

    {%- if section.settings.heading != blank or section.settings.description != blank -%}
      <div class="store-locator-header">
        {%- if section.settings.heading != blank -%}
          <h2 class="store-locator-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="store-locator-description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="pdp-store-locator-wrapper">
      <div class="grid-row">

        <div class="grid-column">
          <div class="store-image-block">
            {%- if section.settings.store_image != blank -%}
              {{
                section.settings.store_image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  alt: section.settings.store_image.alt | default: section.settings.heading,
                  widths: '400, 600, 800, 1000, 1200',
                  sizes: '(max-width: 860px) 100vw, 50vw'
              }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'store-image-placeholder' }}
            {%- endif -%}
          </div>
        </div>

        <div class="grid-column">
          <div class="store-details-block">

            {%- assign city_labels = '' -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'store' -%}
                {%- assign city = block.settings.city_label | strip -%}
                {%- unless city_labels contains city -%}
                  {%- if city_labels == '' -%}
                    {%- assign city_labels = city -%}
                  {%- else -%}
                    {%- assign city_labels = city_labels | append: '||' | append: city -%}
                  {%- endif -%}
                {%- endunless -%}
              {%- endif -%}
            {%- endfor -%}

            {%- assign city_array = city_labels | split: '||' -%}

            {%- if city_array.size > 1 -%}
              <div class="city-tabs" role="tablist">
                {%- for city in city_array -%}
                  {%- assign city_slug = city | handleize -%}
                  <button
                    class="city-tab{% if forloop.first %} active{% endif %}"
                    role="tab"
                    aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                    aria-controls="city-panel-{{ city_slug }}"
                    data-city="{{ city_slug }}"
                  >
                    {{ city }}
                  </button>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- for city in city_array -%}
              {%- assign city_slug = city | handleize -%}
              <div
                class="store-list{% unless forloop.first %} is-hidden{% endunless %}"
                id="city-panel-{{ city_slug }}"
                role="tabpanel"
                data-city-panel="{{ city_slug }}"
              >
                {%- for block in section.blocks -%}
                  {%- if block.type == 'store' and block.settings.city_label == city -%}
                    <div class="store-card" {{ block.shopify_attributes }}>

                      {%- if block.settings.store_name != blank -%}
                        <h3 class="store-name">{{ block.settings.store_name }}</h3>
                      {%- endif -%}

                      {%- if block.settings.address != blank -%}
                        <div class="store-info-row">
                          <svg class="icon-location" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                          <span>{{ block.settings.address }}</span>
                        </div>
                      {%- endif -%}

                      <div class="store-meta-row">
                        {%- if block.settings.phone != blank -%}
                          <div class="store-meta-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.14 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.05 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                            <span>{{ block.settings.phone }}</span>
                          </div>
                        {%- endif -%}
                        {%- if block.settings.hours != blank -%}
                          <div class="store-meta-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            <span>{{ block.settings.hours }}</span>
                          </div>
                        {%- endif -%}
                      </div>

                      <div class="store-cta-row">
                        {%- if block.settings.appointment_url != blank -%}
                          <a href="{{ block.settings.appointment_url }}" class="btn btn-solid">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            {{ block.settings.appointment_label | default: 'Book Appointment' }}
                          </a>
                        {%- endif -%}
                        {%- if block.settings.designs_url != blank -%}
                          <a href="{{ block.settings.designs_url }}" class="btn btn-outline">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            {{ block.settings.designs_label | default: 'Available Designs' }}
                          </a>
                        {%- endif -%}
                      </div>

                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endfor -%}

          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<style>
  .pdp-store-locator-section { background: {{ section.settings.background_color }}; }
  .store-locator-header { text-align: center; margin-bottom: 48px; }
  .store-locator-heading { font-size: 24px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: #1a1a1a; margin-bottom: 6px; margin-top: 0; }
  .store-locator-description {font-size: 16px; margin: 8px auto 25px; line-height: 1.5; font-weight: 400; max-width: 560px; margin: 0 auto; color: {{ section.settings.text_color }}; line-height: 1.75; }
  .pdp-store-locator-wrapper .grid-row { display: grid; grid-template-columns: calc(60% - 15px) calc(40% - 15px); gap: 30px; align-items: start; }
  .store-image-block { position: relative; border-radius: 4px; overflow: hidden; aspect-ratio: 16 / 11; background: #f0ebe8; }
  .store-image-block img, .store-image-block svg { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.6s ease; }
  .store-image-block:hover img { transform: scale(1.03); }
  .store-details-block { display: flex; flex-direction: column; }
  .city-tabs {display: flex; gap: 10px; margin-bottom: 28px;}
  .city-tab { padding: 8px 22px; border-radius: 50px; border: 1px solid {{ section.settings.accent_color }}; font-size: 0.72rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; background: transparent; color: {{ section.settings.accent_color }}; transition: background 0.2s ease, color 0.2s ease; }
  .city-tab.active, .city-tab:hover { background: {{ section.settings.accent_color }}; color: #fff; border-color: {{ section.settings.accent_color }}; }
  .store-list { transition: opacity 0.25s ease, transform 0.25s ease; }
  .store-list.is-hidden { display: none; }
  .store-card { padding: 20px 0 28px; border-bottom: 1px solid {{ section.settings.border_color }}; }
  .store-card:first-child { padding-top: 0; }
  .store-card:last-child { border-bottom: none; }
  .store-name { font-size: 18px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 14px; color: {{ section.settings.heading_color }}; }
  h3.store-name {font-weight: 500; font-size: 16px; line-height: 24px; letter-spacing: 1px; vertical-align: middle; text-transform: uppercase; margin-top: 0;}
  .store-info-row { display: flex; align-items: flex-start; gap: 8px; font-size: 0.82rem; font-weight: 300; color: {{ section.settings.text_color }}; line-height: 1.6; margin-bottom: 10px; }
  .store-info-row svg { flex-shrink: 0; margin-top: 2px; color: {{ section.settings.accent_color }}; }
  .store-meta-row { display: flex; gap: 32px; margin-bottom: 20px; }
  .store-meta-item { display: flex; align-items: center; gap: 7px; font-size: 0.82rem; font-weight: 300; color: {{ section.settings.text_color }}; }
  .store-meta-item svg { color: {{ section.settings.accent_color }}; flex-shrink: 0; }
  .store-cta-row { display: flex; gap: 12px; flex-wrap: wrap; }
  .store-cta-row .btn { display: inline-flex; align-items: center; gap: 8px; padding: 11px 22px; font-size: 0.72rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; border-radius: 3px; cursor: pointer; text-decoration: none; border: 1.5px solid transparent; transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease; }
  .store-cta-row .btn-outline {background: transparent; border-color: #eaeaea; color: #785754; font-size: 10px; padding: 10px 16px; border: 1px solid #785754; font-weight: 500; border-radius: 8px;}
  .store-cta-row .btn-solid { background: {{ section.settings.button_color }}; border-color: {{ section.settings.button_color }}; color: #fff; border-radius: 8px; font-size: 10px; padding: 10px 16px;}
  .store-cta-row .btn-solid:hover { background: {{ section.settings.accent_color }}; border-color: {{ section.settings.accent_color }}; }
  .city-tabs .city-tab .store-details-block {font-family: Futura Std; font-weight: 500; font-size: 12px; line-height: 100%; letter-spacing: 1px; text-transform: uppercase;}
  .city-tabs { display: flex; gap: 10px; margin-bottom: 30px; }
  .city-tabs .city-tab {font-family: Futura Std; font-weight: 500; font-size: 12px; line-height: 100%; letter-spacing: 1.6px; text-transform: uppercase; padding: 10px 22px;}
  .store-info-row span {font-weight: 400; font-size: 12px; line-height: 1.7; letter-spacing: 1px; color: #1a1a1a;}
  .store-meta-row span { font-weight: 400; font-size: 12px; line-height: 1.7; letter-spacing: 1px; color: #1a1a1a; }
  
  @media (max-width: 860px) {
    .pdp-store-locator-wrapper .grid-row { grid-template-columns: 1fr; gap: 32px; }
    .store-image-block { aspect-ratio: 4 / 3; }
  }

  @media (max-width: 500px) {
    .store-meta-row { flex-direction: column; gap: 8px; }
    .store-cta-row { flex-direction: column; }
    .store-cta-row .btn { justify-content: center; }
  }
</style>

<script>
  (function () {
    const section = document.querySelector('.pdp-store-locator-section[data-section-id]') 
      || document.querySelector('.pdp-store-locator-section');

    if (!section) return;

    const tabs = section.querySelectorAll('.city-tab');
    const panels = section.querySelectorAll('[data-city-panel]');

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        const target = tab.dataset.city;

        // Update tabs
        tabs.forEach(function (t) {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');

        // Fade out → swap → fade in
        panels.forEach(function (panel) {
          if (!panel.classList.contains('is-hidden')) {
            panel.style.opacity = '0';
            panel.style.transform = 'translateY(6px)';
            setTimeout(function () {
              panel.classList.add('is-hidden');
              panel.style.opacity = '';
              panel.style.transform = '';
            }, 220);
          }
        });

        setTimeout(function () {
          const active = section.querySelector('[data-city-panel="' + target + '"]');
          if (active) {
            active.classList.remove('is-hidden');
            active.style.opacity = '0';
            active.style.transform = 'translateY(6px)';
            requestAnimationFrame(function () {
              active.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
              active.style.opacity = '1';
              active.style.transform = 'translateY(0)';
            });
          }
        }, 220);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "PDP Store Locator",
  "tag": "section",
  "class": "section-pdp-store-locator",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Know Your Birthstone"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    },
    {
      "type": "image_picker",
      "id": "store_image",
      "label": "Store Image"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (tabs, icons)",
      "default": "#9b7b7b"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Book Appointment Button Color",
      "default": "#7a5c5c"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border / Divider Color",
      "default": "#e0d8d8"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "store",
      "name": "Store",
      "settings": [
        {
          "type": "text",
          "id": "city_label",
          "label": "City Label",
          "info": "Used for the city tab (e.g. Mumbai, Pune). Stores sharing the same city label will be grouped together.",
          "default": "Mumbai"
        },
        {
          "type": "text",
          "id": "store_name",
          "label": "Store Name",
          "default": "Chembur Lucira Store"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address",
          "default": "Shop No. 3 Ground Floor, 487, Geraldine CHS LTD, Central Ave Rd, Chembur, Mumbai - 400071"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone Number",
          "default": "+91 9004402038"
        },
        {
          "type": "text",
          "id": "hours",
          "label": "Store Hours",
          "default": "10:00 AM – 10:00 PM"
        },
        {
          "type": "header",
          "content": "Available Designs Button"
        },
        {
          "type": "text",
          "id": "designs_label",
          "label": "Button Label",
          "default": "Available Designs"
        },
        {
          "type": "url",
          "id": "designs_url",
          "label": "Button URL"
        },
        {
          "type": "header",
          "content": "Book Appointment Button"
        },
        {
          "type": "text",
          "id": "appointment_label",
          "label": "Button Label",
          "default": "Book Appointment"
        },
        {
          "type": "url",
          "id": "appointment_url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Store Locator",
      "blocks": [
        {
          "type": "store",
          "settings": {
            "city_label": "Mumbai",
            "store_name": "Chembur Lucira Store",
            "address": "Shop No. 3 Ground Floor, 487, Geraldine CHS LTD, Central Ave Rd, Chembur, Mumbai, Maharashtra - 400071",
            "phone": "+91 9004402038",
            "hours": "10:00 AM – 10:00 PM"
          }
        },
        {
          "type": "store",
          "settings": {
            "city_label": "Mumbai",
            "store_name": "Borivali Lucira Store",
            "address": "Sky City Mall, S-40, 2nd Floor, Western Express Highway, Borivali East, Mumbai - 400066",
            "phone": "+91 8433667238",
            "hours": "10:00 AM – 10:00 PM"
          }
        },
        {
          "type": "store",
          "settings": {
            "city_label": "Pune",
            "store_name": "Koregaon Park Lucira Store",
            "address": "Shop 12, Ground Floor, Nyati Empress, Koregaon Park, Pune - 411001",
            "phone": "+91 9876543210",
            "hours": "10:00 AM – 9:30 PM"
          }
        }
      ]
    }
  ]
}
{% endschema %}
