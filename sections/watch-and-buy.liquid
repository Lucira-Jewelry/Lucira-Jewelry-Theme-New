<section class="watch-and-buy-section" id="watchAndBuySection">
  <div class="page-width">
    {% if section.settings.watch_buy_title != blank %}
      <h2 class="section-title">{{ section.settings.watch_buy_title }}</h2>
    {% endif %}
    {% if section.settings.watch_buy_subtitle != blank %}
      <h2 class="section-subtitle">{{ section.settings.watch_buy_subtitle }}</h2>
    {% endif %}
    <div class="watch-and-buy-wrapper">
      <div class="swiper watch-buy-slider">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            {% assign selected_product = all_products[block.settings.watch_buy_product] %}
            {% assign product_image = selected_product.featured_image | default: block.settings.watch_buy_product_fallback_image %}
            {% assign product_title = selected_product.title | default: block.settings.watch_buy_product_fallback_title %}
            {% assign product_url = selected_product.url | default: block.settings.watch_buy_product_fallback_url %}

            <div
              class="swiper-slide watch-buy-item"
              data-video="{% if block.settings.video %}{{ block.settings.video.sources[1].url }}{% endif %}"
              data-iframe-url="{% if block.settings.iframe_url %}{{ block.settings.iframe_url }}{% endif %}"
              data-product-image="{{ product_image | img_url: '200x200' }}"
              data-product-title="{{ product_title }}"
              data-product-price="{% if selected_product.price %}{{ selected_product.price | money }}{% else %}{{ block.settings.watch_buy_product_fallback_price }}{% endif %}"
              data-product-compare-price="{% if selected_product.compare_at_price %}{{ selected_product.compare_at_price | money }}{% endif %}"
              data-product-url="{{ product_url }}"
              data-product-id="{% if selected_product.id %}{{ selected_product.id }}{% endif %}"
              data-product-available="{% if selected_product.available %}{{ selected_product.available }}{% else %}false{% endif %}"
              data-variant-id="{% if selected_product.selected_or_first_available_variant.id %}{{ selected_product.selected_or_first_available_variant.id }}{% endif %}"
            >
              {% if block.settings.iframe_url != blank %}
                <div class="media-lazy-container" data-iframe-src="{{ block.settings.iframe_url }}">
                  {% if product_image %}
                    <img src="{{ product_image | img_url: '400x300' }}" alt="{{ product_title }}" title="{{ product_title }}" class="media-placeholder" loading="lazy" width="400" height="300">
                  {% endif %}
                  <div class="play-button">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 3L20 12L6 21V3Z" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                </div>
              {% elsif block.settings.video != blank %}
                <div class="media-lazy-container" data-video-src="{{ block.settings.video.sources[1].url }}">
                  {% if product_image %}
                    <img src="{{ product_image | img_url: '400x300' }}" alt="{{ product_title }}" title="{{ product_title }}" class="media-placeholder" loading="lazy" width="400" height="300">
                  {% elsif block.settings.image %}
                    <img src="{{ block.settings.image | img_url: '400x300' }}" alt="{{ product_title }}" title="{{ product_title }}" class="media-placeholder" loading="lazy" width="400" height="300">
                  {% endif %}
                  <div class="play-button">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 3L20 12L6 21V3Z" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                </div>
              {% elsif block.settings.image != blank %}
                <div class="media-lazy-container" data-img-src="{{ block.settings.image | img_url: '800x800' }}">
                  <img src="{{ block.settings.image | img_url: '100x100' }}" alt="{{ product_title }}" title="{{ product_title }}" class="media-placeholder" loading="lazy" width="400" height="400">
                </div>
              {% endif %}

              {% if selected_product.available and selected_product.url %}
                <button class="carousel-shopping-bag" data-product-url="{{ product_url }}">
                  <svg class="icon icon-bag" width="22" height="22"><use xlink:href="#icon-shopping-bag"></use></svg>
                </button>
              {% elsif block.settings.watch_buy_product_fallback_url != blank %}
                <button class="carousel-shopping-bag" data-product-url="{{ block.settings.watch_buy_product_fallback_url }}">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 2L3 6V20C3 21.1046 3.89543 22 5 22H19C20.1046 22 21 21.1046 21 20V6L18 2H6Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10C16 13.3137 13.3137 16 10 16C6.68629 16 4 13.3137 4 10"/></svg>
                </button>
              {% endif %}

              <div class="item-content">
                {% if product_title != blank %}<h3 class="item-title">{{ product_title }}</h3>{% endif %}
                <div class="item-bottom">
                  <div class="item-price-wrapper">
                    {% if selected_product.compare_at_price > selected_product.price %}<p class="item-price-compare">{{ selected_product.compare_at_price | money }}</p>{% endif %}
                    <p class="item-price">{% if selected_product.price %}{{ selected_product.price | money }}{% else %}{{ block.settings.watch_buy_product_fallback_price }}{% endif %}</p>
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
        <div class="swiper-button-prev">
          <img src='https://cdn.shopify.com/s/files/1/0739/8516/3482/files/arrow_back_ios_new.svg?v=1750503882' title='Previous' alt='Previous' width="24" height="24"/>
        </div>
        <div class="swiper-button-next">
          <img src='https://cdn.shopify.com/s/files/1/0739/8516/3482/files/arrow_forward_ios.svg?v=1750503882' title='Next' alt='Next' width="24" height="24" />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initWatchBuySwiper() {
    if (typeof Swiper === 'undefined') {
      setTimeout(initWatchBuySwiper, 50);
      return;
    }
    const swiper = new Swiper('.watch-buy-slider', {
      slidesPerView: 1.5,
      spaceBetween: 20,
      centeredSlides: true,
      loop: true,
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      breakpoints: {
        600: { slidesPerView: 3 },
        992: { slidesPerView: 4.5, centeredSlides: false },
        1200: { slidesPerView: 5, centeredSlides: false }
      }
    });

    // Re-setup item click handlers for Swiper clones
    setupItemClickHandlers();
  }

  function setupItemClickHandlers() {
    document.querySelectorAll('.watch-buy-item').forEach((item) => {
      item.addEventListener('click', function(e) {
        if (e.target.closest('.carousel-shopping-bag')) return;
        const index = Array.from(document.querySelectorAll('.watch-buy-item')).indexOf(this);
        openVideoPopup(index);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWatchBuySwiper);
  } else {
    initWatchBuySwiper();
  }
</script>

<div class="watch-buy-video-popup" id="videoPopup">
  <div class="popup_overlay" id="popupOverlay">
    <div class="popup-content" id="popupContent">
      <button class="close-popup" id="closePopup">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
          <path d="M11 12.7563L2.54502 21.2117C2.31419 21.4422 2.02405 21.5603 1.6746 21.5659C1.32544 21.5711 1.03002 21.4531 0.788353 21.2117C0.546964 20.97 0.42627 20.6772 0.42627 20.3334C0.42627 19.9895 0.546964 19.6967 0.788353 19.455L9.24377 11L0.788353 2.54502C0.557797 2.31419 0.439742 2.02405 0.434186 1.6746C0.428909 1.32544 0.546964 1.03002 0.788353 0.788353C1.03002 0.546964 1.3228 0.42627 1.66669 0.42627C2.01058 0.42627 2.30335 0.546964 2.54502 0.788353L11 9.24377L19.455 0.788353C19.6859 0.557797 19.976 0.439742 20.3254 0.434186C20.6746 0.428909 20.97 0.546964 21.2117 0.788353C21.4531 1.03002 21.5738 1.3228 21.5738 1.66669C21.5738 2.01058 21.4531 2.30335 21.2117 2.54502L12.7563 11L21.2117 19.455C21.4422 19.6859 21.5603 19.976 21.5659 20.3254C21.5711 20.6746 21.4531 20.97 21.2117 21.2117C20.97 21.4531 20.6772 21.5738 20.3334 21.5738C19.9895 21.5738 19.6967 21.4531 19.455 21.2117L11 12.7563Z" fill="white"/>
        </svg>
      </button>

      <div class="popup-video-container" id="popupVideoContainer">
        <!-- Changed from video to iframe -->
        <iframe
          class="popup-iframe"
          id="popupIframe"
          src=""
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
        >
        </iframe>

        <!-- Removed video progress bar since iframes don't have direct progress access -->
      </div>

      <div class="video-progress-container">
        <div class="video-progress-bar">
          <div class="video-progress-fill" id="videoProgressFill"></div>
        </div>
      </div>

      <div class="popup-slider-nav">
        <button class="popup-nav-btn popup-prev" id="popupPrev">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M15 18L9 12L15 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="popup-nav-btn popup-next" id="popupNext">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M9 18L15 12L9 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <div class="popup-product-card" id="popupProductCard">
        <img class="product-card-image" id="popupProductImage" src="" alt="" loading="lazy">
        <div class="product-card-info" id="popupProductInfo">
          <h3 class="product-card-title" id="popupProductTitle"></h3>
          <div class="product-card-actions">
            <div class="product-card-price-wrapper">
              <span class="product-card-price" id="popupProductPrice"></span>
              <del class="product-card-price-compare" id="popupProductComparePrice" style="display: none;"></del>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function initWatchBuySwiper() {
    if (typeof Swiper === 'undefined') {
      setTimeout(initWatchBuySwiper, 50);
      return;
    }

    const swiper = new Swiper('.watch-buy-slider', {
      slidesPerView: 1.5,
      spaceBetween: 20,
      centeredSlides: true,
      loop: true,
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      breakpoints: {
        600: { slidesPerView: 3 },
        992: { slidesPerView: 4.5, centeredSlides: false },
        1200: { slidesPerView: 5, centeredSlides: false }
      }
    });

    // Re-setup item click handlers
    setupItemClickHandlers();
  }

  function setupItemClickHandlers() {
    document.querySelectorAll('.watch-buy-item').forEach((item) => {
      item.addEventListener('click', function(e) {
        if (e.target.closest('.carousel-shopping-bag')) return;
        
        const videoSrc = this.getAttribute('data-video');
        const iframeSrc = this.getAttribute('data-iframe-url');

        if ((videoSrc && videoSrc !== '') || (iframeSrc && iframeSrc !== '')) {
          const allItems = Array.from(document.querySelectorAll('.watch-and-buy-section .watch-buy-item:not(.swiper-slide-duplicate)'));
          const originalItem = this.classList.contains('swiper-slide-duplicate') ? 
            allItems.find(i => i.dataset.productId === this.dataset.productId) : this;
          
          const videoIndex = allItems.indexOf(originalItem);
          if (videoIndex !== -1) {
            openVideoPopup(videoIndex);
          }
        }
      });
    });

    document.querySelectorAll('.carousel-shopping-bag').forEach((button) => {
      button.addEventListener('click', function (e) {
        e.stopPropagation();
        e.preventDefault();
        const productUrl = this.getAttribute('data-product-url');
        if (productUrl) window.open(productUrl, '_blank');
      });
    });
  }

  // Popup logic
  let currentVideoIndex = 0;
  let videoItems = [];
  let mobileSwiper = null;

  function collectVideoItems() {
    videoItems = Array.from(document.querySelectorAll('.watch-and-buy-section .watch-buy-item:not(.swiper-slide-duplicate)')).filter((item) => {
      return item.getAttribute('data-video') || item.getAttribute('data-iframe-url');
    });
  }

  function openVideoPopup(index) {
    const popup = document.getElementById('videoPopup');
    if (!popup) return;

    collectVideoItems();
    currentVideoIndex = index;
    popup.style.display = 'block';
    document.body.style.overflow = 'hidden';

    if (window.innerWidth <= 768) {
      initializeMobileSwiper();
    } else {
      loadVideoAtIndex(index);
    }
  }

  function initializeMobileSwiper() {
    if (mobileSwiper) return;
    
    const popupContent = document.getElementById('popupContent');
    const swiperContainer = document.createElement('div');
    swiperContainer.className = 'mobile-video-swiper swiper';
    swiperContainer.innerHTML = `
      <div class="swiper-wrapper">
        ${videoItems.map((item, index) => `
          <div class="swiper-slide" data-index="${index}">
            <div class="mobile-video-container">
              ${item.dataset.iframeUrl ? 
                `<iframe class="mobile-popup-iframe" data-src="${item.dataset.iframeUrl}" frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>` :
                `<video class="mobile-popup-video" data-src="${item.dataset.video}" playsinline loop muted controls><source src="${item.dataset.video}" type="video/mp4"></video>`
              }
            </div>
            <div class="mobile-product-card" onclick="window.open('${item.dataset.productUrl}', '_blank')">
              <img class="mobile-product-image" src="${item.dataset.productImage}">
              <div class="mobile-product-info">
                <h3 class="mobile-product-title">${item.dataset.productTitle}</h3>
                <span class="mobile-product-price">${item.dataset.productPrice}</span>
              </div>
            </div>
          </div>
        `).join('')}
      </div>
    `;

    popupContent.appendChild(swiperContainer);
    
    mobileSwiper = new Swiper('.mobile-video-swiper', {
      direction: 'vertical',
      initialSlide: currentVideoIndex,
      on: {
        slideChange: function() { handleMobileVideoChange(this.activeIndex); }
      }
    });
    handleMobileVideoChange(currentVideoIndex);
  }

  function handleMobileVideoChange(index) {
    document.querySelectorAll('.mobile-popup-video').forEach(v => v.pause());
    const slide = document.querySelector(`.mobile-video-swiper .swiper-slide[data-index="${index}"]`);
    if (!slide) return;

    const video = slide.querySelector('.mobile-popup-video');
    const iframe = slide.querySelector('.mobile-popup-iframe');

    if (video) {
      if (!video.src) video.src = video.dataset.src;
      video.play().catch(() => {});
    } else if (iframe && !iframe.src) {
      iframe.src = iframe.dataset.src;
    }
  }

  function loadVideoAtIndex(index) {
    const item = videoItems[index];
    const iframe = document.getElementById('popupIframe');
    const videoContainer = document.getElementById('popupVideoContainer');
    
    // Clear previous
    videoContainer.querySelectorAll('video').forEach(v => v.remove());
    iframe.src = '';
    iframe.style.display = 'none';

    if (item.dataset.iframeUrl) {
      iframe.src = item.dataset.iframeUrl;
      iframe.style.display = 'block';
    } else {
      const video = document.createElement('video');
      video.src = item.dataset.video;
      video.controls = true;
      video.autoplay = true;
      video.style.width = '100%';
      videoContainer.appendChild(video);
    }

    document.getElementById('popupProductImage').src = item.dataset.productImage;
    document.getElementById('popupProductTitle').textContent = item.dataset.productTitle;
    document.getElementById('popupProductPrice').textContent = item.dataset.productPrice;
  }

  function closeVideoPopup() {
    const popup = document.getElementById('videoPopup');
    popup.style.display = 'none';
    document.body.style.overflow = '';
    
    const iframe = document.getElementById('popupIframe');
    if (iframe) iframe.src = '';
    
    const video = document.querySelector('#popupVideoContainer video');
    if (video) video.pause();

    if (mobileSwiper) {
      mobileSwiper.destroy(true, true);
      mobileSwiper = null;
      document.querySelector('.mobile-video-swiper').remove();
    }
  }

  document.getElementById('closePopup').addEventListener('click', closeVideoPopup);
  document.getElementById('popupPrev').addEventListener('click', () => {
    currentVideoIndex = (currentVideoIndex > 0) ? currentVideoIndex - 1 : videoItems.length - 1;
    loadVideoAtIndex(currentVideoIndex);
  });
  document.getElementById('popupNext').addEventListener('click', () => {
    currentVideoIndex = (currentVideoIndex < videoItems.length - 1) ? currentVideoIndex + 1 : 0;
    loadVideoAtIndex(currentVideoIndex);
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWatchBuySwiper);
  } else {
    initWatchBuySwiper();
  }
</script>

<style>
.carousel-iframe{width:100%;height:100%;object-fit:cover;border-radius:8px;transition:opacity .3s ease}
.watch-buy-item{position:relative;overflow:hidden;border-radius:8px;cursor:pointer}
.watch-buy-item .carousel-iframe,.watch-buy-item video{display:block;width:100%;height:200px;object-fit:cover}
.watch-buy-item .play-button{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(0,0,0,.6);border-radius:50%;width:60px;height:60px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:18px;opacity:0;transition:opacity .3s ease;pointer-events:none;z-index:2}
.watch-buy-item:hover .play-button{opacity:1}
.popup-iframe{width:100%;height:90vh;border-radius:8px}
.mobile-popup-iframe{width:100%;height:90vh;border-radius:0}
.swipe-indicator-container{position:absolute;bottom:190px;left:0;right:0;z-index:1000;display:flex;justify-content:center;padding-top:20px;opacity:0;transform:translateY(-20px);transition:all .6s cubic-bezier(.25,.8,.25,1);pointer-events:none;cursor:none}
.swipe-indicator-container.show{opacity:1;transform:translateY(0)}
.swipe-indicator-container.hide{opacity:0;transform:translateY(-20px)}
.swipe-indicator-container.touched{transform:translateY(-5px)}
.swipe-indicator-bg{padding:12px 20px;display:flex;align-items:center;gap:8px;color:#fff;color:#fffffff;font-weight:400;font-size:14px;line-height:21px;vertical-align:middle}
.swipe-text{white-space:nowrap}
.swipe-arrow-wrapper{display:flex;align-items:center;animation:floatUp 2s ease-in-out infinite}
.swipe-arrow{color:#fff}
@keyframes floatUp{
0%,100%{transform:translateY(0)}
50%{transform:translateY(3px)}
}
.mobile-video-swiper{width:100%;height:100vh;position:relative}
.mobile-video-swiper .swiper-slide{display:flex;flex-direction:column;justify-content:center;align-items:center;position:relative;background:#000}
.mobile-video-container{width:100%;height:90vh;position:relative;display:flex;align-items:center;justify-content:center}
.mobile-popup-video{width:100%;height:90vh;object-fit:cover;border-radius:0}
.mobile-video-progress{position:absolute;top:30px;left:0;right:0;height:4px;width:90%;background:rgba(255,255,255,.3);margin:0 auto}
.mobile-progress-fill{height:100%;background:#fff;width:0%;transition:width .1s linear}
.mobile-product-card{width:100%;background:#fff;padding:16px;display:flex;align-items:center;gap:15px;min-height:auto;position:absolute;bottom:70px;max-width:80%;border-radius:8px;cursor:pointer}
.mobile-product-image{width:80px;height:80px;object-fit:cover;border-radius:8px;flex-shrink:0}
.mobile-product-info{flex:1;display:flex;flex-direction:column;gap:6px}
.mobile-product-title{margin:0;color:#1a1a1a;font-family:Futura;font-weight:400;font-size:14px;line-height:21px;vertical-align:middle}
.mobile-product-actions{display:flex;justify-content:space-between;align-items:center}
.mobile-price-wrapper{display:flex;flex-direction:row;gap:10px;align-items:center}
.mobile-product-price{color:#1a1a1a;font-family:Futura,sans-serif;font-weight:600;font-size:16px;line-height:150%;vertical-align:middle}
.mobile-compare-price{font-size:14px;color:#666;text-decoration:line-through}
@media (max-width:768px){
.popup-slider-nav{display:none!important}
.popup-video-container.desktop-only{display:none!important}
.popup-product-card.desktop-only{display:none!important}
}
.mobile-video-swiper .swiper-wrapper{transition-timing-function:cubic-bezier(.25,.8,.25,1)}
.mobile-video-swiper .swiper-slide-active .mobile-popup-iframe,.mobile-video-swiper .swiper-slide-active .mobile-popup-video{opacity:1}
.mobile-video-swiper .swiper-slide:not(.swiper-slide-active) .mobile-popup-iframe,.mobile-video-swiper .swiper-slide:not(.swiper-slide-active) .mobile-popup-video{opacity:.7}
.mobile-popup-iframe,.mobile-popup-video{transition:opacity .3s ease}
.mobile-product-card{transition:transform .3s ease}
.swiper-slide-active .mobile-product-card{transform:translateY(0)}
.swiper-slide:not(.swiper-slide-active) .mobile-product-card{transform:translateY(10px)}
.popup-video-container{width:100%;height:90vh;position:relative;display:flex;align-items:center;justify-content:center}
@media (max-width:768px){
.mobile-popup-iframe,.popup-iframe{width:100%;height:70vh}
}
</style>

