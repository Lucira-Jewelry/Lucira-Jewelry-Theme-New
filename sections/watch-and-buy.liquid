<section class="watch-and-buy-section" id="watchAndBuySection">
  <div class="page-width">
    {% if section.settings.watch_buy_title != blank %}
      <h2 class="section-title">{{ section.settings.watch_buy_title }}</h2>
    {% endif %}
    {% if section.settings.watch_buy_subtitle != blank %}
      <h2 class="section-subtitle">{{ section.settings.watch_buy_subtitle }}</h2>
    {% endif %}
    <div class="watch-and-buy-wrapper swiper watch-buy-slider">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% assign selected_product = all_products[block.settings.watch_buy_product] %}
          <!-- Precompute fallback values to reduce repetitive conditionals -->
          {% assign product_image = selected_product.featured_image
            | default: block.settings.watch_buy_product_fallback_image
          %}
          {% assign product_title = selected_product.title | default: block.settings.watch_buy_product_fallback_title %}
          {% assign product_url = selected_product.url | default: block.settings.watch_buy_product_fallback_url %}

          <div
            class="swiper-slide item watch-buy-item"
            data-video="{% if block.settings.video %}{{ block.settings.video.sources[1].url }}{% endif %}"
            data-iframe-url="{% if block.settings.iframe_url %}{{ block.settings.iframe_url }}{% endif %}"
            data-product-image="{{ product_image | img_url: '200x200' }}"
            data-product-title="{{ product_title }}"
            data-product-price="{% if selected_product.price %}{{ selected_product.price | money }}{% else %}{{ block.settings.watch_buy_product_fallback_price }}{% endif %}"
            data-product-compare-price="{% if selected_product.compare_at_price %}{{ selected_product.compare_at_price | money }}{% endif %}"
            data-product-url="{{ product_url }}"
            data-product-id="{% if selected_product.id %}{{ selected_product.id }}{% endif %}"
            data-product-available="{% if selected_product.available %}{{ selected_product.available }}{% else %}false{% endif %}"
            data-variant-id="{% if selected_product.selected_or_first_available_variant.id %}{{ selected_product.selected_or_first_available_variant.id }}{% endif %}"
          >
            {% if block.settings.iframe_url != blank %}
              <!-- Lazy load iframe with placeholder -->
              <div class="media-lazy-container" data-iframe-src="{{ block.settings.iframe_url }}">
                {% if product_image %}
                  <img
                    src="{{ product_image | img_url: '400x300' }}"
                    alt="{{ product_title }}"
                    title="{{ product_title }}"
                    class="media-placeholder"
                    loading="lazy"
                    width="400"
                    height="300"
                  >
                {% endif %}
                <div class="play-button">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 3L20 12L6 21V3Z" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
            {% elsif block.settings.video != blank %}
              <!-- Lazy load video with placeholder -->
              <div class="media-lazy-container" data-video-src="{{ block.settings.video.sources[1].url }}">
                {% if product_image %}
                  <img
                    src="{{ product_image | img_url: '400x300' }}"
                    alt="{{ product_title }}"
                    title="{{ product_title }}"
                    class="media-placeholder"
                    loading="lazy"
                    width="400"
                    height="300"
                  >
                {% elsif block.settings.image %}
                  <img
                    src="{{ block.settings.image | img_url: '400x300' }}"
                    alt="{{ product_title }}"
                    title="{{ product_title }}"
                    class="media-placeholder"
                    loading="lazy"
                    width="400"
                    height="300"
                  >
                {% endif %}
                <div class="play-button">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 3L20 12L6 21V3Z" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
            {% elsif block.settings.image != blank %}
              <div class="media-lazy-container" data-img-src="{{ block.settings.image | img_url: '800x800' }}">
                <img
                  src="{{ block.settings.image | img_url: '100x100' }}"
                  alt="{{ product_title }}"
                  title="{{ product_title }}"
                  class="media-placeholder"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              </div>
            {% endif %}

            <!-- Shopping bag icon in carousel -->
            {% if selected_product.available and selected_product.url %}
              <button class="carousel-shopping-bag" data-product-url="/products/eternal-glow-solitaire-engagement-ring">
                <svg class="icon icon-bag" width="22" height="22">
                  <use xlink:href="#icon-shopping-bag"></use>
                </svg>
              </button>
            {% elsif block.settings.watch_buy_product_fallback_url
              and block.settings.watch_buy_product_fallback_url != blank
            %}
              <button
                class="carousel-shopping-bag"
                data-product-url="{{ block.settings.watch_buy_product_fallback_url }}"
              >
                <!-- Inline SVG instead of external image request -->
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                >
                  <path d="M6 2L3 6V20C3 21.1046 3.89543 22 5 22H19C20.1046 22 21 21.1046 21 20V6L18 2H6Z"/>
                  <line x1="3" y1="6" x2="21" y2="6"/>
                  <path d="M16 10C16 13.3137 13.3137 16 10 16C6.68629 16 4 13.3137 4 10"/>
                </svg>
              </button>
            {% endif %}

            <div class="item-content">
              {% if product_title != blank %}
                <h3 class="item-title">{{ product_title }}</h3>
              {% endif %}
              <div class="item-bottom">
                <div class="item-price-wrapper">
                  {% if selected_product.compare_at_price
                    and selected_product.compare_at_price > selected_product.price
                  %}
                    <p class="item-price-compare">{{ selected_product.compare_at_price | money }}</p>
                  {% endif %}
                  <p class="item-price">
                    {% if selected_product.price -%}
                      {{- selected_product.price | money -}}
                    {%- else -%}
                      {{- block.settings.watch_buy_product_fallback_price -}}
                    {%- endif %}
                  </p>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<div class="watch-buy-video-popup" id="videoPopup">
  <div class="popup_overlay" id="popupOverlay">
    <div class="popup-content" id="popupContent">
      <button class="close-popup" id="closePopup">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
          <path d="M11 12.7563L2.54502 21.2117C2.31419 21.4422 2.02405 21.5603 1.6746 21.5659C1.32544 21.5711 1.03002 21.4531 0.788353 21.2117C0.546964 20.97 0.42627 20.6772 0.42627 20.3334C0.42627 19.9895 0.546964 19.6967 0.788353 19.455L9.24377 11L0.788353 2.54502C0.557797 2.31419 0.439742 2.02405 0.434186 1.6746C0.428909 1.32544 0.546964 1.03002 0.788353 0.788353C1.03002 0.546964 1.3228 0.42627 1.66669 0.42627C2.01058 0.42627 2.30335 0.546964 2.54502 0.788353L11 9.24377L19.455 0.788353C19.6859 0.557797 19.976 0.439742 20.3254 0.434186C20.6746 0.428909 20.97 0.546964 21.2117 0.788353C21.4531 1.03002 21.5738 1.3228 21.5738 1.66669C21.5738 2.01058 21.4531 2.30335 21.2117 2.54502L12.7563 11L21.2117 19.455C21.4422 19.6859 21.5603 19.976 21.5659 20.3254C21.5711 20.6746 21.4531 20.97 21.2117 21.2117C20.97 21.4531 20.6772 21.5738 20.3334 21.5738C19.9895 21.5738 19.6967 21.4531 19.455 21.2117L11 12.7563Z" fill="white"/>
        </svg>
      </button>

      <div class="popup-video-container" id="popupVideoContainer">
        <!-- Changed from video to iframe -->
        <iframe
          class="popup-iframe"
          id="popupIframe"
          src=""
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
        >
        </iframe>

        <!-- Removed video progress bar since iframes don't have direct progress access -->
      </div>

      <div class="video-progress-container">
        <div class="video-progress-bar">
          <div class="video-progress-fill" id="videoProgressFill"></div>
        </div>
      </div>

      <div class="popup-slider-nav">
        <button class="popup-nav-btn popup-prev" id="popupPrev">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M15 18L9 12L15 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="popup-nav-btn popup-next" id="popupNext">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M9 18L15 12L9 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <div class="popup-product-card" id="popupProductCard">
        <img class="product-card-image" id="popupProductImage" src="" alt="" loading="lazy">
        <div class="product-card-info" id="popupProductInfo">
          <h3 class="product-card-title" id="popupProductTitle"></h3>
          <div class="product-card-actions">
            <div class="product-card-price-wrapper">
              <span class="product-card-price" id="popupProductPrice"></span>
              <del class="product-card-price-compare" id="popupProductComparePrice" style="display: none;"></del>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Store loaded media URLs to avoid re-creating elements
    const loadedMedia = new Set();

    function loadMedia(container) {
      const iframeSrc = container.dataset.iframeSrc;
      const videoSrc = container.dataset.videoSrc;
      const imgSrc = container.dataset.imgSrc;

      // Create unique identifier for this media
      const mediaId = iframeSrc || videoSrc || imgSrc;
      if (!mediaId || loadedMedia.has(mediaId + container.closest('.item').innerHTML)) {
        return;
      }

      if (iframeSrc) {
        const iframe = document.createElement('iframe');
        iframe.className = 'carousel-iframe';
        iframe.src = iframeSrc;
        iframe.frameBorder = '0';
        iframe.allow = 'autoplay; fullscreen; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.loading = 'lazy';
        container.innerHTML = '';
        container.appendChild(iframe);
        const playButton = document.createElement('div');
        playButton.className = 'play-button';
        playButton.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 3L20 12L6 21V3Z" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        container.appendChild(playButton);
      } else if (videoSrc) {
        const video = document.createElement('video');
        video.loop = true;
        video.muted = true; // Keep muted in carousel
        video.autoplay = true;
        video.playsInline = true;
        const source = document.createElement('source');
        source.src = videoSrc;
        source.type = 'video/mp4';
        source.className = 'lazy-video';
        video.appendChild(source);
        container.innerHTML = '';
        container.appendChild(video);
        const playButton = document.createElement('div');
        playButton.className = 'play-button';
        playButton.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 3L20 12L6 21V3Z" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        container.appendChild(playButton);
      } else if (imgSrc) {
        const img = document.createElement('img');
        img.src = imgSrc;
        img.loading = 'lazy';
        img.alt = container.querySelector('.media-placeholder')?.alt || '';
        container.innerHTML = '';
        container.appendChild(img);
      }

      loadedMedia.add(mediaId + container.closest('.item').innerHTML);
    }

    function observeMediaContainers() {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              loadMedia(entry.target);
            }
          });
        },
        { rootMargin: '100px' }
      );

      // Observe all media containers (including cloned ones)
      document.querySelectorAll('.media-lazy-container').forEach((container) => {
        observer.observe(container);

        // Add click handler for manual loading
        container.addEventListener(
          'click',
          function () {
            if (this.dataset.iframeSrc || this.dataset.videoSrc || this.dataset.imgSrc) {
              loadMedia(this);
            }
          },
          { once: true }
        );
      });

      return observer;
    }

    // Initial observation
    let observer = observeMediaContainers();

    // Re-observe when Owl Carousel creates cloned slides
    if (typeof $ !== 'undefined' && $.fn.owlCarousel) {
      $(document).on('initialized.owl.carousel refreshed.owl.carousel', '.owl-carousel', function () {
        // Small delay to ensure cloned elements are in DOM
        setTimeout(() => {
          // Disconnect previous observer
          if (observer) {
            observer.disconnect();
          }
          // Re-observe all containers including new clones
          observer = observeMediaContainers();
        }, 100);
      });
    }

    // Fallback: Re-observe periodically (in case Owl Carousel events don't fire)
    setInterval(() => {
      const unobservedContainers = document.querySelectorAll('.media-lazy-container:not([data-observed])');
      if (unobservedContainers.length > 0) {
        unobservedContainers.forEach((container) => {
          observer.observe(container);
          container.dataset.observed = 'true';

          container.addEventListener(
            'click',
            function () {
              if (this.dataset.iframeSrc || this.dataset.videoSrc || this.dataset.imgSrc) {
                loadMedia(this);
              }
            },
            { once: true }
          );
        });
      }
    }, 2000);

    let _lastDPR = window.devicePixelRatio || 1;
    let _lastInnerWidth = window.innerWidth || document.documentElement.clientWidth;
    const ZOOM_DETECT_THRESHOLD = 0.05; // devicePixelRatio fractional change considered a "zoom"
    const RESIZE_WIDTH_THRESHOLD = 40; // px change in width considered a "layout change"

    // Pause + mute all carousel/popup videos
    function pauseAndMuteAllVideos(markAsZoom = false) {
      document.querySelectorAll('.watch-and-buy-section video, video.popup-video, .mobile-popup-video').forEach((v) => {
        try {
          v.pause();
          // ensure muted to prevent sound if autoplay later runs
          v.muted = true;
          // flag so we know we paused due to zoom/resize (useful if you want to resume later)
          if (markAsZoom) v.dataset.pausedByZoom = 'true';
        } catch (e) {
          /* ignore */
        }
      });
    }

    // Optionally resume videos that weren't paused by user when zoom/resize settles
    function resumeVideosAfterZoom() {
      document.querySelectorAll('.watch-and-buy-section video, video.popup-video, .mobile-popup-video').forEach((v) => {
        try {
          // only resume if we previously paused it due to zoom, and user didn't manually pause it
          if (v.dataset.pausedByZoom === 'true') {
            // leave muted true (only unmute on explicit user interaction)
            v.play().catch(() => {
              /* autoplay prevented - fine */
            });
            delete v.dataset.pausedByZoom;
          }
        } catch (e) {}
      });
    }

    // Detect zoom / big resize and pause videos immediately
    function handlePossibleZoomOrLayoutChange() {
      const dpr = window.devicePixelRatio || 1;
      const iw = window.innerWidth || document.documentElement.clientWidth;

      const dprChange = Math.abs(dpr - _lastDPR);
      const widthChange = Math.abs(iw - _lastInnerWidth);

      if (dprChange > ZOOM_DETECT_THRESHOLD || widthChange > RESIZE_WIDTH_THRESHOLD) {
        // It's likely a zoom or large layout shift → pause & mute to avoid accidental autoplay / audio
        pauseAndMuteAllVideos(true);

        // Debounced resume: try to resume after the user finishes resizing/zooming (optional)
        if (window._zoomResumeTimeout) clearTimeout(window._zoomResumeTimeout);
        window._zoomResumeTimeout = setTimeout(() => {
          resumeVideosAfterZoom();
          // refresh last-known values
          _lastDPR = window.devicePixelRatio || 1;
          _lastInnerWidth = window.innerWidth || document.documentElement.clientWidth;
        }, 700);
      } else {
        // small resize only — just update values
        _lastDPR = dpr;
        _lastInnerWidth = iw;
      }
    }

    // Debounce resize event to avoid thrash
    let _resizeDebounce;
    window.addEventListener('resize', function () {
      clearTimeout(_resizeDebounce);
      _resizeDebounce = setTimeout(handlePossibleZoomOrLayoutChange, 120);
    });

    // Some browsers expose zoom via 'zoom' gesture events (not standardized) — listen to gesturechange if present
    window.addEventListener('gesturechange', () => {
      handlePossibleZoomOrLayoutChange();
    });

    // Ensure videos created by your lazy loader are always muted by default and only play when intended.
    // Add a delegated handler: when you create videos, set muted=true. If you already create them elsewhere, this will enforce it.
    document.addEventListener(
      'play',
      function (e) {
        const target = e.target;
        if (target && target.tagName === 'VIDEO') {
          // If this play was triggered without user interaction and the video has audio, force mute
          if (!target.dataset.userInteracted) {
            target.muted = true; // ensures no audio plays unexpectedly
          }
        }
      },
      true
    ); // capture phase to run early

    // Allow user to unmute with an explicit click / tap - mark that as user interaction
    document.addEventListener('click', function (e) {
      const v = e.target.closest('video');
      if (v) {
        // User explicitly clicked a video → unmute and mark as user-interacted
        try {
          v.muted = false;
          v.dataset.userInteracted = 'true';
          // if it was paused, play it (explicit user gesture should allow autoplay with sound)
          v.play().catch(() => {});
        } catch (err) {}
      }
    });
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Lazy loading functionality
    const watchAndBuySection = document.getElementById('watchAndBuySection');
    let sectionLoaded = false;

    // Intersection observer for lazy loading
    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !sectionLoaded) {
            sectionLoaded = true;
            initializeWatchAndBuy();
            watchAndBuySection.classList.add('loaded');
          }
        });
      },
      {
        rootMargin: '50px 0px',
      }
    );

    // Observe the section
    sectionObserver.observe(watchAndBuySection);

    function initializeWatchAndBuy() {
      // Check if jQuery is available
      if (typeof jQuery === 'undefined') {
        console.error('jQuery is not loaded');
        return;
      }

      let currentVideoIndex = 0;
      let videoItems = [];
      let currentProductUrl = '';
      let currentProductAvailable = false;
      let isMobile = window.innerWidth <= 768;
      let mobileSwiper = null;

      // Mobile touch handling variables
      let touchStartY = 0;
      let touchEndY = 0;
      let isScrolling = false;
      let scrollTimeout;

      // Initialize Swiper for desktop/tablet
      var watchBuySwiper = new Swiper('.watch-buy-slider', {
        slidesPerView: 5,
        spaceBetween: 20,
        loop: true,
        centeredSlides: true,
        navigation: {
          nextEl: '.watch-and-buy-section .owl-next', // Keep class names if possible for CSS compatibility
          prevEl: '.watch-and-buy-section .owl-prev',
        },
        breakpoints: {
          0: {
            slidesPerView: 1.5,
            centeredSlides: true,
          },
          600: {
            slidesPerView: 3,
            centeredSlides: true,
          },
          992: {
            slidesPerView: 4.5,
            centeredSlides: false,
          },
          1200: {
            slidesPerView: 5,
            centeredSlides: false,
          }
        },
        on: {
          init: function() {
            setTimeout(() => {
              collectVideoItems();
              setupItemClickHandlers();
              handleIframeVisibility(this);
            }, 300);
          },
          slideChange: function() {
            handleIframeVisibility(this);
          }
        }
      });

      function handleIframeVisibility(swiper) {
        // Reset all iframe opacity
        document.querySelectorAll('.carousel-iframe').forEach((iframe) => {
          iframe.style.opacity = '0.7';
        });

        // Highlight center/active iframe
        const activeSlide = swiper.slides[swiper.activeIndex];
        if (activeSlide) {
          const activeIframe = activeSlide.querySelector('.carousel-iframe');
          if (activeIframe) {
            activeIframe.style.opacity = '1';
          }
        }
      }

      // Carousel shopping bag click handlers
      document.querySelectorAll('.carousel-shopping-bag').forEach((button) => {
        button.addEventListener('click', function (e) {
          e.stopPropagation();
          e.preventDefault();
          const productUrl = this.getAttribute('data-product-url');
          if (productUrl && productUrl !== 'null' && productUrl !== 'undefined') {
            window.open(productUrl, '_blank');
          }
        });
      });

      // Video popup functionality
      const popup = document.getElementById('videoPopup');
      const popupOverlay = document.getElementById('popupOverlay');
      const popupContent = document.getElementById('popupContent');
      const popupVideoContainer = document.getElementById('popupVideoContainer');
      const popupIframe = document.getElementById('popupIframe');
      const closePopup = document.getElementById('closePopup');
      const popupProductImage = document.getElementById('popupProductImage');
      const popupProductTitle = document.getElementById('popupProductTitle');
      const popupProductPrice = document.getElementById('popupProductPrice');
      const popupProductComparePrice = document.getElementById('popupProductComparePrice');
      const popupProductInfo = document.getElementById('popupProductInfo');
      const popupPrev = document.getElementById('popupPrev');
      const popupNext = document.getElementById('popupNext');
      const videoProgressFill = document.getElementById('videoProgressFill');
      const popupProductCard = document.getElementById('popupProductCard');

      // Collect all video items - now also check for iframe URLs
      function collectVideoItems() {
        videoItems = Array.from(document.querySelectorAll('.watch-and-buy-section .watch-buy-item')).filter((item) => {
          const videoSrc = item.getAttribute('data-video');
          const iframeSrc = item.getAttribute('data-iframe-url');
          return (
            (videoSrc && videoSrc !== 'null' && videoSrc !== '' && videoSrc !== 'undefined') ||
            (iframeSrc && iframeSrc !== 'null' && iframeSrc !== '' && iframeSrc !== 'undefined')
          );
        });
        console.log('Collected video items:', videoItems.length);
      }

      // Initialize video items collection
      collectVideoItems();

      // Create exact swipe indicator from image
      function createSwipeIndicator() {
        if (!document.getElementById('swipeIndicator') && isMobile) {
          const indicator = document.createElement('div');
          indicator.id = 'swipeIndicator';
          indicator.className = 'swipe-indicator-container';
          indicator.innerHTML = `
          <div class="swipe-indicator-bg">
            <div class="swipe-arrow-wrapper">
              <svg class="swipe-arrow" width="14" height="8" viewBox="0 0 14 8" fill="none">
                <path d="M1 7L7 1L13 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="swipe-text">Swipe up to see more</div>
            <div class="swipe-arrow-wrapper">
              <svg class="swipe-arrow" width="14" height="8" viewBox="0 0 14 8" fill="none">
                <path d="M1 7L7 1L13 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        `;
          popupContent.appendChild(indicator);

          // Initial hidden state (below view)
          indicator.style.transform = 'translateY(40px)';
          indicator.style.opacity = '0';
          indicator.style.transition = 'transform 0.5s ease-out, opacity 0.5s ease-out';

          // Show after 3 seconds (animate up)
          setTimeout(() => {
            if (document.getElementById('swipeIndicator')) {
              indicator.style.transform = 'translateY(0)';
              indicator.style.opacity = '1';

              // Hide after another 3 seconds (animate down)
              setTimeout(() => {
                if (document.getElementById('swipeIndicator')) {
                  indicator.style.transform = 'translateY(40px)';
                  indicator.style.opacity = '0';

                  // Remove after animation completes
                  setTimeout(() => {
                    if (indicator.parentNode) {
                      indicator.parentNode.removeChild(indicator);
                    }
                  }, 500);
                }
              }, 3000);
            }
          }, 3000);
        }
      }

      // Initialize mobile vertical swiper
      function initializeMobileSwiper() {
        console.log('Initializing mobile swiper, isMobile:', isMobile, 'existing swiper:', !!mobileSwiper);

        if (!isMobile || mobileSwiper) return;

        // Make sure we have video items
        if (videoItems.length === 0) {
          collectVideoItems();
        }

        if (videoItems.length === 0) {
          console.error('No video items found for mobile swiper');
          return;
        }

        // Create swiper container for mobile
        const swiperContainer = document.createElement('div');
        swiperContainer.className = 'mobile-video-swiper';
        swiperContainer.innerHTML = `
    <div class="swiper-wrapper" id="mobileVideoWrapper">
      ${videoItems
        .map((item, index) => {
          const iframeSrc = item.getAttribute('data-iframe-url');
          const videoSrc = item.getAttribute('data-video');
          const productImage = item.getAttribute('data-product-image');
          const productTitle = item.getAttribute('data-product-title');
          const productPrice = item.getAttribute('data-product-price');
          const productComparePrice = item.getAttribute('data-product-compare-price');
          const productUrl = item.getAttribute('data-product-url');
          const noImagePlaceholder = 'no-image-2048-a2addb12_200x200.gif';

          // Validate image
          const hasImage =
            productImage &&
            productImage !== 'null' &&
            productImage !== 'undefined' &&
            !productImage.includes(noImagePlaceholder);

          // Check if we have any valid product data
          const hasValidData = hasImage || productTitle || productPrice;

          return `
          <div class="swiper-slide" data-index="${index}">
            <div class="mobile-video-container">
              ${
                iframeSrc
                  ? `<iframe class="mobile-popup-iframe" 
                        data-src="${iframeSrc}"
                        ${index === currentVideoIndex ? `src="${iframeSrc}"` : ''}
                        frameborder="0" 
                        allow="autoplay; fullscreen; picture-in-picture" 
                        allowfullscreen>
                </iframe>`
                  : `<video class="mobile-popup-video" 
                      data-src="${videoSrc}"
                      ${index === currentVideoIndex ? 'autoplay' : ''}  
                      playsinline 
                      loop
                      muted
                      controls>
                  <source src="${videoSrc}" type="video/mp4">
                </video>`
              }
            </div>
            ${
              hasValidData
                ? `
            <div class="mobile-product-card" data-product-url="${productUrl || ''}" style="cursor: pointer;">
              ${hasImage ? `<img class="mobile-product-image" src="${productImage}" alt="Product">` : ''}
              <div class="mobile-product-info">
                <h3 class="mobile-product-title">${productTitle || ''}</h3>
                <div class="mobile-product-actions">
                  <div class="mobile-price-wrapper">
                    <span class="mobile-product-price">${productPrice || ''}</span>
                    ${productComparePrice ? `<del class="mobile-compare-price">${productComparePrice}</del>` : ''}
                  </div>
                </div>
              </div>
            </div>
            `
                : ''
            }
          </div>
          `;
        })
        .join('')}
    </div>
  `;

        // Hide desktop elements and add mobile swiper
        if (popupVideoContainer) popupVideoContainer.style.display = 'none';
        if (popupProductCard) popupProductCard.style.display = 'none';
        popupContent.appendChild(swiperContainer);

        // Check if Swiper is available
        if (typeof Swiper === 'undefined') {
          console.error('Swiper library not found. Please include Swiper.js');
          return;
        }

        // Initialize Swiper
        setTimeout(() => {
          try {
            mobileSwiper = new Swiper('.mobile-video-swiper', {
              direction: 'vertical',
              slidesPerView: 1,
              spaceBetween: 0,
              speed: 400,
              followFinger: true,
              threshold: 10,
              touchRatio: 1,
              touchAngle: 90,
              grabCursor: false,
              resistance: true,
              resistanceRatio: 0.85,
              freeMode: false,
              loop: videoItems.length > 1,
              initialSlide: currentVideoIndex,
              mousewheel: {
                enabled: true,
                sensitivity: 1,
                thresholdDelta: 50,
              },
              on: {
                slideChange: function () {
                  handleVideoChange(this.realIndex);
                },
                init: function () {
                  console.log('Mobile swiper initialized');
                  handleVideoChange(currentVideoIndex);
                },
              },
            });

            // Setup mobile product click handlers
            setupMobileProductClickHandlers();
          } catch (error) {
            console.error('Error initializing mobile swiper:', error);
          }
        }, 100);
      }

      // Setup mobile product click handlers
      function setupMobileProductClickHandlers() {
        setTimeout(() => {
          const mobileProductCards = document.querySelectorAll('.mobile-product-card');

          mobileProductCards.forEach((card, index) => {
            card.addEventListener('click', function (e) {
              e.stopPropagation();
              const productUrl = this.getAttribute('data-product-url');

              if (
                productUrl &&
                productUrl !== 'null' &&
                productUrl !== 'undefined' &&
                productUrl !== '' &&
                productUrl !== 'javascript:void(0)'
              ) {
                window.open(productUrl, '_blank');
              }
            });
          });
        }, 200);
      }

      // Handle content change in mobile swiper (videos and iframes)
      function handleVideoChange(newIndex) {
        if (newIndex < 0 || newIndex >= videoItems.length) return;

        const videos = document.querySelectorAll('.mobile-popup-video');
        const iframes = document.querySelectorAll('.mobile-popup-iframe');

        // Pause all videos
        videos.forEach((video) => {
          video.pause();
          video.currentTime = 0;
        });

        // Load iframe for current slide if it's an iframe
        const currentSlide = document.querySelector(`.swiper-slide[data-index="${newIndex}"]`);
        if (currentSlide) {
          const currentIframe = currentSlide.querySelector('.mobile-popup-iframe');
          const currentVideo = currentSlide.querySelector('.mobile-popup-video');

          if (currentIframe && !currentIframe.src) {
            const dataSrc = currentIframe.getAttribute('data-src');
            if (dataSrc) {
              currentIframe.src = dataSrc;
            }
          } else if (currentVideo) {
            const dataSrc = currentVideo.getAttribute('data-src');
            if (dataSrc && !currentVideo.src) {
              currentVideo.src = dataSrc;
            }
            currentVideo.currentTime = 0;
            currentVideo.play().catch((e) => console.log('Autoplay prevented:', e));
            currentVideo.addEventListener('timeupdate', updateVideoProgress);
            currentVideo.addEventListener('loadedmetadata', resetVideoProgress);
          }
        }

        currentVideoIndex = newIndex;
      }

      function updateVideoProgress() {
        let popupVideo = document.getElementById('popupVideo');
        if (isMobile) {
          popupVideo = document.querySelector(`.swiper-slide[data-index="${currentVideoIndex}"] .mobile-popup-video`);
        }
        if (popupVideo && popupVideo.duration && videoProgressFill) {
          const progress = (popupVideo.currentTime / popupVideo.duration) * 100;
          videoProgressFill.style.width = progress + '%';
        }
      }

      function resetVideoProgress() {
        if (videoProgressFill) {
          videoProgressFill.style.width = '0%';
        }
      }

      // Desktop iframe functions
      function loadVideoAtIndex(index) {
        if (index < 0 || index >= videoItems.length) return;

        currentVideoIndex = index;
        const item = videoItems[index];

        const iframeSrc = item.getAttribute('data-iframe-url');
        const videoSrc = item.getAttribute('data-video');
        const productImage = item.getAttribute('data-product-image');
        const productTitle = item.getAttribute('data-product-title');
        const productPrice = item.getAttribute('data-product-price');
        const productComparePrice = item.getAttribute('data-product-compare-price');
        const productUrl = item.getAttribute('data-product-url');
        const productAvailable = item.getAttribute('data-product-available') === 'true';

        currentProductUrl = productUrl;
        currentProductAvailable = productAvailable;

        // Get or create video element
        let popupVideo = document.getElementById('popupVideo');
        if (!popupVideo) {
          popupVideo = createVideoElement();
          popupVideoContainer.appendChild(popupVideo);
        }

        // Handle iframe vs video
        if (iframeSrc && iframeSrc !== 'null' && iframeSrc !== 'undefined' && iframeSrc !== '') {
          // Show iframe, hide video and progress bar
          popupIframe.src = iframeSrc;
          popupIframe.style.display = 'block';
          popupVideo.style.display = 'none';

          // Hide progress bar for iframes since we can't track their progress
          const progressContainer = document.querySelector('.video-progress-container');
          if (progressContainer) {
            progressContainer.style.display = 'none';
          }
        } else if (videoSrc && videoSrc !== 'null' && videoSrc !== 'undefined' && videoSrc !== '') {
          // Show video, hide iframe
          popupIframe.style.display = 'none';
          popupVideo.style.display = 'block';

          // Show progress bar for videos
          const progressContainer = document.querySelector('.video-progress-container');
          if (progressContainer) {
            progressContainer.style.display = 'block';
          }

          // Set video source
          popupVideo.src = videoSrc;

          // Reset progress
          if (videoProgressFill) {
            videoProgressFill.style.width = '0%';
          }

          // Remove existing event listeners to prevent duplicates
          popupVideo.removeEventListener('timeupdate', updateVideoProgress);
          popupVideo.removeEventListener('loadedmetadata', resetVideoProgress);

          // Add event listeners for progress tracking
          popupVideo.addEventListener('timeupdate', updateVideoProgress);
          popupVideo.addEventListener('loadedmetadata', resetVideoProgress);

          // Auto-play video with controls enabled
          popupVideo.play().catch((e) => console.log('Autoplay prevented:', e));
        }

        // ✅ Put this at the top of your script (once)
        const noImagePlaceholder = 'no-image-2048-a2addb12_200x200.gif';

        function updatePopupCard(imageEl, titleEl, priceEl, cardEl, productImage, productTitle, productPrice) {
          // Validate image
          const hasImage =
            productImage &&
            productImage !== 'null' &&
            productImage !== 'undefined' &&
            !productImage.includes(noImagePlaceholder);

          if (hasImage) {
            imageEl.src = productImage;
            imageEl.style.display = 'block';
          } else {
            imageEl.removeAttribute('src');
            imageEl.style.display = 'none';
          }

          // Title & Price
          titleEl.textContent = productTitle || '';
          priceEl.textContent = productPrice || '';

          // Final check → hide card if nothing valid
          if (!hasImage && !productTitle && !productPrice) {
            cardEl.style.setProperty('display', 'none', 'important');
          } else {
            cardEl.style.setProperty('display', 'flex', 'important');
          }
        }

        // ✅ Desktop popup
        updatePopupCard(
          popupProductImage,
          popupProductTitle,
          popupProductPrice,
          popupProductCard,
          productImage,
          productTitle,
          productPrice
        );

        // ✅ Mobile swiper popup
        updatePopupCard(
          popupProductImageMobile,
          popupProductTitleMobile,
          popupProductPriceMobile,
          popupProductCardMobile,
          productImage,
          productTitle,
          productPrice
        );
      }

      function showPrevVideo() {
        const prevIndex = currentVideoIndex > 0 ? currentVideoIndex - 1 : videoItems.length - 1;
        loadVideoAtIndex(prevIndex);
      }

      function showNextVideo() {
        const nextIndex = currentVideoIndex < videoItems.length - 1 ? currentVideoIndex + 1 : 0;
        loadVideoAtIndex(nextIndex);
      }

      // Enhanced popup opening function
      function openVideoPopup(clickedIndex) {
        console.log('Opening popup for index:', clickedIndex, 'isMobile:', isMobile);

        // Update mobile detection
        updateMobileDetection();

        // Set current index
        currentVideoIndex = clickedIndex;

        // Show popup
        popup.style.display = 'block';
        document.body.style.overflow = 'hidden';

        // Pause all carousel videos
        document.querySelectorAll('.watch-and-buy-section .watch-buy-item video').forEach((vid) => {
          vid.pause();
        });

        if (isMobile) {
          console.log('Initializing mobile popup');
          initializeMobileSwiper();
          createSwipeIndicator();
        } else {
          console.log('Initializing desktop popup');
          loadVideoAtIndex(currentVideoIndex);
        }
      }

      // Handle item clicks - FIXED VERSION
      function setupItemClickHandlers() {
        document.querySelectorAll('.watch-and-buy-section .watch-buy-item').forEach((item, index) => {
          // Remove any existing click handlers
          item.removeEventListener('click', handleItemClick);

          // Add new click handler
          item.addEventListener('click', handleItemClick);

          function handleItemClick(e) {
            console.log('Item clicked:', index, 'Target:', e.target);

            // Check if the click was on the shopping bag or its children
            if (e.target.closest('.carousel-shopping-bag')) {
              console.log('Shopping bag clicked, preventing popup');
              return;
            }

            e.preventDefault();
            e.stopPropagation();

            const videoSrc = this.getAttribute('data-video');
            const iframeSrc = this.getAttribute('data-iframe-url');

            console.log('Video src:', videoSrc, 'Iframe src:', iframeSrc);

            if (
              (videoSrc && videoSrc !== 'null' && videoSrc !== '' && videoSrc !== 'undefined') ||
              (iframeSrc && iframeSrc !== 'null' && iframeSrc !== '' && iframeSrc !== 'undefined')
            ) {
              // Find the index in videoItems array
              const videoIndex = videoItems.findIndex((videoItem) => videoItem === this);
              console.log('Found video index:', videoIndex);

              if (videoIndex !== -1) {
                openVideoPopup(videoIndex);
              } else {
                console.error('Could not find video item in array');
                // Fallback: use the DOM index
                const allItems = Array.from(document.querySelectorAll('.watch-and-buy-section .watch-buy-item'));
                const domIndex = allItems.indexOf(this);
                if (domIndex !== -1) {
                  openVideoPopup(domIndex);
                }
              }
            } else {
              console.log('No valid video or iframe source found');
            }
          }
        });
      }

      // Initialize click handlers
      setTimeout(setupItemClickHandlers, 500);

      // Desktop navigation
      if (popupPrev) {
        popupPrev.addEventListener('click', function (e) {
          e.stopPropagation();
          if (!isMobile) {
            showPrevVideo();
          }
        });
      }

      if (popupNext) {
        popupNext.addEventListener('click', function (e) {
          e.stopPropagation();
          if (!isMobile) {
            showNextVideo();
          }
        });
      }

      // Product info click (desktop)
      if (popupProductInfo) {
        popupProductInfo.addEventListener('click', function (e) {
          e.stopPropagation();
          if (currentProductUrl && currentProductUrl !== 'null' && currentProductUrl !== 'undefined') {
            window.open(currentProductUrl, '_blank');
          }
        });
      }

      // Enhanced close popup functionality
      function closeVideoPopup() {
        console.log('Closing popup');

        popup.style.display = 'none';
        document.body.style.overflow = 'auto';

        // Clean up desktop video
        const popupVideo = document.getElementById('popupVideo');
        if (popupVideo) {
          popupVideo.pause();
          popupVideo.currentTime = 0;
          popupVideo.removeEventListener('timeupdate', updateVideoProgress);
          popupVideo.removeEventListener('loadedmetadata', resetVideoProgress);
          popupVideo.muted = false; // ✅ unmute only after user interaction
          popupVideo.play().catch((e) => console.log('Autoplay with sound still blocked:', e));
          popupVideo.src = '';
          popupVideo.load();
        }

        // Clean up desktop iframe
        if (popupIframe) {
          popupIframe.src = '';
        }

        // Reset progress bar
        if (videoProgressFill) {
          videoProgressFill.style.width = '0%';
        }

        // Remove swipe indicator if it exists
        const swipeIndicator = document.getElementById('swipeIndicator');
        if (swipeIndicator && swipeIndicator.parentNode) {
          swipeIndicator.parentNode.removeChild(swipeIndicator);
        }

        // Handle mobile swiper cleanup
        if (mobileSwiper) {
          try {
            console.log('Cleaning up mobile swiper');

            // Pause all mobile videos and clear iframes
            const mobileVideos = document.querySelectorAll('.mobile-popup-video');
            const mobileIframes = document.querySelectorAll('.mobile-popup-iframe');

            mobileVideos.forEach((video) => {
              video.pause();
              video.currentTime = 0;
              video.removeEventListener('timeupdate', updateVideoProgress);
              video.removeEventListener('loadedmetadata', resetVideoProgress);
              video.removeAttribute('src');
              video.load();
            });

            mobileIframes.forEach((iframe) => {
              iframe.src = '';
            });

            // Destroy swiper instance
            mobileSwiper.destroy(true, true);
            mobileSwiper = null;

            // Remove mobile swiper container
            const swiperContainer = document.querySelector('.mobile-video-swiper');
            if (swiperContainer && swiperContainer.parentNode) {
              swiperContainer.parentNode.removeChild(swiperContainer);
            }

            // Restore desktop elements
            if (popupVideoContainer) popupVideoContainer.style.display = 'block';
            if (popupProductCard) popupProductCard.style.display = 'block';
          } catch (error) {
            console.error('Error destroying mobile swiper:', error);
          }
        }

        // Reset current video index
        currentVideoIndex = 0;

        // Resume carousel content after popup closes
        resumeCarouselContent();
      }

      function createVideoElement() {
        const videoElement = document.createElement('video');
        videoElement.id = 'popupVideo';
        videoElement.className = 'popup-video';
        videoElement.controls = true;
        videoElement.loop = true;
        videoElement.muted = false; // ENABLE AUDIO FOR POPUP
        videoElement.playsInline = true;
        videoElement.style.width = '100%';
        videoElement.style.objectFit = 'cover';
        videoElement.style.borderRadius = '8px';
        videoElement.style.display = 'none';

        // Add event listener to ensure audio stays enabled
        videoElement.addEventListener('loadedmetadata', function () {
          this.muted = false;
        });

        return videoElement;
      }

      // Close popup event listeners
      if (closePopup) {
        closePopup.addEventListener('click', function (e) {
          e.stopPropagation();
          closeVideoPopup();
        });
      }

      if (popupOverlay) {
        popupOverlay.addEventListener('click', function (e) {
          if (e.target === popupOverlay) {
            closeVideoPopup();
          }
        });
      }

      if (popupContent) {
        popupContent.addEventListener('click', function (e) {
          e.stopPropagation();
        });
      }

      // Keyboard navigation
      document.addEventListener('keydown', function (e) {
        if (popup.style.display === 'block') {
          if (e.key === 'Escape') {
            closeVideoPopup();
          } else if (!isMobile) {
            if (e.key === 'ArrowLeft') {
              e.preventDefault();
              showPrevVideo();
            } else if (e.key === 'ArrowRight') {
              e.preventDefault();
              showNextVideo();
            }
          }
        }
      });

      // Enhanced carousel content intersection observer for both videos and iframes
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const video = entry.target.querySelector('video');
            const iframe = entry.target.querySelector('.carousel-iframe');

            if (entry.isIntersecting) {
              if (video) {
                video.play().catch(console.error);
              }
              if (iframe) {
                iframe.style.opacity = '1';
              }
            } else {
              if (video) {
                video.pause();
              }
              if (iframe) {
                iframe.style.opacity = '0.7';
              }
            }
          });
        },
        {
          threshold: 0.5,
        }
      );

      // Observe carousel items for content autoplay/visibility
      document.querySelectorAll('.watch-and-buy-section .watch-buy-item').forEach((item) => {
        observer.observe(item);
      });

      // Initialize iframe visibility
      document.querySelectorAll('.carousel-iframe').forEach((iframe) => {
        iframe.style.opacity = '0.7';
        iframe.style.transition = 'opacity 0.3s ease';
      });

      // Set initial active item iframe to full opacity
      setTimeout(() => {
        const activeItem = document.querySelector('.watch-and-buy-section .owl-item.active.center .carousel-iframe');
        if (activeItem) {
          activeItem.style.opacity = '1';
        }
      }, 500);

      // Swiper handles these through its internal observer or by calling update()
      // We already have setupItemClickHandlers in our init and transition events.
    }
  });
</script>

