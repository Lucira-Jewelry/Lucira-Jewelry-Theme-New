<div class="tcc-collection-grid-section">
<div class="page-width">
  <div class="tcc-container">
    {% if section.settings.section_subheader != blank or section.settings.section_header != blank %}
    <div class="tcc-header-wrapper">
      {% if section.settings.section_subheader != blank %}
        <p class="tcc-subheader">{{ section.settings.section_subheader }}</p>
      {% endif %}
      {% if section.settings.section_header != blank %}
        <h2 class="tcc-header">{{ section.settings.section_header }}</h2>
      {% endif %}
    </div>
    {% endif %}
    
    <div class="tcc-grid-wrapper">
      {% for block in section.blocks %}
        <div class="tcc-grid-item" {{ block.shopify_attributes }}>
          {% if block.settings.collection_link != blank %}
            <a href="{{ block.settings.collection_link }}" class="tcc-item-link">
          {% endif %}
          
          <div class="tcc-image-wrapper">
            {% if block.settings.collection_image != blank %}
              <img 
                src="{{ block.settings.collection_image | img_url: '400x400', crop: 'center' }}" 
                alt="{{ block.settings.collection_name | escape }}"
                loading="eager"
                class="tcc-image"
                width="200"
                height="200"
              >
            {% else %}
              <div class="tcc-placeholder">
                {{ 'image' | placeholder_svg_tag: 'tcc-placeholder-svg' }}
              </div>
            {% endif %}
          </div>
          
          <p class="tcc-name">{{ block.settings.collection_name }}</p>
          
          {% if block.settings.collection_link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>
</div>

<style>
  .tcc-collection-grid-section {padding-top: 30px;}
  .tcc-container { max-width: {{ section.settings.max_width }}px; margin: 0 auto; padding-bottom:0px; }
  .tcc-header-wrapper{text-align:center;margin-bottom:40px}
  .tcc-subheader{font-size:14px;font-weight:400;text-transform:uppercase;letter-spacing:2px;color:#666;margin:0 0 8px 0}
  .tcc-header{font-family:Futura Std;font-weight:500;font-style:Medium;font-size:24px;line-height:150%;letter-spacing:3%;text-align:center;vertical-align:middle;letter-spacing: normal; text-transform: uppercase; color: #1a1a1a; text-align: center; font-weight: 400; font-size: 24px; margin-bottom: 0; margin-top: 0;}
  .tcc-grid-wrapper{display:grid;grid-template-columns:repeat(6,1fr);justify-items:center;max-width:1190px;margin:0 auto}
  .tcc-grid-item{text-align:center;width:100%;max-width:160px;display:flex;flex-direction:column;align-items:center}
  .tcc-item-link{text-decoration:none;color:inherit;display:flex;flex-direction:column;align-items:center;gap:12px;width:100%;transition:opacity .3s ease;-webkit-tap-highlight-color:transparent;-webkit-touch-callout:none;-webkit-user-select:none;-moz-user-select:none;-ms-user-select:none;user-select:none}
  .tcc-item-link:hover{opacity:.85}
  .tcc-item-link:focus{outline-offset:4px}
  .tcc-item-link:active{opacity:.7}
  .tcc-image-wrapper{width:100%;padding-bottom:100%;position:relative;border-radius:50%;overflow:hidden;background-color:#f5f5f5}
  .tcc-image{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover}
  .tcc-placeholder{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;align-items:center;justify-content:center;background-color:#e0e0e0}
  .tcc-placeholder-svg{width:50%;height:50%;fill:#999}
  .tcc-name{font-size:14px;font-weight:500;text-transform:uppercase;color:#333;margin:0;letter-spacing:.5px;line-height:1.3;text-align:center; margin-top: 8px;}
  
  @media (max-width: 1024px) {
    .tcc-grid-wrapper { grid-template-columns: repeat(4, 1fr); gap: {{ section.settings.grid_gap | minus: 5 }}px; }
    .tcc-header { font-size: 28px; } 
    .tcc-subheader { font-size: 13px; } 
    .tcc-header-wrapper { margin-bottom: 32px; }
  }

  @media (max-width: 768px) {
    .tcc-collection-grid-section {padding: 24px 16px;}
    .tcc-grid-wrapper { grid-template-columns: repeat(3, 1fr); gap: 22px; }
    .tcc-grid-item { max-width: 100%; }
    .tcc-name { font-size: 11px; letter-spacing: 0.3px; }
    .tcc-item-link { gap: 8px; }
    .tcc-header { font-size: 24px; font-family: Futura Std; font-weight: 500; font-style: Medium; font-size: 18px; line-height: 150%; letter-spacing: 4%; text-align: center; vertical-align: middle; }
    .tcc-subheader { font-size: 12px; letter-spacing: 1.5px; }
    .tcc-header-wrapper { margin-bottom: 24px; }
  }
  
  /* Small Mobile Optimization */
  @media (max-width: 480px) {
    .tcc-collection-grid-section { padding: 0 12px; }
    .tcc-grid-wrapper { gap: 12px; }
    .tcc-name { font-size: 10px; }
    .tcc-header { font-size: 20px; } 
    .tcc-subheader { font-size: 11px; } 
    .tcc-header-wrapper { margin-bottom: 20px; }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // GTM Tracking - Fire promoClick event
  function firePromoClick(collectionItem) {
    const link = collectionItem.querySelector('.tcc-item-link');
    if (!link) return;
    
    const collectionName = collectionItem.querySelector('.tcc-name')?.innerText?.trim() || '';
    const collectionUrl = link.getAttribute('href') || '';
    
    if (!collectionName) return;
    
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: "promoClick",
      promoClick: {
        promo_id: '{{ product.selected_or_first_available_variant.sku }}',
        creative_name: 'PDP Collection Grid',
        promo_position: 'pdp_collection_grid_bottom_above_footer', 
        promo_name: collectionName,
        location_id: collectionUrl
      }
    });
    console.log('GTM promoClick fired for collection:', collectionName, collectionUrl);
  }

  // Bind click tracking with event delegation
  function bindCollectionClickTracking() {
    const container = document.querySelector('.tcc-collection-grid-section');
    
    if (!container) {
      console.log('TCC Collection grid container not found for tracking');
      return;
    }

    console.log('Binding TCC collection click tracking to:', container);
    
    container.addEventListener('click', function(e) {
      const collectionItem = e.target.closest('.tcc-grid-item');
      if (!collectionItem) return;
      
      console.log('TCC Collection item clicked, firing promo click');
      firePromoClick(collectionItem);
    }, { capture: true });
  }
  
  // Initialize tracking
  bindCollectionClickTracking();
});
</script>

{% comment %} 
{
      "type": "text",
      "id": "section_subheader",
      "label": "Subheader",
      "default": "SHOP BY CATEGORY"
    },
     {% endcomment %}
{% schema %}
{
  "name": "Trendy Categories Grid",
  "settings": [
    
    {
      "type": "text",
      "id": "section_header",
      "label": "Header",
      "default": "TRENDY CATEGORIES"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 1400
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Grid gap",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection Item",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "collection_image",
          "label": "Collection Image"
        },
        {
          "type": "text",
          "id": "collection_name",
          "label": "Collection Name",
          "default": "Collection"
        },
        {
          "type": "url",
          "id": "collection_link",
          "label": "Collection Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trendy Categories Grid",
      "blocks": [
        {
          "type": "collection_item",
          "settings": {
            "collection_name": "PROPOSAL RING"
          }
        },
        {
          "type": "collection_item",
          "settings": {
            "collection_name": "PROMISE RING"
          }
        },
        {
          "type": "collection_item",
          "settings": {
            "collection_name": "ENGAGEMENT RING"
          }
        },
        {
          "type": "collection_item",
          "settings": {
            "collection_name": "WEDDING RING"
          }
        },
        {
          "type": "collection_item",
          "settings": {
            "collection_name": "ANNIVERSARY RING"
          }
        },
        {
          "type": "collection_item",
          "settings": {
            "collection_name": "GIFTING RING"
          }
        }
      ]
    }
  ]
}
{% endschema %}