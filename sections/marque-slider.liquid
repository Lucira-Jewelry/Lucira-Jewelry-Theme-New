<div class="logos">
    <div class="logos-slide">
      <h3>{{ section.settings.text1 }}</h3> 
      <h3>{{ section.settings.text2 }}</h3> 
      <h3>{{ section.settings.text3 }}</h3> 
      <h3>{{ section.settings.text4 }}</h3>
      {% if section.settings.text5 != blank %}
        <h3>{{ section.settings.text5 }}</h3>
      {% endif %}
      {% if section.settings.text6 != blank %}
        <h3>{{ section.settings.text6 }}</h3>
      {% endif %}
    </div>
</div>

<style>
  @keyframes slide {
    from { transform: translateX(0); }
    to { transform: translateX(-100%); }
  }
  
  .logos {
    overflow: hidden;
    padding: 10px 0;
    background: #a68380;
    white-space: nowrap;
    position: relative;
    display: flex;
  }
  
  .logos:before,
  .logos:after {
    position: absolute;
    top: 0;
    width: 50px;
    height: 100%;
    content: "";
    z-index: 2;
  }
  
  .logos:before {
    left: 0;
    background: linear-gradient(to right, #a68380, transparent);
  }
  
  .logos:after {
    right: 0;
    background: linear-gradient(to left, #a68380, transparent);
  }
  
  .logos:hover .logos-slide {
    animation-play-state: paused;
  }
  
  .logos-slide {
    display: flex;
    animation: 35s slide infinite linear;
    white-space: nowrap;
  }
  
  .logos-slide h3 {
    margin: 0 40px 0 0;
    font-size: 20px;
    font-weight: 500;
    line-height: 24px;
    letter-spacing: 0.02em;
    color: #fff;
    flex-shrink: 0;
  }
  
  .logos-slide h3:last-child {
    margin-right: 40px;
  }
  
  .logos-slide h3 a {
    text-decoration: underline;
    cursor: pointer;
    color: #000;
  }
  
  @media (max-width: 767px) {
    .logos-slide h3 {
      font-size: 16px;
      margin-right: 30px;
    }
    
    .logos-slide h3:last-child {
      margin-right: 30px;
    }
  }
</style>

{% if product.collections contains collections['hexa'] %}
  <style>
    .logos { background: #0f0916; }
    .logos:before { background: linear-gradient(to right, #0f0916, transparent); }
    .logos:after { background: linear-gradient(to left, #0f0916, transparent); }
  </style>
{% endif %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const logosContainer = document.querySelector(".logos");
    const originalSlide = document.querySelector(".logos-slide");
    
    if (originalSlide && logosContainer) {
      // Clone the slide multiple times for seamless loop
      for (let i = 0; i < 3; i++) {
        const copy = originalSlide.cloneNode(true);
        logosContainer.appendChild(copy);
      }
    }
  });
</script>

