<div class="marquee_container">
    <div class="marquee">
      <h3>{{ section.settings.text1 }}</h3> 
      <h3>{{ section.settings.text2 }}</h3> 
      <h3>{{ section.settings.text3 }}</h3> 
      <h3>{{ section.settings.text4 }}</h3>
      {% if section.settings.text5 != blank %}
        <h3>{{ section.settings.text5 }}</h3>
      {% endif %}
      {% if section.settings.text6 != blank %}
        <h3>{{ section.settings.text6 }}</h3>
      {% endif %}
    </div>
    <div class="marquee">
      <h3>{{ section.settings.text1 }}</h3> 
      <h3>{{ section.settings.text2 }}</h3> 
      <h3>{{ section.settings.text3 }}</h3> 
      <h3>{{ section.settings.text4 }}</h3>
      {% if section.settings.text5 != blank %}
        <h3>{{ section.settings.text5 }}</h3>
      {% endif %}
      {% if section.settings.text6 != blank %}
        <h3>{{ section.settings.text6 }}</h3>
      {% endif %}
    </div>
</div>

<style>
    .marquee_container {
        width: 100%;
        overflow: hidden;
        white-space: nowrap;
        background: #ff5c5c;
        padding: 0.2rem 0;
    }
    .marquee {
        display: inline-block;
        animation: marquee 10s linear infinite;
    }
    @keyframes marquee {
        from {
            transform: translate3d(0, 0, 0);
        }
        to {
            transform: translate3d(-100%, 0, 0);
        }
    }
</style>

{% if product.collections contains collections['hexa'] %}
  <style>
    .logos { background: #0f0916; }
    .logos:before { background: linear-gradient(to right, #0f0916, transparent); }
    .logos:after { background: linear-gradient(to left, #0f0916, transparent); }
  </style>
{% endif %}


