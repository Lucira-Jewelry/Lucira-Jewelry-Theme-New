<style>
.testimonials-wrapper{text-align:center;padding:40px 20px}
.testimonials-wrapper h2{margin:0;font-weight:500;font-size:28px;line-height:150%;text-align:center;text-transform:uppercase;color:#1a1a1a}
.testimonials-grid-wrapper{width:95%;margin:0 auto}
.testimonials-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;justify-content:center}
.testimonial-card{width:100%;height:387px;border:2px solid #ab8a87;border-radius:10px;padding:20px;text-align:left;background-color:#f5eee7}
.product-image{width:100px;height:100px;object-fit:cover;border-radius:50%;border:2px solid #ab8a87;display:block}
.testimonial-text{font-style:italic;font-size:14px;margin-bottom:20px;height:95px}
.testimonial-footer{display:flex;align-items:center;gap:10px;transform:translate(8px,55px)}
.testimonial-footer img{width:50px;height:50px;border-radius:50%}
.testimonial-rating span{color:#ffb000}
a.button-design{background:#a68380;color:#fff;text-decoration:none;padding:16px 32px;display:inline-block;max-width:360px;width:100%;text-align:center;border-radius:20px;font-family:Futura,sans-serif;font-weight:500;font-size:16px;line-height:1.2;text-transform:uppercase}
@media screen and (max-width:767px){
.testimonials-wrapper{padding-top:20px;padding-bottom:20px}
.testimonials-grid{display:flex;gap:16px;overflow-x:auto;justify-content:flex-start;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;width:100%;padding-left:20px;padding-right:20px;margin-right:-16px}
.testimonials-grid-wrapper{width:100%;overflow:hidden}
.testimonial-card{flex:0 0 80%;scroll-snap-align:start;height:auto}
.testimonials-wrapper h2{font-size:18px}
.testimonial-text{height:auto}
.testimonial-footer{transform:translate(8px,13px)}
.testimonials-grid::-webkit-scrollbar{display:none}
.testimonials-grid{-ms-overflow-style:none;scrollbar-width:none}
}
</style>
{% if page.handle contains 'store-page' %}
  <style>
    .button-design {
      display: none !important;
    }
  </style>
{% endif %}

<div class="testimonials-wrapper page-width">
  <h2>{{ section.settings.testheading }}</h2>
  <p>{{ section.settings.testsubheading }}</p>

  <div class="testimonials-grid-wrapper">
    <div class="testimonials-grid">
      {% for block in section.blocks %}
        <div class="testimonial-card" style="background-color: {{ block.settings.card_bg }}">
          {% if block.settings.testproduct_image %}
            <img
              src="{{ block.settings.testproduct_image | img_url: '150x150' }}"
              alt="Product Image"
              class="product-image"
            >
          {% endif %}
          <p class="testimonial-text">“{{ block.settings.testimonial_text }}”</p>
          <div class="testimonial-footer">
            {% if block.settings.author_image %}
              <img src="{{ block.settings.author_image | img_url: '50x50' }}"title="{{ block.settings.author_name }}" alt="{{ block.settings.author_name }}">
            {% endif %}
            <div>
              <div>{{ block.settings.author_name }}</div>
              <div class="testimonial-rating">
                {% for i in (1..block.settings.rating) %}
                  <span>★</span>
                {% endfor %}
                {% for i in (block.settings.rating..4) %}
                  <span style="color:#ccc;">★</span>
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  {% if section.settings.testbutton_text != blank %}
    <div class="testimonials-button">
      <a href="{{ section.settings.button_link }}" class="button-design">{{ section.settings.testbutton_text }}</a>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "videoTestimonials",
  "settings": [
    {
      "type": "text",
      "id": "testheading",
      "label": "Heading",
      "default": "TESTIMONIALS"
    },
    {
      "type": "textarea",
      "id": "testsubheading",
      "label": "Subheading",
      "default": "Lorem ipsum dolor sit amet..."
    },
    {
      "type": "text",
      "id": "testbutton_text",
      "label": "Button Text",
      "default": "SCHEDULE A VIDEO CALL"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "testproduct_image",
          "label": "Product Image"
        },
        {
          "type": "textarea",
          "id": "testimonial_text",
          "label": "Testimonial Text"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author Image"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Tanvi Nair"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating (out of 5)",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 4
        },
        {
          "type": "color",
          "id": "card_bg",
          "label": "Card Background Color",
          "default": "#f5eee7"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "videoTestimonials"
    }
  ]
}
{% endschema %}




