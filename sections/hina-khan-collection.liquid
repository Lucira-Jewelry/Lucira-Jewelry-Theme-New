{%- assign desktop_image = section.settings.background_image_desktop -%}
{%- assign mobile_image = section.settings.background_image_mobile -%}

<style>
  .image-with-text-overlay {
    position: relative;
    height: 605px;
    display: flex;
    width: 100%;
    align-items: center; /* vertical center */
    justify-content: flex-start; /* left align */
    padding: 0 80px; /* left spacing */
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    z-index: 1;
  }

  .page-astro-gemstone-page-template-page .image-with-text-overlay {
    height: 725px;
  }

  /* Desktop Image */
  {% if desktop_image != blank %}
    .image-with-text-overlay {
      background-image: url('{{ desktop_image | img_url: '1920x' }}');
    }
  {% endif %}

  /* Mobile Image */
  {% if mobile_image != blank %}
    @media (max-width: 768px) {
      .image-with-text-overlay {
        background-image: url('{{ mobile_image | img_url: '768x' }}');
        height: 535px;
      }
    }
  {% endif %}

  .image-with-text-overlay__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ section.settings.overlay_color | color_modify: 'alpha', section.settings.overlay_opacity }};
    z-index: 2;
  }

  .image-with-text-overlay__content {
    position: relative;
    z-index: 3;
    text-align: left;
    color: {{ section.settings.text_color }};
    max-width: 500px;
  }

  .image-with-text-overlay__heading {
    font-size: 32px;
    margin: 0 0 10px;
    color: {{ section.settings.text_color }};
  }

  .image-with-text-overlay__subheading {
    font-size: 14px;
    margin: 0;
    line-height: 1.6;
    opacity: 0.9;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .image-with-text-overlay {
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 0 20px;
      height: 535px;
    }

    .image-with-text-overlay__content {
      text-align: center;
      max-width: 90%;
    }

    .image-with-text-overlay__heading {
      font-size: 20px;
    }

    .image-with-text-overlay__subheading {
      font-size: 12px;
    }

    .page-astro-gemstone-page-template-page .image-with-text-overlay {
      height: 200px;
    }
  }

  /* Store pages spacing */
  {% if page.handle == 'store-service-page' or page.handle == 'store-packaging' %}
    .image-with-text-overlay {
      margin-bottom: 80px;
    }

    @media(max-width:767px){
      .image-with-text-overlay {
        margin-bottom: 20px;
      }
    }
  {% endif %}
</style>

<section class="image-with-text-overlay">
  <div class="image-with-text-overlay__overlay"></div>

  <div class="image-with-text-overlay__content">
    {% if section.settings.heading != blank %}
      <h2 class="image-with-text-overlay__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="image-with-text-overlay__subheading">
        {{ section.settings.subheading }}
      </p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hina Khan Banner",
  "tag": "section",
  "class": "shopify-section--image-with-text-overlay",
  "settings": [
    {
      "type": "header",
      "content": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "background_image_desktop",
      "label": "Desktop Background Image"
    },
    {
      "type": "header",
      "content": "Mobile Image"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Mobile Background Image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000",
      "alpha": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Overlay Opacity",
      "default": 0.3
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hina Khan’s Favourite"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Hina Khan Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}