{% comment %}theme-check-disable UndefinedObject{% endcomment %}

{%- assign pick_up_availabilities = product_variant.store_availabilities | where: 'pick_up_enabled', true -%}
{%- assign available_stores = pick_up_availabilities | where: 'available', true -%}

{%- if pick_up_availabilities.size > 0 -%}

  {% assign closest_location = pick_up_availabilities.first %}
  {% assign loc = closest_location.location.name %}

  {% case loc %}
    {% when 'BO1' %}{% assign loc_name = 'Borivali' %}
    {% when 'CS1' %}{% assign loc_name = 'Chembur' %}
    {% when 'PS1' %}{% assign loc_name = 'Pune' %}
    {% when 'NOS18' %}{% assign loc_name = 'Noida' %}
    {% when 'Divinecarat Lifestyles Pvt Ltd' %}{% assign loc_name = 'Head Office' %}
    {% else %}{% assign loc_name = loc %}
  {% endcase %}

  <pickup-availability-preview class="pickup-availability-preview">
    <div class="pickup-availability-info">

      {%- if closest_location.available -%}

        <p class="caption-large">
          {% if available_stores.size == 1 %}
            Available at {{ loc_name }}
          {% else %}
            Available at {{ loc_name }} + {{ available_stores.size | minus: 1 }} other store{% if available_stores.size > 2 %}s{% endif %}
          {% endif %}
        </p>

        <button
          id="ShowPickupAvailabilityDrawer"
          class="pickup-availability-button link link--text underlined-link"
          aria-haspopup="dialog"
        >
          {% if available_stores.size == 1 %}
            View Store
          {% else %}
            Find All Stores
          {% endif %}
        </button>

      {%- else -%}

        <p class="caption-large">
          Not available at {{ loc_name }}
        </p>

        {% if available_stores.size > 1 %}
          <button
            id="ShowPickupAvailabilityDrawer"
            class="pickup-availability-button link link--text underlined-link"
            aria-haspopup="dialog"
          >
            Check Other Stores
          </button>
        {% endif %}

      {%- endif -%}

    </div>
  </pickup-availability-preview>

  <pickup-availability-drawer
    class="gradient"
    tabindex="-1"
    role="dialog"
    aria-modal="true"
    aria-labelledby="PickupAvailabilityHeading"
  >

    <ul class="pickup-availability-list list-unstyled" role="list">

      {%- for availability in available_stores -%}

        {% assign loc = availability.location.name %}

        {% case loc %}
          {% when 'BO1' %}{% assign loc_name = 'Borivali' %}
          {% when 'CS1' %}{% assign loc_name = 'Chembur' %}
          {% when 'PS1' %}{% assign loc_name = 'Pune' %}
          {% when 'NOS18' %}{% assign loc_name = 'Noida' %}
          {% when 'Divinecarat Lifestyles Pvt Ltd' %}{% assign loc_name = 'Head Office' %}
          {% else %}{% assign loc_name = loc %}
        {% endcase %}

        <li class="pickup-availability-list__item">
          <h3 class="h4">{{ loc_name }}</h3>

          <p class="pickup-availability-preview caption-large">
            <span class="svg-wrapper">
              {{- 'icon-tick.svg' | inline_asset_content -}}
            </span>
            Available at {{ loc_name }}
          </p>
        </li>

      {%- endfor -%}

    </ul>

  </pickup-availability-drawer>

{%- endif -%}