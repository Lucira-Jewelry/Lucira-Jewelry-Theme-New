{% comment %}theme-check-disable UndefinedObject{% endcomment %}

{%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities | where: 'pick_up_enabled', true -%}
{%- assign available_stores = pick_up_availabilities | where: 'available', true -%}

{%- if available_stores.size > 0 -%}

  {% assign first_store = available_stores.first %}
  {% assign loc = first_store.location.name %}

  {% case loc %}
    {% when 'BO1' %}{% assign loc_name = 'Borivali' %}
    {% when 'CS1' %}{% assign loc_name = 'Chembur' %}
    {% when 'PS1' %}{% assign loc_name = 'Pune' %}
    {% when 'NOS18' %}{% assign loc_name = 'Noida' %}
    {% when 'Divinecarat Lifestyles Pvt Ltd' %}{% assign loc_name = 'Head Office' %}
    {% else %}{% assign loc_name = loc %}
  {% endcase %}

  <!-- 🔹 PREVIEW -->
  <div class="pickup-availability-preview">
    <p class="caption-large">
      {% if available_stores.size == 1 %}
        Available at {{ loc_name }}
      {% else %}
        Available at {{ loc_name }} + {{ available_stores.size | minus: 1 }} other store{% if available_stores.size > 2 %}s{% endif %}
      {% endif %}
    </p>
  </div>

  <!-- 🔹 DRAWER LIST -->
  <div class="pickup-availability-drawer">
    <ul class="pickup-availability-list">

      {% for availability in available_stores %}

        {% assign loc = availability.location.name %}

        {% case loc %}
          {% when 'BO1' %}{% assign loc_name = 'Borivali' %}
          {% when 'CS1' %}{% assign loc_name = 'Chembur' %}
          {% when 'PS1' %}{% assign loc_name = 'Pune' %}
          {% when 'NOS18' %}{% assign loc_name = 'Noida' %}
          {% when 'Divinecarat Lifestyles Pvt Ltd' %}{% assign loc_name = 'Head Office' %}
          {% else %}{% assign loc_name = loc %}
        {% endcase %}

        <li>
          <strong>{{ loc_name }}</strong><br>
          Available at {{ loc_name }}
        </li>

      {% endfor %}

    </ul>
  </div>

{%- endif -%}