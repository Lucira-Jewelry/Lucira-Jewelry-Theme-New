
<style>
.astrology-gemstone-info{padding:120px 0 104px}
.astrology-gemstone-info .astrology-gemstone-container{max-width:80%;margin:0 auto}
.info-grid{display:grid;grid-template-columns:auto auto;gap:125px}
.about-column h3,.links-column h3{font-size:24px;text-transform:uppercase;margin:0 0 12px}
.about-column p{font-size:18px;color:#333;margin:0}
.links-column ul{list-style-type:disc;margin:0;padding-left:20px}
.links-column a{text-decoration:none;color:#000;font-size:13px}
.links-column a:hover{text-decoration:underline}
@media(max-width:767px){
.info-grid{display:grid;grid-template-columns:auto;gap:40px}
.astrology-gemstone-info{padding:40px 20px 20px}
.astrology-gemstone-info .astrology-gemstone-container{max-width:100%;margin:0 auto}
.about-column h3,.links-column h3{font-size:18px}
.about-column p{font-size:12px;color:#333}
}
</style>
<section class="astrology-gemstone-info">
  <div class="astrology-gemstone-container">
    <div class="info-grid">

      <div class="about-column">
        {% if section.settings.about_heading != blank %}
          <h3>{{ section.settings.about_heading }}</h3>
        {% endif %}

        {% if section.settings.about_text != blank %}
          <p>{{ section.settings.about_text }}</p>
        {% endif %}
      </div>

      <div class="links-column">
        {% if section.settings.links_heading != blank %}
          <h3>{{ section.settings.links_heading }}</h3>
        {% endif %}
        <ul>
          {% for block in section.blocks %}
            <li>
              {% if block.settings.link_url != blank %}
                <a href="{{ block.settings.link_url }}">{{ block.settings.link_text }}</a>
              {% else %}
                {{ block.settings.link_text }}
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </div>

    </div>
  </div>
</section>


{% schema %}
{
  "name": "Astrology & Gemstones",
  "settings": [
    {
      "type": "text",
      "id": "about_heading",
      "label": "About Column Heading",
      "default": "ABOUT ASTROLOGY & GEMSTONES"
    },
    {
      "type": "textarea",
      "id": "about_text",
      "label": "About Column Text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua..."
    },
    {
      "type": "text",
      "id": "links_heading",
      "label": "Links Column Heading",
      "default": "QUICK LINKS"
    }
  ],
  "blocks": [
    {
      "type": "link_item",
      "name": "Link Item",
      "settings": [
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Astrology"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Astrology & Gemstones ",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
