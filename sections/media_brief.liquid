<section class="as-seen-on-section">
  <div class="page-width">
    <div class="section-header center">
      <h2 class="as-seen-on__title">{{ section.settings.astitle }}</h2>
      <p class="as-seen-on__subtitle">{{ section.settings.assubtitle }}</p>
    </div>

    <div class="as-seen-on__grid">
      {% for block in section.blocks %}
        <div class="as-seen-on__card">
          {% if block.settings.logo %}
            <div class="as-seen-on__logo-wrap">
              <img src="{{ block.settings.logo | img_url: 'master' }}" width="auto" height="auto" alt="Logo" class="as-seen-on__logo" loading="lazy">
            </div>
          {% endif %}

          <div class="as-seen-on__content">
            {% if block.settings.asdate %}
              <p class="as-seen-on__date">{{ block.settings.asdate }}</p>
            {% endif %}
            <h3 class="as-seen-on__heading">{{ block.settings.asheading }}</h3>
            <p class="as-seen-on__text">{{ block.settings.astext | truncatewords: 30 }}</p>
            {% if block.settings.read_more_url %}
              <a href="{{ block.settings.read_more_url }}" class="as-seen-on__read-more" target="_blank">READ MORE.</a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .as-seen-on-section {
    padding: 20px 0;
  }

  .as-seen-on__title {
    font-size: 18px;
    letter-spacing: 1px;
    color:black;
    margin-bottom: 10px;
    text-transform: uppercase;
  }

  .as-seen-on__subtitle {
    font-size: 14px;
    color: #777;
    max-width: 600px;
    margin: 0 auto;
  }

  .as-seen-on__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 15px;
    margin-top: 40px;
  }

  .as-seen-on__card {
    background: #f7f7f7;
    border-radius: 10px;
    padding: 20px;
    display: flex;
    flex-direction: column;
  }

 

  .as-seen-on__logo-wrap {
    background: #fff;
    padding: 15px;
    border-radius: 8px;
    text-align: center;
    margin-bottom: 15px;
  }

  .as-seen-on__logo {
    max-height: 105px;
    width: auto;
    max-width: 100%;
  }

  .as-seen-on__date {
    font-size: 12px;
    color: #777;
    margin-bottom: 5px;
    text-transform: uppercase;
  }

  .as-seen-on__heading {
    font-size: 16px;
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .as-seen-on__text {
    font-size: 14px;
    color: #444;
    line-height: 1.5;
    flex-grow: 1;
  }

  .as-seen-on__read-more {
    font-size: 13px;
    color: #000;
    margin-top: 15px;
    display: inline-block;
    text-decoration: underline;
    font-weight: 500;
  }

  @media screen and (max-width: 767px) {
    .as-seen-on-section{
      padding-top: 40px;
    }
    .as-seen-on__date{
      margin-top:0px;
      font-size:10px;
    }
    .as-seen-on__grid {
      grid-template-columns: 1fr 1fr;
      margin-top:24px;
    }
    .as-seen-on__card{
      padding:10px;
    }
    .as-seen-on__text{
      font-size:10px;
    }
    .as-seen-on__heading{
      font-size:12px;
      margin-top:6px;
    }
    .as-seen-on__read-more {
    font-size: 11px;
    margin-top: 5px;
    }
    .as-seen-on__logo-wrap{
      margin-bottom:16px;
    }
    
  }
</style>

{% schema %}
{
  "name": "As Seen On Cards",
  "settings": [
    {
      "type": "text",
      "id": "astitle",
      "label": "Main Title",
      "default": "AS SEEN ON"
    },
    {
      "type": "text",
      "id": "assubtitle",
      "label": "Subtitle",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit..."
    }
  ],
  "blocks": [
    {
      "type": "press_card",
      "name": "Press Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "asdate",
          "label": "Date",
          "default": "May 2025"
        },
        {
          "type": "text",
          "id": "asheading",
          "label": "Title",
          "default": "INSIDE THE WORLD OF LAB GROWN DIAMONDS"
        },
        {
          "type": "textarea",
          "id": "astext",
          "label": "Description",
          "default": "Lorem ipsum dolor sit amet consectetur. Nisl amcorper egestas felis a massa massa."
        },
        {
          "type": "url",
          "id": "read_more_url",
          "label": "Read More Link"
        }
      ]
    }
  ],
 
  "presets": [
    {
      "name": "As Seen On - Grid Cards",
      "category": "Custom",
      "blocks": [
        {
          "type": "press_card"
        },
        {
          "type": "press_card"
        },
        {
          "type": "press_card"
        }
      ]
    }
  ]
}
{% endschema %}
