.quick-weight:hover{border-color:#b76f79;color:#b76f79}
.calculate-exchange-btn{width:100%;padding:18px;background:#b76f79;border:none;border-radius:8px;color:#fff;font-size:16px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;transition:all .3s ease;margin-top:10px;margin-bottom:20px;font-family:'Futura Std';text-transform:uppercase;letter-spacing:1px;display:none}
.calculate-exchange-btn:hover{transform:translateY(-2px)}
.calc-icon{width:20px;height:20px}
.calc-results-column{display:flex;flex-direction:column;gap:20px}
.results-card{background:#b76f79;color:#fff;border-radius:12px;padding:30px;flex:1}
.results-header{margin-bottom:25px;padding-bottom:20px;border-bottom:2px solid rgba(255,255,255,.1)}
.results-title{font-size:24px;font-weight:500;margin:0 0 10px 0;color:#fff;text-transform:uppercase;letter-spacing:2px}
.results-subtitle{font-size:14px;opacity:.8;display:flex;align-items:center;gap:5px}
.selected-karat,.selected-weight{color:#fff;font-weight:600;letter-spacing:1px}
.results-body{margin-bottom:25px}
.result-line{display:flex;justify-content:space-between;align-items:center;padding:18px 0;border-bottom:1px solid rgba(255,255,255,.1)}
.result-line:last-child{border-bottom:none}
.result-line.final-line{padding-top:25px;margin-top:10px}
.result-label .label-main{font-size:16px;font-weight:500;margin-bottom:4px;display:flex;align-items:center;gap:8px}
.result-label .label-sub{font-size:13px;opacity:.7}
.result-amount{font-size:20px;font-weight:700}
.result-amount.final-amount{font-size:32px;color:#fff;font-weight:600}
.results-footer{padding-top:20px;border-top:1px solid rgba(255,255,255,.1)}
.results-note{display:flex;align-items:center;gap:10px;margin-bottom:10px;font-size:13px;opacity:.8}
.results-note:last-child{margin-bottom:0}
.exchange-now-btn{width:100%;padding:18px;background:#3e405b;border:none;border-radius:8px;color:#fff;font-size:16px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;transition:all .3s ease;font-family:'Futura Std';text-transform:uppercase;letter-spacing:1px}
.exchange-now-btn:hover{transform:translateY(-2px)}
/* Bonus badge */
.bonus-badge{display:inline-block;background:rgba(255,255,255,0.25);color:#fff;font-size:12px;font-weight:700;padding:3px 8px;border-radius:20px;letter-spacing:0.5px;border:1px solid rgba(255,255,255,0.4)}
.exchange-price-table{background:#fff;padding:30px;border-radius:12px;box-shadow:0 5px 15px rgba(0,0,0,.08)}
.table-heading{text-align:center;font-size:24px;font-weight:500;color:#1a1a1a;margin-bottom:25px;letter-spacing:2px}
.table-container{overflow-x:auto;border-radius:8px;border:1px solid #f0f0f0}
.price-table{width:100%;border-collapse:collapse}
.price-table th{background:#f8f8f8;padding:18px 15px;text-align:center;font-weight:500;color:#1a1a1a;border-bottom:2px solid #b76f79}
