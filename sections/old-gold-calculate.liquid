<div class="old-gold-exchange-calculator" id="gold-exchange-calculator" data-exchange-bonus="{{ section.settings.exchange_bonus_percent | default: 5 }}">
  <div class="page-width">
    <!-- Rates Banner -->
    <div class="exchange-rates-banner">
      <div class="rates-container">
        <div class="rate-box">
          {% comment %} <div class="rate-icon">💰</div> {% endcomment %}
          <div class="rate-details">
            <div class="rate-name">24KT Gold Rate</div>
            <div class="rate-value" id="exchange-rate-24kt">Loading...</div>
            <div class="rate-unit">per 10 grams</div>
          </div>
        </div>

        <div class="rate-separator"></div>

        <div class="rate-box">
          {% comment %} <div class="rate-icon">💎</div> {% endcomment %}
          <div class="rate-details">
            <div class="rate-name">22KT Gold Rate</div>
            <div class="rate-value" id="exchange-rate-22kt">Loading...</div>
            <div class="rate-unit">per 10 grams</div>
          </div>
        </div>
      </div>

      <div class="rates-source">
        <span class="source-badge">Live Rates</span>
        <span class="source-text">Fetched from our Gold Rate Page</span>
      </div>
    </div>

    <!-- Calculator -->
    <div class="exchange-calculator-wrapper">
      <h2 class="calculator-main-title">Old Gold Exchange Value Calculator</h2>
      <p class="calculator-description">Enter your gold details to calculate exchange value</p>

      <div class="calculator-grid-old">
        <!-- Input Column -->
        <div class="calc-input-column">
          <!-- Karat Selection -->
          <div class="calc-input-group">
            <label class="calc-label">Select Gold Purity</label>
            <div class="karat-selection-grid">
              <button class="karat-select-btn active" data-karat="24" data-purity="1">
                <span class="karat-number">24KT</span>
                <span class="karat-percent">100% pure</span>
              </button>
              <button class="karat-select-btn" data-karat="22" data-purity="0.9167">
                <span class="karat-number">22KT</span>
                <span class="karat-percent">91.6% pure</span>
              </button>
              <button class="karat-select-btn" data-karat="18" data-purity="0.75">
                <span class="karat-number">18KT</span>
                <span class="karat-percent">75% pure</span>
              </button>
              <button class="karat-select-btn" data-karat="14" data-purity="0.583">
                <span class="karat-number">14KT</span>
                <span class="karat-percent">58.3% pure</span>
              </button>
              <button class="karat-select-btn" data-karat="9" data-purity="0.375">
                <span class="karat-number">9KT</span>
                <span class="karat-percent">37.5% pure</span>
              </button>
            </div>
          </div>

          <!-- Weight Input -->
          <div class="calc-input-group">
            <label class="calc-label" for="exchange-gold-weight">Gold Weight (grams)</label>
            <div class="weight-input-container">
              <input
                type="number"
                id="exchange-gold-weight"
                class="weight-input-field"
                value="10"
                min="0.1"
                step="0.1"
                placeholder="Enter weight"
              >
              <span class="weight-unit">grams</span>
            </div>

            <div class="quick-weight-buttons">
              <button class="quick-weight" data-weight="1">1g</button>
              <button class="quick-weight" data-weight="5">5g</button>
              <button class="quick-weight" data-weight="10">10g</button>
              <button class="quick-weight" data-weight="50">50g</button>
              <button class="quick-weight" data-weight="100">100g</button>
            </div>
          </div>

          <!-- Calculate Button -->
          <button class="calculate-exchange-btn" id="calc-exchange-btn">
            Calculate Exchange Value
          </button>

          <a
            href="https://api.whatsapp.com/send/?phone=919004435760&text=Hi%2C%20I%20want%20to%20get%20more%20information%20about%20Old%20Gold%20Exchange !%20&type=phone_number&app_absent=0"
            target="_blank"
            rel="noopener noreferrer"
            class="exchange-now-btn"
          >
          <svg width="24" height="24" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8.00782 1.33337C4.33716 1.33337 1.349 4.31896 1.34767 7.98962C1.347 9.16296 1.65432 10.3084 2.23699 11.3177L1.33334 14.6667L4.82162 13.8425C5.79429 14.3732 6.88925 14.6517 8.00392 14.6524H8.00652C11.6765 14.6524 14.6634 11.6661 14.6654 7.99613C14.6667 6.2168 13.9748 4.54386 12.7175 3.2852C11.4601 2.0272 9.78916 1.33404 8.00782 1.33337ZM8.00652 2.66671C9.43052 2.66737 10.7688 3.22257 11.7747 4.22791C12.7808 5.23457 13.3334 6.57217 13.332 7.99483C13.3307 10.9308 10.9426 13.3191 8.00522 13.3191C7.11655 13.3184 6.23628 13.0952 5.46095 12.6719L5.01173 12.4271L4.51564 12.5443L3.20314 12.8542L3.52345 11.6641L3.66798 11.1302L3.39194 10.6511C2.9266 9.84575 2.68033 8.92496 2.681 7.98962C2.68233 5.05496 5.07119 2.66671 8.00652 2.66671ZM5.65105 4.91671C5.53972 4.91671 5.35971 4.95837 5.20704 5.12504C5.05437 5.29104 4.62371 5.69309 4.62371 6.51176C4.62371 7.33043 5.22006 8.12178 5.3034 8.23311C5.38606 8.34378 6.45451 10.0769 8.14584 10.7435C9.55118 11.2975 9.8366 11.1882 10.1419 11.1602C10.4473 11.1329 11.127 10.7585 11.2656 10.3698C11.4043 9.98116 11.4046 9.64683 11.3633 9.57817C11.322 9.50883 11.2109 9.46749 11.0443 9.38415C10.8783 9.30082 10.0602 8.89912 9.90756 8.84379C9.7549 8.78846 9.64323 8.76046 9.53256 8.92712C9.4219 9.09379 9.10385 9.4675 9.00652 9.57817C8.90919 9.6895 8.81251 9.70447 8.64584 9.62113C8.47918 9.53713 7.9433 9.36098 7.3073 8.79431C6.81264 8.35364 6.47885 7.80994 6.38152 7.64327C6.28485 7.47727 6.37241 7.38609 6.45574 7.30343C6.53041 7.22876 6.6211 7.10909 6.70444 7.01176C6.7871 6.91443 6.81577 6.84508 6.8711 6.73441C6.92644 6.62375 6.89811 6.52608 6.85678 6.44275C6.81545 6.35942 6.49176 5.53771 6.34376 5.20837C6.21909 4.93171 6.08743 4.92528 5.96876 4.92061C5.87209 4.91661 5.76172 4.91671 5.65105 4.91671Z" fill="white"/>
          </svg>
            Get In Touch
          </a>
        </div>

        <div class="calc-results-column">
          <div class="results-card">
            <div class="results-header">
              <h3 class="results-title">Exchange Value</h3>
              <div class="results-subtitle">
                <span class="selected-karat" id="results-karat">24KT</span>
                •
                <span class="selected-weight" id="results-weight">10g</span>
              </div>
            </div>

            <div class="results-body">
              <div class="result-line">
                <div class="result-label">
                  <div class="label-main">Market Value</div>
                  <div class="label-sub">Based on today's rate</div>
                </div>
                <div class="result-amount" id="result-market-price">₹ --</div>
              </div>

              <div class="result-line final-line">
                <div class="result-label">
                  <div class="label-main">
                    Exchange Value
                    <span class="bonus-badge" id="bonus-badge">+5%</span>
                  </div>
                  <div class="label-sub">Total value for your gold</div>
                </div>
                <div class="result-amount final-amount" id="result-final-price">₹ --</div>
              </div>
            </div>

            <div class="results-footer">
              <div class="results-note">
                <span class="note-icon">ℹ️</span>
                <span class="note-text">Rates are fetched from our gold rate page</span>
              </div>
              <div class="results-note">
                <span class="note-icon">⚠️</span>
                <span class="note-text">Final value determined after verification</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="exchange-price-table">
      <h3 class="table-heading">TODAY's GOLD PRICES (PER GRAM)</h3>
      <div class="table-container">
        <table class="price-table">
          <thead>
            <tr>
              <th>Karat</th>
              <th>1g</th>
              <th>5g</th>
              <th>10g</th>
              <th>50g</th>
              <th>100g</th>
            </tr>
          </thead>
          <tbody id="price-table-body">
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<style>
.old-gold-exchange-calculator{padding:40px 0;background:#f8f8f8;font-family:'Futura Std'}
.old-gold-exchange-calculator *{font-family:'Futura Std'}
.exchange-rates-banner{background:linear-gradient(135deg,#b76f79 0,#f3dce0 100%);border-radius:12px;padding:25px;margin-bottom:40px;color:#fff;display:flex;justify-content:space-between}
.rates-container{display:flex;justify-content:left;align-items:center;gap:40px;flex-wrap:wrap}
.rate-box{display:flex;align-items:center;gap:15px;min-width:200px}
.rate-icon{font-size:32px}
.rate-details{flex:1}
.rate-name{font-size:12px;opacity:.9;margin-bottom:5px;text-transform:uppercase;letter-spacing:1px}
.rate-value{font-size:36px;font-weight:600;line-height:1;margin:5px 0}
.rate-unit{font-size:12px;opacity:.8}
.rate-separator{width:1px;height:60px;background:rgba(255,255,255,.3)}
.rates-source{text-align:center;font-size:14px;opacity:.9;display:flex;align-items:center;justify-content:center;gap:10px;color:#3e405b}
.source-badge{background:rgba(255,255,255,.2);padding:4px 12px;border-radius:20px;font-size:12px}
.exchange-calculator-wrapper{max-width:1200px;margin:0 auto 50px}
.calculator-main-title{text-align:center;font-size:24px;font-weight:500;color:#1a1a1a;margin-bottom:8px;letter-spacing:1.5px;text-transform:uppercase}
.calculator-description{text-align:center;color:#666;margin-bottom:40px;font-size:18px;margin-top:0}
.calculator-grid-old{display:grid;grid-template-columns:1fr 1fr;gap:30px}
@media (max-width:768px){
.calculator-grid-old{grid-template-columns:1fr}
.rates-container{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
.rate-separator{width:80%;height:1px}
}
.calc-input-column{background:#fff;padding:30px;border-radius:12px;box-shadow:0 5px 15px rgba(0,0,0,.08)}
.calc-input-group{margin-bottom:45px}
.calc-label{display:block;font-size:16px;font-weight:500;color:#1a1a1a;margin-bottom:15px;letter-spacing:2px}
.karat-selection-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}
.karat-select-btn{background:#f5f5f5;border:2px solid #e0e0e0;border-radius:8px;padding:12px 8px;text-align:center;cursor:pointer;transition:all .3s ease;letter-spacing:1px}
.karat-select-btn:hover{border-color:#b76f79}
.karat-select-btn.active{background:#b76f79;border-color:#b76f79;color:#fff}
.karat-select-btn.active .karat-number,.karat-select-btn.active .karat-percent{color:#fff}
.karat-number{display:block;font-size:16px;font-weight:600;color:#333;margin-bottom:4px}
.karat-percent{display:block;font-size:12px;color:#666}
.weight-input-container{position:relative;margin-bottom:15px}
.weight-input-field{width:100%;padding:16px 20px;padding-right:70px;border:2px solid #e0e0e0;border-radius:8px;font-size:18px;font-weight:600;color:#333}
