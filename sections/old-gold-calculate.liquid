{% comment %} 
  Optimized Gold Rate Calculator for General Use
  Features:
  - Fetches real-time gold rates from API
  - Modern, clean design
  - Works across all pages
  - Auto-calculations with better UX
{% endcomment %}

<div class="gold-calculator-section">
  <div class="page-width">
    <!-- Gold Rate Display Header -->
    <div class="gold-rate-header">
      <div class="gold-rate-card">
        <div class="gold-rate-item">
          <span class="rate-label">24KT Gold Rate</span>
          <span class="rate-value" id="gold-rate-24kt">Loading...</span>
          <span class="rate-unit">per 10gm</span>
        </div>
        <div class="rate-divider"></div>
        <div class="gold-rate-item">
          <span class="rate-label">22KT Gold Rate</span>
          <span class="rate-value" id="gold-rate-22kt">Loading...</span>
          <span class="rate-unit">per 10gm</span>
        </div>
      </div>
      
      <!-- Last Updated Time -->
      <div class="last-updated">
        <span class="update-icon">🕒</span>
        <span id="last-updated-time">Updating...</span>
      </div>
    </div>

    <!-- Main Calculator -->
    <div class="gold-calculator-container">
      <h2 class="calculator-title">Gold Value Calculator</h2>
      <p class="calculator-subtitle">Calculate your gold's value instantly</p>
      
      <div class="calculator-grid">
        <!-- Left Panel: Inputs -->
        <div class="calculator-inputs">
          <!-- Karat Selection -->
          <div class="input-group">
            <label class="input-label">Karat Purity</label>
            <div class="karat-selector">
              <button class="karat-btn active" data-karat="24">24KT</button>
              <button class="karat-btn" data-karat="22">22KT</button>
              <button class="karat-btn" data-karat="18">18KT</button>
              <button class="karat-btn" data-karat="14">14KT</button>
            </div>
          </div>
          
          <!-- Weight Input -->
          <div class="input-group">
            <label class="input-label">Weight (grams)</label>
            <div class="weight-input-container">
              <input 
                type="number" 
                id="weight-input" 
                class="weight-input" 
                value="10" 
                min="0.1" 
                step="0.1"
                placeholder="Enter weight"
              >
              <span class="input-unit">gm</span>
            </div>
            <div class="weight-presets">
              <button class="preset-btn" data-weight="1">1g</button>
              <button class="preset-btn" data-weight="5">5g</button>
              <button class="preset-btn" data-weight="10">10g</button>
              <button class="preset-btn" data-weight="50">50g</button>
              <button class="preset-btn" data-weight="100">100g</button>
            </div>
          </div>
          
          <!-- GST Toggle -->
          <div class="input-group">
            <label class="input-label">Include GST (3%)</label>
            <div class="toggle-switch">
              <input type="checkbox" id="gst-toggle" checked>
              <label for="gst-toggle" class="toggle-label">
                <span class="toggle-text">Excluding</span>
                <span class="toggle-slider"></span>
                <span class="toggle-text">Including</span>
              </label>
            </div>
          </div>
          
          <!-- Calculate Button -->
          <button class="calculate-btn" id="calculate-btn">
            <span class="btn-icon">💎</span>
            Calculate Value
          </button>
        </div>
        
        <!-- Right Panel: Results -->
        <div class="calculator-results">
          <div class="results-header">
            <h3>Estimated Value</h3>
            <span class="results-badge" id="gold-purity-badge">24KT</span>
          </div>
          
          <div class="results-breakdown">
            <!-- Gold Value -->
            <div class="result-item">
              <div class="result-label">
                <span>Gold Price</span>
                <span class="help-tooltip" title="Current market price for selected karat">ℹ️</span>
              </div>
              <div class="result-value" id="gold-price-value">₹ --</div>
            </div>
            
            <!-- GST Breakdown (Only shows when GST is included) -->
            <div class="gst-breakdown" id="gst-breakdown">
              <div class="result-item gst-item">
                <div class="result-label">
                  <span>CGST (1.5%)</span>
                </div>
                <div class="result-value" id="cgst-value">₹ --</div>
              </div>
              <div class="result-item gst-item">
                <div class="result-label">
                  <span>SGST (1.5%)</span>
                </div>
                <div class="result-value" id="sgst-value">₹ --</div>
              </div>
              <div class="result-item gst-item total">
                <div class="result-label">
                  <span>Total GST</span>
                </div>
                <div class="result-value" id="total-gst-value">₹ --</div>
              </div>
            </div>
            
            <!-- Final Amount -->
            <div class="result-item final-amount">
              <div class="result-label">
                <span>Final Amount</span>
                <span class="gst-status" id="gst-status">(Including GST)</span>
              </div>
              <div class="result-value final-value" id="final-amount">₹ --</div>
            </div>
          </div>
          
          <!-- Additional Info -->
          <div class="results-info">
            <div class="info-item">
              <span class="info-icon">💡</span>
              <span class="info-text">Rates update every 15 minutes</span>
            </div>
            <div class="info-item">
              <span class="info-icon">⚠️</span>
              <span class="info-text">Final value may vary at actual transaction</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Gold Rate Table -->
    <div class="gold-rate-table-section">
      <h3 class="table-title">Gold Price Breakdown</h3>
      <div class="rate-table-container">
        <table class="gold-rate-table">
          <thead>
            <tr>
              <th>Karat</th>
              <th>1 gm</th>
              <th>5 gm</th>
              <th>10 gm</th>
              <th>50 gm</th>
              <th>100 gm</th>
            </tr>
          </thead>
          <tbody id="gold-rate-table-body">
            <!-- Filled by JavaScript -->
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<style>
  /* Modern Color Scheme */
  :root {
    --primary-gold: #D4AF37;
    --secondary-gold: #FFD700;
    --dark-bg: #1a1a1a;
    --light-bg: #f8f5f0;
    --card-bg: #ffffff;
    --text-dark: #333333;
    --text-light: #666666;
    --success-green: #10b981;
    --border-color: #e5e7eb;
    --shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    --gold-gradient: linear-gradient(135deg, #D4AF37 0%, #FFD700 100%);
  }
  
  /* Main Section */
  .gold-calculator-section {
    background: var(--light-bg);
    padding: 40px 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  
  /* Gold Rate Header */
  .gold-rate-header {
    margin-bottom: 40px;
    text-align: center;
  }
  
  .gold-rate-card {
    background: var(--gold-gradient);
    border-radius: 20px;
    padding: 30px;
    display: inline-flex;
    align-items: center;
    gap: 40px;
    box-shadow: var(--shadow);
    margin-bottom: 20px;
  }
  
  .gold-rate-item {
    text-align: center;
  }
  
  .rate-label {
    display: block;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.9);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }
  
  .rate-value {
    font-size: 42px;
    font-weight: 700;
    color: white;
    line-height: 1;
  }
  
  .rate-unit {
    display: block;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 4px;
  }
  
  .rate-divider {
    width: 1px;
    height: 60px;
    background: rgba(255, 255, 255, 0.3);
  }
  
  .last-updated {
    font-size: 14px;
    color: var(--text-light);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  
  .update-icon {
    font-size: 16px;
  }
  
  /* Main Calculator */
  .calculator-title {
    text-align: center;
    font-size: 36px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 10px;
  }
  
  .calculator-subtitle {
    text-align: center;
    font-size: 16px;
    color: var(--text-light);
    margin-bottom: 40px;
  }
  
  .calculator-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  @media (max-width: 768px) {
    .calculator-grid {
      grid-template-columns: 1fr;
    }
    .gold-rate-card {
      flex-direction: column;
      gap: 20px;
    }
    .rate-divider {
      width: 60px;
      height: 1px;
    }
  }
  
  /* Input Panel */
  .calculator-inputs {
    background: var(--card-bg);
    border-radius: 20px;
    padding: 30px;
    box-shadow: var(--shadow);
  }
  
  .input-group {
    margin-bottom: 30px;
  }
  
  .input-label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-dark);
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  /* Karat Selector */
  .karat-selector {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  
  .karat-btn {
    padding: 15px 10px;
    border: 2px solid var(--border-color);
    border-radius: 10px;
    background: white;
    color: var(--text-light);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .karat-btn:hover {
    border-color: var(--primary-gold);
    color: var(--primary-gold);
  }
  
  .karat-btn.active {
    background: var(--gold-gradient);
    border-color: var(--primary-gold);
    color: white;
  }
  
  /* Weight Input */
  .weight-input-container {
    position: relative;
    margin-bottom: 15px;
  }
  
  .weight-input {
    width: 100%;
    padding: 18px 20px;
    padding-right: 60px;
    border: 2px solid var(--border-color);
    border-radius: 10px;
    font-size: 18px;
    font-weight: 600;
    color: var(--text-dark);
    transition: border-color 0.3s ease;
  }
  
  .weight-input:focus {
    outline: none;
    border-color: var(--primary-gold);
  }
  
  .input-unit {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 14px;
    color: var(--text-light);
    font-weight: 600;
  }
  
  .weight-presets {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  
  .preset-btn {
    padding: 10px 16px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: white;
    color: var(--text-light);
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .preset-btn:hover {
    background: var(--light-bg);
  }
  
  /* Toggle Switch */
  .toggle-switch {
    display: inline-block;
  }
  
  .toggle-label {
    display: flex;
    align-items: center;
    gap: 15px;
    cursor: pointer;
  }
  
  .toggle-text {
    font-size: 14px;
    color: var(--text-light);
    font-weight: 600;
  }
  
  .toggle-switch input {
    display: none;
  }
  
  .toggle-slider {
    width: 60px;
    height: 30px;
    background: #e5e7eb;
    border-radius: 15px;
    position: relative;
    transition: background-color 0.3s ease;
  }
  
  .toggle-slider:before {
    content: '';
    position: absolute;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: white;
    top: 2px;
    left: 2px;
    transition: transform 0.3s ease;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
  }
  
  .toggle-switch input:checked + .toggle-label .toggle-slider {
    background: var(--success-green);
  }
  
  .toggle-switch input:checked + .toggle-label .toggle-slider:before {
    transform: translateX(30px);
  }
  
  /* Calculate Button */
  .calculate-btn {
    width: 100%;
    padding: 20px;
    background: var(--gold-gradient);
    border: none;
    border-radius: 12px;
    color: white;
    font-size: 18px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    margin-top: 10px;
  }
  
  .calculate-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3);
  }
  
  /* Results Panel */
  .calculator-results {
    background: var(--card-bg);
    border-radius: 20px;
    padding: 30px;
    box-shadow: var(--shadow);
  }
  
  .results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding-bottom: 20px;
    border-bottom: 2px solid var(--border-color);
  }
  
  .results-header h3 {
    font-size: 24px;
    font-weight: 700;
    color: var(--text-dark);
    margin: 0;
  }
  
  .results-badge {
    background: var(--gold-gradient);
    color: white;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
  }
  
  /* Results Breakdown */
  .result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 0;
    border-bottom: 1px solid var(--border-color);
  }
  
  .result-item:last-child {
    border-bottom: none;
  }
  
  .result-label {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .result-label span {
    font-size: 16px;
    color: var(--text-light);
  }
  
  .help-tooltip {
    cursor: help;
    opacity: 0.6;
  }
  
  .result-value {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-dark);
  }
  
  /* GST Breakdown */
  .gst-breakdown {
    margin: 15px 0;
    padding: 20px;
    background: var(--light-bg);
    border-radius: 10px;
  }
  
  .gst-item .result-label span {
    font-size: 14px;
    color: var(--text-light);
  }
  
  .gst-item .result-value {
    font-size: 16px;
  }
  
  .gst-item.total {
    padding-top: 10px;
    border-top: 1px dashed var(--border-color);
    margin-top: 10px;
  }
  
  /* Final Amount */
  .final-amount {
    background: var(--gold-gradient);
    margin: 20px -30px -30px -30px;
    padding: 30px;
    border-radius: 0 0 20px 20px;
  }
  
  .final-amount .result-label span {
    color: white;
    font-size: 18px;
  }
  
  .gst-status {
    font-size: 14px;
    opacity: 0.9;
  }
  
  .final-amount .result-value {
    font-size: 36px;
    color: white;
  }
  
  /* Results Info */
  .results-info {
    margin-top: 30px;
  }
  
  .info-item {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    padding: 10px;
    background: var(--light-bg);
    border-radius: 8px;
  }
  
  .info-icon {
    font-size: 16px;
  }
  
  .info-text {
    font-size: 13px;
    color: var(--text-light);
  }
  
  /* Gold Rate Table */
  .gold-rate-table-section {
    margin-top: 60px;
  }
  
  .table-title {
    text-align: center;
    font-size: 24px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 30px;
  }
  
  .rate-table-container {
    overflow-x: auto;
    border-radius: 15px;
    box-shadow: var(--shadow);
  }
  
  .gold-rate-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--card-bg);
  }
  
  .gold-rate-table th {
    background: var(--gold-gradient);
    color: white;
    padding: 20px;
    font-weight: 600;
    text-align: center;
  }
  
  .gold-rate-table td {
    padding: 20px;
    text-align: center;
    border-bottom: 1px solid var(--border-color);
    font-size: 16px;
  }
  
  .gold-rate-table tr:hover {
    background: var(--light-bg);
  }
  
  /* Loading States */
  .loading {
    opacity: 0.7;
    pointer-events: none;
  }
  
  .loading::after {
    content: '...';
    animation: dots 1.5s infinite;
  }
  
  @keyframes dots {
    0%, 20% { content: ''; }
    40% { content: '.'; }
    60% { content: '..'; }
    80%, 100% { content: '...'; }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Configuration
  const config = {
    goldRateApi: 'https://api.metalpriceapi.com/v1/latest', // Replace with your API
    apiKey: 'YOUR_API_KEY_HERE', // Add your API key
    defaultRates: {
      '24kt': 98440, // Fallback rate for 24kt per 10gm
      '22kt': 90000  // Fallback rate for 22kt per 10gm
    },
    gstRate: 0.03, // 3% GST
    refreshInterval: 900000 // 15 minutes
  };
  
  // State
  let currentRates = {
    '24kt': config.defaultRates['24kt'],
    '22kt': config.defaultRates['22kt']
  };
  let currentKarat = '24';
  let currentWeight = 10;
  let includeGST = true;
  
  // DOM Elements
  const elements = {
    rate24kt: document.getElementById('gold-rate-24kt'),
    rate22kt: document.getElementById('gold-rate-22kt'),
    lastUpdated: document.getElementById('last-updated-time'),
    weightInput: document.getElementById('weight-input'),
    gstToggle: document.getElementById('gst-toggle'),
    calculateBtn: document.getElementById('calculate-btn'),
    karatButtons: document.querySelectorAll('.karat-btn'),
    presetButtons: document.querySelectorAll('.preset-btn'),
    purityBadge: document.getElementById('gold-purity-badge'),
    goldPriceValue: document.getElementById('gold-price-value'),
    cgstValue: document.getElementById('cgst-value'),
    sgstValue: document.getElementById('sgst-value'),
    totalGstValue: document.getElementById('total-gst-value'),
    finalAmount: document.getElementById('final-amount'),
    gstStatus: document.getElementById('gst-status'),
    gstBreakdown: document.getElementById('gst-breakdown'),
    tableBody: document.getElementById('gold-rate-table-body')
  };
  
  // Initialize
  init();
  
  function init() {
    // Fetch initial gold rates
    fetchGoldRates();
    
    // Set up auto-refresh
    setInterval(fetchGoldRates, config.refreshInterval);
    
    // Event Listeners
    elements.karatButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        elements.karatButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentKarat = btn.dataset.karat;
        elements.purityBadge.textContent = `${currentKarat}KT`;
        calculate();
      });
    });
    
    elements.presetButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        currentWeight = parseFloat(btn.dataset.weight);
        elements.weightInput.value = currentWeight;
        calculate();
      });
    });
    
    elements.weightInput.addEventListener('input', () => {
      currentWeight = parseFloat(elements.weightInput.value) || 0;
      calculate();
    });
    
    elements.gstToggle.addEventListener('change', () => {
      includeGST = elements.gstToggle.checked;
      elements.gstStatus.textContent = includeGST ? '(Including GST)' : '(Excluding GST)';
      calculate();
    });
    
    elements.calculateBtn.addEventListener('click', calculate);
    
    // Initial calculation
    calculate();
  }
  
  async function fetchGoldRates() {
    try {
      // In production, replace this with real API call
      // const response = await fetch(`${config.goldRateApi}?api_key=${config.apiKey}&base=XAU&currencies=INR`);
      // const data = await response.json();
      // const goldPerOz = data.rates.INR;
      // const goldPerGram = goldPerOz / 31.1035;
      
      // For demo, using simulated rates
      const simulatedRate = config.defaultRates['24kt'] * (0.995 + Math.random() * 0.01);
      currentRates = {
        '24kt': Math.round(simulatedRate),
        '22kt': Math.round(simulatedRate * 0.9167) // 22kt is 91.67% pure
      };
      
      // Update UI
      updateRateDisplay();
      updateTable();
      updateLastUpdated();
      
    } catch (error) {
      console.error('Error fetching gold rates:', error);
      // Use fallback rates
      updateRateDisplay();
    }
  }
  
  function updateRateDisplay() {
    elements.rate24kt.textContent = formatCurrency(currentRates['24kt']);
    elements.rate22kt.textContent = formatCurrency(currentRates['22kt']);
  }
  
  function updateLastUpdated() {
    const now = new Date();
    const timeString = now.toLocaleTimeString('en-IN', {
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit'
    });
    elements.lastUpdated.textContent = `Last updated: ${timeString}`;
  }
  
  function calculate() {
    const baseRate = currentRates[currentKarat + 'kt'] || currentRates['24kt'];
    const ratePerGram = baseRate / 10;
    const goldValue = ratePerGram * currentWeight;
    const gstAmount = includeGST ? goldValue * config.gstRate : 0;
    const finalValue = goldValue + gstAmount;
    const cgstAmount = gstAmount / 2;
    const sgstAmount = gstAmount / 2;
    
    // Update UI
    elements.goldPriceValue.textContent = formatCurrency(goldValue);
    elements.cgstValue.textContent = formatCurrency(cgstAmount);
    elements.sgstValue.textContent = formatCurrency(sgstAmount);
    elements.totalGstValue.textContent = formatCurrency(gstAmount);
    elements.finalAmount.textContent = formatCurrency(finalValue);
    
    // Show/hide GST breakdown
    elements.gstBreakdown.style.display = includeGST ? 'block' : 'none';
    
    // Update table with current weight
    updateTable();
  }
  
  function updateTable() {
    if (!elements.tableBody) return;
    
    const karats = ['24', '22', '18', '14'];
    const weights = [1, 5, 10, 50, 100];
    const base24ktRate = currentRates['24kt'] / 10; // Per gram
    
    let tableHTML = '';
    
    karats.forEach(karat => {
      const purity = parseInt(karat) / 24;
      const ratePerGram = base24ktRate * purity;
      
      tableHTML += '<tr>';
      tableHTML += `<td><strong>${karat}KT</strong></td>`;
      
      weights.forEach(weight => {
        const value = ratePerGram * weight;
        tableHTML += `<td>${formatCurrency(value)}</td>`;
      });
      
      tableHTML += '</tr>';
    });
    
    elements.tableBody.innerHTML = tableHTML;
  }
  
  function formatCurrency(amount) {
    return new Intl.NumberFormat('en-IN', {
      style: 'currency',
      currency: 'INR',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0
    }).format(amount);
  }
  
  // Initialize everything
  setTimeout(() => {
    // Trigger initial fetch and calculation
    fetchGoldRates();
    calculate();
  }, 100);
});
</script>

