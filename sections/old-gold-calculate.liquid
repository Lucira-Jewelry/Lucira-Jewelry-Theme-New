.exchange-rates-banner{padding:20px 15px;margin-bottom:25px;flex-direction:column;gap:20px}
.rates-container{flex-direction:column;gap:20px;width:100%;margin-bottom:0}
.rate-box{width:100%;justify-content:flex-start;min-width:unset}
.rate-icon{font-size:28px}
.rate-value{font-size:28px}
.rate-separator{width:100%;height:1px;display:none}
.rates-source{flex-direction:row;gap:8px}
.exchange-calculator-wrapper{padding:0 15px}
.calculator-main-title{font-size:20px;margin-bottom:8px;letter-spacing:1px;margin-top:30px}
.calculator-description{font-size:14px;margin-bottom:25px;padding:0 10px}
.calculator-grid-old{grid-template-columns:1fr;gap:20px}
.calc-input-column{padding:20px 15px}
.calc-input-group{margin-bottom:25px}
.calc-label{font-size:14px;margin-bottom:12px;letter-spacing:1px}
.karat-selection-grid{grid-template-columns:repeat(3,1fr);gap:8px}
.karat-select-btn{padding:10px 6px}
.karat-number{font-size:14px;margin-bottom:3px}
.karat-percent{font-size:11px}
.weight-input-field{padding:14px 16px;padding-right:65px;font-size:16px}
.weight-unit{right:16px;font-size:14px}
.quick-weight-buttons{gap:6px}
.quick-weight{padding:8px 14px;font-size:13px;flex:1;min-width:calc(20% - 5px)}
.calculate-exchange-btn{padding:16px;font-size:14px;margin-top:8px;margin-bottom:15px;font-weight:400;letter-spacing:1px}
.calc-icon{width:18px;height:18px}
.results-card{padding:20px 15px}
.results-header{margin-bottom:20px;padding-bottom:15px}
.results-title{font-size:20px;letter-spacing:1.5px}
.results-subtitle{font-size:13px;flex-wrap:wrap}
.results-body{margin-bottom:20px}
.result-line{padding:15px 0;flex-direction:row;align-items:flex-start;gap:8px}
.result-line.final-line{padding-top:20px;margin-top:8px}
.result-label{width:100%}
.result-label .label-main{font-size:14px}
.result-label .label-sub{font-size:12px}
.result-amount{font-size:18px;align-self:center;width:100%;text-align:right}
.result-amount.final-amount{font-size:26px}
.results-footer{padding-top:15px}
.results-note{font-size:12px;gap:8px;margin-bottom:8px}
.note-icon{font-size:14px;flex-shrink:0}
.exchange-now-btn{padding:16px;font-size:16px;font-weight:400;font-family:'Futura Std';letter-spacing:1px;text-transform:uppercase}
.cta-icon{width:18px;height:18px}
.exchange-price-table{padding:20px 15px;margin:0 15px}
.table-heading{font-size:18px;margin-bottom:20px;letter-spacing:1.5px;text-transform:uppercase}
.table-container{overflow-x:auto;-webkit-overflow-scrolling:touch}
.price-table{font-size:13px;min-width:500px}
