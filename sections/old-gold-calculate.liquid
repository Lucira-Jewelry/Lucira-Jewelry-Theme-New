<script>
  class OldGoldExchangeCalculator {
    constructor(container) {
      this.container = container;
      this.state = {
        karat: '24',
        weight: 10,
        rates: {
          '24kt': null,
          '22kt': null,
        },
      };

      // Read exchange bonus % from data attribute (set via Shopify schema)
      this.exchangeBonusPercent = parseFloat(container.getAttribute('data-exchange-bonus')) || 0;

      this.goldRatePageUrl = '/pages/mumbai-gold-rate-today';

      this.init();
    }

    async init() {
      this.bindElements();
      this.bindEvents();
      this.updateBonusBadge();
      this.showLoading();
      await this.fetchGoldRates();
      this.updateRateDisplay();
      this.calculate();
      this.updatePriceTable();
    }

    bindElements() {
      this.elements = {
        rate24kt: this.container.querySelector('#exchange-rate-24kt'),
        rate22kt: this.container.querySelector('#exchange-rate-22kt'),
        weightInput: this.container.querySelector('#exchange-gold-weight'),
        karatBadge: this.container.querySelector('#results-karat'),
        weightBadge: this.container.querySelector('#results-weight'),
        marketPrice: this.container.querySelector('#result-market-price'),
        finalPrice: this.container.querySelector('#result-final-price'),
        priceTable: this.container.querySelector('#price-table-body'),
        bonusBadge: this.container.querySelector('#bonus-badge'),
      };
    }

    updateBonusBadge() {
      if (this.elements.bonusBadge) {
        if (this.exchangeBonusPercent > 0) {
          this.elements.bonusBadge.textContent = `+${this.exchangeBonusPercent}%`;
          this.elements.bonusBadge.style.display = 'inline-block';
        } else {
          this.elements.bonusBadge.style.display = 'none';
        }
      }
    }

    showLoading() {
      if (this.elements.rate24kt) this.elements.rate24kt.textContent = 'Loading...';
      if (this.elements.rate22kt) this.elements.rate22kt.textContent = 'Loading...';
    }

    async fetchGoldRates() {
      try {
        console.log('Fetching gold rates from:', this.goldRatePageUrl);

        const response = await fetch(this.goldRatePageUrl);
        const html = await response.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');

        // METHOD 1: data-base attribute
        const baseElement = doc.querySelector('[data-base]');
        if (baseElement) {
          const rate24ktRaw = baseElement.getAttribute('data-base');
          if (rate24ktRaw) {
            this.state.rates['24kt'] = parseFloat(rate24ktRaw.replace(/[^0-9.]/g, ''));
          }
        }

        // METHOD 2: schema/settings in script tags
        if (!this.state.rates['24kt']) {
          const scriptTags = doc.querySelectorAll('script[type="application/json"]');
          for (let script of scriptTags) {
            try {
              const data = JSON.parse(script.textContent);
              if (data && data.sections) {
                for (let sectionId in data.sections) {
                  const section = data.sections[sectionId];
                  if (section.settings && section.settings.rate_today) {
                    this.state.rates['24kt'] = parseFloat(section.settings.rate_today.replace(/[^0-9.]/g, ''));
                    if (section.settings.rate_avg) {
                      this.state.rates['22kt'] = parseFloat(section.settings.rate_avg.replace(/[^0-9.]/g, ''));
                    }
                    break;
                  }
                }
              }
            } catch (e) {}
          }
        }

        // METHOD 3: .gold-widget__price elements
        if (!this.state.rates['24kt']) {
          const rateElements = doc.querySelectorAll('.gold-widget__price');
          if (rateElements.length > 0) {
            const priceMatch = rateElements[0].textContent.match(/[\d,]+/);
            if (priceMatch) this.state.rates['24kt'] = parseFloat(priceMatch[0].replace(/,/g, ''));
          }
          if (rateElements.length > 1) {
            const priceMatch = rateElements[1].textContent.match(/[\d,]+/);
            if (priceMatch) this.state.rates['22kt'] = parseFloat(priceMatch[0].replace(/,/g, ''));
          }
        }

        // METHOD 4: #goldRate element
        if (!this.state.rates['24kt']) {
          const goldRateEl = doc.querySelector('#goldRate');
          if (goldRateEl) {
            const baseRate = parseFloat(goldRateEl.getAttribute('data-base'));
            if (!isNaN(baseRate)) this.state.rates['24kt'] = baseRate;
          }
        }

        // Calculate 22KT if not found
        if (this.state.rates['24kt'] && !this.state.rates['22kt']) {
          this.state.rates['22kt'] = Math.round(this.state.rates['24kt'] * (22 / 24));
        }

        // Fallback
        if (!this.state.rates['24kt']) {
          console.warn('⚠️ Could not fetch rates, using defaults');
          this.state.rates['24kt'] = 98440;
          this.state.rates['22kt'] = 90000;
        }

      } catch (error) {
        console.error('❌ Error fetching gold rates:', error);
        this.state.rates['24kt'] = 98440;
        this.state.rates['22kt'] = 90000;
      }
    }

    updateRateDisplay() {
      if (this.elements.rate24kt && this.state.rates['24kt']) {
        this.elements.rate24kt.textContent = this.formatCurrency(this.state.rates['24kt']);
      }
      if (this.elements.rate22kt && this.state.rates['22kt']) {
        this.elements.rate22kt.textContent = this.formatCurrency(this.state.rates['22kt']);
      }
    }

    bindEvents() {
      this.container.querySelectorAll('.karat-select-btn').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          this.container.querySelectorAll('.karat-select-btn').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          this.state.karat = btn.dataset.karat;
          this.elements.karatBadge.textContent = `${this.state.karat}KT`;
          this.calculate();
        });
      });

      this.elements.weightInput.addEventListener('input', () => {
        this.state.weight = parseFloat(this.elements.weightInput.value) || 0;
        this.elements.weightBadge.textContent = `${this.state.weight}g`;
        this.calculate();
      });

      this.container.querySelectorAll('.quick-weight').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          this.state.weight = parseFloat(btn.dataset.weight);
          this.elements.weightInput.value = this.state.weight;
          this.elements.weightBadge.textContent = `${this.state.weight}g`;
          this.calculate();
        });
      });

      this.container.querySelector('#calc-exchange-btn')?.addEventListener('click', (e) => {
        e.preventDefault();
        this.calculate();
      });
    }

    calculate() {
      if (!this.state.rates['24kt']) return;

      let baseRate;
      switch (this.state.karat) {
        case '24': baseRate = this.state.rates['24kt']; break;
        case '22': baseRate = this.state.rates['22kt']; break;
        case '18': baseRate = Math.round(this.state.rates['24kt'] * 0.75); break;
        case '14': baseRate = Math.round(this.state.rates['24kt'] * 0.583); break;
        case '9':  baseRate = Math.round(this.state.rates['24kt'] * 0.375); break;
        default:   baseRate = this.state.rates['24kt'];
      }

      // Market value: baseRate is per 10g
      const ratePerGram = baseRate / 10;
      const marketValue = ratePerGram * this.state.weight;

      // Exchange value: market value + bonus percentage
      const exchangeValue = marketValue * (1 + this.exchangeBonusPercent / 100);

      this.elements.marketPrice.textContent = this.formatCurrency(marketValue);
      this.elements.finalPrice.textContent = this.formatCurrency(exchangeValue);
    }

    updatePriceTable() {
      if (!this.elements.priceTable || !this.state.rates['24kt']) return;

      const karats = [
        { name: '24KT', rate: this.state.rates['24kt'] },
        { name: '22KT', rate: this.state.rates['22kt'] },
        { name: '18KT', rate: Math.round(this.state.rates['24kt'] * 0.75) },
        { name: '14KT', rate: Math.round(this.state.rates['24kt'] * 0.583) },
      ];

      const weights = [1, 5, 10, 50, 100];
      let tableHTML = '';

      karats.forEach((karat) => {
        tableHTML += '<tr>';
        tableHTML += `<td><strong>${karat.name}</strong></td>`;
        weights.forEach((weight) => {
          const value = (karat.rate / 10) * weight;
          tableHTML += `<td>${this.formatCurrency(value)}</td>`;
        });
        tableHTML += '</tr>';
      });

      this.elements.priceTable.innerHTML = tableHTML;
    }

    formatCurrency(amount) {
      return new Intl.NumberFormat('en-IN', {
        style: 'currency',
        currency: 'INR',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      }).format(amount);
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.old-gold-exchange-calculator').forEach((container) => {
      new OldGoldExchangeCalculator(container);
    });
  });
</script>

{% schema %}
{
  "name": "Old Gold Exchange",
  "settings": [
    {
      "type": "range",
      "id": "exchange_bonus_percent",
      "label": "Exchange Bonus (%)",
      "info": "Extra percentage offered on top of market value for old gold exchange. E.g. enter 5 to give customers market value + 5%.",
      "min": 0,
      "max": 20,
      "step": 0.5,
      "default": 5
    }
  ],
  "presets": [
    {
      "name": "Old Gold Exchange Calculator"
    }
  ]
}
