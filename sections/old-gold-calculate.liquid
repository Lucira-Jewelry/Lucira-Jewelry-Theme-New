.calculator-description{font-size:13px}
.karat-selection-grid{grid-template-columns:repeat(3,1fr)}
.rate-value{font-size:24px}
.result-amount.final-amount{font-size:24px}
.quick-weight{min-width:calc(33.333% - 5px);border:1px solid #666}
.quick-weight:hover{background:#b76f79;color:#fff}
}
@media (max-width:768px) and (orientation:landscape){
.calculator-grid-old{grid-template-columns:1fr 1fr;gap:15px}
