{% comment %} <div class="gold-exchange-section">
  <div class="page-width">
    <h1 class="exchange-heading">Old Gold Exchange Calculator</h1>
    <p class="exchange-subheading">Calculate the value of your old gold instantly</p>
    
    <div class="exchange-container">
      <!-- Calculator Card -->
      <div class="exchange-card">
        <div class="rate-display-bar">
          <div class="rate-item">
            <span class="rate-label">24K Gold Rate</span>
            <span class="rate-value" id="rate24kt">{{ section.settings.rate_today }}</span>
            <span class="rate-unit">/10gm</span>
          </div>
          <div class="rate-divider"></div>
          <div class="rate-item">
            <span class="rate-label">22K Gold Rate</span>
            <span class="rate-value" id="rate22kt">{{ section.settings.rate_avg }}</span>
            <span class="rate-unit">/10gm</span>
          </div>
        </div>

        <div class="calc-form">
          <div class="form-group">
            <label class="form-label">Select Purity</label>
            <div class="purity-buttons">
              <button class="purity-btn active" data-karat="24">24K</button>
              <button class="purity-btn" data-karat="22">22K</button>
              <button class="purity-btn" data-karat="18">18K</button>
              <button class="purity-btn" data-karat="14">14K</button>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="goldWeight">Weight (in grams)</label>
            <input 
              type="number" 
              id="goldWeight" 
              class="form-input" 
              placeholder="Enter weight" 
              min="0.1" 
              step="0.1"
            >
          </div>

          <div class="form-group">
            <label class="form-label" for="wastagePercent">Wastage (%)</label>
            <input 
              type="number" 
              id="wastagePercent" 
              class="form-input" 
              placeholder="Enter wastage percentage" 
              value="10"
              min="0" 
              max="100"
            >
          </div>

          <button class="calc-button" id="calculateBtn">
            <span>Calculate Value</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

        <div class="result-section" id="resultSection" style="display: none;">
          <div class="result-header">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <h3>Estimated Exchange Value</h3>
          </div>
          
          <div class="result-breakdown">
            <div class="breakdown-item">
              <span class="breakdown-label">Gold Weight</span>
              <span class="breakdown-value" id="resultWeight">—</span>
            </div>
            <div class="breakdown-item">
              <span class="breakdown-label">Purity</span>
              <span class="breakdown-value" id="resultPurity">—</span>
            </div>
            <div class="breakdown-item">
              <span class="breakdown-label">Current Rate</span>
              <span class="breakdown-value" id="resultRate">—</span>
            </div>
            <div class="breakdown-item">
              <span class="breakdown-label">Gross Value</span>
              <span class="breakdown-value" id="resultGross">—</span>
            </div>
            <div class="breakdown-item">
              <span class="breakdown-label">Wastage Deduction</span>
              <span class="breakdown-value deduction" id="resultWastage">—</span>
            </div>
            <div class="breakdown-divider"></div>
            <div class="breakdown-item final">
              <span class="breakdown-label">Net Exchange Value</span>
              <span class="breakdown-value highlight" id="resultFinal">—</span>
            </div>
          </div>

          <p class="result-note">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M8 7V11M8 5H8.01M14 8C14 11.3137 11.3137 14 8 14C4.68629 14 2 11.3137 2 8C2 4.68629 4.68629 2 8 2C11.3137 2 14 4.68629 14 8Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            This is an estimated value. Final valuation depends on physical assessment and current market rates.
          </p>
        </div>
      </div>

      <!-- Info Card -->
      <div class="info-card">
        <div class="info-icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <circle cx="24" cy="24" r="20" fill="#FEF3C7"/>
            <path d="M24 16V24M24 28H24.02M34 24C34 29.5228 29.5228 34 24 34C18.4772 34 14 29.5228 14 24C14 18.4772 18.4772 14 24 14C29.5228 14 34 18.4772 34 24Z" stroke="#D97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="info-title">How It Works</h3>
        <ul class="info-list">
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M16.667 5L7.5 14.167L3.333 10" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Select the purity of your gold (24K, 22K, 18K, or 14K)
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M16.667 5L7.5 14.167L3.333 10" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Enter the weight in grams
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M16.667 5L7.5 14.167L3.333 10" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Add wastage percentage (typically 8-15%)
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M16.667 5L7.5 14.167L3.333 10" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Get instant estimated exchange value
          </li>
        </ul>

        <div class="info-highlight">
          <p><strong>Today's Live Rates</strong></p>
          <p>24K: {{ section.settings.rate_today }} per 10gm</p>
          <p>22K: {{ section.settings.rate_avg }} per 10gm</p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .gold-exchange-section {
    background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
    padding: 60px 0;
  }

  .exchange-heading {
    font-size: 36px;
    font-weight: 600;
    text-align: center;
    color: #1F2937;
    margin: 0 0 12px 0;
    letter-spacing: -0.5px;
  }

  .exchange-subheading {
    text-align: center;
    color: #6B7280;
    font-size: 18px;
    margin: 0 0 40px 0;
  }

  .exchange-container {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .exchange-card, .info-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    padding: 32px;
  }

  .rate-display-bar {
    display: flex;
    background: linear-gradient(135deg, #92400E 0%, #B45309 100%);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 32px;
    align-items: center;
    justify-content: space-around;
  }

  .rate-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .rate-label {
    color: #FEF3C7;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .rate-value {
    color: white;
    font-size: 24px;
    font-weight: 700;
  }

  .rate-unit {
    color: #FDE68A;
    font-size: 12px;
  }

  .rate-divider {
    width: 1px;
    height: 50px;
    background: rgba(254, 243, 199, 0.3);
  }

  .calc-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .form-label {
    font-size: 14px;
    font-weight: 600;
    color: #374151;
    letter-spacing: 0.3px;
  }

  .purity-buttons {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .purity-btn {
    padding: 14px;
    border: 2px solid #E5E7EB;
    border-radius: 10px;
    background: white;
    color: #6B7280;
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .purity-btn:hover {
    border-color: #D97706;
    color: #D97706;
  }

  .purity-btn.active {
    background: linear-gradient(135deg, #92400E 0%, #B45309 100%);
    border-color: #92400E;
    color: white;
  }

  .form-input {
    padding: 14px 16px;
    border: 2px solid #E5E7EB;
    border-radius: 10px;
    font-size: 15px;
    color: #1F2937;
    transition: all 0.2s ease;
  }

  .form-input:focus {
    outline: none;
    border-color: #D97706;
    box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.1);
  }

  .form-input::placeholder {
    color: #9CA3AF;
  }

  .calc-button {
    background: linear-gradient(135deg, #92400E 0%, #B45309 100%);
    color: white;
    border: none;
    padding: 16px 24px;
    border-radius: 10px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all 0.3s ease;
    margin-top: 8px;
  }

  .calc-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px -5px rgba(146, 64, 14, 0.4);
  }

  .result-section {
    margin-top: 32px;
    padding-top: 32px;
    border-top: 2px solid #F3F4F6;
    animation: slideIn 0.4s ease;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .result-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .result-header h3 {
    font-size: 20px;
    font-weight: 600;
    color: #1F2937;
    margin: 0;
  }

  .result-breakdown {
    background: #F9FAFB;
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .breakdown-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .breakdown-label {
    color: #6B7280;
    font-size: 14px;
    font-weight: 500;
  }

  .breakdown-value {
    color: #1F2937;
    font-size: 15px;
    font-weight: 600;
  }

  .breakdown-value.deduction {
    color: #DC2626;
  }

  .breakdown-value.highlight {
    color: #059669;
    font-size: 24px;
  }

  .breakdown-divider {
    height: 1px;
    background: #E5E7EB;
    margin: 4px 0;
  }

  .breakdown-item.final {
    padding-top: 4px;
  }

  .result-note {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-top: 20px;
    padding: 12px;
    background: #FEF3C7;
    border-radius: 8px;
    font-size: 13px;
    color: #92400E;
    line-height: 1.6;
  }

  .result-note svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .info-card {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .info-icon {
    display: flex;
    justify-content: center;
  }

  .info-title {
    font-size: 24px;
    font-weight: 600;
    color: #1F2937;
    text-align: center;
    margin: 0;
  }

  .info-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .info-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: #4B5563;
    font-size: 15px;
    line-height: 1.6;
  }

  .info-list svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .info-highlight {
    background: linear-gradient(135deg, #92400E 0%, #B45309 100%);
    padding: 20px;
    border-radius: 12px;
    color: white;
  }

  .info-highlight p {
    margin: 0 0 8px 0;
    font-size: 14px;
  }

  .info-highlight p:first-child {
    font-weight: 600;
    font-size: 15px;
    margin-bottom: 12px;
  }

  .info-highlight p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 968px) {
    .exchange-container {
      grid-template-columns: 1fr;
    }

    .exchange-heading {
      font-size: 28px;
    }

    .exchange-subheading {
      font-size: 16px;
    }

    .rate-display-bar {
      flex-direction: column;
      gap: 20px;
    }

    .rate-divider {
      width: 100px;
      height: 1px;
    }

    .purity-buttons {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .gold-exchange-section {
      padding: 40px 0;
    }

    .exchange-card, .info-card {
      padding: 24px;
    }

    .exchange-heading {
      font-size: 24px;
    }

    .rate-value {
      font-size: 20px;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Fetch gold rates from the existing rate display
  const baseRate24kt = parseFloat("{{ section.settings.rate_today | remove: '₹' | remove: ',' | strip }}");
  const baseRate22kt = parseFloat("{{ section.settings.rate_avg | remove: '₹' | remove: ',' | strip }}");
  
  let selectedKarat = 24;
  
  // Purity button selection
  document.querySelectorAll('.purity-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.purity-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      selectedKarat = parseInt(this.dataset.karat);
    });
  });
  
  // Calculate function
  document.getElementById('calculateBtn').addEventListener('click', function() {
    const weight = parseFloat(document.getElementById('goldWeight').value);
    const wastage = parseFloat(document.getElementById('wastagePercent').value);
    
    if (!weight || weight <= 0) {
      alert('Please enter a valid weight');
      return;
    }
    
    if (wastage < 0 || wastage > 100) {
      alert('Wastage percentage must be between 0 and 100');
      return;
    }
    
    // Calculate rate per gram based on karat
    let ratePerGram;
    if (selectedKarat === 24) {
      ratePerGram = baseRate24kt / 10;
    } else if (selectedKarat === 22) {
      ratePerGram = baseRate22kt / 10;
    } else {
      // Calculate proportional rate for 18K and 14K
      ratePerGram = (baseRate24kt / 10) * (selectedKarat / 24);
    }
    
    const grossValue = weight * ratePerGram;
    const wastageAmount = grossValue * (wastage / 100);
    const netValue = grossValue - wastageAmount;
    
    // Display results
    document.getElementById('resultWeight').textContent = weight.toFixed(2) + ' gm';
    document.getElementById('resultPurity').textContent = selectedKarat + 'K';
    document.getElementById('resultRate').textContent = '₹' + ratePerGram.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + '/gm';
    document.getElementById('resultGross').textContent = '₹' + grossValue.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2});
    document.getElementById('resultWastage').textContent = '-₹' + wastageAmount.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' (' + wastage + '%)';
    document.getElementById('resultFinal').textContent = '₹' + netValue.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2});
    
    document.getElementById('resultSection').style.display = 'block';
    
    // Smooth scroll to results
    document.getElementById('resultSection').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
  
  // Remove spinner buttons from number inputs
  const style = document.createElement('style');
  style.textContent = `
    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }
    input[type=number] {
      -moz-appearance: textfield;
    }
  `;
  document.head.appendChild(style);
});
</script>

{% schema %}
{
  "name": "Gold Exchange Calculator",
  "tag": "section",
  "class": "gold-exchange-calculator-section",
  "settings": [
    {
      "type": "text",
      "id": "rate_today",
      "label": "24K Gold Rate (per 10gm)",
      "default": "₹75,850",
      "info": "This rate will be automatically fetched from your gold rate section"
    },
    {
      "type": "text",
      "id": "rate_avg",
      "label": "22K Gold Rate (per 10gm)",
      "default": "₹69,530",
      "info": "This rate will be automatically fetched from your gold rate section"
    }
  ],
  "presets": [
    {
      "name": "Gold Exchange Calculator"
    }
  ]
}
{% endschema %} {% endcomment %}