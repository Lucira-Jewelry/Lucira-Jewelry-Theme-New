<script>
  $(document).ready(function () {
  let selectedPurity = 999; // for silver, usually 999 (99.9% pure)

  function getRateByPurity(baseRate, purity) {
    const perGramRate = baseRate / 10; // baseRate is for 10 gm → convert to 1 gm
    return (perGramRate * (purity / 1000)).toFixed(2); // silver purity is in ‰ (per mille)
  }

  const baseRate = parseFloat($('#silverRate').data('base')); // attach base silver rate in HTML

  function updateRateDisplay(purity) {
    const calculatedRate = purity === 999
      ? (baseRate / 10).toFixed(2)
      : getRateByPurity(baseRate, purity);

    $('.silver-calc__label--desktop').text(`Today's Standard Rate of ${purity} Silver`);
    $('.silver-calc__label--mobile').text(`Today's ${purity} Silver Rate`);
    $('#silverRate').text('₹ ' + parseFloat(calculatedRate).toLocaleString('en-IN'));
  }

  updateRateDisplay(selectedPurity);

  // Fixed: Changed from .silver-calc__purity to .silver-calc__karat
  $('.silver-calc__karat').on('click', function () {
    $('.silver-calc__karat').removeClass('silver-calc__karat--active');
    $(this).addClass('silver-calc__karat--active');

    // Extract purity number from button text (e.g., "999 Silver" → 999)
    selectedPurity = parseInt($(this).text().split(' ')[0]);
    updateRateDisplay(selectedPurity);
    $('#silverCalcResult').hide();
  });

  $('.silver-calc__button').on('click', function () {
    const weight = parseFloat($('#weightInput').val());

    if (isNaN(weight) || weight <= 0) {
      alert('Please enter a valid weight.');
      return;
    }

    const currentRate = selectedPurity === 999
      ? baseRate / 10
      : getRateByPurity(baseRate, selectedPurity);

    const total = (weight * currentRate).toFixed(2);

    $('#silverValueOutput').text(`₹${parseFloat(total).toLocaleString('en-IN')}`);
    $('#silverCalcResult').show();
    });
  });
</script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    function updateDateTime() {
      const today = new Date();

      // Format date
      const formattedDate = today.toLocaleDateString('en-IN', {
        day: 'numeric',
        month: 'short',
        year: 'numeric',
      });

      // Static time: 10:00 AM
      const formattedTime = '10:00 AM';

      // Combine date + "Updated on - " + time
      const dateTime = `Last Updated - ${formattedDate}, ${formattedTime}`;

      // Update DOM safely
      const el1 = document.getElementById('rate-today-date');
      const el2 = document.getElementById('rate-today-date-2');

      if (el1) el1.textContent = dateTime;
      if (el2) el2.textContent = dateTime;
    }

    // Run immediately
    updateDateTime();

    // Update once daily at midnight (optional, since only date changes)
    setInterval(updateDateTime, 86400000); // 24 hours
  });
</script>
