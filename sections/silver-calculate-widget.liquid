<div class="silver-widget-section">
  <div class="page-width">
  <div class="wrapper-silver">
    <div class="silver-widget__box">
      <!-- Today's Rate -->
      <div class="silver-widget__block silver-widget__block--today">
        <p class="silver-widget__label"><strong>999 Silver</strong> Rate in {{ page.metafields.custom.city_name }}</p>
        <p class="silver-widget__price"><span class="silver-unit">₹</span>{{ section.settings.rate_today -}}<span class="silver-widget__unit">/10 gm</span>
        </p>
        <p class="silver-widget__date" id="rate-today-date"></p>
      </div>

      <div class="silver-widget__divider"></div>

      <!-- Weekly Average -->
      <div class="silver-widget__block silver-widget__block--week">
        <p class="silver-widget__label"><strong>999 Silver</strong> Rate in {{ page.metafields.custom.city_name }}</p>
        <p class="silver-widget__price"><span class="silver-unit">₹</span>{{ section.settings.rate_avg -}}<span class="silver-widget__unit">/1 KG</span>
        </p>
        {% comment %} <p class="silver-widget__date" id="rate-today-date-2"></p> {% endcomment %}
      </div>
    </div>
          <div class="location-selector">
        <div class="location-dropdown">
          <label for="state">State</label>
          <select id="state" name="state">
            {% assign states = "Andaman and Nicobar Islands,Andhra Pradesh,Arunachal Pradesh,Assam,Bihar,Chandigarh,Chhattisgarh,Dadra and Nagar Haveli,Daman and Diu,Delhi,Goa,Gujarat,Haryana,Himachal Pradesh,Jammu and Kashmir,Jharkhand,Karnataka,Kerala,Lakshadweep,Madhya Pradesh,Maharashtra,Manipur,Meghalaya,Mizoram,Nagaland,Odisha,Puducherry,Punjab,Rajasthan,Sikkim,Tamil Nadu,Telangana,Tripura,Uttar Pradesh,Uttarakhand,West Bengal" | split: "," %}
            {% assign current_state = page.metafields.custom.state_name %}
            {% for state in states %}
              {% assign state_value = state | downcase | replace: ' ', '-' %}
              {% assign state_selected = false %}
              
              {% comment %} Check if current state matches either the display name or the value {% endcomment %}
              {% if current_state == state or current_state == state_value %}
                {% assign state_selected = true %}
              {% endif %}
              
              <option value="{{ state_value }}" {% if state_selected %}selected{% endif %}>{{ state }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="location-dropdown city-dropdown">
          <label for="city">City</label>
          <select id="city" name="city">
            {% assign current_city = page.metafields.custom.city_name %}
            {% comment %} Cities will be populated by JavaScript, but we need to set the selected value {% endcomment %}
          </select>
        </div>

        <button type="button" class="location-submit">→</button>
      </div>
      </div>
  </div>
</div>
<div class="silver-calc-section">
  <div class="page-width">
    <h1 class="silver-calc__heading">Silver Rate Today in {{ page.metafields.custom.city_name }}</h1>
  </div>
  <div class="silver-calc__container">
    <p class="silver-calc__label">Choose Karatage</p>

    <div class="silver-calc__karat-options">
      <button class="silver-calc__karat silver-calc__karat--active">999 Silver</button>
      <button class="silver-calc__karat">958 Silver</button>
      <button class="silver-calc__karat">925 Silver</button>
    </div>

    <div class="silver-calc__inputs">
      <div class="silver-calc__input-group">
        <label for="weightInput" class="silver-calc__input-label">In Grams</label>
        <input type="text" id="weightInput" placeholder="Enter Weight" class="silver-calc__input">
      </div>

      <div class="silver-calc__input-group">
        <label for="silverRate" class="silver-calc__input-label">
          <span class="silver-calc__label--desktop">Today's Standard Rate of 999 Silver</span>
          <span class="silver-calc__label--mobile">Today's 14kt silver Rate</span>
        </label>
        <div
            id="silverRate"
            class="silver-calc__rate-display"
            data-base="{{ section.settings.rate_today | remove: '₹' | remove: ',' | strip }}"
          >
        </div>
      </div>
    </div>

    <button class="silver-calc__button">CALCULATE</button>

    <div id="silverCalcResult" class="silver-calc__rate-display" style="margin-top: 15px; display:none;">
      <span>Estimated Value: </span><span id="silverValueOutput"></span>
    </div>

    <p class="silver-calc__note">*This value is not the final value as Silver Rate might change*</p>
  </div>
</div>
<div class="investment-section">
  <div class="page-width">
    <div class="investment-section__container">
    <!-- Left Column -->
        <div class="investment-section__container">
          <div class="investment-section__column investment-section__left" style="width:fit-content">
            <h2 class="investment-section__heading">{{ section.settings.investment_heading }}</h2>
            <div class="investment-section__description">
              {{ section.settings.investment_description }}
            </div>
          </div>

          <div class="investment-section__column investment-section__right">
            <h3 class="investment-section__toc-heading">Table of Contents</h3>
            {{ section.settings.investment_quick_links }}
          </div>
        </div>
  </div>
  </div>
</div>
<div class="silver-table-v2-section">
  <div class="page-width">
    <h2 class="silver-table-v2-title">Silver PRICE BREAKDOWN BY WEIGHT</h2>
    <div class="silver-table-v2-wrapper">
      <table class="silver-table-v2">
        <thead>
          <tr>
            <th>Weight</th>
            <th>10GM</th>
            <th>0.1KG</th>
            <th>0.5KG</th>
            <th>1KG</th>
          </tr>
        </thead>
        <tbody>
          {%- assign base_24kt = section.settings.rate_today | remove: '₹' | remove: ',' | strip | plus: 0 -%}
          {%- assign rate_per_gram = base_24kt | divided_by: 10.0 -%}
          {%- assign karats = "999,958,925" | split: "," -%}
          {%- assign weights = "10,100,500,1000" | split: "," -%}
          
          {%- for karat in karats -%}
            {%- assign karat_factor = karat | plus: 0 | divided_by: 999.0 -%}
            <tr>
              <td>{{ karat }} Silver</td>
              {%- for w in weights -%}
                {%- assign price = rate_per_gram | times: w | times: karat_factor -%}
                <td>₹{{ price | round }}</td>
              {%- endfor -%}
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</div>
