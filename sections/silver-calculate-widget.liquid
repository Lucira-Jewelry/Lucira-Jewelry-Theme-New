<script>
  $(document).ready(function () {
    let selectedPurity = 999;

    const baseRate = parseFloat($('#silverRate').data('base'));

    // Helper function to calculate the rate for 1 gram at a specific purity
    function getRateByPurity(baseRate, purity) {
      const perGramRate = baseRate / 10; // Rate for 1 gram of 999 purity
      return perGramRate * (purity / 999); // Rate for 1 gram of selected purity
    }

    // Function to update the visible rate display for the selected purity
    function updateRateDisplay(purity) {
      const calculatedRate = purity === 999 ? baseRate / 10 : getRateByPurity(baseRate, purity);

      $('.silver-calc__label--desktop').text(`Today's Standard Rate of ${purity} Silver`);
      $('.silver-calc__label--mobile').text(`Today's ${purity} Silver Rate`);
      $('#silverRate').text(
        '₹ ' +
          parseFloat(calculatedRate).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
      );
    }

    // --- Initial Setup and Events ---

    // 1. Initial display setup - ONLY update rate display, DO NOT calculate
    updateRateDisplay(selectedPurity);

    // Hide results initially
    $('#silverCalcResult').hide();

    // 2. Purity Button Click Handler (Only updates rate display, no auto-calculation)
    $('.silver-calc__karat').on('click', function () {
      $('.silver-calc__karat').removeClass('silver-calc__karat--active');
      $(this).addClass('silver-calc__karat--active');

      selectedPurity = parseInt($(this).text());
      updateRateDisplay(selectedPurity);

      // DO NOT auto-calculate here
    });

    // 3. Weight Input Handler (No auto-calculation)
    $('#weightInput').on('input', function () {
      // DO NOT auto-calculate here
    });

    // 4. Calculate Button - ONLY calculate when clicked
    $('.silver-calc__button').on('click', function () {
      const weight = parseFloat($('#weightInput').val());

      // 1. Input Validation
      if (isNaN(weight) || weight <= 0) {
        $('#silverCalcResult').hide();
        alert('Please enter a valid weight in grams.');
        return;
      }

      // 2. Silver Price Calculation
      const currentRate = selectedPurity === 999 ? baseRate / 10 : getRateByPurity(baseRate, selectedPurity);

      const silverPrice = weight * currentRate;
      const totalExcludingGST = silverPrice.toFixed(2);

      // 3. Update Calculator Result
      $('#silverValueOutput').text(
        `₹${parseFloat(totalExcludingGST).toLocaleString('en-IN', {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        })}`
      );
      $('#silverCalcResult').show();
    });
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function updateDateTime() {
      const today = new Date();

      // Format date
      const formattedDate = today.toLocaleDateString('en-IN', {
        day: 'numeric',
        month: 'short',
        year: 'numeric',
      });

      // Static time: 10:00 AM
      const formattedTime = '10:00 AM';

      // Combine date + "Updated on - " + time
      const dateTime = `Last Updated - ${formattedDate}, ${formattedTime}`;

      // Update DOM safely
      const el1 = document.getElementById('rate-today-date');
      const el2 = document.getElementById('rate-today-date-2');

      if (el1) el1.textContent = dateTime;
      if (el2) el2.textContent = dateTime;
    }

    // Run immediately
    updateDateTime();

    // Update once daily at midnight (optional, since only date changes)
    setInterval(updateDateTime, 86400000); // 24 hours
  });
</script>

<script>
  function replaceSilverShortcodes() {
    const baseEl = document.querySelector('[data-base]');
    if (!baseEl) return;

    const baseRate = parseFloat(baseEl.getAttribute('data-base'));
    if (isNaN(baseRate)) return;

    const ratePerGram = baseRate / 10;

    const rates = {
      // Per 1 gram
      '[silver_rate_999]': Math.round(ratePerGram),
      '[silver_rate_958]': Math.round(ratePerGram * (958 / 999)),
      '[silver_rate_925]': Math.round(ratePerGram * (925 / 999)),

      // ✅ Per 10 gram
      '[silver_rate_999_10gm]': Math.round(ratePerGram * 10),
      '[silver_rate_958_10gm]': Math.round(ratePerGram * 10 * (958 / 999)),
      '[silver_rate_925_10gm]': Math.round(ratePerGram * 10 * (925 / 999)),
    };

    const containers = document.querySelectorAll('p, li, span, div, h1, h2, h3, h4, h5, h6');

    containers.forEach((el) => {
      let html = el.innerHTML;
      let changed = false;

      Object.entries(rates).forEach(([shortcode, price]) => {
        if (html.includes(shortcode)) {
          html = html.replaceAll(shortcode, `₹${price.toLocaleString('en-IN')}`);
          changed = true;
        }
      });

      if (changed) el.innerHTML = html;
    });
  }

  document.addEventListener('DOMContentLoaded', replaceSilverShortcodes);
</script>

<script>
  $(document).ready(function () {
    $('.silver-table-v2 td').each(function () {
      let text = $(this).text().trim();
      if (text.startsWith('₹')) {
        let number = parseInt(text.replace(/[₹,]/g, ''));
        if (!isNaN(number)) {
          let formatted = number.toLocaleString('en-IN');
          $(this).text('₹' + formatted);
        }
      }
    });
  });
</script>

<script>
  function getDaySuffix(day) {
    if (day > 3 && day < 21) return 'th';
    switch (day % 10) {
      case 1:
        return 'st';
      case 2:
        return 'nd';
      case 3:
        return 'rd';
      default:
        return 'th';
    }
  }

  function replaceDateShortcode() {
    const today = new Date();

    const day = today.getDate();
    const suffix = getDaySuffix(day);

    const formattedDate = `${day}${suffix} ${today.toLocaleString('en-IN', {
      month: 'short',
    })}, ${today.getFullYear()}`;

    const elements = document.querySelectorAll('p, li, span, div, h1, h2, h3, h4, h5, h6');

    elements.forEach((el) => {
      if (el.innerHTML.includes('[current_date]')) {
        el.innerHTML = el.innerHTML.replaceAll('[current_date]', formattedDate);
      }
    });
  }

  document.addEventListener('DOMContentLoaded', replaceDateShortcode);
</script>

