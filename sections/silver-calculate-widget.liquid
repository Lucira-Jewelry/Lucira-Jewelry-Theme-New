  const stateDropdown = document.getElementById('state');
  const cityDropdown = document.getElementById('city');
  const submitButton = document.querySelector('.location-submit');

  // Get pre-selected values from Liquid
  const preselectedCity = "{{ page.metafields.custom.city_name | default: '' }}";
  const preselectedState = "{{ page.metafields.custom.state_name | default: '' }}";

  // Get links from schema settings
  const defaultLink = "{{ section.settings.default_cta_link | default: '/collections/all' }}";
  const shopLink = "{{ section.settings.shop_jewelry_link | default: '/collections/all' }}";

  // Store initial dropdown values
  let initialState = '';
  let initialCity = '';

  function populateCities(state) {
    cityDropdown.innerHTML = '';
    if (stateCityMap[state]) {
      stateCityMap[state].forEach((city) => {
        const option = document.createElement('option');
        option.value = city.toLowerCase().replace(/\s+/g, '-');
        option.textContent = city;

        // Check if this city should be pre-selected
        if (
          preselectedCity &&
          (preselectedCity === city || preselectedCity === city.toLowerCase().replace(/\s+/g, '-'))
        ) {
          option.selected = true;
        }

        cityDropdown.appendChild(option);
      });
    }
  }

  // Check if current selection matches the page location
  function isCurrentPageLocation() {
    if (!preselectedCity || !preselectedState) {
      return false;
    }

    const selectedCity = cityDropdown.value;
    const selectedState = stateDropdown.value;
    const selectedCityText = cityDropdown.options[cityDropdown.selectedIndex]?.text || '';
    const selectedStateText = stateDropdown.options[stateDropdown.selectedIndex]?.text || '';

    const cityMatch = preselectedCity === selectedCityText || 
                      preselectedCity === selectedCity ||
                      preselectedCity.toLowerCase().replace(/\s+/g, '-') === selectedCity;

    const stateMatch = preselectedState === selectedState ||
                       preselectedState === selectedStateText ||
                       preselectedState.toLowerCase().replace(/\s+/g, '-') === selectedState;

    return cityMatch && stateMatch;
  }

  // Check if location has been changed from initial
  function hasLocationChanged() {
    return stateDropdown.value !== initialState || cityDropdown.value !== initialCity;
  }

  // Update button state and behavior
  // Update button state and behavior
  function updateButtonState() {
    const matchesPage = isCurrentPageLocation();
    const changed = hasLocationChanged();

    const buttonShopIcon = submitButton.querySelector('.button-icon-shop');
    const buttonUpdateIcon = submitButton.querySelector('.button-icon-update');
    const buttonArrow = submitButton.querySelector('.button-arrow');
    const buttonText = submitButton.querySelector('.button-text');

    // Hide all icons first
    buttonShopIcon.style.display = 'none';
    buttonUpdateIcon.style.display = 'none';
    buttonArrow.style.display = 'none';

    if (matchesPage && !changed) {
      // Current page location is selected - show Shop Gold Jewelry with shopping bag icon
      buttonShopIcon.style.display = 'inline-block';
      buttonText.textContent = 'SHOP JEWELRY';
      submitButton.onclick = function() {
        window.location.href = shopLink;
      };
    } else if (changed) {
      // User changed location - show Update Location with arrow icon
      buttonUpdateIcon.style.display = 'inline-block';
      buttonText.textContent = 'Update Location';
      submitButton.onclick = function() {
        const city = cityDropdown.value;
        window.location.href = `/pages/${city}-gold-rate-today`;
      };
    } else {
      // Default state - show arrow symbol only
      buttonArrow.style.display = 'inline-block';
      buttonText.textContent = '';
      submitButton.onclick = function() {
        window.location.href = defaultLink;
      };
    }
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', function () {
    // Populate cities for the initially selected state
    populateCities(stateDropdown.value);
    
    // Store initial values after population
    initialState = stateDropdown.value;
    initialCity = cityDropdown.value;
    
    // Set initial button state
    updateButtonState();
  });

  // Event listeners
  stateDropdown.addEventListener('change', function () {
    populateCities(this.value);
    updateButtonState();
  });

  cityDropdown.addEventListener('change', function() {
    updateButtonState();
  });
</script>


<script>

  function replaceSilverShortcodes() {
    const baseEl = document.querySelector('[data-base]');
    if (!baseEl) return;

    const baseRate = parseFloat(baseEl.getAttribute('data-base'));
    if (isNaN(baseRate)) return;

    const ratePerGram = baseRate / 10;

    // Helper function to add ordinal suffix to day
    function getOrdinalSuffix(day) {
      if (day > 3 && day < 21) return 'th';
      switch (day % 10) {
        case 1: return 'st';
        case 2: return 'nd';
        case 3: return 'rd';
        default: return 'th';
      }
    }

    // Get current date in various formats
    const today = new Date();
    const day = today.getDate();
    const ordinalDay = day + getOrdinalSuffix(day);
    
    const dateFormats = {
      "[current_date]": today.toLocaleDateString('en-IN', {
        day: 'numeric',
        month: 'long',
        year: 'numeric'
      }), // e.g., "25 August 2025"
      
      "[current_date_short]": today.toLocaleDateString('en-IN', {
        day: 'numeric',
        month: 'short',
        year: 'numeric'
      }), // e.g., "25 Aug 2025"
      
      "[current_date_timestamp]": `${ordinalDay} ${today.toLocaleDateString('en-IN', { month: 'short' })} ${today.getFullYear()}, ${today.toLocaleTimeString('en-IN', { hour12: false })}`, // e.g., "25th Aug 2025, 18:36:45"
      
      "[current_date_midnight]": `${ordinalDay} ${today.toLocaleDateString('en-IN', { month: 'short' })} ${today.getFullYear()}, 00:00:00`, // e.g., "25th Aug 2025, 00:00:00"
      
      "[current_date_time]": `${ordinalDay} ${today.toLocaleDateString('en-IN', { month: 'short' })} ${today.getFullYear()}, ${today.toLocaleTimeString('en-IN', { hour12: false })}`, // e.g., "25th Aug 2025, 14:30:45"
      
      "[current_time]": today.toLocaleTimeString('en-IN', { hour12: false }), // e.g., "14:30:45"
      
      "[current_time_12h]": today.toLocaleTimeString('en-IN', { hour12: true }), // e.g., "2:30:45 PM"
      
      "[current_date_dmy]": today.toLocaleDateString('en-GB'), // e.g., "25/08/2025"
      
      "[current_date_mdy]": today.toLocaleDateString('en-US'), // e.g., "08/25/2025"
      
      "[current_day]": today.toLocaleDateString('en-IN', { weekday: 'long' }), // e.g., "Monday"
      
      "[current_month]": today.toLocaleDateString('en-IN', { month: 'long' }), // e.g., "August"
      
      "[current_year]": today.getFullYear().toString(), // e.g., "2025"
    };

    // Silver rates for different purities and weights
    const silver999PerGram = Math.round(ratePerGram * (999 / 1000));
    const silver958PerGram = Math.round(ratePerGram * (958 / 1000));
    const silver925PerGram = Math.round(ratePerGram * (925 / 1000));
    const silver900PerGram = Math.round(ratePerGram * (900 / 1000));
    const silver800PerGram = Math.round(ratePerGram * (800 / 1000));

    const rates = {
      // Raw rates (numbers only) for different purities
      "[silver_rate_999]": silver999PerGram,
      "[silver_rate_958]": silver958PerGram,
      "[silver_rate_925]": silver925PerGram,
      "[silver_rate_900]": silver900PerGram,
      "[silver_rate_800]": silver800PerGram,
      
      // Formatted with currency symbol - per gram
      "[silver_price_999]": `₹${silver999PerGram.toLocaleString('en-IN')}`,
      "[silver_price_958]": `₹${silver958PerGram.toLocaleString('en-IN')}`,
      "[silver_price_925]": `₹${silver925PerGram.toLocaleString('en-IN')}`,
      "[silver_price_900]": `₹${silver900PerGram.toLocaleString('en-IN')}`,
      "[silver_price_800]": `₹${silver800PerGram.toLocaleString('en-IN')}`,

      // Weight-based pricing for 999 purity (most common)
      "[silver_price_1g]": `₹${silver999PerGram.toLocaleString('en-IN')}`,
      "[silver_price_10g]": `₹${(silver999PerGram * 10).toLocaleString('en-IN')}`,
      "[silver_price_100g]": `₹${(silver999PerGram * 100).toLocaleString('en-IN')}`,
      "[silver_price_1kg]": `₹${(silver999PerGram * 1000).toLocaleString('en-IN')}`,

      // Raw numbers without currency symbol
      "[silver_rate_1g]": silver999PerGram,
      "[silver_rate_10g]": silver999PerGram * 10,
      "[silver_rate_100g]": silver999PerGram * 100,
      "[silver_rate_1kg]": silver999PerGram * 1000,

      // Weight-based pricing for different purities
      "[silver_price_925_1g]": `₹${silver925PerGram.toLocaleString('en-IN')}`,
      "[silver_price_925_10g]": `₹${(silver925PerGram * 10).toLocaleString('en-IN')}`,
      "[silver_price_925_100g]": `₹${(silver925PerGram * 100).toLocaleString('en-IN')}`,
      "[silver_price_925_1kg]": `₹${(silver925PerGram * 1000).toLocaleString('en-IN')}`,
    };

    // Location shortcodes (you can customize these)
    const locationShortcodes = {
      "[city]": "Mumbai",
      "[state]": "Maharashtra",
      "[country]": "India",
      "[city_state]": "Mumbai, Maharashtra",
    };

    // Combine all shortcodes
    const allShortcodes = { ...dateFormats, ...rates, ...locationShortcodes };

    const containers = document.querySelectorAll("p, li, span, div, h1, h2, h3, h4, h5, h6, td, th");

    containers.forEach((el) => {
      let html = el.innerHTML;
      let changed = false;

      Object.entries(allShortcodes).forEach(([shortcode, replacement]) => {
        if (html.includes(shortcode)) {
          html = html.replaceAll(shortcode, replacement);
          changed = true;
        }
      });

      if (changed) el.innerHTML = html;
    });
  }

  document.addEventListener("DOMContentLoaded", function () {
    replaceSilverShortcodes();
  });


</script>

<script>
  $(document).ready(function () {
    $('.silver-table-v2 td').each(function () {
      let text = $(this).text().trim();
      if (text.startsWith('₹')) {
        let number = parseInt(text.replace(/[₹,]/g, ''));
        if (!isNaN(number)) {
          let formatted = number.toLocaleString('en-IN');
          $(this).text('₹' + formatted);
        }
      }
    });
  });
</script>



