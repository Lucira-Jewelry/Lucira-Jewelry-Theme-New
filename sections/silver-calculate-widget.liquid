    <div class="silver-table-v2-wrapper">
      <table class="silver-table-v2">
        <thead>
          <tr>
            <th>PURITY</th>
            <th>1GM</th>
            <th>10GM</th>
            <th>100GM</th>
            <th>1KG</th>
          </tr>
        </thead>
        <tbody>
          {%- assign base_999 = section.settings.rate_today | remove: '₹' | remove: ',' | strip | plus: 0 -%}
          {%- assign rate_per_gram = base_999 | divided_by: 10.0 -%}
          {%- assign purities = '999,958,925' | split: ',' -%}
          {%- assign weights = '1,10,100,1000' | split: ',' -%}

          {%- for purity in purities -%}
            {%- assign purity_factor = purity | plus: 0 | divided_by: 999.0 -%}
            <tr>
              <td>{{ purity }} Silver</td>
              {%- for w in weights -%}
                {%- assign price = rate_per_gram | times: w | times: purity_factor -%}
                <td>₹{{ price | round }}</td>
              {%- endfor -%}
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</div>

