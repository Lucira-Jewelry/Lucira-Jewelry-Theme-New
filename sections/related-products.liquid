<link rel="preload" href="{{ 'product-card.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript>
  <link rel="stylesheet" href="{{ 'product-card.css' | asset_url }}">
</noscript>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  
  .you-may-also-like-collection .collection__title--desktop-slider .title { 
    text-align: center; 
    font-weight: 400; 
    font-size: 28px; 
    margin-bottom: 0 !important;
  }

  .you-may-also-like-collection h2.title.inline-richtext.h1 { text-align: center; font-size: 24px; margin-bottom: 0; }
  
  .you-may-also-like-collection .collection__description p { 
    color: #535361; 
    font-weight: 400; 
    font-size: 18px; 
    line-height: 2; 
    text-align: center; 
    vertical-align: middle; 
    margin: 0 auto 30px !important;
    display: block; 
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    
  }
  @media  screen and  (max-width:440px){
      .you-may-also-like-collection h2.title.inline-richtext.h1, .pdp-match-shine-headers h2, h2.featured-in { text-align: center !important; font-size: 18px !important; margin-bottom: 0px !important; }
      .you-may-also-like-collection .collection__description p, .pdp-match-shine-headers p, .featured-in-parent .into-the-web {font-size: 14px !important;}

    }
{%- endstyle -%}

{%- liquid
  assign selected_collection = collections[section.settings.collection_new]
  assign current_product_tags = product.tags
  assign valid_tags = "Rings,Earrings,Necklaces,Bracelets,Pendants" | split: ","
  assign matched_tag = ""
  
  for tag in current_product_tags
    if valid_tags contains tag
      assign matched_tag = tag
      break
    endif
  endfor
  
  assign related_products = blank
  assign related_products_array = blank
  
  if selected_collection and matched_tag != ""
    for related_product in selected_collection.products
      if related_product.tags contains matched_tag and related_product.id != product.id
        assign related_products_array = related_products_array | append: related_product.id | append: ','
        if related_products_array == blank
          assign related_products = related_product.id
        endif
      endif
    endfor
  endif
  
  assign products_to_display = section.settings.products_to_show
  if products_to_display > 8
    assign products_to_display = 8
  endif

  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = true
  assign show_desktop_slider = section.settings.enable_desktop_slider
  assign use_slider = true
-%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient">
  <div
    class="collection you-may-also-like-collection{% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %} section-{{ section.id }}-padding{% if section.settings.full_width %}  collection--full-width{% endif %}"
    id="you-may-also-like-{{ section.id }}"
    data-id="{{ section.id }}"
  >
    <div class="collection__title title-wrapper title-wrapper--no-top-margin page-width{% if use_slider %} title-wrapper--self-padded-tablet-down{% endif %}{% if show_desktop_slider %} collection__title--desktop-slider{% endif %}">
      {%- if section.settings.header != blank -%}
        <h2 class="title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.header }}
        </h2>
      {%- endif -%}
      {%- if section.settings.subheader != blank -%}
        <div class="collection__description{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <p>{{ section.settings.subheader }}</p>
        </div>
      {%- endif -%}
    </div>

    {% if selected_collection and matched_tag != "" %}
      <div class="{% if section.settings.full_width %}slider-component-full-width{% endif %} page-width{% if use_slider == false %} page-width{% endif %}{% if show_desktop_slider == false and section.settings.full_width == false %} page-width-desktop{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        
        {%- if use_slider -%}
          <!-- Swiper Container -->
          <div class="swiper you-may-also-like-swiper-{{ section.id }}" id="Swiper-{{ section.id }}">
            <div class="swiper-wrapper">
        {%- else -%}
          <!-- Grid Container -->
          <ul
            id="Grid-{{ section.id }}"
            data-id="{{ section.id }}"
            class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down"
            role="list"
            aria-label="You may also like products"
          >
        {%- endif -%}

        {% assign skip_card_product_styles = false %}
        {% assign displayed_count = 0 %}
        
        {%- for related_product in selected_collection.products -%}
          {% if related_product.tags contains matched_tag and related_product.id != product.id and displayed_count < products_to_display %}
            {%- if use_slider -%}
              <div class="swiper-slide">
            {%- else -%}
              <li class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ displayed_count | plus: 1 }};"
                  {% endif %}>
            {%- endif -%}
            
              {% render 'card-product',
                card_product: related_product,
                media_aspect_ratio: section.settings.image_ratio,
                image_shape: section.settings.image_shape,
                show_secondary_image: section.settings.show_secondary_image,
                show_vendor: section.settings.show_vendor,
                show_rating: section.settings.show_rating,
                skip_styles: skip_card_product_styles,
                section_id: section.id,
                quick_add: section.settings.quick_add
              %}
            
            {%- if use_slider -%}
              </div>
            {%- else -%}
              </li>
            {%- endif -%}
            
            {% assign skip_card_product_styles = true %}
            {% assign displayed_count = displayed_count | plus: 1 %}
          {% endif %}
        {%- endfor -%}

        {%- if displayed_count == 0 -%}
          {%- for i in (1..section.settings.columns_desktop) -%}
            {%- if use_slider -%}
              <div class="swiper-slide">
            {%- else -%}
              <li class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                  {% endif %}>
            {%- endif -%}
            
              {% liquid
                assign ridx = forloop.rindex
                case ridx
                  when 5
                    assign ridx = 1
                  when 6
                    assign ridx = 2
                endcase
              %}
              {%- assign placeholder_image = 'product-apparel-' | append: ridx -%}
              {% render 'card-product',
                show_vendor: section.settings.show_vendor,
                media_aspect_ratio: section.settings.image_ratio,
                image_shape: section.settings.image_shape,
                placeholder_image: placeholder_image
              %}
            
            {%- if use_slider -%}
              </div>
            {%- else -%}
              </li>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

        {%- if use_slider -%}
            </div>
            <!-- Swiper Navigation -->
            <div class="swiper-button-next swiper-button-next-{{ section.id }}"></div>
            <div class="swiper-button-prev swiper-button-prev-{{ section.id }}"></div>
            
            <!-- Swiper Pagination -->
            <div class="swiper-pagination swiper-pagination-{{ section.id }}"></div>
          </div>
        {%- else -%}
          </ul>
        {%- endif -%}
      </div>
    {% endif %}

    {% if section.settings.image_shape == 'arch' %}
      {{ 'mask-arch.svg' | inline_asset_content }}
    {%- endif -%}
  </div>
</div>

{%- if use_slider -%}
<style>
  
.you-may-also-like-swiper-{{ section.id }} { overflow: hidden; padding-bottom: 0px; position: relative; }
.you-may-also-like-swiper-{{ section.id }} .swiper-slide { height: auto; }
