  .you-may-also-like-swiper-{{ section.id }} a.product-card-link { display: none; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  function firePromoClick(card) {
    const link = card.querySelector('a[href*="/products/"]');
    if (!link) return;
    
    const productHandle = link.href.split('/products/')[1]?.split('?')[0];
    const productTitle = card.querySelector('.card__heading')?.innerText?.trim() || '';
    
    if (!productHandle) return;
    
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: "promoClick",
      promoClick: {
        promo_id: 'you-may-also-like-{{ section.id }}-product',
        creative_name: 'you_may_also_like_feature', 
        promo_position: 'product_page_you_may_also_like',
        promo_name: productTitle
      }
    });
    console.log('GTM promoClick fired:', productHandle, productTitle);
  }

  function bindPromoClickDelegation() {
    const container = document.querySelector('#you-may-also-like-{{ section.id }}');
    
    if (!container) {
      console.log('Container not found for promo click tracking');
      return;
    }

    container.addEventListener('click', function(e) {
      const card = e.target.closest('.card-wrapper');
      if (!card) return;
      firePromoClick(card);
    }, { capture: true });
  }

  setTimeout(bindPromoClickDelegation, 500);

  // Rest of your video modal code remains the same...
  let modal = document.getElementById('VideoModal');
  if (!modal) {
    modal = document.createElement('div');
    modal.id = 'VideoModal';
    modal.className = 'video-modal hidden';
    modal.innerHTML = `<div class="video-modal__overlay"><div class="video-modal__content"><button class="video-modal__close"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<mask id="mask0_10852_4801" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24">
<rect width="24" height="24" fill="#D9D9D9"/>
</mask>
<g mask="url(#mask0_10852_4801)">
<path d="M12 13.0538L6.92701 18.127C6.78851 18.2653 6.61443 18.3362 6.40476 18.3395C6.19526 18.3427 6.01801 18.2718 5.87301 18.127C5.72818 17.982 5.65576 17.8063 5.65576 17.6C5.65576 17.3937 5.72818 17.218 5.87301 17.073L10.9463 12L5.87301 6.92701C5.73468 6.78851 5.66385 6.61443 5.66051 6.40476C5.65735 6.19526 5.72818 6.01801 5.87301 5.87301C6.01801 5.72818 6.19368 5.65576 6.40001 5.65576C6.60635 5.65576 6.78201 5.72818 6.92701 5.87301L12 10.9463L17.073 5.87301C17.2115 5.73468 17.3856 5.66385 17.5953 5.66051C17.8048 5.65735 17.982 5.72818 18.127 5.87301C18.2718 6.01801 18.3443 6.19368 18.3443 6.40001C18.3443 6.60635 18.2718 6.78201 18.127 6.92701L13.0538 12L18.127 17.073C18.2653 17.2115 18.3362 17.3856 18.3395 17.5953C18.3427 17.8048 18.2718 17.982 18.127 18.127C17.982 18.2718 17.8063 18.3443 17.6 18.3443C17.3937 18.3443 17.218 18.2718 17.073 18.127L12 13.0538Z" fill="#666666"/>
</g>
</svg></button><div class="video-modal__video-container"></div></div></div>`;
    document.body.appendChild(modal);
    
    const style = document.createElement('style');
    style.textContent = `.video-modal{position:fixed;top:0;left:0;width:100%;height:100%;z-index:9999;background:rgba(0,0,0,0);backdrop-filter:blur(0px);opacity:0;visibility:hidden;transition:all 0.5s ease}.video-modal:not(.hidden){background:rgba(0,0,0,0.8);backdrop-filter:blur(10px);opacity:1;visibility:visible}.video-modal__content{position:relative;max-width:100vw;max-height:90vh;margin:0 auto}.video-modal__close{position:absolute;top:-40px;right:0;background:none;border:none;color:white;font-size:24px;cursor:pointer;z-index:10001}.video-modal__video-container video{width:100%;height:auto;max-height:90vh}`;
    document.head.appendChild(style);
  }

  const overlay = modal.querySelector('.video-modal__overlay');
  const closeBtn = modal.querySelector('.video-modal__close');
  const videoContainer = modal.querySelector('.video-modal__video-container');

  function openVideoModal(productHandle, videoId) {
    videoContainer.innerHTML = '';
    fetch(`/products/${productHandle}.js`)
      .then(res => res.json())
      .then(product => {
        const video = product.media.find(m => m.media_type === 'video' && m.id.toString() === videoId.toString());
        if (video && video.sources && video.sources.length) {
          const videoUrl = video.sources[0].url;
          videoContainer.innerHTML = `<video autoplay muted playsinline loop><source src="${videoUrl}" type="video/mp4">Your browser does not support the video tag.</video>`;
          modal.style.display = 'block';
          requestAnimationFrame(() => modal.classList.remove('hidden'));
          document.body.style.overflow = 'hidden';
        }
      })
      .catch(err => console.error('Error fetching product data:', err));
  }

  function closeModal() {
    modal.classList.add('hidden');
    setTimeout(() => {
      modal.style.display = 'none';
      videoContainer.innerHTML = '';
    }, 600);
    document.body.style.overflow = '';
  }

  document.addEventListener('click', e => {
    const videoIcon = e.target.closest('.product-video-icon-wrapper');
    if (videoIcon) {
      e.preventDefault();
      e.stopPropagation();
      const productHandle = videoIcon.getAttribute('data-product-handle');
      const videoId = videoIcon.getAttribute('data-video-id');
      if (productHandle && videoId) openVideoModal(productHandle, videoId);
    }
  }, true);

  overlay?.addEventListener('click', e => {
    if (e.target === overlay) closeModal();
  });

  closeBtn?.addEventListener('click', closeModal);

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });
});
</script>

