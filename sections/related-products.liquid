{%- style -%}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px; }
  .you-may-also-like-collection .collection__title--desktop-slider .title { text-align: center; font-weight: 400; font-size: 28px; margin-bottom: 0 !important; }
  .you-may-also-like-collection h2.title.inline-richtext.h1 { text-align: center; font-size: 24px; margin-bottom: 0; }
  .you-may-also-like-collection .collection__description p { color: #535361; font-weight: 400; font-size: 18px; line-height: 2; text-align: center; vertical-align: middle; margin: 0 auto 30px !important; display: block; }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; }
  }
  @media  screen and  (max-width:440px){
      .you-may-also-like-collection h2.title.inline-richtext.h1, .pdp-match-shine-headers h2, h2.featured-in { text-align: center !important; font-size: 18px !important; margin-bottom: 0px !important; }
      .you-may-also-like-collection .collection__description p, .pdp-match-shine-headers p, .featured-in-parent .into-the-web {font-size: 14px !important;}

    }
{%- endstyle -%}

{%- liquid
  assign selected_collection = collections[section.settings.collection_new]
  assign current_product_tags = product.tags
  assign valid_tags = "Rings,Earrings,Necklaces,Bracelets,Pendants,Nosepins" | split: ","
  assign matched_tag = ""

  # Find first matched tag normalized
  for tag in current_product_tags
    assign cleaned_tag = tag | strip | downcase
    for valid_tag in valid_tags
      assign cleaned_valid_tag = valid_tag | strip | downcase
      if cleaned_tag == cleaned_valid_tag
        assign matched_tag = valid_tag
        break
      endif
    endfor
    if matched_tag != ""
      break
    endif
  endfor

  assign products_to_display = section.settings.products_to_show
  if products_to_display > 8
    assign products_to_display = 8
  endif

  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = true
  assign show_desktop_slider = section.settings.enable_desktop_slider
  assign use_slider = true

  assign filtered_products = "" | split: ""

  for related_product in selected_collection.products
    assign tag_match_found = false
    for tag in related_product.tags
      assign clean_tag = tag | strip | downcase
      assign clean_matched_tag = matched_tag | strip | downcase
      if clean_tag == clean_matched_tag
        assign tag_match_found = true
        break
      endif
    endfor
    if tag_match_found and related_product.id != product.id
      assign filtered_products = filtered_products | push: related_product
    endif
  endfor
-%}


{% if matched_tag != "Nosepins" %}
  <div class="color-{{ section.settings.color_scheme }} isolate gradient" style="content-visibility: auto; contain-intrinsic-size: 1000px;">
    <div
      class="collection you-may-also-like-collection{% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %} section-{{ section.id }}-padding{% if section.settings.full_width %}  collection--full-width{% endif %}"
      id="you-may-also-like-{{ section.id }}"
      data-id="{{ section.id }}"
    >

      <div class="collection__title title-wrapper title-wrapper--no-top-margin page-width{% if use_slider %} title-wrapper--self-padded-tablet-down{% endif %}{% if show_desktop_slider %} collection__title--desktop-slider{% endif %}">
        {%- if section.settings.header != blank -%}
          <h2 class="title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.header }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheader != blank -%}
          <div class="collection__description{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            <p>{{ section.settings.subheader }}</p>
          </div>
        {%- endif -%}
      </div>

      <div class="{% if section.settings.full_width %}slider-component-full-width{% endif %} page-width{% if use_slider == false %} page-width{% endif %}{% if show_desktop_slider == false and section.settings.full_width == false %} page-width-desktop{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        
        <slider-component class="slider-mobile-gutter">
          <ul
            id="Slider-{{ section.id }}"
            class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down slider slider--everywhere"
            role="list"
            aria-label="You may also like products"
          >
            {% assign skip_card_product_styles = false %}
            {% assign displayed_count = 0 %}
            
            {%- for related_product in selected_collection.products -%}
              {% assign tag_match_found = false %}
              {% for tag in related_product.tags %}
                {% assign clean_tag = tag | strip | downcase %}
                {% assign clean_matched_tag = matched_tag | strip | downcase %}
                  {% if clean_tag == clean_matched_tag %}
                    {% assign tag_match_found = true %}
                    {% break %}
                  {% endif %}
                {% endfor %}
              {% if tag_match_found and related_product.id != product.id and displayed_count < products_to_display %}
                <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="grid__item slider__slide{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                    {% if settings.animations_reveal_on_scroll %}
                      data-cascade
                      style="--animation-order: {{ displayed_count | plus: 1 }};"
                    {% endif %}>

                  {% render 'card-product',
                    card_product: related_product,
                    media_aspect_ratio: section.settings.image_ratio,
                    image_shape: section.settings.image_shape,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    skip_styles: skip_card_product_styles,
                    section_id: section.id,
                    quick_add: section.settings.quick_add
                  %}

                </li>

                {% assign skip_card_product_styles = true %}
                {% assign displayed_count = displayed_count | plus: 1 %}
              {% endif %}
            {%- endfor -%}

            {%- if displayed_count == 0 -%}
              {%- for i in (1..section.settings.columns_desktop) -%}
                <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="grid__item slider__slide{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                    {% if settings.animations_reveal_on_scroll %}
                      data-cascade
                      style="--animation-order: {{ forloop.index }};"
                    {% endif %}>

                  {% liquid
                    assign ridx = forloop.rindex
                    case ridx
                      when 5
                        assign ridx = 1
                      when 6
                        assign ridx = 2
                    endcase
                  %}
                  {%- assign placeholder_image = 'product-apparel-' | append: ridx -%}
                  {% render 'card-product',
                    show_vendor: section.settings.show_vendor,
                    media_aspect_ratio: section.settings.image_ratio,
                    image_shape: section.settings.image_shape,
                    placeholder_image: placeholder_image
                  %}

                </li>
              {%- endfor -%}
            {%- endif -%}
          </ul>

          <div class="slider-buttons no-js-hidden">
            <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
              <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
            </button>
            <div class="slider-counter caption">
              <span class="slider-counter--current">1</span>
              <span aria-hidden="true"> / </span>
              <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
              <span class="slider-counter--total">{{ displayed_count | default: section.settings.columns_desktop }}</span>
            </div>
            <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
              <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
            </button>
          </div>
        </slider-component>
      </div>

      {% if section.settings.image_shape == 'arch' %}
        {{ 'mask-arch.svg' | inline_asset_content }}
      {%- endif -%}
    </div>
  </div>
{% endif %}


