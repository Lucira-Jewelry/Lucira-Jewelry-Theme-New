{% comment %}<style type="text/css">
  .template-404 .title + * {
    margin-top: 1rem;
  }

  @media screen and (min-width: 750px) {
    .template-404 .title + * {
      margin-top: 2rem;
    }
  }
</style>

<div class="template-404 page-width page-margin center">
  <p>
    {{ 'templates.404.subtext' | t }}
  </p>
  <h1 class="title">
    {{ 'templates.404.title' | t }}
  </h1>
  <a href="{{ routes.all_products_collection_url }}" class="button">
    {{ 'general.continue_shopping' | t }}
  </a>
</div>
{% section '404_page' %}{% endcomment %}
<section class="custom-404-section">
  <div class="custom-404-wrapper">
    <div class="custom-404-code">
     
      {% if section.settings.ring_image != blank %}
        <img src="{{ section.settings.ring_image | img_url: 'master' }}" width="auto" height="auto" loading="lazy"title="Missing Gem" alt="Missing Gem" class="gem-ring" />
      {% else %}
        <span>0</span>
      {% endif %}
     
    </div>

    <h2 class="custom-404-heading">{{ section.settings.heading }}</h2>
    <p class="custom-404-subheading">{{ section.settings.subheading }}</p>

    <div class="custom-404-buttons">
      <a href="{{ section.settings.collection_link }}" class="custom-404-btn primary">{{ section.settings.collection_label }}</a>
      <a href="{{ section.settings.home_link }}" class="custom-404-btn secondary">{{ section.settings.home_label }}</a>
    </div>
  </div>
</section>

<style>
  .custom-404-wrapper {
    text-align: center;
    padding-bottom:50px;
    
  }
.custom-404-section{
   padding-top:30px;
}
  .custom-404-code {
    font-size: 100px;
    display: flex;
    justify-content: center;
    align-items: center;
    width:50%;
    margin:0 auto;
    gap: 10px;
  }

  .custom-404-code span {
    font-weight: bold;
  }

  .gem-ring {
    width: 70%;
    height: auto;
  }

  .custom-404-heading {
    font-size: 40px;
    margin-top: 20px;
    margin-bottom: 8px;
  }

  .custom-404-subheading {
    font-size: 20px;
    color: #666;
    margin-bottom: 30px;
    margin-top:0px;
  }

  /* .custom-404-buttons {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
  }

  .custom-404-btn {
    padding: 10px 20px;
    border: 1px solid #a87e6d;
    text-decoration: none;
    border-radius: 20px;
  }

  .custom-404-btn.primary {
    background: #a87e6d;
    color: #fff;
   
  }

  .custom-404-btn.secondary {
    background: transparent;
    color: #a87e6d;
     
  }*/

      .custom-404-buttons {
      display: flex;
      justify-content: center;
      gap: 15px;
      flex-wrap: wrap;
    }

    .custom-404-btn {
      padding: 10px 20px;
      border: 1px solid #a68380;
      text-decoration: none;
      border-radius: 20px;
      font-size: 16px;
        width:25%;
    }

    .custom-404-btn.primary {
      background: #a68380;
      color: #fff;
        
    }

    .custom-404-btn.secondary {
      background: transparent;
      color: #a68380;
    }

  @media(max-width:767px){ 
     .custom-404-btn.primary {
   
    width:90%;
    margin:0 auto;
  }

  .custom-404-btn.secondary {
     width:90%;
    margin:0 auto;
  }
    .custom-404-heading {
      font-size:40px;
    }
    .custom-404-subheading {
    font-size: 14px;
      margin-top:0px;
    }
     .custom-404-wrapper {
    padding-top:30px;
    
  }
    .gem-ring {
    width: 100%;
    height: auto;
  }

  }


  @media(max-width:428px){
    .custom-404-heading{
      font-size:20px;
      
    }
    .custom-404-subheading{
      font-size:14px;
      margin-top:0px;
    }
    .custom-404-btn{
      font-size:16px;
    }
  }
</style>

{% schema %}

{
  "name": "Custom 404 Page",
  "settings": [
    {
      "type": "image_picker",
      "id": "ring_image",
      "label": "404 Middle Image (Ring)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "LOOKS LIKE THE GEM IS MISSING…"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "But don’t worry, treasures waiting for you."
    },
    {
      "type": "url",
      "id": "collection_link",
      "label": "Browse Collection Button Link"
    },
    {
      "type": "text",
      "id": "collection_label",
      "label": "Browse Button Text",
      "default": "BROWSE OUR COLLECTIONS"
    },
    {
      "type": "url",
      "id": "home_link",
      "label": "Homepage Button Link"
    },
    {
      "type": "text",
      "id": "home_label",
      "label": "Home Button Text",
      "default": "GO TO HOMEPAGE"
    }
  ],
  "presets": [
    {
      "name": "Custom 404 Page",
      "category": "Custom"
    }
  ]
}
{% endschema %}
