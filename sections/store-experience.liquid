{{ 'component-slider.css' | asset_url | stylesheet_tag: preload: true }}

{%- style -%}
  /* ===== Skeleton Loading Styles ===== */
  .store-experience-skeleton {
    width: 100%;
    height: 400px;
    background: linear-gradient(
      90deg,
      #f0f0f0 25%,
      #f8f8f8 37%,
      #f0f0f0 63%
    );
    background-size: 400% 100%;
    animation: storeExpShimmer 1.4s ease infinite;
    border-radius: 8px;
  }

  @keyframes storeExpShimmer {
    0% { background-position: 100% 0; }
    100% { background-position: -100% 0; }
  }

  .store-experience-content {
    display: none;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .store-experience-content.loaded {
    opacity: 1;
  }

  /* ===== Original Banner Styles ===== */
  .store-experience-banner-swiper{width:100%;height:100%;position:relative; display: flex; flex-wrap: inherit; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; list-style: none; padding: 0; margin: 0;}
  .store-experience-banner-swiper .swiper-slide{display:flex;justify-content:center;align-items:center; width: 100%; flex-shrink: 0; scroll-snap-align: start; opacity: 1;}
  .store-experience-banner-slider-item{position:relative;width:100%;height:100%;display:block;overflow:hidden}
  .store-experience-banner-image{width:100%;height:100%;object-fit:cover;display:block;content-visibility:auto}
  .store-experience-banner-slider-content{position:absolute;left:0;right:0;bottom:0;display:flex;align-items:center;justify-content:center!important;padding:50px;pointer-events:none;text-align:center}
  .store-experience-banner-slider-content.mid-left{justify-content:flex-start}
  .store-experience-banner-slider-content.mid-center{justify-content:center;text-align:center}
  .store-experience-banner-slider-content.mid-right{justify-content:flex-end;text-align:right}
  .store-experience-banner-slider-content>div{max-width:60rem;pointer-events:all}
  .store-experience-banner-slider-content-header{font-size:28px;font-family:'Futura Std',sans-serif!important;font-weight:500;line-height:1.2;margin:0 0 2rem 0;color:#fff;text-shadow:2px 2px 4px rgba(0,0,0,.5)}
  .store-experience-banner-slider-content-subheader{font-size:20px;line-height:1.5;margin:0 0 2.5rem 0;color:#fff;text-shadow:1px 1px 3px rgba(0,0,0,.5)}
  .store-experience-banner-slider-content-button{background:#fff;text-transform:uppercase;font-size:14px;font-weight:500;letter-spacing:1px;padding:1.2rem 3.5rem;border-radius:8px;border:none;cursor:pointer;color:#000;transition:all .3s ease;box-shadow:0 2px 8px rgba(0,0,0,.2);font-family:'Futura Std',sans-serif}
  .store-experience-banner-slider-content-button:hover{background:#8f6d6a;color:#fff;transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.3)}
  
  .store-experience-banner .slider-buttons { position: absolute; bottom: 20px; width: 100%; display: flex; justify-content: center; align-items: center; z-index: 2; }
  .store-experience-banner .slider-button { color:#ffffff;height:32px;width:32px;background:#00000042;border-radius:50%; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; margin: 0 10px; }
  .store-experience-banner .slider-counter--dots .dot { width: 4px; height: 4px; border-radius: 50%; background: #fff; display: block; margin: 0 4px; }
  .store-experience-banner .slider-counter__link--active .dot { background: #fff; width: 14px; border-radius: 3rem; }

  .store-experience-banner-slider-content-header {font-weight: 500; text-transform: uppercase; font-size: 24px;}
  
  @media (max-width:767px){
    .store-experience-banner .slider-buttons{display:none}
    .store-experience-banner-slider-content{padding:5rem 2rem}
    .store-experience-banner-slider-content-header{font-size:20px;margin-bottom:1rem}
    .store-experience-banner-slider-content-subheader{font-size:16px;margin-bottom:2rem}
    .store-experience-banner-slider-content-button{padding:1rem 2.5rem;font-size:13px}
    .store-experience-banner-slider-content-header { font-size: 20px; margin-bottom: 20px; }
  }
  @media (max-width:480px){
    .store-experience-banner-slider-content{padding:3rem 1.5rem}
    .store-experience-banner-slider-content-header{font-size:20px}
    .store-experience-banner-slider-content-subheader{font-size:14px}
  }
{%- endstyle -%}

<section 
  class="store-experience-banner {{ section.settings.banner_height }} {{ section.settings.banner_height_mobile }}"
  data-store-exp-lazy
>
  <!-- ===== SKELETON LOADER ===== -->
  <div class="store-experience-skeleton"></div>

  <!-- ===== ACTUAL CONTENT ===== -->
  <div class="store-experience-content">
    <slideshow-component class="slider-mobile-gutter" role="region" aria-label="Store Experience Banner">
      <ul
        id="Slider-{{ section.id }}"
        class="store-experience-banner-swiper grid grid--1-col slider slider--everywhere"
        data-autoplay="{{ section.settings.autoplay }}"
        data-speed="5"
      >
        {% for block in section.blocks %}
          <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="swiper-slide grid__item slider__slide">
            <a
              id="{{ block.settings.slide_id }}"
              href="{{ block.settings.slide_url }}"
              data-promo-id="{{ block.settings.dlv_promo_id }}"
              data-promo-name="{{ block.settings.dlv_promo_name }}"
              onclick="handleStoreExpGTMClick(event)"
              aria-label="Explore store experience"
              class="store-experience-banner-slider-item"
            >
              <picture>
                {% if block.settings.mobile_slide_image %}
                  <source 
                    media="(max-width: 749px)"
                    srcset="{{ block.settings.mobile_slide_image | img_url: '750x1000', crop: 'center' }} 750w,
                            {{ block.settings.mobile_slide_image | img_url: '375x500', crop: 'center' }} 375w"
                    sizes="100vw"
                  >
                {% endif %}
                {% if block.settings.slide_image %}
                  <source 
                    srcset="{{ block.settings.slide_image | img_url: '1920x823', crop: 'center' }} 1920w,
                            {{ block.settings.slide_image | img_url: '960x400', crop: 'center' }} 960w"
                    sizes="100vw"
                  >
                {% endif %}
                <img 
                  class="store-experience-banner-image"
                  src="{{ block.settings.slide_image | img_url: '1920x823', crop: 'center' }}"
                  width="1920"
                  height="800"
                  alt="{{ block.settings.slide_image.alt | escape }}"
                  title="{{ block.settings.slide_image.alt | escape }}"
                  loading="lazy"
                  decoding="async"
                  {% if forloop.first %}fetchpriority="high"{% endif %}
                >
              </picture>

              <div class="store-experience-banner-slider-content {{ section.settings.content_position }}">
                <div>
                  {% if block.settings.slide_header != blank %}
                    <p class="store-experience-banner-slider-content-header">{{ block.settings.slide_header }}</p>
                  {% endif %}
                  {% if block.settings.slide_subheader != blank %}
                    <p class="store-experience-banner-slider-content-subheader">{{ block.settings.slide_subheader }}</p>
                  {% endif %}
                  {% if block.settings.show_button and block.settings.slide_button_text != blank %}
                    <button class="store-experience-banner-slider-content-button">
                      {{ block.settings.slide_button_text }}
                    </button>
                  {% endif %}
                </div>
              </div>
            </a>
          </li>
        {% endfor %}
      </ul>

      {%- if section.blocks.size > 1 -%}
        <div class="slider-buttons no-js-hidden">
          <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="Previous slide">
            {{ 'icon-left-arrow-banner.svg' | inline_asset_content }}
          </button>
          <div class="slider-counter slider-counter--dots">
            <div class="slideshow__control-wrapper">
              {%- for block in section.blocks -%}
                <button class="slider-counter__link slider-counter__link--dots link" aria-label="Load slide {{ forloop.index }} of {{ forloop.length }}" aria-controls="Slider-{{ section.id }}">
                  <span class="dot"></span>
                </button>
              {%- endfor -%}
            </div>
          </div>
          <button type="button" class="slider-button slider-button--next" name="next" aria-label="Next slide">
            {{ 'icon-right-arrow-banner.svg' | inline_asset_content }}
          </button>
        </div>
      {%- endif -%}
    </slideshow-component>
  </div>
</section>

<script>
  window.addEventListener('DOMContentLoaded', () => {
    if (window.initStoreExpSkeleton) window.initStoreExpSkeleton();

    const slideshow = document.querySelector('[data-store-exp-lazy] slideshow-component');
    if (slideshow) {
      slideshow.addEventListener('slideChanged', (event) => {
        const slide = event.detail.currentElement;
        const target = slide?.querySelector("a");
        if (target && target.dataset.promoId) {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: "promoView",
            promoView: {
              promo_id: target.dataset.promoId,
              promo_name: target.dataset.promoName,
              creative_name: "store_experience_banner",
              promo_position: "Home Page"
            }
          });
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Store Experience Banner",
  "settings": [
    {
      "type": "select",
      "id": "banner_height",
      "label": "Banner Height",
      "options": [
        { "value": "banner--small", "label": "Small" },
        { "value": "banner--medium", "label": "Medium" },
        { "value": "banner--large", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "banner_height_mobile",
      "label": "Banner Height (Mobile)",
      "options": [
        { "value": "banner--small", "label": "Small" },
        { "value": "banner--medium-mobile", "label": "Medium" },
        { "value": "banner--large-mobile", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content Position",
      "options": [
        { "value": "mid-left", "label": "Middle Left" },
        { "value": "mid-center", "label": "Middle Center" },
        { "value": "mid-right", "label": "Middle Right" }
      ]
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "AutoPlay",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "experience_slide",
      "name": "Experience Slide",
      "settings": [
        { "type": "text", "id": "slide_id", "label": "Slide ID" },
        { "type": "text", "id": "dlv_promo_id", "label": "DLV Promo ID" },
        { "type": "text", "id": "dlv_promo_name", "label": "DLV Promo Name" },
        { 
          "type": "image_picker", 
          "id": "slide_image", 
          "label": "Desktop Image",
          "info": "Recommended size: 1920x800px"
        },
        { 
          "type": "image_picker", 
          "id": "mobile_slide_image", 
          "label": "Mobile Image",
          "info": "Recommended size: 750x1000px"
        },
        { "type": "url", "id": "slide_url", "label": "Slide URL" },
        { "type": "text", "id": "slide_header", "label": "Header Text" },
        { "type": "text", "id": "slide_subheader", "label": "Subheader Text" },
        { "type": "text", "id": "slide_button_text", "label": "Button Text" },
        { "type": "checkbox", "id": "show_button", "label": "Show Button" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Experience Banner",
      "category": "Image"
    }
  ],
  "max_blocks": 5
}
{% endschema %}
