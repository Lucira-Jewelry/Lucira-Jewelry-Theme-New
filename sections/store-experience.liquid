<section class="custom-slider-section">
  <div class="custom-slider-wrapper slider-enabled">
    {% for block in section.blocks %}
      <div class="custom-slide">
        <img
          class="exp_deskimage"
          src="{{ block.settings.image | img_url: 'master' }}"
          width="1920"
          height="1000"
          loading="lazy"
          alt="Slide Image"
          title="Slide Image"
        >
        <img
          class="exp_mobimage"
          src="{{ block.settings.exp_mobimage | img_url: 'master' }}"
          width="642"
          height="803"
          loading="lazy"
          alt="Slide Image"
          title="Slide Image"
        >
      </div>
    {% endfor %}
  </div>

  <div class="fixed-overlay-text">
    <div class="overlay-text-content">
      <h2>{{ section.settings.experience_heading }}</h2>
      <p>{{ section.settings.experience_subtext }}</p>
      {% if section.settings.button_type == 'find_store' %}
        <a href="/pages/stores" class="btn btn-primary">
          <div>
            <svg xmlns="http://www.w3.org/2000/svg" width="25" height="24" viewBox="0 0 25 24" fill="none">
              <path d="M2.5 12H5.5" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M19.5 12H22.5" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12.5 2V5" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12.5 19V22" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12.5 19C16.366 19 19.5 15.866 19.5 12C19.5 8.13401 16.366 5 12.5 5C8.63401 5 5.5 8.13401 5.5 12C5.5 15.866 8.63401 19 12.5 19Z" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12.5 15C14.1569 15 15.5 13.6569 15.5 12C15.5 10.3431 14.1569 9 12.5 9C10.8431 9 9.5 10.3431 9.5 12C9.5 13.6569 10.8431 15 12.5 15Z" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span> Find a Store </span>
        </a>
      {% else %}
        <a href="{{ section.settings.store_location }}" target="_blank" class="btn btn-secondary">
          <div>
            <svg xmlns="http://www.w3.org/2000/svg" width="25" height="24" viewBox="0 0 25 24" fill="none">
              <path d="M3.5 11L22.5 2L13.5 21L11.5 13L3.5 11Z" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span> Locate Us </span>
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Store Experience",
  "settings": [
    {
      "type": "text",
      "id": "experience_heading",
      "label": "Heading",
      "default": "Our First Experience Store Near You"
    },
    {
      "type": "textarea",
      "id": "experience_subtext",
      "label": "Subtext",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit..."
    },
    {
      "type": "select",
      "id": "button_type",
      "label": "Button Type",
      "options": [
        { "value": "find_store", "label": "Find a Store" },
        { "value": "direct_me", "label": "Locate Us" }
      ],
      "default": "find_store"
    },
    {
      "type": "text",
      "id": "store_location",
      "label": "Store Location (for Direct Me button)",
      "default": "New York, USA"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "image_picker",
          "id": "exp_mobimage",
          "label": "Slide mobile Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Experience"
    }
  ]
}
{% endschema %}

<style>
  .custom-slider-section {
  position: relative;
  padding: 30px 0;
  content-visibility: auto;
  contain-intrinsic-size: 500px auto;
  {% comment %} transform: translateY(30px);
  opacity: 0;
  transition: opacity 0.6s ease, transform 0.6s ease; {% endcomment %}
}

/* Reveal when visible */
{% comment %} .custom-slider-section.visible {
  opacity: 1;
  transform: translateY(0);
} {% endcomment %}
  .custom-slider-section{position:relative;padding:30px 0}
  .fixed-overlay-text a.btn.btn-secondary{display:flex;border-radius:12px;justify-content:center;align-items:center;margin:0 auto;gap:10px;width:max-content;padding:12px 34px}
  .custom-slider-wrapper img{width:100%;display:block;height:100%;object-fit:cover;object-position:bottom}
  .fixed-overlay-text a.btn svg{display:inline-block;vertical-align:middle}
  .fixed-overlay-text{position:absolute;bottom:70px;left:50%;transform:translateX(-50%);display:flex;align-items:center;justify-content:center;gap:20px;z-index:2;width:auto}
  .fixed-overlay-text a.btn.btn-primary{display:flex;gap:10px;border-radius:12px;width:35%;margin:0 auto;justify-content:center;align-items:center}
  .fixed-overlay-text button{color:#fff;border:none;font-size:24px;width:40px;height:40px;border-radius:50%;cursor:pointer}
  .overlay-text-content{text-align:center;color:#fff;max-width:600px}
  .overlay-text-content h2{font-size:24px;color:#fff;margin-bottom:22px;text-transform:uppercase}
  .overlay-text-content p{font-size:18px;margin-bottom:32px;margin-top:0}
  .fixed-overlay-text .slick-prev{left:-20%}
  .fixed-overlay-text .slick-next{right:-20%}
  .fixed-overlay-text .slick-prev:before{content:unset}
  .fixed-overlay-text .slick-next:before{content:unset}
  .overlay-text-content a.btn{text-decoration:none;padding:10px 20px;background:#fff;color:#000;border-radius:5px}
  .exp_deskimage{display:block!important}
  .exp_mobimage{display:none!important}
  @media (max-width:767px){
  .exp_deskimage{display:none!important}
  .exp_mobimage{display:block!important}
  .overlay-text-content h2{font-size:16px;margin-bottom:16px}
  .overlay-text-content p{font-size:12px;line-height:16px;margin-bottom:20px}
  .overlay-text-content a.btn{padding:5px}
  .fixed-overlay-text a.btn.btn-secondary{width:100%}
  .fixed-overlay-text a.btn.btn-primary{width:100%}
  .fixed-overlay-text{bottom:32px;width:80%}
  .fixed-overlay-text .slick-next svg{width:12px;height:30px}
  .fixed-overlay-text .slick-prev svg{width:12px;height:30px}
  .custom-slider-wrapper img{height:100%}
  .fixed-overlay-text a.btn.btn-secondary {display: flex ; border-radius: 12px; justify-content: center; align-items: center; margin: 0 auto; gap: 10px; font-size: 14px; width: max-content !important; padding: 8px 28px !important; }
  .custom-slider-section  {padding:30px 0 0;}
  .custom-slide {width: 100%;}
}
</style>
<script>
document.addEventListener("DOMContentLoaded", function () {
  // Lazy reveal observer
  const sliderSection = document.querySelector('.custom-slider-section');
  if (sliderSection) {
    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    observer.observe(sliderSection);
  }

  // Optional: GTM click tracking for overlay buttons
  document.querySelectorAll('.overlay-text-content a.btn').forEach((btn, index) => {
    btn.addEventListener('click', function() {
      const btnText = this.textContent.trim() || 'Store Experience Button';
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'promoClick',
        promoClick: {
          promo_id: `store-experience-${index+1}`,
          promo_name: btnText,
          creative_name: 'Store Experience Overlay Button'
        }
      });
    });
  });
});
</script>