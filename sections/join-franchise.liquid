    },
    {
      "type": "range",
      "id": "button_font_size_mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Button font size (mobile)",
      "default": 12
    },
    {
      "type": "select",
      "id": "button_weight",
