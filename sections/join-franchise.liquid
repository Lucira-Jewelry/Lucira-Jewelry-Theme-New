      "min": 300,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Subheading max width",
      "default": 600
    },
    {
      "type": "range",
      "id": "subheading_spacing",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Space below subheading",
      "default": 30
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
