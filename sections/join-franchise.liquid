<style>
  .franchise-banner-{{ section.id }} {
    position: relative;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
    overflow: hidden;
    margin:60px;
    border-radius:12px;
    height: 500px;
  }

  .franchise-banner-{{ section.id }} .franchise-container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: {{ section.settings.content_alignment }};
    position: relative;
    z-index: 2;
  }

  .franchise-banner-{{ section.id }} .franchise-background-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit }};
    opacity: {{ section.settings.image_opacity }};
    z-index: 1;
  }

  .franchise-banner-{{ section.id }} .franchise-background-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity }};
    z-index: 1;
  }

  .franchise-banner-{{ section.id }} .franchise-content {
    position: relative;
    z-index: 2;
    top:70px;
  }

  .franchise-banner-{{ section.id }} .franchise-heading {
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
    font-weight: {{ section.settings.heading_weight }};
    text-transform: {{ section.settings.heading_transform }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    line-height: {{ section.settings.heading_line_height }};
    margin: 0 0 {{ section.settings.heading_spacing }}px 0;
    {% if section.settings.heading_shadow %}
      text-shadow: {{ section.settings.heading_shadow_x }}px {{ section.settings.heading_shadow_y }}px {{ section.settings.heading_shadow_blur }}px rgba(0,0,0,{{ section.settings.heading_shadow_opacity }});
    {% endif %}
  }

  .franchise-banner-{{ section.id }} .franchise-subheading {
    font-size: {{ section.settings.subheading_size }}px;
    color: {{ section.settings.subheading_color }};
    font-weight: {{ section.settings.subheading_weight }};
    letter-spacing: {{ section.settings.subheading_letter_spacing }}px;
    line-height: {{ section.settings.subheading_line_height }};
    margin: 0 0 {{ section.settings.subheading_spacing }}px 0;
    max-width: {{ section.settings.subheading_max_width }}px;
    {% if section.settings.content_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% elsif section.settings.content_alignment == 'right' %}
      margin-left: auto;
    {% endif %}
  }

  .franchise-banner-{{ section.id }} .franchise-button {
    display: inline-block;
    padding: {{ section.settings.button_padding_v }}px {{ section.settings.button_padding_h }}px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: {{ section.settings.button_weight }};
    color: {{ section.settings.button_text_color }};
    background: {{ section.settings.button_background }};
    border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
    border-radius: {{ section.settings.button_border_radius }}px;
    text-decoration: none;
    text-transform: {{ section.settings.button_transform }};
    letter-spacing: {{ section.settings.button_letter_spacing }}px;
    transition: all {{ section.settings.button_transition }}s ease;
    cursor: pointer;
    font-family:'Futura Std';
  }

  .franchise-banner-{{ section.id }} .franchise-button:hover {
    color: {{ section.settings.button_hover_text_color }};
    background: {{ section.settings.button_hover_background }};
    border-color: {{ section.settings.button_hover_border_color }};
    transform: translateY({{ section.settings.button_hover_lift }}px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .franchise-banner-{{ section.id }} {
      {% comment %} padding: {{ section.settings.padding_top_mobile }}px 0 {{ section.settings.padding_bottom_mobile }}px; {% endcomment %}
      margin:20px;
      height:485px;
    }

    .franchise-banner-{{ section.id }} .franchise-heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }

    .franchise-banner-{{ section.id }} .franchise-subheading {
      font-size: {{ section.settings.subheading_size_mobile }}px;
    }

    .franchise-banner-{{ section.id }} .franchise-button {
      font-size: {{ section.settings.button_font_size_mobile }}px;
      padding: {{ section.settings.button_padding_v_mobile }}px {{ section.settings.button_padding_h_mobile }}px;
    }
  }
</style>

<div class="franchise-banner-{{ section.id }}">
  {% if section.settings.background_image %}
    <img 
      class="franchise-background-image"
      src="{{ section.settings.background_image | img_url: '1920x' }}"
      alt="{{ section.settings.background_image.alt | escape }}"
      loading="lazy"
    >
  {% endif %}

  {% if section.settings.show_overlay %}
    <div class="franchise-background-overlay"></div>
  {% endif %}

  <div class="franchise-container">
   
    <div class="franchise-content">
      {% if section.settings.show_heading and section.settings.heading_text != blank %}
        <h1 class="franchise-heading">{{ section.settings.heading_text }}</h1>
      {% endif %}

      {% if section.settings.show_subheading and section.settings.subheading_text != blank %}
        <p class="franchise-subheading">{{ section.settings.subheading_text }}</p>
      {% endif %}

      {% if section.settings.show_button and section.settings.button_text != blank %}
        <button 
          href="{{ section.settings.button_link }}" 
          class="franchise-button"  onclick="openFranchiseOverlay()"
        >
          {{ section.settings.button_text }}
        </button>
      {% endif %}
    </div>
    </div>

</div>

{% schema %}
{
  "name": "Franchise Page Banner",
  "settings": [
    {
      "type": "header",
      "content": "Background"
