<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('franchise_contact_form');
    const submitBtn = document.getElementById('franchiseSubmitBtn');
    const successMsg = document.getElementById('ff-success-msg');
    const errorMsg = document.getElementById('ff-error-msg');
    const phoneInput = document.getElementById('franchise-phone');
    const nameInput = document.getElementById('franchise-name');
    const emailInput = document.getElementById('franchise-email');
    const cityInput = document.getElementById('franchise-city');
    const phoneError = document.getElementById('franchise_phoneError');

    // Real-time validation function
    function validateInputs() {
      const phoneValid = /^\d{10}$/.test(phoneInput.value.trim());
      const nameValid = nameInput.value.trim().length > 0;
      const emailValid = emailInput.value.trim().length > 0 && emailInput.validity.valid;
      const cityValid = cityInput.value.trim().length > 0;
      
      submitBtn.disabled = !(phoneValid && nameValid && emailValid && cityValid);
      
      // Show/hide phone error
      phoneError.style.display = (phoneInput.value.trim() && !phoneValid) ? 'block' : 'none';
    }

    // Add event listeners for real-time validation
    phoneInput.addEventListener('input', validateInputs);
    nameInput.addEventListener('input', validateInputs);
    emailInput.addEventListener('input', validateInputs);
    cityInput.addEventListener('input', validateInputs);

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      // Hide previous messages
      successMsg.style.display = 'none';
      errorMsg.style.display = 'none';
      
      // Get form data
      const name = nameInput.value.trim();
      const phone = phoneInput.value.trim();
      const email = emailInput.value.trim();
      const city = cityInput.value.trim();
      
      // Validate phone number (10 digits)
      const phoneValid = /^\d{10}$/.test(phone);
      if (!phoneValid) {
        phoneError.style.display = 'block';
        return;
      }
      
      // Disable submit button and show loading
      submitBtn.disabled = true;
      submitBtn.textContent = 'SUBMITTING...';
      submitBtn.style.opacity = '0.6';
      
      // Prepare payload for GCP API (same structure as your overlay form)
      const payload = {
        name: name,
        phone: phone,
        email: email,
        city: city,
        formType: 'franchise_registration',
        pageUrl: window.location.href,
        timestamp: new Date().toISOString()
      };
      
      console.log('Sending payload:', payload);
      
      // Submit to GCP API
      fetch('https://franchise-api-385594025448.asia-south1.run.app/', {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(payload)
      })
      .then(function(response) {
        console.log('Response status:', response.status);
        
        if (!response.ok) {
          throw new Error('Submission failed with status: ' + response.status);
        }
        return response.json();
      })
      .then(function(data) {
        console.log('Success response:', data);
        
        // Track event in dataLayer (same as your GCP script)
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'promoClick',
          franchiseRegistrationSubmit: {
            formName: 'Franchise Registration Form submit',
            creative_name: "Franchise-Registration-Form-submit",
            franchiseData: payload,
            submissionTimestamp: new Date().toISOString()
          }
        });
        
        // Success - show success message
        successMsg.style.display = 'flex';
        form.reset();
        submitBtn.disabled = true;
        submitBtn.textContent = 'SUBMIT';
        submitBtn.style.opacity = '1';
        
        // Scroll to success message
        successMsg.scrollIntoView({ 
          behavior: 'smooth', 
          block: 'center' 
        });
      })
      .catch(function(error) {
        console.error('Form submission error:', error);
        
        // Error - show error message
        errorMsg.style.display = 'flex';
        submitBtn.disabled = false;
        submitBtn.textContent = 'SUBMIT';
        submitBtn.style.opacity = '1';
      });
    });

    // Initial validation
    validateInputs();
  });
</script>

