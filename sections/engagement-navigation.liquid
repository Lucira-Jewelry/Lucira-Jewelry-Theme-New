{% comment %} Metaobjects logic - FIXED VERSION {% endcomment %}
{% assign current_path = canonical_url | split: shop.url | last %}
{% assign path_segments = current_path | split: '/' %}
{% assign current_slug = path_segments.last %}

{% comment %} Determine main tab slug {% endcomment %}
{% if path_segments.size >= 3 %}
  {% assign main_tab_slug = path_segments[2] %}
{% elsif path_segments.size == 2 %}
  {% assign main_tab_slug = path_segments[1] %}
{% else %}
  {% assign main_tab_slug = 'engagement' %}
{% endif %}

