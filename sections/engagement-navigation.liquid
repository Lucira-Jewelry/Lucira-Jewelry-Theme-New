{% comment %}
  SHOPIFY LIQUID TEMPLATE - Nested Information Page
  
  File location: sections/nested-info-page.liquid
  
  This section fetches data from Shopify metaobjects and renders
  the nested information page with two levels of tabs.
  
  Setup required:
  1. Create metaobject definitions (see SHOPIFY_METAOBJECT_SCHEMA.md)
  2. Add this file to your theme's sections folder
  3. Add to a page template or use in theme editor
{% endcomment %}

{% comment %} ==================== FETCH DATA FROM METAOBJECTS ==================== {% endcomment %}

{% comment %} Get all active primary tabs, sorted by order {% endcomment %}
{% assign primary_tabs = shop.metaobjects.primary_tab.values 
  | where: "is_active", true 
  | sort: "tab_order" %}

{% comment %} Set initial active tabs {% endcomment %}
{% assign initial_primary = primary_tabs.first %}

{% comment %} ==================== SECTION SETTINGS ==================== {% endcomment %}

<div class="nested-info-page" data-section-id="{{ section.id }}">
  
  {% comment %} ==================== HEADER ==================== {% endcomment %}
  
  {% comment %} <header class="nested-info-header">
    <div class="container">
      <div class="header-wrapper">
        <h1 class="site-logo">
          <a href="/">{{ shop.name }}</a>
        </h1>
        
        <div class="header-search">
          <form action="/search" method="get">
            <input 
              type="search" 
              name="q" 
              placeholder="Search for a product"
              class="search-input"
            >
          </form>
        </div>
        
        <nav class="header-nav">
          <a href="/pages/favorites">Favorites</a>
          <a href="/pages/how-it-works">How It Works</a>
          <a href="/account">Login</a>
        </nav>
      </div>
    </div>
  </header> {% endcomment %}

  {% comment %} ==================== PRIMARY NAVIGATION ==================== {% endcomment %}
  
  <nav class="primary-nav">
    <div class="container">
      <div class="primary-nav-wrapper">
        {% for primary_tab in primary_tabs %}
          <button 
            class="primary-nav-item{% if forloop.first %} active{% endif %}"
            data-primary-tab="{{ primary_tab.tab_key.value }}"
            data-tab-index="{{ forloop.index0 }}"
          >
            {{ primary_tab.display_label.value }}
          </button>
        {% endfor %}
        <a href="/collections/all" class="browse-btn">Browse</a>
      </div>
    </div>
  </nav>

  {% comment %} ==================== BANNER + SECONDARY NAV + CONTENT ==================== {% endcomment %}
  
  {% for primary_tab in primary_tabs %}
    <div 
      class="tab-content{% if forloop.first %} active{% endif %}"
      data-primary-content="{{ primary_tab.tab_key.value }}"
    >
      
      {% comment %} Banner {% endcomment %}
      <div class="banner-section" 
        {% if primary_tab.banner_image.value %}
          style="background-image: url('{{ primary_tab.banner_image.value | image_url: width: 1600 }}');"
        {% endif %}
      >
        <div class="banner-overlay">
          <h2 class="banner-title">{{ primary_tab.banner_title.value }}</h2>
          {% if primary_tab.banner_subtitle.value != blank %}
            <p class="banner-subtitle">{{ primary_tab.banner_subtitle.value }}</p>
          {% endif %}
        </div>
      </div>

      {% comment %} Secondary Navigation {% endcomment %}
      {% assign secondary_tabs = primary_tab.secondary_tabs.value 
        | where: "is_active", true 
        | sort: "tab_order" %}
      
      <nav class="secondary-nav">
        <div class="container">
          <div class="secondary-nav-wrapper">
            {% for secondary_tab in secondary_tabs %}
              <button 
                class="secondary-nav-item{% if forloop.first %} active{% endif %}"
                data-secondary-tab="{{ secondary_tab.tab_key.value }}"
                data-parent="{{ primary_tab.tab_key.value }}"
                data-tab-index="{{ forloop.index0 }}"
              >
                {{ secondary_tab.display_label.value }}
              </button>
            {% endfor %}
          </div>
        </div>
      </nav>

      {% comment %} Content Sections {% endcomment %}
      {% for secondary_tab in secondary_tabs %}
        <section 
          class="content-section{% if forloop.first %} active{% endif %}"
          data-secondary-content="{{ secondary_tab.tab_key.value }}"
          data-parent="{{ primary_tab.tab_key.value }}"
        >
          <div class="container">
            <div class="content-grid">
              
              {% comment %} Left: Product Image + CTA {% endcomment %}
              <div class="product-wrapper">
                {% if secondary_tab.product_image.value %}
                  <img 
                    src="{{ secondary_tab.product_image.value | image_url: width: 800 }}"
                    srcset="{{ secondary_tab.product_image.value | image_url: width: 400 }} 400w,
                            {{ secondary_tab.product_image.value | image_url: width: 800 }} 800w"
                    sizes="(max-width: 768px) 100vw, 400px"
                    alt="{{ secondary_tab.content_title.value }}"
                    class="product-image"
                    loading="lazy"
                  >
                {% endif %}
                
                {% if secondary_tab.cta_text.value and secondary_tab.cta_link.value %}
                  <a 
                    href="{{ secondary_tab.cta_link.value }}" 
                    class="cta-button"
                  >
                    {{ secondary_tab.cta_text.value }}
                  </a>
                {% endif %}
              </div>

              {% comment %} Right: Content Info {% endcomment %}
              <div class="content-info">
                <h2 class="content-title">{{ secondary_tab.content_title.value }}</h2>
                
                {% if secondary_tab.content_description.value %}
                  <div class="content-description rte">
                    {{ secondary_tab.content_description.value }}
                  </div>
                {% endif %}

                {% comment %} Related Topics {% endcomment %}
                {% if secondary_tab.related_topics.value.size > 0 %}
                  <div class="related-topics">
                    <h3 class="related-topics-title">RELATED TOPICS</h3>
                    <ul class="related-topics-list">
                      {% assign topics = secondary_tab.related_topics.value | sort: "topic_order" %}
                      {% for topic in topics %}
                        <li class="related-topic-item">
                          <a 
                            href="{{ topic.topic_link.value }}" 
                            class="related-topic-link"
                          >
                            {{ topic.topic_text.value }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              </div>

            </div>
          </div>
        </section>
      {% endfor %}

    </div>
  {% endfor %}

</div>

{% comment %} ==================== JAVASCRIPT ==================== {% endcomment %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  const nestedInfoPage = document.querySelector('.nested-info-page');
  if (!nestedInfoPage) return;

  // ========== PRIMARY TAB SWITCHING ==========
  const primaryNavItems = nestedInfoPage.querySelectorAll('.primary-nav-item');
  
  primaryNavItems.forEach(item => {
    item.addEventListener('click', function() {
      const targetTab = this.dataset.primaryTab;
      
      // Update active primary nav
      primaryNavItems.forEach(nav => nav.classList.remove('active'));
      this.classList.add('active');
      
      // Show corresponding content
      const allPrimaryContent = nestedInfoPage.querySelectorAll('[data-primary-content]');
      allPrimaryContent.forEach(content => {
        if (content.dataset.primaryContent === targetTab) {
          content.classList.add('active');
          
          // Activate first secondary tab
          const firstSecondaryNav = content.querySelector('.secondary-nav-item');
          const firstSecondaryContent = content.querySelector('.content-section');
          
          if (firstSecondaryNav) {
            // Reset all secondary navs in this primary tab
            content.querySelectorAll('.secondary-nav-item').forEach(nav => 
              nav.classList.remove('active')
            );
            firstSecondaryNav.classList.add('active');
          }
          
          if (firstSecondaryContent) {
            // Reset all secondary contents in this primary tab
            content.querySelectorAll('.content-section').forEach(section => 
              section.classList.remove('active')
            );
            firstSecondaryContent.classList.add('active');
          }
        } else {
          content.classList.remove('active');
        }
      });
      
      // Scroll to top of content
      const banner = this.closest('.nested-info-page').querySelector('.banner-section');
      if (banner) {
        banner.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });

  // ========== SECONDARY TAB SWITCHING ==========
  const secondaryNavItems = nestedInfoPage.querySelectorAll('.secondary-nav-item');
  
  secondaryNavItems.forEach(item => {
    item.addEventListener('click', function() {
      const targetTab = this.dataset.secondaryTab;
      const parentTab = this.dataset.parent;
      
      // Update active secondary nav (only within same parent)
      const siblingNavs = nestedInfoPage.querySelectorAll(
        `.secondary-nav-item[data-parent="${parentTab}"]`
      );
      siblingNavs.forEach(nav => nav.classList.remove('active'));
      this.classList.add('active');
      
      // Show corresponding content
      const allSecondaryContent = nestedInfoPage.querySelectorAll(
        `.content-section[data-parent="${parentTab}"]`
      );
      allSecondaryContent.forEach(content => {
        if (content.dataset.secondaryContent === targetTab) {
          content.classList.add('active');
        } else {
          content.classList.remove('active');
        }
      });
      
      // Smooth scroll to content
      const activeContent = nestedInfoPage.querySelector(
        `.content-section[data-secondary-content="${targetTab}"][data-parent="${parentTab}"]`
      );
      if (activeContent) {
        activeContent.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // ========== KEYBOARD NAVIGATION ==========
  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
      const activeNav = document.activeElement;
      
      if (activeNav.classList.contains('primary-nav-item')) {
        const allNavs = Array.from(primaryNavItems);
        const currentIndex = allNavs.indexOf(activeNav);
        
        if (e.key === 'ArrowRight' && currentIndex < allNavs.length - 1) {
          allNavs[currentIndex + 1].focus();
          allNavs[currentIndex + 1].click();
        } else if (e.key === 'ArrowLeft' && currentIndex > 0) {
          allNavs[currentIndex - 1].focus();
          allNavs[currentIndex - 1].click();
        }
      }
    }
  });
});
</script>

{% comment %} ==================== STYLES ==================== {% endcomment %}

<style>
/* ========== RESET & BASE ========== */
.nested-info-page * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.nested-info-page {
  font-family: var(--font-body-family, 'Georgia', serif);
  color: #2c2c2c;
  background: #fafafa;
}

.container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 2rem;
}

/* ========== HEADER ========== */
.nested-info-header {
  background: #1a1a1a;
  color: #fff;
  padding: 1rem 0;
  position: sticky;
  top: 0;
  z-index: 1000;
}

.header-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}

.site-logo {
  font-size: 1.8rem;
  font-weight: 300;
  letter-spacing: 2px;
  margin: 0;
}

.site-logo a {
  color: #fff;
  text-decoration: none;
}

.header-search {
  flex: 1;
  max-width: 400px;
}

.search-input {
  width: 100%;
  padding: 0.6rem 1rem;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 4px;
  font-size: 0.9rem;
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.header-nav {
  display: flex;
  gap: 2rem;
}

.header-nav a {
  color: #fff;
  text-decoration: none;
  font-size: 0.9rem;
  letter-spacing: 1px;
  transition: opacity 0.3s;
}

.header-nav a:hover {
  opacity: 0.7;
}

/* ========== PRIMARY NAVIGATION ========== */
.primary-nav {
  background: #fff;
  border-bottom: 1px solid #e0e0e0;
  position: sticky;
  top: 60px;
  z-index: 999;
}

.primary-nav-wrapper {
  display: flex;
  gap: 3rem;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.primary-nav-wrapper::-webkit-scrollbar {
  display: none;
}

.primary-nav-item {
  background: none;
  border: none;
  padding: 1.2rem 0;
  font-size: 0.85rem;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #666;
  cursor: pointer;
  position: relative;
  white-space: nowrap;
  transition: color 0.3s;
  font-family: var(--font-heading-family, 'Helvetica Neue', sans-serif);
}

.primary-nav-item:hover {
  color: #2c2c2c;
}

.primary-nav-item.active {
  color: #2c2c2c;
  font-weight: 500;
}

.primary-nav-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: #2c2c2c;
}

.browse-btn {
  background: none;
  border: 1px solid #2c2c2c;
  padding: 0.5rem 1.5rem;
  font-size: 0.85rem;
  letter-spacing: 1px;
  text-transform: uppercase;
  cursor: pointer;
  margin-left: auto;
  transition: all 0.3s;
  text-decoration: none;
  color: #2c2c2c;
  display: inline-block;
}

.browse-btn:hover {
  background: #2c2c2c;
  color: #fff;
}

/* ========== TAB CONTENT VISIBILITY ========== */
.tab-content {
  display: none;
}

.tab-content.active {
  display: block;
}

/* ========== BANNER ========== */
.banner-section {
  height: 400px;
  background-size: cover;
  background-position: center;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-overlay {
  background: rgba(0, 0, 0, 0.3);
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #fff;
  padding: 2rem;
}

.banner-title {
  font-size: 2.5rem;
  font-weight: 300;
  letter-spacing: 4px;
  margin-bottom: 1rem;
}

.banner-subtitle {
  font-size: 1rem;
  font-weight: 300;
  letter-spacing: 1px;
  max-width: 600px;
  opacity: 0.9;
}

/* ========== SECONDARY NAVIGATION ========== */
.secondary-nav {
  background: #fff;
  border-bottom: 1px solid #e0e0e0;
  position: sticky;
  top: 95px;
  z-index: 998;
}

.secondary-nav-wrapper {
  display: flex;
  gap: 3rem;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.secondary-nav-wrapper::-webkit-scrollbar {
  display: none;
}

.secondary-nav-item {
  background: none;
  border: none;
  padding: 1rem 0;
  font-size: 0.9rem;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #999;
  cursor: pointer;
  position: relative;
  white-space: nowrap;
  transition: color 0.3s;
  font-family: var(--font-heading-family, 'Helvetica Neue', sans-serif);
}

.secondary-nav-item:hover {
  color: #666;
}

.secondary-nav-item.active {
  color: #2c2c2c;
}

.secondary-nav-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: #c9a05f;
}

/* ========== CONTENT SECTION ========== */
.content-section {
  display: none;
  padding: 4rem 0;
  background: #fff;
  animation: fadeIn 0.5s ease-in;
}

.content-section.active {
  display: block;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.content-grid {
  display: grid;
  grid-template-columns: 400px 1fr;
  gap: 4rem;
}

/* ========== PRODUCT IMAGE + CTA ========== */
.product-wrapper {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.product-image {
  width: 100%;
  height: auto;
  object-fit: cover;
  border-radius: 4px;
}

.cta-button {
  background: #c9a05f;
  color: #fff;
  border: none;
  padding: 1rem 2rem;
  font-size: 0.9rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.3s;
  text-decoration: none;
  text-align: center;
  display: inline-block;
  font-family: var(--font-heading-family, 'Helvetica Neue', sans-serif);
}

.cta-button:hover {
  background: #b38f4f;
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(201, 160, 95, 0.3);
}

/* ========== CONTENT INFO ========== */
.content-info {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.content-title {
  font-size: 2rem;
  font-weight: 300;
  letter-spacing: 3px;
  color: #2c2c2c;
}

.content-description {
  font-size: 1rem;
  line-height: 1.8;
  color: #666;
}

.content-description p {
  margin-bottom: 1rem;
}

/* ========== RELATED TOPICS ========== */
.related-topics {
  margin-top: 2rem;
}

.related-topics-title {
  font-size: 0.9rem;
  font-weight: 500;
  letter-spacing: 2px;
  color: #2c2c2c;
  margin-bottom: 1.5rem;
}

.related-topics-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.related-topic-item {
  background: #f8f8f8;
  padding: 1rem 1.5rem;
  border-radius: 4px;
  transition: all 0.3s;
}

.related-topic-item:hover {
  background: #f0f0f0;
  transform: translateX(4px);
}

.related-topic-link {
  color: #2c2c2c;
  text-decoration: none;
  font-size: 0.95rem;
  letter-spacing: 0.5px;
}

/* ========== RESPONSIVE ========== */
@media (max-width: 1024px) {
  .content-grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .product-wrapper {
    max-width: 500px;
    margin: 0 auto;
  }
}

@media (max-width: 768px) {
  .header-wrapper {
    flex-wrap: wrap;
  }

  .header-search {
    order: 3;
    max-width: 100%;
    flex-basis: 100%;
  }

  .banner-section {
    height: 300px;
  }

  .banner-title {
    font-size: 1.8rem;
  }

  .primary-nav-wrapper,
  .secondary-nav-wrapper {
    gap: 1.5rem;
  }

  .content-section {
    padding: 2rem 0;
  }

  .container {
    padding: 0 1rem;
  }
}
</style>

{% comment %} ==================== SECTION SCHEMA ==================== {% endcomment %}

{% schema %}
{
  "name": "Nested Information Page",
  "settings": [
    {
      "type": "paragraph",
      "content": "This section automatically loads content from your Primary Tab metaobjects. To manage content, go to: Settings → Custom data → Metaobjects → Primary Tab"
    },
    {
      "type": "header",
      "content": "Optional Settings"
    },
    {
      "type": "color",
      "id": "cta_button_color",
      "label": "CTA Button Color",
      "default": "#c9a05f"
    },
    {
      "type": "color",
      "id": "active_tab_color",
      "label": "Active Tab Indicator Color",
      "default": "#c9a05f"
    }
  ],
  "presets": [
    {
      "name": "Nested Information Page"
    }
  ]
}
{% endschema %}
