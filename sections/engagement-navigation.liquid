

{% comment %} 
{{ 'section-engagement-navigation.css' | asset_url | stylesheet_tag }}

{% comment %} Metaobjects logic {% endcomment %}
{% assign current_slug = request.path | split: '/' | last %}
{% assign main_tab_slug = request.path | split: '/' | last | default: 'engagement' %}

{% comment %} Get main tab data {% endcomment %}
{% assign main_tab = shop.metaobjects.navigation_tab.values 
  | where: "slug", main_tab_slug 
  | first 
  | default: shop.metaobjects.navigation_tab.values 
  | where: "slug", "engagement" 
  | first %}

{% comment %} Get all main tabs (tabs without parent) {% endcomment %}
{% assign main_tabs = shop.metaobjects.navigation_tab.values 
  | where: "parent_tab", blank 
  | where: "is_active", true 
  | sort: "sort_order" %}

{% comment %} Get sub-tabs for current main tab {% endcomment %}
{% assign sub_tabs = shop.metaobjects.navigation_tab.values 
  | where: "parent_tab.slug", main_tab_slug 
  | where: "is_active", true 
  | sort: "sort_order" %}

{% comment %} Get current content page if sub-tab is selected {% endcomment %}
{% assign current_content_page = nil %}
{% if request.path contains '/pages/' %}
  {% assign path_parts = request.path | split: '/' %}
  {% assign content_slug = path_parts[3] | default: path_parts[2] %}
  
  {% if content_slug != main_tab_slug %}
    {% assign current_content_page = shop.metaobjects.content_page.values 
      | where: "slug", content_slug 
      | where: "parent_tab.slug", main_tab_slug 
      | first %}
  {% endif %}
{% endif %}

{% comment %} Set meta information {% endcomment %}
{% if current_content_page %}
  {% assign page_title = current_content_page.meta_title | default: current_content_page.content_header %}
  {% assign page_description = current_content_page.meta_description | default: current_content_page.content_body | strip_html | truncate: 160 %}
{% else %}
  {% assign page_title = main_tab.title %}
  {% assign page_description = main_tab.description | strip_html | truncate: 160 %}
{% endif %}

{% assign featured_image = current_content_page.banner_image | default: main_tab.banner_image %} {% endcomment %}
 {{ 'section-engagement-navigation.css' | asset_url | stylesheet_tag }}

{% comment %} ========== DEBUG SECTION ========== {% endcomment %}
{% if section.settings.show_debug %}
<div style="background: #ffebee; padding: 15px; margin-bottom: 20px; border: 1px solid #f44336;">
  <h3>🔍 DEBUG MODE</h3>
  
  <p><strong>Page Info:</strong></p>
  <p>Page Title: {{ page.title }}</p>
  <p>Page Handle: {{ page.handle }}</p>
  <p>Page URL: {{ page.url }}</p>
  
  <p><strong>All Navigation Tabs:</strong></p>
  <ul>
  {% for tab in shop.metaobjects.navigation_tab.values %}
    <li>
      <strong>{{ tab.title }}</strong> 
      (slug: {{ tab.slug }}) 
      - Parent: {% if tab.parent_tab %}{{ tab.parent_tab.slug }}{% else %}None (MAIN TAB){% endif %}
      - Active: {{ tab.is_active }}
    </li>
  {% endfor %}
  </ul>
</div>
{% endif %}
{% comment %} ========== END DEBUG ========== {% endcomment %}

{% comment %} ========== MAIN LOGIC ========== {% endcomment %}

{% comment %} Extract rich text from metaobject {% endcomment %}
{% assign main_tab = nil %}
{% assign main_tabs = shop.metaobjects.navigation_tab.values 
  | where: "parent_tab", blank 
  | where: "is_active", true 
  | sort: "sort_order" %}

{% comment %} Find current tab based on page handle {% endcomment %}
{% assign current_slug = page.handle %}
{% for tab in main_tabs %}
  {% if tab.slug == current_slug %}
    {% assign main_tab = tab %}
    {% break %}
  {% endif %}
{% endfor %}

{% if main_tab == nil and main_tabs.size > 0 %}
  {% assign main_tab = main_tabs.first %}
{% endif %}

{% comment %} Get description from rich text field {% endcomment %}
{% assign tab_description = '' %}
{% if main_tab.description %}
  {% assign desc_json = main_tab.description | parse_json %}
  {% if desc_json %}
    {% assign tab_description = desc_json.children[0].children[0].value %}
  {% else %}
    {% assign tab_description = main_tab.description %}
  {% endif %}
{% endif %}

{% comment %} Get sub-tabs for current main tab {% endcomment %}
{% assign sub_tabs = shop.metaobjects.navigation_tab.values 
  | where: "parent_tab.slug", main_tab.slug 
  | where: "is_active", true 
  | sort: "sort_order" %}

{% comment %} Get content page if URL has sub-tab {% endcomment %}
{% assign current_content_page = nil %}
{% assign url_path = request.path %}
{% if url_path contains '/' %}
  {% assign path_parts = url_path | split: '/' %}
  {% if path_parts.size >= 4 %}
    {% assign content_slug = path_parts[3] %}
    {% assign current_content_page = shop.metaobjects.content_page.values 
      | where: "slug", content_slug 
      | where: "parent_tab.slug", main_tab.slug 
      | first %}
  {% endif %}
{% endif %}

{% comment %} ========== RENDER CONTENT ========== {% endcomment %}

<div class="page-width">
  {% if main_tab %}
    <!-- Banner Section -->
    <section class="tab-banner">
      <div class="banner-image-container">
        {% if main_tab.banner_image %}
          <img src="{{ main_tab.banner_image | image_url: width: 2000 }}" 
               alt="{{ main_tab.title }}" 
               class="banner-image"
               loading="eager">
        {% endif %}
        
        <div class="banner-content">
          <h1 class="banner-title">
            {{ main_tab.header | default: main_tab.title }}
          </h1>
          
          <p class="banner-description">
            {{ tab_description }}
          </p>
          
          {% if main_tab.cta_text and main_tab.cta_link %}
            <a href="{{ main_tab.cta_link }}" class="button button--primary">
              {{ main_tab.cta_text }}
            </a>
          {% endif %}
        </div>
      </div>
    </section>

    <!-- Main Tabs -->
    {% if main_tabs.size > 1 %}
      <nav class="main-tabs-navigation">
        <ul class="main-tabs-list">
          {% for tab in main_tabs %}
            <li class="main-tab-item {% if tab.slug == main_tab.slug %}active{% endif %}">
              <a href="/pages/{{ tab.slug }}" class="main-tab-link">
                {{ tab.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

    <!-- Sub Tabs -->
    {% if sub_tabs.size > 0 %}
      <nav class="sub-tabs-navigation">
        <ul class="sub-tabs-list">
          {% for sub_tab in sub_tabs %}
            <li class="sub-tab-item">
              <a href="/pages/{{ main_tab.slug }}/{{ sub_tab.slug }}" class="sub-tab-link">
                {{ sub_tab.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

    <!-- Content Area -->
    <section class="tab-content-area">
      {% if current_content_page %}
        <!-- Sub-tab Content -->
        <article class="content-page">
          <h2>{{ current_content_page.content_header | default: current_content_page.title }}</h2>
          <div class="rte">
            {{ current_content_page.content_body }}
          </div>
        </article>
      {% else %}
        <!-- Main Tab Content -->
        <article class="default-content">
          {% if page.content %}
            {{ page.content }}
          {% else %}
            <h2>Welcome to {{ main_tab.title }}</h2>
            <p>{{ tab_description }}</p>
          {% endif %}
        </article>
      {% endif %}
    </section>

  {% else %}
    <!-- No tabs found -->
    <div style="text-align: center; padding: 50px;">
      <h2>No tabs configured</h2>
      <p>Please create Navigation Tab metaobjects in Shopify admin.</p>
      <p>Go to: <strong>Settings → Custom Data</strong></p>
    </div>
  {% endif %}
</div>

<style>
  .tab-banner {
    position: relative;
    margin-bottom: 40px;
  }
  
  .banner-image-container {
    position: relative;
    height: 400px;
    overflow: hidden;
  }
  
  .banner-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .banner-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
    color: white;
    padding: 40px;
  }
  
  .banner-title {
    font-size: 2.5rem;
    margin-bottom: 15px;
  }
  
  .banner-description {
    font-size: 1.1rem;
    max-width: 600px;
    margin-bottom: 20px;
  }
  
  .button--primary {
    background: #000;
    color: white;
    padding: 12px 30px;
    text-decoration: none;
    border-radius: 4px;
    display: inline-block;
  }
  
  .main-tabs-navigation {
    margin: 40px 0;
    border-bottom: 1px solid #e0e0e0;
  }
  
  .main-tabs-list {
    display: flex;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
    gap: 10px;
  }
  
  .main-tab-item {
    margin: 0 5px;
  }
  
  .main-tab-link {
    padding: 15px 30px;
    text-decoration: none;
    color: #333;
    border-bottom: 3px solid transparent;
    font-weight: 500;
    transition: all 0.3s ease;
  }
  
  .main-tab-item.active .main-tab-link {
    border-bottom-color: {{ section.settings.tab_active_color }};
    color: {{ section.settings.tab_active_color }};
  }
  
  .main-tab-link:hover {
    border-bottom-color: {{ section.settings.tab_hover_color }};
    color: {{ section.settings.tab_hover_color }};
  }
  
  .sub-tabs-navigation {
    margin: 20px 0 40px;
  }
  
  .sub-tabs-list {
    display: flex;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
    gap: 15px;
  }
  
  .sub-tab-link {
    padding: 10px 20px;
    text-decoration: none;
    color: #666;
    background: #f5f5f5;
    border-radius: 4px;
    transition: all 0.3s ease;
  }
  
  .sub-tab-link:hover {
    background: {{ section.settings.tab_active_color }};
    color: white;
  }
  
  .tab-content-area {
    margin: 60px 0;
  }
</style>

{% schema %}
{
  "name": "Tab Navigation System",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_debug",
      "label": "Show Debug Information",
      "default": true
    },
    {
      "type": "color",
      "id": "tab_active_color",
      "label": "Active Tab Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "tab_hover_color",
      "label": "Tab Hover Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner Height",
      "min": 300,
      "max": 800,
      "step": 50,
      "default": 500,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Tab Navigation System",
      "category": "Navigation"
    }
  ]
}
{% endschema %}