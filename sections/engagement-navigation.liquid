{% comment %} In your section file {% endcomment %}
{% schema %}
{
  "name": "Tab Navigation System",
  "settings": [
    {
      "type": "header",
      "content": "Tab Navigation Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_ajax",
      "label": "Enable AJAX Navigation",
      "default": true
    },
    {
      "type": "color",
      "id": "tab_active_color",
      "label": "Active Tab Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "tab_hover_color",
      "label": "Tab Hover Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner Height",
      "min": 300,
      "max": 800,
      "step": 50,
      "default": 500,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Tab Navigation System",
      "category": "Navigation"
    }
  ]
}
{% endschema %}