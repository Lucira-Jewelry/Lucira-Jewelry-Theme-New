<style>

.franchise-how-it-works-{{ section.id }} { padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; background-color: {{ section.settings.background_color }}; }

.franchise-how-it-works-{{ section.id }} .franchise-works-container { max-width: {{ section.settings.container_width }}px; margin: 0 auto; padding: 0 20px; }

.franchise-how-it-works-{{ section.id }} .franchise-works-header { text-align: {{ section.settings.header_alignment }}; margin-bottom: {{ section.settings.header_spacing }}px; }

.franchise-how-it-works-{{ section.id }} .franchise-works-title { font-size: {{ section.settings.title_size }}px; color: {{ section.settings.title_color }}; font-weight: {{ section.settings.title_weight }}; text-transform: {{ section.settings.title_transform }}; letter-spacing: {{ section.settings.title_letter_spacing }}px; line-height: {{ section.settings.title_line_height }}; margin: 0 0 {{ section.settings.title_spacing }}px 0; }

.franchise-how-it-works-{{ section.id }} .franchise-works-description { font-size: {{ section.settings.description_size }}px; color: {{ section.settings.description_color }}; font-weight: {{ section.settings.description_weight }}; line-height: {{ section.settings.description_line_height }}; max-width: {{ section.settings.description_max_width }}px; margin: 0 auto; }

.franchise-how-it-works-{{ section.id }} .franchise-works-grid { display: grid; grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr); gap: {{ section.settings.grid_gap }}px; }

.franchise-how-it-works-{{ section.id }} .franchise-work-image-wrapper { position: relative; width: 100%; padding-top: {{ section.settings.image_aspect_ratio }}%; overflow: hidden; background-color: {{ section.settings.image_placeholder_color }}; }

.franchise-how-it-works-{{ section.id }} .franchise-work-image { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: {{ section.settings.image_fit }}; transition: transform {{ section.settings.image_transition }}s ease; border-radius:8px; }

.franchise-how-it-works-{{ section.id }} .franchise-work-card:hover .franchise-work-image { transform: scale({{ section.settings.image_hover_scale }}); }

@media screen and (min-width: 768px) {
.franchise-how-it-works-{{ section.id }} .franchise-work-content { padding: {{ section.settings.content_padding }}px; text-align: {{ section.settings.content_alignment }}; width: 250px; height:auto; background-color: white; left: 7%; bottom: 15%; position: relative; border-radius: 8px; overflow: hidden; box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1); transition: all 0.3s ease; border: 0px solid #e5e5e5; }
}

.franchise-how-it-works-{{ section.id }} .franchise-work-step { font-size: {{ section.settings.step_size }}px; color: {{ section.settings.step_color }}; font-weight: {{ section.settings.step_weight }}; text-transform: {{ section.settings.step_transform }}; letter-spacing: {{ section.settings.step_letter_spacing }}px; margin: 0 0 {{ section.settings.step_spacing }}px 0; }

.franchise-how-it-works-{{ section.id }} .franchise-work-heading { font-size: {{ section.settings.card_title_size }}px; color: {{ section.settings.card_title_color }}; font-weight: {{ section.settings.card_title_weight }}; line-height: {{ section.settings.card_title_line_height }}; margin: 0; position: relative; bottom: -3px; letter-spacing: 1px; }


@media (max-width: 1024px) {
.franchise-how-it-works-{{ section.id }} .franchise-works-grid { grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr); }

.franchise-how-it-works-{{ section.id }} .franchise-works-title { font-size: {{ section.settings.title_size_tablet }}px; }

.franchise-how-it-works-{{ section.id }} .franchise-works-description { font-size: {{ section.settings.description_size_tablet }}px; }
  }

@media (max-width: 768px) {

.franchise-how-it-works-{{ section.id }} .franchise-work-card { background: {{ section.settings.card_background }}; border-radius: {{ section.settings.card_border_radius }}px; overflow: hidden; box-shadow: {{ section.settings.card_shadow_x }}px {{ section.settings.card_shadow_y }}px {{ section.settings.card_shadow_blur }}px rgba(0,0,0,{{ section.settings.card_shadow_opacity }}); transition: all {{ section.settings.card_transition }}s ease; border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }}; display: flex; flex-direction: column; }

.franchise-how-it-works-{{ section.id }} { padding: {{ section.settings.padding_top_mobile }}px 0 {{ section.settings.padding_bottom_mobile }}px; }

.franchise-how-it-works-{{ section.id }} .franchise-works-grid { grid-template-columns: 1fr; gap: {{ section.settings.grid_gap_mobile }}px; }

.franchise-how-it-works-{{ section.id }} .franchise-work-card { flex-direction: row; align-items: center; }

.franchise-how-it-works-{{ section.id }} .franchise-work-image-wrapper { width: 140px; min-width: 140px; padding-top: 0; height: 100px; position: relative; }

.franchise-how-it-works-{{ section.id }} .franchise-work-content { flex: 1; text-align: left; }

.franchise-how-it-works-{{ section.id }} .franchise-works-title { font-size: {{ section.settings.title_size_mobile }}px; font-weight:500; }

.franchise-how-it-works-{{ section.id }} .franchise-works-description { font-size: {{ section.settings.description_size_mobile }}px; }
.franchise-how-it-works-{{ section.id }} .franchise-work-content { padding: {{ section.settings.content_padding_mobile }}px; }

.franchise-how-it-works-{{ section.id }} .franchise-work-step { font-size: {{ section.settings.step_size_mobile }}px; }

.franchise-how-it-works-{{ section.id }} .franchise-work-heading { font-size: {{ section.settings.card_title_size_mobile }}px; }
  }

  @media (max-width:380px){
.franchise-how-it-works-{{ section.id }} .franchise-work-heading { font-size:14px; }
  }
</style>

<div class="franchise-how-it-works-{{ section.id }}">
  <div class="franchise-works-container">
    {% if section.settings.show_header %}
      <div class="franchise-works-header">
        {% if section.settings.title != blank %}
          <h2 class="franchise-works-title">{{ section.settings.title }}</h2>
        {% endif %}
        
        {% if section.settings.description != blank %}
          <p class="franchise-works-description">{{ section.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="franchise-works-grid">
      {% for block in section.blocks %}
        <div class="franchise-work-card" {{ block.shopify_attributes }}>
          {% if block.settings.image %}
            <div class="franchise-work-image-wrapper">
              <img 
                class="franchise-work-image"
                src="{{ block.settings.image | img_url: '800x' }}"
                alt="{{ block.settings.image.alt | escape }}"
                loading="lazy"
              >
            </div>
          {% endif %}

          <div class="franchise-work-content">
            {% if block.settings.step_label != blank %}
              <div class="franchise-work-step">{{ block.settings.step_label }}</div>
            {% endif %}

            {% if block.settings.heading != blank %}
              <h3 class="franchise-work-heading">{{ block.settings.heading }}</h3>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>




