{% schema %}
{
  "name": "Custom Video Banner",
  "settings": [
    {
      "type": "range",
      "id": "margin_top_desktop",
      "label": "Margin Top (Desktop)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "label": "Margin Bottom (Desktop)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Margin Top (Mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Margin Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "video",
      "id": "video_desktop",
      "label": "Desktop Video"
    },
    {
      "type": "video",
      "id": "video_mobile",
      "label": "Mobile Video"
    }
  ],
  "presets": [
    {
      "name": "Custom Video Banner"
    }
  ]
}
{% endschema %}

<section 
  class="video-banner-section"
  style="
    --mt-desktop: {{ section.settings.margin_top_desktop }}px;
    --mb-desktop: {{ section.settings.margin_bottom_desktop }}px;
    --mt-mobile: {{ section.settings.margin_top_mobile }}px;
    --mb-mobile: {{ section.settings.margin_bottom_mobile }}px;
  "
>

  <div class="video-banner-wrapper page-width">

    {% if section.settings.video_desktop %}
  <video class="video-desktop" autoplay muted loop playsinline controls>
    <source src="{{ section.settings.video_desktop.sources[0].url }}" type="video/mp4">
  </video>
{% endif %}

{% if section.settings.video_mobile %}
  <video class="video-mobile" autoplay muted loop playsinline controls>
    <source src="{{ section.settings.video_mobile.sources[0].url }}" type="video/mp4">
  </video>
{% endif %}

  </div>

</section>

<style>
.video-banner-section {
  margin-top: var(--mt-desktop);
  margin-bottom: var(--mb-desktop);
}

.video-banner-wrapper {
  position: relative;
  width: 100%;
  height: auto;
}

.video-banner-wrapper video {
  width: 100%;
  height: auto;
}
.video-mobile {
    display: none !important;
  }

@media (max-width: 767px) {
  .video-banner-section {
    margin-top: var(--mt-mobile);
    margin-bottom: var(--mb-mobile);
  }

  .video-desktop {
    display: none !important;
  }

  .video-mobile {
    display: block !important;
  }
}
</style>
