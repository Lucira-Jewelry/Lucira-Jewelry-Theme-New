{{ 'plp-product-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'product-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'component-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'component-slider.css' | asset_url | stylesheet_tag: preload: true }}

<section class="lucira-bestseller-collection">
    <div class="heading-wrapper">
        <h2 class="lucira-wc-header">{{ section.settings.heading }}</h2>
        <p class="lucira-wc-subheader">{{ section.settings.subheading }}</p>
    </div>
    <div class="page-width">
        <div class="lucira-featured-wrapper">
            <div class="lucira-featured-left">
              {% if section.settings.image != blank %}
                {% if section.settings.banner_link != blank %}
                  <a href="{{ section.settings.banner_link }}" {% if section.settings.banner_link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                {% endif %}
                <picture>
                  {% if section.settings.mobile_image != blank %}
                    <source media="(max-width: 749px)" 
                      srcset="{{ section.settings.mobile_image | image_url: width: 600 }}">
                  {% endif %}
                  <img 
                    src="{{ section.settings.image | image_url: width: 600 }}" 
                    alt="bestseller" 
                    width="{{ section.settings.image.width | default: 600 }}" 
                    height="{{ section.settings.image.height | default: 800 }}"
                    loading="lazy">
                </picture>
                {% if section.settings.banner_link != blank %}
                  </a>
                {% endif %}
              {% endif %}
            </div>
            <div class="lucira-featured-right">
                <div class="swiper lucira-bestseller-swiper">
                    <div class="swiper-wrapper">
                        {% assign collection = collections[section.settings.collection] %}
                        {% assign product_limit = section.settings.products_to_show | default: 12 %}
                        {% for product in collection.products limit: product_limit %}
                        <div class="swiper-slide">
                            {% capture di_values %}
                                {% render 'di-discount-calc',
                                    product: product,
                                    stone_pricing_db: shop.metafields['DI-GoldPrice'].stone_pricing.value
                                %}
                            {% endcapture %}
                            {% assign di_parts = di_values | strip | split: '|' %}
                            {% assign diamond_percent = di_parts[0] | plus: 0 %}
                            {% assign mc_percent = di_parts[1] | plus: 0 %}
                            {% render 'card-product',
                                card_product: product,
                                diamond_percent: diamond_percent,
                                mc_percent: mc_percent,
                                media_aspect_ratio: 'adapt',
                                show_secondary_image: false,
                                show_vendor: false,
                                show_rating: false,
                                section_id: section.id
                            %}
                        </div>
                        {% endfor %}
                    </div>
                    <div class="swiper-button-next"></div>
                    <div class="swiper-button-prev"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .lucira-bestseller-swiper { margin-top: 0; }
    .lucira-featured-wrapper { display: flex; gap: 14px; align-items: stretch; justify-content: flex-start; }
    .lucira-featured-left { width: 24%; }
    .lucira-featured-left img { width: 100%; border-radius: 12px; display: block; height: 100%; object-fit: cover; }
    .lucira-featured-right { width: 76%; }
    .lucira-bestseller-swiper { margin-top: 0px; }
    .lucira-bestseller-swiper .swiper-slide { width: auto; }
    .lucira-bestseller-swiper .swiper-button-next,
    .lucira-bestseller-swiper .swiper-button-prev { color: #fff; }
    .lucira-bestseller-collection .page-width { width: calc(100% - ((100% - 92%) / 2)) !important; max-width: none !important; margin-left: calc((100% - 92%) / 2) !important; margin-right: 0 !important; padding: 0 !important; }
    .lucira-bestseller-collection h2.lucira-wc-header { font-size: 24px; margin: 0; font-weight: 500; line-height: 1.7; text-align: center; vertical-align: middle; text-transform: uppercase; color: #1a1a1a; letter-spacing:1.5px;}
    .lucira-bestseller-collection p.lucira-wc-subheader { text-align: center; font-size: 18px; color: #666; font-family: Futura Std, sans-serif; margin: 0 0 40px; }
    section.lucira-bestseller-collection { padding-top: 30px; padding-bottom:40px;}
    .lucira-bestseller-swiper .swiper-button-prev { display: none !important; }
    .lucira-bestseller-swiper { position: relative; }
    .lucira-bestseller-swiper .swiper-button-next { transform: translateX(50%); right: 50px !important; left: auto !important; width: 35px; height: 35px; background: #b67665; border-radius: 50%; box-shadow: 0 2px 10px rgba(0,0,0,.1); display: flex; align-items: center; justify-content: center; z-index: 10; }
    .lucira-bestseller-swiper .swiper-button-next:after { font-size: 14px; }
    .lucira-featured-left a {display: block; height: 100%;}
    @media (max-width: 749px) {
        .lucira-featured-wrapper { flex-direction: column; }
        .lucira-featured-left, .lucira-featured-right { width: 100%; }
        section.lucira-bestseller-collection { padding-top: 20px; padding-bottom:20px; }
        .lucira-bestseller-collection .page-width { width: 100% !important; padding: 0 !important; margin-left: 0 !important; }
        .lucira-bestseller-collection h2.lucira-wc-header { font-size: 18px; }
        .lucira-bestseller-collection p.lucira-wc-subheader { text-align: center; color: #666; margin: 0 0 20px; font-size: 12px; padding: 0 15px; }
        .lucira-bestseller-swiper .swiper-button-next:after { font-size: 10px; }
        .lucira-bestseller-swiper .swiper-button-next { right: 20px !important; top: 42%; width: 25px; height: 25px; }
        .lucira-featured-right { padding-left: 12px; }
        .lucira-featured-left { padding: 0 12px; }
    }

    @media (min-width: 1600px) {
        .lucira-featured-left { width: 20%; }
        .lucira-featured-right { width: 80%; }
    }
</style>

{% render 'product-collection-card' %}

<script>
document.addEventListener("DOMContentLoaded", function () {
  new Swiper(".lucira-bestseller-swiper", {
    slidesPerView: 4.2,
    spaceBetween: 14,
    loop: true,
    autoplay: {
      delay: 5000,
      disableOnInteraction: false,
      pauseOnMouseEnter: true
    },
    navigation: {
      nextEl: ".lucira-bestseller-swiper .swiper-button-next",
      prevEl: ".lucira-bestseller-swiper .swiper-button-prev",
    },
    breakpoints: {
      0:    { slidesPerView: 2.1, slidesPerGroup: 2, spaceBetween: 12 },
      768:  { slidesPerView: 3.2 },
      1024: { slidesPerView: 3.2 },
      1600: { slidesPerView: 4.2 }
    }
  });
});
</script>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const section = document.querySelector('.lucira-bestseller-collection');
  if (!section) return;

  section.querySelectorAll('.card-wrapper').forEach((card, index) => {
    card.addEventListener('click', (event) => {
      const target = event.target.closest('a, .product-card-link, .card__media img');
      if (!target) return;

      const productTitle =
        card.querySelector('.card__heading, .card__title')?.textContent.trim() || '';
      const productSku =
        card.querySelector('[data-product-sku]')?.dataset.productSku || '';

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'promoClick',
        promoClick: {
          promo_id: productSku || `bestseller_product_${index + 1}`,
          creative_name: 'Bestseller Collection',
          promo_name: productTitle,
        },
      });
    });
  });
});
</script>

{% schema %}
{
  "name": "Bestseller Collection",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner Link"
    },
    {
      "type": "checkbox",
      "id": "banner_link_new_tab",
      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "default": "BESTSELLERS",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "default": "Our most loved pieces",
      "label": "Subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 12,
      "label": "Maximum products to show"
    }
  ],
  "presets": [
    {
      "name": "Bestseller Collection Swiper"
    }
  ]
}
{% endschema %}