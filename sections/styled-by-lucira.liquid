<script>
  document.addEventListener('DOMContentLoaded', function () {

    /* ─── Swiper thumbnails ─── */
    new Swiper('.lucira-swiper', {
      slidesPerView: 'auto',
      spaceBetween: 12,
      centeredSlides: true,
      loop: true,
      breakpoints: {
        768: { spaceBetween: 16 },
        1024: { spaceBetween: 20 },
      },
    });

    const section = document.querySelector('.styled-lucira-section');
    if (section) {
      const thumbObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            section.querySelectorAll('.video-placeholder[data-src]').forEach((placeholder) => {
              const video = document.createElement('video');
              video.autoplay = true;
              video.loop = true;
              video.muted = true;
              video.playsInline = true;
              video.setAttribute('playsinline', '');
              video.poster = placeholder.dataset.poster;
              const source = document.createElement('source');
              source.src = placeholder.dataset.src;
              source.type = 'video/mp4';
              video.appendChild(source);
              placeholder.replaceWith(video);
              video.play().catch(() => {});
            });
            thumbObserver.disconnect();
          });
        },
        { threshold: 0.2 }
      );
      thumbObserver.observe(section);
    }

    function addToCartAjax(variantId, quantity = 1) {
      return fetch(window.Shopify?.routes?.root + 'cart/add.js' || '/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json'
        },
        body: JSON.stringify({
          id: variantId,
          quantity: quantity,
          sections: 'cart-drawer,cart-icon-bubble', // Request sections directly in the add call
          sections_url: window.location.pathname
        })
      }).then((res) => {
        if (!res.ok) return res.json().then(err => Promise.reject(err));
        return res.json();
      });
    }

    function addAllToCartAjax(variantIds) {
      const items = variantIds.map(id => ({
        id: Number(id),
        quantity: 1
      }));

      return fetch(window.Shopify?.routes?.root + 'cart/add.js' || '/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json'
        },
        body: JSON.stringify({
          items: items,
          sections: 'cart-drawer,cart-icon-bubble', // Request sections directly in the add call
          sections_url: window.location.pathname
        })
      }).then((res) => {
        if (!res.ok) return res.json().then(err => Promise.reject(err));
        return res.json();
      });
    }

    // Single item Add to Cart logic
    document.querySelectorAll('#luciraPopup form[action="/cart/add"]').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const variantId = form.querySelector('input[name="id"]').value;
        const btn = form.querySelector('.lucira-add-btn');
        if (!variantId) return;

        const originalText = btn.textContent;

        try {
          btn.textContent = 'Adding...';
          btn.disabled = true;

          // Fetch the response which now contains the updated sections HTML
          const response = await addToCartAjax(variantId);

          btn.textContent = '✓ Added';
          btn.style.opacity = '0.7';

          const drawer = document.querySelector('cart-drawer');
          if (drawer) {
            if (typeof drawer.renderContents === 'function') {
              drawer.renderContents(response); // Pass Dawn the exact structure it expects
            }
            
            // CRUCIAL: Remove the empty classes that hide the cart items
            drawer.classList.remove('is-empty');
            const drawerInner = drawer.querySelector('.drawer__inner');
            if (drawerInner) drawerInner.classList.remove('is-empty');
            
            drawer.open();
          }

          setTimeout(() => {
            closePopup(); 
          }, 200);

          setTimeout(() => {
            btn.textContent = originalText;
            btn.disabled = false;
            btn.style.opacity = '';
          }, 1500);

        } catch (err) {
          console.error('[Lucira] add failed', err);

          btn.textContent = 'Error';
          setTimeout(() => {
            btn.textContent = originalText;
            btn.disabled = false;
          }, 2000);
        }
      });
    });

    // Add All to Cart logic
    document.querySelectorAll('.lucira-add-all-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {

        const ids = btn.dataset.variants
          ? btn.dataset.variants.split(',').map(id => id.trim()).filter(Boolean)
          : [];

        if (!ids.length) return;

        const originalText = btn.textContent;

        try {
          btn.textContent = 'Adding...';
          btn.disabled = true;

          // Fetch the response which now contains the updated sections HTML
          const response = await addAllToCartAjax(ids);

          btn.textContent = '✓ All Added';
          btn.style.opacity = '0.7';

          const drawer = document.querySelector('cart-drawer');
          if (drawer) {
            if (typeof drawer.renderContents === 'function') {
              drawer.renderContents(response);
            }
            
            // CRUCIAL: Remove the empty classes that hide the cart items
            drawer.classList.remove('is-empty');
            const drawerInner = drawer.querySelector('.drawer__inner');
            if (drawerInner) drawerInner.classList.remove('is-empty');

            drawer.open();
          }

          setTimeout(() => {
            closePopup();
          }, 200);

          setTimeout(() => {
            btn.textContent = originalText;
            btn.disabled = false;
            btn.style.opacity = '';
          }, 1500);

        } catch (err) {
          console.error('[Lucira] add-all failed', err);

          btn.textContent = 'Error';
          setTimeout(() => {
            btn.textContent = originalText;
            btn.disabled = false;
          }, 2000);
        }
      });
    });

    /* ─── Popup open / close ─── */
    const overlay     = document.getElementById('luciraPopup');
    const closeBtn    = document.getElementById('luciraPopupClose');
    const counter     = document.getElementById('luciraPopupCounter');
    const prevBtn     = document.getElementById('luciraPopupPrev');
    const nextBtn     = document.getElementById('luciraPopupNext');
    const popupSlides = document.querySelectorAll('#luciraPopupSwiper .swiper-slide');
    let popupSwiper   = null;
    let isMuted       = true;
    let arrowsBound   = false;
    let isPopupOpen   = false;

    const isMobile = () => window.innerWidth < 768;

    function loadSlideVideo(slide) {
      const inner = slide.querySelector('.lucira-popup-slide-inner');
      if (!inner || inner.querySelector('video')) return;

      const src    = slide.dataset.src    || slide.closest('[data-src]')?.dataset.src;
      const poster = slide.dataset.poster || slide.closest('[data-poster]')?.dataset.poster;
      if (!src) return;

      // Poster image fallback — shown immediately, hidden once video is ready
      if (poster && !inner.querySelector('.lucira-poster-fallback')) {
        const img = document.createElement('img');
        img.src = poster;
        img.className = 'lucira-poster-fallback';
        img.style.cssText = `
          position:absolute;inset:0;width:100%;height:100%;
          object-fit:cover;z-index:2;display:block;
          transition:opacity 0.3s ease;
        `;
        inner.style.position = 'relative';
        inner.appendChild(img);
      }

      const video = document.createElement('video');
      video.loop        = true;
      video.playsInline = true;
      video.controls    = true;
      video.muted       = false;
      video.volume      = 1;
      video.setAttribute('playsinline', '');
      video.poster      = poster || '';
      video.setAttribute('preload', 'auto');
      video.style.cssText = 'position:relative;z-index:1;width:100%;height:100%;object-fit:cover;display:block;';

      const source = document.createElement('source');
      source.src  = src;
      source.type = 'video/mp4';
      video.appendChild(source);

      // Hide poster once video has buffered enough to display a frame
      video.addEventListener('canplay', () => {
        const fallback = inner.querySelector('.lucira-poster-fallback');
        if (fallback) {
          fallback.style.opacity = '0';
          setTimeout(() => fallback.remove(), 300);
        }
      }, { once: true });

      inner.appendChild(video);
      return video;
    }

    function loadCloneVideos() {
      if (!popupSwiper) return;
      popupSwiper.slides.forEach((slide) => {
        if (slide.classList.contains('swiper-slide-duplicate')) {
          const origIndex = parseInt(slide.dataset.swiperSlideIndex, 10);
          const original  = popupSlides[origIndex];
          if (original && !slide.dataset.src) {
            slide.dataset.src    = original.dataset.src;
            slide.dataset.poster = original.dataset.poster;
          }
          loadSlideVideo(slide);
        }
      });
    }

    function stopAllVideos() {
      document.querySelectorAll('#luciraPopup video').forEach((v) => {
        v.pause();
        v.muted = true;
        v.currentTime = 0;
      });
    }

    function playActiveSlide(swiper) {
      if (!isPopupOpen) return;
      if (!swiper || swiper.destroyed) return;
      const activeReal = swiper.realIndex;
      swiper.slides.forEach((slide) => {
        const video = slide.querySelector('video');
        if (!video) return;
        const isActive = slide.classList.contains('swiper-slide-active');
        if (isActive) {
          video.muted = false;
          video.currentTime = 0;
          const p = video.play();
          if (p !== undefined) {
            p.catch(() => {
              if (!isPopupOpen) return;
              setTimeout(() => video.play().catch(() => {}), 200);
            });
          }
        } else {
          video.pause();
          video.currentTime = 0;
        }
      });
      counter.textContent = `${activeReal + 1} / ${popupSlides.length}`;
    }

    function openPopup(startIndex) {
      isPopupOpen = true;
      overlay.style.display = 'flex';
      void overlay.offsetHeight;
      overlay.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      isMuted = false;

      [startIndex - 1, startIndex, startIndex + 1].forEach((i) => {
        const slide = popupSlides[(i + popupSlides.length) % popupSlides.length];
        if (slide) loadSlideVideo(slide);
      });

      if (!popupSwiper) {
        popupSwiper = new Swiper('#luciraPopupSwiper', {
          direction: isMobile() ? 'vertical' : 'horizontal',
          slidesPerView: isMobile() ? 1 : 'auto',
          centeredSlides: true,
          spaceBetween: isMobile() ? 0 : 32,
          initialSlide: startIndex,
          speed: 380,
          loop: true,
          keyboard: { enabled: true },
          on: {
            afterInit: function () {
              loadCloneVideos();
              setTimeout(() => playActiveSlide(this), 100);
            },
            slideChange: function () {
              if (!isPopupOpen) return;
              const idx  = this.realIndex;
              const next = popupSlides[(idx + 1) % popupSlides.length];
              if (next) loadSlideVideo(next);
              loadCloneVideos();
              this.slides.forEach((slide) => {
                const video = slide.querySelector('video');
                if (video && !slide.classList.contains('swiper-slide-active')) video.pause();
              });
            },
            transitionEnd: function () {
              if (!isPopupOpen) return;
              playActiveSlide(this);
            },
          },
        });

        if (!arrowsBound) {
          prevBtn.addEventListener('click', () => popupSwiper && popupSwiper.slidePrev());
          nextBtn.addEventListener('click', () => popupSwiper && popupSwiper.slideNext());
          arrowsBound = true;
        }
      } else {
        stopAllVideos();
        popupSwiper.slideToLoop(startIndex, 0);
        setTimeout(() => playActiveSlide(popupSwiper), 100);
      }
    }

    function closePopup() {
      isPopupOpen = false;
      stopAllVideos();
      if (popupSwiper) { popupSwiper.destroy(true, true); popupSwiper = null; }
      overlay.classList.remove('is-open');
      document.body.style.overflow = '';
      isMuted = true;
      overlay.addEventListener('transitionend', function handler() {
        if (!overlay.classList.contains('is-open')) {
          overlay.style.display = 'none';
        }
        overlay.removeEventListener('transitionend', handler);
      });
    }

    document.querySelectorAll('.lucira-card[data-popup-index]').forEach((card) => {
      card.style.cursor = 'pointer';
      card.addEventListener('click', () => openPopup(parseInt(card.dataset.popupIndex, 10)));
    });

    closeBtn.addEventListener('click', closePopup);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) closePopup(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePopup(); });

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        if (popupSwiper) { popupSwiper.destroy(true, true); popupSwiper = null; }
      }, 300);
    });

    /* ─── Share button ─── */
    const shareBtn = document.getElementById('luciraShareBtn');
    if (shareBtn) {
      shareBtn.addEventListener('click', async () => {
        try {
          const activeSlide = popupSwiper ? popupSwiper.slides[popupSwiper.activeIndex] : null;
          const realIndex   = popupSwiper ? popupSwiper.realIndex : 0;
          const shareUrl    = `${window.location.origin}${window.location.pathname}#look-${realIndex + 1}`;
          const products    = [];
          if (activeSlide) {
            activeSlide.querySelectorAll('.lucira-product-item').forEach((item) => {
              const title = item.querySelector('.lucira-product-title')?.textContent.trim();
              const url   = item.dataset.url ? `${window.location.origin}${item.dataset.url}` : null;
              if (title) products.push({ title, url });
            });
          }
          const productLines = products.map((p) => p.url ? `• ${p.title}\n  ${p.url}` : `• ${p.title}`).join('\n');
          const shareTitle   = products.length ? 'Shop this look' : 'Check out this look';
          const shareText    = products.length ? `✨ Styled by Lucira\n\n${productLines}\n\nShop the full look 👇` : 'Styled by Lucira';
          if (navigator.share) {
            await navigator.share({ title: shareTitle, text: shareText, url: shareUrl });
          } else {
            await navigator.clipboard.writeText(`${shareTitle}\n${shareUrl}`);
            const orig = shareBtn.innerHTML;
            shareBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
            shareBtn.title = 'Link copied!';
            setTimeout(() => { shareBtn.innerHTML = orig; shareBtn.title = ''; }, 2000);
          }
        } catch (err) {}
      });
    }

    /* ─── Swipe hint ─── */
    let swipeHintDismissed = false;
    overlay.addEventListener('touchstart', () => {
      if (!swipeHintDismissed) { swipeHintDismissed = true; overlay.classList.add('swiped'); }
    }, { passive: true, once: true });

  });
</script>

