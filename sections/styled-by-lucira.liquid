<section class="styled-lucira-section">
  <div class="styled-lucira-wrapper">
    <div class="page-width">
      <div class="heading-wrapper">
        <h2 class="section-heading lucira-wc-header">{{ section.settings.styled_lucira_heading }}</h2>
        <p class="lucira-wc-subheader">{{ section.settings.styled_lucira_subheading }}</p>
      </div>
    </div>

    <div class="swiper lucira-swiper">
      <div class="swiper-wrapper">
        {% assign popup_index = -1 %}
        {% for block in section.blocks %}
          {% assign video_src = blank %}
          {% if block.settings.video != blank %}
            {% assign video_src = block.settings.video.sources | where: 'format', 'mp4' | first %}
            {% assign popup_index = popup_index | plus: 1 %}
          {% endif %}

          <div class="swiper-slide">
            <div
              class="lucira-card"
              {% if block.settings.video != blank %}
                data-popup-index="{{ popup_index }}"
              {% endif %}
            >
              {% if block.settings.video != blank %}
                {% assign video_poster = block.settings.video.preview_image | image_url: width: 600 %}
                <div
                  class="video-placeholder"
                  data-src="{{ video_src.url }}"
                  data-poster="{{ video_poster }}"
                >
                  {{
                    block.settings.video.preview_image
                    | image_url: width: 600
                    | image_tag: loading: 'lazy', alt: 'lucira poster'
                  }}
                </div>

              {% elsif block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="lucira style"
                  width="328"
                  height="516"
                  loading="lazy"
                >
              {% endif %}

              {% if video_src %}
                <div class="play-icon">{{ 'icon-video-play.svg' | inline_asset_content }}</div>
              {% endif %}
              <div class="video-cart-icon">{{ 'icon-video-cart.svg' | inline_asset_content }}</div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<div class="lucira-popup-overlay" id="luciraPopup" role="dialog" aria-modal="true">
  <button class="lucira-popup-close" id="luciraPopupClose" aria-label="Close">✕</button>
  <div class="lucira-popup-counter" id="luciraPopupCounter"></div>
  <button class="lucira-popup-arrow lucira-popup-prev" id="luciraPopupPrev" aria-label="Previous">
    {{ 'icon-arrow.svg' | inline_asset_content }}
  </button>
  <button class="lucira-popup-arrow lucira-popup-next" id="luciraPopupNext" aria-label="Next">
    {{ 'icon-arrow.svg' | inline_asset_content }}
  </button>
  <div class="lucira-swipe-hint" id="luciraSwipeHint" aria-hidden="true">
    <div class="lucira-swipe-hint__track">
      <div class="lucira-swipe-hint__thumb"></div>
    </div>
    <span class="lucira-swipe-hint__label">Swipe Up</span>
  </div>

  <button class="lucira-share-btn" id="luciraShareBtn" aria-label="Share">
    {{ 'share-icon.svg' | inline_asset_content }}
  </button>

  <div class="swiper lucira-popup-swiper" id="luciraPopupSwiper">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        {% if block.settings.video != blank %}
          {% assign popup_src = block.settings.video.sources | where: 'format', 'mp4' | first %}
          {% assign popup_poster = block.settings.video.preview_image | image_url: width: 600 %}

          {% assign total_price = 0 %}
          {% for product in block.settings.products %}
            {% assign current_variant = product.selected_or_first_available_variant %}
            {% assign total_price = total_price | plus: current_variant.price %}
          {% endfor %}

          <div class="swiper-slide" data-src="{{ popup_src.url }}" data-poster="{{ popup_poster }}">
            <div class="lucira-popup-inner">
              <div class="lucira-popup-wrapper">
                <div class="lucira-popup-video-wrap">
                  <div class="lucira-popup-slide-inner"></div>
                </div>

                {% if block.settings.products != blank %}
                  <div class="lucira-popup-products">
                    <div class="lucira-products-list">
                      {% for product in block.settings.products %}
                        {% assign current_variant = product.selected_or_first_available_variant %}
                        <div class="lucira-product-item" data-url="{{ product.url }}">
                          <div class="lucira-product-img">
                            <img
                              src="{{ product.featured_image | image_url: width: 120 }}"
                              alt="{{ product.title }}"
                              width="60"
                              height="60"
                              loading="lazy"
                            >
                          </div>
                          <div class="lucira-product-info">
                            <p class="lucira-product-title">{{ product.title }}</p>
                            <div class="lucira-product-pricing">
                              <span class="lucira-price">{{ current_variant.price | money }}</span>
                              
                              {% if current_variant.compare_at_price > current_variant.price %}
                                <span class="lucira-compare-price">{{ current_variant.compare_at_price | money }}</span>
                                {% assign discount = current_variant.compare_at_price
                                  | minus: current_variant.price
                                  | times: 100
                                  | divided_by: current_variant.compare_at_price
                                %}
                                <span class="lucira-badge">{{ discount }}% OFF</span>
                              {% endif %}
                            </div>
                          </div>
                          <form action="/cart/add" method="post">
                            <input type="hidden" name="id" value="{{ current_variant.id }}">
                            <button type="submit" class="lucira-add-btn">ADD</button>
                          </form>
                        </div>
                      {% endfor %}
                    </div>

                    <div class="lucira-add-all-wrap">
                      <button
                        class="lucira-add-all-btn"
                        data-variants="{% for product in block.settings.products %}{{ product.selected_or_first_available_variant.id }}{% unless forloop.last %},{% endunless %}{% endfor %}"
                      >
                        ADD ALL PRODUCTS TO CART — {{ total_price | money }}
                      </button>
                    </div>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<style>
