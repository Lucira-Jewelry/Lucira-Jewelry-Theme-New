  .lucira-popup-overlay .lucira-popup-swiper .swiper-slide{width:100vw;height:100dvh;display:flex;align-items:stretch}
  .lucira-popup-overlay .lucira-popup-inner{flex-direction:column}
  .lucira-popup-overlay .lucira-popup-video-wrap{flex:1;position:relative;overflow:hidden}
  .lucira-popup-overlay .lucira-popup-slide-inner{width:100%;height:100%}
  .lucira-popup-overlay .lucira-popup-slide-inner video{width:100%;height:100vh;object-fit:cover;display:block}
  .lucira-popup-overlay .lucira-popup-products{position:absolute;bottom:0;left:0px;right:0;z-index:10;background:linear-gradient(to top,rgba(0,0,0,.85) 0,transparent 100%);padding:24px 0px 24px 12px}
  .lucira-popup-overlay .lucira-products-list{display:flex;gap:10px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;padding:0 16px;scrollbar-width:none}
  .lucira-popup-overlay .lucira-products-list::-webkit-scrollbar{display:none}
  .lucira-popup-overlay .lucira-product-item{flex:0 0 auto;scroll-snap-align:start;display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.95);border-radius:12px;padding:10px 12px;min-width:270px;max-width:310px}
  .lucira-popup-overlay .lucira-product-img img{width:52px;height:52px;object-fit:contain;border-radius:8px;background:#f5f5f5}
  .lucira-popup-overlay .lucira-product-title{font-size:12px;font-weight:600;color:#111;margin:0 0 4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .lucira-popup-overlay .lucira-add-all-wrap{display:none}
  .lucira-popup-overlay button.lucira-add-btn{font-family:Futura Std,sans-serif;font-weight:500;font-size:14px;line-height:100%;text-transform:uppercase;background:#5a413f;color:#fff;border:none;border-radius:4px;padding:6px 12px;cursor:pointer;letter-spacing:.06em;white-space:nowrap;transition:background .2s}
  .styled-lucira-section h2 { text-align: center; text-transform: uppercase; font-weight: 500; margin: 0 0 5px; color: #1a1a1a; font-size: 18px; }
  .styled-lucira-section p.lucira-wc-subheader { font-size: 12px; margin-bottom: 20px; padding: 0 15px; text-align: center; margin-top: 0; }
