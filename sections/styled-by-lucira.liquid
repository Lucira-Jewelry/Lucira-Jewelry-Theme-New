  @media (min-width:768px){
  .lucira-popup-overlay .lucira-popup-arrow{display:flex}
  .lucira-popup-overlay .lucira-popup-swiper .swiper-slide{width:100vw;height:100dvh;display:flex;align-items:center;justify-content:center}
  .lucira-popup-overlay .lucira-popup-inner{flex-direction:row;align-items:center;justify-content:center;gap:32px;height:100%;padding:0;box-sizing:border-box}
  .lucira-popup-overlay .lucira-popup-video-wrap{flex:0 0 auto;height:85dvh;aspect-ratio:9/16;border-radius:4px;overflow:hidden;background:#000}
