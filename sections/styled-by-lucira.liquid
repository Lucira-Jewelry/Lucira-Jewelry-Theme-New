  .lucira-popup-overlay .lucira-swipe-hint__track{width:4px;height:64px;background:rgba(255,255,255,.2);border-radius:4px;position:relative;overflow:hidden}
  .lucira-popup-overlay .lucira-swipe-hint__thumb{position:absolute;bottom:0;left:0;width:100%;height:40%;background:rgba(255,255,255,.85);border-radius:4px;animation:swipeUpHint 1.6s ease-in-out infinite;display:block}
