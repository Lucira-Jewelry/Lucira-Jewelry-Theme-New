<script>
  document.addEventListener('DOMContentLoaded', function () {
    var pageType = '{{ request.page_type }}'; 
    var locationId;

    if (pageType === 'index') {
      locationId = 'homepage';
    } else if (pageType === 'collection') {
      locationId = 'plp';
    } else if (pageType === 'product') {
      locationId = 'pdp';
    } else {
      locationId = pageType;
    }

    var storeNearbyLink = document.querySelector('.icon-store-wrapper a');

    if (storeNearbyLink) {
      storeNearbyLink.addEventListener('click', function () {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'promoClick',
          promoClick: {
            creative_name: 'Store Nearby - Header',
            location_id: locationId
          }
        });
      });
    }
  });
</script>

