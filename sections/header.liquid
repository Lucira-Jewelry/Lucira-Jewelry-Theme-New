<script>
  document.addEventListener('DOMContentLoaded', function () {
    const cartIcon = document.getElementById('cart-icon-bubble');

    if (cartIcon) {
      cartIcon.addEventListener('click', function () {
        fetch('/cart.js')
          .then(response => response.json())
          .then(cart => {
            const cartData = {
              event: 'viewCart',
              cart: {
                currency: 'INR', // or cart.currency if present
                cart_total: cart.original_total_price / 100,
                grand_total: cart.total_price / 100,
                discount_amount: (cart.original_total_price - cart.total_price) / 100,
                total_quantity: cart.item_count,
                total_product: cart.items.length,
                coupon_code: (cart.cart_level_discount_applications?.[0]?.code) || '',
                items: cart.items.map((item, index) => ({
                  id: item.product_id.toString(),
                  sku: item.sku || '',
                  variant_id: item.variant_id.toString(),
                  product_name: item.product_title,
                  product_type: item.product_type,
                  category: item.vendor,
                  sub_category: item.product_type, // adjust if needed
                  price: item.original_price / 100,
                  offer_price: item.discounted_price / 100,
                  quantity: item.quantity,
                  thumbnail_image: item.image,
                  index_position: index + 1
                }))
              }
            };

            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push(cartData);
          })
          .catch(error => {
            console.error('Cart fetch error:', error);
          });
      });
    }
  });
</script>

