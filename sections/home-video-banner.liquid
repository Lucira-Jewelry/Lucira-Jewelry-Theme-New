<style>
  section.video-banner {
    height: 100vh;
    position: relative;
    overflow: hidden;
  }
  
  .video-banner__iframe-container {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    transform: translate(-50%, -50%);
    z-index: 1;
  }
  
  .video-banner__iframe {
    width: 100%;
    height: 100%;
    border: none;
    object-fit: cover;
  }
  
  .video-banner__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0);
    z-index: 2;
  }
  
  .video-banner__content {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    color: #fff;
    z-index: 2;
    width: 100% !important;
    max-width: 800px;
    padding: 0 20px;
  }
  
  .video-banner__title {
    font-size: 3.5rem;
    font-weight: 400;
    font-family: 'Futura Std', sans-serif !important;
    color: #fff;
    letter-spacing: 1px;
    margin-bottom: 16px;
    text-shadow: 2px 2px 4px rgb(0 0 0 / 28%);
    margin-top: 0;
    margin-bottom: 4px;
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-thickness: 1px;
  }
  
  .video-banner__subtitle {
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 1px;
    opacity: 1;
    text-shadow: 1px 1px 2px rgb(0 0 0 / 37%);
    margin-bottom: 0;
    margin-top: 0;
    color: #fff;
  }
  
  .video-banner__controls {
    position: absolute;
    bottom: 30px;
    right: 30px;
    z-index: 2;
  }
  
  .video-banner__play-pause {
    background: rgba(255,255,255,.9);
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .3s ease;
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 20px rgba(0,0,0,.1);
  }
  
  .video-banner__play-pause:hover {
    background: rgba(255,255,255,1);
    transform: scale(1.1);
    box-shadow: 0 6px 25px rgba(0,0,0,.15);
  }
  
  .video-banner__play-pause svg {
    width: 24px;
    height: 24px;
    fill: #333;
  }
  
  .video-banner__content a {
    text-decoration: none;
  }
  
  .video-banner__audio-controls {
    position: absolute;
    bottom: 30px;
    left: 30px;
    z-index: 2;
  }
  
  .video-banner__mute-unmute {
    background: rgba(255,255,255,.9);
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .3s ease;
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 20px rgba(0,0,0,.1);
  }
  
  .video-banner__mute-unmute:hover {
    background: rgba(255,255,255,1);
    transform: scale(1.1);
    box-shadow: 0 6px 25px rgba(0,0,0,.15);
  }
  
  .video-banner__mute-unmute svg {
    width: 24px;
    height: 24px;
    fill: #333;
  }
  
  .video-banner__fallback {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 0;
  }
  
  /* LCP optimization - ensure fallback image loads first */
  .video-banner__fallback.lcp-priority {
    z-index: 3;
  }
  
  /* Hide iframes initially to prevent LCP impact */
  .video-banner__iframe-container {
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  
  .video-banner__iframe-container.loaded {
    opacity: 1;
  }
  
  @media (max-width: 768px) {
    section.video-banner {
      height: 85vh;
    }
    
    .video-banner {
      min-height: 300px;
    }
    
    .video-banner__title {
      font-size: 2.5rem;
      margin-bottom: 8px;
    }
    
    .video-banner__subtitle {
      font-size: 1.3rem;
      margin-top: 8px;
    }
    
    .video-banner__content {
      bottom: 40px;
      padding: 0;
    }
    
    .video-banner__controls {
      bottom: 20px;
      right: 20px;
    }
    
    .video-banner__play-pause {
      width: 50px;
      height: 50px;
    }
    
    .video-banner__play-pause svg {
      width: 20px;
      height: 20px;
    }
    
    .video-banner__play-pause {
      width: 40px;
      height: 40px;
    }
    
    .video-banner__audio-controls {
      bottom: 20px;
      left: 20px;
    }
    
    .video-banner__mute-unmute {
      width: 40px;
      height: 40px;
    }
    
    .video-banner__mute-unmute svg {
      width: 20px;
      height: 20px;
    }
  }
  
  @media (max-width: 390px) {
    .brad-mob-logo {
      max-width: 80%;
    }
  }
  
  @media (min-width: 1400px) {
    .video-banner__title {
      font-size: 4rem;
    }
    
    .video-banner__subtitle {
      font-size: 1.4rem;
    }
  }
  
  /* Updated mobile-specific video handling */
  @media (max-width: 768px) {
    .video-banner__iframe-desktop {
      display: none;
    }
  }
  
  @media (min-width: 769px) {
    .video-banner__iframe-mobile {
      display: none;
    }
  }
  
  @media only screen and (min-width: 410px) and (max-width: 767px) {
    section.video-banner {
      height: 90vh !important;
    }
  }
</style>

<section class="video-banner" style="min-height: {{ section.settings.min_height }}px;">

  <!-- Fallback Images (shown immediately for LCP) -->
  <div id="videoBannerFallbackDesktop" class="video-banner__fallback lcp-priority video-banner__fallback-desktop"></div>
  <div id="videoBannerFallbackMobile" class="video-banner__fallback lcp-priority video-banner__fallback-mobile"></div>

  <!-- Video iFrames (loaded after page load) -->
  {% assign desktop_video = section.settings.desktop_video %}
  {% assign mobile_video = section.settings.mobile_video %}

  <!-- Desktop Video iFrame -->
  {% if desktop_video != blank %}
    <div class="video-banner__iframe-container video-banner__iframe-desktop" id="iframeContainerDesktop">
      <iframe 
        class="video-banner__iframe" 
        id="videoBannerDesktop"
        data-src="{{ desktop_video.sources[1].url | replace: '.mp4', '' }}"
        title="Desktop Video Banner"
        loading="lazy"
        allow="autoplay; encrypted-media"
        allowfullscreen>
      </iframe>
    </div>
  {% endif %}

  <!-- Mobile Video iFrame -->
  {% if mobile_video != blank %}
    <div class="video-banner__iframe-container video-banner__iframe-mobile" id="iframeContainerMobile">
      <iframe 
        class="video-banner__iframe" 
        id="videoBannerMobile"
        data-src="{{ mobile_video.sources[1].url | replace: '.mp4', '' }}"
        title="Mobile Video Banner"
        loading="lazy"
        allow="autoplay; encrypted-media"
        allowfullscreen>
      </iframe>
    </div>
  {% elsif desktop_video != blank %}
    <!-- Fallback: Use desktop video on mobile if no mobile video is set -->
    <div class="video-banner__iframe-container video-banner__iframe-mobile" id="iframeContainerMobileFallback">
      <iframe 
        class="video-banner__iframe" 
        id="videoBannerMobileFallback"
        data-src="{{ desktop_video.sources[1].url | replace: '.mp4', '' }}"
        title="Mobile Video Banner"
        loading="lazy"
        allow="autoplay; encrypted-media"
        allowfullscreen>
      </iframe>
    </div>
  {% endif %}

  <!-- Content -->
  <div class="video-banner__content">
    {% if section.settings.title != blank %}
      <a href="https://www.lucirajewelry.com/collections/hexa">
        <div class="video-banner__title">{{ section.settings.title }}</div>
      </a>
    {% endif %}
    {% if section.settings.subtitle != blank %}
      <a href="https://www.lucirajewelry.com/collections/hexa">
        <p class="video-banner__subtitle">{{ section.settings.subtitle }}</p>
      </a>
    {% endif %}
  </div>

  <!-- Play/Pause Controls -->
  {% if section.settings.show_controls %}
    <div class="video-banner__controls">
      <button class="video-banner__play-pause" id="playPauseBtn" aria-label="Play/Pause video">
        <svg class="pause-icon" viewBox="0 0 24 24" style="display: none;">
          <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
        </svg>
        <svg class="play-icon" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
      </button>
    </div>
  {% endif %}

  <!-- Audio Controls -->
  {% if section.settings.show_controls %}
    <div class="video-banner__audio-controls">
      <button class="video-banner__mute-unmute" id="muteUnmuteBtn" aria-label="Mute/Unmute video">
        <svg class="unmute-icon" viewBox="0 0 24 24">
          <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
        </svg>
        <svg class="mute-icon" viewBox="0 0 24 24" style="display: none;">
          <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
        </svg>
      </button>
    </div>
  {% endif %}
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Elements
  const desktopIframeContainer = document.getElementById('iframeContainerDesktop');
  const mobileIframeContainer = document.getElementById('iframeContainerMobile') || document.getElementById('iframeContainerMobileFallback');
  const desktopIframe = document.getElementById('videoBannerDesktop');
  const mobileIframe = document.getElementById('videoBannerMobile') || document.getElementById('videoBannerMobileFallback');
  const fallbackDesktop = document.getElementById('videoBannerFallbackDesktop');
  const fallbackMobile = document.getElementById('videoBannerFallbackMobile');
  const playPauseBtn = document.getElementById('playPauseBtn');
  const muteUnmuteBtn = document.getElementById('muteUnmuteBtn');
  const playIcon = playPauseBtn?.querySelector('.play-icon');
  const pauseIcon = playPauseBtn?.querySelector('.pause-icon');
  const muteIcon = muteUnmuteBtn?.querySelector('.mute-icon');
  const unmuteIcon = muteUnmuteBtn?.querySelector('.unmute-icon');

  const isMobile = window.innerWidth <= 768;
  const currentIframeContainer = isMobile ? mobileIframeContainer : desktopIframeContainer;
  const currentIframe = isMobile ? mobileIframe : desktopIframe;
  const currentFallback = isMobile ? fallbackMobile : fallbackDesktop;

  // STEP 1: Load fallback images immediately for LCP
  const fallbackUrl = isMobile ? 
    '{{ section.settings.fallback_image_mobile | img_url: "1080x1920" }}' : 
    '{{ section.settings.fallback_image_desktop | img_url: "1920x1080" }}';
  
  if(currentFallback) {
    currentFallback.style.backgroundImage = `url('${fallbackUrl}')`;
    currentFallback.style.display = 'block';
  }

  // STEP 2: Load iframes after a delay to prevent LCP impact
  function loadIframe() {
    if(currentIframe && currentIframeContainer) {
      const videoSrc = currentIframe.getAttribute('data-src');
      
      // For YouTube URLs (example)
      if(videoSrc.includes('youtube.com') || videoSrc.includes('youtu.be')) {
        currentIframe.src = videoSrc + '?autoplay=1&mute=1&loop=1&playlist=' + 
          videoSrc.split('/').pop() + '&controls=0&modestbranding=1&rel=0';
      } 
      // For Vimeo URLs (example)
      else if(videoSrc.includes('vimeo.com')) {
        currentIframe.src = videoSrc + '?autoplay=1&muted=1&loop=1&background=1';
      }
      // For direct video files - we'll use a video player iframe service
      else {
        // Using a placeholder service - replace with your actual video hosting iframe URL
        currentIframe.src = 'https://example-video-service.com/embed?url=' + 
          encodeURIComponent(videoSrc + '.mp4') + '&autoplay=1&muted=1&loop=1';
      }
      
      // Show iframe once loaded
      currentIframe.addEventListener('load', function() {
        currentIframeContainer.classList.add('loaded');
        
        // Hide fallback after iframe is ready
        setTimeout(() => {
          if(currentFallback) {
            currentFallback.classList.remove('lcp-priority');
            currentFallback.style.opacity = '0';
            setTimeout(() => {
              currentFallback.style.display = 'none';
            }, 500);
          }
        }, 1000);
      });
    }
  }

  // Wait for page to fully load before loading iframes
  if (document.readyState === 'complete') {
    setTimeout(loadIframe, 2000);
  } else {
    window.addEventListener('load', function() {
      setTimeout(loadIframe, 2000);
    });
  }

  // Play/Pause logic for iframes
  playPauseBtn?.addEventListener('click', function() {
    if(!currentIframe || !currentIframe.contentWindow) return;
    
    // This would need to be implemented based on your video hosting service's API
    // For example, with YouTube iframe API:
    // player.pauseVideo() or player.playVideo()
    
    // Toggle fallback visibility as visual feedback
    if(currentFallback.style.display === 'none') {
      currentFallback.style.display = 'block';
      currentFallback.style.opacity = '1';
      playIcon.style.display = 'block';
      pauseIcon.style.display = 'none';
    } else {
      currentFallback.style.opacity = '0';
      setTimeout(() => {
        currentFallback.style.display = 'none';
      }, 500);
      playIcon.style.display = 'none';
      pauseIcon.style.display = 'block';
    }
  });

  // Mute/Unmute logic for iframes
  muteUnmuteBtn?.addEventListener('click', function() {
    if(!currentIframe || !currentIframe.contentWindow) return;
    
    // This would need to be implemented based on your video hosting service's API
    // For example, with YouTube iframe API:
    // if(player.isMuted()) { player.unMute(); } else { player.mute(); }
    
    // Toggle mute icons as visual feedback
    if(unmuteIcon.style.display === 'none') {
      unmuteIcon.style.display = 'block';
      muteIcon.style.display = 'none';
    } else {
      unmuteIcon.style.display = 'none';
      muteIcon.style.display = 'block';
    }
  });

  // Handle responsive changes
  window.addEventListener('resize', function() {
    // You might want to reload iframes on orientation change for mobile
    if(window.innerWidth <= 768 !== isMobile) {
      location.reload();
    }
  });
});
</script>