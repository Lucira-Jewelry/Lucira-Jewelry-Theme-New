<style>
    section.video-banner { height: 100vh; position: relative; background-color: #000; }
    .video-banner__video { position: absolute; top: 50%; left: 50%; width: 100%; height: 100%; object-fit: cover; transform: translate(-50%,-50%); z-index: 1; cursor: pointer; }
    .video-banner__overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0); z-index: 2; }
    .video-banner__content { position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%); text-align: center; color: #fff; z-index: 2; width: 100% !important; max-width: 800px; padding: 0 20px; }
    .video-banner__title { font-size: 24px; font-weight: 400; font-family: 'Futura Std', sans-serif !important; color: #fff; letter-spacing: 1px; margin-bottom: 16px; text-shadow: 2px 2px 4px rgb(0 0 0 / 28%); margin-top: 0; margin-bottom: 4px; text-decoration: underline; text-underline-offset: 5px; text-decoration-thickness: 1px; }
    .video-banner__subtitle { font-size: 18px; font-weight: 400; letter-spacing: 1px; opacity: 1; text-shadow: 1px 1px 2px rgb(0 0 0 / 37%); margin-bottom: 0; margin-top: 0; color: #fff; }
    
    .video-banner__controls { position: absolute; bottom: 30px; right: 30px; z-index: 3; }
    .video-banner__play-pause { background: rgba(255,255,255,.9); border: none; border-radius: 50%; width: 40px; height: 40px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .3s ease; backdrop-filter: blur(10px); box-shadow: 0 4px 20px rgba(0,0,0,.1); }
    .video-banner__play-pause:hover { background: rgba(255,255,255,1); transform: scale(1.1); box-shadow: 0 6px 25px rgba(0,0,0,.15); }
    .video-banner__play-pause svg { width: 24px; height: 24px; fill: #333; }
    
    .video-banner__content a { text-decoration: none; }
    
    .video-banner__audio-controls { position: absolute; bottom: 30px; left: 30px; z-index: 3; }
    .video-banner__mute-unmute { background: rgba(255,255,255,.9); border: none; border-radius: 50%; width: 40px; height: 40px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .3s ease; backdrop-filter: blur(10px); box-shadow: 0 4px 20px rgba(0,0,0,.1); }
    .video-banner__mute-unmute:hover { background: rgba(255,255,255,1); transform: scale(1.1); box-shadow: 0 6px 25px rgba(0,0,0,.15); }
    .video-banner__mute-unmute svg { width: 24px; height: 24px; fill: #333; }
    
    /* Optimized Fallback Styles */
    .video-banner__fallback { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-size: cover; background-position: center; background-repeat: no-repeat; z-index: 2; cursor: pointer; transition: opacity 0.4s ease-in-out; }

    @media (max-width: 768px) {
        section.video-banner { height: 390px; }
        .video-banner { min-height: 300px; }
        .video-banner__title { font-size: 2.5rem; margin-bottom: 8px; }
        .video-banner__subtitle { font-size: 1.3rem; margin-top: 8px; }
        .video-banner__content { bottom: 40px; padding: 0; }
        .video-banner__controls { bottom: 20px; right: 20px; }
        .video-banner__play-pause { width: 40px; height: 40px; }
        .video-banner__play-pause svg { width: 20px; height: 20px; }
        .video-banner__audio-controls { bottom: 20px; left: 20px; }
        .video-banner__mute-unmute { width: 40px; height: 40px; }
        .video-banner__mute-unmute svg { width: 20px; height: 20px; }
    }
    
    @media (max-width: 390px) {
        .brad-mob-logo { max-width: 80%; }
    }
    
    @media (min-width: 1400px) {
        .video-banner__title { font-size: 24px; }
        .video-banner__subtitle { font-size: 18px; }
    }
    
    @media only screen and (min-width: 410px) and (max-width: 767px) {
        section.video-banner { height: 90vh !important; }
    }
    /* Note: Removed the old media queries that used display:none for videos */
</style>

<section class="video-banner" style="min-height: {{ section.settings.min_height }}px;" data-promo-name="{{ section.settings.title | escape }}">

  <div id="videoFallback" class="video-banner__fallback" 
       style="background-image: url('{{ section.settings.fallback_image_desktop | img_url: "1920x" }}');"
       {% if section.settings.redirect_url != blank %}data-redirect-url="{{ section.settings.redirect_url }}"{% endif %}>
  </div>

  <video class="video-banner__video" 
         id="mainVideoBanner"
         muted 
         {% if section.settings.loop_video %}loop{% endif %}
         playsinline
         preload="metadata" 
         {% if section.settings.redirect_url != blank %}data-redirect-url="{{ section.settings.redirect_url }}"{% endif %}>
         Your browser does not support the video tag.
  </video>

  <div class="video-banner__content">
    {% if section.settings.title != blank %}
      <a href="{{ section.settings.redirect_url | default: '#' }}" data-promo-name="{{ section.settings.title | escape }}">
        <div class="video-banner__title">{{ section.settings.title }}</div>
      </a>
    {% endif %}
    {% if section.settings.subtitle != blank %}
      <a href="{{ section.settings.redirect_url | default: '#' }}" data-promo-name="{{ section.settings.title | escape }}">
        <p class="video-banner__subtitle">{{ section.settings.subtitle }}</p>
      </a>
    {% endif %}
  </div>

  {% if section.settings.show_controls %}
    <div class="video-banner__controls">
      <button class="video-banner__play-pause" id="playPauseBtn" aria-label="Play/Pause video">
        <svg class="pause-icon" viewBox="0 0 24 24" style="display: none;">
          <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
        </svg>
        <svg class="play-icon" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
      </button>
    </div>
  {% endif %}

  {% if section.settings.show_controls %}
    <div class="video-banner__audio-controls">
      <button class="video-banner__mute-unmute" id="muteUnmuteBtn" aria-label="Mute/Unmute video">
        <svg class="unmute-icon" viewBox="0 0 24 24">
          <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
        </svg>
        <svg class="mute-icon" viewBox="0 0 24 24" style="display: none;">
          <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
        </svg>
      </button>
    </div>
  {% endif %}
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const video = document.getElementById('mainVideoBanner');
  const fallback = document.getElementById('videoFallback');
  const videoBannerSection = document.querySelector('section.video-banner');
  
  const playPauseBtn = document.getElementById('playPauseBtn');
  const muteUnmuteBtn = document.getElementById('muteUnmuteBtn');
  const playIcon = playPauseBtn?.querySelector('.play-icon');
  const pauseIcon = playPauseBtn?.querySelector('.pause-icon');
  const muteIcon = muteUnmuteBtn?.querySelector('.mute-icon');
  const unmuteIcon = muteUnmuteBtn?.querySelector('.unmute-icon');

  if (!video) return;

  const isMobile = window.innerWidth <= 768;

  // Initialize dataLayer
  window.dataLayer = window.dataLayer || [];

  // --- 1. Dynamic Asset Routing ---
  // Get URLs directly from Liquid
  const desktopUrl = "{{ section.settings.desktop_video.sources[1].url }}";
  // Fallback to desktop video if mobile is empty
  const mobileUrl = "{% if section.settings.mobile_video != blank %}{{ section.settings.mobile_video.sources[1].url }}{% else %}{{ section.settings.desktop_video.sources[1].url }}{% endif %}";
  
  const mobilePoster = "{{ section.settings.fallback_image_mobile | img_url: '768x' }}";

  // Swap to mobile poster immediately if needed
  if (isMobile && mobilePoster && mobilePoster.indexOf('no-image') === -1) {
    fallback.style.backgroundImage = `url('${mobilePoster}')`;
  }

  // Inject only the necessary video source
  const source = document.createElement('source');
  source.src = isMobile && mobileUrl ? mobileUrl : desktopUrl;
  source.type = 'video/mp4';
  video.appendChild(source);

  // Tell browser to fetch metadata
  video.load();

  // --- 2. Performance-First Autoplay & Transition ---
  video.addEventListener('loadeddata', () => {
    // Attempt play immediately
    video.play().then(() => {
      // Fade out fallback smoothly once video is playing
      fallback.style.opacity = '0';
      setTimeout(() => { fallback.style.display = 'none'; }, 400);
      updatePlayIcons();
    }).catch(err => {
      console.log('Autoplay prevented by browser:', err);
      // Keep fallback visible, user will have to manually interact
      updatePlayIcons();
    });
  });

  // --- 3. Click Tracking & Redirects ---
  const handleRedirect = (e, targetElement) => {
    // Prevent redirect if clicking controls
    if(e.target.closest('.video-banner__controls') || e.target.closest('.video-banner__audio-controls')) return;
    
    const redirectUrl = targetElement.dataset.redirectUrl;
    if (redirectUrl) {
      const promoName = videoBannerSection?.dataset.promoName || "Video Banner";
      window.dataLayer.push({
        event: "promoClick",
        promoClick: {
          promo_name: promoName,
          creative_name: "Homepage Video Banner",
          promo_position: "homepage_top"
        },
        "gtm.uniqueEventId": Math.floor(Math.random() * 10000)
      });
      window.location.href = redirectUrl;
    }
  };

  video.addEventListener('click', (e) => handleRedirect(e, video));
  if (fallback) fallback.addEventListener('click', (e) => handleRedirect(e, fallback));

  document.querySelectorAll('.video-banner__content a').forEach(link => {
    link.addEventListener('click', function() {
      const promoName = this.dataset.promoName || videoBannerSection?.dataset.promoName || "Video Banner";
      window.dataLayer.push({
        event: "promoClick",
        promoClick: {
          promo_name: promoName,
          creative_name: "Homepage Video Banner",
          promo_position: "homepage_top"
        },
        "gtm.uniqueEventId": Math.floor(Math.random() * 10000)
      });
    });
  });

  // --- 4. Video Controls Logic ---
  function updatePlayIcons() {
    if (video.paused) {
      if(playIcon) playIcon.style.display = 'block';
      if(pauseIcon) pauseIcon.style.display = 'none';
    } else {
      if(playIcon) playIcon.style.display = 'none';
      if(pauseIcon) pauseIcon.style.display = 'block';
    }
  }

  function updateMuteIcons() {
    if (video.muted) {
      if(unmuteIcon) unmuteIcon.style.display = 'block';
      if(muteIcon) muteIcon.style.display = 'none';
    } else {
      if(unmuteIcon) unmuteIcon.style.display = 'none';
      if(muteIcon) muteIcon.style.display = 'block';
    }
  }

  playPauseBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (video.paused) {
      video.play().catch(err => console.log('Play failed:', err));
    } else {
      video.pause();
    }
  });

  muteUnmuteBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    video.muted = !video.muted;
    updateMuteIcons();
  });

  video.addEventListener('play', updatePlayIcons);
  video.addEventListener('pause', updatePlayIcons);
  video.addEventListener('volumechange', updateMuteIcons);
  
  // Stop at last frame if loop is disabled
  video.addEventListener('ended', () => {
    video.pause();
    updatePlayIcons();
  });

});
</script>


{% schema %}
{
  "name": "Video Banner",
  "settings": [
    {
      "type": "header",
      "content": "Video Settings"
    },
    {
      "type": "video",
      "id": "desktop_video",
      "label": "Desktop Video"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile Video (Optional)"
    },
    {
      "type": "image_picker",
      "id": "fallback_image_desktop",
      "label": "Desktop Fallback Image"
    },
    {
      "type": "image_picker",
      "id": "fallback_image_mobile",
      "label": "Mobile Fallback Image"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show Play/Pause & Audio Controls",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop_video",
      "label": "Loop Video",
      "default": true,
      "info": "If disabled, video will stop at the end and show fallback image"
    },
    {
      "type": "header",
      "content": "Redirect Settings"
    },
    {
      "type": "url",
      "id": "redirect_url",
      "label": "Click Redirect URL",
      "info": "URL to redirect when video or title/subtitle is clicked. Example: /collections/hexa"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Exquisite Jewelry Collection"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Crafted with passion, designed for elegance"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum Height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 400
    }
  ],
  "presets": [
    {
      "name": "Home Video Banner",
      "settings": {
        "title": "Exquisite Jewelry Collection",
        "subtitle": "Crafted with passion, designed for elegance",
        "autoplay": true,
        "show_controls": true,
        "loop_video": true,
        "min_height": 400,
        "redirect_url": "/collections/hexa"
      }
    }
  ]
}
{% endschema %}