<style>

    section.video-banner {height: 100vh; position: relative;}
    .video-banner__video{position:absolute;top:50%;left:50%;width:100%;height:100%;object-fit:cover;transform:translate(-50%,-50%);z-index:1}
    .video-banner__overlay{position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0);z-index:2}
    .video-banner__content{position:absolute;bottom:30px;left:50%;transform:translateX(-50%);text-align:center;color:#fff;z-index:2;width:100%!important;max-width:800px;padding:0 20px}
    .video-banner__title{font-size:3.5rem;font-weight:400;font-family:'Futura Std',sans-serif!important;color:#fff;letter-spacing:1px;margin-bottom:16px;text-shadow:2px 2px 4px rgb(0 0 0 / 28%);margin-top:0; margin-bottom: 4px;    text-decoration: underline; text-underline-offset: 5px; text-decoration-thickness: 1px;}
    .video-banner__subtitle{font-size:16px;font-weight:400;letter-spacing:1px;opacity:1;text-shadow:1px 1px 2px rgb(0 0 0 / 37%);margin-bottom:0; margin-top: 0; color: #fff;}
    .video-banner__controls{position:absolute;bottom:30px;right:30px;z-index:2}
    .video-banner__play-pause{background:rgba(255,255,255,.9);border:none;border-radius:50%;width:40px;height:40px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .3s ease;backdrop-filter:blur(10px);box-shadow:0 4px 20px rgba(0,0,0,.1)}
    .video-banner__play-pause:hover{background:rgba(255,255,255,1);transform:scale(1.1);box-shadow:0 6px 25px rgba(0,0,0,.15)}
    .video-banner__play-pause svg{width:24px;height:24px;fill:#333}
    .video-banner__content a { text-decoration: none; }
    .video-banner__audio-controls{position:absolute;bottom:30px;left:30px;z-index:2}
    .video-banner__mute-unmute{background:rgba(255,255,255,.9);border:none;border-radius:50%;width:40px;height:40px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .3s ease;backdrop-filter:blur(10px);box-shadow:0 4px 20px rgba(0,0,0,.1)}
    .video-banner__mute-unmute:hover{background:rgba(255,255,255,1);transform:scale(1.1);box-shadow:0 6px 25px rgba(0,0,0,.15)}
    .video-banner__mute-unmute svg{width:24px;height:24px;fill:#333}
    

    @media (max-width:768px){
    {% comment %} sticky-header.header-wrapper .header__icon.header__icon--search svg path {fill: #FFF;}
    sticky-header.header-wrapper:hover .header__icon.header__icon--search svg path {fill: #333;}
    sticky-header.header-wrapper:hover header .header__icon {color: #333 !important;}
    sticky-header:hover svg-wrapper svg {color: #333 !important;}
    .header__heading-logo-wrapper {color: #ffffff !important;} {% endcomment %}

    section.video-banner {height: 85vh;}
    .video-banner{min-height:300px;}
    .video-banner__title{font-size:2.5rem;margin-bottom:8px}
    .video-banner__subtitle{font-size:1.3rem;margin-top:8px}
    .video-banner__content{bottom:40px;padding:0}
    .video-banner__controls{bottom:20px;right:20px}
    .video-banner__play-pause{width:50px;height:50px}
    .video-banner__play-pause svg{width:20px;height:20px}
    .video-banner__play-pause{width:40px;height:40px}
    .video-banner__audio-controls{bottom:20px;left:20px}
    .video-banner__mute-unmute{width:40px;height:40px}
    .video-banner__mute-unmute svg{width:20px;height:20px}

    
    }
    @media (max-width:390px){
    .brad-mob-logo{max-width:80%}
    }
    @media (min-width:1400px){
    .video-banner__title{font-size:4rem}
    .video-banner__subtitle{font-size:1.4rem}
    }
    .video-banner__fallback{position:absolute;top:0;left:0;width:100%;height:100%;background-size:cover;background-position:center;background-repeat:no-repeat;z-index:0}

  /* Updated mobile-specific video handling */
  {% if section.settings.mobile_video != blank %}
    /* Only hide desktop video on mobile if mobile video exists */
    @media (max-width: 768px) {
      .video-banner__video-desktop {
        display: none;
      }
    }
    
    @media (min-width: 769px) {
      .video-banner__video-mobile {
        display: none;
      }
    }
  {% else %}
    /* If no mobile video, hide the mobile fallback on desktop */
    @media (min-width: 769px) {
      .video-banner__video-mobile {
        display: none;
      }
    }
  {% endif %}
  @media only screen and (min-width:410px) and (max-width:767px;){
      section.video-banner {
          height: 90vh !important;
      }
  }
</style>

<section class="video-banner" style="min-height: {{ section.settings.min_height }}px;">

  <!-- Fallback Images (shown immediately) -->
  <div id="videoBannerFallbackDesktop" class="video-banner__fallback video-banner__fallback-desktop" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; display: none;"></div>
  <div id="videoBannerFallbackMobile" class="video-banner__fallback video-banner__fallback-mobile" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; display: none;"></div>

  <!-- Video Elements -->
  {% assign desktop_video = section.settings.desktop_video %}
  {% assign mobile_video = section.settings.mobile_video %}

  <!-- Desktop Video -->
  {% if desktop_video != blank %}
    <video class="video-banner__video video-banner__video-desktop" 
           id="videoBannerDesktop"
           muted 
           loop
           playsinline
           preload="none" loading="lazy">
      <source src="{{ desktop_video.sources[1].url }}" type="video/mp4">
      Your browser does not support the video tag.
    </video>
  {% endif %}

  <!-- Mobile Video -->
  {% if mobile_video != blank %}
    <video class="video-banner__video video-banner__video-mobile" 
           id="videoBannerMobile"
           muted 
           {% if section.settings.loop_video %}loop{% endif %}
           playsinline
           preload="none" loading="lazy">
      <source src="{{ mobile_video.sources[1].url }}" type="video/mp4">
      Your browser does not support the video tag.
    </video>
  {% elsif desktop_video != blank %}
    <!-- Fallback: Use desktop video on mobile if no mobile video is set -->
    <video class="video-banner__video video-banner__video-mobile" 
           id="videoBannerMobileFallback"
           muted 
           {% if section.settings.loop_video %}loop{% endif %}
           playsinline
           preload="none" loading="lazy">
      <source src="{{ desktop_video.sources[1].url }}" type="video/mp4">
      Your browser does not support the video tag.
    </video>
  {% endif %}

  <!-- Content -->
  <div class="video-banner__content">
    {% if section.settings.title != blank %}
      <a href="https://www.lucirajewelry.com/collections/hexa">
        <div class="video-banner__title">{{ section.settings.title }}</div>
      </a>
    {% endif %}
    {% if section.settings.subtitle != blank %}
      <a href="https://www.lucirajewelry.com/collections/hexa">
        <p class="video-banner__subtitle">{{ section.settings.subtitle }}</p>
      </a>
    {% endif %}
  </div>

  <!-- Play/Pause Controls -->
  {% if section.settings.show_controls %}
    <div class="video-banner__controls">
      <button class="video-banner__play-pause" id="playPauseBtn" aria-label="Play/Pause video">
        <svg class="pause-icon" viewBox="0 0 24 24" style="display: none;">
          <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
        </svg>
        <svg class="play-icon" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
      </button>
    </div>
  {% endif %}

  <!-- Audio Controls -->
  {% if section.settings.show_controls %}
    <div class="video-banner__audio-controls">
      <button class="video-banner__mute-unmute" id="muteUnmuteBtn" aria-label="Mute/Unmute video">
        <svg class="unmute-icon" viewBox="0 0 24 24">
          <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
        </svg>
        <svg class="mute-icon" viewBox="0 0 24 24" style="display: none;">
          <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
        </svg>
      </button>
    </div>
  {% endif %}
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const desktopVideo = document.getElementById('videoBannerDesktop');
  const mobileVideo = document.getElementById('videoBannerMobile') || document.getElementById('videoBannerMobileFallback');
  const fallbackDesktop = document.getElementById('videoBannerFallbackDesktop');
  const fallbackMobile = document.getElementById('videoBannerFallbackMobile');
  const playPauseBtn = document.getElementById('playPauseBtn');
  const muteUnmuteBtn = document.getElementById('muteUnmuteBtn');
  const playIcon = playPauseBtn?.querySelector('.play-icon');
  const pauseIcon = playPauseBtn?.querySelector('.pause-icon');
  const muteIcon = muteUnmuteBtn?.querySelector('.mute-icon');
  const unmuteIcon = muteUnmuteBtn?.querySelector('.unmute-icon');

  const isMobile = window.innerWidth <= 768;
  const currentVideo = isMobile ? mobileVideo : desktopVideo;
  const currentFallback = isMobile ? fallbackMobile : fallbackDesktop;

  // STEP 1: Always load fallback image immediately
  const fallbackUrl = isMobile ? '{{ section.settings.fallback_image_mobile | img_url: "1080x1920" }}' : '{{ section.settings.fallback_image_desktop | img_url: "1920x1080" }}';
  if(currentFallback) {
    currentFallback.style.backgroundImage = `url('${fallbackUrl}')`;
    currentFallback.style.backgroundSize = 'cover';
    currentFallback.style.backgroundPosition = 'center';
    currentFallback.style.width = '100%';
    currentFallback.style.height = '100%';
    currentFallback.style.display = 'block';
  }

  if(currentVideo){
    // Ensure autoplay disabled initially
    currentVideo.autoplay = false;
    currentVideo.pause();

    // Hide fallback only when video actually starts playing
    currentVideo.addEventListener('playing', () => {
      if(currentFallback) {
        currentFallback.style.display = 'none';
        currentVideo.style.zIndex = '1';
      }
    });

    // Show fallback if video errors
    currentVideo.addEventListener('error', () => {
      if(currentFallback) currentFallback.style.display = 'block';
    });

    // Show fallback if paused
    currentVideo.addEventListener('pause', () => {
      if(currentFallback) currentFallback.style.display = 'block';
    });

    // Handle video end when not looping - pause at last frame
    currentVideo.addEventListener('ended', () => {
      // Keep video visible at last frame, don't show fallback
      currentVideo.pause();
      updatePlayIcons();
    });
  }

  // STEP 2: Delay autoplay until 5s after page fully loaded
  window.addEventListener('load', () => {
    setTimeout(() => {
      if(currentVideo && currentVideo.paused){
        currentVideo.play().catch(err => console.log('Autoplay failed:', err));
      }
    }, 500);
  });

  // Play/Pause logic
  playPauseBtn?.addEventListener('click', () => {
    if(!currentVideo) return;
    if(currentVideo.paused){
      currentVideo.play().catch(err => console.log('Play failed:', err));
    } else {
      currentVideo.pause();
    }
  });

  // Mute/Unmute logic
  muteUnmuteBtn?.addEventListener('click', () => {
    if(!currentVideo) return;
    currentVideo.muted = !currentVideo.muted;
    updateMuteIcons();
  });

  function updatePlayIcons(){
    if(!currentVideo) return;
    if(currentVideo.paused){
      playIcon.style.display = 'block';
      pauseIcon.style.display = 'none';
    } else {
      playIcon.style.display = 'none';
      pauseIcon.style.display = 'block';
    }
  }

  function updateMuteIcons(){
    if(!currentVideo) return;
    if(currentVideo.muted){
      unmuteIcon.style.display = 'block';
      muteIcon.style.display = 'none';
    } else {
      unmuteIcon.style.display = 'none';
      muteIcon.style.display = 'block';
    }
  }

  [desktopVideo, mobileVideo].forEach(video => {
    if(video){
      video.addEventListener('play', updatePlayIcons);
      video.addEventListener('pause', updatePlayIcons);
      video.addEventListener('volumechange', updateMuteIcons);
      video.addEventListener('loadeddata', () => {
        updatePlayIcons();
        updateMuteIcons();
      });
    }
  });

  window.addEventListener('resize', () => {
    updatePlayIcons();
    updateMuteIcons();
  });
});
</script>


{% schema %}
{
  "name": "Video Banner",
  "settings": [
    {
      "type": "header",
      "content": "Video Settings"
    },
    {
      "type": "video",
      "id": "desktop_video",
      "label": "Desktop Video"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile Video (Optional)"
    },
    {
      "type": "image_picker",
      "id": "fallback_image_desktop",
      "label": "Desktop Fallback Image"
    },
    {
      "type": "image_picker",
      "id": "fallback_image_mobile",
      "label": "Mobile Fallback Image"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show Play/Pause & Audio Controls",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop_video",
      "label": "Loop Mobile Video",
      "default": true,
      "info": "If disabled, mobile video will pause at the end. Desktop video always loops."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Exquisite Jewelry Collection"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Crafted with passion, designed for elegance"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum Height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 400
    }
  ],
  "presets": [
    {
      "name": "Home Video Banner",
      "settings": {
        "title": "Exquisite Jewelry Collection",
        "subtitle": "Crafted with passion, designed for elegance",
        "autoplay": true,
        "show_controls": true,
        "loop_video": true,
        "min_height": 400
      }
    }
  ]
}
{% endschema %}