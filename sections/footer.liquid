      window.addEventListener('scroll', requestTick, { passive: true });
      
      // Initial check
      handleScroll();
    } else {
      // For browsers that support animation-timeline, we need to override with JS
      // since CSS animations don't support direction-based logic
      backToTopBtn.style.animation = 'none'; // Disable CSS animation
      
      function handleScrollModern() {
        const currentScroll = window.pageYOffset || document.documentElement.scrollTop;
        
        if (currentScroll > showButtonThreshold) {
          if (currentScroll < lastScrollTop) {
            // Scrolling UP
            isScrollingUp = true;
            
            // Calculate how much we've scrolled up
            const scrollUpDistance = lastScrollTop - currentScroll;
            
            // Show button only if we've scrolled up at least the threshold amount
            if (scrollUpDistance >= scrollUpThreshold && !backToTopBtn.classList.contains('visible')) {
              backToTopBtn.style.opacity = '1';
              backToTopBtn.style.visibility = 'visible';
              backToTopBtn.style.transform = 'scale(1) translateY(0)';
              backToTopBtn.classList.add('visible');
            }
          } else if (currentScroll > lastScrollTop) {
            // Scrolling DOWN
            isScrollingUp = false;
            
            // Hide button when scrolling down
            if (backToTopBtn.classList.contains('visible')) {
              backToTopBtn.style.opacity = '0';
              backToTopBtn.style.visibility = 'hidden';
              backToTopBtn.style.transform = 'scale(0.85) translateY(25px)';
              backToTopBtn.classList.remove('visible');
            }
          }
        } else {
          // At the top of the page - hide button
          if (backToTopBtn.classList.contains('visible')) {
            backToTopBtn.style.opacity = '0';
            backToTopBtn.style.visibility = 'hidden';
            backToTopBtn.style.transform = 'scale(0.85) translateY(25px)';
            backToTopBtn.classList.remove('visible');
          }
        }
        
        lastScrollTop = currentScroll <= 0 ? 0 : currentScroll;
        ticking = false;
      }
      
      function requestTickModern() {
        if (!ticking) {
          window.requestAnimationFrame(handleScrollModern);
          ticking = true;
        }
      }
      
      window.addEventListener('scroll', requestTickModern, { passive: true });
      
      // Initial check
      handleScrollModern();
    }
    
    // Smooth scroll to top on click
    backToTopLink.addEventListener('click', function(e) {
      e.preventDefault();
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
    
    // Optional: Hide button immediately when user clicks and starts scrolling to top
    backToTopLink.addEventListener('click', function() {
      setTimeout(() => {
        backToTopBtn.classList.remove('visible');
        if (supportsScrollTimeline) {
          backToTopBtn.style.opacity = '0';
          backToTopBtn.style.visibility = 'hidden';
          backToTopBtn.style.transform = 'scale(0.85) translateY(25px)';
        }
      }, 300); // Slight delay to allow smooth scroll to start
    });
    
    // Optional: Reset scroll tracking when page loads at top
    window.addEventListener('load', function() {
      lastScrollTop = window.pageYOffset || document.documentElement.scrollTop;
    });
    
  })();
</script>
{% endif %}

