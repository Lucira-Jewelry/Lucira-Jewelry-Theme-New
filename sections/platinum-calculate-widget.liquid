<script>
  $(document).ready(function () {
  let selectedPurity = 999; // for platinum, usually 999 (99.9% pure)

  function getRateByPurity(baseRate, purity) {
    const perGramRate = baseRate / 10; // baseRate is for 10 gm → convert to 1 gm
    return (perGramRate * (purity / 1000)).toFixed(2); // platinum purity is in ‰ (per mille)
  }

  const baseRate = parseFloat($('#platinumRate').data('base')); // attach base platinum rate in HTML

  function updateRateDisplay(purity) {
    const calculatedRate = purity === 999
      ? (baseRate / 10).toFixed(2)
      : getRateByPurity(baseRate, purity);

    $('.platinum-calc__label--desktop').text(`Today's Standard Rate of Pt${purity}`);
    $('.platinum-calc__label--mobile').text(`Today's Pt${purity} Rate`);
    $('#platinumRate').text('₹ ' + parseFloat(calculatedRate).toLocaleString('en-IN'));
  }

  updateRateDisplay(selectedPurity);

  // Fixed: Changed from .platinum-calc__purity to .platinum-calc__karat
  $('.platinum-calc__karat').on('click', function () {
    $('.platinum-calc__karat').removeClass('platinum-calc__karat--active');
    $(this).addClass('platinum-calc__karat--active');

    // Extract purity number from button text (e.g., "Pt999" → 999)
    selectedPurity = parseInt($(this).text().replace('Pt', ''));
    updateRateDisplay(selectedPurity);
    $('#platinumCalcResult').hide();
  });

  $('.platinum-calc__button').on('click', function () {
    const weight = parseFloat($('#weightInput').val());

    if (isNaN(weight) || weight <= 0) {
      alert('Please enter a valid weight.');
      return;
    }

    const currentRate = selectedPurity === 999
      ? baseRate / 10
      : getRateByPurity(baseRate, selectedPurity);

    const total = (weight * currentRate).toFixed(2);

    $('#platinumValueOutput').text(`₹${parseFloat(total).toLocaleString('en-IN')}`);
    $('#platinumCalcResult').show();
    });
  });
</script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    function updateDateTime() {
      const today = new Date();

      // Format date
      const formattedDate = today.toLocaleDateString('en-IN', {
        day: 'numeric',
        month: 'short',
        year: 'numeric',
      });

      // Format time (12-hour format with seconds + AM/PM)
      const formattedTime = today.toLocaleTimeString('en-IN', {
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        hour12: true,
      });

      // Combine date + "Updated on - " + time
      const dateTime =  `Updated on - ${formattedDate},  ${formattedTime}`;

      // Update DOM safely
      const el1 = document.getElementById('rate-today-date');
      const el2 = document.getElementById('rate-today-date-2');

      if (el1) el1.textContent = dateTime;
      if (el2) el2.textContent = dateTime;
    }

    // Run immediately
    updateDateTime();

    // Update every second
    setInterval(updateDateTime, 1000);
  });
</script>

<script>

  function replacePlatinumShortcodes() {
    const baseEl = document.querySelector('[data-base]');
    if (!baseEl) return;

    const baseRate = parseFloat(baseEl.getAttribute('data-base'));
    if (isNaN(baseRate)) return;

    const ratePerGram = baseRate / 10;

    // Helper function to add ordinal suffix to day
    function getOrdinalSuffix(day) {
      if (day > 3 && day < 21) return 'th';
      switch (day % 10) {
        case 1: return 'st';
        case 2: return 'nd';
        case 3: return 'rd';
        default: return 'th';
      }
    }

    // Get current date in various formats
    const today = new Date();
    const day = today.getDate();
    const ordinalDay = day + getOrdinalSuffix(day);
    
    const dateFormats = {
      "[current_date]": today.toLocaleDateString('en-IN', {
        day: 'numeric',
        month: 'long',
        year: 'numeric'
      }), // e.g., "25 August 2025"
      
      "[current_date_short]": today.toLocaleDateString('en-IN', {
        day: 'numeric',
        month: 'short',
        year: 'numeric'
      }), // e.g., "25 Aug 2025"
      
      "[current_date_timestamp]": `${ordinalDay} ${today.toLocaleDateString('en-IN', { month: 'short' })} ${today.getFullYear()}, ${today.toLocaleTimeString('en-IN', { hour12: false })}`, // e.g., "25th Aug 2025, 18:36:45"
      
      "[current_date_midnight]": `${ordinalDay} ${today.toLocaleDateString('en-IN', { month: 'short' })} ${today.getFullYear()}, 00:00:00`, // e.g., "25th Aug 2025, 00:00:00"
      
      "[current_date_time]": `${ordinalDay} ${today.toLocaleDateString('en-IN', { month: 'short' })} ${today.getFullYear()}, ${today.toLocaleTimeString('en-IN', { hour12: false })}`, // e.g., "25th Aug 2025, 14:30:45"
      
      "[current_time]": today.toLocaleTimeString('en-IN', { hour12: false }), // e.g., "14:30:45"
      
      "[current_time_12h]": today.toLocaleTimeString('en-IN', { hour12: true }), // e.g., "2:30:45 PM"
      
      "[current_date_dmy]": today.toLocaleDateString('en-GB'), // e.g., "25/08/2025"
      
      "[current_date_mdy]": today.toLocaleDateString('en-US'), // e.g., "08/25/2025"
      
      "[current_day]": today.toLocaleDateString('en-IN', { weekday: 'long' }), // e.g., "Monday"
      
      "[current_month]": today.toLocaleDateString('en-IN', { month: 'long' }), // e.g., "August"
      
      "[current_year]": today.getFullYear().toString(), // e.g., "2025"
    };

    // Platinum rates for different purities and weights
    const platinum999PerGram = Math.round(ratePerGram * (999 / 1000));
    const platinum950PerGram = Math.round(ratePerGram * (950 / 1000));
    const platinum900PerGram = Math.round(ratePerGram * (900 / 1000));
    const platinum850PerGram = Math.round(ratePerGram * (850 / 1000));

    const rates = {
      // Raw rates (numbers only) for different purities
      "[platinum_rate_999]": platinum999PerGram,
      "[platinum_rate_950]": platinum950PerGram,
      "[platinum_rate_900]": platinum900PerGram,
      "[platinum_rate_850]": platinum850PerGram,
      
      // Formatted with currency symbol - per gram
      "[platinum_price_999]": `₹${platinum999PerGram.toLocaleString('en-IN')}`,
      "[platinum_price_950]": `₹${platinum950PerGram.toLocaleString('en-IN')}`,
      "[platinum_price_900]": `₹${platinum900PerGram.toLocaleString('en-IN')}`,
      "[platinum_price_850]": `₹${platinum850PerGram.toLocaleString('en-IN')}`,

      // Weight-based pricing for 999 purity (most common)
      "[platinum_price_1g]": `₹${platinum999PerGram.toLocaleString('en-IN')}`,
      "[platinum_price_10g]": `₹${(platinum999PerGram * 10).toLocaleString('en-IN')}`,
      "[platinum_price_100g]": `₹${(platinum999PerGram * 100).toLocaleString('en-IN')}`,
      "[platinum_price_1kg]": `₹${(platinum999PerGram * 1000).toLocaleString('en-IN')}`,

      // Raw numbers without currency symbol
      "[platinum_rate_1g]": platinum999PerGram,
      "[platinum_rate_10g]": platinum999PerGram * 10,
      "[platinum_rate_100g]": platinum999PerGram * 100,
      "[platinum_rate_1kg]": platinum999PerGram * 1000,

      // Weight-based pricing for different purities
      "[platinum_price_950_1g]": `₹${platinum950PerGram.toLocaleString('en-IN')}`,
      "[platinum_price_950_10g]": `₹${(platinum950PerGram * 10).toLocaleString('en-IN')}`,
      "[platinum_price_950_100g]": `₹${(platinum950PerGram * 100).toLocaleString('en-IN')}`,
      "[platinum_price_950_1kg]": `₹${(platinum950PerGram * 1000).toLocaleString('en-IN')}`,
    };

    // Location shortcodes (you can customize these)
    const locationShortcodes = {
      "[city]": "Mumbai",
      "[state]": "Maharashtra",
      "[country]": "India",
      "[city_state]": "Mumbai, Maharashtra",
    };

    // Combine all shortcodes
    const allShortcodes = { ...dateFormats, ...rates, ...locationShortcodes };

    const containers = document.querySelectorAll("p, li, span, div, h1, h2, h3, h4, h5, h6, td, th");

    containers.forEach((el) => {
      let html = el.innerHTML;
      let changed = false;

      Object.entries(allShortcodes).forEach(([shortcode, replacement]) => {
        if (html.includes(shortcode)) {
          html = html.replaceAll(shortcode, replacement);
          changed = true;
        }
      });

      if (changed) el.innerHTML = html;
    });
  }

  document.addEventListener("DOMContentLoaded", function () {
    replacePlatinumShortcodes();
  });


</script>
