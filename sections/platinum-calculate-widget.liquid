      const today = new Date();

      // Format date
      const formattedDate = today.toLocaleDateString('en-IN', {
        day: 'numeric',
        month: 'short',
        year: 'numeric',
      });

      // Static time: 10:00 AM
      const formattedTime = '10:00 AM';

      // Combine date + "Updated on - " + time
      const dateTime = `Last Updated - ${formattedDate}, ${formattedTime}`;

      // Update DOM safely
      const el1 = document.getElementById('rate-today-date');
      const el2 = document.getElementById('rate-today-date-2');

      if (el1) el1.textContent = dateTime;
      if (el2) el2.textContent = dateTime;
