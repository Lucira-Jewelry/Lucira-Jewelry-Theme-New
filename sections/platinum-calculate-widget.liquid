<div class="platinum-calc-section">
  <div class="page-width">
    <h1 class="platinum-calc__heading">Platinum Rate Today in {{ page.metafields.custom.city_name }}</h1>
  </div>
  <div class="platinum-calc__container">
    <p class="platinum-calc__label">Choose Purity</p>

    <div class="platinum-calc__karat-options">
      <button class="platinum-calc__karat platinum-calc__karat--active">Pt999</button>
      <button class="platinum-calc__karat">Pt950</button>
      <button class="platinum-calc__karat">Pt900</button>
    </div>

    <div class="platinum-calc__inputs">
      <div class="platinum-calc__input-group">
        <label for="weightInput" class="platinum-calc__input-label">In Grams</label>
        <input type="text" id="weightInput" placeholder="Enter Weight" class="platinum-calc__input">
      </div>

      <div class="platinum-calc__input-group">
        <label for="platinumRate" class="platinum-calc__input-label">
          <span class="platinum-calc__label--desktop">Today's Standard Rate of Pt999</span>
          <span class="platinum-calc__label--mobile">Today's Pt999 Rate</span>
        </label>
        <div
            id="platinumRate"
            class="platinum-calc__rate-display"
            data-base="{{ section.settings.rate_today | remove: '₹' | remove: ',' | strip }}"
          >
        </div>
      </div>
    </div>

    <button class="platinum-calc__button">CALCULATE</button>

    <div id="platinumCalcResult" class="platinum-calc__rate-display" style="margin-top: 15px; display:none;">
      <span>Estimated Value: </span><span id="platinumValueOutput"></span>
    </div>

    <p class="platinum-calc__note">*This value is not the final value as Platinum Rate might change*</p>
  </div>
</div>
<div class="investment-section">
  <div class="page-width">
    <div class="investment-section__container">
    <!-- Left Column -->
        <div class="investment-section__container">
          <div class="investment-section__column investment-section__left" style="width:fit-content">
            <h2 class="investment-section__heading">{{ section.settings.investment_heading }}</h2>
            <div class="investment-section__description">
              {{ section.settings.investment_description }}
            </div>
          </div>

          <div class="investment-section__column investment-section__right">
            <h3 class="investment-section__toc-heading">Table of Contents</h3>
            {{ section.settings.investment_quick_links }}
          </div>
        </div>
  </div>
  </div>
</div>
<div class="platinum-table-v2-section">
  <div class="page-width">
    <h2 class="platinum-table-v2-title">Platinum PRICE BREAKDOWN BY WEIGHT</h2>
    <div class="platinum-table-v2-wrapper">
      <table class="platinum-table-v2">
        <thead>
          <tr>
            <th>Purity</th>
            <th>1G</th>
            <th>5G</th>
            <th>10G</th>
            <th>100G</th>
          </tr>
        </thead>
        <tbody>
          {%- assign base_999 = section.settings.rate_today | remove: '₹' | remove: ',' | strip | plus: 0 -%}
          {%- assign rate_per_gram = base_999 | divided_by: 10.0 -%}
          {%- assign purities = "999,950,900" | split: "," -%}
          {%- assign weights = "1,5,10,100" | split: "," -%}
      
          {%- for purity in purities -%}
            {%- assign purity_factor = purity | plus: 0 | divided_by: 1000.0 -%}
            <tr>
              <td>Pt{{ purity }}</td>
              {%- for w in weights -%}
                {%- assign price = rate_per_gram | times: w | times: purity_factor -%}
                <td>₹{{ price | round }}</td>
              {%- endfor -%}
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</div>


