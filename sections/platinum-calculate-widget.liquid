<div class="platinum-widget-section">
  <div class="page-width">
    <div class="wrapper-platinum">
    <div class="platinum-widget__box">
      <!-- Today's Rate -->
      <div class="platinum-widget__block platinum-widget__block--today">
        <p class="platinum-widget__label"><strong>999 Platinum</strong> Rate in {{ page.metafields.custom.city_name }}</p>
        <p class="platinum-widget__price"><span class="platinum-unit">₹</span>{{ section.settings.rate_today -}}<span class="platinum-widget__unit">/10 gm</span>
        </p>
        <p class="platinum-widget__date" id="rate-today-date"></p>
      </div>

      <div class="platinum-widget__divider"></div>

      <!-- Weekly Average -->
      <div class="platinum-widget__block platinum-widget__block--week">
        <p class="platinum-widget__label"><strong>999 Platinum</strong> Rate in  {{ page.metafields.custom.city_name }}</p>
        <p class="platinum-widget__price"><span class="platinum-unit">₹</span>{{ section.settings.rate_avg -}}<span class="platinum-widget__unit">/1 KG</span>
        </p>
        {% comment %} <p class="platinum-widget__date" id="rate-today-date-2"></p> {% endcomment %}
      </div>
    </div>
          <div class="location-selector">
        <div class="location-dropdown">
          <label for="state">State</label>
          <select id="state" name="state">
            {% assign states = "Andaman and Nicobar Islands,Andhra Pradesh,Arunachal Pradesh,Assam,Bihar,Chandigarh,Chhattisgarh,Dadra and Nagar Haveli,Daman and Diu,Delhi,Goa,Gujarat,Haryana,Himachal Pradesh,Jammu and Kashmir,Jharkhand,Karnataka,Kerala,Lakshadweep,Madhya Pradesh,Maharashtra,Manipur,Meghalaya,Mizoram,Nagaland,Odisha,Puducherry,Punjab,Rajasthan,Sikkim,Tamil Nadu,Telangana,Tripura,Uttar Pradesh,Uttarakhand,West Bengal" | split: "," %}
            {% assign current_state = page.metafields.custom.state_name %}
            {% for state in states %}
              {% assign state_value = state | downcase | replace: ' ', '-' %}
              {% assign state_selected = false %}
              
              {% comment %} Check if current state matches either the display name or the value {% endcomment %}
              {% if current_state == state or current_state == state_value %}
                {% assign state_selected = true %}
              {% endif %}
              
              <option value="{{ state_value }}" {% if state_selected %}selected{% endif %}>{{ state }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="location-dropdown city-dropdown">
          <label for="city">City</label>
          <select id="city" name="city">
            {% assign current_city = page.metafields.custom.city_name %}
            {% comment %} Cities will be populated by JavaScript, but we need to set the selected value {% endcomment %}
          </select>
        </div>

        <button type="button" class="location-submit">→</button>
      </div>
    </div>
  </div>
</div>
<div class="platinum-calc-section">
  <div class="page-width">
    <h1 class="platinum-calc__heading">Platinum Rate Today in {{ page.metafields.custom.city_name }}</h1>
  </div>
  <div class="platinum-calc__container">
    <p class="platinum-calc__label">Choose Purity</p>

    <div class="platinum-calc__karat-options">
      <button class="platinum-calc__karat platinum-calc__karat--active">Pt999</button>
      <button class="platinum-calc__karat">Pt950</button>
      <button class="platinum-calc__karat">Pt900</button>
    </div>

    <div class="platinum-calc__inputs">
      <div class="platinum-calc__input-group">
        <label for="weightInput" class="platinum-calc__input-label">In Grams</label>
        <input type="text" id="weightInput" placeholder="Enter Weight" class="platinum-calc__input">
      </div>

      <div class="platinum-calc__input-group">
        <label for="platinumRate" class="platinum-calc__input-label">
          <span class="platinum-calc__label--desktop">Today's Standard Rate of Pt999</span>
          <span class="platinum-calc__label--mobile">Today's Pt999 Rate</span>
        </label>
        <div
            id="platinumRate"
            class="platinum-calc__rate-display"
            data-base="{{ section.settings.rate_today | remove: '₹' | remove: ',' | strip }}"
          >
        </div>
      </div>
    </div>

    <button class="platinum-calc__button">CALCULATE</button>

    <div id="platinumCalcResult" class="platinum-calc__rate-display" style="margin-top: 15px; display:none;">
      <span>Estimated Value: </span><span id="platinumValueOutput"></span>
    </div>

    <p class="platinum-calc__note">*This value is not the final value as Platinum Rate might change*</p>
  </div>
</div>
<div class="investment-section">
  <div class="page-width">
    <div class="investment-section__container">
    <!-- Left Column -->
        <div class="investment-section__container">
          <div class="investment-section__column investment-section__left" style="width:fit-content">
            <h2 class="investment-section__heading">{{ section.settings.investment_heading }}</h2>
            <div class="investment-section__description">
              {{ section.settings.investment_description }}
            </div>
          </div>

          <div class="investment-section__column investment-section__right">
            <h3 class="investment-section__toc-heading">Table of Contents</h3>
            {{ section.settings.investment_quick_links }}
          </div>
        </div>
  </div>
  </div>
</div>
<div class="platinum-table-v2-section">
  <div class="page-width">
    <h2 class="platinum-table-v2-title">Platinum PRICE BREAKDOWN BY WEIGHT</h2>
    <div class="platinum-table-v2-wrapper">
      <table class="platinum-table-v2">
        <thead>
          <tr>
            <th>Purity</th>
            <th>1G</th>
            <th>5G</th>
            <th>10G</th>
            <th>100G</th>
          </tr>
        </thead>
        <tbody>
          {%- assign base_999 = section.settings.rate_today | remove: '₹' | remove: ',' | strip | plus: 0 -%}
          {%- assign rate_per_gram = base_999 | divided_by: 10.0 -%}
          {%- assign purities = "999,950,900" | split: "," -%}
          {%- assign weights = "1,5,10,100" | split: "," -%}
      
          {%- for purity in purities -%}
            {%- assign purity_factor = purity | plus: 0 | divided_by: 1000.0 -%}
            <tr>
              <td>Pt{{ purity }}</td>
              {%- for w in weights -%}
                {%- assign price = rate_per_gram | times: w | times: purity_factor -%}
                <td>₹{{ price | round }}</td>
              {%- endfor -%}
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</div>


