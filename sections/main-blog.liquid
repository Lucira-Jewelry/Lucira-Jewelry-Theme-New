{% schema %}
{
  "name": "Lucira Blog Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Lucira Blogs"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Default Text"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "post_limit",
      "label": "Number of posts to show",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 8
    },
    {
      "type": "range",
      "id": "max_categories",
      "label": "Maximum categories to display",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Lucira Blog Grid",
      "category": "Blog"
    }
  ]
}
{% endschema %}


<style>
/* Base styles and reset */
.lucira-section * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.lucira-section {
  background-color: #fff;
  color: #1a1a1a;
  line-height: 1.5;
  padding: 0 100px;
  overflow: visible;
  margin-bottom: 60px;
  position: relative;
  width: 100%;
  clear: both;
  /* Add this to ensure proper stacking */
  z-index: 1;
}

/* Create a main wrapper with proper flow control */
.lucira-main-wrapper {
  width: 100%;
  position: relative;
  overflow: visible;
  display: flow-root; /* Modern clearfix */
}

.lucira-section img {
  max-width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
  width: 100%;
}

/* Typography */
.lucira-section h1, 
.lucira-section h2, 
.lucira-section h3, 
.lucira-section h4 {
  letter-spacing: 0.04em;
  text-transform: uppercase;
  font-weight: 500;
  margin-bottom: 1rem;
  font-family: 'Futura';
}

.lucira-section h1 {
  font-size: 2rem;
}

.lucira-section h2 {
  font-size: 1.75rem;
}

.lucira-section p {
  margin-bottom: 1rem;
}

/* Common layout */
.lucira-section .container-1 {
  width: 100%;
  max-width: 1720px;
  margin: 0 auto;
  padding: 0 15px;
  overflow: visible;
  position: relative;
  /* Add this for better flow control */
  display: flow-root;
    font-family: 'Futura';
}

.lucira-section .section {
  padding: 3rem 0;
  position: relative;
  /* Add display flow-root for modern clearfix */
  display: flow-root;
}

/* Header */
.lucira-section .header {
  padding: 2rem 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  width: 100%;
  box-sizing: border-box;
}

.lucira-section .header-subtitle {
  font-size: 1.125rem;
  max-width: 850px;
  margin: 0 auto;
  color: #666;
}

/* Navigation - Dropdown */
.lucira-blog .blog-nav {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 2rem;
  margin-bottom: 2rem;
  position: relative;
  z-index: 10;
}

.lucira-blog .blog-nav a {
  text-decoration: none;
  color: #1a1a1a;
  text-transform: uppercase;
  font-weight: 500;
  letter-spacing: 0.04em;
  padding: 0.5rem 0;
  transition: all 0.3s ease;
}

.lucira-blog .blog-nav a.active {
  text-decoration: underline;
  color: #a68380;
}

.lucira-blog .blog-nav a:hover {
  color: #a68380;
}

/* Mobile dropdown menu */
.lucira-blog .dropdown-toggle {
  display: none;
  background-color: #a68380;
  color: white;
  border: none;
  padding: 10px 15px;
  border-radius: 4px;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  font-weight: 500;
  width: 100%;
  text-align: left;
  position: relative;
}

.lucira-blog .dropdown-toggle:after {
  content: '▼';
  position: absolute;
  right: 15px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 0.8em;
  transition: transform 0.3s ease;
}

.lucira-blog .dropdown-toggle.active:after {
  transform: translateY(-50%) rotate(180deg);
}

.lucira-blog .dropdown-content {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 2rem;
  width: 100%;
  text-align: center;
}

/* Blog Grid */
.lucira-blog .blog-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
  margin-bottom: 2rem;
  position: relative;
}

/* Common card styles for blogs and categories */
.lucira-section .card-image-container {
  width: 100%;
  overflow: hidden;
  transition: background-color 0.3s ease;
}

.lucira-section .card-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.lucira-section a:hover .card-image {
  transform: scale(1.05);
}

/* Blog Card specific */
.lucira-blog .blog-card {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-bottom: 2rem;
  cursor: pointer;
  transition: transform 0.3s ease;
}

.lucira-blog .blog-card:hover {
  transform: translateY(-5px);
}

.lucira-blog .blog-card-image-container {
  aspect-ratio: 1/1.15;
  border-radius: 8px;
}

.lucira-blog .blog-card-category {
  text-transform: uppercase;
  color: #666;
  text-align: left;
  letter-spacing: 0.04em;
  font-size: 12px;
}

.lucira-blog .blog-card-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.lucira-blog .blog-card-title {
  text-transform: uppercase;
  font-weight: 500;
  font-size: 18px;
  letter-spacing: 0.04em;
  line-height: 1.5;
  flex: 1;
  transition: color 0.3s ease;
}

.lucira-blog .blog-card:hover .blog-card-title {
  color: #a68380;
}

.lucira-blog .blog-card-avatar-container {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  margin-left: 1rem;
}

.lucira-blog .blog-card:hover .blog-card-avatar-container {
  background-color: rgba(166, 131, 128, 0.1);
}

.lucira-blog .blog-card-avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.lucira-blog .blog-card:hover .blog-card-avatar,
.lucira-blog .a-anchor:hover .blog-card-avatar {
  transform: rotate(-45deg);
}

/* Hidden posts initially */
.lucira-blog .blog-grid .a-anchor.hidden-post {
  display: none;
}

/* No posts message */
.lucira-blog .no-posts-message {
  grid-column: 1 / -1;
  text-align: center;
  padding: 3rem 0;
  color: #666;
}

/* Buttons */
.lucira-section .btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 1rem 2rem;
  border-radius: 20px;
  font-size: 1rem;
  text-transform: uppercase;
  font-weight: 500;
  letter-spacing: 0.04em;
  cursor: pointer;
  transition: all 0.3s ease;
  border: none;
  text-decoration: none;
}

.lucira-section .btn-primary {
  background-color: #a68380;
  color: #fff;
  font-size: 16px;
}

.lucira-section .btn-primary:hover {
  background-color: #8e6c69;
}

.lucira-section .load-more {
  display: flex;
  justify-content: center;
  margin: 2rem 0;
  padding-bottom: 2rem;
  position: relative;
  width: 100%;
  clear: both;
}

.lucira-section a {
  text-decoration: none;
  color: inherit;
}

/* Categories specific */
/* Horizontal scroll for categories */
.lucira-trendy-categories .categories-wrapper {
  display: flex;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch; /* smooth scrolling on iOS */
  gap: 1rem; /* spacing between categories */
  padding-bottom: 10px; /* optional */
}

/* Optional: hide scrollbar for cleaner look */
.lucira-trendy-categories .categories-wrapper::-webkit-scrollbar {
  display: none;
}
/* Featured Products Section */
.lucira-featured-products {
  background-color: {{ section.settings.background_color }};
  padding: 60px 20px;
  margin: 60px 0;
  font-family: 'Futura Std', Arial, sans-serif;
  color: #1a1a1a;
  position: relative;
  clear: both;
  width: 100%;
  /* Add display flow-root for modern clearfix */
  display: flow-root;
}

.lucira-section + .lucira-featured-products {
  margin-top: 60px;
}

.lucira-featured-products .container-1 {
  width: 100%;
  max-width: 1720px;
  margin: 0 auto;
  padding: 0 15px;
  position: relative;
}

.lucira-featured-products .section-header {
  text-align: center;
  margin-bottom: 40px;
}

.lucira-featured-products h2.section-title {
  font-size: 2rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  font-weight: 500;
  margin-bottom: 1rem;
}

.lucira-featured-products .section-subtitle {
  font-size: 1.125rem;
  max-width: 750px;
  margin: 0 auto;
  color: #666;
}

/* Featured Layout */
.lucira-featured-products .products-featured {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30px;
  position: relative;
}

.lucira-featured-products .featured-main {
  grid-column: 1 / 2;
  grid-row: 1 / 3;
}

.lucira-featured-products .featured-secondary {
  grid-column: 2 / 3;
  display: grid;
  grid-template-rows: repeat(3, 1fr);
  gap: 30px;
}

/* Product Card */
.lucira-featured-products .product-card {
  position: relative;
  overflow: hidden;
  border-radius: 8px;
  box-shadow: 0 5px 15px rgba(0,0,0,0.08);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  background-color: #000;
  height: 100%;
}

.lucira-featured-products .product-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 25px rgba(0,0,0,0.15);
}

.lucira-featured-products .product-image-container {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.lucira-featured-products .product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: opacity 0.3s ease, transform 0.5s ease;
  opacity: 0.8;
}

.lucira-featured-products .product-card:hover .product-image {
  transform: scale(1.05);
  opacity: 0.6;
}

.lucira-featured-products .product-info {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20px;
  background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 60%, rgba(0,0,0,0) 100%);
  color: #fff;
  transition: all 0.3s ease;
}

.lucira-featured-products .product-card:hover .product-info {
  background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.6) 70%, rgba(0,0,0,0.2) 100%);
}

.lucira-featured-products .product-category {
  font-size: 0.875rem;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin-bottom: 8px;
  color: #a68380;
}

.lucira-featured-products .product-title {
  font-size: 1.25rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin-bottom: 8px;
}

.lucira-featured-products .cta-container {
  text-align: center;
  margin-top: 40px;
}

.lucira-featured-products .cta-btn {
  display: inline-block;
  padding: 12px 30px;
  border-radius: 30px;
  background-color: #a68380;
  color: #fff;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  font-weight: 500;
  font-size: 0.9rem;
  transition: background-color 0.3s ease;
}

.lucira-featured-products .cta-btn:hover {
  background-color: #8e6c69;
}

.lucira-featured-products .product-overlay-link {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* Clear fix for sections */
.section-clearfix {
  clear: both;
  width: 100%;
  height: 0;
  display: block;
}

/* Final wrapper to prevent overflow issues */
.lucira-wrapper {
  overflow: visible;
  position: relative;
  width: 100%;
  display: flow-root; /* Modern clearfix */
}

/* Add this class to end of your Lucira content to fix footer overlap */
.lucira-end-spacer {
  clear: both;
  width: 100%;
  height: 40px; /* Adjust as needed */
  display: block;
  content: "";
  visibility: visible;
}

/* Responsive styles */
@media (max-width: 1024px) {
  .lucira-blog .blog-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .lucira-trendy-categories .category-item {
    width: calc(20% - 2rem);
  }
}

@media (max-width: 768px) {
  /* Section spacing improvements */
  .lucira-section {
    margin-bottom: 40px;
    padding: 0 15px;
      font-family: 'Futura Std';

  }
  
  .lucira-section .section {
    padding: 2rem 0;
  }
  
  .lucira-trendy-categories {
    padding: 2rem 15px;
    margin-top: 40px;
    margin-bottom: 40px;
  }
  
  /* Layout adjustments */
  .lucira-blog .blog-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .lucira-trendy-categories .category-item {
    width: calc(33.33% - 2rem);
  }
  
  /* Typography adjustments */
  .lucira-section h1 {
    font-size: 1.75rem;
  }
  
  .lucira-section h2 {
    font-size: 1.5rem;
  }
  
  /* Dropdown menu styles for mobile */
  .lucira-blog .dropdown-toggle {
    display: block;
  }
  
  .lucira-blog .blog-nav {
    display: block;
    position: relative;
    margin-bottom: 3rem;
  }
  
  .lucira-blog .dropdown-content {
    display: none;
    position: absolute;
    flex-direction: column;
    gap: 0;
    background-color: #f9f9f9;
    width: 100%;
    box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);
    z-index: 20;
    margin-top: 5px;
    border-radius: 4px;
  }
  
  .lucira-blog .dropdown-content.show {
    display: flex;
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 20;
    width: 100%;
  }
  
  .lucira-blog .dropdown-content a {
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid #f1f1f1;
    width: 100%;
  }
  
  .lucira-blog .dropdown-content a:last-child {
    border-bottom: none;
  }
  
  .lucira-blog .dropdown-content a:hover {
    background-color: #f1f1f1;
  }
  
  /* Featured products adjustments */
  .lucira-featured-products {
    padding: 40px 15px;
    margin: 40px 0;
  }
  
  .lucira-featured-products .products-featured {
    grid-template-columns: 1fr;
  }
  
  .lucira-featured-products .featured-main {
    grid-column: 1 / 2;
    grid-row: 1 / 2;
  }
  
  .lucira-featured-products .featured-secondary {
    grid-column: 1 / 2;
    grid-row: 2 / 3;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 1fr;
    margin-top: 0;
  }
  
  /* Fix load more button spacing */
  .lucira-section .load-more {
    margin: 2rem 0;
    padding-bottom: 2rem;
  }
  
  /* Add more space after the last section in mobile */
  .lucira-end-spacer {
    height: 60px;
  }
}




  @media (max-width: 720px) {
  .lucira-section {
    overflow: scroll; /* Change to hidden instead of visible */
    position: relative;
    z-index: 1; /* Set explicit z-index */
    margin-bottom: 40px;
    padding-bottom: 20px; /* Add bottom padding for spacing */
    border-bottom: 1px solid #f1f1f1; /* Visual separator */
      font-family: 'Futura Std';

  }
  
  /* Make sure the dropdown doesn't get cut off */
  .lucira-blog .blog-nav {
    overflow: visible;
    position: relative;
    z-index: 10;
  }
}


  
@media (max-width: 480px) {
  /* Container padding */
  .lucira-section {
    padding: 0 10px;
    margin-bottom: 30px;
      font-family: 'Futura Std';

  }
  
  .lucira-section .container-1 {
    padding: 0 5px;
  }
  
  /* Element spacing */
  .lucira-blog .blog-grid {
    gap: 1rem;
    row-gap: 1.5rem;
  }
  
  .lucira-blog .blog-card {
    gap: 1rem;
    margin-bottom: 1rem;
  }
  
  .lucira-trendy-categories {
    padding: 25px 10px;
    margin-top: 30px;
    margin-bottom: 30px;
  }
  
  .lucira-trendy-categories .categories-grid {
    gap: 1.5rem;
  }
  
  .lucira-trendy-categories .category-item {
    width: calc(50% - 1.5rem);
  }
  
  /* Typography */
  .lucira-blog .blog-card-category {
    font-size: 0.7rem;
  }
  
  .lucira-blog .blog-card-title {
    font-size: 0.9rem;
  }
  
  .lucira-trendy-categories .category-title {
    font-size: 1rem;
  }
  
  .lucira-trendy-categories h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  /* Featured products spacing */
  .lucira-featured-products {
    padding: 25px 10px;
    margin: 30px 0;
  }
  
  .lucira-featured-products .featured-secondary {
    grid-template-columns: 1fr;
    grid-template-rows: repeat(3, auto);
    margin-top: 0;
    gap: 15px;
  }
  
  .lucira-featured-products .product-card {
    min-height: 180px;
  }
  
  /* Section headers spacing */
  .lucira-section .header,
  .lucira-trendy-categories h2 {
    padding: 1.5rem 0;
    word-wrap: break-word;
  }
  
  /* Increased space for footer in very small screens */
  .lucira-end-spacer {
    height: 80px;
  }

  .lucira-blog .blog-card-avatar-container {width: 20px !important; height: 20px !important;}
  .lucira-blog .blog-card-title { font-size: 12px; !important;}
}
</style>
<div class="lucira-section lucira-blog">
  <div class="container-1">
    <div class="header">
      {% if section.settings.title != blank %}
        <h2 class="header-title">{{ section.settings.title }}</h2>
      {% endif %}
      
      {% if section.settings.subtitle != blank %}
        <p class="header-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <main>
      <section class="section">
        {% if section.settings.blog != blank %}
          {% assign blog_handle = section.settings.blog %}
          
          {% comment %}
          Get the current tag from the URL
          {% endcomment %}
          {% assign current_tag = '' %}
          {% if current_tags.size > 0 %}
            {% assign current_tag = current_tags.first %}
          {% endif %}
          
          <nav class="blog-nav">
            <button class="dropdown-toggle" data-default-text="Categories">
              {% if current_tags.size > 0 %}
                {{ current_tags.first }}
              {% else %}
                Categories
              {% endif %}
            </button>
            <div class="dropdown-content">
              <a href="{{ blog.url }}" class="{% if current_tags.size == 0 %}active{% endif %}">All</a>
              {% for tag in blog.all_tags %}
                <a href="{{ blog.url }}/tagged/{{ tag | handle }}" 
                   class="{% if current_tags contains tag %}active{% endif %}">
                  {{ tag }}
                </a>
              {% endfor %}
            </div>
          </nav>

          <div class="blog-grid" >
            {% comment %}
            If we have a current tag, filter articles by that tag
            {% endcomment %}
            {% if current_tags.size > 0 %}
              {% comment %}
              Filter articles for the current tag - note Shopify doesn't have a direct "where" filter 
              for tags, so we need to manually check if each article has the tag
              {% endcomment %}
              {% assign tag_found = false %}
              {% assign tag_articles_count = 0 %}
              {% assign all_articles_count = 0 %}
              
              {% for article in blog.articles %}
                {% if article.tags contains current_tags.first %}
                  {% assign tag_found = true %}
                  {% assign all_articles_count = all_articles_count | plus: 1 %}
                  {% assign tag_articles_count = tag_articles_count | plus: 1 %}
                  
                  {% if tag_articles_count <= section.settings.post_limit %}
                    <a class="a-anchor" href="{{ article.url }}">
                      <div class="blog-card">
                        <div class="blog-card-image-container card-image-container">
                          {% if article.image %}
                            <img 
                              src="{{ article.image | img_url: '600x600', crop: 'center' }}" 
                              alt="{{ article.title }}" 
                              class="blog-card-image card-image"
                              loading="lazy"
                            >
                          {% else %}
                            <img 
                              src="https://i.postimg.cc/mDSyRfRg/612bb2954f79f7184b14fddfb4625b0800e1465f.jpg" 
                              alt="{{ article.title }}" 
                              class="blog-card-image card-image"
                              loading="lazy"
                            >
                          {% endif %}
                        </div>
                        <div class="blog-card-category">
                          {% if article.tags.size > 0 %}
                            {{ article.tags.first }}
                          {% else %}
                            Blog
                          {% endif %}
                        </div>
                        <div class="blog-card-content">
                          <p class="blog-card-title">{{ article.title }}</p>
                          <div class="blog-card-avatar-container">
                            <img 
                              src="{{ 'arrow.svg' | asset_url }}" 
                              alt="Arrow" 
                              class="blog-card-avatar"
                              loading="lazy"
                            >
                          </div>
                        </div>
                      </div>
                    </a>
                  {% else %}
                    <a class="a-anchor hidden-post" href="{{ article.url }}">
                      <div class="blog-card">
                        <div class="blog-card-image-container card-image-container">
                          {% if article.image %}
                            <img 
                              src="{{ article.image | img_url: '600x600', crop: 'center' }}" 
                              alt="{{ article.title }}" 
                              class="blog-card-image card-image"
                              loading="lazy"
                            >
                          {% else %}
                            <img 
                              src="https://i.postimg.cc/mDSyRfRg/612bb2954f79f7184b14fddfb4625b0800e1465f.jpg" 
                              alt="{{ article.title }}" 
                              class="blog-card-image card-image"
                              loading="lazy"
                            >
                          {% endif %}
                        </div>
                        <div class="blog-card-category">
                          {% if article.tags.size > 0 %}
                            {{ article.tags.first }}
                          {% else %}
                            Blog
                          {% endif %}
                        </div>
                        <div class="blog-card-content">
                          <h3 class="blog-card-title">{{ article.title }}</h3>
                          <div class="blog-card-avatar-container">
                            <img 
                              src="{{ 'arrow.svg' | asset_url }}" 
                              alt="Arrow" 
                              class="blog-card-avatar"
                              loading="lazy"
                            >
                          </div>
                        </div>
                      </div>
                    </a>
                  {% endif %}
                {% endif %}
              {% endfor %}
              
              {% if tag_found == false %}
                <div class="no-posts-message">
                  <p>No posts found for "{{ current_tags.first }}"</p>
                </div>
              {% endif %}
            {% else %}
              {% comment %}
              No tag selected, show all articles
              {% endcomment %}
              {% assign all_articles_count = 0 %}
              
              {% for article in blog.articles %}
                {% assign all_articles_count = all_articles_count | plus: 1 %}
                
                {% if forloop.index <= section.settings.post_limit %}
                  <a class="a-anchor" href="{{ article.url }}">
                    <div class="blog-card">
                      <div class="blog-card-image-container card-image-container">
                        {% if article.image %}
                          <img 
                            src="{{ article.image | img_url: '600x600', crop: 'center' }}" 
                            alt="{{ article.title }}" 
                            class="blog-card-image card-image"
                            loading="lazy"
                          >
                        {% else %}
                          <img 
                            src="https://i.postimg.cc/mDSyRfRg/612bb2954f79f7184b14fddfb4625b0800e1465f.jpg" 
                            alt="{{ article.title }}" 
                            class="blog-card-image card-image"
                            loading="lazy"
                          >
                        {% endif %}
                      </div>
                      <div class="blog-card-category">
                        {% if article.tags.size > 0 %}
                          {{ article.tags.first }}
                        {% else %}
                          Blog
                        {% endif %}
                      </div>
                      <div class="blog-card-content">
                        <h3 class="blog-card-title">{{ article.title }}</h3>
                        <div class="blog-card-avatar-container">
                          <img 
                            src="{{ 'arrow.svg' | asset_url }}" 
                            alt="Arrow" 
                            class="blog-card-avatar"
                            loading="lazy"
                          >
                        </div>
                      </div>
                    </div>
                  </a>
                {% else %}
                  <a class="a-anchor hidden-post" href="{{ article.url }}">
                    <div class="blog-card">
                      <div class="blog-card-image-container card-image-container">
                        {% if article.image %}
                          <img 
                            src="{{ article.image | img_url: '600x600', crop: 'center' }}" 
                            alt="{{ article.title }}" 
                            class="blog-card-image card-image"
                            loading="lazy"
                          >
                        {% else %}
                          <img 
                            src="https://i.postimg.cc/mDSyRfRg/612bb2954f79f7184b14fddfb4625b0800e1465f.jpg" 
                            alt="{{ article.title }}" 
                            class="blog-card-image card-image"
                            loading="lazy"
                          >
                        {% endif %}
                      </div>
                      <div class="blog-card-category">
                        {% if article.tags.size > 0 %}
                          {{ article.tags.first }}
                        {% else %}
                          Blog
                        {% endif %}
                      </div>
                      <div class="blog-card-content">
                        <h3 class="blog-card-title">{{ article.title }}</h3>
                        <div class="blog-card-avatar-container">
                          <img 
                            src="{{ 'arrow.svg' | asset_url }}" 
                            alt="Arrow" 
                            class="blog-card-avatar"
                            loading="lazy"
                          >
                        </div>
                      </div>
                    </div>
                  </a>
                {% endif %}
              {% endfor %}
            {% endif %}
          </div>
            
          <div class="load-more">
            {% if current_tags.size > 0 %}
              {% if tag_articles_count > section.settings.post_limit %}
                <button class="btn btn-primary" id="load-more-btn">
                  View All in {{ current_tags.first }}
                </button>
              {% else %}
                <a href="{{ blog.url }}/tagged/{{ current_tags.first | handle }}" class="btn btn-primary">
                  Back to {{ current_tags.first }}
                </a>
              {% endif %}
            {% else %}
              {% if all_articles_count > section.settings.post_limit %}
                <button class="btn btn-primary" id="load-more-btn">
                  View More
                </button>
              {% else %}
                <a href="{{ blog.url }}" class="btn btn-primary">
                  Back to Blog Home
                </a>
              {% endif %}
            {% endif %}
          </div>
        {% else %}
          <div class="text-center">
            <p>No available blogs</p>
          </div>
        {% endif %}
      </section>
    </main>


    
</div>


  
</div>



<script>
document.addEventListener('DOMContentLoaded', function() {
  // Dropdown functionality
  const dropdownToggle = document.querySelector('.lucira-blog .dropdown-toggle');
  const dropdownContent = document.querySelector('.lucira-blog .dropdown-content');
  const defaultText = dropdownToggle ? dropdownToggle.getAttribute('data-default-text') : 'Categories';
  
  if (dropdownToggle && dropdownContent) {
    // Update dropdown text if a tag is selected
    const activeTag = document.querySelector('.lucira-blog .dropdown-content a.active');
    if (activeTag && activeTag.textContent.trim() !== 'All') {
      dropdownToggle.textContent = activeTag.textContent.trim();
    } else {
      dropdownToggle.textContent = defaultText;
    }
    
    // Add click handlers to all tag links to update the active class
    const tagLinks = document.querySelectorAll('.lucira-blog .dropdown-content a');
    tagLinks.forEach(link => {
      link.addEventListener('click', function() {
        // Remove active class from all links
        tagLinks.forEach(l => l.classList.remove('active'));
        // Add active class to clicked link
        this.classList.add('active');
        // Update dropdown text
        if (this.textContent.trim() !== 'All') {
          dropdownToggle.textContent = this.textContent.trim();
        } else {
          dropdownToggle.textContent = defaultText;
        }
      });
    });
    
    dropdownToggle.addEventListener('click', function() {
      dropdownContent.classList.toggle('show');
      this.classList.toggle('active');
    });
    
    // Close the dropdown if clicked outside
    document.addEventListener('click', function(event) {
      if (!event.target.matches('.dropdown-toggle') && 
          !event.target.closest('.dropdown-content')) {
        dropdownContent.classList.remove('show');
        dropdownToggle.classList.remove('active');
      }
    });
  }
  
  // Load More functionality
  const loadMoreBtn = document.getElementById('load-more-btn');
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', function() {
      // Find all hidden posts
      const hiddenPosts = document.querySelectorAll('.lucira-blog .blog-grid .a-anchor.hidden-post');
      
      // Determine how many posts to show - display 4 more at a time
      const postsToShow = Math.min(hiddenPosts.length, 4);
      
      // Show the next batch of posts
      for (let i = 0; i < postsToShow; i++) {
        hiddenPosts[i].classList.remove('hidden-post');
      }
      
      // Update remaining count
      const remainingPosts = document.querySelectorAll('.lucira-blog .blog-grid .a-anchor.hidden-post').length;
      
      // Update button text to show remaining count
      if (remainingPosts > 0) {
        this.textContent = `View More (${remainingPosts} remaining)`;
      } else {
        // All posts are now visible
        this.textContent = 'All Posts Loaded';
        this.disabled = true;
        this.style.opacity = '0.7';
        this.style.cursor = 'default';
      }
      
      // Optional: scroll smoothly to where new content starts
      const lastRevealedPost = hiddenPosts[postsToShow - 1];
      if (lastRevealedPost) {
        setTimeout(() => {
          lastRevealedPost.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }, 100);
      }
    });
  }
});
  </script>