<style>
  /* Lucira Blog Grid Styles - Integrated */
  .lucira-section * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .lucira-section {
    background-color: #fff;
    color: #1a1a1a;
    line-height: 1.5;
    padding: 0 100px;
    overflow: visible;
    margin-bottom: 60px;
    position: relative;
    width: 100%;
    clear: both;
    z-index: 1;
  }

  .lucira-main-wrapper {
    width: 100%;
    position: relative;
    overflow: visible;
    display: flow-root;
  }

  .lucira-section img {
    max-width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    width: 100%;
  }

  /* Typography */
  .lucira-section h1,
  .lucira-section h2,
  .lucira-section h3,
  .lucira-section h4 {
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 1rem;
    font-family: 'Futura';
  }

  .lucira-section h1 {
    font-size: 2rem;
  }

  .lucira-section h2 {
    font-size: 2rem;
  }

  .lucira-section p {
    margin-bottom: 1rem;
  }

  /* Common layout */
  .lucira-section .container-1 {
    width: 100%;
    max-width: 1720px;
    margin: 0 auto;
    padding: 0 15px;
    overflow: visible;
    position: relative;
    display: flow-root;
    font-family: 'Futura';
  }

  .lucira-section .section {
    padding: 3rem 0;
    position: relative;
    display: flow-root;
  }

  /* Header */
  .lucira-section .header {
    padding: 2rem 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
    box-sizing: border-box;
  }

  .lucira-section .header-subtitle {
    font-size: 1.125rem;
    max-width: 850px;
    margin: 0 auto;
    color: #666;
  }

  /* Navigation - Dropdown */
  .lucira-blog .blog-nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2rem;
    margin-bottom: 2rem;
    position: relative;
    z-index: 10;
  }

  .lucira-blog .blog-nav a {
    text-decoration: none;
    color: #1a1a1a;
    text-transform: uppercase;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 0.5rem 0;
    transition: all 0.3s ease;
  }

  .lucira-blog .blog-nav a.active {
    color: #a68380;
  }

  .lucira-blog .blog-nav a:hover {
    color: #a68380;
  }

  /* Mobile dropdown menu */
  .lucira-blog .dropdown-toggle {
    display: none;
    background-color: #a68380;
    color: white;
    border: none;
    padding: 10px 15px;
    border-radius: 4px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 500;
    width: 100%;
    text-align: left;
    position: relative;
  }

  .lucira-blog .dropdown-toggle:after {
    content: '▼';
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.8em;
    transition: transform 0.3s ease;
  }

  .lucira-blog .dropdown-toggle.active:after {
    transform: translateY(-50%) rotate(180deg);
  }

  .lucira-blog .dropdown-content {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 2rem;
    width: 100%;
    text-align: center;
  }

  /* Blog Grid */
  .lucira-blog .blog-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    position: relative;
  }

  /* Common card styles for blogs and categories */
  .lucira-section .card-image-container {
    width: 100%;
    overflow: hidden;
    transition: background-color 0.3s ease;
  }

  .lucira-section .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .lucira-section a:hover .card-image {
    transform: scale(1.05);
  }

  /* Blog Card specific */
  .lucira-blog .blog-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .lucira-blog .blog-card:hover {
    transform: translateY(-5px);
  }

  .lucira-blog .blog-card-image-container {
    aspect-ratio: 1/1.15;
    border-radius: 8px;
  }

  .lucira-blog .blog-card-category {
    text-transform: uppercase;
    color: #666;
    text-align: left;
    letter-spacing: 0.04em;
    font-size: 12px;
  }

  .lucira-blog .blog-card-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .lucira-blog .blog-card-title {
    text-transform: uppercase;
    font-weight: 500;
    font-size: 18px;
    letter-spacing: 0.04em;
    line-height: 1.5;
    flex: 1;
    transition: color 0.3s ease;
  }

  .lucira-blog .blog-card:hover .blog-card-title {
    color: #a68380;
  }

  .lucira-blog .blog-card-avatar-container {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    margin-left: 1rem;
  }

  .lucira-blog .blog-card:hover .blog-card-avatar-container {
    background-color: rgba(166, 131, 128, 0.1);
  }

  .lucira-blog .blog-card-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .lucira-blog .blog-card:hover .blog-card-avatar,
  .lucira-blog .a-anchor:hover .blog-card-avatar {
    transform: rotate(-45deg);
  }

  /* Infinite scroll styles */
  .lucira-blog blog-infinite-scroll {
    display: block;
    grid-column: 1 / -1;
    text-align: center;
    margin-top: 40px;
  }
  
  .lucira-blog blog-infinite-scroll a {
    display: inline-block;
    color: currentColor;
    text-decoration: none;
    min-height: 60px;
    width: 100%;
  }
  
  .luxury-dots {
    display: inline-flex;
    gap: 8px;
  }
  
  .luxury-dots .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: #a68380;
    animation: pulse 1.5s infinite ease-in-out;
  }
  
  .luxury-dots .dot:nth-child(2) {
    animation-delay: 0.2s;
  }
  
  .luxury-dots .dot:nth-child(3) {
    animation-delay: 0.4s;
  }
  
  @keyframes pulse {
    0%, 100% {
      opacity: 0.3;
      transform: scale(0.8);
    }
    50% {
      opacity: 1;
      transform: scale(1.1);
    }
  }
  
  .end-of-posts {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px 0;
    color: #666;
    font-size: 0.9rem;
  }

  .end-of-posts .end-content {
    text-align: center;
  }
  
  .end-of-posts .end-decoration {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 20px;
  }
  
  .end-of-posts .luxury-line {
    width: 60px;
    height: 1px;
    background-color: #a68380;
  }
  
  .end-of-posts .end-diamond {
    color: #a68380;
    font-size: 18px;
  }
  
  .end-of-posts .end-text {
    font-family: 'Futura';
    font-size: 18px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #1a1a1a;
    margin-bottom: 8px;
  }
  
  .end-of-posts .end-subtitle {
    font-family: 'Futura';
    font-size: 14px;
    color: #666;
    letter-spacing: 0.04em;
  }

  /* No posts message */
  .lucira-blog .no-posts-message {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem 0;
    color: #666;
  }

  /* Responsive styles */
  @media (max-width: 1024px) {
    .lucira-blog .blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .lucira-section {
      margin-bottom: 40px;
      padding: 0 15px;
      font-family: 'Futura Std';
    }

    .lucira-section .section {
      padding: 2rem 0;
    }

    .lucira-blog .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .lucira-section h1 {
      font-size: 1.75rem;
    }

    .lucira-section h2 {
      font-size: 1.5rem;
    }

    .lucira-blog .dropdown-toggle {
      display: block;
    }

    .lucira-blog .blog-nav {
      display: block;
      position: relative;
      margin-bottom: 3rem;
    }

    .lucira-blog .dropdown-content {
      display: none;
      position: absolute;
      flex-direction: column;
      gap: 0;
      background-color: #f9f9f9;
      width: 100%;
      box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);
      z-index: 20;
      margin-top: 5px;
      border-radius: 4px;
    }

    .lucira-blog .dropdown-content.show {
      display: flex;
      position: absolute;
      top: 100%;
      left: 0;
      z-index: 20;
      width: 100%;
    }

    .lucira-blog .dropdown-content a {
      padding: 12px 16px;
      text-align: left;
      border-bottom: 1px solid #f1f1f1;
      width: 100%;
    }

    .lucira-blog .dropdown-content a:last-child {
      border-bottom: none;
    }

    .lucira-blog .dropdown-content a:hover {
      background-color: #f1f1f1;
    }
  }

  @media (max-width: 720px) {
    .lucira-section {
      overflow: scroll;
      position: relative;
      z-index: 1;
      margin-bottom: 40px;
      padding-bottom: 20px;
      border-bottom: 1px solid #f1f1f1;
      font-family: 'Futura Std';
    }

    .lucira-blog .blog-nav {
      overflow: visible;
      position: relative;
      z-index: 10;
    }
  }

  @media (max-width: 480px) {
    .lucira-section {
      padding: 0 10px;
      margin-bottom: 30px;
      font-family: 'Futura Std';
    }

    .lucira-section .container-1 {
      padding: 0 5px;
    }

    .lucira-blog .blog-grid {
      gap: 1rem;
      row-gap: 1.5rem;
    }

    .lucira-blog .blog-card {
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .lucira-blog .blog-card-category {
      font-size: 0.7rem;
    }

    .lucira-blog .blog-card-title {
      font-size: 0.9rem;
    }

    .lucira-section .header,
    .lucira-trendy-categories h2 {
      padding: 1.5rem 0;
      word-wrap: break-word;
    }

    .lucira-blog .blog-card-avatar-container {
      width: 20px !important; 
      height: 20px !important;
    }
    
    .lucira-blog .blog-card-title { 
      font-size: 12px !important;
    }

    .end-of-posts .luxury-line {
      width: 40px;
    }
  }

  @media only screen and (min-width:1200px) and (max-width:1400px) {
    .lucira-blog .blog-card-title { font-size: 14px;}
    .lucira-blog .blog-card-avatar-container { width: 28px; height: 28px;}
  }
</style>

<div class="lucira-section lucira-blog">
  <div class="container-1">
    <div class="header">
      {% if section.settings.title != blank %}
        <h2 class="header-title">{{ section.settings.title }}</h2>
      {% else %}
        <h2 class="header-title">{{ blog.title }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="header-subtitle">{{ section.settings.subtitle }}</p>
      {% elsif blog.metafields.custom.subtitle != blank %}
        <p class="header-subtitle">{{ blog.metafields.custom.subtitle }}</p>
      {% endif %}
    </div>

    {% if blog.articles_count > 0 %}
      {% assign current_tag = current_tags.first | default: '' %}

      <nav class="blog-nav">
        <button class="dropdown-toggle" data-default-text="Categories">
          {% if current_tag != '' %}{{ current_tag }}{% else %}Categories{% endif %}
        </button>
        <div class="dropdown-content">
          <a href="{{ blog.url }}" class="{% if current_tag == '' %}active{% endif %}">All</a>
          {% for tag in blog.all_tags %}
            <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="{% if current_tag == tag %}active{% endif %}">
              {{ tag }}
            </a>
          {% endfor %}
        </div>
      </nav>

      {% comment %} Paginate blog articles (50 per page) {% endcomment %}
      {% paginate blog.articles by 50 %}
        <div class="blog-grid" id="blog-grid">
          {% assign displayed_count = 0 %}
          {% for article in blog.articles %}
            {% if current_tag == '' or article.tags contains current_tag %}
              {% assign displayed_count = displayed_count | plus: 1 %}
              <a class="a-anchor" href="{{ article.url }}" data-post-index="{{ displayed_count }}">
                <div class="blog-card">
                  <div class="blog-card-image-container card-image-container">
                    {% if article.image %}
                      <img src="{{ article.image | img_url: '600x600', crop: 'center' }}" 
                           alt="{{ article.title }}" 
                           title="{{ article.title }}" 
                           class="blog-card-image card-image" 
                           loading="lazy">
                    {% else %}
                      <img src="https://i.postimg.cc/mDSyRfRg/612bb2954f79f7184b14fddfb4625b0800e1465f.jpg" 
                           title="{{ article.title }}" 
                           alt="{{ article.title }}" 
                           class="blog-card-image card-image" 
                           loading="lazy">
                    {% endif %}
                  </div>
                  <div class="blog-card-category">
                    {% if article.tags.size > 0 %}
                      {{ article.tags.first }}
                    {% else %}
                      Blog
                    {% endif %}
                  </div>
                  <div class="blog-card-content">
                    <p class="blog-card-title">{{ article.title }}</p>
                    <div class="blog-card-avatar-container">
                      <img src="{{ 'arrow.svg' | asset_url }}" 
                           title="Arrow" 
                           alt="Arrow" 
                           class="blog-card-avatar" 
                           loading="lazy">
                    </div>
                  </div>
                </div>
              </a>
            {% endif %}
          {% endfor %}

          {% if displayed_count == 0 %}
            <div class="no-posts-message">
              <p>No posts found{% if current_tag != '' %} for "{{ current_tag }}"{% endif %}</p>
            </div>
          {% endif %}

          {% comment %} Add infinite scroll anchor {% endcomment %}
          {% if paginate.pages > 1 and paginate.next %}
            <blog-infinite-scroll>
              <a href="{{ paginate.next.url }}"
                 style="color: currentColor; text-decoration: none; pointer-events: none;">
              </a>
            </blog-infinite-scroll>
          {% elsif displayed_count > 0 %}
            <div class="end-of-posts">
              <div class="end-content">
                <div class="end-decoration">
                  <div class="luxury-line"><span style="display: none">.</span></div>
                  <div class="end-diamond"><span style="display: none">.</span>◆</div>
                  <div class="luxury-line"><span style="display: none">.</span></div>
                </div>
                <p class="end-text">You've explored all our stories</p>
                <p class="end-subtitle">Every tale is a journey of elegance</p>
              </div>
            </div>
          {% endif %}
        </div>
      {% endpaginate %}

    {% else %}
      <p class="no-posts-message" style="text-align: center; padding: 3rem 0;">No articles available in this blog</p>
    {% endif %}
  </div>
</div>

<script>
class BlogInfiniteScroll extends HTMLElement {
  constructor() {
    super();
    this.anchor = this.querySelector('a');
    
    if (!this.anchor) {
      return;
    }
    
    this.observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          this.loadNextPage();
        }
      });
    }, {
      rootMargin: '200px 0px'
    });
    
    this.observer.observe(this);
  }
  
  async loadNextPage() {
    this.observer.disconnect();
    
    // Show loading state
    const originalContent = this.anchor.innerHTML;
    this.anchor.innerHTML = `
      <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 0;">
        <div style="display: flex; align-items: center; justify-content: center;">
          <span class="luxury-dots">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </span>
        </div>
        <div style="font-family: Futura; text-align: center; margin-top: 10px; color: #a68380; letter-spacing: 0.04em;">
          Loading more stories...
        </div>
      </div>
    `;
    
    const url = this.anchor.getAttribute('href');
    
    if (url) {
      try {
        const response = await fetch(url);
        const text = await response.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(text, 'text/html');
        
        // Get the blog grid from the fetched page
        const newGrid = doc.querySelector('.lucira-blog .blog-grid');
        const currentGrid = document.querySelector('.lucira-blog .blog-grid');
        
        if (newGrid && currentGrid) {
          // Get all articles from the new page
          const articles = newGrid.querySelectorAll('.a-anchor');
          
          // Insert them before the infinite scroll element
          articles.forEach(article => {
            currentGrid.insertBefore(article, this);
          });
          
          // Update the infinite scroll anchor with next page URL
          const newInfiniteScroll = newGrid.querySelector('blog-infinite-scroll');
          
          if (newInfiniteScroll) {
            const newAnchor = newInfiniteScroll.querySelector('a');
            if (newAnchor) {
              this.anchor.setAttribute('href', newAnchor.getAttribute('href'));
              this.anchor.innerHTML = originalContent;
              this.observer.observe(this);
            } else {
              this.showEndMessage();
              this.remove();
            }
          } else {
            // No more pages - show end message
            this.showEndMessage();
            this.remove();
          }
        }
      } catch (error) {
        console.error('Error loading next page:', error);
        // Restore original content on error
        this.anchor.innerHTML = originalContent;
        this.observer.observe(this);
      }
    }
  }
  
  showEndMessage() {
    const endMessage = document.createElement('div');
    endMessage.className = 'end-of-posts';
    endMessage.innerHTML = `
      <div class="end-content">
        <div class="end-decoration">
          <div class="luxury-line"><span style="display: none">.</span></div>
          <div class="end-diamond"><span style="display: none">.</span>◆</div>
          <div class="luxury-line"><span style="display: none">.</span></div>
        </div>
        <p class="end-text">You've explored all our stories</p>
        <p class="end-subtitle">Every tale is a journey of elegance</p>
      </div>
    `;
    
    this.parentNode.insertBefore(endMessage, this.nextSibling);
    this.remove();
  }
}

// Register the custom element
if (!customElements.get('blog-infinite-scroll')) {
  customElements.define('blog-infinite-scroll', BlogInfiniteScroll);
}

// Dropdown functionality
document.addEventListener('DOMContentLoaded', function() {
  const dropdownToggle = document.querySelector('.lucira-blog .dropdown-toggle');
  const dropdownContent = document.querySelector('.lucira-blog .dropdown-content');
  const defaultText = dropdownToggle?.getAttribute('data-default-text') || 'Categories';

  if (dropdownToggle && dropdownContent) {
    const activeTag = document.querySelector('.lucira-blog .dropdown-content a.active');
    dropdownToggle.textContent = activeTag && activeTag.textContent.trim() !== 'All' ? activeTag.textContent.trim() : defaultText;

    dropdownToggle.addEventListener('click', function(e) {
      e.stopPropagation();
      dropdownContent.classList.toggle('show');
      this.classList.toggle('active');
    });

    document.addEventListener('click', function(event) {
      if (!event.target.matches('.dropdown-toggle') && !event.target.closest('.dropdown-content')) {
        dropdownContent.classList.remove('show');
        dropdownToggle.classList.remove('active');
      }
    });

    const tagLinks = dropdownContent.querySelectorAll('a');
    tagLinks.forEach(link => {
      link.addEventListener('click', function() {
        tagLinks.forEach(l => l.classList.remove('active'));
        this.classList.add('active');
        dropdownToggle.textContent = this.textContent.trim() !== 'All' ? this.textContent.trim() : defaultText;
        dropdownContent.classList.remove('show');
        dropdownToggle.classList.remove('active');
      });
    });
  }
});
</script>

{% schema %}
{
  "name": "Lucira Blog Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Lucira Blogs"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Default Text"
    }
  ],
  "presets": [
    {
      "name": "Lucira Blog Grid",
      "category": "Blog"
    }
  ]
}
{% endschema %}