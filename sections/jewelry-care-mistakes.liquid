<style>
.jewelry-care-mistakes {
  margin-top: var(--margin-top-desktop, 60px) !important;
  margin-bottom: var(--margin-bottom-desktop, 60px) !important;
      max-width:1180px !important;
}

@media (max-width: 768px) {
  .jewelry-care-mistakes {
    margin-top: var(--margin-top-mobile, 40px) !important;
    margin-bottom: var(--margin-bottom-mobile, 40px) !important;
  }
}

/* Margin variable injection */
.jewelry-care-mistakes[data-margin-top-desktop] {
  --margin-top-desktop: attr(data-margin-top-desktop px);
}
.jewelry-care-mistakes[data-margin-bottom-desktop] {
  --margin-bottom-desktop: attr(data-margin-bottom-desktop px);
}
.jewelry-care-mistakes[data-margin-top-mobile] {
  --margin-top-mobile: attr(data-margin-top-mobile px);
}
.jewelry-care-mistakes[data-margin-bottom-mobile] {
  --margin-bottom-mobile: attr(data-margin-bottom-mobile px);
}

/* Tip block styling */
.tip-icon {
  display: flex;
  margin-top: 20px;
  justify-content: end;
}
.text_icon_blk_main {
  width: 50%;
}
.tip-block.reverse .tip-icon {
  justify-content: start;
}
.care-mistakes-heading {
  font-weight: 500;
  font-style: Medium;
  font-size: 32px;
  line-height: 150%;
  letter-spacing: 4%;
  text-align: center;
  text-transform: uppercase;
  margin: 0 0 8px 0;
  color: #1A1A1A;
}
.care-mistakes-subheading {
  font-weight: 400;
  font-style: Book;
  font-size: 18px;
  line-height: 24px;
  letter-spacing: 4%;
  text-align: center;
  margin: 0 0 40px 0;
  color: #1A1A1A;
}
.care-mistakes-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 19.62px;
}
.tip-block {
  display: flex;
  text-align: center;
  gap: 20px;
  flex-direction: row;
  justify-content: center;
}
.tip-block.reverse {
  flex-direction: row-reverse;
}
.tip-icon img {
  width: 40px;
  height: 40px;
}
.tip-image {
  display: flex;
  width: 50%;
}
.tip-image img {
  width: 100%;
  height: auto;
}
.tip-text {
  margin: 0;
  margin-top: 12px;
  font-family: Futura Std;
  font-weight: 400;
  font-style: Book;
  font-size: 18px;
  line-height: 24px;
  letter-spacing: 4%;
  color: #1A1A1A;
  text-align: right;
}
.tip-block.reverse .tip-text {
  text-align: left;
}

/* Mobile Styles */
@media (max-width: 768px) {
  .tip-text {
    font-size: 14px;
    line-height: 20px;
  }
  .tip-block,
  .tip-block.reverse {
    flex-direction: column-reverse !important;
    text-align: center;
  }
  .care-mistakes-heading {
    font-size: 21px;
    margin-bottom: 12px;
  }
  .text_icon_blk_main {
    width: 100%;
  }
  .care-mistakes-subheading {
    font-size: 12px;
    line-height: 18px;
    margin-bottom: 24px;
  }
  .tip-icon {
    margin-top: 12px;
  }
  .tip-image {
    width: 100%;
  }
  .tip-image img {
    max-width: 100%;
  }
  .tip-block {
    gap: 12px;
    justify-content: flex-end;
  }
  .tip-text {
    max-width: 100%;
    text-align: end;
  }
  .care-mistakes-grid{
    gap:12px;
    row-gap:24px;
  }
  .text_icon_blk_main{
    padding-right:12px;
  }
  .tip-block.reverse .text_icon_blk_main{
    padding-right:0 !important;
    padding-left:12px;
  }
}
</style>

<div
  class="jewelry-care-mistakes page-width"
  data-margin-top-desktop="{{ section.settings.margin_top_desktop }}"
  data-margin-bottom-desktop="{{ section.settings.margin_bottom_desktop }}"
  data-margin-top-mobile="{{ section.settings.margin_top_mobile }}"
  data-margin-bottom-mobile="{{ section.settings.margin_bottom_mobile }}"
>
  <div class="care-mistakes-content">
    {% if section.settings.heading != blank %}
      <h2 class="care-mistakes-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="care-mistakes-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="care-mistakes-grid">
      {% for block in section.blocks %}
        {% assign mod = forloop.index0 | modulo: 2 %}
        <div class="tip-block {% if mod != 0 %}reverse{% endif %}">
          <div class="text_icon_blk_main">
            {% if block.settings.icon_image %}
              <div class="tip-icon">
                <img src="{{ block.settings.icon_image | image_url: width: 40 }}" alt="Tip icon">
              </div>
            {% endif %}
            <p class="tip-text">{{ block.settings.tip_text }}</p>
          </div>
          {% if block.settings.main_image %}
            <div class="tip-image">
              <img src="{{ block.settings.main_image | image_url: width: 300 }}" alt="Main image">
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>


{% schema %}
{
  "name": "Jewelry Care Mistakes",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What are the biggest jewelry care mistakes to avoid?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Protect your jewelry from the climate, the tangles and the tarnish by storing them the right way."
    },
    {
      "type": "range",
      "id": "margin_top_desktop",
      "label": "Margin Top Desktop",
      "default": 60,
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "label": "Margin Bottom Desktop",
      "default": 60,
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Margin Top Mobile",
      "default": 40,
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Margin Bottom Mobile",
      "default": 40,
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "tip_block",
      "name": "Tip Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image (X or Checkmark)"
        },
        {
          "type": "image_picker",
          "id": "main_image",
          "label": "Main Image"
        },
        {
          "type": "textarea",
          "id": "tip_text",
          "label": "Tip Text",
          "default": "Don’t use toothpaste as it is abrasive and can scratch metals and gemstones."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Jewelry Care Mistakes"
    }
  ]
}
{% endschema %}