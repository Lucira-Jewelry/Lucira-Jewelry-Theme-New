          "type": "rich_text",
          "name": "Halo Rings Work Beautifully With Many Diamond Shapes",
          "settings": {
            "content": "<h2>Halo Rings Work Beautifully With Many Diamond Shapes</h2>",
            "custom_id": "beautifully",
