          "type": "rich_text",
          "name": "Halo Rings Offer More Creative and Unique Design Possibilities",
          "settings": {
            "content": "<h2>Halo Rings Offer More Creative and Unique Design Possibilities</h2><p>Unlike simple solitaire rings, halo rings allow designers to experiment with different shapes and patterns.</p>",
            "custom_id": "halo-rings-offer",
            "text_alignment": "left"
          }
        },
        "image_9KhX3Y": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Styling_a_Solitaire_Ring_for_Brunch_or_Casual_Weekend_Outings.jpg"
          }
        },
        "rich_text_qwTzXx": {
          "type": "rich_text",
          "settings": {
            "content": "<p>For example:</p><p>1.] The Gem Hexagon Halo Diamond Ring uses a geometric halo design that feels modern and distinctive.<br/>2.] The Round Halo Split Diamond Ring adds extra detail with a split band, giving the ring more character.<br/>3.]The Vintage Halo Oval Diamond Ring combines a halo with vintage-inspired styling.<br/><br/>These variations show how halo settings can transform the personality of a ring while still keeping the focus on the center diamond.</p>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
