        "rich_text_G8V6GG": {
          "type": "rich_text",
          "name": "Vintage and Modern Halo Designs Both Remain Popular",
          "settings": {
            "content": "<h2>Vintage and Modern Halo Designs Both Remain Popular</h2>",
            "custom_id": "vintage",
            "text_alignment": "left"
          }
        },
        "image_CV378m": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Styling_a_Solitaire_Ring_for_Date_Nights_and_Evening_Plans.jpg"
