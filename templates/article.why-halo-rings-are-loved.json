        "rich_text_htc4FK": {
          "type": "rich_text",
          "settings": {
            "content": "<p>Another advantage of halo designs is that they complement many different diamond shapes.</p><p>Round diamonds are the most common choice, but halos also work beautifully with oval, cushion, marquise, and heart-shaped stones.</p><p>For instance, Lucira’s Two Oval Halo Engagement Diamond Ring highlights the elongated shape of the oval diamond, while the Heart and Halo Diamond Ring adds a romantic touch.</p><p>The halo helps define the shape of the center stone, making it stand out even more.</p>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
        "image_with_text_Le4Pmf": {
          "type": "image_with_text",
          "settings": {
