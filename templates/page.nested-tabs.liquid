{% comment %} {% layout 'theme' %}

{% assign category_handle = page.handle %}
{% assign current_category = metaobjects.category_page[category_handle] %}

{% if current_category == blank %}
  <div class="container" style="padding: 40px; text-align: center;">
    <h1>Category not found</h1>
    <p>Please check the page configuration.</p>
  </div>
{% else %}
  {% comment %} Get all tabs for this category {% endcomment %}
  {% assign all_tabs = metaobjects.tab_content.values %}
  {% assign category_tabs = "" | split: "" %}
  
  {% comment %} Filter tabs by parent category {% endcomment %}
  {% for tab in all_tabs %}
    {% if tab.parent_category %}
      {% assign parent = tab.parent_category %}
      {% if parent.system.handle == current_category.system.handle 
          or parent.title == current_category.title 
          or parent.system.id == current_category.system.id %}
        {% assign category_tabs = category_tabs | push: tab %}
      {% endif %}
    {% endif %}
  {% endfor %}
  
  {% comment %} If no filtered tabs, show all tabs {% endcomment %}
  {% if category_tabs.size == 0 %}
    {% assign category_tabs = all_tabs %}
  {% endif %}
  
  {% comment %} Get active tab from URL {% endcomment %}
  {% assign url_search = request.search %}
  {% assign url_tab = '' %}
  
  {% if url_search contains 'tab=' %}
    {% assign url_parts = url_search | remove: '?' | split: '&' %}
    {% for part in url_parts %}
      {% if part contains 'tab=' %}
        {% assign url_tab = part | split: '=' | last %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endif %}
  
  {% assign default_tab = current_category.default_tab_slug | default: category_tabs.first.tab_slug %}
  {% assign active_tab_slug = url_tab | default: default_tab %}
  {% assign active_tab_slug_lower = active_tab_slug | downcase %}
  
  {% comment %} Store data for JavaScript {% endcomment %}
  {% comment %} <script type="application/json" id="tabs-data">
    {
      "category": {
        "title": "{{ current_category.title | escape }}",
        "handle": "{{ current_category.system.handle | escape }}"
      },
      "tabs": [
        {% for tab in category_tabs %}
          {
            "id": "tab-{{ forloop.index0 }}",
            "title": "{{ tab.title | escape }}",
            "slug": "{{ tab.tab_slug | escape }}",
            "header": "{{ tab.header | default: tab.title | escape }}",
            "description": "{{ tab.description | escape | newline_to_br }}",
            "content_image": "{% if tab.content_image %}{{ tab.content_image | image_url: width: 800 | escape }}{% endif %}",
            "cta_text": "{{ tab.cta_text | escape }}",
            "cta_link": "{{ tab.cta_link | escape }}",
            "banner_image": "{% if tab.banner_image %}{{ tab.banner_image | image_url: width: 1920 | escape }}{% endif %}",
            "banner_title": "{{ tab.banner_title | default: tab.header | default: tab.title | escape }}",
            "related_blogs": [
              {% for article_ref in tab.related_blogs %}
                {% assign article = article_ref %}
                {% if article %}
                  {
                    "title": "{{ article.title | escape }}",
                    "url": "{{ article.url | escape }}"
                  }{% unless forloop.last %},{% endunless %}
                {% endif %}
              {% endfor %}
            ]
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ],
      "activeTabSlug": "{{ active_tab_slug | escape }}"
    }
  </script> {% endcomment %}
