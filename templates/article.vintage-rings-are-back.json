        "rich_text_AJHQPB": {
          "type": "rich_text",
          "name": "Vintage Rings Feel Personal Rather Than Trend-Driven",
          "settings": {
            "content": "<h2>Vintage Rings Feel Personal Rather Than Trend-Driven</h2>",
            "custom_id": "vintage-rings",
            "text_alignment": "left"
          }
        },
        "image_9KhX3Y": {
          "type": "image",
