          "type": "faq_item",
          "settings": {
            "faq_question": "How long does the entire gold evaluation process take?",
            "faq_answer": "<p>The entire process approximately takes around 10 - 15 minutes, depending on the number of pieces. We work quickly without losing accuracy.<br/><br/></p>"
          }
        },
        "faq_item_DHqXHb": {
          "type": "faq_item",
          "settings": {
