          }
        },
        "faq_item_4EQGkm": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What type of gold is accepted under the Old Gold Exchange (OGE) program?",
            "faq_answer": "<p>We accept gold of all karats under the Old Gold Exchange program. However, only <strong>plain gold</strong> is eligible for value assessment.</p>"
