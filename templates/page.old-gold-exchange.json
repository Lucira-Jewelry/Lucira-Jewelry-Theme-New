          "type": "faq_item",
          "settings": {
            "faq_question": "Can I use the exchange value to buy any jewellery?",
            "faq_answer": "<p>Yes, you can redeem the full value toward any jewelry at Lucira stores whether it's a new design, a daily-wear piece or a custom order.</p>"
          }
