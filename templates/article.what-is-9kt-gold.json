    "faqs_jWyqCp": {
      "type": "faq-section",
      "blocks": {
        "faq_item_Xa7a9G": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Q1. Is 9kt gold worth buying?",
            "faq_answer": "<p>Yes, it is an excellent choice for its durability, affordability, and suitability for everyday wear, offering the look of gold at a more accessible price.</p>"
          }
        },
        "faq_item_rcaANV": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Q2. Is 9kt or 18kt better?",
            "faq_answer": "<p>Neither is inherently 'better'; it depends on your priorities. 9kt is more durable and affordable, while 18kt has a higher gold content and richer color.</p>"
          }
        },
        "faq_item_HMGtjz": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Q3. How much gold is in 9kt?",
            "faq_answer": "<p>It contains 37.5% pure gold, with the remaining 62.5% being other alloy metals.</p>"
          }
        },
        "faq_item_UHKzLJ": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Q4. Can 9kt gold cause skin allergies?",
            "faq_answer": "<p>While rare, individuals with extreme metal sensitivities might react to alloys. Reputable jewelers use high-quality, often nickel-free alloys to minimize this risk.</p>"
          }
        },
        "faq_item_eAdDeB": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Q5. How is 9kt gold hallmarked in India?",
            "faq_answer": "<p>In India, it is typically hallmarked by the Bureau of Indian Standards (BIS) with the number '375' to signify 37.5% gold purity.</p>"
          }
        },
        "faq_item_jktigb": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Q6. Is 9kt gold suitable for engagement rings?",
            "faq_answer": "<p>Absolutely. Its superior durability and strength make it a practical and popular choice for engagement rings meant to be worn daily.</p>"
          }
        },
        "faq_item_tFyEna": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Q7. What is the difference between 9kt gold and gold-plated jewelry?",
            "faq_answer": "<p>9kt gold is a solid gold alloy throughout the entire piece, whereas gold-plated jewelry has only a thin layer of gold coated over a base metal, which can wear off.</p>"
          }
        },
        "faq_item_rNe7NJ": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Q8. Does Lucira Jewelry offer a buyback policy on 9kt gold pieces?",
            "faq_answer": "<p>Yes, we offer a comprehensive Lifetime Exchange and Buyback policy on all our jewelry, including pieces made from 9kt gold.</p>"
          }
        }
      },
