<section class="lucira-section nector-referral-program-section" id="refer-and-earn">
  <div class="page-width">
    <div class="nector-referral-program-wrapper">
      <div class="heading-wrapper">
        <h2>Referral Program</h2>
        <p>
            Let your sparkle inspire and earn while you do. Invite your friends to join Lucira and enjoy exclusive perks when they make their first purchase - you earn Lucira Coins and they get a discount. It's our way of saying thank you.        
        </p>
      </div>
      <div class="grid-row">
          {% if customer %}
          {% if customer.metafields.nector.custom_properties.value.nector_user_referral_link %}
            <div class="grid-column">
              <div class="referral-copy-wrapper">
                <p>Copy the Link & Share it with your friends</p>
                <div class="copy-link-container">
                  <input type="text" id="referralLink" value="{{ customer.metafields.nector.custom_properties.value.nector_user_referral_link }}" readonly>
                  <button class="copy-btn" onclick="copyLink()">Copy Link</button>
                </div>
                <div class="grid-social-icons">
                  <a href="#" onclick="shareOnWhatsApp(); return false;">
                    <img
                      src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_427319185.svg?v=1750933732"
                      alt="whatsapp icon"
                      title="whatsapp icon"
                      width="72"
                      height="72"
                    >
                  </a>
                  <a href="#" onclick="shareOnInstagram(); return false;">
                    <img
                      src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_427322338_1.png?v=1750933869"
                      alt="instagram icon"
                      title="instagram icon"
                      width="72"
                      height="72"
                    >
                  </a>
                  <a href="#" onclick="shareOnFacebook(); return false;">
                    <img
                      src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_427319188.svg?v=1750933732"
                      alt="facebook icon"
                      title="facebook icon"
                      width="72"
                      height="72"
                    >
                  </a>
                  <a href="#" onclick="shareOnLinkedIn(); return false;">
                    <img
                      src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_427319187.svg?v=1750933732"
                      alt="linkedin icon"
                      title="linkedin icon"
                      width="72"
                      height="72"
                    >
                  </a>
                </div>
              </div>
            </div>
          {% else %}
          <div class="grid-column">
                <div class="referral-copy-wrapper">
                  <p>Please log in share your referral link with friends.</p>
                </div>
              </div>
            {% endif %}
          {% else %}
            <div class="grid-column">
              <div class="referral-copy-wrapper">
                <p>Your Referral Link is Ready to Share with your friends</p>
                <div class="copy-link-container">
                  <input type="text" id="referralLink" value="Please Login to Share your Referral Link" readonly>
                  <a class="login_button" href="/account/login">Login</a>
                </div>
              </div>
            </div>
          {% endif %}
       
        <div class="grid-column">
          <div class="grid-card-wrapper">
            <img
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/They_Get_img_2.png?v=1751354604"
              class="image-bg-left"
              alt="loyalty page left"
              title="loyalty page image left"
              width="auto"
              height="auto"
            >
            <p>They Get</p>
            <p>
              ₹1,000 Off<br>
              <span> on their 1st Order</span>
            </p>
          </div>
        </div>
        <div class="grid-column">
          <div class="grid-card-wrapper">
            <img
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/7d93784d-d99f-4716-8c45-779b911938f6_2.png?v=1751352893"
              class="image-bg-right"
              alt="image-by-right"
              title="image-by-right"
              width="auto"
              height="auto"
            >
            <p>You Get</p>
            <p>
              2,000<br>
              <span>Lucira Coins</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="lucira-section faq-section">
  <div itemscope="" itemtype="https://schema.org/FAQPage" class="page-width">
    <div class="heading-wrapper">
      <h2>FAQ'S</h2>
      <p>
        Curious about Lucira Rewards? We’ve got you covered! Here’s everything you need to know about earning, redeeming, and making the most of your Lucira Rewards.
      </p>
    </div>
    <div id="accordion_block" class="accordion">
      <!-- FAQ 1 -->
      <div itemscope="" itemprop="mainEntity" itemtype="https://schema.org/Question" class="accordion-item">
        <h2 itemprop="name" class="accordion-title">What is Lucira Rewards?</h2>
        <div itemscope="" itemprop="acceptedAnswer" itemtype="https://schema.org/Answer" class="accordion-content">
          <p itemprop="text">
            Lucira Rewards is our loyalty program designed to thank you for shopping with us. You earn Lucira Coins with
            every purchase, review, referral, and more redeem them for savings on future orders.
          </p>
        </div>
      </div>
      <!-- FAQ 2 -->
      <div itemscope="" itemprop="mainEntity" itemtype="https://schema.org/Question" class="accordion-item">
        <h2 itemprop="name" class="accordion-title">How do I join Lucira Rewards?</h2>
        <div itemscope="" itemprop="acceptedAnswer" itemtype="https://schema.org/Answer" class="accordion-content">
          <p itemprop="text">
            It’s easy! Just sign up for a Lucira account and you’ll automatically be enrolled in our rewards program,no
            extra steps required.
          </p>
        </div>
      </div>
      <!-- FAQ 3 -->
      <div itemscope="" itemprop="mainEntity" itemtype="https://schema.org/Question" class="accordion-item">
        <h2 itemprop="name" class="accordion-title">How do I earn Lucira Coins?</h2>
        <div itemscope="" itemprop="acceptedAnswer" itemtype="https://schema.org/Answer" class="accordion-content">
          <p itemprop="text">
            You can earn Lucira Coins in multiple ways:
            <ul>
              <li>By signing up</li>
              <li>Making purchases</li>
              <li>Referring friends</li>
            </ul>
          </p>
        </div>
      </div>
      <!-- FAQ 4 -->
      <div itemscope="" itemprop="mainEntity" itemtype="https://schema.org/Question" class="accordion-item">
        <h2 itemprop="name" class="accordion-title">How do I redeem my Lucira Coins?</h2>
        <div itemscope="" itemprop="acceptedAnswer" itemtype="https://schema.org/Answer" class="accordion-content">
          <p itemprop="text">
            At checkout, you’ll see the option to apply your available Lucira Coins to your order. Use them to get
            discounts and enjoy more sparkle for less.
          </p>
        </div>
      </div>
      <div itemscope="" itemprop="mainEntity" itemtype="https://schema.org/Question" class="accordion-item">
        <h2 itemprop="name" class="accordion-title">Is there a limit to how many Lucira Coins I can earn?</h2>
        <div itemscope="" itemprop="acceptedAnswer" itemtype="https://schema.org/Answer" class="accordion-content">
          <p itemprop="text">
            There’s no cap on how many coins you can collect. The more you shop, refer, and engage, the more you earn!
          </p>
        </div>
      </div>
      <div itemscope="" itemprop="mainEntity" itemtype="https://schema.org/Question" class="accordion-item">
        <h2 itemprop="name" class="accordion-title">How do referrals work?</h2>
        <div itemscope="" itemprop="acceptedAnswer" itemtype="https://schema.org/Answer" class="accordion-content">
          <p itemprop="text">
            Share your unique referral link with friends. When they make their first purchase using your link, both of
            you will receive Lucira Coins!
          </p>
        </div>
      </div>
      <div itemscope="" itemprop="mainEntity" itemtype="https://schema.org/Question" class="accordion-item">
        <h2 itemprop="name" class="accordion-title">
          I forgot to log in before placing my order. Can I still get Lucira Coins?
        </h2>
        <div itemscope="" itemprop="acceptedAnswer" itemtype="https://schema.org/Answer" class="accordion-content">
          <p itemprop="text">
            Yes! Just contact our support team with your order details, and we’ll manually credit your Lucira Coins.
          </p>
        </div>
      </div>
      <div itemscope="" itemprop="mainEntity" itemtype="https://schema.org/Question" class="accordion-item">
        <h2 itemprop="name" class="accordion-title">Where can I check my Lucira Coins balance?</h2>
        <div itemscope="" itemprop="acceptedAnswer" itemtype="https://schema.org/Answer" class="accordion-content">
          <p itemprop="text">
            Log in to your Lucira account and go to the "Rewards" section. Your current balance and earning history will
            be displayed there.
          </p>
        </div>
      </div>
      <!-- Add more FAQs following the same structure -->
    </div>
  </div>
</div>

<script>
  function copyLink() {
    const linkInput = document.getElementById('referralLink');
    const copyBtn = document.querySelector('.copy-btn');
    const toast = document.getElementById('toast');

    // Select and copy the text
    linkInput.select();
    linkInput.setSelectionRange(0, 99999); // For mobile devices

    try {
      document.execCommand('copy');

      // Update button state
      copyBtn.textContent = 'Copied!';
      copyBtn.classList.add('copied');

      // Show toast notification
      toast.classList.add('show');

      // Reset button after 2 seconds
      setTimeout(() => {
        copyBtn.textContent = 'Copy Link';
        copyBtn.classList.remove('copied');
        toast.classList.remove('show');
      }, 2000);

    } catch (err) {
      console.error('Failed to copy text: ', err);
    }
  }

  function shareOnWhatsApp() {
    const referralLink = document.getElementById('referralLink').value;
    const message = `Hey! Check out this amazing platform - Lucira! Use my referral link to get ₹1000 off on your first order: ${referralLink}`;
    const whatsappUrl = `https://api.whatsapp.com/send?text=${encodeURIComponent(message)}`;
    window.open(whatsappUrl, '_blank');
  }

  function shareOnFacebook() {
    const referralLink = document.getElementById('referralLink').value;
    const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(referralLink)}`;
    window.open(facebookUrl, '_blank', 'width=600,height=400');
  }

  function shareOnTwitter() {
    const referralLink = document.getElementById('referralLink').value;
    const message = `Join me on Lucira and get ₹1000 off your first order!`;
    const twitterUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(message)}&url=${encodeURIComponent(referralLink)}`;
    window.open(twitterUrl, '_blank', 'width=600,height=800');
  }

  function shareOnLinkedIn() {
    const referralLink = document.getElementById('referralLink').value;
    const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(referralLink)}`;
    window.open(linkedinUrl, '_blank', 'width=600,height=800');
  }

  function shareOnInstagram() {
      const referralLink = document.getElementById('referralLink').value;
      copyLink(); // Your existing copy function
      // Open Instagram in a new tab
      const instagramUrl = `https://www.instagram.com/create/story?text=${encodeURIComponent(referralLink)}`;
      window.open('https://www.instagram.com/', '_blank', 'width=600,height=800');
  }

  // Add some interactive animations
  document.addEventListener('DOMContentLoaded', function () {
    const cards = document.querySelectorAll('.grid-card-wrapper');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    });

    cards.forEach(card => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(20px)';
      card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      observer.observe(card);
    });
  });
</script>


