          "name": "Vintage Craftsmanship Meets Modern Diamond Jewelry",
          "settings": {
            "content": "<h2>Vintage Craftsmanship Meets Modern Diamond Jewelry</h2>",
            "custom_id": "vintage-craftsmanship",
