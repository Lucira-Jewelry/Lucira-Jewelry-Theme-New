        "faq_item_dRqQHj": {
          "type": "faq_item",
          "settings": {
            "faq_question": "1.] What are side stones in a ring?",
            "faq_answer": "<p>Side stones are smaller diamonds placed beside the center diamond. They add sparkle and help highlight the main stone.</p>"
          }
        },
        "faq_item_nF93xE": {
          "type": "faq_item",
          "settings": {
            "faq_question": "2.] Do side stones make a diamond look bigger?",
            "faq_answer": "<p>Yes. Side stones can create the illusion of a larger center diamond by expanding the visual area of the ring.</p>"
          }
        },
        "faq_item_GkCANY": {
          "type": "faq_item",
          "settings": {
            "faq_question": "3.] What are the most popular side stone shapes?",
            "faq_answer": "<p>Common side stone shapes include round, pear, baguette, and smaller accent diamonds.</p>"
          }
        },
        "faq_item_xdDYpj": {
          "type": "faq_item",
          "settings": {
            "faq_question": "4.] Are side stones suitable for engagement rings?",
            "faq_answer": "<p>Yes. Many engagement rings include side stones because they add extra brilliance while keeping the focus on the center diamond.</p>"
          }
        },
        "faq_item_FdJJ9z": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Can any diamond shape have side stones?",
            "faq_answer": "<p>Most diamond shapes can be paired with side stones. The key is choosing shapes that complement the center diamond’s proportions.</p>"
          }
