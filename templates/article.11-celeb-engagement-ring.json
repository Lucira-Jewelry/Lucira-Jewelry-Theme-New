    "faq_section_fdfEkk": {
      "type": "faq-section",
      "blocks": {
        "faq_item_4XDbp7": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What is a modern engagement ring?",
            "faq_answer": "<p>A modern engagement ring blends timeless beauty with a personal touch. It is made for women who want something elegant, meaningful, and unique to their own story rather than just following trends.</p>"
          }
        },
        "faq_item_rmknH8": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Which celebrity has the biggest diamond ring?",
            "faq_answer": "<p>Priyanka Chopra’s Tiffany cushion cut engagement ring is one of the most stunning in Bollywood. It is elegant, bright, and perfectly reflects her mix of grace and global confidence.</p>"
          }
        },
        "faq_item_Bth9A3": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Are platinum engagement rings popular?",
            "faq_answer": "<p>Yes, very much. Platinum is loved by modern brides for its strength, purity, and soft white glow. It enhances the sparkle of diamonds and represents love that lasts forever.</p>"
          }
        },
        "faq_item_adBbLc": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What is the most famous ring in the world?",
            "faq_answer": "<p>Princess Diana’s blue sapphire ring, now worn by Kate Middleton, is often considered the most famous engagement ring in the world. It is a timeless symbol of elegance and history.</p>"
          }
        },
        "faq_item_KrReLH": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What are the benefits of a platinum ring?",
            "faq_answer": "<p>Platinum is naturally white, gentle on the skin, and extremely durable. It does not lose its shine or fade over time, which makes it ideal for everyday wear and lifelong memories.</p>"
          }
        },
        "faq_item_ykCcaY": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Who is the real owner of the Kohinoor diamond?",
            "faq_answer": "<p>The Kohinoor diamond is part of the British Crown Jewels today, but its ownership has long been debated. Many in India believe it should return to its place of origin.</p>"
          }
        },
        "faq_item_eaApg8": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Who can break a diamond?",
            "faq_answer": "<p>Although diamonds are the hardest natural material, they are not unbreakable. A strong impact at the right angle can chip or crack them, so careful handling is always important.</p>"
          }
        },
        "faq_item_bRXrby": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Who verifies diamonds?",
            "faq_answer": "<p>Diamonds are verified by trusted organizations such as GIA, IGI, and HRD Antwerp. These institutes check each stone’s authenticity, quality, and grading so you know exactly what you are buying.</p>"
          }
        },
        "faq_item_xwkWjQ": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Which certificate is best for diamonds?",
            "faq_answer": "<p>The GIA certificate is considered the most reliable. It gives a detailed and unbiased report on a diamond’s cut, clarity, color, and carat, helping you make an informed choice.</p>"
          }
        }
      },
