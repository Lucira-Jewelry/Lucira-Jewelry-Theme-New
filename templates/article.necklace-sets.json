        "rich_text_KGqjX6": {
          "type": "rich_text",
          "name": "Luxury Gifting with Lab Grown Diamond Necklace Sets",
          "settings": {
            "content": "<h1>Luxury Gifting with Lab Grown Diamond Necklace Sets</h1>",
            "custom_id": ""
