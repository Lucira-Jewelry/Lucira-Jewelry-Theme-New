        "richtext_rkHnPy": {
          "type": "richtext",
          "settings": {
            "content": "<p>Whenever making a large investment in gold, you should study the historic gold data to understand if making a purchase at the present price of gold will be profitable in the future or not. As an investor, knowing the gold worth today will help you decide if you should buy or sell gold today.</p>"
          }
        }
      },
