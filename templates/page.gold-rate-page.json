    "information_content_info_M9tj43": {
      "type": "information-content-info",
      "blocks": {
        "heading_xqyHHc": {
          "type": "heading",
          "name": "Today’s Gold Rate In India: What’s Gold Worth Today?",
          "settings": {
            "text": "Today’s Gold Rate In India: What’s Gold Worth Today?",
