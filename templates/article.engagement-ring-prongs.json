        "rich_text_RPKfir": {
          "type": "rich_text",
          "name": "Four Prong Setting:",
          "settings": {
            "content": "<p>Beyond a four or six prong setting, you may also go for more prongs, which are suitable for extra-large stones. They also provide added security to fancy shapes like marquise, pear, or heart.</p>",
            "custom_id": ""
          }
        },
