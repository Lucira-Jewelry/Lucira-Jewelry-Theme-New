<script>
    // Combined scroll effects handler
    class ScrollEffectsManager {
        constructor() {
            this.ticking = false;
            this.textReveal = null;
            
            // Initialize components
            this.init();
            this.bindEvents();
        }
        
        init() {
            // Initialize text reveal if the section exists
            if (document.getElementById('revealSection')) {
                this.textReveal = new TextRevealOnScroll();
            }
            
            // Run initial scroll effects
            this.updateAllScrollEffects();
        }
        
        updateAllScrollEffects() {
            // Smooth scroll effects for banner/sections
            this.updateSmoothScrollEffects();
            
            // Text reveal effects (if initialized)
            if (this.textReveal) {
                this.textReveal.handleScroll();
            }
            
            this.ticking = false;
        }
        
        updateSmoothScrollEffects() {
            const scrollY = window.scrollY;
            const windowHeight = window.innerHeight;
            const bannerContent = document.getElementById('bannerContent');
            const aboutText = document.getElementById('aboutText');
            const brandText = document.getElementById('brandText');

            // First section - smooth content movement with overflow hidden (center to bottom)
            if (bannerContent) {
                const section1Progress = Math.min(scrollY / windowHeight, 1);
                const translateY = section1Progress * windowHeight * 0.5;
                bannerContent.style.transform = `translate(-50%, calc(50% + ${translateY}px))`;
            }

            // Second section - fade in when visible
            if (aboutText) {
                const section2Top = windowHeight;
                if (scrollY >= section2Top - windowHeight * 0.3) {
                    aboutText.classList.add('visible');
                }
            }

            // Fourth/Last section - REVERSE EFFECT (top to center)
            if (brandText) {
                // Calculate the position of the brand section
                const brandSection = document.querySelector('.purpose-value-build-jewelry-brand');
                const brandSectionRect = brandSection.getBoundingClientRect();
                const brandSectionTop = scrollY + brandSectionRect.top;
                
                // Check if we're in the brand section's scroll zone
                const scrollStart = brandSectionTop - windowHeight;
                const scrollEnd = brandSectionTop;
                
                if (scrollY >= scrollStart && scrollY <= scrollEnd) {
                    // Calculate progress from 0 to 1 as we scroll through the section
                    const progress = (scrollY - scrollStart) / (scrollEnd - scrollStart);
                    const clampedProgress = Math.max(0, Math.min(1, progress));
                    
                    // Start from top (-100vh) and move to center (0vh)
                    const translateY = -100 + (clampedProgress * 100);
                    
                    brandText.style.transform = `translate(-50%, calc(-50% + ${translateY}vh))`;
                    brandText.style.opacity = clampedProgress;
                } else if (scrollY < scrollStart) {
                    // Before entering the section - stay at top
                    brandText.style.transform = `translate(-50%, calc(-50% - 100vh))`;
                    brandText.style.opacity = 0;
                } else {
                    // After the section - stay at center
                    brandText.style.transform = `translate(-50%, -50%)`;
                    brandText.style.opacity = 1;
                }
            }
        }
        
        onScroll() {
            if (!this.ticking) {
                requestAnimationFrame(() => this.updateAllScrollEffects());
                this.ticking = true;
            }
        }
        
        bindEvents() {
            // Single scroll event listener for all effects
            window.addEventListener('scroll', () => this.onScroll(), { passive: true });
        }
    }

    // Text Reveal Component (modified to work with the manager)
    class TextRevealOnScroll {
        constructor() {
            this.revealSection = document.getElementById('revealSection');
            this.revealText = document.getElementById('revealText');
            this.progressBar = document.getElementById('progressBar');
            
            if (!this.revealSection || !this.revealText) {
                console.warn('Text reveal elements not found');
                return;
            }
            
            this.originalText = this.revealText.textContent.trim();
            this.currentMode = 'word';
            this.elements = [];
            
            this.init();
            this.bindControlEvents();
        }
        
        init() {
            this.setupWordReveal();
            this.handleScroll();
        }
        
        setupWordReveal() {
            const words = this.originalText.split(' ');
            this.elements = words;
            
            this.revealText.innerHTML = words.map((word, index) => 
                `<span class="word" data-index="${index}">${word}</span>`
            ).join(' ');
        }
        
        setupCharReveal() {
            const chars = this.originalText.split('');
            this.elements = chars;
            
            this.revealText.innerHTML = chars.map((char, index) => {
                if (char === ' ') {
                    return `<span class="char space" data-index="${index}"> </span>`;
                }
                return `<span class="char" data-index="${index}">${char}</span>`;
            }).join('');
        }
        
        handleScroll() {
            if (!this.revealSection) return;
            
            const rect = this.revealSection.getBoundingClientRect();
            const windowHeight = window.innerHeight;
            const sectionHeight = this.revealSection.offsetHeight;
            
            let progress = 0;
            
            // Calculate progress based on 100vh scroll distance
            if (rect.top <= windowHeight && rect.bottom >= 0) {
                // When section enters viewport (top at 100vh) until it leaves (bottom at 0)
                progress = (windowHeight - rect.top) / windowHeight;
            }
            
            progress = Math.max(0, Math.min(1, progress));
            
            // Update progress bar
            if (this.progressBar) {
                this.progressBar.style.width = `${progress * 100}%`;
            }
            
            // Calculate elements to reveal
            const totalElements = this.elements.length;
            const elementsToReveal = Math.floor(progress * totalElements);
            
            // Reveal elements
            const elementSpans = this.revealText.querySelectorAll(
                this.currentMode === 'word' ? '.word' : '.char'
            );
            
            elementSpans.forEach((span, index) => {
                if (index <= elementsToReveal) {
                    span.classList.add('revealed');
                } else {
                    span.classList.remove('revealed');
                }
            });
        }
        
        switchMode(mode) {
            this.currentMode = mode;
            if (mode === 'word') {
                this.setupWordReveal();
            } else {
                this.setupCharReveal();
            }
            this.handleScroll();
        }
        
        reset() {
            const elementSpans = this.revealText.querySelectorAll(
                this.currentMode === 'word' ? '.word' : '.char'
            );
            elementSpans.forEach(span => span.classList.remove('revealed'));
            
            if (this.progressBar) {
                this.progressBar.style.width = '0%';
            }
        }
        
        bindControlEvents() {
            // Control buttons for text reveal
            const wordBtn = document.getElementById('wordBtn');
            const charBtn = document.getElementById('charBtn');
            const resetBtn = document.getElementById('resetBtn');
            
            if (wordBtn) {
                wordBtn.addEventListener('click', (e) => {
                    document.querySelectorAll('.reveal-controls button').forEach(btn => 
                        btn.classList.remove('active')
                    );
                    e.target.classList.add('active');
                    this.switchMode('word');
                });
            }
            
            if (charBtn) {
                charBtn.addEventListener('click', (e) => {
                    document.querySelectorAll('.reveal-controls button').forEach(btn => 
                        btn.classList.remove('active')
                    );
                    e.target.classList.add('active');
                    this.switchMode('char');
                });
            }
            
            if (resetBtn) {
                resetBtn.addEventListener('click', () => {
                    this.reset();
                });
            }
        }
    }

    // Initialize everything when DOM is loaded
    document.addEventListener('DOMContentLoaded', () => {
        new ScrollEffectsManager();
    });
</script>
