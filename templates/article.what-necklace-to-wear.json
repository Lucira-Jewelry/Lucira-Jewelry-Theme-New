        "rich_text_rQKzCe": {
          "type": "rich_text",
          "name": "Final Styling Recommendations",
          "settings": {
            "content": "<h2>Final Styling Recommendations</h2><p>When choosing which necklace to wear with which neckline, always remember the goal: enhance the shape, add visual balance, and suit your personal style. A V-neck offers the perfect canvas for pendants, lariats, and drop necklaces, allowing you to express elegance with minimal effort.</p>",
            "custom_id": "final",
            "text_alignment": "left"
          }
