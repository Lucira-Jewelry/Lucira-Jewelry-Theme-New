        "rich_text_gwnjAn": {
          "type": "rich_text",
          "name": "Our Vision: Blending Ethical Brilliance with Contemporary Design",
          "settings": {
            "content": "<h3>Our Vision: Blending Ethical Brilliance with Contemporary Design</h3><p>Founded by Rupesh Jain, Lucira is built on trust, transparency, and exquisite craftsmanship.</p><p>1.]Our Mission: To empower self-expression through bold, beautiful, and sustainable jewelry.<br/>2.]Our Promise: Every Lucira diamond is certified, of the highest quality, and guaranteed to be ethically sourced.<br/>3.]Our Focus: We specialize in creating stunning<a href=\"https://www.lucirajewelry.com/collections/\"> <span style=\"text-decoration:underline\">Collections</span></a> of lab-grown diamond jewelry in India that tell your story, without costing the Earth.</p>",
            "custom_id": ""
          }
        },
        "rich_text_pJQikP": {
          "type": "rich_text",
          "name": "Craft Your Story with Lucira's Exquisite Lab-Grown Diamond Jewelry",
          "settings": {
            "content": "<h2>Craft Your Story with Lucira's Exquisite Lab-Grown Diamond Jewelry</h2><p>Lucira offers a diverse portfolio of jewelry designed for every moment, from milestone celebrations to everyday elegance. Our pieces are crafted to be as unique as the individuals who wear them.</p>",
            "custom_id": "craft-your"
          }
        },
        "rich_text_i9T8xk": {
