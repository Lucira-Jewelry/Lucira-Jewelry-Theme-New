        "rich_text_JWgV8J": {
          "type": "rich_text",
          "name": "A Seamless & Transparent Experience: Lucira's Customer-First Services",
          "settings": {
            "content": "<h2>A Seamless & Transparent Experience: Lucira's Customer-First Services</h2><p>We believe the experience of buying a diamond should be as flawless as the diamond itself. Lucira offers a suite of services designed for your convenience and confidence.</p>",
            "custom_id": "a-seamless"
