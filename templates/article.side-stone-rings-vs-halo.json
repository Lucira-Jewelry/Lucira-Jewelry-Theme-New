        "rich_text_A8fUE6": {
          "type": "rich_text",
          "name": "What a Halo Ring Is and Why It Creates So Much Sparkle",
          "settings": {
            "content": "<h2>What a Halo Ring Is and Why It Creates So Much Sparkle</h2>",
            "custom_id": "what-a-halo",
            "text_alignment": "left"
          }
        },
        "rich_text_GiMmzb": {
          "type": "rich_text",
          "settings": {
            "content": "<p>A <a href=\"https://www.lucirajewelry.com/collections/halo-rings\" target=\"_blank\" title=\"halo ring\">halo ring</a> is designed differently. Instead of placing diamonds along the band, small diamonds are arranged in a circle around the center stone.</p><p>This ring of diamonds forms a “halo” around the center diamond.</p><p>The result is a brighter, more eye-catching appearance because light reflects from many stones at once.</p><p>Lucira’s Round Halo Split Diamond Ring shows this effect clearly. The small diamonds surrounding the center stone create a glowing frame that increases the overall brilliance of the ring.</p><p>Halo rings are especially popular with people who want their ring to stand out more.</p>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
