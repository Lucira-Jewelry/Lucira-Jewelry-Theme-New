          "name": "Heading",
          "settings": {
            "content": "<h1>What Are Engagement Ring Trends in 2025?</h1>",
            "custom_id": ""
          }
        },
        "follow_us_3ggfwT": {
          "type": "follow_us",
          "settings": {
            "heading": "Follow Us on"
