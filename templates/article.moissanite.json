          }
        },
        "image_with_text_YaTGTp": {
          "type": "image_with_text",
          "settings": {
            "image": "shopify://shop_images/Sustainability_0053bdec-967a-488a-bc17-48bee8d16f94.jpg",
            "text": "<p>Both moissanite and lab-grown diamonds are environmentally conscious alternatives to mined diamonds, but lab-grown diamonds take sustainability a step further. Lucira’s diamonds are 100% ethically created, certified by IGI, and free </p>",
            "layout_direction": "row",
