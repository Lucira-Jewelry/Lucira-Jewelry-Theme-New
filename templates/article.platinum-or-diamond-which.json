        "rich_text_iTeW3d": {
          "type": "rich_text",
          "settings": {
            "content": "<p>Diamonds almost always exceed platinum in overall cost when used in fine jewelry designs. A single premium-quality stone can cost more than an entire platinum band.</p>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
        "rich_text_33jfEi": {
          "type": "rich_text",
          "name": "Short-term vs Long-term Value",
          "settings": {
            "content": "<h2>Short-term vs Long-term Value</h2><ul><li>Diamonds often retain value when high clarity and color grades are present.<br/><br/></li><li>Platinum provides long-lasting durability and hypoallergenic benefits, appealing to those who want metal that lasts a lifetime.</li></ul>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
