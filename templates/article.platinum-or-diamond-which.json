        "faq_item_Xa7a9G": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Q1. What is a 22 carat gold hallmark?",
            "faq_answer": "<p> A 22 carat gold hallmark is a certification mark that confirms the jewellery contains 91.6% pure gold, tested and approved by BIS, along with traceability marks of the jeweller and lab.</p>"
          }
        },
        "faq_item_rcaANV": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Q2. Is hallmarking mandatory for 22K gold in India?",
            "faq_answer": "<p> Yes. Since 2021, all 22K gold jewellery sold in India must be hallmarked under BIS regulations.</p>"
          }
        },
        "faq_item_HMGtjz": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Q3. How do I verify a 22 carat gold hallmark?",
            "faq_answer": "<p> You can verify it using the BIS Care App, inspecting the hallmark symbols, and checking the invoice against the HUID number.</p>"
          }
        },
        "faq_item_UHKzLJ": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Q4. Can hallmarked 22K gold be fake?",
            "faq_answer": "<p>While rare, fake hallmarks exist. Always verify the HUID number and check for consistent BIS and purity marks.</p>"
          }
        },
        "faq_item_eAdDeB": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Q5. What is the HUID number?",
            "faq_answer": "<p> It is a 6-digit unique identification number issued for hallmarked jewellery from 2023 onward, allowing traceability and verification.</p>"
          }
        },
        "faq_item_jktigb": {
          "type": "faq_item",
          "settings": {
