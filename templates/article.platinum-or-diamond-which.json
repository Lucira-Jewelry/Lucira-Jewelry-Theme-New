        "rich_text_KFEFt3": {
          "type": "rich_text",
          "name": "Heading",
          "settings": {
            "content": "<h1>Platinum or Diamond: Which Is More Expensive? Complete 2025 Comparison</h1>",
            "custom_id": ""
          }
        },
        "follow_us_3ggfwT": {
          "type": "follow_us",
          "settings": {
            "heading": "Follow Us on"
          }
