        },
        "rich_text_JmwFBb": {
          "type": "rich_text",
          "settings": {
            "content": "<p>Lucira Jewelry offers custom design options so you can add your personal touch — be it your wedding date, a meaningful word, or a heartfelt message. Pair your customization with sustainable sparkle using<a href=\"https://www.lucirajewelry.com/collections/lab-grown-diamond\"> <span style=\"text-decoration:underline\">lab grown diamond</span></a> jewelry — ethical, brilliant, and made to last forever.</p><p>Every time she wears it, she’ll be reminded of the thought you put into choosing something truly her own.</p>",
            "custom_id": ""
          }
        },
        "rich_text_Jc4E4r": {
          "type": "rich_text",
