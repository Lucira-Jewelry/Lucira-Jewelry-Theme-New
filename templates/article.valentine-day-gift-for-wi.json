            "custom_id": "comparison"
          }
        },
        "rich_text_ADDTPa": {
          "type": "rich_text",
          "name": "Buying Guide: Smart Tips for Hallmarked Jewellery",
          "settings": {
            "content": "<h2>Thoughtful Gifts for Every Stage of Love</h2><p>Whether she’s your newlywed partner or a mother who continues to inspire you every day, jewelry is a reflection of appreciation.</p><ul><li><strong>For new moms:</strong> Choose lightweight pieces that blend comfort with grace.<br/></li><li><strong>For milestone anniversaries:</strong> A personalized pendant or ring celebrates the journey you’ve shared.<br/></li><li><strong>For everyday romance:</strong> A simple bracelet or stud earrings that remind her of you daily.<br/></li></ul><p>Each gift tells her, in its quiet brilliance — “You’re loved. You’re cherished. You’re my forever.”</p>",
            "custom_id": "buying"
          }
        },
