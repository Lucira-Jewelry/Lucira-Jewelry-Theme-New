        "rich_text_6WCWXy": {
          "type": "rich_text",
          "name": "Jewelry is more than adornment — it’s emotion turned into artistry. Here are some romantic valentine",
          "settings": {
            "content": "<p>Jewelry is more than adornment — it’s emotion turned into artistry. Here are some romantic <strong>valentine's day gift ideas for wife</strong> that reflect different shades of love and personality.</p>",
            "custom_id": "components"
          }
