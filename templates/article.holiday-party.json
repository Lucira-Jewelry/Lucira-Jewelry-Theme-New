        "rich_text_ARRHEL": {
          "type": "rich_text",
          "name": "Heading",
          "settings": {
            "content": "<h1>Top 07 Holiday Party Outfit Ideas</h1>",
            "custom_id": ""
          }
        },
        "follow_us_4Tk8dx": {
          "type": "follow_us",
          "settings": {
            "heading": "Follow Us on"
          }
