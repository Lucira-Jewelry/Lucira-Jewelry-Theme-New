        "faq_item_fbCzzh": {
          "type": "faq_item",
          "settings": {
            "faq_question": "1.] What does a Toi et Moi ring symbolize?",
            "faq_answer": "<p>A Toi et Moi ring symbolises two people united in one design. The two stones represent partners in a relationship.</p>"
          }
        },
        "faq_item_XeQk4g": {
          "type": "faq_item",
          "settings": {
            "faq_question": "2.] Are Toi et Moi rings popular for engagement rings?",
            "faq_answer": "<p>Yes. Many couples choose Toi et Moi rings because they represent partnership and individuality.</p>"
          }
        },
        "faq_item_tUecVH": {
          "type": "faq_item",
          "settings": {
            "faq_question": "3.] Do the two stones have to be the same shape?",
            "faq_answer": "<p>No. Many Toi et Moi rings intentionally use different shapes or gemstones to represent two unique personalities.</p>"
          }
        },
