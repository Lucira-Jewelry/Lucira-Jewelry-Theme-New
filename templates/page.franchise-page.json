    "faq_section_EJk8XE": {
      "type": "faq-section",
      "blocks": {
        "faq_item_RFi68h": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What is the lock in?",
            "faq_answer": "<p>The franchise has a lock-in period of 4.5 years in alignment with the payback timelines to ensure stable operations.</p>"
          }
        },
        "faq_item_GCHTEW": {
          "type": "faq_item",
          "settings": {
            "faq_question": "How much is the tenure of the agreement?",
            "faq_answer": "<p>The franchise agreement runs for 9 years.</p>"
          }
        },
        "faq_item_BCa4PU": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What is the security of the franchise?",
            "faq_answer": "<p>The franchise operates under a formal agreement, brand standards, and clearly defined commercial terms, ensuring complete transparency and operational clarity.<br/><br/></p>"
          }
        },
        "faq_item_bJnyzQ": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Is there any fee?",
            "faq_answer": "<p>Yes. The franchise requires a one time franchise fee which is included within the total investment.<br/><br/></p>"
          }
        },
        "faq_item_w9jdgw": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Will I get the store of my choice?",
            "faq_answer": "<p>You may propose your preferred location, and our team will evaluate it based on brand standards, market potential, visibility, and sales viability. If it meets the criteria, we will approve it.<br/><br/></p>"
          }
        },
        "faq_item_zRiycy": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What is the process to start?",
            "faq_answer": "<p>Submit your application → Location approval → Agreement signing → Store design and setup → Training and inventory → Grand launch.</p>"
          }
        },
        "faq_item_6adRfV": {
          "type": "faq_item",
          "settings": {
            "faq_question": "How fast can a franchise start?",
            "faq_answer": "<p>Once the agreement is signed, a store can be ready to open within 90 to 120 days, depending on site readiness and local permissions.</p>"
          }
        },
        "faq_item_pipQwk": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Who will run the store?",
            "faq_answer": "<p>The store will be operated by your hired team, while Lucira provides training, audits, and ongoing support to ensure smooth performance.</p>"
          }
        },
        "faq_item_gfkkJw": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Will I get support with reconciliation and bookkeeping?",
            "faq_answer": "<p>Yes. Lucira provides complete operational guidance, including daily reconciliation formats, reporting systems, and support with financial tracking.</p>"
          }
        },
        "faq_item_UkcQxA": {
          "type": "faq_item",
          "settings": {
            "faq_question": "How will I get initial stock?",
            "faq_answer": "<p>Initial inventory is supplied directly by Lucira based on your store size and assortment plan.<br/><br/></p>"
          }
        },
        "faq_item_HdAqPn": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Will I get GST input outstanding on the initial billing? How will I manage this?",
            "faq_answer": "<p>Yes. All GST input on initial billing will appear in your books.</p><p>You can utilize the input credit against future GST liabilities from your revenue.</p>"
          }
        },
        "faq_item_NYmfQr": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What happens if I want to exit before 4.5 years?",
            "faq_answer": "<p>Early exit is possible but subject to terms mentioned in the agreement, including notice period requirements and settlement of outstanding obligations.</p>"
          }
        },
        "faq_item_maNF7K": {
          "type": "faq_item",
          "settings": {
            "faq_question": "How will collections happen at the store?",
            "faq_answer": "<p>Customer payments flow directly into the designated franchise bank accounts, ensuring complete transparency.</p><p>Lucira audits collections regularly for accuracy.</p>"
          }
        },
        "faq_item_rtpWmq": {
          "type": "faq_item",
          "settings": {
            "faq_question": "How will I know the sales for the store?",
            "faq_answer": "<p>You will receive real time access to sales data through the POS system, along with daily, weekly, and monthly reports.<br/><br/></p>"
          }
        },
        "faq_item_HDE9Nw": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What expenses do I have to cover?",
            "faq_answer": "<p>You will be responsible for rent, salaries, utilities, local marketing, and operational expenses as outlined in the franchise agreement.<br/><br/></p>"
          }
        },
        "faq_item_Gypca6": {
          "type": "faq_item",
          "settings": {
            "faq_question": "How will I get the MG?",
            "faq_answer": "<p>The Minimum Guarantee (MG) is credited as per the defined cycle in your agreement, based on actuals and reconciled sales data.</p>"
          }
        },
        "faq_item_eGxNQK": {
          "type": "faq_item",
          "settings": {
            "faq_question": "How can I offset the extra GST input in my books?",
            "faq_answer": "<p>You can offset GST input against your monthly output GST liability generated through store sales.</p>"
          }
        },
        "faq_item_LmgHYJ": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Is there any timeline for GST input credits to be utilized? Do they lapse?",
            "faq_answer": "<p>GST input credits do not lapse as long as they remain valid under GST regulations.</p><p>They continue to carry forward until fully utilized.</p>"
          }
        }
      },
