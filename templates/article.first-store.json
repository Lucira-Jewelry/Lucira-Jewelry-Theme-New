        "rich_text_86FgMN": {
          "type": "rich_text",
          "name": "Why Choose Lucira Jewelry’s Lab Grown Diamond Jewelry?",
          "settings": {
            "content": "<h2>Why Choose Lucira Jewelry’s Lab Grown Diamond Jewelry?</h2>",
            "custom_id": "choose",
