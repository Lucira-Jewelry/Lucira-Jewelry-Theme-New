        "rich_text_HVNrRh": {
          "type": "rich_text",
          "name": "Oval Center Diamonds Look Elegant with Pear or Round Accent Stones",
          "settings": {
            "content": "<h2>Oval Center Diamonds Look Elegant with Pear or Round Accent Stones</h2>",
            "custom_id": "oval-center",
            "text_alignment": "left"
          }
        },
        "image_YDUrmD": {
          "type": "image",
