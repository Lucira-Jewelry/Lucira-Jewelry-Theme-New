          "type": "rich_text",
          "name": "Princess Cut Diamonds Pair Well with Straight or Channel Side Stones",
          "settings": {
            "content": "<h2>Princess Cut Diamonds Pair Well with Straight or Channel Side Stones</h2>",
            "custom_id": "princess",
            "text_alignment": "left"
