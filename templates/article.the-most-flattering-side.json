          "type": "rich_text",
          "name": "Marquise Center Diamonds Shine with Round or Pavé Side Stones",
          "settings": {
            "content": "<h2>Marquise Center Diamonds Shine with Round or Pavé Side Stones</h2>",
            "custom_id": "marquise",
            "text_alignment": "left"
          }
        },
