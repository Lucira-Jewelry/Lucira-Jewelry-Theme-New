        },
        "image_with_text_VWDmRU": {
          "type": "image_with_text",
          "settings": {
            "image": "shopify://shop_images/4_1c5c2735-0846-4fad-b11a-1918b360536b.jpg",
            "text": "<p>A <a href=\"https://www.lucirajewelry.com/collections/trilogy-engagement-rings\" target=\"_blank\" title=\"Trilogy Engagement RIng\">trilogy engagement ring</a> features three diamonds:  your past, your present, and your future. This design embodies the commitment that grows stronger with time. Each stone compliments the other, symbolizing how two lives intertwine and evolve together. <br/>Say yes if you’re drawn to sentimental designs that carry emotional depth. </p>",
            "reverse_layout": true,
            "custom_id": "",
            "image_size_option": "medium"
          }
        },
        "rich_text_BWVmEe": {
          "type": "rich_text",
          "name": "Elegance Ring Paragraph",
          "settings": {
            "content": "<p>This elegant engagement ring is the perfect for someone who cherishes every moment.<br/>Go the extra step by customising this ring with engravings that carry a personal message to embark on the journey of forever with a ring that sparkles for a lifetime. </p>",
