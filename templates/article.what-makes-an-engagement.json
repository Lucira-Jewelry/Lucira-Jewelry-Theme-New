    "faq_section_J4fpH8": {
      "type": "faq-section",
      "blocks": {
        "faq_item_PWTKCa": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What makes an engagement ring elegant?",
            "faq_answer": "<p>An elegant ring has balanced proportions, a well cut diamond, and a setting that suits everyday wear. Look for clean prongs, a comfortable band, and a diamond that catches light from all angles. The ring should look refined from both the top and the side.</p>"
          }
        },
        "faq_item_ETpqPc": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What makes an engagement ring timeless?",
            "faq_answer": "<p>Timeless rings avoid trends and rely on classic shapes like round or emerald cuts. Choose a design that is comfortable, durable, and easy to maintain. Neutral metals like yellow gold, white gold, or platinum help keep the look fresh for decades.</p>"
          }
        },
        "faq_item_f8LTP7": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What is the most elegant engagement ring shape?",
            "faq_answer": "<p>Round, oval, and emerald cuts are considered the most elegant because they flatter every hand shape. Round offers the most sparkle, oval creates a soft elongated look, and emerald gives a calm mirror like shine.</p>"
          }
        },
        "faq_item_z7mjHE": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What does a timeless ring mean?",
            "faq_answer": "<p>A timeless ring is one that continues to feel beautiful no matter your age or the current style. It usually has a clean setting, a classic diamond shape, and a metal color you will enjoy wearing every day.</p>"
          }
        },
        "faq_item_fTVcN9": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What are the four main types of diamonds?",
            "faq_answer": "<p>Round, princess, emerald, and cushion cuts are the main diamond shapes. They are popular because they offer predictable sparkle, suit many settings and are easy to pair with wedding bands.</p>"
          }
        },
        "faq_item_ABLJ79": {
          "type": "faq_item",
          "settings": {
            "faq_question": "How can I make an engagement ring unique?",
            "faq_answer": "<p>Add meaningful details such as an engraving, a hidden gemstone inside the band, a custom gallery or a mixed metal setting. These touches personalize the ring without making it look overly trendy</p>"
          }
        },
        "faq_item_XXYUKn": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Why are engagement rings so fancy?",
            "faq_answer": "<p>Engagement rings are made with high quality materials and careful craftsmanship because they are meant to last for life. Diamonds, gold, and platinum are durable, and the detailed work ensures the ring stays secure and beautiful for life.</p>"
          }
        }
      },
