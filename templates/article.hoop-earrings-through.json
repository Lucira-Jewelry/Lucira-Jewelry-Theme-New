        "rich_text_rJaBdp": {
          "type": "rich_text",
          "name": "Introduction",
          "settings": {
            "content": "<p>Hoop earrings have transcended time, culture, and fashion to become one of the most enduring styles in the world of jewellery. From ancient civilizations to modern-day runway looks, the hoop’s circular silhouette continues to symbolize unity, infinity, and effortless elegance. Today, modern fine jewellery houses like Lucira are reinterpreting this timeless form - blending tradition with contemporary aesthetics to create pieces that resonate with today’s sophisticated wearers.</p>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
        "rich_text_3mEYbJ": {
          "type": "rich_text",
          "name": "The Evolution of Hoop Earrings",
          "settings": {
            "content": "<h2>The Evolution of Hoop Earrings</h2>",
            "custom_id": "the-evolution",
            "text_alignment": "left"
