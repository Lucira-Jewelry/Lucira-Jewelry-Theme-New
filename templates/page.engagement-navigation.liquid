{% comment %}
Template: page.engagement-navigation
Description: Dynamic tab navigation system
{% endcomment %}

{% layout 'theme' %}

{% comment %} Include the section directly {% endcomment %}
{% section 'nested-tab-navigation' %}


{% assign current_slug = request.path | split: '/' | last %}
{% assign main_tab_slug = request.path | split: '/' | last | default: 'engagement' %}

{% comment %} Get main tab data {% endcomment %}
{% assign main_tab = shop.metaobjects.navigation_tab.values 
  | where: "slug", main_tab_slug 
  | first 
  | default: shop.metaobjects.navigation_tab.values 
  | where: "slug", "engagement" 
  | first %}

{% comment %} Get all main tabs (tabs without parent) {% endcomment %}
{% assign main_tabs = shop.metaobjects.navigation_tab.values 
  | where: "parent_tab", blank 
  | where: "is_active", true 
  | sort: "sort_order" %}

{% comment %} Get sub-tabs for current main tab {% endcomment %}
{% assign sub_tabs = shop.metaobjects.navigation_tab.values 
  | where: "parent_tab.slug", main_tab_slug 
  | where: "is_active", true 
  | sort: "sort_order" %}

{% comment %} Get current content page if sub-tab is selected {% endcomment %}
{% assign current_content_page = nil %}
{% if request.path contains '/pages/' %}
  {% assign path_parts = request.path | split: '/' %}
  {% assign content_slug = path_parts[3] | default: path_parts[2] %}
  
  {% if content_slug != main_tab_slug %}
    {% assign current_content_page = shop.metaobjects.content_page.values 
      | where: "slug", content_slug 
      | where: "parent_tab.slug", main_tab_slug 
      | first %}
  {% endif %}
{% endif %}

{% comment %} Set meta information {% endcomment %}
{% if current_content_page %}
  {% assign page_title = current_content_page.meta_title | default: current_content_page.content_header %}
  {% assign page_description = current_content_page.meta_description | default: current_content_page.content_body | strip_html | truncate: 160 %}
{% else %}
  {% assign page_title = main_tab.title %}
  {% assign page_description = main_tab.description | strip_html | truncate: 160 %}
{% endif %}

{% assign featured_image = current_content_page.banner_image | default: main_tab.banner_image %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ shop.url }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{ main_tab.title }}",
      "item": "{{ shop.url }}/pages/{{ main_tab.slug }}"
    }
    {% if current_content_page %}
    ,{
      "@type": "ListItem",
      "position": 3,
      "name": "{{ current_content_page.content_header }}",
      "item": "{{ shop.url }}/pages/{{ main_tab.slug }}/{{ current_content_page.slug }}"
    }
    {% endif %}
  ]
}
</script>

<div class="page-width" data-section-id="{{ section.id }}" data-section-type="tab-navigation">
  <!-- Dynamic Banner Section -->
  <section class="tab-banner" id="tab-banner">
    <div class="banner-image-container">
      {% if featured_image %}
        <img src="{{ featured_image | image_url: width: 2000 }}" 
             alt="{{ main_tab.title }}" 
             class="banner-image"
             loading="eager"
             width="2000"
             height="800">
      {% endif %}
      
      <div class="banner-content">
        <h1 class="banner-title" id="banner-header">
          {% if current_content_page %}
            {{ current_content_page.content_header }}
          {% else %}
            {{ main_tab.header }}
          {% endif %}
        </h1>
        
        <p class="banner-description" id="banner-description">
          {% if current_content_page %}
            {{ current_content_page.content_body | strip_html | truncate: 200 }}
          {% else %}
            {{ main_tab.description }}
          {% endif %}
        </p>
        
        <a href="{% if current_content_page %}{{ current_content_page.cta_link }}{% else %}{{ main_tab.cta_link }}{% endif %}" 
           class="button button--primary" 
           id="banner-cta">
          {% if current_content_page %}
            {{ current_content_page.cta_text | default: 'Learn More' }}
          {% else %}
            {{ main_tab.cta_text | default: 'Explore Collection' }}
          {% endif %}
        </a>
      </div>
    </div>
  </section>

  <!-- Main Tabs Navigation -->
  <nav class="main-tabs-navigation" aria-label="Main navigation">
    <ul class="main-tabs-list" id="main-tabs">
      {% for tab in main_tabs %}
        <li class="main-tab-item {% if tab.slug == main_tab.slug %}active{% endif %}">
          <a href="/pages/{{ tab.slug }}" 
             class="main-tab-link"
             data-tab-slug="{{ tab.slug }}"
             data-banner-src="{{ tab.banner_image | image_url: width: 2000 }}"
             data-banner-header="{{ tab.header }}"
             data-banner-description="{{ tab.description }}"
             data-banner-cta-text="{{ tab.cta_text }}"
             data-banner-cta-link="{{ tab.cta_link }}">
            {{ tab.title }}
          </a>
        </li>
      {% endfor %}
    </ul>
  </nav>

  <!-- Sub Tabs Navigation -->
  {% if sub_tabs.size > 0 %}
    <nav class="sub-tabs-navigation" aria-label="Sub navigation">
      <ul class="sub-tabs-list" id="sub-tabs">
        {% for sub_tab in sub_tabs %}
          {% comment %} Get content page for this sub-tab {% endcomment %}
          {% assign content_page = shop.metaobjects.content_page.values 
            | where: "slug", sub_tab.slug 
            | where: "parent_tab.slug", main_tab_slug 
            | first %}
          
          <li class="sub-tab-item {% if current_content_page.slug == sub_tab.slug %}active{% endif %}">
            <a href="/pages/{{ main_tab_slug }}/{{ sub_tab.slug }}" 
               class="sub-tab-link"
               data-content-slug="{{ sub_tab.slug }}"
               {% if content_page %}
                 data-banner-src="{{ content_page.banner_image | default: sub_tab.banner_image | image_url: width: 2000 }}"
                 data-banner-header="{{ content_page.content_header }}"
                 data-banner-description="{{ content_page.content_body | strip_html | truncate: 200 }}"
                 data-banner-cta-text="{{ content_page.cta_text }}"
                 data-banner-cta-link="{{ content_page.cta_link }}"
               {% endif %}>
              {{ sub_tab.title }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>
  {% endif %}

  <!-- Dynamic Content Area -->
  <section class="tab-content-area" id="content-area">
    {% if current_content_page %}
      <article class="content-page">
        <div class="content-page__header">
          <h2>{{ current_content_page.content_header }}</h2>
        </div>
        
        <div class="content-page__body rte">
          {{ current_content_page.content_body }}
        </div>
        
        {% if current_content_page.gallery_images.size > 0 %}
          <div class="content-page__gallery">
            <h3>Gallery</h3>
            <div class="gallery-grid">
              {% for image in current_content_page.gallery_images %}
                <div class="gallery-item">
                  <img src="{{ image | image_url: width: 600 }}" 
                       alt="{{ current_content_page.content_header }} - Image {{ forloop.index }}"
                       loading="lazy"
                       width="600"
                       height="400">
                </div>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </article>
    {% else %}
      <!-- Default content for main tab -->
      <article class="default-content">
        <div class="rte">
          {{ page.content }}
        </div>
      </article>
    {% endif %}
  </section>

  <!-- Related Topics Section -->
  <section class="related-topics-section">
    <h3 class="related-topics__title">RELATED TOPICS</h3>
    
    {% assign related_articles = current_content_page.related_topics | default: main_tab.related_blogs %}
    
    {% if related_articles.size > 0 %}
      <ul class="related-topics__list">
        {% for article_ref in related_articles %}
          {% assign article = article_ref %}
          <li class="related-topic__item">
            <a href="{{ article.url }}" class="related-topic__link">
              {{ article.title }}
            </a>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <!-- Fallback to manually selected articles -->
      {% assign fallback_articles = blogs['news'].articles | limit: 5 %}
      {% if fallback_articles.size > 0 %}
        <ul class="related-topics__list">
          {% for article in fallback_articles %}
            <li class="related-topic__item">
              <a href="{{ article.url }}" class="related-topic__link">
                {{ article.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    {% endif %}
  </section>

  <!-- Explore More Section -->
  <section class="explore-more-section">
    <h3 class="explore-more__title">EXPLORE MORE</h3>
    
    <div class="explore-more__grid">
      {% comment %} Get related content pages {% endcomment %}
      {% assign related_content = shop.metaobjects.content_page.values 
        | where: "parent_tab.slug", main_tab_slug 
        | where: "slug", "!=", current_content_page.slug 
        | limit: 3 %}
      
      {% for content in related_content %}
        <div class="explore-card">
          <a href="/pages/{{ main_tab_slug }}/{{ content.slug }}" class="explore-card__link">
            {% if content.banner_image %}
              <img src="{{ content.banner_image | image_url: width: 400 }}" 
                   alt="{{ content.content_header }}"
                   class="explore-card__image"
                   loading="lazy"
                   width="400"
                   height="300">
            {% endif %}
            
            <div class="explore-card__content">
              <h4 class="explore-card__title">{{ content.content_header }}</h4>
              <p class="explore-card__excerpt">{{ content.content_body | strip_html | truncate: 100 }}</p>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </section>
</div>

<style>
  /* Tab Navigation Styles */
  .main-tabs-navigation {
    margin: 40px 0;
    border-bottom: 1px solid #e0e0e0;
  }
  
  .main-tabs-list {
    display: flex;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
    gap: 10px;
  }
  
  .main-tab-item {
    margin: 0 5px;
  }
  
  .main-tab-link {
    padding: 15px 30px;
    text-decoration: none;
    color: #333;
    border-bottom: 3px solid transparent;
    font-weight: 500;
    transition: all 0.3s ease;
  }
  
  .main-tab-item.active .main-tab-link,
  .main-tab-link:hover {
    border-bottom-color: #000;
    color: #000;
  }
  
  .sub-tabs-navigation {
    margin: 20px 0 40px;
  }
  
  .sub-tabs-list {
    display: flex;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
    gap: 15px;
  }
  
  .sub-tab-item {
    margin: 0 5px;
  }
  
  .sub-tab-link {
    padding: 10px 20px;
    text-decoration: none;
    color: #666;
    background: #f5f5f5;
    border-radius: 4px;
    transition: all 0.3s ease;
  }
  
  .sub-tab-item.active .sub-tab-link,
  .sub-tab-link:hover {
    background: #000;
    color: #fff;
  }
  
  /* Banner Styles */
  .tab-banner {
    position: relative;
    margin-bottom: 40px;
  }
  
  .banner-image-container {
    position: relative;
    height: 500px;
    overflow: hidden;
  }
  
  .banner-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .banner-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
    color: white;
    padding: 40px;
  }
  
  .banner-title {
    font-size: 3rem;
    margin-bottom: 15px;
  }
  
  .banner-description {
    font-size: 1.2rem;
    max-width: 600px;
    margin-bottom: 20px;
  }
  
  /* Content Area */
  .tab-content-area {
    margin: 60px 0;
  }
  
  .content-page__gallery {
    margin-top: 40px;
  }
  
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
    margin-top: 20px;
  }
  
  .gallery-item img {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }
  
  /* Related Topics */
  .related-topics-section {
    margin: 60px 0;
    padding: 40px 0;
    border-top: 1px solid #e0e0e0;
    border-bottom: 1px solid #e0e0e0;
  }
  
  .related-topics__title {
    margin-bottom: 30px;
    text-align: center;
  }
  
  .related-topics__list {
    list-style: none;
    padding: 0;
    margin: 0;
    text-align: center;
  }
  
  .related-topic__item {
    margin: 10px 0;
  }
  
  .related-topic__link {
    color: #333;
    text-decoration: none;
    font-size: 1.1rem;
  }
  
  .related-topic__link:hover {
    text-decoration: underline;
  }
  
  /* Explore More */
  .explore-more-section {
    margin: 60px 0;
  }
  
  .explore-more__title {
    margin-bottom: 40px;
    text-align: center;
  }
  
  .explore-more__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }
  
  .explore-card {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.3s ease;
  }
  
  .explore-card:hover {
    transform: translateY(-5px);
  }
  
  .explore-card__image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  
  .explore-card__content {
    padding: 20px;
  }
  
  .explore-card__title {
    margin-bottom: 10px;
  }
  
  .explore-card__excerpt {
    color: #666;
    font-size: 0.9rem;
  }
  
  /* Responsive Styles */
  @media (max-width: 768px) {
    .main-tabs-list {
      flex-direction: column;
      align-items: center;
    }
    
    .main-tab-link {
      padding: 12px 20px;
      width: 100%;
      text-align: center;
    }
    
    .sub-tabs-list {
      flex-direction: column;
      align-items: center;
    }
    
    .sub-tab-link {
      width: 100%;
      text-align: center;
    }
    
    .banner-image-container {
      height: 300px;
    }
    
    .banner-content {
      padding: 20px;
    }
    
    .banner-title {
      font-size: 2rem;
    }
    
    .explore-more__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  class ShopifyTabNavigation {
    constructor() {
      this.init();
    }

    init() {
      this.cacheSelectors();
      this.bindEvents();
      this.setupHistory();
    }

    cacheSelectors() {
      this.mainTabLinks = document.querySelectorAll('.main-tab-link');
      this.subTabLinks = document.querySelectorAll('.sub-tab-link');
      this.bannerImage = document.querySelector('.banner-image');
      this.bannerHeader = document.querySelector('.banner-title');
      this.bannerDescription = document.querySelector('.banner-description');
      this.bannerCta = document.querySelector('.button--primary');
    }

    bindEvents() {
      // Prevent default link behavior for main tabs and handle with AJAX
      this.mainTabLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          this.handleMainTabClick(e.currentTarget);
        });
      });

      // Handle sub tab clicks
      this.subTabLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          this.handleSubTabClick(e.currentTarget);
        });
      });
    }

    setupHistory() {
      // Handle browser back/forward buttons
      window.addEventListener('popstate', (e) => {
        if (e.state && e.state.tabSlug) {
          this.loadTab(e.state.tabSlug);
        }
      });
    }

    async handleMainTabClick(tabLink) {
      const tabSlug = tabLink.dataset.tabSlug;
      const url = `/pages/${tabSlug}`;
      
      // Update URL without reload
      history.pushState({ tabSlug: tabSlug }, '', url);
      
      // Update banner immediately from data attributes
      this.updateBannerFromAttributes(tabLink);
      
      // Load tab content via AJAX
      await this.loadTab(tabSlug);
      
      // Update active states
      this.updateActiveTab('main', tabSlug);
    }

    async handleSubTabClick(tabLink) {
      const contentSlug = tabLink.dataset.contentSlug;
      const mainTabSlug = window.location.pathname.split('/')[2];
      const url = `/pages/${mainTabSlug}/${contentSlug}`;
      
      // Update URL
      history.pushState({ contentSlug: contentSlug }, '', url);
      
      // Update banner
      this.updateBannerFromAttributes(tabLink);
      
      // Load content via AJAX
      await this.loadContent(contentSlug);
      
      // Update active state
      this.updateActiveTab('sub', contentSlug);
    }

    async loadTab(tabSlug) {
      try {
        // Show loading state
        document.body.classList.add('loading');
        
        // Fetch tab content
        const response = await fetch(`/pages/${tabSlug}?view=ajax`);
        const html = await response.text();
        
        // Parse the response
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        
        // Update sub tabs
        const newSubTabs = doc.querySelector('.sub-tabs-navigation');
        const currentSubTabs = document.querySelector('.sub-tabs-navigation');
        
        if (newSubTabs && currentSubTabs) {
          currentSubTabs.innerHTML = newSubTabs.innerHTML;
        } else if (newSubTabs && !currentSubTabs) {
          document.querySelector('.main-tabs-navigation').after(newSubTabs);
        } else if (!newSubTabs && currentSubTabs) {
          currentSubTabs.remove();
        }
        
        // Update content area
        const newContent = doc.querySelector('.tab-content-area');
        const currentContent = document.querySelector('.tab-content-area');
        if (newContent && currentContent) {
          currentContent.innerHTML = newContent.innerHTML;
        }
        
        // Update related topics
        const newRelatedTopics = doc.querySelector('.related-topics-section');
        const currentRelatedTopics = document.querySelector('.related-topics-section');
        if (newRelatedTopics && currentRelatedTopics) {
          currentRelatedTopics.innerHTML = newRelatedTopics.innerHTML;
        }
        
        // Update explore more section
        const newExploreMore = doc.querySelector('.explore-more-section');
        const currentExploreMore = document.querySelector('.explore-more-section');
        if (newExploreMore && currentExploreMore) {
          currentExploreMore.innerHTML = newExploreMore.innerHTML;
        }
        
        // Rebind events for new elements
        this.rebindEvents();
        
        // Update meta tags
        this.updateMetaTags(doc);
        
      } catch (error) {
        console.error('Error loading tab:', error);
        // Fallback to full page load
        window.location.href = `/pages/${tabSlug}`;
      } finally {
        document.body.classList.remove('loading');
      }
    }

    async loadContent(contentSlug) {
      try {
        const mainTabSlug = window.location.pathname.split('/')[2];
        const response = await fetch(`/pages/${mainTabSlug}/${contentSlug}?view=ajax`);
        const html = await response.text();
        
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        
        // Update content area
        const newContent = doc.querySelector('.tab-content-area');
        const currentContent = document.querySelector('.tab-content-area');
        if (newContent && currentContent) {
          currentContent.innerHTML = newContent.innerHTML;
        }
        
        // Update related topics
        const newRelatedTopics = doc.querySelector('.related-topics-section');
        const currentRelatedTopics = document.querySelector('.related-topics-section');
        if (newRelatedTopics && currentRelatedTopics) {
          currentRelatedTopics.innerHTML = newRelatedTopics.innerHTML;
        }
        
        // Update meta tags
        this.updateMetaTags(doc);
        
      } catch (error) {
        console.error('Error loading content:', error);
        window.location.reload();
      }
    }

    updateBannerFromAttributes(element) {
      if (element.dataset.bannerSrc) {
        this.bannerImage.src = element.dataset.bannerSrc;
      }
      
      if (element.dataset.bannerHeader) {
        this.bannerHeader.textContent = element.dataset.bannerHeader;
      }
      
      if (element.dataset.bannerDescription) {
        this.bannerDescription.textContent = element.dataset.bannerDescription;
      }
      
      if (element.dataset.bannerCtaText) {
        this.bannerCta.textContent = element.dataset.bannerCtaText;
      }
      
      if (element.dataset.bannerCtaLink) {
        this.bannerCta.href = element.dataset.bannerCtaLink;
      }
    }

    updateActiveTab(type, activeSlug) {
      // Remove active class from all tabs
      if (type === 'main') {
        document.querySelectorAll('.main-tab-item').forEach(item => {
          item.classList.remove('active');
        });
        
        // Add active class to current tab
        const activeTab = document.querySelector(`.main-tab-link[data-tab-slug="${activeSlug}"]`);
        if (activeTab) {
          activeTab.parentElement.classList.add('active');
        }
      } else if (type === 'sub') {
        document.querySelectorAll('.sub-tab-item').forEach(item => {
          item.classList.remove('active');
        });
        
        const activeTab = document.querySelector(`.sub-tab-link[data-content-slug="${activeSlug}"]`);
        if (activeTab) {
          activeTab.parentElement.classList.add('active');
        }
      }
    }

    updateMetaTags(doc) {
      // Update page title
      const newTitle = doc.querySelector('title');
      if (newTitle) {
        document.title = newTitle.textContent;
      }
      
      // Update meta description
      const newMetaDesc = doc.querySelector('meta[name="description"]');
      const currentMetaDesc = document.querySelector('meta[name="description"]');
      if (newMetaDesc && currentMetaDesc) {
        currentMetaDesc.content = newMetaDesc.content;
      }
      
      // Update canonical link
      const newCanonical = doc.querySelector('link[rel="canonical"]');
      const currentCanonical = document.querySelector('link[rel="canonical"]');
      if (newCanonical && currentCanonical) {
        currentCanonical.href = newCanonical.href;
      }
    }

    rebindEvents() {
      // Rebind events for newly loaded elements
      this.cacheSelectors();
      this.bindEvents();
    }
  }

  // Initialize when DOM is loaded
  document.addEventListener('DOMContentLoaded', () => {
    new ShopifyTabNavigation();
  });
</script>