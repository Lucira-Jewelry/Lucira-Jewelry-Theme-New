            "show_products": true,
            "products": [
              "marquise-bezel-diamond-stud-earrings",
              "0-50-ct-pear-solitaire-cascade-hoops-earrings"
            ]
          }
        },
        "rich_text_bhGzpc": {
          "type": "rich_text",
          "name": "3. Look for the HUID Number",
          "settings": {
            "content": "<h2>3. Look for the HUID Number</h2>",
            "custom_id": "look",
            "text_alignment": "left"
          }
        },
        "image_8Qp4zt": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Look_for_the_HUID_Number.jpg"
          }
        },
        "rich_text_qwTzXx": {
          "type": "rich_text",
          "settings": {
            "content": "<p>Every hallmarked gold item now comes with a 6-digit alphanumeric HUID code.</p><p>What to look for: A unique code engraved along with the hallmark.</p><p>Real-life example: After buying earrings, you enter the HUID number in the BIS Care app and confirm the product details match.</p>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
        "image_with_text_BiE3eV": {
          "type": "image_with_text",
          "name": "Image With Text",
          "settings": {
            "text": "",
            "layout_direction": "row",
