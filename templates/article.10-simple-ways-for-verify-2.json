            ]
          }
        },
        "rich_text_A8fUE6": {
          "type": "rich_text",
          "name": "2. Verify the Purity Mark (Karat Value)",
          "settings": {
            "content": "<h2>2. Verify the Purity Mark (Karat Value)</h2>",
            "custom_id": "verify",
            "text_alignment": "left"
          }
        },
        "image_hLzBxi": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Verify_the_Purity_Mark.jpg"
          }
        },
        "rich_text_AJHQPB": {
          "type": "rich_text",
          "settings": {
            "content": "<p>Gold purity is always mentioned along with the hallmark.</p><p>What to look for: Numbers like 916 (22K), 750 (18K), or 585 (14K).</p><p>Real-life example: You buy a gold chain and notice “750” engraved on it. This means it is 18K gold, suitable for daily wear jewellery.</p>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
        "image_with_text_ry4cQt": {
          "type": "image_with_text",
          "name": "Image With Text ",
          "settings": {
            "text": "",
            "layout_direction": "row",
            "reverse_layout": false,
            "custom_id": "",
