            "products": [
              "0-20-cts-dewdrop-diamond-ring",
              "0-25-cts-classic-solitaire-diamond-ring"
            ]
          }
        },
        "rich_text_mEE3FU": {
          "type": "rich_text",
          "name": "4. Check the Jeweller’s Identification Mark",
          "settings": {
            "content": "<h2>4. Check the Jeweller’s Identification Mark</h2>",
            "custom_id": "check",
            "text_alignment": "left"
          }
        },
        "image_YXJJUH": {
          "type": "image",
          "settings": {}
        },
        "rich_text_REkBDD": {
          "type": "rich_text",
          "settings": {
            "content": "<p>Each BIS-certified jeweller has a unique identification mark.</p><p>What to look for: A jeweller’s stamp or code alongside the hallmark.</p><p>Real-life example: You compare two stores—one provides a BIS jeweller ID on the product, the other doesn’t. You choose the certified one.</p>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
        "image_with_text_XgNzg9": {
          "type": "image_with_text",
          "name": "Image With Text",
          "settings": {
