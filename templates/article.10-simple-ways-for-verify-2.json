        "faq_item_M3T9jp": {
          "type": "faq_item",
          "settings": {
            "faq_question": "1]  What is BIS hallmark in gold?",
            "faq_answer": "<p>BIS hallmark is a certification that confirms the purity and authenticity of gold jewellery in India.</p>"
          }
        },
        "faq_item_4bnBLF": {
          "type": "faq_item",
          "settings": {
            "faq_question": "2 ] What is HUID in gold jewellery?",
            "faq_answer": "<p>HUID is a unique identification number assigned to each hallmarked gold item for verification.</p>"
          }
        },
        "faq_item_tCyF6M": {
          "type": "faq_item",
          "settings": {
            "faq_question": "3 ] Can I check gold hallmark online?",
            "faq_answer": "<p>Yes, you can verify gold using the BIS Care app by entering the HUID number.</p>"
          }
        },
        "faq_item_R6EaTN": {
          "type": "faq_item",
          "settings": {
            "faq_question": "4 ] Is 916 gold always hallmarked?",
            "faq_answer": "<p>Yes, 916 gold (22K) should be BIS hallmarked to ensure authenticity.</p>"
          }
        },
        "faq_item_8iDt9Q": {
          "type": "faq_item",
          "settings": {
            "faq_question": "5 ] What happens if gold is not hallmarked?",
            "faq_answer": "<p>Non-hallmarked gold may not guarantee purity and can lead to financial loss during resale or exchange.</p>"
          }
        }
      },
