        "rich_text_rJaBdp": {
          "type": "rich_text",
          "name": "Introduction",
          "settings": {
            "content": "<p>Earrings are more than just accessories; they're an expression of individuality, elegance and personal style. Whether you prefer minimal studs or dramatic chandeliers, understanding earring types helps you choose the perfect pair for every occasion.</p><p>At <a href=\"https://www.lucirajewelry.com/\" target=\"_blank\" title=\"https://www.lucirajewelry.com/\">Lucira Jewelry</a>, every piece tells a story of craftsmanship and conscious luxury. This guide will walk you through the most popular earring types, what makes them unique and how to choose the perfect style for your look and budget.</p>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
        "rich_text_9cELiG": {
          "type": "rich_text",
          "name": "1. Stud Earrings -Simple, Timeless, and Elegant",
          "settings": {
            "content": "<h2>1. Stud Earrings -Simple, Timeless, and Elegant</h2>",
            "custom_id": "stud-earrings",
            "text_alignment": "left"
          }
        },
        "image_with_text_C4KUKT": {
          "type": "image_with_text",
          "name": "Image with Text",
          "settings": {
            "image": "shopify://shop_images/1._Stud_Earrings_Simple_Timeless_and_Elegant.png",
            "text": "<p>Studs are the foundation of every jewelry collection. Sitting neatly on the earlobe, they’re perfect for everyday wear and ethnic looks. From classic diamonds to sleek metals, studs pair effortlessly with every outfit.</p>",
            "layout_direction": "row",
            "reverse_layout": true,
            "custom_id": "cut",
            "image_size_option": "adaptive",
            "show_products": true,
            "products": [
              "bezel-set-hexagon-diamond-earrings",
              "celestial-hex-diamond-stud-earrings"
            ]
          }
        },
        "rich_text_qw7HLy": {
          "type": "rich_text",
          "settings": {
            "content": "<p>If you appreciate minimalist beauty, explore the handcrafted designs from our<a href=\"https://www.lucirajewelry.com/collections/\"> <span style=\"text-decoration:underline\">Collections</span></a>, where timeless elegance meets modern artistry.</p>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
        "rich_text_A8fUE6": {
          "type": "rich_text",
          "name": "2. Hoop Earrings – Versatile and Bold",
          "settings": {
            "content": "<h2>2. Hoop Earrings – Versatile and Bold</h2>",
            "custom_id": "hoop",
            "text_alignment": "left"
          }
        },
        "image_with_text_ry4cQt": {
          "type": "image_with_text",
          "name": "Image with Text ",
          "settings": {
