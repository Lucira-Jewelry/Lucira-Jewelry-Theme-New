          }
        },
        "rich_text_AJHQPB": {
          "type": "rich_text",
          "settings": {
            "content": "<p>For a warm toned twist, the soft hue of rose gold offers a modern charm. Discover that refined glow in our<a href=\"https://www.lucirajewelry.com/collections/rose-gold-diamond-necklace\"> <span style=\"text-decoration:underline\">rose gold diamond necklace</span></a> collection, a perfect complement to any hoop or minimalist earring ensemble.</p>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
