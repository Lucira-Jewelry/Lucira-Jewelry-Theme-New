          "type": "rich_text",
          "name": "3. Drop Earrings – Effortlessly Graceful",
          "settings": {
            "content": "<h2>3. Drop Earrings – Effortlessly Graceful</h2>",
            "custom_id": "drop",
            "text_alignment": "left"
          }
        },
        "image_with_text_BiE3eV": {
          "type": "image_with_text",
          "name": "Image with Text ",
