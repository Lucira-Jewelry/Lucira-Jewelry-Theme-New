        },
        "rich_text_n7Jhe6": {
          "type": "rich_text",
          "name": "2. They’re Way More Affordable",
          "settings": {
            "content": "<h3>2. They’re Way More Affordable</h3><p>A Naturally Colored Diamond can cost a small fortune. But with Lab Grown options, you can get that same beauty without the giant price tag. It's like unlocking a luxury that used to feel off-limits.</p>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
        "rich_text_7UNinH": {
          "type": "rich_text",
          "name": "3. They’re Better for the Planet",
          "settings": {
            "content": "<h3>3. They’re Better for the Planet</h3>",
            "custom_id": "",
            "text_alignment": "left"
          }
        },
        "image_with_text_DJexEQ": {
          "type": "image_with_text",
          "settings": {
            "image": "shopify://shop_images/Sustainaiblity.jpg",
            "text": "<p>Lab Grown means no large-scale mining, fewer environmental concerns, and a cleaner supply chain. So you’re not just wearing something gorgeous, you’re wearing something you can feel good about.</p>",
            "layout_direction": "row",
            "reverse_layout": false,
            "custom_id": "",
