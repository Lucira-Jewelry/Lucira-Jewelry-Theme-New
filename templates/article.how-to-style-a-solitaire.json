    "faq_section_96ebQw": {
      "type": "faq-section",
      "blocks": {
        "faq_item_nHTx9p": {
          "type": "faq_item",
          "settings": {
            "faq_question": "1. Can I wear a solitaire ring every day?",
            "faq_answer": "<p>Yes. Solitaire rings are designed to be worn daily. Their simple design makes them comfortable and easy to pair with different outfits.</p>"
          }
        },
        "faq_item_GVgzBR": {
          "type": "faq_item",
          "settings": {
            "faq_question": "2 .Can solitaire rings be stacked with other rings?",
            "faq_answer": "<p>Yes, many people like to stack slim bands with their solitaire ring. Stackable designs like Lucira’s Elegant Solitaire Stackable Ring work especially well for this.</p>"
          }
        },
        "faq_item_NBPxf8": {
          "type": "faq_item",
          "settings": {
            "faq_question": "3. Are solitaire rings only for engagements?",
            "faq_answer": "<p>Not at all. While solitaire rings are popular for engagements, they are also worn as fashion rings, anniversary gifts, or everyday jewellery.</p>"
          }
        },
        "faq_item_YWgC9D": {
          "type": "faq_item",
          "settings": {
            "faq_question": "4. Which diamond shape looks best for a solitaire ring?",
            "faq_answer": "<p>Round, oval, and emerald cuts are among the most popular choices because they highlight the diamond beautifully in solitaire settings.</p>"
          }
        },
        "faq_item_UqMwLC": {
          "type": "faq_item",
          "settings": {
            "faq_question": "5. Are solitaire rings suitable for men?",
            "faq_answer": "<p>Yes. Many modern designs are created specifically for men. Rings like the Geometric Emerald Solitaire Men’s Ring offer a stylish and confident look.</p>"
          }
        }
      },
