        },
        "rich_text_6WCWXy": {
          "type": "rich_text",
          "name": "Factors That Improve Lab Grown Diamonds Resale Value",
          "settings": {
            "content": "<p>Even though the resale value of lab grown diamonds tends to be lower, certain factors can increase the amount you can recover.</p>",
            "custom_id": "factors",
            "text_alignment": "left"
          }
        },
        "rich_text_xii4nX": {
          "type": "rich_text",
          "name": "Lab Grown vs Natural Diamonds",
          "settings": {
            "content": "<h2>Lab Grown vs Natural Diamonds: Resale Value Comparison</h2>",
