    "faqs_NazHdb": {
      "type": "faq-section",
      "blocks": {
        "faq_item_6wKYkP": {
          "type": "faq_item",
          "settings": {
            "faq_question": "What is a Lucira video call?",
            "faq_answer": "<p>A live, one-on-one session with our jewelry expert, where you can view pieces up close. It’s just like being in a store, but from the comfort of your home.</p>"
          }
        },
        "faq_item_decRbX": {
          "type": "faq_item",
          "settings": {
            "faq_question": "How do I book a video call?",
            "faq_answer": "<p>Just fill out the form on our video call page with your name, email, and phone number. Our team will reach out to check your preferred time slots and send a confirmation once your appointment is scheduled.</p>"
          }
        },
        "faq_item_Gti6mg": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Is the video call free?",
            "faq_answer": "<p>Yes, it’s completely free! Our video call service is a personal shopping experience to help you find the perfect piece.</p>"
          }
        },
        "faq_item_CpLeE4": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Can I request specific pieces to view?",
            "faq_answer": "<p>Absolutely! While booking your call, just mention the styles or product codes you're interested in, and we'll have them ready to show you during your session.</p>"
          }
        },
        "faq_item_Fkkwxt": {
          "type": "faq_item",
          "settings": {
            "faq_question": "How long does a video call last?",
            "faq_answer": "<p>Most video calls last around 20 - 25 minutes, but there’s no time limit. We’re happy to take as much or as little time as you need!</p>"
          }
        },
        "faq_item_qDNVzF": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Can I reschedule or cancel the call?",
            "faq_answer": "<p>Yes, you can easily reschedule or cancel by replying to your confirmation email or messaging our team. We’ll take care of the rest.</p>"
          }
        },
        "faq_item_kxn3DW": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Can I place an order during or after the call?",
            "faq_answer": "<p>Yes! You can place your order during the call or our expert will guide you through the steps to complete your purchase afterward.</p>"
          }
        },
        "faq_item_WXjBRc": {
          "type": "faq_item",
          "settings": {
            "faq_question": "Can someone join the video call with me?",
            "faq_answer": "<p>Absolutely! Feel free to invite a friend, family member, or partner to join you while you explore our jewelry together.</p>"
          }
        }
      },
