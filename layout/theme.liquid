    <script>
      function getUTMParameter(name) {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get(name) || '';
      }
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'pageView',
        pageData: {
          pageType: "{{ template | split: '.' | first }}",
          pageUrl: '{{ canonical_url }}',
          utmSource: getUTMParameter('utm_source'),
          utmMedium: getUTMParameter('utm_medium'),
          utmCampaign: getUTMParameter('utm_campaign'),
          utmTerm: getUTMParameter('utm_term'),
          utmContent: getUTMParameter('utm_content'),
          utmId: getUTMParameter('utm_id'),
        },
      });
      window.dataLayer.push({
        event: 'customerData',
        customer: {
          name: "{{ customer.first_name | default: '' }} {{ customer.last_name | default: '' }}",
          mobile: "{{ customer.phone | default: '' }}",
          email: "{{ customer.email | default: '' }}",
          gender: "{{ customer.metafields.custom.gender | default: '' }}",
          dob: "{{ customer.metafields.custom.dob | default: '' }}",
          doa: "{{ customer.metafields.custom.doa | default: '' }}",
          billingAddress: {
            address_line1: "{{ customer.default_address.address1 | default: '' }}",
            address_line2: "{{ customer.default_address.address2 | default: '' }}",
            city: "{{ customer.default_address.city | default: '' }}",
            state: "{{ customer.default_address.province | default: '' }}",
            country: "{{ customer.default_address.country | default: '' }}",
            zip_code: "{{ customer.default_address.zip | default: '' }}",
          },
          shippingAddress: {
            address_line1: "{{ customer.default_address.address1 | default: '' }}",
            address_line2: "{{ customer.default_address.address2 | default: '' }}",
            city: "{{ customer.default_address.city | default: '' }}",
            state: "{{ customer.default_address.province | default: '' }}",
            country: "{{ customer.default_address.country | default: '' }}",
            zip_code: "{{ customer.default_address.zip | default: '' }}",
          },
          deviceType: /Mobi|Android|iPhone/i.test(navigator.userAgent) ? 'mobile' : 'desktop',
        },
      });
      window.dataLayer.push({
        event: 'marketingData',
        marketing: {
          utmSource: getUTMParameter('utm_source'),
          utmMedium: getUTMParameter('utm_medium'),
          utmCampaign: getUTMParameter('utm_campaign'),
          utmTerm: getUTMParameter('utm_term'),
          utmContent: getUTMParameter('utm_content'),
          utmId: getUTMParameter('utm_id'),
        },
      });
    </script>

