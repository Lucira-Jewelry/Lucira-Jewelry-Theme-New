    <template id="delayed-scripts-template">
      {% render 'delayed-scripts' %}
    </template>
    
    <script>
      (function() {
        var scriptsLoaded = false;
        function loadDelayedScripts() {
          if (scriptsLoaded) return;
          scriptsLoaded = true;
          var template = document.getElementById('delayed-scripts-template');
          if (!template || !template.content) return;
          
          var container = document.createElement('div');
          container.appendChild(template.content.cloneNode(true));
          
          var scripts = container.querySelectorAll('script');
          scripts.forEach(function(oldScript, index) {
            setTimeout(function() {
              var newScript = document.createElement('script');
              Array.from(oldScript.attributes).forEach(function(attr) {
                newScript.setAttribute(attr.name, attr.value);
              });
              if (oldScript.src) {
                newScript.src = oldScript.src;
              } else {
                newScript.textContent = oldScript.textContent;
              }
              document.body.appendChild(newScript);
            }, index * 100);
          });

          setTimeout(function() {
            while (container.firstChild) {
              if (container.firstChild.tagName !== 'SCRIPT') {
                document.body.appendChild(container.firstChild);
              } else {
                container.removeChild(container.firstChild);
              }
            }
          }, 10);
          
          console.log('⚡ Apps hydrated safely');
        }
        window.addEventListener('scroll', loadDelayedScripts, { passive: true, once: true });
        window.addEventListener('mousemove', loadDelayedScripts, { passive: true, once: true });
        window.addEventListener('touchstart', loadDelayedScripts, { passive: true, once: true });
        setTimeout(loadDelayedScripts, 5000);
      })();
    </script>
