<script>
  document.addEventListener('DOMContentLoaded', function () {
    const CONFIG = {
      storageKey: 'lucira_profile_data',
      apiBase: 'https://api.lucirajewelry.com/earn-rewards',
      totalSteps: 4,
      pointsPerStep: 100
    };
    const defaultState = {
      currentStep: 1,
      maxStepReached: 0,
      formData: {},
      rewardedSteps: [],
      profileComplete: false,
      customerId: null
    };

    let state = JSON.parse(JSON.stringify(defaultState)); // Deep copy
    const ui = {
      trackProgress: document.getElementById('trackProgress'),
      ringFill: document.getElementById('ringFill'),
      ringPct: document.getElementById('ringPct'),
      coinsDisplay: document.getElementById('coinsEarned'),
      marriedToggle: document.getElementById('marriedToggle'),
      spouseFields: document.getElementById('spouseFields'),
      stepList: document.getElementById('stepsList')
    };

    const CIRCUMFERENCE = 2 * Math.PI * 42;
    if(ui.ringFill) ui.ringFill.style.strokeDasharray = CIRCUMFERENCE;

    async function init() {
      loadLocalState();
      bindEvents();
      if (window.customerData && window.customerData.id) {
        await fetchProgressFromServer();
      }
      renderUI();
    }

    window.goToStep = function(step) {
      const direction = step > state.currentStep ? 'forward' : 'backward';
      scrapeFormData();
      
      if (direction === 'forward') {
        const rewardedSet = new Set(state.rewardedSteps);
        
        if (!rewardedSet.has(state.currentStep)) {
          state.rewardedSteps.push(state.currentStep);
          state.maxStepReached = Math.max(state.maxStepReached, state.currentStep);
          
          saveLocalState();
          saveStepToApi(state.currentStep);
        }
      }

      state.currentStep = step;
      saveLocalState();
      renderUI();
      document.querySelector('.page-wrap').scrollIntoView({ behavior: 'smooth' });
    };

    window.completeProfile = function() {
      scrapeFormData();
      state.maxStepReached = 4;
      state.profileComplete = true;
      
      // Add step 4 if not present
      if(!state.rewardedSteps.includes(4)) {
        state.rewardedSteps.push(4);
      }
      
      saveLocalState();
      saveStepToApi(4);
      renderUI();
    };

    async function fetchProgressFromServer() {
      try {
        const customerId = `shopify-${window.customerData.id}`;
        const res = await fetch(`${CONFIG.apiBase}/get-progress.php?customer_id=${customerId}&t=${Date.now()}`);
        const data = await res.json();

        if (data && typeof data.completed_steps !== 'undefined') {
          
          const serverSteps = data.completed_steps.map(Number);

          if (serverSteps.length === 0 && state.rewardedSteps.length > 0) {
             resetState();
             return; 
          }

          // Otherwise, sync up
          state.rewardedSteps = serverSteps;
          state.maxStepReached = Math.max(...serverSteps, 0);
          
          if (state.rewardedSteps.includes(4)) {
            state.profileComplete = true;
            state.currentStep = 4;
          }

          saveLocalState();
        }
      } catch (e) {
        console.error('Sync with server failed', e);
      }
    }

    function saveStepToApi(step) {
      if (!window.customerData || !window.customerData.id) return;

      const payload = {
        customer_id: `shopify-${window.customerData.id}`,
        step: step
      };

      fetch(`${CONFIG.apiBase}/save-step.php`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        keepalive: true 
      })
      .then(res => res.json())
      .catch(err => console.error('API Save Error:', err));
    }

    // ── Helper Functions ──

    function resetState() {
      // Reset to defaults
      state = JSON.parse(JSON.stringify(defaultState));
      // Ensure we keep the current ID if logged in
      if (window.customerData?.id) {
        state.customerId = window.customerData.id;
      }
      localStorage.removeItem(CONFIG.storageKey);
    }

    function scrapeFormData() {
      document.querySelectorAll('input, select, textarea').forEach(el => {
        if (el.type === 'radio') {
          if (el.checked) state.formData[el.name] = el.value;
        } else if (el.type === 'checkbox') {
          state.formData[el.id] = el.checked;
        } else {
          let key = el.id || el.name || 'field_' + Math.random();
          state.formData[key] = el.value;
        }
      });

      document.querySelectorAll('.chip-group').forEach((group, index) => {
        const selected = Array.from(group.querySelectorAll('.chip.selected')).map(c => c.innerText);
        state.formData['chip_group_' + index] = selected;
      });
    }

    function restoreFormInputs() {
      if (!state.formData) return;
      Object.entries(state.formData).forEach(([key, value]) => {
        const el = document.getElementById(key);
        if (el) {
          if (el.type === 'checkbox') el.checked = value;
          else el.value = value;
        }
      });
      // Chips restoration logic could be added here if needed
      toggleSpouseFields();
    }

    function saveLocalState() {
      // Always ensure the current logged in user owns this data
      if (window.customerData?.id) {
        state.customerId = window.customerData.id;
      }
      localStorage.setItem(CONFIG.storageKey, JSON.stringify(state));
    }

    function loadLocalState() {
      const saved = localStorage.getItem(CONFIG.storageKey);
      if (saved) {
        try {
          const parsed = JSON.parse(saved);
          
          // CRITICAL FIX: Check Ownership
          // If we are logged in, but the saved data belongs to a different ID (or no ID), reset.
          if (window.customerData && window.customerData.id) {
             if (parsed.customerId && parsed.customerId.toString() !== window.customerData.id.toString()) {
               console.log("User mismatch detected. Resetting form.");
               resetState();
               return;
             }
          }

          state = { ...state, ...parsed };
          
          // Ensure arrays/sets are handled correctly
          if(!Array.isArray(state.rewardedSteps)) {
             state.rewardedSteps = [];
          }

          restoreFormInputs();
        } catch (e) {
          console.error("Error parsing local state, resetting", e);
          resetState();
        }
      }
    }

    function renderUI() {
      // Update Milestones (Dots)
      // We do this first so completion screen doesn't break logic
      for (let i = 0; i <= CONFIG.totalSteps; i++) {
        const dot = document.getElementById('dot' + i);
        const lbl = document.getElementById('lbl' + i);
        if (dot) {
            dot.classList.toggle('done', i < state.currentStep);
            dot.classList.toggle('current', i === state.currentStep);
            
            // Also color the label
            if(lbl) {
              lbl.classList.toggle('done', i < state.currentStep);
              lbl.classList.toggle('current', i === state.currentStep);
            }
        }
      }

      // Logic for Completion Screen
      if (state.profileComplete) {
        document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
        const compScreen = document.getElementById('step-complete');
        if(compScreen) compScreen.classList.add('active');
        
        if(ui.trackProgress) ui.trackProgress.style.width = '100%';
        updateProgressRing(100);
        
        // Max out coins visual
        if(ui.coinsDisplay) ui.coinsDisplay.innerText = CONFIG.totalSteps * CONFIG.pointsPerStep;
        return;
      }

      // Toggle Panels
      document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
      const currPanel = document.getElementById('step-' + state.currentStep);
      if(currPanel) currPanel.classList.add('active');

      // Update Top Progress Bar
      const barPercent = ((state.currentStep - 1) / (CONFIG.totalSteps)) * 100; // Adjusted math slightly
      if(ui.trackProgress) ui.trackProgress.style.width = barPercent + '%';

      // Update Sidebar & Coins
      // Calculate based on unique rewarded steps
      const coins = state.rewardedSteps.length * CONFIG.pointsPerStep;
      if(ui.coinsDisplay) ui.coinsDisplay.innerText = coins;
      
      updateProgressRing((state.maxStepReached / CONFIG.totalSteps) * 100);
      
      // Update sidebar checklist
      if(ui.stepList) {
        const lis = ui.stepList.querySelectorAll('li');
        lis.forEach((li, idx) => {
           const stepNum = idx + 1;
           if(state.rewardedSteps.includes(stepNum)) {
             li.classList.add('done');
             const cc = li.querySelector('.check-circle');
             if(cc) cc.classList.add('done');
           } else {
             li.classList.remove('done');
             const cc = li.querySelector('.check-circle');
             if(cc) cc.classList.remove('done');
           }
        });
      }
    }

    function updateProgressRing(percent) {
      if(!ui.ringFill) return;
      const offset = CIRCUMFERENCE - (percent / 100) * CIRCUMFERENCE;
      ui.ringFill.style.strokeDashoffset = offset;
      if(ui.ringPct) ui.ringPct.innerText = Math.round(percent);
    }

    function bindEvents() {
      document.querySelectorAll('.chip').forEach(c => {
        c.addEventListener('click', () => {
          // Deselect others in group
          const parent = c.parentElement;
          // Toggle logic: If you want single select per row, uncomment below:
          // parent.querySelectorAll('.chip').forEach(sib => sib.classList.remove('selected'));
          
          c.classList.toggle('selected');
          scrapeFormData();
          saveLocalState();
        });
      });

      if(ui.marriedToggle) {
        ui.marriedToggle.addEventListener('change', () => {
          toggleSpouseFields();
          scrapeFormData();
          saveLocalState();
        });
      }
    }

    function toggleSpouseFields() {
      if (ui.spouseFields && ui.marriedToggle) {
        ui.spouseFields.style.display = ui.marriedToggle.checked ? 'block' : 'none';
      }
    }

    init();
  });
</script>


