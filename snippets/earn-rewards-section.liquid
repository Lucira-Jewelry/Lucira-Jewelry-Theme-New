
<style>
  :root {
    --ink:        #1c1410;
    --gold:       #b8892a;
    --gold-light: #d4aa5a;
    --blush:      #b76f79;
    --ivory:      #faf7f3;
    --ivory-2:    #f2ede6;
    --border:     #e5ddd4;
    --muted:      #9a8f85;
    --white:      #ffffff;
    --dark-btn:   #3d2a1e;
    --success:    #c2906a;
    --r:          3px;
    --shadow:     0 2px 20px rgba(28,20,16,.07);
    --shadow-lg:  0 8px 40px rgba(28,20,16,.12);
  }
  .banner{background:var(--ink);color:var(--white);text-align:center;padding:7px 16px;font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:400;position:fixed;top:0;left:0;right:0;z-index:100}
  .banner em{color:var(--gold-light);font-style:normal}
  .page-wrap{max-width: 980px; margin: 32px auto 0; padding: 0 32px 0px 0; display: grid; grid-template-columns: 1fr 210px; gap: 20px; align-items: start;}
  .main-card{background:var(--white);box-shadow:var(--shadow);border-radius:var(--r);overflow:hidden}
  .pts-bar-wrap{padding:20px 28px 16px;background:#F4F0F0;border-bottom:1px solid var(--ivory-2)}
  .pts-track{display:flex;align-items:flex-start;gap:0;position:relative;margin-bottom:6px}
  .pts-segment{flex:1;display:flex;flex-direction:column;align-items:center;position:relative}
  .pts-segment:first-child{align-items:flex-start}
  .pts-segment:last-child{align-items:flex-end}
  .pts-label{font-size:9px;letter-spacing:1px;color:var(--muted);text-transform:uppercase;margin-bottom:8px;white-space:nowrap}
  .pts-label.gold{color:#b76f79;font-weight:500}
  .pts-line-row{display:flex;align-items:center;width:100%;position:relative}
  .track-full{position:relative;height:3px;background:var(--border);flex:1;margin:0;border-radius:2px;overflow:hidden;align-self:center}
  .track-fill{position:absolute;top:0;left:0;bottom:0;background:linear-gradient(90deg,var(--blush),#b76f79);border-radius:2px;transition:width .8s cubic-bezier(.4,0,.2,1)}
  .milestones-row{display:flex;align-items:center;position:relative;padding:0 2px}
  .milestone{display:flex;flex-direction:column-reverse;align-items:center;flex:1;position:relative;gap: 8px;}
  .milestone:first-child{align-items:flex-start}
  .milestone:last-child{align-items:flex-end}
  .m-dot{width:22px;height:22px;border-radius:50%;border:2px solid var(--border);background:var(--white);display:flex;align-items:center;justify-content:center;position:relative;z-index:2;transition:all .3s ease;cursor:default;flex-shrink:0}
  .m-dot.done{background: #b76f79; border-color: #b76f79;}
  .m-dot.current{background:var(--white);border-color:#b76f79;box-shadow:0 0 0 3px rgb(255 255 255 / 15%)}
  .m-dot svg{display:none}
  .m-dot.done svg{display:block}
  .m-dot-inner{width:8px;height:8px;border-radius:50%;background:var(--border)}
  .m-dot.done .m-dot-inner{display:none}
  .m-dot.current .m-dot-inner{background:#b76f79}
  .m-label { font-size: 12px; font-weight: 500; letter-spacing: .8px; text-transform: uppercase; margin-top: 6px; white-space: nowrap; }
  .m-label.done{color:#000;}
  .m-label.current{color:#000000;font-weight:500}
  .pts-hint{font-size: 14px; color: #1a1a1a; margin-top: 10px; letter-spacing: .3px;}
  .pts-hint strong{color:#b76f79;font-weight:500}
  .pts-hint strong {font-size: 14px;}
  .milestones-container{position:relative;padding:0 0px;margin-bottom:4px}
  .track-bg{position: absolute; top: 41px; left: 0; right: 0; height: 10px; background: #ffffff; border-radius: 2px; display: block !important; width: 100%;}
  .track-progress{position:absolute;top:41px;left:0;height:10px;background:#b76f79;border-radius:2px;transition:width .8s cubic-bezier(.4,0,.2,1);display: block !important; border-radius: 3rem;}
  .milestones-inner{display:flex;justify-content:space-between;position:relative;z-index:2}
  .step-tabs{display:flex;border-bottom:1px solid var(--border);background:var(--ivory-2)}
  .step-tab{flex:1;text-align:center;padding:9px 4px;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;font-weight:400;font-family:Futura Std,sans-serif}
  .step-tab.done{color:var(--ink)}
  .step-tab.active{color:var(--blush);border-bottom-color:var(--blush);background:var(--white)}
  .step-panel{display:none}
  .step-panel.active{display:block;animation:fadeSlide .35s ease}
  
  @keyframes fadeSlide{
  from{opacity:0;transform:translateY(8px)}
  to{opacity:1;transform:translateY(0)}
  }
  .step-body{padding:20px 20px 20px}
  .step-eyebrow{font-size:9px;letter-spacing:2.5px;text-transform:uppercase;color:var(--blush);margin-bottom:5px;font-weight:500}
  .step-title{color: var(--ink); margin-bottom: 4px; letter-spacing: .3px; font-family: Futura Std; font-weight: 500; font-size: 20px; line-height: 150%; vertical-align: middle;}
  .step-sub { color: #666666; margin-bottom: 22px; font-family: Futura Std; font-weight: 400; font-size: 14px; line-height: 150%; vertical-align: middle; }
  .field-label{font-size:9.5px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:10px;margin-top:18px;font-weight:500}
  .field-label:first-child{margin-top:0}
  .radio-group{display:flex;gap:18px;flex-wrap:wrap;margin-bottom:4px}
  .radio-opt{display:flex;align-items:center;gap:7px;cursor:pointer}
  .radio-opt input[type=radio]{appearance:none;width:15px;height:15px;border:1.5px solid var(--border);border-radius:50%;cursor:pointer;position:relative;transition:border-color .2s;flex-shrink:0}
  .radio-opt input[type=radio]:checked{border-color:var(--blush)}
  .radio-opt input[type=radio]::after{content:'';position:absolute;top:50%;left:50%;width:7px;height:7px;background:var(--blush);border-radius:50%;transform:translate(-50%,-50%) scale(0);transition:transform .2s ease}
  .radio-opt input[type=radio]:checked::after{transform:translate(-50%,-50%) scale(1)}
  .radio-opt label{font-size:12px;color:var(--ink);cursor:pointer;letter-spacing:.3px}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:4px}
  .form-row.single{grid-template-columns:1fr}
  .form-field{display:flex;flex-direction:column;position:relative}
  .form-field>label{font-size:9.5px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:8px;font-weight:500}
  .input-wrap{position:relative;display:flex;align-items:center}
  .input-wrap input[type=date],.input-wrap input[type=text]{width: 100%; border: 1px solid #f4f0f0; border-radius: 8px; padding: 12px 10px 12px 12px; font-size: 12px; color: var(--ink); background: #f4f0f0; outline: 0; transition: border-color .2s, background .2s; -webkit-appearance: none; color-scheme: light; font-family: 'Futura Std', sans-serif;}
  .input-wrap input:focus{border-color:var(--blush);background:var(--white)}
  .input-wrap input:focus+.input-icon{color:var(--blush)}
  .input-icon{position:absolute;right:12px;top:50%;transform:translateY(-50%);color:var(--muted);pointer-events:none;transition:color .2s}
  .input-icon svg{display:block}
  .toggle-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-top:1px solid var(--ivory-2);border-bottom:1px solid var(--ivory-2);margin:14px 0 14px}
  .toggle-text{font-size:12px;color:var(--ink);letter-spacing:.2px;color: #000 !important;}
  .toggle-switch{position:relative;width:40px;height:22px;flex-shrink:0}
  .toggle-switch input{display:none}
  .toggle-track{position:absolute;inset:0;background:var(--border);border-radius:22px;cursor:pointer;transition:background .3s}
  .toggle-track::after{content:'';position:absolute;width:16px;height:16px;background:var(--white);border-radius:50%;top:3px;left:3px;transition:transform .3s;box-shadow:0 1px 4px rgba(0,0,0,.2)}
  .toggle-switch input:checked~.toggle-track{background:var(--blush)}
  .toggle-switch input:checked~.toggle-track::after{transform:translateX(18px)}
  .chip-group{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:4px}
  .chip{padding:6px 16px;border:1px solid var(--border);border-radius:20px;font-size:11px;letter-spacing:.5px;cursor:pointer;color:var(--ink);background:var(--white);transition:all .2s;font-family:Futura Std,sans-serif;font-weight:400}
  .chip:hover{border-color:var(--blush);color:var(--blush)}
  .chip.selected{background:var(--blush);border-color:var(--blush);color:var(--white)}
  .checkbox-list{display:flex;flex-direction:column;gap:10px;margin-bottom:4px}
  .checkbox-opt{display:flex;align-items:center;gap:10px;cursor:pointer}
  .checkbox-opt input[type=checkbox]{appearance:none;width:15px;height:15px;border:1.5px solid var(--border);border-radius:3px;cursor:pointer;position:relative;transition:all .2s;flex-shrink:0;background:var(--white)}
  .checkbox-opt input[type=checkbox]:checked{background:var(--blush);border-color:var(--blush)}
  .checkbox-opt input[type=checkbox]:checked::after{content:'';position:absolute;top:1px;left:4px;width:5px;height:8px;border-right:2px solid #fff;border-bottom:2px solid #fff;transform:rotate(45deg)}
  .checkbox-opt label{font-size:12px;color:var(--ink);cursor:pointer;line-height:1.5}
  .step-actions{display:flex;align-items:center;justify-content:space-between;margin-top:24px;padding-top:18px;border-top:1px solid var(--ivory-2)}
  .btn-back{font-size:9.5px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);background:0 0;border:none;cursor:pointer;font-family:Futura Std,sans-serif;transition:color .2s;padding:4px 0}
  .btn-back:hover{color:var(--ink)}
  .btn-continue{background:var(--dark-btn);color:var(--white);border:none;padding:11px 26px;font-family:Futura Std,sans-serif;font-size:9.5px;letter-spacing:2.5px;text-transform:uppercase;cursor:pointer;display:flex;align-items:center;gap:10px;border-radius:var(--r);transition:background .2s,transform .1s;font-weight:500}
  .btn-continue:hover{background:var(--blush)}
  .btn-continue:active{transform:scale(.98)}
  .btn-continue svg{width:12px;height:12px;flex-shrink:0}
  .fun-facts{background:var(--ivory-2);border-top:1px solid var(--border);padding:16px 28px;display:flex;gap:12px;align-items:flex-start}
  .fun-facts-icon{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--blush),#b76f79);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
  .fun-facts-icon svg{display:block}
  .fun-facts-title{font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--blush);margin-bottom:5px;font-weight:500}
  .fun-facts-content p{font-size: 14px; color: #000000; line-height: 1.65; font-style: italic; font-weight: 400;margin-top: 8px;}
  .sidebar{display:flex;flex-direction:column;gap:14px;position:sticky;top:60px}
  .progress-card{background:var(--white);border:0;border-radius:var(--r);padding:22px 18px;text-align:center;box-shadow:var(--shadow)}
  .ring-wrap{position:relative;width:96px;height:96px;margin:0 auto 14px}
  .ring-wrap svg{transform:rotate(-90deg);display:block}
  .ring-bg{fill:none;stroke:var(--ivory-2);stroke-width:5}
  .ring-fill{fill:none; stroke: #b76f79;stroke-width:5;stroke-linecap:round;stroke-dasharray:264;stroke-dashoffset:264;transition:stroke-dashoffset .9s cubic-bezier(.4,0,.2,1)}
  .ring-center{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;gap: 4px;}
  .ring-pct{font-family:'Futura Std',serif;font-size:22px;font-weight:500;color:var(--ink);line-height:1}
  .ring-sign{font-size:11px;font-family:Futura Std,sans-serif;font-weight:400;color:var(--muted);letter-spacing:.5px;margin-top:2px}
  .progress-card-label{font-size:9.5px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:16px;font-weight:500}
  .steps-list{list-style:none;text-align:left;display:flex;flex-direction:column;gap:10px;border-top:1px solid var(--ivory-2);padding-top:14px;padding-left: 0;}
  .steps-list li{display:flex;align-items:center;gap:9px;font-size:11.5px;color:var(--muted);transition:color .3s}
  .steps-list li.done{color:var(--ink)}
  .check-circle{width:18px;height:18px;border-radius:50%;border:1.5px solid var(--border);background:var(--white);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .3s}
  .check-circle.done{background:#b76f79;border-color:transparent}
  .check-circle svg{display:none}
  .check-circle.done svg{display:block}
  .check-circle-dot{width:6px;height:6px;border-radius:50%;background:var(--border);transition:background .3s}
  .check-circle.current .check-circle-dot,.check-circle.done .check-circle-dot{display:none}
  .check-circle.current{border-color:#b76f79;box-shadow:0 0 0 2px rgba(184,137,42,.2)}
  .help-card{background:var(--ink);border-radius:var(--r);padding:16px 16px;text-align:center;box-shadow:var(--shadow)}
  .help-card-label{font-size:10px;letter-spacing:1px;color:rgba(255,255,255,.5);text-transform:uppercase;margin-bottom:8px}
  .help-card a{color:#fff;text-decoration:none;font-size:11.5px;display:inline-flex;align-items:center;gap:5px;letter-spacing:.3px;transition:color .2s}
  .help-card a:hover{color:var(--white)}
  .help-card a svg{width:10px;height:10px}
  .rewards-card{background:linear-gradient(135deg,#3d2a1e,#5c3d28);border-radius:var(--r);padding:14px 16px;text-align:center;box-shadow:var(--shadow)}
  .rewards-card-label{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:6px}
  .rewards-card-pts{font-family:'Futura Std',serif;font-size:26px;color:#fff;font-weight:500;line-height:1;margin-bottom:2px}
  .rewards-card-sub{font-size:10px;color:rgba(255,255,255,.45);letter-spacing:.5px;margin-top: 8px;}
  .track-progress {display: block !important;}
  
  .input-wrap .input-icon svg {stroke: #000;}
  .step-actions button:disabled {max-width: 145px !important; width: 100%; margin: 0 !important;border-radius: 3rem; align-items: center; font-size: 12px !important;}
  .btn-continue {border-radius: 3rem !important; background: var(--blush) !important; align-items: center !important; font-size: 12px !important;}
  .chip-group .chip { margin: 0 !important; color: #b76f79; border: 1px solid #b76f79; font-size: 14px; }
  .chip-group .chip.selected { margin: 0 !important; color: #fff; border: 1px solid #b76f79; }
  .chip-group .chip {min-width: calc(32% + var(--buttons-border-width) * 2) !important; min-height: calc(4rem + var(--buttons-border-width) * 2) !important;border-radius: 8px;}
  button.btn-back { max-width: 145px !important; width: 100%; margin: 0 !important; border-radius: 3rem; align-items: center; font-size: 12px !important; background: #ffffff; color: #b76f79; border: 1px solid #b76f79; }
  @media (max-width:700px){
  .page-wrap{grid-template-columns:1fr}
  .sidebar{display:grid;grid-template-columns:1fr 1fr;position:static}
  .progress-card{grid-column:1/-1}
  .form-row{grid-template-columns:1fr}
  
  }
</style>

<div class="page-wrap">
  <div class="main-card">
    <div class="pts-bar-wrap">
      <div class="milestones-container">
        <div class="track-bg"></div>
        <div class="track-progress" id="trackProgress" style="width:0%"></div>
        <div class="milestones-inner">
          <div class="milestone">
            <div class="m-dot done" id="dot0">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
              <div class="m-dot-inner"></div>
            </div>
            <div class="m-label done" id="lbl0">Start</div>
          </div>
          <div class="milestone">
            <div class="m-dot current" id="dot1">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
              <div class="m-dot-inner"></div>
            </div>
            <div class="m-label current" id="lbl1">+100 pts</div>
          </div>
          <div class="milestone">
            <div class="m-dot" id="dot2">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
              <div class="m-dot-inner"></div>
            </div>
            <div class="m-label" id="lbl2">+200 pts</div>
          </div>
          <div class="milestone">
            <div class="m-dot" id="dot3">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
              <div class="m-dot-inner"></div>
            </div>
            <div class="m-label" id="lbl3">+300 pts</div>
          </div>
          <div class="milestone">
            <div class="m-dot" id="dot4">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
              <div class="m-dot-inner"></div>
            </div>
            <div class="m-label" id="lbl4">+400 pts</div>
          </div>
        </div>
      </div>
      <div class="pts-hint" id="ptsHint">You are just <strong>3 more steps</strong> away for Bonus Lucira Coins</div>
    </div>

    <div class="step-panel active" id="step-1">
      <div class="step-body">
        <div class="step-eyebrow">Step 1 of 4</div>
        <div class="step-title">Let Us Know You Better</div>
        <div class="step-sub">Tell us a little about yourself so we can personalise your experience.</div>

        <div class="field-label">Gender</div>
        <div class="radio-group">
          <div class="radio-opt">
            <input type="radio" name="gender" id="r-male" value="male" checked>
            <label for="r-male">Male</label>
          </div>
          <div class="radio-opt">
            <input type="radio" name="gender" id="r-female" value="female">
            <label for="r-female">Female</label>
          </div>
          <div class="radio-opt">
            <input type="radio" name="gender" id="r-other" value="other">
            <label for="r-other">Others</label>
          </div>
        </div>

        <div class="field-label">Date of Birth</div>
        <div class="form-row single">
          <div class="form-field">
            <div class="input-wrap">
              <input type="date" value="2000-10-10">
              <span class="input-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </span>
            </div>
          </div>
        </div>

        <div class="toggle-row">
          <span class="toggle-text">Are you Married?</span>
          <label class="toggle-switch">
            <input type="checkbox" id="marriedToggle" checked>
            <div class="toggle-track">.</div>
          </label>
        </div>

        <div id="spouseFields">
          <div class="form-row">
            <div class="form-field">
              <label>Date of Anniversary</label>
              <div class="input-wrap">
                <input type="date" value="2015-03-15">
                <span class="input-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </span>
              </div>
            </div>
            <div class="form-field">
              <label>Date of Birth (Spouse)</label>
              <div class="input-wrap">
                <input type="date" value="1992-07-22">
                <span class="input-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </span>
              </div>
            </div>
          </div>
        </div>

        <div class="step-actions">
          <button class="btn-back" disabled style="opacity:.3;cursor:default">Back</button>
          <button class="btn-continue" onclick="goToStep(2)">
            Save & Continue
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
      <div class="fun-facts">
        <div class="fun-facts-icon">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
        </div>
        <div class="fun-facts-content">
          <div class="fun-facts-title">Fun Facts</div>
          <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.</p>
        </div>
      </div>
    </div>

    <!-- ── Step 2: Gifting ── -->
    <div class="step-panel" id="step-2">
      <div class="step-body">
        <div class="step-eyebrow">Step 2 of 4</div>
        <div class="step-title">Gifting Behaviour</div>
        <div class="step-sub">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod.</div>

        <div class="field-label">How often do you buy Jewelry as a Gift?</div>
        <div class="chip-group">
          <button class="chip selected">Frequently</button>
          <button class="chip">Occasionally</button>
          <button class="chip">Rarely</button>
