<script>
document.addEventListener('DOMContentLoaded', function () {
  const TOTAL = 4;
  const CIRCUMFERENCE = 2 * Math.PI * 42;
  document.getElementById('ringFill').style.strokeDasharray = CIRCUMFERENCE;

  /* Chip toggle */
  document.querySelectorAll('.chip-group').forEach(g => {
    g.querySelectorAll('.chip').forEach(c => {
      c.addEventListener('click', () => c.classList.toggle('selected'));
    });
  });

  /* Married toggle */
  document.getElementById('marriedToggle').addEventListener('change', function () {
    document.getElementById('spouseFields').style.display = this.checked ? '' : 'none';
  });

  const hintTexts = [
    'You are just <strong>3 more steps</strong> away for Bonus Lucira Coins',
    'You are just <strong>2 more steps</strong> away for Bonus Lucira Coins',
    'You are just <strong>1 more step</strong> away for Bonus Lucira Coins',
    'One final step — complete your profile for <strong>400 Lucira Coins!</strong>',
    '🎉 You\'ve unlocked all <strong>400 Lucira Coins!</strong>'
  ];

  const coinsPerStep = [0, 100, 200, 300, 400];

  window.goToStep = function (step) {
    /* Panels */
    document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('step-' + step).classList.add('active');

    /* Tabs */
    document.querySelectorAll('.step-tab').forEach((t, i) => {
      t.classList.remove('active', 'done');
      if (i + 1 < step) t.classList.add('done');
      if (i + 1 === step) t.classList.add('active');
    });

    /* Milestone dots */
    for (let i = 0; i <= 4; i++) {
      const dot = document.getElementById('dot' + i);
      const lbl = document.getElementById('lbl' + i);
      if (!dot) continue;
      dot.classList.remove('done', 'current');
      lbl.classList.remove('done', 'current');
      if (i < step) {
        dot.classList.add('done');
        lbl.classList.add('done');
      } else if (i === step) {
        dot.classList.add('current');
        lbl.classList.add('current');
      }
    }

    /* Track fill (between milestones) */
    const trackPct = ((step - 1) / (TOTAL)) * 100;
    document.getElementById('trackProgress').style.width = trackPct + '%';

    /* Ring */
    const pct = Math.round(((step - 1) / TOTAL) * 100);
    const offset = CIRCUMFERENCE - (pct / 100) * CIRCUMFERENCE;
    document.getElementById('ringFill').style.strokeDashoffset = offset;
    document.getElementById('ringPct').textContent = pct;

    /* Sidebar steps */
    for (let i = 1; i <= 4; i++) {
      const li = document.getElementById('sli-' + i);
      const cc = document.getElementById('cc' + i);
      if (!li || !cc) continue;
      li.classList.remove('done');
      cc.classList.remove('done', 'current');
      if (i < step) {
        li.classList.add('done');
        cc.classList.add('done');
      } else if (i === step) {
        cc.classList.add('current');
      }
    }

    /* Coins */
    animateCoins(coinsPerStep[step - 1]);

    /* Hint */
    document.getElementById('ptsHint').innerHTML = hintTexts[step - 1] || hintTexts[0];
  };

  window.completeProfile = function () {
    /* All done */
    for (let i = 0; i <= 4; i++) {
      const dot = document.getElementById('dot' + i);
      const lbl = document.getElementById('lbl' + i);
      if (dot) { dot.classList.add('done'); dot.classList.remove('current'); }
      if (lbl) { lbl.classList.add('done'); lbl.classList.remove('current'); }
    }
    document.getElementById('trackProgress').style.width = '100%';

    const offset = 0;
    document.getElementById('ringFill').style.strokeDashoffset = offset;
    document.getElementById('ringPct').textContent = '100';

    for (let i = 1; i <= 4; i++) {
      const li = document.getElementById('sli-' + i);
      const cc = document.getElementById('cc' + i);
      if (li) li.classList.add('done');
      if (cc) { cc.classList.add('done'); cc.classList.remove('current'); }
    }
    document.querySelectorAll('.step-tab').forEach(t => t.classList.add('done'));
    animateCoins(400);
    document.getElementById('ptsHint').innerHTML = hintTexts[4];
    setTimeout(() => alert('🎉 Profile Complete! Your 400 Lucira Coins are unlocked.'), 600);
  };

  function animateCoins(target) {
    const el = document.getElementById('coinsEarned');
    const start = parseInt(el.textContent) || 0;
    const diff = target - start;
    const dur = 600;
    const startTime = performance.now();
    function step(now) {
      const t = Math.min((now - startTime) / dur, 1);
      const ease = 1 - Math.pow(1 - t, 3);
      el.textContent = Math.round(start + diff * ease);
      if (t < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  /* Init */
  goToStep(1);
});
</script>
