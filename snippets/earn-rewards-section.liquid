<script>
  let currentStep = 2;
  const totalSteps = 4;

  // Chip toggle behavior
  document.querySelectorAll('.chip-group').forEach((group) => {
    group.querySelectorAll('.chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        chip.classList.toggle('selected');
      });
    });
  });

  function goToStep(step) {
    // Hide all panels
    document.querySelectorAll('.step-panel').forEach((p) => p.classList.remove('active'));
    document.querySelectorAll('.step-tab').forEach((t) => t.classList.remove('active'));

    // Show target panel
    document.getElementById('step-' + step).classList.add('active');

    // Update tabs
    const tabs = document.querySelectorAll('.step-tab');
    tabs.forEach((tab, idx) => {
      if (idx + 1 < step) tab.classList.add('done');
      else tab.classList.remove('done');
      if (idx + 1 === step) tab.classList.add('active');
    });

    // Update progress bar dots
    document.querySelectorAll('.step-dot').forEach((dot, idx) => {
      dot.classList.remove('active', 'current');
      if (idx + 1 < step) dot.classList.add('active');
      if (idx + 1 === step) dot.classList.add('current');
    });

    // Update progress fill line
    const pct = ((step - 1) / (totalSteps - 1)) * 100;
    document.getElementById('progressFill').style.width = pct + '%';

    // Update circular progress
    const completedSteps = step - 1;
    const percentage = Math.round((completedSteps / totalSteps) * 100);
    const circumference = 2 * Math.PI * 35;
    const offset = circumference - (percentage / 100) * circumference;
    document.getElementById('progressRing').style.strokeDashoffset = offset;
    document.getElementById('progressPercent').textContent = percentage;

    // Update checklist
    for (let i = 2; i <= 4; i++) {
      const el = document.getElementById('checkStep' + i);
      if (el) {
        if (i < step) el.classList.add('done');
        else el.classList.remove('done');
      }
    }

    currentStep = step;
  }

  function completeProfile() {
    // Mark all done
    document.querySelectorAll('.step-dot').forEach((dot) => {
      dot.classList.remove('current');
      dot.classList.add('active');
    });
    document.getElementById('progressFill').style.width = '100%';
    document.getElementById('progressRing').style.strokeDashoffset = 0;
    document.getElementById('progressPercent').textContent = '100';
    for (let i = 2; i <= 4; i++) {
      const el = document.getElementById('checkStep' + i);
      if (el) el.classList.add('done');
    }
    document.querySelectorAll('.step-tab').forEach((t) => t.classList.add('done'));
    alert('🎉 Profile Complete! Your rewards are unlocked.');
  }

  // Init: show step 2 by default (as in screenshot)
  goToStep(2);
</script>