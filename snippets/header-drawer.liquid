{% comment %}
  Renders a header drawer menu for mobile and desktop.
  Special behavior: If menu handle or title is 'collection', opens a child drawer with two images.
  Usage:
  {% render 'header-drawer' %}
{% endcomment %}

<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {{- 'icon-hamburger.svg' | inline_asset_content -}}
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </summary>

    <div id="menu-drawer" class="gradient menu-drawer motion-reduce color-{{ section.settings.menu_color_scheme }}">
      <div class="menu-drawer__inner-container">
        <div class="menu-drawer__navigation-container">

          <!-- Optional Top Slider Images -->
          <div class="image-menu-mobile-slider">
            <img class="offer-image-menu-mobile" src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Hexa_V2.jpg?v=1762843077" width="100%" height="180">
            <img class="offer-image-menu-mobile" src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Bezel_67fedcb7-1524-4b30-95c5-27986e403f21.jpg?v=1762841804" width="100%" height="180">
          </div>

          <!-- Main Navigation -->
          <nav class="menu-drawer__navigation">
            <ul class="menu-drawer__menu has-submenu list-menu" role="list">
              {%- for link in section.settings.menu.links -%}
                <li>
                  {%- if link.links != blank -%}
                    <details id="Details-menu-drawer-menu-item-{{ forloop.index }}">
                      <summary
                        id="HeaderDrawer-{{ link.handle }}"
                        class="title-mobile-css border-css-menu-mobile menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.child_active %} menu-drawer__menu-item--active{% endif %}"
                      >
                        <span class="menu-parent-title">{{ link.title | escape }}</span>
                      </summary>

                      <div
                        id="link-{{ link.handle | escape }}"
                        class="menu-drawer__submenu has-submenu gradient motion-reduce"
                        tabindex="-1"
                      >
                        <div class="menu-drawer__inner-submenu">
                          <button class="menu-drawer__close-button link link--text focus-inset" aria-expanded="true">
                            <span class="svg-wrapper">
                              {{- 'icon-arrow.svg' | inline_asset_content -}}
                            </span>
                            {{ link.title | escape }}
                          </button>

                          {% comment %}
                            Special case: If menu is 'collection', show two images in child drawer
                          {% endcomment %}
                          {% if link.title | downcase == 'collection' or link.handle == 'collection' %}
                            <div class="lucira-mobile-menu-drawer" style="display: block">
                              {% if settings.image_11-1 %}
                                <div class="lucira-mobile-image-box">
                                  <a href="{{ settings.url_11-1 | default: '#' }}">
                                    <img src="{{ settings.image_11-1 | image_url: width: 329, height: 329 }}" width="190" height="253" alt="collection" loading="lazy">
                                  </a>
                                  <div style="text-align: center;">
                                    <span style="display: block; font-weight: 600;">HEXA CUT</span>
                                    <span style="display: block; font-size: 0.9em;">An Ode to Transformation</span>
                                  </div>
                                </div>
                              {% endif %}

                              {% if settings.image_11-2 %}
                                <div class="lucira-mobile-image-box margin-bottom-10">
                                  <a href="{{ settings.url_11-2 | default: '#' }}">
                                    <img src="{{ settings.image_11-2 | image_url: width: 329, height: 329 }}" width="190" height="253" alt="collection" loading="lazy">
                                  </a>
                                  <div style="text-align: center;">
                                    <span style="display: block; font-weight: 600;">ON THE MOVE</span>
                                    <span style="display: block; font-size: 0.9em;">For Life In Constant Motion</span>
                                  </div>
                                </div>
                              {% endif %}
                            </div>
                          {% else %}
                            {%- comment -%} Regular child links loop {%- endcomment -%}
                            <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                              {%- for childlink in link.links -%}
                                <li>
                                  <a href="{{ childlink.url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset">
                                    {{ childlink.title | escape }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {% endif %}

                        </div>
                      </div>
                    </details>
                  {%- else -%}
                    <a
                      id="HeaderDrawer-{{ link.handle }}"
                      href="{{ link.url }}"
                      class="title-mobile-css border-css-menu-mobile menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}"
                      {% if link.current %} aria-current="page" {% endif %}
                    >
                      {{ link.title | escape }}
                    </a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </nav>

          <!-- Optional Bottom Slider -->
          <div class="image-menu-mobile-slider" style="padding-top:0px;">
            <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Offer_crop_V2.jpg?v=1762842871" width="100%" height="130" class="offer-image-menu-mobile">
          </div>

          <!-- Services Section -->
          <section class="services-section">
            <h2 class="services-heading">SERVICES</h2>
            <div class="services-grid">
              <!-- Example Service Cards -->
              <div class="service-card">
                <div class="service-icon" style="color:#25D366;">
                  <!-- SVG icon here -->
                </div>
                <p class="service-title">WhatsApp Us</p>
                <p class="service-desc">Lorem Ipsum description</p>
              </div>
              <div class="service-card">
                <div class="service-icon" style="color:#3AA6D0;">
                  <!-- SVG icon here -->
                </div>
                <p class="service-title">Vault Of Dreams</p>
                <p class="service-desc">Lorem Ipsum description</p>
              </div>
              <div class="service-card">
                <div class="service-icon" style="color:#F57C00;">
                  <!-- SVG icon here -->
                </div>
                <p class="service-title">Video Call</p>
                <p class="service-desc">Lorem Ipsum description</p>
              </div>
              <div class="service-card">
                <div class="service-icon" style="color:#E84A8A;">
                  <!-- SVG icon here -->
                </div>
                <p class="service-title">Visit Store</p>
                <p class="service-desc">Lorem Ipsum description</p>
              </div>
            </div>
          </section>

        </div>
      </div>
    </div>
  </details>
</header-drawer>
