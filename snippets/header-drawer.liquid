                                      class="{% if childlink.title == 'EDUCATION' %}education-section-blog-ul {% endif %} {% unless has_image %}without-image-menu-click{% endunless %} menu-drawer__submenu-list list-menu always-open-list {{ childlink.title | downcase | replace: "'", "" | replace: " ","" }}"
                                      role="list"
                                    >
                                      {%- for grandchildlink in childlink.links -%}
                                        <li class="{{ grandchildlink.title | downcase | replace: "'", "" }}-grandchild-menuLink{% if childlink.title == 'EDUCATION' %} education-image-flow{% endif %} grandchild-link">
                                          {%- if childlink.title == 'EDUCATION' -%}
