<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {{- 'icon-hamburger.svg' | inline_asset_content -}}
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </summary>
    <div id="menu-drawer" class="gradient menu-drawer motion-reduce color-{{ section.settings.menu_color_scheme }}">
      <div class="menu-drawer__inner-container">
        <div class="menu-drawer__navigation-container">
          <div class="image-menu-mobile-slider">
            <a href="https://www.lucirajewelry.com/collections/cotton-candy">
              <img
                class="offer-image-menu-mobile"
                src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Cotton_Candy_Menu_bAr_v2.jpg?v=1766136159"
                width="100%"
                height="180"
                loading="lazy"
                alt="menu-mobile-offer"
                title="menu-mobile-offer"
              >
            </a>

            <a href="https://www.lucirajewelry.com/collections/hexa">
              <img
                class="offer-image-menu-mobile"
                src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Hexa_V2.jpg?v=1762843077"
                width="100%"
                height="180"
                loading="lazy"
                alt="menu-image"
                title="menu-mobile-image"
              >
            </a>
            <a href="https://www.lucirajewelry.com/collections/sports-collection">
              <img
                class="offer-image-menu-mobile"
                src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Bezel_67fedcb7-1524-4b30-95c5-27986e403f21.jpg?v=1762841804"
                width="100%"
                height="180"
                loading="lazy"
                alt="menu-image-2"
                title="menu-mobile-image-2"
              >
            </a>
          </div>
          <nav class="menu-drawer__navigation">
            <ul class="menu-drawer__menu has-submenu list-menu" role="list">
              {%- for link in section.settings.menu.links -%}
                {% assign parent_menu_index = forloop.index %}
                {% assign badge_key = 'menu_badge_' | append: parent_menu_index %}
                {% assign badge_type = settings[badge_key] %}

                <li class="menu-{{ link.title }}">
                  {%- if link.links != blank -%}
                    <details id="Details-menu-drawer-menu-item-{{ forloop.index }}">
                      <summary
                        id="HeaderDrawer-{{ link.handle }}"
                        class="title-mobile-css border-css-menu-mobile menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.child_active %} menu-drawer__menu-item--active{% endif %}"
                      >
                        {%- assign parent_collection = link.object -%}
                        {%- if parent_collection
                          and parent_collection.metafields.custom.menu_image_svg_sprite != blank
                        -%}
                          <span class="menu-parent-icon">
                            <svg class="icon">
                              {{ parent_collection.metafields.custom.menu_image_svg_sprite }}
                            </svg>
                          </span>
                        {%- elsif parent_collection and parent_collection.metafields.custom.mega_menu_image != blank -%}
                          <span class="menu-parent-icon">
                            <img
                              src="{{ parent_collection.metafields.custom.mega_menu_image | image_url: width: 40 }}"
                              alt="{{ link.title | escape }}"
                              loading="lazy"
                            >
                          </span>
                        {%- endif -%}

                        
                        <span class="menu-parent-title">
                          {{ link.title | escape }}

                          {% if badge_type != 'none' %}
                            <span class="menu-badge menu-badge-{{ badge_type }} mobile-menu-badge">
                              {% if badge_type == 'fire' %}
                                🔥
                              {% else %}
                                New
                              {% endif %}
                            </span>
                          {% endif %}
                        </span>
                      </summary>
                      <div
                        id="link-{{ link.handle | escape }}"
                        class="height-isuue-resolved menu-drawer__submenu has-submenu gradient motion-reduce"
                        tabindex="-1"
                      >
                        <div class="menu-drawer__inner-submenu">
                          <button class="menu-drawer__close-button link link--text focus-inset" aria-expanded="true">
                            <span class="svg-wrapper">
                              {{- 'icon-arrow.svg' | inline_asset_content -}}
                            </span>
                            <span class="menu-parent-title">
                              {{ link.title | escape }}

                              {% if badge_type != 'none' %}
  <span class="menu-badge menu-badge-{{ badge_type }} mobile-menu-badge">
    {% if badge_type == 'fire' %}
      🔥
    {% else %}
      New
    {% endif %}
  </span>
{% endif %}
                            </span>
                          </button>
                          <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                            {%- for childlink in link.links -%}
                              <li>
                                {%- if childlink.links == blank -%}
                                  <a
                                    id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                    href="{{ childlink.url }}"
                                    class="menu-drawer__menu-item link link--text list-menu__item focus-inset{% if childlink.current %} menu-drawer__menu-item--active{% endif %}"
                                    {% if childlink.current %}
                                      aria-current="page"
                                    {% endif %}
                                  >
                                    {{ childlink.title | escape }}
                                  </a>
                                {%- else -%}
                                  {%- assign has_image = false -%}
                                  {%- for grandchildlink in childlink.links -%}
                                    {%- assign grandchild_collection = grandchildlink.object -%}
                                    {%- if grandchild_collection != blank -%}
                                      {%- if grandchild_collection.metafields.custom.menu_image_svg_sprite != blank
                                        or grandchild_collection.metafields.custom.mega_menu_image != blank
                                      -%}
                                        {%- assign has_image = true -%}
                                        {%- break -%}
                                      {%- endif -%}
                                    {%- endif -%}
                                  {%- endfor -%}
                                  {% if link.title == 'GIFTING' and forloop.first %}
                                    <div class="image-menu-mobile-slider">
                                      <a href="/collections/couple-bands">
                                        <img
                                          class="offer-image-menu-mobile"
                                          src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_1410103716_1.png?v=1769668191"
                                          width="100%"
                                          height="180"
                                          loading="lazy"
                                          alt="gifting-section-1"
                                          title="gifting-section-1"
                                        >
                                      </a>
                                      <a href="/collections/valentine">
                                        <img
                                          class="offer-image-menu-mobile"
                                          src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_1410103717_1.png?v=1769668191"
                                          width="100%"
                                          height="180"
                                          loading="lazy"
                                          alt="gifting-section-2"
                                          title="gifting-section-2"
                                        >
                                      </a>
                                    </div>
                                  {% endif %}

                                  <div class="menu-drawer__submenu-inline always-open">
                                    <div
                                      id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                      class="menu-drawer__menu-item link link--text list-menu__item focus-inset has-grandchildren"
                                    >
                                      {%- assign child_collection = childlink.object -%}
                                      {%- if child_collection
                                        and child_collection.metafields.custom['Menu Image - SVG Sprite'] != blank
                                      -%}
                                        <div class="menu-image">
                                          <img
                                            src="{{ child_collection.metafields.custom["Menu Image - SVG Sprite"] | image_url: width: 60 }}"
                                            alt="{{ childlink.title | escape }}"
                                            loading="lazy"
                                            alt="mobile-menu"
                                            title="mobile-menu"
                                          >
                                        </div>
                                      {%- endif -%}

                                      <span class="menu-title">{{ childlink.title | escape }}</span>
                                    </div>

                                    <ul
                                      class="{% if childlink.title == 'EDUCATION' %}education-section-blog-ul {% endif %} {% unless has_image %}without-image-menu-click{% endunless %} menu-drawer__submenu-list list-menu always-open-list {{ childlink.title | downcase | replace: "'", "" | replace: " ","" }}"
                                      role="list"
                                    >
                                      {%- for grandchildlink in childlink.links -%}
                                        <li class="{{ grandchildlink.title | downcase | replace: "'", "" }}-grandchild-menuLink{% if childlink.title == 'EDUCATION' %} education-image-flow{% endif %} grandchild-link">
                                          {%- if childlink.title == 'EDUCATION' -%}
                                            <a href="{{ grandchildlink.url }}">
                                              <div class="education-image">
                                                <img
                                                  height="280px"
                                                  width="250px"
                                                  class="education-image-img"
                                                  src="{{ grandchildlink.object.image | image_url: width: 400 }}"
                                                  alt="{{ grandchildlink.title | escape }}"
                                                  loading="lazy"
                                                >
                                              </div>
                                            </a>
                                          {%- endif -%}

                                          <a
                                            id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                            href="{{ grandchildlink.url }}"
                                            class="{% if childlink.title == 'EDUCATION' %}education-a-tag-blog {% endif %} grandchild-a-tag menu-drawer__menu-item link link--text list-menu__item focus-inset{% if grandchildlink.current %} menu-drawer__menu-item--active{% endif %}"
                                            {% if grandchildlink.current %}
                                              aria-current="page"
                                            {% endif %}
                                          >
                                            {%- assign grandchild_collection = grandchildlink.object -%}
                                            {%- if grandchild_collection != blank -%}
                                              {%- if grandchild_collection.metafields.custom.menu_image_svg_sprite
                                                  != blank
                                              -%}
                                                <div class="mega-menu__image">
                                                  <svg class="icon menu-image-icon">
                                                    {{ grandchild_collection.metafields.custom.menu_image_svg_sprite }}
                                                  </svg>
                                                </div>
                                              {%- elsif grandchild_collection.metafields.custom.mega_menu_image != blank
                                              -%}
                                                <div class="mega-menu__image">
                                                  <img
                                                    src="{{ grandchild_collection.metafields.custom.mega_menu_image | image_url: width: 160 }}"
                                                    alt="{{ grandchild_collection.title | escape }}"
                                                    width="24"
                                                    height="24"
                                                    loading="lazy"
                                                  >
                                                </div>
                                              {%- endif -%}
                                            {%- endif -%}
                                            <span class="{% if childlink.title == 'EDUCATION' %}education-section-blog-span {% endif %} great-grand-child-menu menu-title {{ childlink.title | downcase | replace: "'", "" | replace: " ",""}}-grandchild-title">
                                              {{- grandchildlink.title | escape -}}
                                            </span>
                                          </a>
                                        </li>
                                      {%- endfor -%}
                                    </ul>
                                  </div>
                                {%- endif -%}
                              </li>
                            {%- endfor -%}
                          </ul>
                        </div>
                      </div>
                    </details>
                  {%- else -%}
                    <a
                      id="HeaderDrawer-{{ link.handle }}"
                      href="{{ link.url }}"
                      class="title-mobile-css border-css-menu-mobile menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}"
                    >
                      {{ link.title | escape }}
                      {% if badge_type != 'none' %}
  <span class="menu-badge menu-badge-{{ badge_type }} mobile-menu-badge">
    {% if badge_type == 'fire' %}
      🔥
    {% else %}
      New
    {% endif %}
  </span>
{% endif %}

                    </a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </nav>

          <div class="image-menu-mobile-slider " style="padding-top:0px;">
            <a href="https://www.lucirajewelry.com/collections/tennis-bracelets">
              <img
                src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Mobile-Drawer_1.jpg?v=1764697336"
                width="100%"
                height="140"
                class="offer-image-menu-mobile-bottom"
                loading="lazy"
                alt="offer-banner-menu-bottom"
                title="offer-banner-menu-bottom"
              >
            </a>
          </div>

