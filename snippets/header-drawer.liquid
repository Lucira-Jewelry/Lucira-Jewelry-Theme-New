                                              <div class="education-image">
                                                <img
                                                  height="280px"
                                                  width="250px"
                                                  class="education-image-img"
                                                  src="{{ grandchildlink.object.image | image_url: width: 400 }}"
                                                  alt="{{ grandchildlink.title | escape }}"
                                                  loading="lazy"
                                                >
                                              </div>
                                            </a>
                                          {%- endif -%}

                                          <a
                                            id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                            href="{{ grandchildlink.url }}"
                                            class="{% if childlink.title == 'EDUCATION' %}education-a-tag-blog {% endif %} grandchild-a-tag menu-drawer__menu-item link link--text list-menu__item focus-inset{% if grandchildlink.current %} menu-drawer__menu-item--active{% endif %}"
                                            {% if grandchildlink.current %}
                                              aria-current="page"
                                            {% endif %}
                                          >
                                            {%- assign grandchild_collection = grandchildlink.object -%}
                                            {%- if grandchild_collection != blank -%}
                                              {%- if grandchild_collection.metafields.custom.menu_image_svg_sprite
                                                  != blank
                                              -%}
                                                <div class="mega-menu__image">
                                                  <svg class="icon menu-image-icon">
                                                    {{ grandchild_collection.metafields.custom.menu_image_svg_sprite }}
                                                  </svg>
                                                </div>
                                              {%- elsif grandchild_collection.metafields.custom.mega_menu_image != blank
                                              -%}
                                                <div class="mega-menu__image">
                                                  <img
                                                    src="{{ grandchild_collection.metafields.custom.mega_menu_image | image_url: width: 160 }}"
                                                    alt="{{ grandchild_collection.title | escape }}"
                                                    width="24"
                                                    height="24"
                                                    loading="lazy"
                                                  >
                                                </div>
                                              {%- endif -%}
                                            {%- endif -%}
                                            <span class="{% if childlink.title == 'EDUCATION' %}education-section-blog-span {% endif %} great-grand-child-menu menu-title {{ childlink.title | downcase | replace: "'", "" | replace: " ",""}}-grandchild-title">
                                              {{- grandchildlink.title | escape -}}
                                            </span>
                                          </a>
                                        </li>
                                      {%- endfor -%}
                                    </ul>
                                  </div>
                                {%- endif -%}
                              </li>
                            {%- endfor -%}
                          </ul>
                        </div>
                      </div>
                    </details>
                  {%- else -%}
                    <a
                      id="HeaderDrawer-{{ link.handle }}"
                      href="{{ link.url }}"
                      class="title-mobile-css border-css-menu-mobile menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}"
