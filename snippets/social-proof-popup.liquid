  ];

  var TIME_STRINGS = [
    'Just now', '1 minute ago', '2 minutes ago', '3 minutes ago',
    '4 minutes ago', '5 minutes ago', '7 minutes ago', '9 minutes ago',
    '11 minutes ago', '14 minutes ago', '18 minutes ago', '22 minutes ago',
    '27 minutes ago', '34 minutes ago', '41 minutes ago', '48 minutes ago',
    '55 minutes ago', '1 hour ago'
  ];

  var popup    = document.getElementById('lj-sp-popup');
  var nameEl   = document.getElementById('lj-sp-name');   /* NEW */
  var cityEl   = document.getElementById('lj-sp-city');   /* NEW */
  var prodEl   = document.getElementById('lj-sp-product-name');
  var timeEl   = document.getElementById('lj-sp-time');
  var imgWrap  = document.getElementById('lj-sp-img-wrap');
  var closeBtn = document.getElementById('lj-sp-close-btn');

  if (!popup) return;

  function rand(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

  var imgCache = {};
  function fetchProductImage(handle, cb) {
    if (!handle) { cb(null); return; }
    if (imgCache[handle] !== undefined) { cb(imgCache[handle]); return; }
    fetch('/products/' + handle + '.js')
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(data) {
        var url = (data && data.images && data.images[0]) ? data.images[0] : null;
        imgCache[handle] = url;
        cb(url);
      })
      .catch(function() { imgCache[handle] = null; cb(null); });
  }

  var defaultIconHTML = (function() {
    var el = document.getElementById('lj-sp-icon');
    return el ? el.outerHTML : '';
  }());

  function setAvatar(imgUrl, productName) {
    var badge = imgWrap.querySelector('.lj-sp-badge');
    var badgeHTML = badge ? badge.outerHTML : '';
    imgWrap.innerHTML = imgUrl
      ? badgeHTML + '<img src="' + imgUrl + '" alt="' + productName + '" loading="lazy">'
      : badgeHTML + defaultIconHTML;
  }

  function show() {
    var item = rand(PURCHASES);
    var name = rand(NAMES);
    var city = rand(CITIES);

    try { sessionStorage.setItem(SESSION_DONE_KEY, '1'); } catch (e) {}

    /* Update name + city separately so the name span keeps its colour */
    nameEl.textContent = name;
    cityEl.textContent = ' in ' + city;

    prodEl.textContent = item.product;
    timeEl.textContent = rand(TIME_STRINGS);

    popup.setAttribute('data-href', item.url);

    setAvatar(null, item.product);
    fetchProductImage(item.handle, function(url) { setAvatar(url, item.product); });

    popup.classList.add('lj-sp-show');

    setTimeout(function() {
      popup.classList.remove('lj-sp-show');
    }, DISPLAY_DURATION);
  }

  popup.addEventListener('click', function(e) {
    if (e.target === closeBtn || closeBtn.contains(e.target)) return;
    var href = popup.getAttribute('data-href');
    if (href) window.location.href = href;
  });

  closeBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    popup.classList.remove('lj-sp-show');
  });

  setTimeout(show, INITIAL_DELAY);

}());
</script>

