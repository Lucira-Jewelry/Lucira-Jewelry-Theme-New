{% if template == 'index' %}

<style id="lj-sp-css">
  #lj-sp-popup {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 9999999999999999999999;
    background: #ffffff;
    border-left: 3px solid #c8956c;
    border-radius: 6px;
    padding: 14px 36px 14px 14px;
    display: flex;
    align-items: center;
    gap: 13px;
    max-width: 320px;
    width: calc(100vw - 32px);
    box-shadow: 0 8px 40px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.07);
    transform: translateX(calc(-100% - 30px));
    opacity: 0;
    transition: transform 0.5s cubic-bezier(0.34,1.2,0.64,1), opacity 0.38s ease, box-shadow 0.4s ease;
    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif;
    pointer-events: all;
    cursor: pointer;
    box-sizing: border-box;
    text-decoration: none;
  }
  @media (min-width: 480px) {
    #lj-sp-popup { width: 320px; }
  }
  #lj-sp-popup.lj-sp-show {
    transform: translateX(0);
    opacity: 1;
    border-left-color:#a05a64;
    box-shadow: 0 8px 40px rgba(0,0,0,0.13), -3px 0 12px rgba(184,115,64,0.18), 0 2px 8px rgba(0,0,0,0.07);
  }
  #lj-sp-popup .lj-sp-img-wrap {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    border: 1.5px solid #e8d5c4;
    background: #f9f2ec;
    flex-shrink: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: border-color 0.4s ease;
  }
  #lj-sp-popup.lj-sp-show .lj-sp-img-wrap {
    border-color: #a05a64;
  }
  #lj-sp-popup .lj-sp-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    display: block;
  }
  #lj-sp-popup .lj-sp-img-wrap svg {
    width: 28px;
    height: 28px;
    opacity: 0.5;
    flex-shrink: 0;
  }
  #lj-sp-popup .lj-sp-body {
    flex: 1;
    min-width: 0;
    line-height: 1.3;
  }
  #lj-sp-popup .lj-sp-location {
    font-size: 11.5px;
    color: #999;
    font-weight: 400;
    letter-spacing: 0.02em;
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  /* ── Name highlight ── */
  #lj-sp-popup .lj-sp-location .lj-sp-name {
    color: #a05a64;
    font-weight: 500;
  }
  #lj-sp-popup .lj-sp-product {
    font-size: 13px;
    color: #1a1a1a;
    font-weight: 500;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  #lj-sp-popup .lj-sp-product strong {
    color: #a05a64;
  }
  /* ── Timestamp pill ── */
  #lj-sp-popup .lj-sp-time {
    font-size: 10.5px;
    color: #bbb;
    margin-top: 6px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: #fdf5ef;
    border-radius: 20px;
    padding: 2px 7px 2px 5px;
    color:#1a1a1a;
  }
  #lj-sp-popup .lj-sp-dot {
    width: 6px;
    height: 6px;
    background: #4caf7d;
    border-radius: 50%;
    flex-shrink: 0;
    animation: lj-sp-pulse 1.8s infinite;
  }
  #lj-sp-popup .lj-sp-close {
    position: absolute;
    top: 7px;
    right: 9px;
    background: none;
    border: none;
    cursor: pointer;
    color: #ccc;
    font-size: 18px;
    line-height: 1;
    padding: 2px 4px;
    transition: color 0.2s;
    font-family: Arial, sans-serif;
  }
  #lj-sp-popup .lj-sp-close:hover { color: #888; }
  #lj-sp-popup .lj-sp-badge {
    position: absolute;
    top: -2px;
    left: -2px;
    width: 14px;
    height: 14px;
    background: #4caf7d;
    border-radius: 50%;
    border: 2px solid #fff;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #lj-sp-popup .lj-sp-badge svg {
    width: 7px;
    height: 7px;
    opacity: 1;
  }
  @keyframes lj-sp-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.35; transform: scale(0.65); }
  }
  @media (max-width: 360px) {
    #lj-sp-popup { bottom: 12px; left: 12px; width: calc(100vw - 24px); }
  }
</style>

<div id="lj-sp-popup" role="status" aria-live="polite" aria-atomic="true">
  <div class="lj-sp-img-wrap" id="lj-sp-img-wrap">
    {% comment %} <div class="lj-sp-badge" aria-hidden="true">
      <svg viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1.5" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div> {% endcomment %}
    <svg id="lj-sp-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 2L8 7H16L12 2Z" stroke="#c8956c" stroke-width="1.5" stroke-linejoin="round"/>
      <path d="M4 7H8M16 7H20" stroke="#c8956c" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M4 7L12 22L20 7" stroke="#c8956c" stroke-width="1.5" stroke-linejoin="round"/>
      <path d="M8 7L12 22L16 7" stroke="#c8956c" stroke-width="1.5" stroke-linejoin="round"/>
    </svg>
  </div>
  <div class="lj-sp-body">
    <!-- Name is now a <span> so it can be coloured independently -->
    <div class="lj-sp-location" id="lj-sp-location"><span class="lj-sp-name" id="lj-sp-name">Priya</span><span id="lj-sp-city"> in Mumbai</span></div>
