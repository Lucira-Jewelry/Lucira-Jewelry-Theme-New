    <div class="lj-sp-time"><span class="lj-sp-dot"></span><span id="lj-sp-time">Just now</span></div>
  </div>
  <button class="lj-sp-close" id="lj-sp-close-btn" aria-label="Close notification">&times;</button>
</div>

