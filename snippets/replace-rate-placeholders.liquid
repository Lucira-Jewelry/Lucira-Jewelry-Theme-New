{% comment %}
  Snippet to replace rate placeholders with actual values
  Usage: {% render 'replace-rate-placeholders', content: your_content, rate_22k_display: rate_22k_display, rate_24k_display: rate_24k_display, ... %}
{% endcomment %}

{% assign content = content %}

{% if content != blank %}
  {% assign content = content | replace: '[RATE_22K]', rate_22k_display %}
  {% assign content = content | replace: '[RATE_24K]', rate_24k_display %}
  {% assign content = content | replace: '[RATE_18K]', rate_18k_display %}
  {% assign content = content | replace: '[RATE_14K]', rate_14k_display %}
  {% assign content = content | replace: '[RATE_22K_8G]', rate_22k_8g %}
  {% assign content = content | replace: '[RATE_24K_8G]', rate_24k_8g %}
  {% assign content = content | replace: '[RATE_18K_8G]', rate_18k_8g %}
  {% assign content = content | replace: '[RATE_14K_8G]', rate_14k_8g %}
  {% assign content = content | replace: '[RATE_22K_10G]', rate_22k_10g %}
  {% assign content = content | replace: '[RATE_24K_10G]', rate_24k_10g %}
  {% assign content = content | replace: '[RATE_18K_10G]', rate_18k_10g %}
  {% assign content = content | replace: '[RATE_14K_10G]', rate_14k_10g %}
  {% assign content = content | replace: '[RATE_22K_100G]', rate_22k_100g %}
  {% assign content = content | replace: '[RATE_24K_100G]', rate_24k_100g %}
  {% assign content = content | replace: '[RATE_18K_100G]', rate_18k_100g %}
  {% assign content = content | replace: '[RATE_14K_100G]', rate_14k_100g %}
  {{ content | metafield_tag }}
{% endif %}
