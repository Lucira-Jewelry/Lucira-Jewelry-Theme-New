<div class="drawer-overlay" id="drawer-overlay"></div>

<div class="product-variant-drawer" id="variant-drawer">
  <div class="product-variant-drawer-wrapper">
    {%- unless product.has_only_default_variant -%}
      <variant-selects
        id="variant-selects-drawer-{{ section.id }}"
        data-section="{{ section.id }}"
        data-product-handle="{{ product.handle }}"
        data-product-url="{{ product.url }}"
        {{ block.shopify_attributes }}
      >
        <div class="product-variant-drawer-title-wrap">
          <div class="title-wrapper">
            <div class="customize-product-prices" id="customize-price-drawer-prices">
              <!-- Add data attributes for variant price and compare price -->
              <span class="price" id="customize-price-drawer-price" 
                data-price="{{ product.selected_or_first_available_variant.price | money }}"
                data-compare-price="{{ product.selected_or_first_available_variant.compare_at_price | money }}"
                data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                
                <!-- Show compare price if available -->
                {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
                  <span class="compare-price">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
                {%- endif -%}
                
                {{ product.selected_or_first_available_variant.price | money }}
              </span>
            </div>
          </div>
          <div class="close-button" id="close-drawer">
            <i class="fa-solid fa-xmark"></i>
          </div>
        </div>
        
        <div class="product-variants-wrapper">
          {%- for option in product.options_with_values -%}
            <fieldset class="js product-form__input product-form__input--pill variant-type-{{ option.name | handle }}" data-option-index="{{ forloop.index0 }}">
              <legend class="form__label">
                {{ option.name }}: 
                <span data-selected-value>{{ option.selected_value }}</span>
              </legend>
              {% render 'product-variant-options',
                product: product,
                option: option,
                block: block,
                picker_type: 'button'
              %}
            </fieldset>
          {%- endfor -%}
        </div>

        <div class="customize-button-wrapper">
          <button id="customize_close_drawer" class="customize-variants-button">Confirm Customization</button>
        </div>
        
        <!-- Add all variants data for JavaScript to use -->
        <script type="application/json" data-product-variants>
          {{ product.variants | json }}
        </script>
        
        <script type="application/json" data-selected-variant>
          {{ product.selected_or_first_available_variant | json }}
        </script>
      </variant-selects>
    {%- endunless -%}
  </div>
</div>