<div class="drawer-overlay" id="drawer-overlay"></div>

<div class="product-variant-drawer" id="variant-drawer">

  <div class="product-variant-drawer-wrapper">
    {%- unless product.has_only_default_variant -%}
      <variant-selects
        id="variant-selects-drawer-{{ section.id }}"
        data-section="{{ section.id }}"
        {{ block.shopify_attributes }}
      >
        <div class="product-variant-drawer-title-wrap">
          <div class="title-wrapper">
            <span id="drawer-price" data-price="{{ product.selected_or_first_available_variant.price | money_without_trailing_zeros}}">
              {{ product.selected_or_first_available_variant.price | money_without_trailing_zeros}}
            </span>
          </div>
          <div class="close-button" id="close-drawer">
            <i class="fa-solid fa-xmark"></i>
          </div>
        </div>
        <div class="product-variants-wrapper">
            {%- for option in product.options_with_values -%}
                <fieldset class="js product-form__input product-form__input--pill variant-type-{{ option.name | handle }}">
                <legend class="form__label">
                    {{ option.name }}: 
                    <span data-selected-value>{{ option.selected_value }}</span>
                </legend>
                {% render 'product-variant-options',
                    product: product,
                    option: option,
                    block: block,
                    picker_type: 'button'
                %}
                </fieldset>
            {%- endfor -%}
        </div>

        <div class="customize-button-wrapper">
          <button id="customize_close_drawer" class="customize-variants-button">Confirm Customization</button>
        </div>
        <script type="application/json" data-selected-variant>
          {{ product.selected_or_first_available_variant | json }}
        </script>
      </variant-selects>
    {%- endunless -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const variantSelectors = document.querySelector('#variant-selects-drawer-{{ section.id }}');
    const drawerPrice = document.querySelector('#drawer-price');
    
    if (!variantSelectors || !drawerPrice) return;
    
    // Listen for variant changes
    variantSelectors.addEventListener('change', function(event) {
      // Check if the changed element is a variant option
      if (event.target.matches('input[name*="options"], select[name*="options"]')) {
        updateDrawerPrice();
      }
    });
    
    // Also listen for click events on variant buttons
    variantSelectors.addEventListener('click', function(event) {
      if (event.target.matches('.product-form__input input, .product-form__input label')) {
        // Small delay to allow the variant to be selected first
        setTimeout(updateDrawerPrice, 10);
      }
    });
    
    function updateDrawerPrice() {
      // Get the currently selected variant data
      const selectedVariantScript = variantSelectors.querySelector('script[data-selected-variant]');
      
      if (!selectedVariantScript) return;
      
      try {
        const currentVariant = JSON.parse(selectedVariantScript.textContent);
        
        if (currentVariant && currentVariant.price) {
          // Format the price (you may need to adjust this based on your store's currency format)
          const formattedPrice = formatPrice(currentVariant.price);
          
          // Update both the text content and data attribute
          drawerPrice.textContent = formattedPrice;
          drawerPrice.setAttribute('data-price', formattedPrice);
          
          // Add a subtle animation to indicate the price changed
          drawerPrice.classList.add('price-updated');
          setTimeout(() => {
            drawerPrice.classList.remove('price-updated');
          }, 300);
        }
      } catch (error) {
        console.error('Error updating drawer price:', error);
      }
    }
    
    function formatPrice(priceInCents) {
      // Convert cents to dollars and format
      // Adjust this function based on your store's currency and formatting needs
      const price = priceInCents / 100;
      
      // Basic formatting - you may want to use Shopify's money filters equivalent
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 0,
        maximumFractionDigits: 2,
      }).format(price).replace(/\.00$/, ''); // Remove .00 for whole numbers
    }
  });

  // Alternative approach using MutationObserver for more reliable updates
  document.addEventListener('DOMContentLoaded', function() {
    const drawerPrice = document.querySelector('#drawer-price');
    const variantScript = document.querySelector('script[data-selected-variant]');
    
    if (!drawerPrice || !variantScript) return;
    
    // Watch for changes in the variant script content
    const observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        if (mutation.type === 'childList' || mutation.type === 'characterData') {
          try {
            const currentVariant = JSON.parse(variantScript.textContent);
            if (currentVariant && currentVariant.price) {
              const formattedPrice = formatPrice(currentVariant.price);
              drawerPrice.textContent = formattedPrice;
              drawerPrice.setAttribute('data-price', formattedPrice);
            }
          } catch (error) {
            console.error('Error in MutationObserver:', error);
          }
        }
      });
    });
    
    // Start observing
    observer.observe(variantScript, {
      childList: true,
      characterData: true,
      subtree: true
    });
    
    function formatPrice(priceInCents) {
      const price = priceInCents / 100;
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 0,
        maximumFractionDigits: 2,
      }).format(price).replace(/\.00$/, '');
    }
  });
</script>