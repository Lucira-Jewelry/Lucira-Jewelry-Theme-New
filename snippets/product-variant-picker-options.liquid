<div class="drawer-overlay" id="drawer-overlay"></div>

<div class="product-variant-drawer" id="variant-drawer">

  <div class="product-variant-drawer-wrapper">
    {%- unless product.has_only_default_variant -%}
      <variant-selects
        id="variant-selects-drawer-{{ section.id }}"
        data-section="{{ section.id }}"
        {{ block.shopify_attributes }}
      >
        <div class="product-variant-drawer-title-wrap">
          <div class="title-wrapper">
            <span id="drawer-price" data-price="">
              
            </span>
          </div>
          <div class="close-button" id="close-drawer">
            <i class="fa-solid fa-xmark"></i>
          </div>
        </div>
        <div class="product-variants-wrapper">
            {%- for option in product.options_with_values -%}
                <fieldset class="js product-form__input product-form__input--pill variant-type-{{ option.name | handle }}">
                <legend class="form__label">
                    {{ option.name }}: 
                    <span data-selected-value>{{ option.selected_value }}</span>
                </legend>
                {% render 'product-variant-options',
                    product: product,
                    option: option,
                    block: block,
                    picker_type: 'button'
                %}
                </fieldset>
            {%- endfor -%}
        </div>

        <div class="customize-button-wrapper">
          <button id="customize_close_drawer" class="customize-variants-button">Confirm Customization</button>
        </div>
        <script type="application/json" data-selected-variant>
          {{ product.selected_or_first_available_variant | json }}
        </script>
      </variant-selects>
    {%- endunless -%}
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const drawerPriceEl = document.getElementById('drawer-price');
  const variantSelectsEl = document.querySelector('#variant-selects-drawer-{{ section.id }}');

  if (!drawerPriceEl || !variantSelectsEl) return;

  // Function to format price
  function formatPrice(price) {
    if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
      return Shopify.formatMoney(price, '{{ shop.money_format }}');
    }
    return '₹' + (price / 100).toFixed(0);
  }

  // Initialize with first available variant
  const initialVariantScript = variantSelectsEl.querySelector('script[data-selected-variant]');
  if (initialVariantScript) {
    const variant = JSON.parse(initialVariantScript.innerHTML);
    drawerPriceEl.textContent = formatPrice(variant.price);
    drawerPriceEl.dataset.price = variant.price;
  }

  // Function to get the currently selected variant
  function getSelectedVariant() {
    const variantScript = variantSelectsEl.querySelector('script[data-selected-variant]');
    if (!variantScript) return null;
    return JSON.parse(variantScript.innerHTML);
  }

  // Listen to any changes on variant options (buttons, radio inputs, selects)
  variantSelectsEl.addEventListener('change', () => {
    const variant = getSelectedVariant();
    if (variant) {
      drawerPriceEl.textContent = formatPrice(variant.price);
      drawerPriceEl.dataset.price = variant.price;
    }
  });

  // If using Shopify's 'variant-selects' custom event
  variantSelectsEl.addEventListener('variantChange', (event) => {
    const variant = event.detail.variant;
    if (variant) {
      drawerPriceEl.textContent = formatPrice(variant.price);
      drawerPriceEl.dataset.price = variant.price;
    }
  });
});
</script>

