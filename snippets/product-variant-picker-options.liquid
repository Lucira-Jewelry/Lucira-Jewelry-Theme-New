<div class="drawer-overlay" id="drawer-overlay"></div>

<div class="product-variant-drawer" id="variant-drawer">

  <div class="product-variant-drawer-wrapper">
    {%- unless product.has_only_default_variant -%}
      <variant-selects
        id="variant-selects-drawer-{{ section.id }}"
        data-section="{{ section.id }}"
        {{ block.shopify_attributes }}
      >
        <div class="product-variant-drawer-title-wrap">
          <div class="title-wrapper">
           <div class="customize-product-prices" id="customize-price-drawer-prices">
              {% if product.compare_at_price > product.price %}
                <span class="price" id="customize-price-drawer-sale-price" data-price="{{ product.price }}"></span>
              {% endif %}
            </div>
          </div>
          <div class="close-button" id="close-drawer">
            <i class="fa-solid fa-xmark"></i>
          </div>
        </div>
        <div class="product-variants-wrapper">
            {%- for option in product.options_with_values -%}
                <fieldset class="js product-form__input product-form__input--pill variant-type-{{ option.name | handle }}">
                <legend class="form__label">
                    {{ option.name }}: 
                    <span data-selected-value>{{ option.selected_value }}</span>
                </legend>
                {% render 'product-variant-options',
                    product: product,
                    option: option,
                    block: block,
                    picker_type: 'button'
                %}
                </fieldset>
            {%- endfor -%}
        </div>

        <div class="customize-button-wrapper">
          <button id="customize_close_drawer" class="customize-variants-button">Confirm Customization</button>
        </div>
        <script type="application/json" data-selected-variant>
          {{ product.selected_or_first_available_variant | json }}
        </script>
      </variant-selects>
    {%- endunless -%}
  </div>
</div>

<script>
  // Global configuration for Customize Price
  const CustomizePriceConfig = {
    variantsData: { {{ variants_data }} },
    currentVariantId: {{ product.selected_or_first_available_variant.id }}
  };

  class CustomizePriceManager {
    constructor(config) {
      this.config = config;
      this.isInitialized = false;
      this.currentVariantId = null;
      this.debounceTimer = null;
      
      // Performance optimizations
      this.numberFormatter = new Intl.NumberFormat('en-IN', {
        style: 'currency',
        currency: 'INR',
        maximumFractionDigits: 0,
        minimumFractionDigits: 0
      });
      
      // Pre-bind methods to avoid recreation
      this.handleVariantChange = this.debounce(this.handleVariantChange.bind(this), 100);
      this.handleDocumentChange = this.handleDocumentChange.bind(this);
      
      this.init();
    }

    init() {
      console.log('[Customize Price Manager] Initializing Customize Price Display.');
      this.setupEventListeners();
      
      // Initial price update
      this.updateCustomizePrice(this.config.currentVariantId);
      this.isInitialized = true;
    }

    setupEventListeners() {
      // Listen for variant changes
      document.addEventListener('change', this.handleDocumentChange, { passive: true });
      
      // Listen for URL changes (if variants change via URL)
      if (window.history.length > 1) {
        window.addEventListener('popstate', this.handleVariantChange, { passive: true });
      }
    }

    handleDocumentChange(e) {
      // Check if it's a variant selector change
      if (e.target.name === 'id' || e.target.classList.contains('variant-selector')) {
        this.handleVariantChange();
      }
    }

    getCurrentVariantId() {
      // Check URL parameters first
      const url = new URL(window.location);
      const urlVariantId = url.searchParams.get("variant");
      
      // Check for selected variant in forms
      const variantInput = document.querySelector('input[name="id"]:checked') || 
                          document.querySelector('select[name="id"]') ||
                          document.querySelector('input[name="id"]');
      
      if (variantInput) {
        return variantInput.value;
      }
      
      return urlVariantId || this.config.currentVariantId;
    }

    handleVariantChange() {
      const variantId = this.getCurrentVariantId();
      
      // Avoid unnecessary updates
      if (variantId === this.currentVariantId) return;
      
      if (variantId && this.config.variantsData[variantId]) {
        console.log('[Customize Price Manager] Variant changed to:', variantId);
        this.updateCustomizePrice(variantId);
      }
    }

    updateCustomizePrice(variantId) {
      try {
        const selectedVariant = this.config.variantsData[variantId];
        
        if (!selectedVariant) {
          console.warn('[Customize Price Manager] No variant data found for:', variantId);
          return;
        }

        this.renderCustomizePrice(selectedVariant);
        this.currentVariantId = variantId;

      } catch (error) {
        console.error('[Customize Price Manager] Error updating customize price:', error);
        this.showError(error.message);
      }
    }

    renderCustomizePrice(selectedVariant) {
      const priceElement = document.getElementById('customize-price-drawer-sale-price');
      
      if (!priceElement) {
        console.warn('[Customize Price Manager] Price element not found');
        return;
      }

      const price = selectedVariant.price / 100; // convert paise to rupees
      const compareAtPrice = selectedVariant.compare_at_price / 100;

      // Update the price display
      priceElement.textContent = this.formatCurrency(price);
      priceElement.setAttribute('data-price', selectedVariant.price);

      // Handle visibility based on compare price logic
      const shouldShow = compareAtPrice && compareAtPrice > price;
      
      if (shouldShow) {
        priceElement.style.display = 'inline';
        // Add sale class if needed
        if (!priceElement.classList.contains('sale')) {
          priceElement.classList.add('sale');
        }
      } else {
        priceElement.style.display = 'none';
        priceElement.classList.remove('sale');
      }

      console.log('[Customize Price Manager] Updated price:', this.formatCurrency(price), 'Visible:', shouldShow);
    }

    formatCurrency(price) {
      return this.numberFormatter.format(Math.round(Number(price)));
    }

    debounce(func, wait) {
      return (...args) => {
        clearTimeout(this.debounceTimer);
        this.debounceTimer = setTimeout(() => func.apply(this, args), wait);
      };
    }

    showError(message) {
      console.error('[Customize Price Manager]', message);
      // Optionally show user-friendly error
      const errorDiv = document.createElement('div');
      errorDiv.className = 'customize-price-error';
      errorDiv.textContent = `Price Error: ${message}`;
      errorDiv.style.color = 'red';
      errorDiv.style.fontSize = '12px';
      
      const priceElement = document.getElementById('customize-price-drawer-sale-price');
      if (priceElement && priceElement.parentNode) {
        priceElement.parentNode.insertBefore(errorDiv, priceElement.nextSibling);
        setTimeout(() => errorDiv.remove(), 3000);
      }
    }

    // Cleanup method
    destroy() {
      if (this.debounceTimer) {
        clearTimeout(this.debounceTimer);
      }
    }
  }

  // Initialize the Customize Price Manager
  let customizePriceManager = null;

  function initializeCustomizePrice() {
    if (!customizePriceManager) {
      customizePriceManager = new CustomizePriceManager(CustomizePriceConfig);
    }
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeCustomizePrice);
  } else {
    // DOM is already loaded
    initializeCustomizePrice();
  }

  // Make it available globally if needed
  window.CustomizePriceManager = CustomizePriceManager;
  window.customizePriceManager = customizePriceManager;
</script>