<div class="drawer-overlay" id="drawer-overlay"></div>

<div class="product-variant-drawer" id="variant-drawer">

  <div class="product-variant-drawer-wrapper">
    {%- unless product.has_only_default_variant -%}
      <variant-selects
        id="variant-selects-drawer-{{ section.id }}"
        data-section="{{ section.id }}"
        {{ block.shopify_attributes }}
      >
        <div class="product-variant-drawer-title-wrap">
          <div class="title-wrapper">
           <div class="product-prices" id="price-drawer-prices">
              {% if product.compare_at_price > product.price %}
                <span class="price sale" id="price-drawer-price" data-price="{{ product.price }}"></span>
                <del class="compare-price" id="price-drawer-compare-price" data-price="{{ product.compare_at_price }}"></del>
              {% else %}
                <span class="price" id="price-drawer-sale-price" data-price="{{ product.price }}"></span>
              {% endif %}
            </div>
          </div>
          <div class="close-button" id="close-drawer">
            <i class="fa-solid fa-xmark"></i>
          </div>
        </div>
        <div class="product-variants-wrapper">
            {%- for option in product.options_with_values -%}
                <fieldset class="js product-form__input product-form__input--pill variant-type-{{ option.name | handle }}">
                <legend class="form__label">
                    {{ option.name }}: 
                    <span data-selected-value>{{ option.selected_value }}</span>
                </legend>
                {% render 'product-variant-options',
                    product: product,
                    option: option,
                    block: block,
                    picker_type: 'button'
                %}
                </fieldset>
            {%- endfor -%}
        </div>

        <div class="customize-button-wrapper">
          <button id="customize_close_drawer" class="customize-variants-button">Confirm Customization</button>
        </div>
        <script type="application/json" data-selected-variant>
          {{ product.selected_or_first_available_variant | json }}
        </script>
      </variant-selects>
    {%- endunless -%}
  </div>
</div>
