<section class="always-with-you">
  <h2 class="always-with-you__title">ALWAYS WITH YOU</h2>

  <div class="always-with-you__grid">
    {% assign benefits = 'Free Resizing post purchase|15 Days Return|Loose diamond fixation|100% Lifetime Exchange'
      | split: '|'
    %}

    {% for benefit in benefits %}
      <div class="always-with-you__item">
        <div class="always-with-you__icon">
          {% case forloop.index %}
            {% when 1 %}
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 7h4V3M21 17h-4v4M3 3l6 6M21 21l-6-6"/>
              </svg>

            {% when 2 %}
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2v20M5 12h14"/>
              </svg>
            {% when 3 %}
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 7l3 3-7 7-3-3z"/>
              </svg>
            {% when 4 %}
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2l4 4-4 4-4-4zM2 12l4 4-4 4-4-4z"/>
              </svg>
          {% endcase %}
        </div>

        <p class="always-with-you__text">
          {{ benefit }}
        </p>

        <span class="always-with-you__arrow"></span>
      </div>
    {% endfor %}
  </div>
</section>
