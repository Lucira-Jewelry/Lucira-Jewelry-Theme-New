<style>
    html.awy-open, html.awy-open body { overflow: hidden; touch-action: none; /* prevents mobile scroll */ }
        /* Lock background scroll when overlay is open */
    .design-font-div-wrapper{
    text-align: center;
    }
          .awy-drawer {
          position: fixed;
          top: 0;
          right: 0;
          overflow-y: auto;
          -webkit-overflow-scrolling: touch;
        }
      /* Arrow */
      .awy-drawer summary::after {
        content: ''; position: absolute; right: 12px; width: 8px; height: 8px; border-right: 1.5px solid #585858; border-bottom: 1.5px solid #585858; transform: rotate(45deg); transition: transform 0.25s ease;
      }

      /* Rotate arrow when open */
      .awy-drawer details[open] > summary::after {
        transform: rotate(-135deg);
      }

        .awy-overlay {
          position: fixed;
          inset: 0;
        }

            /* ===== CARDS ===== */
            .always-with-you {
              text-align: center;
              padding: 10px 0;
            }

            .always-with-you__title {
                font-weight: 400;
                font-size: 12px;
                line-height: 150%;
                letter-spacing: 4%;
                text-transform: uppercase;
                text-align:left;
            }

            .always-with-you__grid {
              display: grid;
              grid-template-columns: repeat(4, 1fr);
              gap:12px;
            }
            span.design-font{
            font-family: Beau Rivage !important; font-weight: 400; font-size: 24px; line-height: 150%; letter-spacing: 1px; text-align: center; padding: 0 0px;
            }
            .always-with-you__item {
              background: none;
              border: none;
              cursor: pointer;
              display: flex;
              padding:0;
              flex-direction: column;
              align-items: center;
              gap: 6px;
            }

            .always-with-you__icon {
              width: 60px;
              height: 60px;
              border-radius: 50%;
              background: #f6f6f6;
              display: flex;
              align-items: center;
              justify-content: center;
              margin-bottom: 10px;
            }

            .always-with-you__text {
                font-weight: 400;
                font-size: 12px;
                line-height: 21px;
                letter-spacing: 0.2%;
                text-align: center;
                margin:0;
                text-decoration: underline;
                text-underline-offset: 4px;
                text-decoration-color: rgba(255, 0, 0, 0.2);


            }

            

            /* ===== OVERLAY ===== */
            .awy-overlay {
              position: fixed;
              top: 0;
              left: 0;
              width: 100vw;
              height: 100vh;
              background: rgba(0, 0, 0, 0.45);
              opacity: 0;
              pointer-events: none;
              transition: opacity .3s ease;
              z-index: 9999999;
            }

            /* ===== DRAWER ===== */
            .awy-drawer {
              position: fixed;
              top: 0;
              justify-content: flex-start;
              right: 0;
              width: 40%;
              max-width: 100%;
              height: 100%;
              background: #fff;
              transform: translateX(100%);
              transition: transform .35s ease;
              z-index: 99999999;
              display: flex;
              border-top-left-radius: 24px;
              flex-direction: column;
            }

            /* ACTIVE STATE */
            .awy-open .awy-overlay {
              opacity: 1;
              pointer-events: auto;
              display:block;
            }

            .awy-open .awy-drawer {
              transform: translateX(0);
            }


            .awy-drawer__header {
                padding: 8px 32px 0 28px;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .awy-drawer__header h3 {font-weight: 400; font-size: 16px; line-height: 150%; letter-spacing: 1px; text-transform: uppercase;}
            span.text-title { font-family: Futura Std; font-weight: 500; font-size: 14px; line-height: 21px; letter-spacing: 0.7px; text-align: center; vertical-align: middle; text-transform: uppercase; }
            .awy-drawer p { font-family: Futura Std; font-weight: 400 !important; font-size: 14px; line-height: 150%; letter-spacing: 0.1px !important; padding: 0 !important; text-align: justify !important; }
            span.text-title { font-weight: 500; font-size: 14px; line-height: 1; letter-spacing: 0.5px; text-align: center; vertical-align: middle; text-transform: uppercase; color: #1a1a1a; }
            .awy-close {
              background: none;
              border: none;
              font-size: 20px;
              cursor: pointer;
              color: #000;
            }

            .awy-drawer__content {
              padding: 10px 32px;
            }


            /* Accordion */
            .awy-drawer details {
              border-bottom: 1px solid #eee;
              padding: 15px 0;

            }

            .awy-drawer summary {
                cursor: pointer;
                font-weight: 500;
                list-style: none;
                font-weight: 400;
                font-size: 14px;
                line-height: 21px;
                letter-spacing: 0.2%;
                text-transform: uppercase;
                display:flex;
                gap:10px;
                align-items:center;
            }

            .awy-drawer summary::-webkit-details-marker {
              display: none;
            }

            .awy-drawer p {
            font-weight: 400;
            font-size: 14px;
            line-height: 150%;
            letter-spacing: 2%;
            padding: 0 20px;
            text-align: center;
            }


            img.image-drawer-awy{
              width: 100%;
              height: 200px;
            display: block;
              object-fit: cover;
              padding-top: 10px;
            }
            .svg-summary-wrapper{
              display:flex;
              gap:10px;
          }

          .always-with-you__arrow {margin-top: 6px;}

          .awy-close svg {width: 30px;}
            /* ===== MOBILE ===== */
            @media (max-width: 768px) {
              .always-with-you__grid {
                grid-template-columns: repeat(4, 1fr);
                gap: 10px;
              }

              span.text-title{
                font-weight: 400;
                font-size: 12px;
                line-height: 150%;
                letter-spacing: 2%;
                text-align: center;
                text-transform: uppercase;
            }

            .awy-drawer {border-top-left-radius: 24px; border-top-right-radius: 24px;}
            
  .awy-drawer__content{
  padding: 0 22px;
  }
              .always-with-you__text{
                font-size: 12px;
                line-height: 17.15px;
                letter-spacing: 0.2%;
                text-align: center;
                color: #000;
            }
              .awy-drawer {
                width: 100%;
                height: 85%;
                top: auto;
                bottom: 0;
                transform: translateY(100%);
              }
.awy-drawer__header{
padding: 8px 16px 0 28px;
}
              .awy-drawer p{
        font-weight: 300;
        font-size: 12px;
        line-height: 150%;
        letter-spacing: 2%;
        text-align: center;
        padding : 0;
            }

            span.design-font{
            font-family: Beau Rivage;
        font-weight: 400;
        font-size: 20px;
        line-height: 150%;
        letter-spacing: 2%;
        padding: 0px;
            }
              .awy-open .awy-drawer {
                transform: translateY(0);
              }

            }
</style>

<script>
  let awyCurrentIndex = 1;
  const awyTotal = document.querySelectorAll('.awy-drawer details').length;

  function openAlwaysWithYou(index) {
    awyCurrentIndex = index;
    document.documentElement.classList.add('awy-open');

    document.querySelectorAll('.awy-drawer details').forEach((d) => {
      d.removeAttribute('open');
      if (Number(d.dataset.index) === index) {
        d.setAttribute('open', '');
        d.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }

  function closeAlwaysWithYou() {
    document.documentElement.classList.remove('awy-open');
  }

  document.addEventListener('keydown', function (e) {
    if (!document.documentElement.classList.contains('awy-open')) return;

    if (e.key === 'ArrowRight') {
      awyCurrentIndex = awyCurrentIndex === awyTotal ? 1 : awyCurrentIndex + 1;
      openAlwaysWithYou(awyCurrentIndex);
    }

    if (e.key === 'ArrowLeft') {
      awyCurrentIndex = awyCurrentIndex === 1 ? awyTotal : awyCurrentIndex - 1;
      openAlwaysWithYou(awyCurrentIndex);
    }

    if (e.key === 'Escape') {
      closeAlwaysWithYou();
    }
  });
</script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const accordionItems = document.querySelectorAll('.awy-drawer details');

    accordionItems.forEach((item) => {
      item.addEventListener('toggle', function () {
        if (this.open) {
          accordionItems.forEach((otherItem) => {
            if (otherItem !== this) {
              otherItem.removeAttribute('open');
            }
          });
        }
      });
    });
  });
</script>
