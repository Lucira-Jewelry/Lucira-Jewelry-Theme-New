<style>
      html.awy-open, html.awy-open body { overflow: hidden; touch-action: none; /* prevents mobile scroll */ }
          /* Lock background scroll when overlay is open */
      .design-font-div-wrapper{
      text-align: center;
      }
            .awy-drawer {
            position: fixed;
            top: 0;
            right: 0;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
          }
        /* Arrow */
        .awy-drawer summary::after {
          content: ''; position: absolute; right: 12px; width: 8px; height: 8px; border-right: 1.5px solid #585858; border-bottom: 1.5px solid #585858; transform: rotate(45deg); transition: transform 0.25s ease;
        }

        /* Rotate arrow when open */
        .awy-drawer details[open] > summary::after {
          transform: rotate(-135deg);
        }

          .awy-overlay {
            position: fixed;
            inset: 0;
          }

              /* ===== CARDS ===== */
              .always-with-you {
                text-align: center;
                padding: 10px 0;
              }

              .always-with-you__title {
                  font-weight: 400;
                  font-size: 12px;
                  line-height: 150%;
                  letter-spacing: 4%;
                  text-transform: uppercase;
                  text-align:left;
              }

              .always-with-you__grid {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap:12px;
              }
              span.design-font{
              font-family: Beau Rivage !important; font-weight: 400; font-size: 24px; line-height: 150%; letter-spacing: 1px; text-align: center; padding: 0 0px;
              }
              .always-with-you__item {
                background: none;
                border: none;
                cursor: pointer;
                display: flex;
                padding:0;
                flex-direction: column;
                align-items: center;
                gap: 6px;
              }

              .always-with-you__icon {
                width: 60px;
                height: 60px;
                border-radius: 50%;
                background: #f6f6f6;
                display: flex;
                align-items: center;
                justify-content: center;
                margin-bottom: 10px;
              }

              .always-with-you__text {
                  font-weight: 400;
                  font-size: 12px;
                  line-height: 21px;
                  letter-spacing: 0.2%;
                  text-align: center;
                  margin:0;
                  text-decoration: underline;
                  text-underline-offset: 4px;
                  text-decoration-color: rgb(226, 226, 226);
              }



              /* ===== OVERLAY ===== */
              .awy-overlay {
                position: fixed;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                background: rgba(0, 0, 0, 0.45);
                opacity: 0;
                pointer-events: none;
                transition: opacity .3s ease;
                z-index: 9999999;
