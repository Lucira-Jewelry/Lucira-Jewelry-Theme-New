  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const insuranceVariantId = '46764838093018';
      let isProcessing = false;

      const checkbox = document.getElementById('insurance-check');
      const features = document.querySelector('.insurance-features');
      const preloader = document.getElementById('insurance-preloader');
      const preloaderText = preloader.querySelector('.preloader-text');
      const addSVG = document.getElementById('preloader-add');
      const removeSVG = document.getElementById('preloader-remove');

      if (!checkbox || !features) return;

      function showPreloader(isAdding) {
        preloader.classList.add('active');
        preloaderText.textContent = isAdding
          ? 'Adding insurance to your order...'
          : 'Removing insurance from your order...';
        addSVG.style.display = isAdding ? 'block' : 'none';
        removeSVG.style.display = isAdding ? 'none' : 'block';
      }

      function hidePreloader() {
        preloader.classList.remove('active');
      }

      function updateUI(isActive) {
        if (isActive) {
          checkbox.classList.add('checked-box-insurance');
          features.classList.add('active');
          features.classList.remove('unactive');
        } else {
          checkbox.classList.remove('checked-box-insurance');
          features.classList.remove('active');
          features.classList.add('unactive');
        }
      }

      function updateCartCount() {
        fetch('/cart.js')
          .then((res) => res.json())
          .then((cart) => {
            const bubbleWrapper = document.querySelector('.cart-count-bubble');
            if (bubbleWrapper) {
              const countSpan = bubbleWrapper.querySelector('span[aria-hidden="true"]');
              const hiddenText = bubbleWrapper.querySelector('.visually-hidden');
              if (countSpan) countSpan.textContent = cart.item_count;
              if (hiddenText) hiddenText.textContent = `${cart.item_count} items in cart`;
              bubbleWrapper.classList.toggle('hidden', cart.item_count === 0);
            }
          });
      }

      function syncCheckboxWithCart() {
        fetch('/cart.js')
          .then((res) => res.json())
          .then((cart) => {
            const insuranceItem = cart.items.find((item) => item.variant_id == insuranceVariantId);
            checkbox.checked = !!insuranceItem;
            updateUI(!!insuranceItem);
          });
      }

      function toggleInsurance() {
        if (isProcessing) return;
        isProcessing = true;

        showPreloader(checkbox.checked);

        fetch('/cart.js')
          .then((res) => res.json())
          .then((cart) => {
            const insuranceItem = cart.items.find((item) => item.variant_id == insuranceVariantId);
            const otherItems = cart.items.filter((item) => item.variant_id != insuranceVariantId);

            if (checkbox.checked) {
              // Prevent adding insurance if cart is empty
              if (otherItems.length === 0) {
                checkbox.checked = false;
                updateUI(false);
                hidePreloader();
                isProcessing = false;
                return;
              }

              if (!insuranceItem) {
                return fetch('/cart/add.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ id: insuranceVariantId, quantity: 1 }),
                });
              }
            } else {
              if (insuranceItem) {
                return fetch('/cart/change.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ id: insuranceItem.key, quantity: 0 }),
                });
              }
            }
          })
          .then(() => {
            syncCheckboxWithCart();
            updateCartCount();
            hidePreloader();
            isProcessing = false;
          })
          .catch((err) => {
            console.error(err);
            hidePreloader();
            isProcessing = false;
          });
      }

      // Bind checkbox toggle
      checkbox.addEventListener('change', toggleInsurance);

      // Sync checkbox when cart updates anywhere else on site
      document.addEventListener('cart:updated', syncCheckboxWithCart);

      // Initial sync
      syncCheckboxWithCart();
    });
  </script>
