<style>
  .preloader-svg{animation:pulse 2.5s infinite ease-in-out}
  .inner-path,.middle-path,.outer-path{transform-origin:center;animation:draw 3s ease-in-out infinite alternate}
  @keyframes draw{
    0%{opacity:0;transform:scale(.9)}
    50%{opacity:1;transform:scale(1)}
    100%{opacity:.7;transform:scale(1.05)}
  }
  @keyframes pulse{
    0%,100%{transform:scale(1)}
    50%{transform:scale(1.05)}
  }
  .preloader-spinner{border:3px solid #f3e8e9;border-top:3px solid #b76f79;border-radius:50%;width:60px;height:60px;margin-bottom:20px;animation:spin 1.4s linear infinite}
  @keyframes spin{
    0%{transform:rotate(0)}
    100%{transform:rotate(360deg)}
  }
  .preloader-text{margin-top:15px;font-family:Futura,sans-serif;font-size:18px;color:#b76f79;letter-spacing:1px;animation:flicker 2s ease-in-out infinite}
  @keyframes flicker{
    0%,100%{opacity:1}
    50%{opacity:.4}
  }
  .brad_8992950714586{display:flex;justify-content:space-around;align-content:space-around;align-items:stretch}
  .brad_8992950714586 .cart-item__totals.right,.brad_8992950714586 .delivery-date-expected,.brad_8992950714586 a.cart-item__link,.brad_8992950714586 cart-remove-button,.brad_8992950714586 quantity-input.quantity.cart-quantity.qty{display:none}
  .brad_8992950714586 .cart-items td{padding:0!important}
  .brad_8992950714586 .cart-item__image{width:70px;height:70px;position:absolute;top:-20px;left:20px}
  .insurance-box{border:1px solid #ccc;border-radius:8px;padding:16px;font-family:inherit;margin:3px 10px;position:relative}
  .insurance-label{display:flex;align-items:center;justify-content:space-between;font-weight:600;margin-bottom:10px;cursor:pointer}
  .insurance-label input[type=checkbox]{accent-color: #0d508c; height: 16px; width: 16px; margin: 0; margin-right: 8px;}
  .insurance-text{flex:1;margin-left:8px;font-weight:500}
  span.insurance-price { font-weight: 600; font-size: 15px; letter-spacing: 1.2px; color: #1A1A1A; }
  span.insurance-price{font-weight:600}
  .insurance-features{list-style:none;padding-left:0;margin:0;font-size:14px;transition:color .1s ease}
  ul.insurance-features.active{color:#0d508c}
  ul.insurance-features.unactive{color:#999}
  .insurance-preloader{position:absolute;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.9);display:flex;flex-direction:column;align-items:center;justify-content:center;border-radius:8px;z-index:10;opacity:0;visibility:hidden;transition:opacity .3s ease,visibility .3s ease}
  .insurance-preloader.active{opacity:1;visibility:visible}
  .preloader-spinner{width:30px;height:30px;border:3px solid #f3f3f3;border-top:3px solid #0d508c;border-radius:50%;animation:spin 1s linear infinite;margin-bottom:10px}
  .preloader-text{font-size:14px;color:#0d508c;font-weight:500}
  @keyframes spin{
    0%{transform:rotate(0)}
    100%{transform:rotate(360deg)}
  }
  @media(max-width:768px){
    .insurance-text,span.insurance-price{font-size:14px}
    .insurance-features li{font-size:10px}
    .insurance-box{padding:4px 10px}
    .insurance-label input[type=checkbox]{margin-right:3px;height:14px;width:14px}
    .insurance-label{margin-bottom:0}
    .cart-drawer .brad_8992950714586{height:70px!important}
    .brad_8992950714586 .cart-item__image{top:-15px;left:0}
    .preloader-spinner{width:20px;height:20px;margin-bottom:5px}
    .preloader-text{font-size:10px}
    .preloader-text{margin-top:5px;}
  }
  .insurance-features li {position: relative;padding-left: 30px;}
  .insurance-features li:after {content: ''; position: absolute; background: url(https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Vector_dbc3c50f-fb9c-4477-ad24-24e7ddec9141.svg?v=1760449960); left: 0; top: 50%; transform: translateY(-50%); width: 14px; height: 14px; background-size: 14px 14px;}
</style>

<script>
  const insuranceVariantId = '46764838093018';
  
  // Debounce flag - MUST be declared at the top
  let quantityChangeInProgress = false;

  function updateUI(checkbox, features, isActive) {
    if (isActive) {
      checkbox.classList.add('checked-box-insurance');
      features.classList.add('active');
      features.classList.remove('unactive');
    } else {
      checkbox.classList.remove('checked-box-insurance');
      features.classList.remove('active');
      features.classList.add('unactive');
    }
  }

  // Sync insurance with cart state
  async function syncInsuranceCheckbox() {
    // Don't sync if a quantity change is still processing
    if (quantityChangeInProgress) {
      console.log('Skipping sync - quantity change in progress');
      return;
    }
    
    const cart = await (await fetch('/cart.js')).json();
    const insuranceItem = cart.items.find((i) => i.variant_id == insuranceVariantId);
    const otherItems = cart.items.filter((i) => i.variant_id != insuranceVariantId);
    const hasOtherItems = otherItems.length > 0;

    // If cart is empty or has only insurance, remove insurance
    if (!hasOtherItems && insuranceItem) {
      await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: insuranceItem.key, quantity: 0 }),
      });
      
      // Refresh cart after removal
      const updatedCart = await (await fetch('/cart.js')).json();
      const updatedInsuranceItem = updatedCart.items.find((i) => i.variant_id == insuranceVariantId);
      
      document.querySelectorAll('#insurance-check').forEach((checkbox) => {
        const box = checkbox.closest('.insurance-box');
        if (!box) return;
        const features = box.querySelector('.insurance-features');
        checkbox.checked = false;
        updateUI(checkbox, features, false);
      });
      return;
    }

    // Keep insurance quantity at 1 if it exists
    if (hasOtherItems && insuranceItem && insuranceItem.quantity !== 1) {
      await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: insuranceItem.key, quantity: 1 }),
      });
    }

    // Update UI
    document.querySelectorAll('#insurance-check').forEach((checkbox) => {
      const box = checkbox.closest('.insurance-box');
      if (!box) return;
      const features = box.querySelector('.insurance-features');
      checkbox.checked = !!insuranceItem && hasOtherItems;
      updateUI(checkbox, features, checkbox.checked);
    });
  }

  async function toggleInsurance(checkbox, features, preloader) {
    if (checkbox.dataset.processing === 'true') return;
    checkbox.dataset.processing = 'true';

    const isChecked = checkbox.checked;
    const preloaderText = preloader.querySelector('.preloader-text');
    const addSVG = preloader.querySelector('#preloader-add');
    const removeSVG = preloader.querySelector('#preloader-remove');

    preloader.classList.add('active');
    preloaderText.textContent = isChecked
      ? 'Adding insurance to your order...'
      : 'Removing insurance from your order...';
    addSVG.style.display = isChecked ? 'block' : 'none';
    removeSVG.style.display = isChecked ? 'none' : 'block';

    try {
      const cart = await (await fetch('/cart.js')).json();
      const insuranceItem = cart.items.find((i) => i.variant_id == insuranceVariantId);
      const otherItems = cart.items.filter((i) => i.variant_id != insuranceVariantId);
      const hasOtherItems = otherItems.length > 0;
      
      if (isChecked && hasOtherItems) {
        if (!insuranceItem) {
          // Add insurance with quantity 1
          await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: insuranceVariantId, quantity: 1 }),
          });
        } else if (insuranceItem.quantity !== 1) {
          // Keep insurance quantity at 1
          await fetch('/cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: insuranceItem.key, quantity: 1 }),
          });
        }
        await new Promise((r) => setTimeout(r, 400));
      } else if (!isChecked && insuranceItem) {
        // Remove insurance
        await fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: insuranceItem.key, quantity: 0 }),
        });
      } else if (isChecked && !hasOtherItems) {
        // Can't add insurance to empty cart
        checkbox.checked = false;
        updateUI(checkbox, features, false);
        checkbox.dataset.processing = 'false';
        preloader.classList.remove('active');
        return;
      }

      await new Promise((r) => setTimeout(r, 100));
      await syncInsuranceCheckbox();

      // Update cart bubble
      const updatedCart = await (await fetch('/cart.js')).json();
      const bubbleWrapper = document.querySelector('.cart-count-bubble');
      if (bubbleWrapper) {
        const countSpan = bubbleWrapper.querySelector('span[aria-hidden="true"]');
        const hiddenText = bubbleWrapper.querySelector('.visually-hidden');
        if (countSpan) countSpan.textContent = updatedCart.item_count;
        if (hiddenText) hiddenText.textContent = `${updatedCart.item_count} items in cart`;
        bubbleWrapper.classList.toggle('hidden', updatedCart.item_count === 0);
      }
    } catch (err) {
      console.error(err);
    } finally {
      preloader.classList.remove('active');
      checkbox.dataset.processing = 'false';
    }
  }

  // Event delegation for checkbox changes
  document.body.addEventListener('change', function (e) {
    if (e.target && e.target.matches('#insurance-check')) {
      const box = e.target.closest('.insurance-box');
      const features = box.querySelector('.insurance-features');
      const preloader = box.querySelector('.insurance-preloader');
      toggleInsurance(e.target, features, preloader);
    }
  });

  // Listen for quantity button clicks (+ and -)
  document.body.addEventListener('click', async function(e) {
    // Check if it's a quantity button
    if (e.target && (e.target.matches('quantity-input button, .quantity__button, button[name="plus"], button[name="minus"]') 
        || e.target.closest('quantity-input button, .quantity__button, button[name="plus"], button[name="minus"]'))
        && !e.target.closest('.insurance-box')) {
      console.log('Quantity button clicked, setting flag');
      quantityChangeInProgress = true;
      
      // Wait for Shopify to process the change
      await new Promise(r => setTimeout(r, 2000));
      
      quantityChangeInProgress = false;
      console.log('Quantity button change complete');
      await syncInsuranceCheckbox();
    }
  });

  // Listen for quantity changes in cart
  document.body.addEventListener('change', async function(e) {
    // Check if it's a quantity input change (but NOT the insurance checkbox)
    if (e.target && e.target.matches('quantity-input input, .quantity__input, input[name="updates[]"]') 
        && !e.target.closest('.insurance-box')) {
      console.log('Quantity change detected, setting flag');
      quantityChangeInProgress = true;
      
      // Wait longer for Shopify to process
      await new Promise(r => setTimeout(r, 2000));
      
      quantityChangeInProgress = false;
      console.log('Quantity change complete, syncing');
      await syncInsuranceCheckbox();
    }
  });

  // Also listen for input events (fires during typing)
  document.body.addEventListener('input', function(e) {
    if (e.target && e.target.matches('quantity-input input, .quantity__input, input[name="updates[]"]') 
        && !e.target.closest('.insurance-box')) {
      console.log('Quantity input detected');
      quantityChangeInProgress = true;
    }
  });

  // Listen for cart item removal
  document.body.addEventListener('click', async function(e) {
    if (e.target && (e.target.matches('cart-remove-button, .cart-item__remove, [data-cart-item-remove]') || 
        e.target.closest('cart-remove-button, .cart-item__remove, [data-cart-item-remove]'))) {
      await new Promise(r => setTimeout(r, 500));
      await syncInsuranceCheckbox();
    }
  });

  // Initial load
  document.addEventListener('DOMContentLoaded', syncInsuranceCheckbox);

  // Cart update events
  document.addEventListener('cart:updated', () => setTimeout(syncInsuranceCheckbox, 300));
  document.addEventListener('cart:refresh', () => setTimeout(syncInsuranceCheckbox, 300));

  // Observe cart drawer changes
  const observeCartChanges = () => {
    const cartDrawer = document.querySelector('cart-drawer, #CartDrawer, .cart-drawer, [id*="cart"]');
    if (!cartDrawer) return;

    let debounceTimer;
    const observer = new MutationObserver(() => {
      // Don't sync if quantity change is happening
      if (quantityChangeInProgress) {
        console.log('Observer: Skipping - quantity change in progress');
        return;
      }
      
      // Debounce to avoid multiple rapid syncs
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        if (!quantityChangeInProgress) {
          console.log('Observer: Syncing after mutation');
          syncInsuranceCheckbox();
        }
      }, 800);
    });

    observer.observe(cartDrawer, {
      childList: true,
      subtree: true
    });
  };

  document.addEventListener('DOMContentLoaded', () => {
    observeCartChanges();
    setTimeout(observeCartChanges, 1000);
  });

  // Shopify theme events
  if (window.Shopify && window.Shopify.theme) {
    document.addEventListener('shopify:section:load', () => setTimeout(syncInsuranceCheckbox, 300));
    document.addEventListener('shopify:section:reorder', () => setTimeout(syncInsuranceCheckbox, 300));
  }
</script>
