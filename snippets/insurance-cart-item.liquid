  // Add this function to re-initialize insurance after cart updates
  function initializeInsurance() {
    const insuranceVariantId = '46764838093018';
    let isProcessing = false;

    const checkbox = document.getElementById('insurance-check');
    const features = document.querySelector('.insurance-features');
    const preloader = document.getElementById('insurance-preloader');

    if (!checkbox || !features || !preloader) {
      console.log('Insurance elements not found, will retry...');
      return;
    }

    console.log('Insurance initialized successfully');

    const preloaderText = preloader.querySelector('.preloader-text');
    const addSVG = document.getElementById('preloader-add');
    const removeSVG = document.getElementById('preloader-remove');

    // Remove any existing listeners by cloning the checkbox
    const newCheckbox = checkbox.cloneNode(true);
    checkbox.parentNode.replaceChild(newCheckbox, checkbox);

    function showPreloader(isAdding) {
      preloader.classList.add('active');
      preloaderText.textContent = isAdding
        ? 'Adding insurance to your order...'
        : 'Removing insurance from your order...';
      addSVG.style.display = isAdding ? 'block' : 'none';
      removeSVG.style.display = isAdding ? 'none' : 'block';
    }

    function hidePreloader() {
      preloader.classList.remove('active');
    }

    function updateUI(isActive) {
      if (isActive) {
        newCheckbox.classList.add('checked-box-insurance');
        features.classList.add('active');
        features.classList.remove('unactive');
      } else {
        newCheckbox.classList.remove('checked-box-insurance');
        features.classList.remove('active');
        features.classList.add('unactive');
      }
    }

    function updateCartCount() {
      fetch('/cart.js')
        .then((res) => res.json())
        .then((cart) => {
          const bubbleWrapper = document.querySelector('.cart-count-bubble');
          if (bubbleWrapper) {
            const countSpan = bubbleWrapper.querySelector('span[aria-hidden="true"]');
            const hiddenText = bubbleWrapper.querySelector('.visually-hidden');
            if (countSpan) countSpan.textContent = cart.item_count;
            if (hiddenText) hiddenText.textContent = `${cart.item_count} items in cart`;
            bubbleWrapper.classList.toggle('hidden', cart.item_count === 0);
          }
        });
    }

    function syncCheckboxWithCart() {
      fetch('/cart.js')
        .then((res) => res.json())
        .then((cart) => {
          const insuranceItem = cart.items.find((item) => item.variant_id == insuranceVariantId);
          newCheckbox.checked = !!insuranceItem;
          updateUI(!!insuranceItem);
        });
    }

    function toggleInsurance() {
      if (isProcessing) return;
      isProcessing = true;

      const isChecked = newCheckbox.checked;
      showPreloader(isChecked);

      fetch('/cart.js')
        .then((res) => res.json())
        .then((cart) => {
          const insuranceItem = cart.items.find((item) => item.variant_id == insuranceVariantId);
          const otherItems = cart.items.filter((item) => item.variant_id != insuranceVariantId);

          if (isChecked) {
            // Prevent adding insurance if cart is empty
            if (otherItems.length === 0) {
              newCheckbox.checked = false;
              updateUI(false);
              hidePreloader();
              isProcessing = false;
              return Promise.resolve();
            }

            // Add insurance if not already in cart
            if (!insuranceItem) {
              return fetch('/cart/add.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: insuranceVariantId, quantity: 1 }),
              }).then(() => {
                // Wait a bit for cart to update on server
                return new Promise((resolve) => setTimeout(resolve, 200));
              });
            }
          } else {
            // Remove insurance if it exists
            if (insuranceItem) {
              return fetch('/cart/change.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: insuranceItem.key, quantity: 0 }),
              }).then(() => {
                // Wait a bit for cart to update on server
                return new Promise((resolve) => setTimeout(resolve, 200));
              });
            }
          }
          return Promise.resolve();
        })
        .then(() => {
          // Now sync with cart after operations complete
          return fetch('/cart.js').then((res) => res.json());
        })
        .then((cart) => {
          const insuranceItem = cart.items.find((item) => item.variant_id == insuranceVariantId);
          newCheckbox.checked = !!insuranceItem;
          updateUI(!!insuranceItem);
          updateCartCount();
          hidePreloader();
          isProcessing = false;
        })
        .catch((err) => {
          console.error(err);
          // Revert checkbox state on error
          syncCheckboxWithCart();
          hidePreloader();
          isProcessing = false;
        });
    }

    newCheckbox.addEventListener('change', toggleInsurance);
    syncCheckboxWithCart();
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', initializeInsurance);

  // Re-initialize when cart drawer content is updated with retry logic
  document.addEventListener('cart:updated', function () {
    let retries = 0;
    const maxRetries = 10;

    function tryInitialize() {
      const checkbox = document.getElementById('insurance-check');
      if (checkbox) {
        initializeInsurance();
      } else if (retries < maxRetries) {
        retries++;
        setTimeout(tryInitialize, 100);
      }
    }

    setTimeout(tryInitialize, 50);
  });

  // Also listen for cart drawer open events
  const observer = new MutationObserver(function (mutations) {
    mutations.forEach(function (mutation) {
      if (mutation.type === 'childList' || mutation.type === 'attributes') {
        const cartDrawer = document.querySelector('cart-drawer');
        if (cartDrawer && cartDrawer.classList.contains('active')) {
          const checkbox = document.getElementById('insurance-check');
          if (checkbox && !checkbox.dataset.initialized) {
            checkbox.dataset.initialized = 'true';
            setTimeout(initializeInsurance, 50);
          }
        }
      }
    });
  });

  // Observe cart drawer for changes
  const cartDrawer = document.querySelector('cart-drawer');
  if (cartDrawer) {
    observer.observe(cartDrawer, {
      childList: true,
      subtree: true,
      attributes: true,
      attributeFilter: ['class'],
    });
  }

  // MODIFY YOUR EXISTING CART DRAWER UPDATE CODE
  // Add this after the cart drawer innerHTML is updated
  document.addEventListener('DOMContentLoaded', () => {
    const e = document.querySelector('cart-drawer');
    e &&
      document.body.addEventListener('submit', async (t) => {
        const r = t.target;
        if (!r.matches('form[action^="/cart/add"]')) return;
        t.preventDefault();
        const s = new FormData(r);
        try {
          await fetch('/cart/add.js', {
            method: 'POST',
            body: s,
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
          });
          const t = await fetch('/cart?section_id=cart-drawer'),
            r = await t.text(),
            a = new DOMParser(),
            o = a.parseFromString(r, 'text/html').querySelector('cart-drawer');
          if (o) {
            e.innerHTML = o.innerHTML;
            e.open();

            // RE-INITIALIZE INSURANCE HERE
            setTimeout(initializeInsurance, 100);

            const t = e.querySelector('.you-may-also-like-wrapper'),
              r = e.querySelector('.you-may-also-like-wrapper-mobile');
            t && ((t.style.display = 'block'), e.activateCrossSelling()), r && (r.style.display = 'block');
          }
        } catch (e) {}
      });
  });
</script>
