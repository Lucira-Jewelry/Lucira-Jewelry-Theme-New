{% comment %}
  Delayed scripts to improve performance by loading third-party apps only after user interaction.
{% endcomment %}

{% render 'sticky-chat-experts' %}
{% render 'gokwik' %}
{% render 'wishlist-app-links', linkType: 'app-script' %}

<script src="{{ 'script.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'infinite-scroll.js' | asset_url }}" defer="defer"></script>
{% unless customer %}
  <script src="{{ 'login-register.js' | asset_url }}" defer="defer"></script>
{% endunless %}

<script>
  // Add any additional third-party JS that needs to be delayed here
  console.log('🚀 Third-party apps and secondary theme scripts loaded');
</script>