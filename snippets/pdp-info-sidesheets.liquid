<!-- ============================================================
     PDP INFO SIDE SHEETS — render once via main-product.liquid
     ============================================================ -->

<!-- OVERLAY -->
<div id="pdp-sheet-overlay" class="pdp-sheet-overlay" aria-hidden="true"><span></span></div>

<!-- ── 1. METAL SHEET ─────────────────────────────────────────── -->
<aside id="pdp-sheet-metal" class="pdp-info-sheet" role="dialog" aria-modal="true" aria-label="Metal information" hidden>
  <div class="pdp-sheet-header">
    <span class="pdp-sheet-title">Metal</span>
    <button class="pdp-sheet-close" data-sheet="metal" aria-label="Close">&times;</button>
  </div>
  <div class="pdp-sheet-body">

    <div class="pdp-sheet-section">
      <h4 class="pdp-sheet-label">Karat</h4>
      <div class="pdp-sheet-image-row">
        <figure class="pdp-sheet-fig">
          <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Rings_92988b51-2435-443b-97e3-f09ef94dcef8.png?v=1774258841" alt="9 KT Gold" loading="lazy" width="90" height="90">
          {% comment %} <figcaption>9 KT<br><small>37.5% Gold</small></figcaption> {% endcomment %}
        </figure>
        {% comment %} <figure class="pdp-sheet-fig">
          <img src="{{ 'info-metal-14kt.jpg' | asset_url }}" alt="14 KT Gold" loading="lazy" width="90" height="90">
          <figcaption>14 KT<br><small>58.5% Gold</small></figcaption>
        </figure>
        <figure class="pdp-sheet-fig">
          <img src="{{ 'info-metal-18kt.jpg' | asset_url }}" alt="18 KT Gold" loading="lazy" width="90" height="90">
          <figcaption>18 KT<br><small>75% Gold</small></figcaption>
        </figure> {% endcomment %}
      </div>
    </div>

    <div class="pdp-sheet-section">
      <h4 class="pdp-sheet-label">Color</h4>
      <div class="pdp-sheet-image-row">
        <figure class="pdp-sheet-fig">
          <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/ChatGPT_Image_Mar_9_2026_07_51_41_PM_1_6401ee6d-fa6f-44cf-b10b-94368203a063.png?v=1774258840" alt="Yellow Gold" loading="lazy" width="90" height="90">
        </figure>
        {% comment %} <figure class="pdp-sheet-fig">
          <img src="{{ 'info-metal-rose.jpg' | asset_url }}" alt="Rose Gold" loading="lazy" width="90" height="90">
          <figcaption>Rose Gold</figcaption>
        </figure>
        <figure class="pdp-sheet-fig">
          <img src="{{ 'info-metal-white.jpg' | asset_url }}" alt="White Gold" loading="lazy" width="90" height="90">
          <figcaption>White Gold</figcaption>
        </figure> {% endcomment %}
      </div>
    </div>

    <div class="pdp-sheet-section">
      <h4 class="pdp-sheet-label">Net Wt.</h4>
      <p class="pdp-sheet-desc">Net Wt. indicates only the weight of Metal from the total weight of the jewelry.</p>
    </div>

  </div>
</aside>

<!-- ── 2. DIMENSION SHEET ─────────────────────────────────────── -->
<aside id="pdp-sheet-dimension" class="pdp-info-sheet" role="dialog" aria-modal="true" aria-label="Dimension information" hidden>
  <div class="pdp-sheet-header">
    <span class="pdp-sheet-title">Dimension</span>
    <button class="pdp-sheet-close" data-sheet="dimension" aria-label="Close">&times;</button>
  </div>
  <div class="pdp-sheet-body">

    <div class="pdp-sheet-section">
      <div class="pdp-sheet-dim-row">
        <figure class="pdp-sheet-dim-fig">
                <h4 class="pdp-sheet-label">Height</h4>  
          <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_1437257497_ef0e1883-fce6-4ae5-8f5f-7d767cc4a343.png?v=1774258960" alt="Height measurement" loading="lazy" width="120" height="140">
          {% comment %} <figcaption>
            <strong>Height</strong>
            <p>The vertical dimension used to indicate how long a piece of jewelry is from the top of the setting.</p>
          </figcaption> {% endcomment %}
        </figure>
        <figure class="pdp-sheet-dim-fig">
                            <h4 class="pdp-sheet-label">Width</h4>  
          <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_1437257497_4df01e1c-7846-4b7d-a1ae-48e44907e308.png?v=1774258983" alt="Width measurement" loading="lazy" width="120" height="140">
          {% comment %} <figcaption>
            <strong>Width</strong>
            <p>The horizontal measurement used to indicate the widest point of the jewelry or the setting.</p>
          </figcaption> {% endcomment %}
        </figure>
      </div>
    </div>

    <div class="pdp-sheet-section">
      <h4 class="pdp-sheet-label">Gross Wt.</h4>
      <p class="pdp-sheet-desc">Gross Weight indicates the total weight of the jewelry, including the metal, diamonds, gemstones, and all other components used in the piece.</p>
    </div>

  </div>
</aside>

<!-- ── 3. DIAMOND SHEET ───────────────────────────────────────── -->
<aside id="pdp-sheet-diamond" class="pdp-info-sheet" role="dialog" aria-modal="true" aria-label="Diamond information" hidden>
  <div class="pdp-sheet-header">
    <span class="pdp-sheet-title">Diamond</span>
    <button class="pdp-sheet-close" data-sheet="diamond" aria-label="Close">&times;</button>
  </div>
  <div class="pdp-sheet-body">

    <div class="pdp-sheet-section">
      <h4 class="pdp-sheet-label">Position</h4>
      <div class="pdp-sheet-image-row">
        <figure class="pdp-sheet-fig">
          <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_1437257503_e5b7f116-3848-44e1-b838-e3691c85d5a2.png?v=1774259140" alt="Center diamond" loading="lazy" width="100" height="100">
          {% comment %} <figcaption>Center</figcaption> {% endcomment %}
        </figure>
        {% comment %} <figure class="pdp-sheet-fig">
          <img src="{{ 'info-diamond-side.jpg' | asset_url }}" alt="Side diamond" loading="lazy" width="100" height="100">
          <figcaption>Side</figcaption>
        </figure> {% endcomment %}
      </div>
    </div>

    <div class="pdp-sheet-section">
      <h4 class="pdp-sheet-label">Quality</h4>
      <div class="pdp-sheet-image-row">
        <figure class="pdp-sheet-fig">
          <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_1437257505_d217c271-1e27-4513-b571-c6464e313e2b.png?v=1774259140" alt="VVS-VS quality" loading="lazy" width="100" height="100">
          {% comment %} <figcaption>VVS - VS</figcaption> {% endcomment %}
        </figure>
        {% comment %} <figure class="pdp-sheet-fig">
          <img src="{{ 'info-diamond-ef.jpg' | asset_url }}" alt="EF quality" loading="lazy" width="100" height="100">
          <figcaption>EF</figcaption>
        </figure> {% endcomment %}
      </div>
    </div>

    <div class="pdp-sheet-section">
      <h4 class="pdp-sheet-label">Shape</h4>
      {% comment %} <div class="pdp-sheet-image-grid">
        {%- assign diamond_shapes = 'Emerald,Oval,Cushion,Round,Princess,Pear,Marquise,Heart' | split: ',' -%}
        {%- for shape in diamond_shapes -%}
          {%- assign shape_handle = shape | downcase -%}
          <figure class="pdp-sheet-grid-fig">
            <img src="{{ 'info-diamond-shape-' | append: shape_handle | append: '.jpg' | asset_url }}" alt="{{ shape }} cut" loading="lazy" width="64" height="64">
            <figcaption>{{ shape }}</figcaption>
          </figure>
        {%- endfor -%}
      </div> {% endcomment %}
      <div class="pdp-sheet-image-row">
        <figure class="pdp-sheet-fig">
          <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_1437257506_6987bc69-acbf-4dfb-b2e0-df136b4f6ed5.png?v=1774259141" alt="diamond shape" loading="lazy" width="100" height="100">
          {% comment %} <figcaption>VVS - VS</figcaption> {% endcomment %}
        </figure>
        {% comment %} <figure class="pdp-sheet-fig">
          <img src="{{ 'info-diamond-ef.jpg' | asset_url }}" alt="EF quality" loading="lazy" width="100" height="100">
          <figcaption>EF</figcaption>
        </figure> {% endcomment %}
      </div>
    </div>

    <div class="pdp-sheet-section">
      <h4 class="pdp-sheet-label">Quantity</h4>
      <p class="pdp-sheet-desc">Quantity indicates the total number of Diamonds used in the jewelry.</p>
    </div>

    <div class="pdp-sheet-section">
      <h4 class="pdp-sheet-label">Carat</h4>
      <p class="pdp-sheet-desc">Carat (ct) is the standard unit of measurement used to indicate the weight of Diamonds used in the jewelry.</p>
    </div>

  </div>
</aside>

<!-- ── 4. GEMSTONE SHEET ──────────────────────────────────────── -->
<aside id="pdp-sheet-gemstone" class="pdp-info-sheet" role="dialog" aria-modal="true" aria-label="Gemstone information" hidden>
  <div class="pdp-sheet-header">
    <span class="pdp-sheet-title">Gemstone</span>
    <button class="pdp-sheet-close" data-sheet="gemstone" aria-label="Close">&times;</button>
  </div>
  <div class="pdp-sheet-body">

    <div class="pdp-sheet-section">
      <h4 class="pdp-sheet-label">Color</h4>
     <div class="pdp-sheet-image-row">
        <figure class="pdp-sheet-fig">
          <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_1437257506_1_8d9ce413-b8c0-4273-865c-f77702ff25bb.png?v=1774259280" alt="Gemstone image" loading="lazy" width="100" height="100">
          {% comment %} <figcaption>VVS - VS</figcaption> {% endcomment %}
        </figure>
        {% comment %} <figure class="pdp-sheet-fig">
          <img src="{{ 'info-diamond-ef.jpg' | asset_url }}" alt="EF quality" loading="lazy" width="100" height="100">
          <figcaption>EF</figcaption>
        </figure> {% endcomment %}
      </div>
    </div>

    <div class="pdp-sheet-section">
      <h4 class="pdp-sheet-label">Shape</h4>
     <div class="pdp-sheet-image-row">
        <figure class="pdp-sheet-fig">
          <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_1437257506_6987bc69-acbf-4dfb-b2e0-df136b4f6ed5.png?v=1774259141" alt="Gemstone shape" loading="lazy" width="100" height="100">
          {% comment %} <figcaption>VVS - VS</figcaption> {% endcomment %}
        </figure>
        {% comment %} <figure class="pdp-sheet-fig">
          <img src="{{ 'info-diamond-ef.jpg' | asset_url }}" alt="EF quality" loading="lazy" width="100" height="100">
          <figcaption>EF</figcaption>
        </figure> {% endcomment %}
      </div>
    </div>

    <div class="pdp-sheet-section">
      <h4 class="pdp-sheet-label">Quantity</h4>
      <p class="pdp-sheet-desc">Quantity indicates the total number of Gemstones used in the jewelry.</p>
    </div>

    <div class="pdp-sheet-section">
      <h4 class="pdp-sheet-label">Carat</h4>
      <p class="pdp-sheet-desc">Carat (ct) is the standard unit of measurement used to indicate the weight of Gemstones used in the jewelry.</p>
    </div>

  </div>
</aside>


<!-- ── CSS ───────────────────────────────────────────────────── -->
<style>
  /* ── Overlay (covers only the area BESIDE the sheet) ─────── */
  .pdp-sheet-overlay {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    right: 400px;                        /* matches sheet max-width — leaves sheet area clear */
    width: auto;
    background: rgba(0, 0, 0, 0.45);
    z-index: 9998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .pdp-sheet-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  /* ── Side sheet ──────────────────────────────────────────── */
  .pdp-info-sheet {
    position: fixed;
    top: 0;
    right: 0;
    width: 100%;
    max-width: 500px;
    height: 100%;
    background: #fff;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.12);
    font-family: 'Futura Std', sans-serif;  /* ← applied here, cascades to all children */
  }
  .pdp-info-sheet:not([hidden]) {
    display: flex;
  }
  .pdp-info-sheet.is-open {
    transform: translateX(0);
  }

  /* ── Header ──────────────────────────────────────────────── */
  .pdp-sheet-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    border-bottom: 1px solid #e8e8e8;
    flex-shrink: 0;
  }
  .pdp-sheet-title {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 1.4px;
    color: #1a1a1a;
    font-family: 'Futura Std', sans-serif;
  }
  .pdp-sheet-close {
    background: none;
    border: none;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    color: #666;
    padding: 0 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    transition: background 0.2s;
    font-family: 'Futura Std', sans-serif;
  }
  .pdp-sheet-close:hover {
    background: #f2f2f2;
    color: #1a1a1a;
  }

  /* ── Scrollable body ─────────────────────────────────────── */
  .pdp-sheet-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    -webkit-overflow-scrolling: touch;
  }

  /* ── Section ─────────────────────────────────────────────── */
  .pdp-sheet-section {
    margin-bottom: 28px;
  }
  .pdp-sheet-section:last-child {
    margin-bottom: 0;
  }

  /* ── Section label ───────────────────────────────────────── */
  .pdp-sheet-label {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 1.2px;
    text-transform: capitalize;
    color: #1a1a1a;
    margin: 0 0 14px;
    {% comment %} padding-bottom: 8px; {% endcomment %}
    {% comment %} border-bottom: 1px solid #efefef; {% endcomment %}
    font-family: 'Futura Std', sans-serif;
  }

  /* ── Description text ────────────────────────────────────── */
  .pdp-sheet-desc {
    font-size: 13px;
    color: #666;
    line-height: 1.6;
    margin: 0;
    font-family: 'Futura Std', sans-serif;
  }

  /* ── Image row (up to 3 items) ───────────────────────────── */
  .pdp-sheet-image-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .pdp-sheet-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex: 1 1 0;
    min-width: 80px;
  }
  .pdp-sheet-fig img {
    width: 100%;
    {% comment %} max-width: 100px; %} {% endcomment %}
    height: auto;
    object-fit: contain;
    border-radius: 6px;
    border: 1px solid #f0f0f0;
    background: #fafafa;
    padding: 6px;
  }
  .pdp-sheet-fig figcaption {
    font-size: 12px;
    color: #444;
    text-align: center;
    line-height: 1.4;
    font-family: 'Futura Std', sans-serif;
  }
  .pdp-sheet-fig figcaption small {
    color: #888;
    font-size: 11px;
    font-family: 'Futura Std', sans-serif;
  }

  /* ── 4-col grid (shapes / gemstone colors) ───────────────── */
  .pdp-sheet-image-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  .pdp-sheet-grid-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
  }
  .pdp-sheet-grid-fig img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: contain;
    border-radius: 6px;
    border: 1px solid #f0f0f0;
    background: #fafafa;
    padding: 4px;
  }
  .pdp-sheet-grid-fig figcaption {
    font-size: 11px;
    color: #555;
    text-align: center;
    font-family: 'Futura Std', sans-serif;
  }

  /* ── Dimension 2-col ─────────────────────────────────────── */
  .pdp-sheet-dim-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .pdp-sheet-dim-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .pdp-sheet-dim-fig img {
    width: 100%;
    {% comment %} max-width: 140px; {% endcomment %}
    height: auto;
    object-fit: contain;
    border-radius: 6px;
    border: 1px solid #f0f0f0;
    background: #fafafa;
    padding: 8px;
  }
  .pdp-sheet-dim-fig figcaption {
    font-size: 12px;
    color: #444;
    text-align: center;
    line-height: 1.5;
    font-family: 'Futura Std', sans-serif;
  }
  .pdp-sheet-dim-fig figcaption strong {
    display: block;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 4px;
    color: #1a1a1a;
    font-family: 'Futura Std', sans-serif;
  }
  .pdp-sheet-dim-fig figcaption p {
    margin: 0;
    color: #666;
    font-size: 11.5px;
    font-family: 'Futura Std', sans-serif;
  }

  /* ── i trigger button ────────────────────────────────────── */
  .pdp-info-trigger {
        display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
  }
  .pdp-info-trigger:hover {
    border-color: #1a1a1a;
    color: #1a1a1a;
  }
  .pdp-info-trigger svg {
    display: block;
  }

  /* ── Mobile ──────────────────────────────────────────────── */
  @media (max-width: 480px) {
    /* Sheet goes full width, overlay has nothing to show beside it */
    .pdp-info-sheet  { max-width: 100%; }
    .pdp-sheet-overlay { right: 100vw; }  /* effectively hidden on mobile */
    .pdp-sheet-image-grid { grid-template-columns: repeat(4, 1fr); gap: 8px; }

  }
  @media (max-width: 768px)
  {
  .pdp-info-sheet.is-open {z-index: 9999999999;}
  }
</style>


<!-- ── JS ────────────────────────────────────────────────────── -->
<script>
(function () {
  'use strict';

  const overlay  = document.getElementById('pdp-sheet-overlay');
  let activeSheet = null;

  function openSheet(sheetId) {
    const sheet = document.getElementById('pdp-sheet-' + sheetId);
    if (!sheet) return;

    // close any open sheet first (no animation needed)
    if (activeSheet && activeSheet !== sheet) {
      activeSheet.classList.remove('is-open');
      activeSheet.setAttribute('hidden', '');
    }

    sheet.removeAttribute('hidden');
    // force reflow so transition fires
    sheet.getBoundingClientRect();
    sheet.classList.add('is-open');
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    activeSheet = sheet;

    // Move focus to close button for a11y
    const closeBtn = sheet.querySelector('.pdp-sheet-close');
    if (closeBtn) closeBtn.focus();
  }

  function closeSheet() {
    if (!activeSheet) return;
    activeSheet.classList.remove('is-open');
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';

    const closing = activeSheet;
    activeSheet = null;

    // Hide after transition completes
    closing.addEventListener('transitionend', function handler() {
      closing.setAttribute('hidden', '');
      closing.removeEventListener('transitionend', handler);
    });
  }

  // Delegate: trigger buttons
  document.addEventListener('click', function (e) {
    const trigger = e.target.closest('.pdp-info-trigger[data-sheet]');
    if (trigger) {
      openSheet(trigger.dataset.sheet);
      return;
    }

    const closeBtn = e.target.closest('.pdp-sheet-close[data-sheet]');
    if (closeBtn) {
      closeSheet();
      return;
    }

    // Clicking overlay closes
    if (e.target === overlay) {
      closeSheet();
    }
  });

  // ESC key
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && activeSheet) closeSheet();
  });
})();
</script>