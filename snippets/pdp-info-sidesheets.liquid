<style>
  .pdp-sheet-overlay {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    right: 400px;                       
    width: auto;
    background: rgba(0, 0, 0, 0.45);
    z-index: 9998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .pdp-sheet-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .pdp-info-sheet {
    position: fixed;
    top: 0;
    right: 0;
    width: 100%;
    max-width: 500px;
    height: 100%;
    background: #fff;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.12);
    font-family: 'Futura Std', sans-serif;  
  }
  .pdp-info-sheet:not([hidden]) {
    display: flex;
  }
  .pdp-info-sheet.is-open {
    transform: translateX(0);
  }

  .pdp-sheet-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    border-bottom: 1px solid #e8e8e8;
    flex-shrink: 0;
  }
  .pdp-sheet-title {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 1.4px;
    color: #1a1a1a;
    font-family: 'Futura Std', sans-serif;
  }
  .pdp-sheet-close {
    background: none;
    border: none;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    color: #666;
    padding: 0 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    transition: background 0.2s;
    font-family: 'Futura Std', sans-serif;
  }
  .pdp-sheet-close:hover {
    background: #f2f2f2;
    color: #1a1a1a;
  }

  .pdp-sheet-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    -webkit-overflow-scrolling: touch;
  }

  .pdp-sheet-section {
    margin-bottom: 28px;
  }
  .pdp-sheet-section:last-child {
    margin-bottom: 0;
  }

  .pdp-sheet-label {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 1.2px;
    text-transform: capitalize;
    color: #1a1a1a;
    margin: 0 0 14px;
    font-family: 'Futura Std', sans-serif;
  }

  .pdp-sheet-desc {
    font-size: 13px;
    color: #666;
    line-height: 1.6;
    margin: 0;
    font-family: 'Futura Std', sans-serif;
  }

  .pdp-sheet-image-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .pdp-sheet-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex: 1 1 0;
    min-width: 80px;
  }
  .pdp-sheet-fig img {
    width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: 6px;
    border: 1px solid #f0f0f0;
    background: #fafafa;
    padding: 6px;
  }
  .pdp-sheet-fig figcaption {
    font-size: 12px;
    color: #444;
    text-align: center;
    line-height: 1.4;
    font-family: 'Futura Std', sans-serif;
  }
  .pdp-sheet-fig figcaption small {
    color: #888;
    font-size: 11px;
    font-family: 'Futura Std', sans-serif;
  }

  .pdp-sheet-image-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  .pdp-sheet-grid-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
  }
  .pdp-sheet-grid-fig img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: contain;
    border-radius: 6px;
    border: 1px solid #f0f0f0;
    background: #fafafa;
    padding: 4px;
  }
  .pdp-sheet-grid-fig figcaption {
    font-size: 11px;
    color: #555;
    text-align: center;
    font-family: 'Futura Std', sans-serif;
  }

  .pdp-sheet-dim-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .pdp-sheet-dim-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .pdp-sheet-dim-fig img {
    width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: 6px;
    border: 1px solid #f0f0f0;
    background: #fafafa;
    padding: 8px;
  }
  .pdp-sheet-dim-fig figcaption {
    font-size: 12px;
    color: #444;
    text-align: center;
    line-height: 1.5;
    font-family: 'Futura Std', sans-serif;
  }
  .pdp-sheet-dim-fig figcaption strong {
    display: block;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 4px;
    color: #1a1a1a;
    font-family: 'Futura Std', sans-serif;
  }
  .pdp-sheet-dim-fig figcaption p {
    margin: 0;
    color: #666;
    font-size: 11.5px;
    font-family: 'Futura Std', sans-serif;
  }

  .pdp-info-trigger {
        display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
  }
  .pdp-info-trigger:hover {
    border-color: #1a1a1a;
    color: #1a1a1a;
  }
  .pdp-info-trigger svg {
    display: block;
  }

  @media (max-width: 480px) {
    .pdp-info-sheet  { max-width: 100%; }
    .pdp-sheet-overlay { right: 100vw; }  
    .pdp-sheet-image-grid { grid-template-columns: repeat(4, 1fr); gap: 8px; }

  }
  @media (max-width: 768px)
  {
  .pdp-info-sheet.is-open {z-index: 9999999999;}
  }
</style>


<script>
(function () {
  'use strict';

  const overlay  = document.getElementById('pdp-sheet-overlay');
  let activeSheet = null;

  function openSheet(sheetId) {
    const sheet = document.getElementById('pdp-sheet-' + sheetId);
    if (!sheet) return;

    if (activeSheet && activeSheet !== sheet) {
      activeSheet.classList.remove('is-open');
      activeSheet.setAttribute('hidden', '');
    }

    sheet.removeAttribute('hidden');
    sheet.getBoundingClientRect();
    sheet.classList.add('is-open');
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    activeSheet = sheet;

    const closeBtn = sheet.querySelector('.pdp-sheet-close');
    if (closeBtn) closeBtn.focus();
  }

  function closeSheet() {
    if (!activeSheet) return;
    activeSheet.classList.remove('is-open');
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';

    const closing = activeSheet;
    activeSheet = null;

    closing.addEventListener('transitionend', function handler() {
      closing.setAttribute('hidden', '');
      closing.removeEventListener('transitionend', handler);
    });
  }

  document.addEventListener('click', function (e) {
    const trigger = e.target.closest('.pdp-info-trigger[data-sheet]');
    if (trigger) {
      openSheet(trigger.dataset.sheet);
      return;
    }

    const closeBtn = e.target.closest('.pdp-sheet-close[data-sheet]');
    if (closeBtn) {
      closeSheet();
      return;
    }

    if (e.target === overlay) {
      closeSheet();
    }
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && activeSheet) closeSheet();
  });
})();
</script>