  class RingVariantSelector {
    constructor() {
      this.sectionId = '{{ section.id }}';
      this.productUrl = window.location.pathname;
      this.selectedOptionValues = [];
      this.init();
    }

    init() {
      document.addEventListener('DOMContentLoaded', () => {
        this.attachEventListeners();
        this.initializeSelectedValues();
      });
    }

    attachEventListeners() {
      const inputs = document.querySelectorAll('input[name^="Color"], input[name^="Size"]');
      inputs.forEach(input => {
        input.addEventListener('change', (e) => this.handleOptionChange(e));
      });
    }

    initializeSelectedValues() {
      const checked = document.querySelectorAll('input[type="radio"]:checked');
      checked.forEach(input => {
        this.selectedOptionValues.push(input.dataset.optionValueId);
      });
    }

    handleOptionChange(event) {
      const optionValueId = event.target.dataset.optionValueId;
      const optionName = event.target.name;

      // Update selected values array
      const index = this.selectedOptionValues.findIndex(id => {
        const input = document.querySelector(`input[data-option-value-id="${id}"]`);
        return input && input.name === optionName;
      });

      if (index !== -1) {
        this.selectedOptionValues[index] = optionValueId;
      } else {
        this.selectedOptionValues.push(optionValueId);
      }

      // Fetch updated option picker with new availability state
      this.fetchUpdatedOptions();
    }

    fetchUpdatedOptions() {
      const params = new URLSearchParams();
      params.append('section_id', this.sectionId);
      
      if (this.selectedOptionValues.length > 0) {
        params.append('option_values', this.selectedOptionValues.join(','));
      }

      const fetchUrl = `${this.productUrl}?${params.toString()}`;

      fetch(fetchUrl)
        .then(response => response.text())
        .then(html => this.updateOptionPicker(html))
        .catch(error => console.error('Variant fetch error:', error));
    }

    updateOptionPicker(html) {
      const parser = new DOMParser();
      const newDoc = parser.parseFromString(html, 'text/html');
      
      // Find the variant wrapper in the new response
      const newOptions = newDoc.querySelector(
        `[data-section="${this.sectionId}"]`
      );

      if (newOptions) {
        const currentOptions = document.querySelector(
          `[data-section="${this.sectionId}"]`
        );
        
        if (currentOptions) {
          // Replace with updated options (availability recalculated by server)
          currentOptions.innerHTML = newOptions.innerHTML;
          
          // Re-attach listeners to new elements
          this.attachEventListeners();
          
          // Re-initialize selected values
          this.initializeSelectedValues();
          
          // Apply text normalization
          this.normalizeVariantText();
        }
      }
    }

    normalizeVariantText(root = document) {
      const walker = document.createTreeWalker(
        root,
        NodeFilter.SHOW_TEXT,
        null,
        false
      );

      let node;
      while ((node = walker.nextNode())) {
        let t = node.nodeValue;
        t = t.replace(/\b0(\d+KT)\b/g, '$1');
        node.nodeValue = t;
      }
    }
  }

  // Initialize variant selector
  new RingVariantSelector();

  /**
   * TEXT NORMALIZATION: 09KT → 9KT
   */
  (function () {
    function normalizeVariantText(root = document) {
      const walker = document.createTreeWalker(
        root,
        NodeFilter.SHOW_TEXT,
        null,
        false
      );

      let node;
      while ((node = walker.nextNode())) {
        let t = node.nodeValue;
        t = t.replace(/\b0(\d+KT)\b/g, '$1');
        node.nodeValue = t;
      }
    }

    document.addEventListener('DOMContentLoaded', function () {
      normalizeVariantText(document.body);
    });

    document.addEventListener('click', function (e) {
      if (e.target.closest('#product_variant_drawer')) {
        setTimeout(function () {
          const drawer = document.getElementById('variant-drawer');
          if (drawer) normalizeVariantText(drawer);
        }, 0);
      }
    });

    const observer = new MutationObserver(function (mutations) {
      mutations.forEach(function (mutation) {
        mutation.addedNodes.forEach(function (node) {
          if (node.nodeType === 1 && node.closest && node.closest('#variant-drawer')) {
            normalizeVariantText(node);
          }
        });
      });
    });

    observer.observe(document.body, {
      childList: true,
      subtree: true
    });
  })();
</script>