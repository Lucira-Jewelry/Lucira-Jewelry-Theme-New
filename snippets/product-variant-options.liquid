{% comment %}
  Renders product variant options

  Accepts:
  - product: {Object} product object.
  - option: {Object} current product_option object.
  - block: {Object} block object.
  - picker_type: {String} type of picker to dispay


  Usage:
  {% render 'product-variant-options',
    product: product,
    option: option,
    block: block
    picker_type: picker_type
  %}
{% endcomment %}
{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
-%}

{%- if option.name == 'Size' -%}
  {%- assign sorted_values = option.values | sort -%}
{%- else -%}
  {%- assign sorted_values = option.values -%}
{%- endif -%}

{%- for value in sorted_values -%}
  {%- liquid
    assign swatch_focal_point = null
    if value.swatch.image
      assign image_url = value.swatch.image | image_url: width: 50
      assign swatch_value = 'url(' | append: image_url | append: ')'
      assign swatch_focal_point = value.swatch.image.presentation.focal_point
    elsif value.swatch.color
      assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
    else
      assign swatch_value = null
    endif

    assign option_disabled = true
    if value.available
      assign option_disabled = false
    endif
  -%}

  {%- capture input_id -%}
    {{ section.id }}-{{ option.position }}-{{ forloop.index0 -}}
  {%- endcapture -%}

  {%- capture input_name -%}
    {{ option.name }}-{{ option.position }}
  {%- endcapture -%}

  {%- capture input_dataset -%}
    data-product-url="{{ value.product_url }}"
    data-option-value-id="{{ value.id }}"
  {%- endcapture -%}

  {%- capture label_unavailable -%}
    <span class="visually-hidden label-unavailable">
      {{- 'products.product.variant_sold_out_or_unavailable' | t -}}
    </span>
  {%- endcapture -%}

  {%- assign is_default_selected = false -%}
  {%- if value == '12' and option.selected_value == blank -%}
    {%- assign is_default_selected = true -%}
  {%- endif -%}

  {%- if picker_type == 'swatch' -%}
    {%- capture help_text -%}
      <span class="visually-hidden">{{ value | escape }}</span>
      {{ label_unavailable }}
    {%- endcapture -%}
    {%
      render 'swatch-input',
      id: input_id,
      name: input_name,
      value: value | escape,
      swatch: value.swatch,
      product_form_id: product_form_id,
      checked: value.selected or is_default_selected,
      visually_disabled: option_disabled,
      shape: block.settings.swatch_shape,
      help_text: help_text,
      additional_props: input_dataset
    %}
  {%- elsif picker_type == 'button' -%}
    <input
      type="radio"
      id="{{ input_id }}"
      name="{{ input_name | escape }}"
      value="{{ value | escape }}"
      form="{{ product_form_id }}"
      {% if value.selected %}
        checked
      {% endif %}
      {% if option_disabled %}
        class="disabled"
      {% endif %}
      {{ input_dataset }}
    >

    <label for="{{ input_id }}" class="variant-label">
      {%- assign v = value | downcase -%}

      {%- if v contains 'yellow' or v contains 'rose' or v contains 'white' or v contains 'silver' -%}
        <span class="variant-swatch" aria-hidden="true">
          {%- if v contains 'yellow' -%}
            {{- 'yellow-color.svg' | inline_asset_content -}}
          {%- elsif v contains 'rose' or v contains 'rose gold' -%}
            {{- 'rose-color.svg' | inline_asset_content -}}
          {%- elsif v contains 'white' or v contains 'silver' or v contains 'white gold' -%}
            {{- 'silver-color.svg' | inline_asset_content -}}
          {%- endif -%}
        </span>
      {%- endif -%}

      {%- if option.name == 'Color' -%}
        {% assign color_in_stock = false %}
        {% for variant in product.variants %}
          {% if variant.option1 == value and variant.available and variant.inventory_quantity > 0 %}
            {% assign color_in_stock = true %}
            {% break %}
          {% endif %}
        {% endfor %}

        <span class="variant-text">
          {%- assign parts = value | split: ' ' -%}
          <span class="variant-karat">{{ parts[0] }}</span>
          {{ parts[1] }}
          {{ parts[2] }}
          <span class="Variant_Stock_Status">
            {% if color_in_stock %}
              <span class="stock-active">In Stock</span>
            {% else %}
              Make to Order
            {% endif %}
          </span>
          {{ label_unavailable }}
        </span>

      {%- elsif option.name == 'Size' -%}
        <span class="variant-text" style="display: inline-block !important;" data-size-value="{{ value }}">
          {{ value }}
          <span class="Variant_Stock_Status" data-size-stock="{{ value }}">
            {%- comment -%}Stock status will be updated dynamically{%- endcomment -%}
          </span>
          {{ label_unavailable }}
        </span>

      {%- else -%}
        <span class="variant-text">
          {{ value }}
          {{ label_unavailable }}
        </span>
      {%- endif -%}
    </label>

  {%- elsif picker_type == 'dropdown' or picker_type == 'swatch_dropdown' -%}
    <option
      id="{{ input_id }}"
      value="{{ value | escape }}"
      {% if value.selected %}
        selected="selected"
      {% endif %}
      {% if swatch_value and picker_type == 'swatch_dropdown' %}
        data-option-swatch-value="{{ swatch_value }}"
        {% if swatch_focal_point %}
          data-option-swatch-focal-point="{{ swatch_focal_point }}"
        {% endif %}
      {% endif %}
      {{ input_dataset }}
    >
      {% if option_disabled -%}
        {{- 'products.product.value_unavailable' | t: option_value: value -}}
      {%- else -%}
        {{- value -}}
      {%- endif %}
    </option>
  {%- endif -%}
{%- endfor -%}

{%- comment -%}Add variant data for JavaScript{%- endcomment -%}
<script type="application/json" id="variant-stock-data-{{ section.id }}">
  {
    "variants": [
      {%- for variant in product.variants -%}
        {
          "option1": {{ variant.option1 | json }},
          "option2": {{ variant.option2 | json }},
          "available": {{ variant.available | json }},
          "inventory_quantity": {{ variant.inventory_quantity | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
</script>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const variantData = JSON.parse(document.getElementById('variant-stock-data-' + sectionId).textContent);
  
  function updateSizeStockStatus(selectedColor) {
    document.querySelectorAll('[data-size-stock]').forEach(function(stockEl) {
      const sizeValue = stockEl.getAttribute('data-size-stock');
      
      // Find matching variant
      const matchingVariant = variantData.variants.find(function(v) {
        return v.option1 === selectedColor && v.option2 === sizeValue;
      });
      
      // Update stock status
      if (matchingVariant && matchingVariant.available && matchingVariant.inventory_quantity > 0) {
        stockEl.innerHTML = '<span class="stock-active">In Stock</span>';
      } else {
        stockEl.innerHTML = '';
      }
    });
  }
  
  // Listen for color changes
  document.querySelectorAll('input[name="Color-1"]').forEach(function(input) {
    input.addEventListener('change', function() {
      if (this.checked) {
        updateSizeStockStatus(this.value);
      }
    });
  });
  
  // Initialize on page load
  const checkedColor = document.querySelector('input[name="Color-1"]:checked');
  if (checkedColor) {
    updateSizeStockStatus(checkedColor.value);
  }
})();
</script>