{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
-%}

{%- if option.name == 'Size' -%}
  {%- assign sorted_values = option.values | sort -%}
{%- else -%}
  {%- assign sorted_values = option.values -%}
{%- endif -%}

{%- for value in sorted_values -%}
  {%- liquid
    assign swatch_focal_point = null
    if value.swatch.image
      assign image_url = value.swatch.image | image_url: width: 50
      assign swatch_value = 'url(' | append: image_url | append: ')'
      assign swatch_focal_point = value.swatch.image.presentation.focal_point
    elsif value.swatch.color
      assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
    else
      assign swatch_value = null
    endif

    assign option_disabled = true
    if value.available
      assign option_disabled = false
    endif
  -%}

  {%- capture input_id -%}
    {{ section.id }}-{{ option.position }}-{{ forloop.index0 -}}
  {%- endcapture -%}

  {%- capture input_name -%}
    {{ option.name }}-{{ option.position }}
  {%- endcapture -%}

  {%- capture input_dataset -%}
    data-product-url="{{ value.product_url }}"
    data-option-value-id="{{ value.id }}"
  {%- endcapture -%}

  {%- capture label_unavailable -%}
    <span class="visually-hidden label-unavailable">
      {{- 'products.product.variant_sold_out_or_unavailable' | t -}}
    </span>
  {%- endcapture -%}

  {%- assign is_default_selected = false -%}
  {%- if value == '12' and option.selected_value == blank -%}
    {%- assign is_default_selected = true -%}
  {%- endif -%}

  {%- if picker_type == 'swatch' -%}
    {%- capture help_text -%}
      <span class="visually-hidden">{{ value | escape }}</span>
      {{ label_unavailable }}
    {%- endcapture -%}
    {%
      render 'swatch-input',
      id: input_id,
      name: input_name,
      value: value | escape,
      swatch: value.swatch,
      product_form_id: product_form_id,
      checked: value.selected or is_default_selected,
      visually_disabled: option_disabled,
      shape: block.settings.swatch_shape,
      help_text: help_text,
      additional_props: input_dataset
    %}
  {%- elsif picker_type == 'button' -%}
    <input
      type="radio"
      id="{{ input_id }}"
      name="{{ input_name | escape }}"
      value="{{ value | escape }}"
      form="{{ product_form_id }}"
      {% if value.selected or is_default_selected %}
        checked
      {% endif %}
      {% if option_disabled %}
        class="disabled"
      {% endif %}
      {{ input_dataset }}
      data-option-index="{{ option.position }}"
      data-option-value="{{ value | escape }}"
    >

    {%- if option.name == 'Color' -%}
      {% comment %} Color options - we'll handle stock status via JavaScript {% endcomment %}
      <label for="{{ input_id }}" class="variant-product brad-sm Label-{{ value | handle }}" style="width: 30%;">
        <span class="Variant_Product_color">
          {%- assign v = value | downcase -%}
          {%- if v contains 'yellow' -%}
            <span class="Variant_Color_Icon">{{ 'yellow-color.svg' | inline_asset_content }}</span>
          {%- elsif v contains 'rose' or v contains 'rose gold' -%}
            <span class="Variant_Color_Icon">{{ 'rose-color.svg' | inline_asset_content }}</span>
          {%- elsif v contains 'white' or v contains 'silver' or v contains 'white gold' -%}
            <span class="Variant_Color_Icon">{{ 'silver-color.svg' | inline_asset_content }}</span>
          {%- else -%}
            <span style="display:inline-block;width:34px;height:34px;border-radius:50%;background-color:#ccc;margin-right:6px;border:3px solid #fff;box-shadow:0 .3rem .3rem #0000001a;box-sizing:border-box;"></span>
          {%- endif -%}
        </span>

        <span class="Variant_Product_name">
          {%- assign parts = value | split: ' ' -%}
          <span class="variant-karat">{{ parts[0] }}</span>
          {{ parts[1] }}
          {{ parts[2] }}
        </span>

        <span class="Variant_Stock_Status" data-color-value="{{ value | escape }}">
          {% comment %} Stock status will be updated by JavaScript {% endcomment %}
          Loading...
        </span>
        {{ label_unavailable }}
      </label>

    {%- elsif option.name == 'Size' -%}
      {% comment %} Size options - stock status depends on selected color {% endcomment %}
      <label for="{{ input_id }}" class="variant-product brad-sm brad-sm-size Label-{{ value | handle }}" style="width: 31%; justify-content:center; align-items:center;">
        <span class="Variant_Product_size_name">{{ value }}</span>
        
        <span class="Variant_Stock_Status" data-size-value="{{ value | escape }}">
          {% comment %} Stock status will be updated by JavaScript {% endcomment %}
          Loading...
        </span>
        {{ label_unavailable }}
      </label>

    {%- else -%}
      <label for="{{ input_id }}" class="variant-label">
        <span class="variant-text">
          {{ value }}
          {{ label_unavailable }}
        </span>
      </label>
    {%- endif -%}

  {%- elsif picker_type == 'dropdown' or picker_type == 'swatch_dropdown' -%}
    <option
      id="{{ input_id }}"
      value="{{ value | escape }}"
      {% if value.selected or is_default_selected %}
        selected="selected"
      {% endif %}
      {% if swatch_value and picker_type == 'swatch_dropdown' %}
        data-option-swatch-value="{{ swatch_value }}"
        {% if swatch_focal_point %}
          data-option-swatch-focal-point="{{ swatch_focal_point }}"
        {% endif %}
      {% endif %}
      {{ input_dataset }}
    >
      {% if option_disabled -%}
        {{- 'products.product.value_unavailable' | t: option_value: value -}}
      {%- else -%}
        {{- value -}}
      {%- endif %}
    </option>
  {%- endif -%}
{%- endfor -%}

<style>
  .product .product-form__input--pill input[type=radio]:checked+label {
    background-color: #ffffff !important; 
    color: #000 !important; 
    border: 2px solid #AB8A87 !important; 
    transition: .3s;
  }
  .product .product-form__input--pill input[type=radio]+label {
    padding: .5rem .5rem;
    height: 100px;
    font-weight: 500;
    border: .5px solid #cfcfcf;
    background-color: #fff !important;
    margin: 0;
  }
  span.Variant_Color_Icon {
    display: inline-block;
  }
  .Variant_Product_name {
    gap: 6px;
  }
  .product .product-form__input--pill input[type=radio]+label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    position: relative;
  }
  .Variant_Product_size_name {
    font-size: 16px;
    font-weight: 600;
    text-align: center;
    justify-content: center;
  }
  .brad-sm-size {
    max-height: 60px;
  }
  span.Variant_Stock_Status {
    position: absolute;
    bottom: -9px;
    background: #fff !important;
    padding: 4px 10px;
    font-size: 10px;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
  }
  span.Variant_Stock_Status .stock-active {
    color: #008000;
  }
  span.Variant_Stock_Status .stock-make-to-order {
    color: #666;
  }
</style>

<script>
// Update stock status for all options when variant changes
function updateStockStatuses() {
  const selectedColor = getSelectedColor();
  updateColorStockStatuses();
  updateSizeStockStatuses(selectedColor);
  removeLeadingZeros();
}

// Update color stock statuses
function updateColorStockStatuses() {
  const colorStatusElements = document.querySelectorAll('[data-color-value]');
  
  colorStatusElements.forEach(element => {
    const colorValue = element.getAttribute('data-color-value');
    const isInStock = checkColorStockStatus(colorValue);
    
    if (isInStock) {
      element.innerHTML = '<span class="stock-active">In Stock</span>';
    } else {
      element.innerHTML = 'Make to Order';
    }
  });
}

// Update size stock statuses based on selected color
function updateSizeStockStatuses(selectedColor) {
  const sizeStatusElements = document.querySelectorAll('[data-size-value]');
  
  sizeStatusElements.forEach(element => {
    const sizeValue = element.getAttribute('data-size-value');
    const isInStock = checkSizeStockStatus(selectedColor, sizeValue);
    
    if (isInStock) {
      element.innerHTML = '<span class="stock-active">In Stock</span>';
    } else {
      element.innerHTML = 'Make to Order';
    }
  });
}

// Check if a color is in stock
function checkColorStockStatus(colorValue) {
  const variants = {{ product.variants | json }};
  
  for (const variant of variants) {
    if (variant.option1 === colorValue && variant.available && variant.inventory_quantity > 0) {
      return true;
    }
  }
  return false;
}

// Check if a size is in stock for the selected color
function checkSizeStockStatus(selectedColor, sizeValue) {
  const variants = {{ product.variants | json }};
  
  for (const variant of variants) {
    if (variant.option1 === selectedColor && variant.option2 === sizeValue) {
      return variant.available && variant.inventory_quantity > 0;
    }
  }
  return false;
}

// Get currently selected color
function getSelectedColor() {
  const colorInputs = document.querySelectorAll('input[name^="Color"], input[name^="color"]');
  for (const input of colorInputs) {
    if (input.checked) {
      return input.value;
    }
  }
  
  // Fallback to first available color
  const firstColorInput = document.querySelector('input[name^="Color"], input[name^="color"]');
  return firstColorInput ? firstColorInput.value : '';
}

// Remove leading zeros from size labels
function removeLeadingZeros() {
  const sizeLabels = document.querySelectorAll('.Variant_Product_size_name');
  sizeLabels.forEach(label => {
    const currentText = label.textContent.trim();
    if (/^0\d+$/.test(currentText)) {
      label.textContent = currentText.replace(/^0+/, '');
    }
  });
}

// Initialize and set up event listeners
document.addEventListener('DOMContentLoaded', function() {
  // Initial update
  updateStockStatuses();
  
  // Update when variant changes
  document.addEventListener('variant:change', updateStockStatuses);
  
  // Update when color/size inputs are clicked
  const variantInputs = document.querySelectorAll('input[type="radio"][name*="Color"], input[type="radio"][name*="color"], input[type="radio"][name*="Size"], input[type="radio"][name*="size"]');
  variantInputs.forEach(input => {
    input.addEventListener('change', function() {
      setTimeout(updateStockStatuses, 50);
    });
  });
  
  // Set up observer for dynamic content
  const observer = new MutationObserver(function(mutations) {
    let shouldUpdate = false;
    mutations.forEach(function(mutation) {
      if (mutation.type === 'childList' || mutation.type === 'characterData') {
        shouldUpdate = true;
      }
    });
    if (shouldUpdate) {
      setTimeout(updateStockStatuses, 50);
    }
  });
  
  const productForm = document.querySelector('form[id*="product-form"], .product-form, .product__form');
  if (productForm) {
    observer.observe(productForm, {
      childList: true,
      subtree: true,
      characterData: true,
    });
  }
});

// Fallback interval check
setInterval(function() {
  const sizeLabels = document.querySelectorAll('.Variant_Product_size_name');
  let needsUpdate = false;
  sizeLabels.forEach(function(label) {
    if (/^0\d+$/.test(label.textContent.trim())) {
      needsUpdate = true;
    }
  });
  if (needsUpdate) {
    removeLeadingZeros();
  }
}, 500);
</script>