{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
-%}

{%- if option.name == 'Size' -%}
  {%- assign sorted_values = option.values | sort -%}
{%- else -%}
  {%- assign sorted_values = option.values -%}
{%- endif -%}

{%- for value in sorted_values -%}
  {%- liquid
    assign option_disabled = true
    if value.available
      assign option_disabled = false
    endif
  -%}

  {%- capture input_id -%}{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}{%- endcapture -%}
  {%- capture input_name -%}{{ option.name }}-{{ option.position }}{%- endcapture -%}

  {%- assign is_default_selected = false -%}
  {%- if value == '12' and option.selected_value == blank -%}
    {%- assign is_default_selected = true -%}
  {%- endif -%}

  <input type="radio"
         id="{{ input_id }}"
         name="{{ input_name }}"
         value="{{ value }}"
         form="{{ product_form_id }}"
         {% if value.selected or is_default_selected %}checked{% endif %}
         {% if option_disabled %}class="disabled"{% endif %}
  >

  <label for="{{ input_id }}" class="variant-label {% if option.name == 'Size' %}brad-sm-size{% endif %}">
    <span class="Variant_Product_size_name">{{ value }}</span>
    <span class="Variant_Stock_Status">
      {% assign selected_color = product.selected_or_first_available_variant.option1 %}
      {% assign current_variant = product.variants | where: 'option1', selected_color | where: 'option2', value | first %}
      {% if current_variant and current_variant.available and current_variant.inventory_quantity > 0 %}
        <span class="stock-active">In Stock</span>
      {% else %}
        Make to Order
      {% endif %}
    </span>
  </label>
{%- endfor -%}

<script>
window.productVariants = {{ product.variants | json }};

document.addEventListener('DOMContentLoaded', function () {
  function updateStockStatus() {
    const selectedOptions = {};

    document.querySelectorAll('input[type=radio]:checked').forEach(input => {
      const optionName = input.name.split('-')[0];
      selectedOptions[optionName] = input.value;
    });

    document.querySelectorAll('.variant-label').forEach(label => {
      const input = label.querySelector('input');
      if (!input) return;

      const value = input.value;
      const optionName = input.name.split('-')[0];

      let variantAvailable = false;
      window.productVariants.forEach(v => {
        const matches = Object.keys(selectedOptions).every(key => {
          if (key === 'Color') return v.option1 === selectedOptions[key];
          if (key === 'Size') return v.option2 === selectedOptions[key];
          return true;
        });
        if (matches && v.available && v.inventory_quantity > 0) variantAvailable = true;
      });

      const stockSpan = label.querySelector('.Variant_Stock_Status');
      if (stockSpan) {
        stockSpan.innerHTML = variantAvailable
          ? '<span class="stock-active">In Stock</span>'
          : 'Make to Order';
      }
    });
  }

  document.querySelectorAll('input[type=radio]').forEach(input => {
    input.addEventListener('change', updateStockStatus);
  });

  updateStockStatus(); // initial load
});
</script>
