{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
-%}

{%- if option.name == 'Size' -%}
  {%- assign sorted_values = option.values | sort -%}
{%- else -%}
  {%- assign sorted_values = option.values -%}
{%- endif -%}

{%- for value in sorted_values -%}
  {%- liquid
    assign swatch_focal_point = null
    if value.swatch.image
      assign image_url = value.swatch.image | image_url: width: 50
      assign swatch_value = 'url(' | append: image_url | append: ')'
      assign swatch_focal_point = value.swatch.image.presentation.focal_point
    elsif value.swatch.color
      assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
    else
      assign swatch_value = null
    endif

    assign option_disabled = true
    if value.available
      assign option_disabled = false
    endif
  -%}

  {%- capture input_id -%}
    {{ section.id }}-{{ option.position }}-{{ forloop.index0 -}}
  {%- endcapture -%}

  {%- capture input_name -%}
    {{ option.name }}-{{ option.position }}
  {%- endcapture -%}

  {%- capture input_dataset -%}
    data-product-url="{{ value.product_url }}"
    data-option-value-id="{{ value.id }}"
  {%- endcapture -%}

  {%- capture label_unavailable -%}
    <span class="visually-hidden label-unavailable">
      {{- 'products.product.variant_sold_out_or_unavailable' | t -}}
    </span>
  {%- endcapture -%}

  {%- assign is_default_selected = false -%}
  {%- if value == '12' and option.selected_value == blank -%}
    {%- assign is_default_selected = true -%}
  {%- endif -%}

  {%- if picker_type == 'swatch' -%}
    {%- capture help_text -%}
      <span class="visually-hidden">{{ value | escape }}</span>
      {{ label_unavailable }}
    {%- endcapture -%}
    {%
      render 'swatch-input',
      id: input_id,
      name: input_name,
      value: value | escape,
      swatch: value.swatch,
      product_form_id: product_form_id,
      checked: value.selected or is_default_selected,
      visually_disabled: option_disabled,
      shape: block.settings.swatch_shape,
      help_text: help_text,
      additional_props: input_dataset
    %}
  {%- elsif picker_type == 'button' -%}
    <input
      type="radio"
      id="{{ input_id }}"
      name="{{ input_name | escape }}"
      value="{{ value | escape }}"
      form="{{ product_form_id }}"
      {% if value.selected or is_default_selected %}
        checked
      {% endif %}
      {% if option_disabled %}
        class="disabled"
      {% endif %}
      {{ input_dataset }}
    >

    {% if option.name == 'Color' %}
      {% assign color_in_stock = false %}
      {% for v in product.variants %}
        {% if v.option1 == value and v.available and v.inventory_quantity > 0 %}
          {% assign color_in_stock = true %}
          {% break %}
        {% endif %}
      {% endfor %}

      <label
        class="variant-product brad-sm Label-{{ value | handle }}"
        for="{{ input_id }}"
        style="width: 30%;"
      >
        <!-- Swatch Image -->
        <span class="Variant_Product_color">
          {% if value contains 'Yellow Gold' %}
            <span class="Variant_Color_Icon">{{ 'yellow-color.svg' | inline_asset_content }}</span>
          {% elsif value contains 'Rose Gold' %}
            <span class="Variant_Color_Icon">{{ 'rose-color.svg' | inline_asset_content }}</span>
          {% elsif value contains 'White Gold' %}
            <span class="Variant_Color_Icon">{{ 'silver-color.svg' | inline_asset_content }}</span>
          {% else %}
            <span style="display:inline-block;width:34px;height:34px;border-radius:50%;background-color:#ccc;margin-right:6px;border:3px solid #fff;box-shadow:0 .3rem .3rem #0000001a;box-sizing:border-box;"></span>
          {% endif %}
        </span>

        <!-- Swatch Name -->
        <span class="Variant_Product_name">{{ value }}</span>

        <!-- Stock Status -->
        <span class="Variant_Stock_Status">
          {% if color_in_stock %}
            <span class="stock-active">In Stock</span>
          {% else %}
            Make to Order
          {% endif %}
        </span>
      </label>
    {% endif %}

    {% if option.name == 'Size' %}
    {% comment %}
      For size, check the currently selected color (option1) + this size (option2)
    {% endcomment %}
    {% assign selected_color = product.selected_or_first_available_variant.option1 %}
    {% assign current_variant = product.variants | where: 'option1', selected_color | where: 'option2', value | first %}

    <label
      class="variant-product brad-sm brad-sm-size Label-{{ value | handle }}"
      for="{{ input_id }}"
      style="width: 31%; justify-content:center; align-items:center;"
    >
      <!-- Swatch Name -->
      <span class="Variant_Product_size_name">{{ value }}</span>

      <!-- Stock Status -->
      <span class="Variant_Stock_Status" data-size-stock="{{ value }}">
        {% if current_variant and current_variant.available and current_variant.inventory_quantity > 0 %}
          <span class="stock-active">In Stock</span>
        {% else %}
          Make to Order
        {% endif %}
      </span>
    </label>
  {% endif %}

  {%- elsif picker_type == 'dropdown' or picker_type == 'swatch_dropdown' -%}
    <option
      id="{{ input_id }}"
      value="{{ value | escape }}"
      {% if value.selected %}
        selected="selected"
      {% endif %}
      {% if swatch_value and picker_type == 'swatch_dropdown' %}
        data-option-swatch-value="{{ swatch_value }}"
        {% if swatch_focal_point %}
          data-option-swatch-focal-point="{{ swatch_focal_point }}"
        {% endif %}
      {% endif %}
      {{ input_dataset }}
    >
      {% if option_disabled -%}
        {{- 'products.product.value_unavailable' | t: option_value: value -}}
      {%- else -%}
        {{- value -}}
      {%- endif %}
    </option>
  {%- endif -%}
{%- endfor -%}

{%- comment -%}Add variant data for JavaScript{%- endcomment -%}
<script type="application/json" id="variant-stock-data-{{ section.id }}">
  {
    "variants": [
      {%- for variant in product.variants -%}
        {
          "option1": {{ variant.option1 | json }},
          "option2": {{ variant.option2 | json }},
          "available": {{ variant.available | json }},
          "inventory_quantity": {{ variant.inventory_quantity | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
</script>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const variantData = JSON.parse(document.getElementById('variant-stock-data-' + sectionId).textContent);
  
  function updateSizeStockStatus(selectedColor) {
    document.querySelectorAll('[data-size-stock]').forEach(function(stockEl) {
      const sizeValue = stockEl.getAttribute('data-size-stock');
      
      // Find matching variant
      const matchingVariant = variantData.variants.find(function(v) {
        return v.option1 === selectedColor && v.option2 === sizeValue;
      });
      
      // Update stock status
      if (matchingVariant && matchingVariant.available && matchingVariant.inventory_quantity > 0) {
        stockEl.innerHTML = '<span class="stock-active">In Stock</span>';
      } else {
        stockEl.innerHTML = 'Make to Order';
      }
    });
  }
  
  // Listen for color changes
  document.querySelectorAll('input[name="Color-1"]').forEach(function(input) {
    input.addEventListener('change', function() {
      if (this.checked) {
        updateSizeStockStatus(this.value);
      }
    });
  });
  
  // Initialize on page load
  const checkedColor = document.querySelector('input[name="Color-1"]:checked');
  if (checkedColor) {
    updateSizeStockStatus(checkedColor.value);
  }
})();

  function removeLeadingZeros() {
    const sizeLabels = document.querySelectorAll('.Variant_Product_size_name');

    sizeLabels.forEach(function (label) {
      const currentText = label.textContent.trim();
      if (/^0\d+$/.test(currentText)) {
        const newText = currentText.replace(/^0+/, '');
        label.textContent = newText;
      }
    });

    const sizeDisplayElements = document.querySelectorAll('[class*="size"], [class*="Size"]');

    sizeDisplayElements.forEach(function (element) {
      if (element.textContent.includes('Size:') || element.textContent.includes('size:')) {
        const currentText = element.textContent;
        const updatedText = currentText.replace(/(\bsize:\s*)0(\d+)/gi, '$1$2');
        if (updatedText !== currentText) {
          element.textContent = updatedText;
        }
      }
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    removeLeadingZeros();

    const observer = new MutationObserver(function (mutations) {
      let shouldUpdate = false;

      mutations.forEach(function (mutation) {
        if (mutation.type === 'childList' || mutation.type === 'characterData') {
          shouldUpdate = true;
        }
      });

      if (shouldUpdate) {
        setTimeout(removeLeadingZeros, 50);
      }
    });

    const productForm = document.querySelector('form[id*="product-form"], .product-form, .product__form');
    if (productForm) {
      observer.observe(productForm, {
        childList: true,
        subtree: true,
        characterData: true,
      });
    } else {
      observer.observe(document.body, {
        childList: true,
        subtree: true,
        characterData: true,
      });
    }
  });

  document.addEventListener('variant:change', function () {
    setTimeout(removeLeadingZeros, 100);
  });

  document.addEventListener('shopify:section:load', function () {
    setTimeout(removeLeadingZeros, 100);
  });

  setInterval(function () {
    const sizeLabels = document.querySelectorAll('.Variant_Product_size_name');
    let needsUpdate = false;

    sizeLabels.forEach(function (label) {
      if (/^0\d+$/.test(label.textContent.trim())) {
        needsUpdate = true;
      }
    });
    if (needsUpdate) {
      removeLeadingZeros();
    }
  }, 500);
</script>