{%- else -%}
{{- value -}}
{%- endif %}
</option>
{%- endif -%}
{%- endfor -%}

<script>
(function() {
  'use strict';
  
  // ✅ Build variant stock data efficiently - only once
  const stockData = {};
  {% for v in product.variants %}
  const c{{ forloop.index }} = '{{ v.option1 | escape }}';
  const s{{ forloop.index }} = '{{ v.option2 | escape }}';
  stockData[c{{ forloop.index }}] = stockData[c{{ forloop.index }}] || {};
  stockData[c{{ forloop.index }}][s{{ forloop.index }}] = {
    a: {{ v.available | json }},
    i: {{ v.inventory_quantity | default: 0 | json }}
  };
  {% endfor %}
  
  window.variantStockData = stockData;
  window.productSectionId = '{{ section.id }}';

  // ✅ Cache DOM queries
  let sizeElements = null;
  let colorInputs = null;

  function updateSizeStockStatus(colorValue) {
    if (!sizeElements) {
      sizeElements = document.querySelectorAll('.Variant_Stock_Status[data-size]');
    }
    
    const colorStock = stockData[colorValue] || {};
    
    sizeElements.forEach(function(el) {
      const size = el.dataset.size;
      const stock = colorStock[size];
      
      if (stock && stock.a && stock.i > 0) {
        el.innerHTML = '<span class="stock-active">In Stock</span>';
      } else {
        el.innerHTML = '';
      }
    });
  }

  // ✅ Debounced fetch for Section Rendering API
  let fetchTimeout;
  function fetchUpdatedAvailability(optionValueElement) {
    if (!optionValueElement) return;
    
    clearTimeout(fetchTimeout);
    fetchTimeout = setTimeout(function() {
      const sectionId = window.productSectionId;
      const productUrl = optionValueElement.dataset.productUrl || window.location.pathname;
      
      if (!colorInputs) {
        colorInputs = document.querySelectorAll('input[type="radio"][data-option-value-id]');
      }
      
      const selectedIds = [];
      colorInputs.forEach(function(input) {
        if (input.checked && input.dataset.optionValueId) {
          selectedIds.push(input.dataset.optionValueId);
        }
      });

      const params = selectedIds.length ? '&option_values=' + selectedIds.join(',') : '';

      fetch(productUrl + '?section_id=' + sectionId + params)
        .then(function(res) { return res.text(); })
        .then(function(text) {
          const match = text.match(/const stockData = ({[\s\S]*?});/);
          if (match && match[1]) {
            try {
              const newData = JSON.parse(match[1]);
              Object.assign(stockData, newData);
            } catch (e) {
              console.warn('Parse error:', e);
            }
          }
          
          updateSizeStockStatus(optionValueElement.value);
          
          if (window.normalizeVariantText) {
            window.normalizeVariantText(document.body);
          }
        })
        .catch(function(err) {
          console.warn('Fetch error:', err);
          updateSizeStockStatus(optionValueElement.value);
        });
    }, 150);
  }

  // ✅ Efficient event delegation
  function handleColorChange(e) {
    const target = e.target;
    if (target.type === 'radio' && target.name.indexOf('Color') === 0) {
      if (target.dataset.optionValueId) {
        fetchUpdatedAvailability(target);
      } else {
        updateSizeStockStatus(target.value);
      }
    }
  }

  // ✅ Single DOMContentLoaded handler
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  function init() {
    const initialColor = '{{ product.selected_or_first_available_variant.option1 | escape }}';
    updateSizeStockStatus(initialColor);
    
    document.addEventListener('change', handleColorChange);
    
    document.addEventListener('variant:change', function(evt) {
      if (evt.detail && evt.detail.variant) {
        updateSizeStockStatus(evt.detail.variant.option1);
      }
    });
  }

  // ✅ TEXT NORMALIZATION - Optimized
  (function() {
    const textCache = new WeakMap();
    
    function normalizeVariantText(root) {
      if (!root) return;
      if (textCache.has(root)) return;
      
      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
      let node;
      
      while ((node = walker.nextNode())) {
        const original = node.nodeValue;
        const normalized = original.replace(/\b0(\d+KT)\b/g, '$1');
        if (original !== normalized) {
          node.nodeValue = normalized;
        }
      }
      
      textCache.set(root, true);
    }

    window.normalizeVariantText = normalizeVariantText;

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        normalizeVariantText(document.body);
      });
    } else {
      normalizeVariantText(document.body);
    }

    document.addEventListener('click', function(e) {
      if (e.target.closest('#product_variant_drawer')) {
        setTimeout(function() {
          const drawer = document.getElementById('variant-drawer');
          if (drawer) normalizeVariantText(drawer);
        }, 0);
      }
    });

    document.addEventListener('variant:change', function() {
      const drawer = document.getElementById('variant-drawer');
      if (drawer) {
        setTimeout(function() { normalizeVariantText(drawer); }, 0);
      }
    });

    // ✅ Optimized MutationObserver with throttling
    let observerTimeout;
    const observer = new MutationObserver(function(mutations) {
      clearTimeout(observerTimeout);
      observerTimeout = setTimeout(function() {
        mutations.forEach(function(mutation) {
          mutation.addedNodes.forEach(function(node) {
            if (node.nodeType === 1 && node.closest && node.closest('#variant-drawer')) {
              normalizeVariantText(node);
            }
          });
        });
      }, 100);
    });

    observer.observe(document.body, { childList: true, subtree: true });
  })();
})();
</script>