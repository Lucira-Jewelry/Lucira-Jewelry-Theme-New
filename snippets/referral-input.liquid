<div class="nector-referral-program-wrapper">
  <div class="grid-column">
    <div
      class="grid-card-wrapper"
    >
      <img
        src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/They_Get_img_2.png?v=1751354604"
        class="image-bg-left"
        alt="loyalty page left"
        title="loyalty page image left"
        width="auto"
        height="auto"
      >
      <p>They Get</p>
      <p class="coins-text">
        ₹1,000 Off<br>
        <span> on their 1st Order</span>
      </p>
    </div>
  </div>
  <div class="grid-column">
    <div
      class="grid-card-wrapper"
    >
      <img
        src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/7d93784d-d99f-4716-8c45-779b911938f6_2.png?v=1751352893"
        class="image-bg-right"
        alt="image-by-right"
        title="image-by-right"
        width="auto"
        height="auto"
      >
      <p>You Get</p>
      <p class="coins-text">
        2,000<br>
        <span>Lucira Coins</span>
      </p>
    </div>
  </div>
</div>
<div class="grid-row referal-row">
  {% if customer %}
    {% if customer.metafields.nector.custom_properties.value.nector_user_referral_link %}
      <div class="grid-column">
        <div class="referral-copy-wrapper">
          <p>Your Referral Link is Ready to Share with your friends</p>
          <div class="copy-link-container">
            <input
              type="text"
              id="referralLink"
              value="{{ customer.metafields.nector.custom_properties.value.nector_user_referral_link }}"
              readonly
            >
            <button class="copy-btn" onclick="copyLink()">Copy Link</button>
          </div>
        </div>
      </div>

      <div class="grid-column">
        <div class="or-text">OR</div>
      </div>

      <div class="grid-column">
        <div class="grid-social-icons">
          <a href="#" onclick="shareOnWhatsApp(); return false;">
            <img
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_427319185.png?v=1766570053"
              alt="whatsapp icon"
              title="whatsapp icon"
              width="72"
              height="72"
            >
          </a>
          <a href="#" onclick="shareOnInstagram(); return false;">
            <img
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_427322338.png?v=1766570052"
              alt="instagram icon"
              title="instagram icon"
              width="72"
              height="72"
            >
          </a>
          <a href="#" onclick="shareOnFacebook(); return false;">
            <img
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_427319188.png?v=1766570053"
              alt="facebook icon"
              title="facebook icon"
              width="72"
              height="72"
            >
          </a>
          <a href="#" onclick="shareOnLinkedIn(); return false;">
            <img
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_427319187.png?v=1766570053"
              alt="linkedin icon"
              title="linkedin icon"
              width="72"
              height="72"
            >
          </a>
        </div>
      </div>
    {% endif %}
  {% endif %}
</div>

<div class="referral-history-wrapper">

  <h3 class="referral-title">Referral & Transactional History</h3>

  <div class="referral-summary">
    <div>
      <span>TOTAL TRANSACTIONS:</span>
      <strong id="total-referrals">0</strong>
    </div>
    <div>
      <span>LUCIRA COINS EARNED:</span>
      <strong id="coins-earned">0</strong>
    </div>
    <div>
      <span>LUCIRA COINS BALANCE:</span>
      <strong id="coins-balance">0</strong>
    </div>
  </div>

  <table class="referral-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Date</th>
        <th>Status</th>
        <th>Reward</th>
      </tr>
    </thead>
    <tbody id="referral-history-body">
    </tbody>
  </table>

  {% if customer and customer.metafields.nector.custom_properties.value.nector_user_referral_link %}
    <div class="invite-btn-wrapper">
      <button class="invite-btn" onclick="shareReferralLink()">
        INVITE FRIENDS
      </button>

      <input
        type="text"
        id="referralLink"
        value="{{ customer.metafields.nector.custom_properties.value.nector_user_referral_link }}"
        readonly
        style="position:absolute; left:-9999px;"
      >
    </div>
  {% endif %}

</div>

{% if customer %}
  <script>
    (function () {
      const endpoint = "https://refer-earn-385594025448.asia-south1.run.app";
      const customerId = "shopify-{{ customer.id }}";

      fetch(`${endpoint}?customer_id=${encodeURIComponent(customerId)}`)
        .then(res => res.json())
        .then(data => {
          if (!data.status) return;

          document.getElementById('total-referrals').innerText =
            data.total_referrals;

          document.getElementById('coins-earned').innerText =
            data.coins_earned;

          document.getElementById('coins-balance').innerText =
            data.coins_balance;

          const tbody = document.getElementById('referral-history-body');
          tbody.innerHTML = '';

          data.history.forEach(row => {
            const tr = document.createElement('tr');

            const statusHtml =
              row.status === 'Earned'
                ? '<p class="status-earned"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"> <mask id="mask0_11564_5826" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="20" height="20"> <rect width="20" height="20" fill="#D9D9D9"/> </mask> <g mask="url(#mask0_11564_5826)"> <path d="M8.81733 13.5445L14.4198 7.94197L13.5417 7.06384L8.81733 11.7882L6.44233 9.41322L5.56421 10.2913L8.81733 13.5445ZM10.0015 17.9163C8.9065 17.9163 7.87726 17.7086 6.91379 17.293C5.95032 16.8775 5.11226 16.3135 4.39962 15.6011C3.68698 14.8888 3.12275 14.0511 2.70692 13.088C2.29122 12.125 2.08337 11.096 2.08337 10.0011C2.08337 8.90613 2.29115 7.8769 2.70671 6.91342C3.12226 5.94995 3.68622 5.1119 4.39858 4.39926C5.11094 3.68662 5.94865 3.12238 6.91171 2.70655C7.87476 2.29085 8.90372 2.08301 9.99858 2.08301C11.0936 2.08301 12.1228 2.29079 13.0863 2.70634C14.0498 3.1219 14.8878 3.68586 15.6005 4.39822C16.3131 5.11058 16.8773 5.94829 17.2932 6.91134C17.7089 7.8744 17.9167 8.90335 17.9167 9.99822C17.9167 11.0932 17.7089 12.1225 17.2934 13.0859C16.8778 14.0494 16.3139 14.8875 15.6015 15.6001C14.8891 16.3127 14.0514 16.877 13.0884 17.2928C12.1253 17.7085 11.0964 17.9163 10.0015 17.9163Z" fill="#00D26A"/> </g> </svg> <span class="desktop-show">Earned</span></p>'
                : '<p class="status-failed"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"> <mask id="mask0_11564_5835" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="20" height="20"> <rect width="20" height="20" fill="#D9D9D9"/> </mask> <g mask="url(#mask0_11564_5835)"> <path d="M7.00004 13.8778L10 10.8778L13 13.8778L13.8782 12.9997L10.8782 9.99967L13.8782 6.99967L13 6.12155L10 9.12155L7.00004 6.12155L6.12192 6.99967L9.12192 9.99967L6.12192 12.9997L7.00004 13.8778ZM10.0015 17.9163C8.9065 17.9163 7.87726 17.7086 6.91379 17.293C5.95032 16.8775 5.11226 16.3135 4.39962 15.6011C3.68698 14.8888 3.12275 14.0511 2.70692 13.088C2.29122 12.125 2.08337 11.096 2.08337 10.0011C2.08337 8.90613 2.29115 7.8769 2.70671 6.91342C3.12226 5.94995 3.68622 5.1119 4.39858 4.39926C5.11094 3.68662 5.94865 3.12238 6.91171 2.70655C7.87476 2.29085 8.90372 2.08301 9.99858 2.08301C11.0936 2.08301 12.1228 2.29079 13.0863 2.70634C14.0498 3.1219 14.8878 3.68586 15.6005 4.39822C16.3131 5.11058 16.8773 5.94829 17.2932 6.91134C17.7089 7.8744 17.9167 8.90335 17.9167 9.99822C17.9167 11.0932 17.7089 12.1225 17.2934 13.0859C16.8778 14.0494 16.3139 14.8875 15.6015 15.6001C14.8891 16.3127 14.0514 16.877 13.0884 17.2928C12.1253 17.7085 11.0964 17.9163 10.0015 17.9163Z" fill="#D32F2F"/> </g> </svg> <span class="desktop-show">Failed</span></p>';

            tr.innerHTML = `
              <td>${row.name}</td>
              <td>${row.date}</td>
              <td>${statusHtml}</td>
              <td>${row.reward} coins</td>
            `;

            tbody.appendChild(tr);
          });
        })
        .catch(err => {
          console.error('Referral history fetch failed:', err);
        });
    })();
  </script>
{% endif %}

{% if customer %}
<script>
  fetch('/apps/nector', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
        customer_id: {{ customer.id }}
    })
  })
  .then(res => res.json())
  .then(data => {
    if (!data.status) return;
    document.querySelector('#rewardCoins').innerText = data.coins;
  });
</script>
{% endif %}

<script>
  function copyLink() {
    const linkInput = document.getElementById('referralLink');
    const copyBtn = document.querySelector('.copy-btn');
    const toast = document.getElementById('toast');

    linkInput.select();
    linkInput.setSelectionRange(0, 99999);

    try {
      document.execCommand('copy');

      copyBtn.textContent = 'Copied!';
      copyBtn.classList.add('copied');

      toast.classList.add('show');

      setTimeout(() => {
        copyBtn.textContent = 'Copy Link';
        copyBtn.classList.remove('copied');
        toast.classList.remove('show');
      }, 2000);

    } catch (err) {
      console.error('Failed to copy text: ', err);
    }
  }

  function shareOnWhatsApp() {
    const referralLink = document.getElementById('referralLink').value;
    const message = `Hey! Check out this amazing platform - Lucira! Use my referral link to get ₹1000 off on your first order: ${referralLink}`;
    const whatsappUrl = `https://api.whatsapp.com/send?text=${encodeURIComponent(message)}`;
    window.open(whatsappUrl, '_blank');
  }

  function shareOnFacebook() {
    const referralLink = document.getElementById('referralLink').value;
    const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(referralLink)}`;
    window.open(facebookUrl, '_blank', 'width=600,height=400');
  }

  function shareOnTwitter() {
    const referralLink = document.getElementById('referralLink').value;
    const message = `Join me on Lucira and get ₹1000 off your first order!`;
    const twitterUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(message)}&url=${encodeURIComponent(referralLink)}`;
    window.open(twitterUrl, '_blank', 'width=600,height=800');
  }

  function shareOnLinkedIn() {
    const referralLink = document.getElementById('referralLink').value;
    const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(referralLink)}`;
    window.open(linkedinUrl, '_blank', 'width=600,height=800');
  }

  function shareOnInstagram() {
      const referralLink = document.getElementById('referralLink').value;
      copyLink();
      const instagramUrl = `https://www.instagram.com/create/story?text=${encodeURIComponent(referralLink)}`;
      window.open('https://www.instagram.com/', '_blank', 'width=600,height=800');
  }

  document.addEventListener('DOMContentLoaded', function () {
    const cards = document.querySelectorAll('.grid-card-wrapper');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    });

    cards.forEach(card => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(20px)';
      card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      observer.observe(card);
    });
  });
</script>

<script>
  function shareReferralLink() {
    const referralLink = document.getElementById('referralLink').value;
    const message = `Hey! Use my referral link and get ₹1000 off on your first order: ${referralLink}`;

    if (navigator.share) {
      navigator.share({
        title: 'Invite Friends to Lucira',
        text: message,
        url: referralLink
      }).catch(err => console.log('Share cancelled', err));
    } 
    else {
      navigator.clipboard.writeText(referralLink).then(() => {
        alert('Referral link copied! Share it with your friends 💖');
      });
    }
  }
</script>
