<div class="nector-referral-program-wrapper">
  <div class="grid-column">
    <div
      class="grid-card-wrapper"
    >
      <img
        src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/They_Get_img_2.png?v=1751354604"
        class="image-bg-left"
        alt="loyalty page left"
        title="loyalty page image left"
        width="auto"
        height="auto"
      >
      <p>They Get</p>
      <p class="coins-text">
        ₹1,000 Off<br>
        <span> on their 1st Order</span>
      </p>
    </div>
  </div>
  <div class="grid-column">
    <div
      class="grid-card-wrapper"
    >
      <img
        src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/7d93784d-d99f-4716-8c45-779b911938f6_2.png?v=1751352893"
        class="image-bg-right"
        alt="image-by-right"
        title="image-by-right"
        width="auto"
        height="auto"
      >
      <p>You Get</p>
      <p class="coins-text">
        2,000<br>
        <span>Lucira Coins</span>
      </p>
    </div>
  </div>
</div>
<div class="grid-row referal-row">
  {% if customer %}
    {% if customer.metafields.nector.custom_properties.value.nector_user_referral_link %}
      <div class="grid-column">
        <div class="referral-copy-wrapper">
          <p>Your Referral Link is Ready to Share with your friends</p>
          <div class="copy-link-container">
            <input
              type="text"
              id="referralLink"
              value="{{ customer.metafields.nector.custom_properties.value.nector_user_referral_link }}"
              readonly
            >
            <button class="copy-btn" onclick="copyLink()">Copy Link</button>
          </div>
        </div>
      </div>

      <div class="grid-column">
        <div class="or-text">OR</div>
      </div>

      <div class="grid-column">
        <div class="grid-social-icons">
          <a href="#" onclick="shareOnWhatsApp(); return false;">
            <img
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_427319185.png?v=1766570053"
              alt="whatsapp icon"
              title="whatsapp icon"
              width="72"
              height="72"
            >
          </a>
          <a href="#" onclick="shareOnInstagram(); return false;">
            <img
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_427322338.png?v=1766570052"
              alt="instagram icon"
              title="instagram icon"
              width="72"
              height="72"
            >
          </a>
          <a href="#" onclick="shareOnFacebook(); return false;">
            <img
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_427319188.png?v=1766570053"
              alt="facebook icon"
              title="facebook icon"
              width="72"
              height="72"
            >
          </a>
          <a href="#" onclick="shareOnLinkedIn(); return false;">
            <img
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Frame_427319187.png?v=1766570053"
              alt="linkedin icon"
              title="linkedin icon"
              width="72"
              height="72"
            >
          </a>
        </div>
      </div>
    {% endif %}
  {% endif %}
</div>

<div class="referral-history-wrapper">

  <h3 class="referral-title">Referral & Transactional History</h3>

  <div class="referral-summary">
    <div>
      <span>TOTAL REFERRALS:</span>
      <strong id="total-referrals">0</strong>
    </div>
    <div>
      <span>LUCIRA COINS EARNED:</span>
      <strong id="coins-earned">0</strong>
    </div>
    <div>
      <span>LUCIRA COINS BALANCE:</span>
      <strong id="coins-balance">0</strong>
    </div>
  </div>

  <table class="referral-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Date</th>
        <th>Status</th>
        <th>Reward</th>
      </tr>
    </thead>
    <tbody id="referral-history-body">
    </tbody>
  </table>

  <div class="invite-btn-wrapper">
    <button class="invite-btn">INVITE MORE FRIENDS</button>
  </div>

</div>

{% if customer %}
  <script>
    (function () {
      const endpoint = "https://refer-earn-385594025448.asia-south1.run.app";
      const customerId = "shopify-{{ customer.id }}";

      fetch(`${endpoint}?customer_id=${encodeURIComponent(customerId)}`)
        .then(res => res.json())
        .then(data => {
          if (!data.status) return;

          document.getElementById('total-referrals').innerText =
            data.total_referrals;

          document.getElementById('coins-earned').innerText =
            data.coins_earned;

          document.getElementById('coins-balance').innerText =
            data.coins_balance;

          const tbody = document.getElementById('referral-history-body');
          tbody.innerHTML = '';

          data.history.forEach(row => {
            const tr = document.createElement('tr');

            const statusHtml =
              row.status === 'Earned'
                ? '<p class="status-earned">🟢 <span class="desktop-show">Earned</span></p>'
                : '<p class="status-failed">🔴 <span class="desktop-show">Failed</span></p>';

            tr.innerHTML = `
              <td>${row.name}</td>
              <td>${row.date}</td>
              <td>${statusHtml}</td>
              <td>₹ ${row.reward}</td>
            `;

            tbody.appendChild(tr);
          });
        })
        .catch(err => {
          console.error('Referral history fetch failed:', err);
        });
    })();
  </script>
{% endif %}





