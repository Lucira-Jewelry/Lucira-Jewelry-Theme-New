<script>
(function () {
  if (!window.ShopifyIconCarousel) {
    window.ShopifyIconCarousel = class {
      constructor(containerElement) {
        this.container = containerElement;
        this.textContent = this.container.querySelector('.text-content');
        this.icons = this.container.querySelectorAll('.icon');
        this.currentIndex = 0;
        this.isAnimating = false;
        this.cycleCount = 0;
        this.productId = this.container.dataset.productId;
        this.isExpanded = false;
        this.isMobile = this.checkIfMobile();
        this.isInitialized = false;
        this.hasBeenViewed = false;
        this.animationStarted = false;

        this.items = [];
        this.icons.forEach((icon, index) => {
          const tagType = icon.dataset.tagType || `tag-${index}`;
          const altText = icon.alt || `Tag ${index + 1}`;
          this.items.push({
            iconClass: `.tag-icon-${index}`,
            text: altText,
            tagType: tagType
          });
        });

        this.maxCycles = Math.max(2, this.items.length * 2);

        if (this.items.length > 0) {
          this.init();
        }
      }

      checkIfMobile() {
        return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) ||
          window.innerWidth <= 768;
      }

      async init() {
        await this.waitForDOMReady();
        await this.preCalculateWidths();
        this.setInitialState();
        await this.wait(100);
        this.isInitialized = true;
        this.setupScrollObserver();
      }

      setupScrollObserver() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting && !this.hasBeenViewed && !this.animationStarted) {
              this.hasBeenViewed = true;
              this.animationStarted = true;
              this.startAnimation();
            }
          });
        }, {
          threshold: 0.5,
          rootMargin: '0px 0px -50px 0px'
        });

        observer.observe(this.container);
      }

      async waitForDOMReady() {
        return new Promise(resolve => {
          if (document.readyState === 'complete') {
            resolve();
          } else {
            window.addEventListener('load', resolve, { once: true });
          }
        });
      }

      async preCalculateWidths() {
        const tempElement = document.createElement('div');
        tempElement.className = 'text-measurer';
        tempElement.style.cssText = `
          position: absolute;
          opacity: 0; /* instead of visibility:hidden */
          pointer-events: none;
          height: auto;
          width: auto;
          white-space: nowrap;
          font-family: Futura Std, sans-serif;
          font-weight: 400;
          font-size: 12px;
          line-height: 150%;
          text-transform: capitalize;
          top: -9999px;
          left: -9999px;
          transform: translateZ(0);
        `;
        document.body.appendChild(tempElement);

        this.widthCache = {};
        for (let i = 0; i < this.items.length; i++) {
          tempElement.textContent = this.items[i].text;
          tempElement.offsetWidth;
          this.widthCache[i] = this.calculateWidthForText(tempElement.offsetWidth);
        }

        document.body.removeChild(tempElement);
      }

      calculateWidthForText(textWidth) {
        const iconWidth = this.isMobile ? 36 : 50;
        const leftMargin = 8;
        const rightSpace = this.isMobile ? 2 : 3;
        const basePadding = this.isMobile ? 0 : 6;
        const totalWidth = iconWidth + leftMargin + textWidth + basePadding + rightSpace;
        const maxWidth = window.innerWidth - 40;
        return Math.min(totalWidth, maxWidth);
      }

      setInitialState() {
        const initialWidth = this.widthCache[this.currentIndex] || this.calculateOptimalWidth();
        this.container.style.setProperty('--dynamic-width', `${initialWidth}px`);
        const firstIcon = this.container.querySelector(this.items[0].iconClass);
        if (firstIcon) firstIcon.classList.add('active');
        this.textContent.textContent = this.items[this.currentIndex].text;
      }

      calculateOptimalWidth() {
        if (this.widthCache && this.widthCache[this.currentIndex]) {
          return this.widthCache[this.currentIndex];
        }

        const currentText = this.textContent.textContent;
        const tempElement = document.createElement('div');
        tempElement.className = 'text-measurer';
        tempElement.textContent = currentText;
        tempElement.style.cssText = `
          position: absolute;
          visibility: hidden;
          white-space: nowrap;
          font-family: 'Futura, sans-serif';
          font-weight: 400;
          font-size: 12px;
          line-height: 150%;
          text-transform: capitalize;
          top: -9999px;
          left: -9999px;
        `;

        document.body.appendChild(tempElement);
        const textWidth = tempElement.offsetWidth;
        document.body.removeChild(tempElement);

        return this.calculateWidthForText(textWidth);
      }

      async switchIcon(newIndex) {
        if (this.items.length <= 1) return;

        const currentIcon = this.container.querySelector(this.items[this.currentIndex].iconClass);
        const newIcon = this.container.querySelector(this.items[newIndex].iconClass);
        if (!currentIcon || !newIcon) return;

        this.textContent.textContent = this.items[newIndex].text;
        const newWidth = this.widthCache[newIndex] || this.calculateOptimalWidth();
        this.container.style.setProperty('--dynamic-width', `${newWidth}px`);

        currentIcon.classList.remove('active');
        currentIcon.classList.add('exit');
        await this.wait(100);

        currentIcon.classList.remove('exit');
        newIcon.classList.add('active', 'enter');

        setTimeout(() => {
          newIcon.classList.remove('enter');
        }, 200);
      }

      async animateItem(index) {
        if (this.isAnimating) return;
        this.isAnimating = true;
        this.container.classList.add('animating');

        if (index !== this.currentIndex && this.items.length > 1) {
          await this.switchIcon(index);
          this.currentIndex = index;
        }

        const optimalWidth = this.widthCache[index] || this.calculateOptimalWidth();
        this.container.style.setProperty('--dynamic-width', `${optimalWidth}px`);
        await this.wait(25);

        this.container.classList.add('expanded');
        await this.wait(2000);
        this.container.classList.remove('expanded');
        await this.wait(400);
        this.container.classList.remove('animating');

        this.isAnimating = false;
      }

      wait(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
      }

      async startAnimation() {
        if (!this.isInitialized) {
          await this.wait(50);
          return this.startAnimation();
        }

        let index = 0;
        let animationCount = 0;
        await this.wait(200);

        while (animationCount < this.maxCycles) {
          await this.animateItem(index);
          animationCount++;
          if (this.items.length > 1) {
            index = (index + 1) % this.items.length;
          }
          if (animationCount < this.maxCycles) {
            await this.wait(300);
          }
        }

        this.container.classList.add('animation-complete');
        this.setupInteractionFunctionality();
      }

      setupInteractionFunctionality() {
        if (this.isMobile) {
          this.container.addEventListener('touchstart', this.handleMobileTouch.bind(this), { passive: true });
          this.container.addEventListener('click', this.handleMobileClick.bind(this));
          this.container.classList.add('mobile-interactive');
          this.container.style.cursor = 'pointer';
        } else {
          this.container.addEventListener('mouseenter', () => {
            if (!this.isAnimating) {
              const optimalWidth = this.widthCache[this.currentIndex] || this.calculateOptimalWidth();
              this.container.style.setProperty('--dynamic-width', `${optimalWidth}px`);
              this.container.classList.add('expanded');
              this.isExpanded = true;
            }
          });

          this.container.addEventListener('mouseleave', async () => {
            if (!this.isAnimating) {
              this.container.classList.remove('expanded');
              this.isExpanded = false;
              if (this.items.length > 1) {
                await this.wait(150);
                await this.switchToNextTag();
              }
            }
          });
        }
      }

      handleMobileTouch(e) {
        e.preventDefault();
        this.handleMobileInteraction();
      }

      handleMobileClick(e) {
        e.stopPropagation();
        this.handleMobileInteraction();
      }

      async handleMobileInteraction() {
        if (this.isAnimating) return;

        if (!this.isExpanded) {
          const optimalWidth = this.widthCache[this.currentIndex] || this.calculateOptimalWidth();
          this.container.style.setProperty('--dynamic-width', `${optimalWidth}px`);
          await this.wait(25);

          this.container.classList.add('expanded');
          this.isExpanded = true;

          setTimeout(async () => {
            if (this.isExpanded) {
              this.container.classList.remove('expanded');
              this.isExpanded = false;
              if (this.items.length > 1) {
                await this.wait(150);
                await this.switchToNextTag();
              }
            }
          }, 2500);
        } else {
          if (this.items.length > 1) {
            await this.switchToNextTag();
          }
        }
      }

      async switchToNextTag() {
        if (this.isAnimating || this.items.length <= 1) return;
        const nextIndex = (this.currentIndex + 1) % this.items.length;
        await this.switchIcon(nextIndex);
        this.currentIndex = nextIndex;
      }
    };
  }

  function initializeCarousels() {
    const carouselContainers = document.querySelectorAll('.carousel-container');
    requestAnimationFrame(() => {
      carouselContainers.forEach(container => {
        if (!container.hasAttribute('data-carousel-initialized')) {
          new window.ShopifyIconCarousel(container);
          container.setAttribute('data-carousel-initialized', 'true');
        }
      });
    });
  }

  function domReady(fn) {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fn);
    } else {
      fn();
    }
  }

  domReady(() => setTimeout(initializeCarousels, 50));

  let mutationTimeout;
  const observer = new MutationObserver((mutations) => {
    clearTimeout(mutationTimeout);
    mutationTimeout = setTimeout(() => {
      let shouldInitialize = false;
      mutations.forEach((mutation) => {
        if (mutation.type === 'childList' && mutation.addedNodes.length > 0) {
          mutation.addedNodes.forEach((node) => {
            if (node.nodeType === Node.ELEMENT_NODE) {
              if ((node.classList && node.classList.contains('carousel-container')) ||
                node.querySelectorAll('.carousel-container').length > 0) {
                shouldInitialize = true;
              }
            }
          });
        }
      });

      if (shouldInitialize) {
        initializeCarousels();
      }
    }, 100);
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true
  });

  document.addEventListener('shopify:section:load', initializeCarousels);
  document.addEventListener('shopify:section:reorder', initializeCarousels);
  document.addEventListener('theme:collection:updated', initializeCarousels);
  document.addEventListener('collection:updated', initializeCarousels);
  document.addEventListener('ajax:success', initializeCarousels);
  document.addEventListener('facets:updated', initializeCarousels);

  const productGridSelectors = [
    '.product-grid',
    '.collection-product-list',
    '.product-collection',
    '.collection-grid',
    '[data-collection-products]'
  ];

  function setupGridObservers() {
    productGridSelectors.forEach(selector => {
      const grids = document.querySelectorAll(selector);
      grids.forEach(grid => {
        if (!grid.hasAttribute('data-grid-observed')) {
          const gridObserver = new MutationObserver(() => {
            clearTimeout(grid.initTimeout);
            grid.initTimeout = setTimeout(initializeCarousels, 100);
          });
          gridObserver.observe(grid, { childList: true, subtree: true });
          grid.setAttribute('data-grid-observed', 'true');
        }
      });
    });
  }

  domReady(setupGridObservers);

  let lastCarouselCount = 0;
  const startTime = Date.now();
  const intervalCheck = setInterval(() => {
    const currentCount = document.querySelectorAll('.carousel-container').length;
    if (currentCount !== lastCarouselCount) {
      initializeCarousels();
      lastCarouselCount = currentCount;
    }
    if (Date.now() - startTime > 30000) {
      clearInterval(intervalCheck);
    }
  }, 2000);

  window.initializeCarousels = initializeCarousels;
})();
</script>


<script>
