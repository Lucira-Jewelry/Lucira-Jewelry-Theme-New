<script>
document.addEventListener("DOMContentLoaded", function () {
  const wishlistBtns = document.querySelectorAll(".product-card-wrapper .iWishAddColl");

  wishlistBtns.forEach(function (btn) {
    btn.addEventListener("click", function () {

      // Prevent duplicate pushes
      if (btn.classList.contains("iwishAdded")) return;

      const productCard = btn.closest(".product-card-wrapper"); // adjust selector if different
      if (!productCard) return;

      // Collect info from the DOM
      const titleEl = productCard.querySelector(".card__heading a, .product-title a");
      const priceEl = productCard.querySelector(".price .price-item--regular");
      const compareAtEl = productCard.querySelector(".price .price-item--sale, .price .price-item--compare");
      const imgEl = productCard.querySelector("img");

      // Build product data
      const productData = {
        productName: titleEl ? titleEl.innerText.trim() : "",
        product_url: titleEl ? titleEl.href : "",
        price: priceEl ? parseFloat(priceEl.innerText.replace(/[^0-9.]/g, "")) : "",
        offer_price: compareAtEl ? parseFloat(compareAtEl.innerText.replace(/[^0-9.]/g, "")) : "",
        thumbnail_image: imgEl ? imgEl.src : "",
        currency: "{{ shop.currency }}"  
      };

      // Push to dataLayer
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: "addToWishlist",
        products: productData
      });

      // Mark button as added to prevent duplicate pushes
      btn.classList.add("iwishAdded");

    });
  });
});

// Disable console logs in production
if (typeof console !== "undefined") {
  console.log = function() {};
  console.warn = function() {};
  console.error = function() {};
  console.info = function() {};
  console.debug = function() {};
}
</script>
