    let modal = document.getElementById('VideoModal');
    if (!modal) {
      modal = document.createElement('div');
      modal.id = 'VideoModal';
      modal.className = 'video-modal hidden';
      modal.innerHTML = `
        <div class="video-modal__overlay">
          <div class="video-modal__content">
            <button class="video-modal__close"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<mask id="mask0_10852_4801" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24">
<rect width="24" height="24" fill="#D9D9D9"/>
</mask>
