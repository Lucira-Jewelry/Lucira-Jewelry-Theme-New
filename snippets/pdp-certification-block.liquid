        "
        sizes="(max-width: 480px) 50px, 100px"
        src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/IGI.webp?v=1747116568&width=100"
        loading="lazy"
        width="50"
        height="50"
      >

      <img
        alt="Certification logo 2"
        title="Certification logo 2"
        srcset="
          https://cdn.shopify.com/s/files/1/0739/8516/3482/files/SGL.webp?v=1747116568&width=50 50w,
          https://cdn.shopify.com/s/files/1/0739/8516/3482/files/SGL.webp?v=1747116568&width=100 100w,
          https://cdn.shopify.com/s/files/1/0739/8516/3482/files/SGL.webp?v=1747116568&width=150 150w,
          https://cdn.shopify.com/s/files/1/0739/8516/3482/files/SGL.webp?v=1747116568&width=300 300w
        "
        sizes="(max-width: 480px) 50px, 100px"
        src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/SGL.webp?v=1747116568&width=100"
        loading="lazy"
        width="50"
        height="50"
      >
      <img
        alt="Certification logo 5"
        srcset="
          https://cdn.shopify.com/s/files/1/0739/8516/3482/files/BIS.webp?v=1747116567&width=50 50w,
          https://cdn.shopify.com/s/files/1/0739/8516/3482/files/BIS.webp?v=1747116567&width=100 100w,
          https://cdn.shopify.com/s/files/1/0739/8516/3482/files/BIS.webp?v=1747116567&width=150 150w,
