<div class="certification-section-main">
  <div class="certification-section">
    <div class="certification-titles">
      <h2>Product is certified</h2>
      <h2 style="color: #3C2C2A;font-weight: 500; font-size: 14px; line-height: 150%; letter-spacing: .7px;">
        <a 
          href="https://www.lucirajewelry.com/pages/certificate" 
          style="color: #3C2C2A;" 
          target="_blank"
          onclick="trackCertificateClick(event)"
        >Check Sample Certificate</a>
      </h2>
    </div>
    <div class="certification-logos">
      <img
        alt="Certification logo 1"
        title="Certification logo 1"
