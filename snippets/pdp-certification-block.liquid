        "
        sizes="(max-width: 480px) 50px, 100px"
        src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/BIS.webp?v=1747116567&width=100"
        title="certification logo 5"
        loading="lazy"
        width="50"
        height="50"
      >
    </div>
    {% comment %} <div class="certification-note">
      Note: Handcrafted and personalized with care - slight variations in metal weight are natural with different sizes.<br>
      {% if product.tags contains 'Only Pendant' %}
        <span>Chain is not included in the purchase.</span>
      {% endif %}
        {% if product.tags contains 'Eternity' or  'Tennis Bracelets' %}
        <span > Handcrafted and personalized with care - slight variations in metal weight, diamond weight and quantity are natural with different sizes.</span>
      {% endif %}
    </div> {% endcomment %}
    <div class="certification-note">
      {% if product.tags contains 'Eternity' or product.tags contains 'Tennis Bracelets' %}
        <span>Note: Handcrafted and personalized with care - slight variations in metal weight, diamond weight and quantity are natural with different sizes.</span>
      {% else %}
        Note: Handcrafted and personalized with care - slight variations in metal weight are natural with different sizes.
        {% if product.tags contains 'Only Pendant' %}
          <br><span>Chain is not included in the purchase.</span>
        {% endif %}
      {% endif %}
    </div>
  </div>
</div>

<script>
  function trackCertificateClick(event) {
    // Initialize dataLayer if it doesn't exist
    window.dataLayer = window.dataLayer || [];
    
    // Push the event to dataLayer
    window.dataLayer.push({
      event: "promoClick",
      promoClick: {
        promo_id: '{{ product.selected_or_first_available_variant.sku }}',
        creative_name: 'View Sample Certificate',
        promo_position: {{product.title | json}},
        location_id: 'pdp'
      }
    });
  }
</script>