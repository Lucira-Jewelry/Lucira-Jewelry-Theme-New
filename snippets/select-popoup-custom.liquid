{{ 'select-popup-custom.css' | asset_url | stylesheet_tag }}
<script src="{{ 'select-popup-custom.js' | asset_url }}" defer="defer"></script>

<div id="product-popup" class="popup-overlay">
  <div class="popup-content">

    <!-- LEFT SIDE -->
    <div class="popup-left">
      <img id="popup-product-img" src="" loading="lazy" alt="Product Image">
      <div class="product-content">
        <div class="popup-color-options"></div>
        <h3 id="popup-product-title"></h3>
        <p>
          <span id="popup-product-price" class="current-price"></span>
          <span id="popup-product-compare" class="compare-price"></span>
        </p>
      </div>
    </div>

    <!-- RIGHT SIDE -->
    <div class="popup-right">
      <h4>Select Your Size</h4>

      <div class="popup-side">
        <div id="popup-sizes" class="popup-sizes"></div>

        <!-- DESKTOP IMAGE -->
        <div class="size-imge-cstm size-imge-cstm_desk">
          <img
            id="collection-size-image-desk"
            alt="Size Guide"
            loading="lazy"
          >
        </div>

        <div
          class="Proceed_button"
          id="Proceed_click_btn"
          onclick="proceedBtnClicked()"
          data-role="proceed"
          style="display:none;"
        >
          Proceed
        </div>
      </div>
    </div>

    <!-- MOBILE IMAGE -->
    <div class="size-imge-cstm size-imge-cstm_mob cstm_mob_custom">
      <img
        id="collection-size-image-mob"
        alt="Size Guide"
        loading="lazy"
      >
    </div>

  </div>
</div>

<!-- DYNAMIC COLLECTION IMAGE SCRIPT -->
<script>
document.addEventListener("DOMContentLoaded", function () {

  const params = new URLSearchParams(window.location.search);
  const collection = params.get("collection");

  const deskImg = document.getElementById("collection-size-image-desk");
  const mobImg = document.getElementById("collection-size-image-mob");

  if (!collection) return;

  const collectionImages = {

    // 🔹 Chain Bracelets
    "chain-braceletss-1": {
      desk: "https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Bracelet_acce0591-8a81-4480-82b9-ade0ec65d08d.jpg?v=1771050258",
      mob:  "https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Chain-Bracelet-Size-Mob.jpg"
    },

    // 🔹 Bangle Bracelets
    "bangle-bracelets": {
      desk: "https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Bangle-Size.jpg",
      mob:  "https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Bangle-Size-Mob.jpg"
    },

    // 🔹 Cuff Bracelets
    "cuff-bracelets": {
      desk: "https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Cuff-Size.jpg",
      mob:  "https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Cuff-Size-Mob.jpg"
    }

  };

  if (collectionImages[collection]) {
    if (deskImg) deskImg.src = collectionImages[collection].desk;
    if (mobImg) mobImg.src = collectionImages[collection].mob;
  }

});
</script>
