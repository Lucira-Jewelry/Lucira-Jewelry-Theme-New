{%- if card_product and card_product != empty -%}
  {%- liquid
    # -------------------------------
    # 1. ASPECT RATIO & SETUP
    # -------------------------------
    assign ratio = 1.4
    if card_product.featured_media and media_aspect_ratio == 'portrait'
      assign ratio = 0.72
    elsif card_product.featured_media and media_aspect_ratio == 'adapt'
      assign ratio = card_product.featured_media.aspect_ratio
    endif
    if ratio == 0 or ratio == null
      assign ratio = 1.4
    endif

    assign current_collection_handle = collection.handle | default: ''
    
    # -------------------------------
    # 2. SINGLE PASS VARIANT LOOP
    # Optimized: Find stock, shipping, colors, and discounts in one loop
    # -------------------------------
    assign first_instock_variant = nil
    assign show_fast_shipping = false
    assign max_discount = 0
    assign found_colors = ''
    
    # Color Swatch Config
    assign color_map = 'Yellow Gold,Rose Gold,White Gold,Platinum' | split: ','
    assign color_output = ''

    # Check if we should skip variant pre-selection (9kt logic)
    assign skip_variant_preselect = false
    if current_collection_handle == '9kt-collection'
      for col in card_product.collections
        if col.handle == '9kt-collection'
          assign skip_variant_preselect = true
          break
        endif
      endfor
    endif

    for v in card_product.variants
      # A. First In-Stock Variant
      if first_instock_variant == nil and skip_variant_preselect == false and v.inventory_quantity > 0
        assign first_instock_variant = v
      endif

      # B. Fast Shipping Logic
      if show_fast_shipping == false and v.available
        if current_collection_handle == '9kt-collection'
          assign v_title_down = v.title | downcase
          if v_title_down contains '9kt' or v_title_down contains '9 kt'
             if v.inventory_management == nil or v.inventory_quantity > 0
               assign show_fast_shipping = true
             endif
          endif
        else
          if v.inventory_management == nil or v.inventory_quantity > 0
             assign show_fast_shipping = true
          endif
        endif
      endif

      # C. Max Discount Calculation
      if v.compare_at_price > v.price
        assign diff = v.compare_at_price | minus: v.price
        assign pct = diff | times: 100.0 | divided_by: v.compare_at_price | round
        if pct > max_discount
          assign max_discount = pct
        endif
      endif

      # D. Color Swatches (One pass mapping)
      if color_output == ''
        assign v_title_down = v.title | downcase
        for color_name in color_map
          assign color_key = color_name | downcase
          if v_title_down contains color_key
            unless found_colors contains color_key
              assign found_colors = found_colors | append: color_key | append: ','
              
              assign icon_url = ''
              case color_name
                when 'Yellow Gold'
                  assign icon_url = 'https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Yellow_Gold.svg?v=1752822068'
                when 'Rose Gold'
                  assign icon_url = 'https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Rose_Gold.svg?v=1752822068'
                when 'White Gold'
                  assign icon_url = 'https://cdn.shopify.com/s/files/1/0739/8516/3482/files/White_Gold.svg?v=1752822068'
                when 'Platinum'
                  assign icon_url = 'https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Platinum.svg?v=1752822068'
              endcase

              capture color_btn
                echo '<button class="color-option" data-variant-id="' | echo: v.id | echo: '" data-color="' | echo: color_name | echo: '" data-product-id="' | echo: card_product.id | echo: '"'
                if v.featured_media
                  echo ' data-image-src="' | echo: v.featured_media | image_url: width: 533 | echo: '" data-image-alt="' | echo: v.featured_media.alt | escape | echo: '"'
                else
                  echo ' data-image-src="" data-image-alt="No image for ' | echo: color_name | echo: '"'
                endif
                echo ' title="' | echo: color_name | echo: '">'
                if icon_url != ''
                  echo '<img src="' | echo: icon_url | echo: '" alt="' | echo: color_name | echo: '" width="20" height="20" title="' | echo: color_name | echo: '" loading="lazy" />'
                else
                   echo '<span class="color-swatch color-' | echo: color_name | handleize | echo: '"></span>'
                endif
                echo '</button>'
              endcapture
              assign color_output = color_output | append: color_btn
            endunless
            break
          endif
        endfor
      endif
    endfor

    # -------------------------------
    # 3. IMAGE SELECTION
    # -------------------------------
    assign primary_media = nil
    assign secondary_media = nil
    assign product_title_down = card_product.title | downcase

    if first_instock_variant and first_instock_variant.featured_media
      assign primary_media = first_instock_variant.featured_media
    elsif card_product.featured_media
      assign primary_media = card_product.featured_media
    endif

    if show_secondary_image
      assign found_secondary = false
      for media in card_product.media
        if media.media_type == 'image' and media.id != primary_media.id
          assign alt_down = media.alt | default: '' | downcase | strip
          
          if alt_down == 'mq'
            assign secondary_media = media
            assign found_secondary = true
          endif
          
          if found_secondary == false and primary_media
             assign p_alt = primary_media.alt | downcase
             assign p_color = p_alt | split: '-' | last | strip
             if p_color != '' and alt_down contains p_color
               assign secondary_media = media
               assign found_secondary = true
             endif
          endif
          
          if found_secondary
            break
          endif
        endif
      endfor
      
      if secondary_media == nil and card_product.media.size > 1
         for media in card_product.media
           if media.media_type == 'image' and media.id != primary_media.id
             assign secondary_media = media
             break
           endif
         endfor
      endif
    endif

    # -------------------------------
    # 4. PRICING CALCULATIONS
    # -------------------------------
    assign target_variant = first_instock_variant | default: card_product.selected_or_first_available_variant
    if forced_variant
      assign target_variant = forced_variant
    endif

    assign diamond_final = 0.0
    assign diamond_original = 0.0
    assign mc_percent = 0
    assign diamond_percent = 0
    assign config = target_variant.metafields['DI-GoldPrice'].variant_config.value

    if config
      assign stone_pricing_db = shop.metafields['DI-GoldPrice'].stone_pricing.value
      for stone_item in config.advanced_stone_config
        if stone_item.stone_type == 'diamond'
          assign slab_rate = 0
          assign slab_discount = 0
          assign pricing_ref = stone_pricing_db | where: 'id', stone_item.pricing_id | first
          if pricing_ref
            assign avg_weight = stone_item.stone_weight | times: 1.0 | divided_by: stone_item.stone_quantity
            for slab in pricing_ref.slabs
              if avg_weight >= slab.from_weight and avg_weight <= slab.to_weight
                assign slab_rate = slab.price | times: 100
                assign slab_discount = slab.discount | default: 0
                break
              endif
            endfor
          endif
          assign item_base_cost = slab_rate | times: stone_item.stone_weight
          assign applied_discount = config.diamond_discount | default: slab_discount
          assign discount_amount = item_base_cost | times: applied_discount | divided_by: 100.0
          assign diamond_final = diamond_final | plus: item_base_cost | minus: discount_amount
          assign diamond_original = diamond_original | plus: item_base_cost
        endif
      endfor

      assign mc_rate_original = config.making_charges | default: 0 | times: 100
      assign mc_discount_percent = config.making_charges_discount | default: 0
      assign mc_cost_original = mc_rate_original | times: config.metal_weight
      assign mc_rate_disc_amt = mc_rate_original | times: mc_discount_percent | divided_by: 100.0
      assign mc_cost_final = mc_cost_original | minus: mc_rate_disc_amt
      
      if mc_cost_original > mc_cost_final and mc_cost_original > 0
        assign mc_percent = mc_cost_original | minus: mc_cost_final | times: 100 | divided_by: mc_cost_original | round
      endif
    endif

    if diamond_original > diamond_final and diamond_original > 0
      assign diamond_percent = diamond_original | minus: diamond_final | times: 100 | divided_by: diamond_original | round
    endif
    
    assign discount_color = '#4CBC7F'
    if diamond_percent >= 35
      assign discount_color = '#009147'
    elsif diamond_percent >= 25
      assign discount_color = '#01A652'
    elsif diamond_percent >= 20
      assign discount_color = '#27B169'
    endif

    # -------------------------------
    # 5. URL HANDLING (FIXED SYNTAX ERROR)
    # -------------------------------
    # We split the URL to get the clean base path.
    assign base_url = card_product.url | split: '?' | first
    
    # Since base_url is clean (no ?), we always start the variant parameter with ?
    assign variant_url = ''
    if first_instock_variant
      assign variant_url = '?variant=' | append: first_instock_variant.id
    endif
  -%}

  <div
    class="card-wrapper product-card-wrapper underline-links-hover card_{{ forloop.index0 }}"
    data-product-handle="{{ card_product.handle }}"
  >
    {% render 'wishlist-app-links', linkType: 'list-product', product: card_product %}
    <div
      class="
        card card--{{ settings.card_style }}
        {% if card_product.featured_media %} card--media{% else %} card--text{% endif %}
        {% if settings.card_style == 'card' %} color-{{ settings.card_color_scheme }} gradient{% endif %}
        {% if image_shape and image_shape != 'default' %} card--shape{% endif %}
        {% if extend_height %} card--extend-height{% endif %}
        {% if card_product.featured_media == nil and settings.card_style == 'card' %} ratio{% endif %}
        {% if horizontal_class %} card--horizontal{% endif %}
      "
      style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
      data-product-id="{{ card_product.id }}"
    >
      <div
        class="card__inner {% if settings.card_style == 'standard' %}color-{{ settings.card_color_scheme }} gradient{% endif %}{% if card_product.featured_media or settings.card_style == 'standard' %} ratio{% endif %} {% if section.settings.portrait_mobile_only %}portrait-mobile-only{% endif %}"
        style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
        data-desktop-ratio="{{ section.settings.image_ratio }}"
      >
        {%- if card_product.featured_media -%}
          <a
            href="{{ base_url }}{{ variant_url }}"
            class="product-image-link custom-image-link open-in-new-tab"
            aria-label="{{ card_product.title | escape }}"
            data-product-url="{{ card_product.url }}"
            data-product-id="{{ card_product.id }}"
            data-variant-id="{% if first_instock_variant %}{{ first_instock_variant.id }}{% else %}{{ card_product.variants.first.id }}{% endif %}"
            data-sku="{{ card_product.variants.first.sku }}"
            data-product-name="{{ card_product.title | escape }}"
            data-product-type="{{ card_product.type | escape }}"
            data-product-category="{{ card_product.collections.first.title | escape }}"
            data-category="{{ card_product.vendor | escape }}"
            data-sub-category="{{ card_product.tags | join: ',' | escape }}"
            data-thumbnail-image="{% if primary_media %}{{ primary_media | image_url: '300x' }}{% else %}{{ card_product.featured_image | img_url: '300x' }}{% endif %}"
            data-purity="{{ card_product.metafields.custom.purity }}"
            data-price="{{ card_product.price | money_without_currency }}"
            data-offer-price="{{ card_product.compare_at_price | money_without_currency }}"
            data-expected-delivery-date="{{ card_product.metafields.custom.expected_delivery_date }}"
            data-coupon-code="{{ card_product.metafields.custom.coupon_code }}"
            data-making-charges="{{ card_product.metafields.custom.making_charges }}"
            data-number-of-review="{{ card_product.metafields.reviews.rating_count }}"
            data-rating="{{ card_product.metafields.reviews.rating.value }}"
          >
            <div class="card__media{% if image_shape and image_shape != 'default' %} shape--{{ image_shape }} color-{{ settings.card_color_scheme }} gradient{% endif %}">
              <div class="media media--transparent media--hover-effect">
                {%- if primary_media -%}
                  <img
                    id="product-image-{{ card_product.id }}"
                    class="motion-reduce primary-image"
                    srcset="
                      {%- if primary_media.width >= 165 -%}{{ primary_media | image_url: width: 165 }} 165w,{%- endif -%}
                      {%- if primary_media.width >= 360 -%}{{ primary_media | image_url: width: 360 }} 360w,{%- endif -%}
                      {%- if primary_media.width >= 533 -%}{{ primary_media | image_url: width: 533 }} 533w,{%- endif -%}
                      {%- if primary_media.width >= 720 -%}{{ primary_media | image_url: width: 720 }} 720w,{%- endif -%}
                      {%- if primary_media.width >= 940 -%}{{ primary_media | image_url: width: 940 }} 940w,{%- endif -%}
                      {%- if primary_media.width >= 1066 -%}{{ primary_media | image_url: width: 1066 }} 1066w,{%- endif -%}
                      {{ primary_media | image_url }} {{ primary_media.width }}w
                    "
                    src="{{ primary_media | image_url: width: 533 }}"
                    sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                    alt="{{ card_product.title }} - {{ primary_media.alt }}"
                    loading="lazy"
                    decoding="async"
                    width="400"
                    height="400"
                    title="{{ card_product.title }}"
                    data-current-variant="{{ primary_media.alt | escape }}"
                  >
                  {%- if show_secondary_image -%}
                    <img
                      id="product-image-secondary-{{ card_product.id }}"
                      class="motion-reduce secondary-image"
                      style="{% unless secondary_media %}display: none;{% endunless %}"
                      {% if secondary_media %}
                        src="{{ secondary_media | image_url: width: 533 }}"
                        srcset="
                          {%- if secondary_media.width >= 165 -%}{{ secondary_media | image_url: width: 165 }} 165w,{%- endif -%}
                          {%- if secondary_media.width >= 360 -%}{{ secondary_media | image_url: width: 360 }} 360w,{%- endif -%}
                          {%- if secondary_media.width >= 533 -%}{{ secondary_media | image_url: width: 533 }} 533w,{%- endif -%}
                          {%- if secondary_media.width >= 720 -%}{{ secondary_media | image_url: width: 720 }} 720w,{%- endif -%}
                          {%- if secondary_media.width >= 940 -%}{{ secondary_media | image_url: width: 940 }} 940w,{%- endif -%}
                          {%- if secondary_media.width >= 1066 -%}{{ secondary_media | image_url: width: 1066 }} 1066w,{%- endif -%}
                          {{ secondary_media | image_url }} {{ secondary_media.width }}w
                        "
                        sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                        width="400"
                        height="400"
                        title="{{ card_product.title | escape }}"
                        alt="{{ card_product.title }} - {{ secondary_media.alt }}"
                        loading="lazy"
                      {% endif %}
                    >
                  {%- endif -%}
                {%- else -%}
                  {%- if placeholder_image -%}
                    {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- else -%}
                    {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                {%- endif -%}
              </div>
            </div>
          </a>
        {%- endif -%}

        <div class="card__content">
          <div class="card__information">
            <div
              class="card__heading"
              {% if card_product.featured_media == null and settings.card_style == 'standard' %}
                id="title-{{ section_id }}-{{ card_product.id }}"
              {% endif %}
            >
              <a
                href="{{ base_url }}{{ variant_url }}"
                id="StandardCardNoMediaLink-{{ section_id }}-{{ card_product.id }}"
                class="full-unstyled-link"
                aria-labelledby="StandardCardNoMediaLink-{{ section_id }}-{{ card_product.id }} NoMediaStandardBadge-{{ section_id }}-{{ card_product.id }}"
                target="_blank"
              >
                {{ card_product.title | escape }}
              </a>
            </div>
          </div>
          <div class="card__badge {{ settings.badge_position }}">
            {%- if card_product.available == false -%}
              <span
                id="NoMediaStandardBadge-{{ section_id }}-{{ card_product.id }}"
                class="badge badge--bottom-left color-{{ settings.sold_out_badge_color_scheme }}"
              >
                {{- 'products.product.sold_out' | t -}}
              </span>
            {%- elsif card_product.compare_at_price > card_product.price and card_product.available -%}
              <span
                id="NoMediaStandardBadge-{{ section_id }}-{{ card_product.id }}"
                class="badge badge--bottom-left color-{{ settings.sale_badge_color_scheme }}"
              >
                {{- 'products.product.on_sale' | t -}}
              </span>
            {%- endif -%}
          </div>
        </div>
      </div>
      
      <div class="card-content-wrapper">
        <div class="color-variants-options">
          {{ color_output }}
        </div>

        <div class="card__rating">
          {%- if show_rating and card_product.metafields.reviews.rating.value != blank -%}
            {% liquid
              assign rating_decimal = 0
              assign decimal = card_product.metafields.reviews.rating.value.rating | modulo: 1
              if decimal >= 0.3 and decimal <= 0.7
                assign rating_decimal = 0.5
              elsif decimal > 0.7
                assign rating_decimal = 1
              endif
            %}
            <div
              class="rating"
              role="img"
              aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: card_product.metafields.reviews.rating.value, rating_max: card_product.metafields.reviews.rating.value.scale_max }}"
            >
              <span
                aria-hidden="true"
                class="rating-star desktop-show"
                style="--rating: {{ card_product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ card_product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"
              ></span>
              <span class="">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 10" height="10" width="10">
                  <path fill="#FEC602" d="M5 8.3747L7.42493 9.90932C7.86901 10.1906 8.41243 9.77481 8.29556 9.24901L7.65281 6.36318L9.79727 4.41892C10.1888 4.0643 9.97841 3.39176 9.4642 3.34896L6.64194 3.09829L5.53757 0.371428C5.33891 -0.123809 4.6611 -0.123809 4.46243 0.371428L3.35806 3.09217L0.535797 3.34285C0.021595 3.38565 -0.18876 4.05819 0.202734 4.4128L2.34719 6.35707L1.70444 9.24289C1.58757 9.7687 2.13099 10.1845 2.57507 9.90321L5 8.3747Z"></path>
                </svg>
              </span>
            </div>
            <p class="rating-text caption">
              <span aria-hidden="true">
                {{- card_product.metafields.reviews.rating.value }}
              </span>
            </p>
            <p class="rating-count caption">
              <span aria-hidden="true">({{ card_product.metafields.reviews.rating_count }})</span>
              <span class="visually-hidden">
                {{- card_product.metafields.reviews.rating_count }}
                {{ 'accessibility.total_reviews' | t -}}
              </span>
            </p>
          {%- endif -%}
        </div>
      </div>

      <div class="card__content">
        {% if card_product.metafields.custom.product_card_tags.value != blank or show_fast_shipping %}
          <div class="product-collection-card-icons">
            <div class="carousel-container" data-product-id="{{ card_product.id }}">
              <div class="icon-container">
                {% assign first_tag = true %}
                {% assign icon_index = 0 %}
                {% assign all_labels = '' %}

                {% for tag_icon in card_product.metafields.custom.product_card_tags.value %}
                  {% if tag_icon.product_tags_enable and tag_icon.product_tags_image %}
                    <img
                      src="{{ tag_icon.product_tags_image | img_url: '16x16' }}"
                      class="icon tag-icon-{{ icon_index }}{% if first_tag %} active{% endif %}"
                      width="16"
                      height="16"
                      style="width:16px;height:16px;object-fit:contain;"
                      alt="{{ tag_icon.product_tags_label | default: 'Product tag' }}"
                      title="{{ tag_icon.product_tags_label | default: 'Product tag' }}"
                      data-tag-type="{{ tag_icon.icon_type | default: 'tag' }}"
                      loading="lazy"
                    >
                    {% assign first_tag = false %}
                    {% assign icon_index = icon_index | plus: 1 %}
                    {% assign all_labels = all_labels | append: tag_icon.product_tags_label | append: '|' %}
                  {% endif %}
                {% endfor %}

                {% if show_fast_shipping %}
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Fast_Box.svg?v=1752218539"
                    class="icon tag-icon-{{ icon_index }}{% if first_tag %} active{% endif %}"
                    width="16"
                    height="16"
                    style="width:16px;height:16px;object-fit:contain;"
                    alt="Fast Shipping"
                    title="Fast Shipping"
                    data-tag-type="shipping"
                    loading="lazy"
                  >
                  {% assign first_tag = false %}
                  {% assign icon_index = icon_index | plus: 1 %}
                  {% assign all_labels = all_labels | append: 'Fast Shipping' | append: '|' %}
                {% endif %}

                {% if card_product.tags contains 'Engraving Available' %}
                  <img
                    src="https://www.lucirajewelry.com/cdn/shop/files/draw_1_50x.png?v=1751278108"
                    class="icon tag-icon-{{ icon_index }}{% if first_tag %} active{% endif %}"
                    width="16"
                    height="16"
                    style="width:16px;height:16px;object-fit:contain;"
                    alt="Engraving"
                    title="Engraving"
                    data-tag-type="engraving"
                    loading="lazy"
                  />
                  {% assign all_labels = all_labels | append: 'Engraving' | append: '|' %}
                {% endif %}
              </div>

              <div class="text-content">
                {% assign labels_array = all_labels | split: '|' %}
                {% if labels_array[0] != blank %}
                  {{ labels_array[0] }}
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}

        {% if max_discount > 0 %}
          <span class="label-amount">{{ max_discount }}% OFF</span>
        {% endif %}

        {% assign video = card_product.media | where: 'media_type', 'video' | first %}
        {% if video %}
          <div
            class="product-video-icon-wrapper"
            data-product-handle="{{ card_product.handle }}"
            data-video-id="{{ video.id }}"
            data-product-id="{{ card_product.id }}"
          >
            <img
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/play_circle.svg?v=1753099595"
              width="28"
              height="28"
              loading="lazy"
              alt="Play product video"
              title="Play product video"
              class="product-video-icon"
            >
          </div>
        {% endif %}

        <div class="card__information">
          <h3
            class="card__heading{% if card_product.featured_media or settings.card_style == 'standard' %} h5{% endif %}"
            {% if card_product.featured_media or settings.card_style == 'card' %}
              id="title-{{ section_id }}-{{ card_product.id }}"
            {% endif %}
          >
            <a
              href="{{ base_url }}{{ variant_url }}"
              id="CardLink-{{ section_id }}-{{ card_product.id }}"
              class="full-unstyled-link"
              aria-labelledby="CardLink-{{ section_id }}-{{ card_product.id }} Badge-{{ section_id }}-{{ card_product.id }}"
            >
              {{ card_product.title | escape }}
            </a>
          </h3>

          <div class="card-information price-details-wrapper">
            {%- if show_vendor -%}
              <span class="visually-hidden">{{ 'accessibility.vendor' | t }}</span>
              <div class="caption-with-letter-spacing light">{{ card_product.vendor }}</div>
            {%- endif -%}
            
            {% render 'price',
              product: card_product,
              use_variant: true,
              forced_variant: first_instock_variant,
              price_class: '',
              show_compare_at_price: true
            %}
            <a
              href="{{ base_url }}{{ variant_url }}"
              class="product-card-link"
            >
              View details {{ 'icon-right-arrow-cp.svg' | inline_asset_content }}
            </a>
          </div>

          <div class="discount-container">
            <div class="flip-wrapper {% if diamond_percent > 0 and mc_percent > 0 %}animate-flip{% endif %}">
              {% if diamond_percent > 0 %}
                <small class="discount-text" style="color: {{ discount_color }};">
                  {{ diamond_percent }}% OFF on Diamond Price
                </small>
              {% endif %}

              {% if mc_percent > 0 %}
                <small class="discount-text" style="color: {{ discount_color }};">
                  {{ mc_percent }}% OFF on Making Charges
                </small>
              {% endif %}
            </div>
          </div>

        </div>  

        <div class="card__badge {{ settings.badge_position }}">
          {%- if card_product.available == false -%}
            <span
              id="Badge-{{ section_id }}-{{ card_product.id }}"
              class="badge badge--bottom-left color-{{ settings.sold_out_badge_color_scheme }}"
            >
              {{- 'products.product.sold_out' | t -}}
            </span>
          {%- elsif card_product.compare_at_price > card_product.price and card_product.available -%}
            <span
              id="Badge-{{ section_id }}-{{ card_product.id }}"
              class="badge badge--bottom-left color-{{ settings.sale_badge_color_scheme }}"
            >
              {{- 'products.product.on_sale' | t -}}
            </span>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
{%- else -%}
  <div class="card-wrapper product-card-wrapper underline-links-hover">
    <div class="card card--{{ settings.card_style }}">
      <div class="card__inner">
        <div class="card__media">
          {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      </div>
      <div class="card__content">
        <h3 class="card__heading">
          <a class="full-unstyled-link">{{ 'onboarding.product_title' | t }}</a>
        </h3>
      </div>
    </div>
  </div>
{%- endif -%}