{%- if card_product and card_product != empty -%}
  {%- liquid
    assign ratio = 1.4
    if card_product.featured_media and media_aspect_ratio == 'portrait'
      assign ratio = 0.72
    elsif card_product.featured_media and media_aspect_ratio == 'adapt'
      assign ratio = card_product.featured_media.aspect_ratio
    endif
    if ratio == 0 or ratio == null
      assign ratio = 1.4
    endif
  -%}

  {%- assign first_instock_variant = nil -%}
  {%- assign is_9kt_collection = false -%}
  {%- assign current_collection_handle = collection.handle | default: '' -%}
  
  {%- comment -%} Check if product is in 9kt-collection {%- endcomment -%}
  {%- for collection in card_product.collections -%}
    {%- if collection.handle == '9kt-collection' -%}
      {%- assign is_9kt_collection = true -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} First in-stock variant logic {%- endcomment -%}
  {%- if current_collection_handle == '9kt-collection' and is_9kt_collection -%}
    {%- comment -%} On 9kt-collection page viewing 9kt products: Skip first_instock_variant logic {%- endcomment -%}
  {%- else -%}
    {%- for v in card_product.variants -%}
      {%- if v.inventory_quantity > 0 -%}
        {%- assign first_instock_variant = v -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  {%- comment -%} Simplified URL construction {%- endcomment -%}
  {% assign product_url = card_product.url %}
  {% if first_instock_variant %}
    {% if card_product.url contains '?' %}
      {% assign product_url = product_url | append: '&variant=' | append: first_instock_variant.id %}
    {% else %}
      {% assign product_url = product_url | append: '?variant=' | append: first_instock_variant.id %}
    {% endif %}
  {% endif %}

  <div
    class="card-wrapper product-card-wrapper underline-links-hover card_{{ forloop.index0 }}"
    data-product-handle="{{ card_product.handle }}"
  >
    <div
      class="
        card card--{{ settings.card_style }}
        {% if card_product.featured_media %} card--media{% else %} card--text{% endif %}
        {% if settings.card_style == 'card' %} color-{{ settings.card_color_scheme }} gradient{% endif %}
        {% if image_shape and image_shape != 'default' %} card--shape{% endif %}
        {% if extend_height %} card--extend-height{% endif %}
        {% if card_product.featured_media == nil and settings.card_style == 'card' %} ratio{% endif %}
        {% if horizontal_class %} card--horizontal{% endif %}
      "
      style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
      data-product-id="{{ card_product.id }}"
    >
      <div
        class="card__inner {% if settings.card_style == 'standard' %}color-{{ settings.card_color_scheme }} gradient{% endif %}{% if card_product.featured_media or settings.card_style == 'standard' %} ratio{% endif %} {% if section.settings.portrait_mobile_only %}portrait-mobile-only{% endif %}"
        style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
      >
        {%- if card_product.featured_media -%}
          {%- comment -%} Simplified Media Selection - Primary and Secondary only {%- endcomment -%}
          {%- assign primary_media = nil -%}
          {%- assign secondary_media = nil -%}

          {%- comment -%} Get primary media {%- endcomment -%}
          {%- if first_instock_variant and first_instock_variant.featured_media -%}
            {%- assign primary_media = first_instock_variant.featured_media -%}
          {%- elsif card_product.featured_media -%}
            {%- assign primary_media = card_product.featured_media -%}
          {%- endif -%}

          {%- comment -%} Get secondary media - simplified logic {%- endcomment -%}
          {%- if show_secondary_image -%}
            {%- comment -%} Priority: MQ alt text image {%- endcomment -%}
            {%- for media in card_product.media -%}
              {%- assign alt_text = media.alt | default: '' | downcase | strip -%}
              {%- if media.media_type == 'image' and media.id != primary_media.id and alt_text == 'mq' -%}
                {%- assign secondary_media = media -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}

            {%- comment -%} Fallback: Next available image {%- endcomment -%}
            {%- if secondary_media == nil -%}
              {%- for media in card_product.media -%}
                {%- if media.media_type == 'image' and media.id != primary_media.id -%}
                  {%- assign secondary_media = media -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          {%- endif -%}

          <a
            href="{{ product_url }}"
            class="product-image-link"
            aria-label="{{ card_product.title | escape }}"
          >
            <div class="card__media{% if image_shape and image_shape != 'default' %} shape--{{ image_shape }} color-{{ settings.card_color_scheme }} gradient{% endif %}">
              <div class="media media--transparent media--hover-effect">
                {%- if primary_media -%}
                  <img
                    class="motion-reduce primary-image"
                    srcset="
                      {%- if primary_media.width >= 165 -%}{{ primary_media | image_url: width: 165 }} 165w,{%- endif -%}
                      {%- if primary_media.width >= 360 -%}{{ primary_media | image_url: width: 360 }} 360w,{%- endif -%}
                      {%- if primary_media.width >= 533 -%}{{ primary_media | image_url: width: 533 }} 533w,{%- endif -%}
                      {{ primary_media | image_url }} {{ primary_media.width }}w
                    "
                    src="{{ primary_media | image_url: width: 533 }}"
                    sizes="(min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                    alt="{{ primary_media.alt | default: card_product.title | escape }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                  {%- if show_secondary_image and secondary_media -%}
                    <img
                      class="motion-reduce secondary-image"
                      src="{{ secondary_media | image_url: width: 533 }}"
                      srcset="
                        {%- if secondary_media.width >= 165 -%}{{ secondary_media | image_url: width: 165 }} 165w,{%- endif -%}
                        {%- if secondary_media.width >= 360 -%}{{ secondary_media | image_url: width: 360 }} 360w,{%- endif -%}
                        {%- if secondary_media.width >= 533 -%}{{ secondary_media | image_url: width: 533 }} 533w,{%- endif -%}
                        {{ secondary_media | image_url }} {{ secondary_media.width }}w
                      "
                      sizes="(min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                      alt="{{ secondary_media.alt | default: card_product.title | escape }}"
                      loading="lazy"
                      width="400"
                      height="400"
                    >
                  {%- endif -%}
                {%- else -%}
                  {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>
          </a>
        {%- endif -%}

        <div class="card__content">
          <div class="card__information">
            <div class="card__heading">
              <a
                href="{{ product_url }}"
                class="full-unstyled-link"
                target="_blank"
              >
                {{ card_product.title | escape }}
              </a>
            </div>
          </div>
          <div class="card__badge {{ settings.badge_position }}">
            {%- if card_product.available == false -%}
              <span class="badge badge--bottom-left color-{{ settings.sold_out_badge_color_scheme }}">
                {{- 'products.product.sold_out' | t -}}
              </span>
            {%- elsif card_product.compare_at_price > card_product.price and card_product.available -%}
              <span class="badge badge--bottom-left color-{{ settings.sale_badge_color_scheme }}">
                {{- 'products.product.on_sale' | t -}}
              </span>
            {%- endif -%}
          </div>
        </div>
      </div>
      
      <div class="card-content-wrapper">
        {%- comment -%} Rating Section {%- endcomment -%}
        <div class="card__rating">
          {%- if show_rating and card_product.metafields.reviews.rating.value != blank -%}
            {% liquid
              assign rating_decimal = 0
              assign decimal = card_product.metafields.reviews.rating.value.rating | modulo: 1
              if decimal >= 0.3 and decimal <= 0.7
                assign rating_decimal = 0.5
              elsif decimal > 0.7
                assign rating_decimal = 1
              endif
            %}
            <div
              class="rating"
              role="img"
              aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: card_product.metafields.reviews.rating.value, rating_max: card_product.metafields.reviews.rating.value.scale_max }}"
            >
              <span
                aria-hidden="true"
                class="rating-star desktop-show"
                style="--rating: {{ card_product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ card_product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"
              ></span>
              <span class="">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 10" height="10" width="10">
                  <path fill="#FEC602" d="M5 8.3747L7.42493 9.90932C7.86901 10.1906 8.41243 9.77481 8.29556 9.24901L7.65281 6.36318L9.79727 4.41892C10.1888 4.0643 9.97841 3.39176 9.4642 3.34896L6.64194 3.09829L5.53757 0.371428C5.33891 -0.123809 4.6611 -0.123809 4.46243 0.371428L3.35806 3.09217L0.535797 3.34285C0.021595 3.38565 -0.18876 4.05819 0.202734 4.4128L2.34719 6.35707L1.70444 9.24289C1.58757 9.7687 2.13099 10.1845 2.57507 9.90321L5 8.3747Z"></path>
                </svg>
              </span>
            </div>
            <p class="rating-text caption">
              <span aria-hidden="true">{{ card_product.metafields.reviews.rating.value }}</span>
            </p>
            <p class="rating-count caption">
              <span aria-hidden="true">({{ card_product.metafields.reviews.rating_count }})</span>
            </p>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Fast Shipping Logic {%- endcomment -%}
      {% assign show_fast_shipping = false %}
      
      {% if current_collection_handle == '9kt-collection' %}
        {% for v in card_product.variants %}
          {% if v.available %}
            {% assign variant_title_lower = v.title | downcase %}
            {% if variant_title_lower contains '9kt' or variant_title_lower contains '9 kt' %}
              {% if v.inventory_management %}
                {% if v.inventory_quantity > 0 %}
                  {% assign show_fast_shipping = true %}
                  {% break %}
                {% endif %}
              {% else %}
                {% assign show_fast_shipping = true %}
                {% break %}
              {% endif %}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% else %}
        {% for v in card_product.variants %}
          {% if v.available %}
            {% if v.inventory_management %}
              {% if v.inventory_quantity > 0 %}
                {% assign show_fast_shipping = true %}
                {% break %}
              {% endif %}
            {% else %}
              {% assign show_fast_shipping = true %}
              {% break %}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endif %}

      <div class="card__content">
        {%- comment -%} Product Tags and Icons {%- endcomment -%}
        {% if card_product.metafields.custom.product_card_tags.value != blank or show_fast_shipping %}
          <div class="product-collection-card-icons">
            <div class="carousel-container" data-product-id="{{ card_product.id }}">
              <div class="icon-container">
                {% assign first_tag = true %}
                {% assign icon_index = 0 %}
                {% assign all_labels = '' %}

                {% for tag_icon in card_product.metafields.custom.product_card_tags.value %}
                  {% if tag_icon.product_tags_enable and tag_icon.product_tags_image %}
                    <img
                      src="{{ tag_icon.product_tags_image | img_url: '16x16' }}"
                      class="icon tag-icon-{{ icon_index }}{% if first_tag %} active{% endif %}"
                      width="16"
                      height="16"
                      style="width:16px;height:16px;object-fit:contain;"
                      alt="{{ tag_icon.product_tags_label | default: 'Product tag' }}"
                      loading="lazy"
                    >
                    {% assign first_tag = false %}
                    {% assign icon_index = icon_index | plus: 1 %}
                    {% assign all_labels = all_labels | append: tag_icon.product_tags_label | append: '|' %}
                  {% endif %}
                {% endfor %}

                {% if show_fast_shipping %}
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Fast_Box.svg?v=1752218539"
                    class="icon tag-icon-{{ icon_index }}{% if first_tag %} active{% endif %}"
                    width="16"
                    height="16"
                    style="width:16px;height:16px;object-fit:contain;"
                    alt="Fast Shipping"
                    loading="lazy"
                  >
                  {% assign first_tag = false %}
                  {% assign icon_index = icon_index | plus: 1 %}
                  {% assign all_labels = all_labels | append: 'Fast Shipping' | append: '|' %}
                {% endif %}

                {% if card_product.tags contains 'Engraving Available' %}
                  <img
                    src="https://www.lucirajewelry.com/cdn/shop/files/draw_1_50x.png?v=1751278108"
                    class="icon tag-icon-{{ icon_index }}{% if first_tag %} active{% endif %}"
                    width="16"
                    height="16"
                    style="width:16px;height:16px;object-fit:contain;"
                    alt="Engraving"
                    loading="lazy"
                  >
                  {% assign first_tag = false %}
                  {% assign icon_index = icon_index | plus: 1 %}
                  {% assign all_labels = all_labels | append: 'Engraving' | append: '|' %}
                {% endif %}
              </div>

              <div class="text-content">
                {% assign labels_array = all_labels | split: '|' %}
                {% if labels_array[0] != blank %}
                  {{ labels_array[0] }}
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}

        {%- comment -%} Discount Badge {%- endcomment -%}
        {% for variant in card_product.variants %}
          {% if variant.compare_at_price and variant.compare_at_price > variant.price %}
            {% assign discount = variant.compare_at_price | minus: variant.price %}
            {% assign discount_percent = discount | times: 100.0 | divided_by: variant.compare_at_price %}
            <span class="label-amount">{{ discount_percent | round }}% OFF</span>
            {% break %}
          {% endif %}
        {% endfor %}

        <div class="card__information">
          <h3 class="card__heading{% if card_product.featured_media or settings.card_style == 'standard' %} h5{% endif %}">
            <a
              href="{{ product_url }}"
              class="full-unstyled-link"
            >
              {{ card_product.title | escape }}
            </a>
          </h3>
          <div class="card-information price-details-wrapper">
            {%- if show_vendor -%}
              <span class="visually-hidden">{{ 'accessibility.vendor' | t }}</span>
              <div class="caption-with-letter-spacing light">{{ card_product.vendor }}</div>
            {%- endif -%}

            {% render 'price',
              product: card_product,
              use_variant: true,
              forced_variant: first_instock_variant,
              price_class: '',
              show_compare_at_price: true
            %}
            <a href="{{ product_url }}" class="product-card-link">
              View details {{ 'icon-right-arrow-cp.svg' | inline_asset_content }}
            </a>
          </div>
        </div>

        <div class="card__badge {{ settings.badge_position }}">
          {%- if card_product.available == false -%}
            <span class="badge badge--bottom-left color-{{ settings.sold_out_badge_color_scheme }}">
              {{- 'products.product.sold_out' | t -}}
            </span>
          {%- elsif card_product.compare_at_price > card_product.price and card_product.available -%}
            <span class="badge badge--bottom-left color-{{ settings.sale_badge_color_scheme }}">
              {{- 'products.product.on_sale' | t -}}
            </span>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
{%- else -%}
  <div class="card-wrapper product-card-wrapper underline-links-hover">
    <div class="card card--{{ settings.card_style }}">
      <div class="card__inner">
        <div class="card__media">
          {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      </div>
      <div class="card__content">
        <h3 class="card__heading">
          <a class="full-unstyled-link">{{ 'onboarding.product_title' | t }}</a>
        </h3>
      </div>
    </div>
  </div>
{%- endif -%}
