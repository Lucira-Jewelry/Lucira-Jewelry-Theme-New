{%- if card_product and card_product != empty -%}
  {%- liquid
    # Fast path: Only compute absolute essentials
    assign ratio = 1.4
    if card_product.featured_media and media_aspect_ratio == 'portrait'
      assign ratio = 0.72
    elsif card_product.featured_media and media_aspect_ratio == 'adapt'
      assign ratio = card_product.featured_media.aspect_ratio
    endif
    if ratio == 0 or ratio == null
      assign ratio = 1.4
    endif
    
    # Minimal variant check - just get first available
    assign first_available_id = nil
    for variant in card_product.variants
      if variant.available and variant.inventory_quantity > 0
        assign first_available_id = variant.id
        break
      endif
    endfor
    
    # Check if in 9kt collection (fast path)
    assign is_9kt = false
    for collection in card_product.collections limit: 20
      if collection.handle == '9kt-collection'
        assign is_9kt = true
        break
      endif
    endfor
    
    assign base_url = card_product.url | split: '?' | first
    assign variant_param = ''
    if first_available_id
      assign variant_param = '?variant=' | append: first_available_id
    endif
  -%}

  <div class="card-wrapper product-card-wrapper"
       data-product-id="{{ card_product.id }}"
       data-product-handle="{{ card_product.handle }}"
       data-first-variant="{{ first_available_id }}"
       data-is-9kt="{{ is_9kt }}"
       data-product-json="{{ card_product | json | escape }}">
    
    <div class="card card--{{ settings.card_style }}"
         style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;">
      
      <!-- Image Section -->
      {%- if card_product.featured_media -%}
        <a href="{{ base_url }}{{ variant_param }}"
           class="product-image-link"
           aria-label="{{ card_product.title | escape }}">
          <div class="card__media">
            <div class="media media--transparent media--hover-effect">
              <!-- Primary Image -->
              <img class="primary-image motion-reduce"
                   src="{{ card_product.featured_media | image_url: width: 400 }}"
                   srcset="{{ card_product.featured_media | image_url: width: 400 }} 1x, {{ card_product.featured_media | image_url: width: 800 }} 2x"
                   alt="{{ card_product.title | escape }}"
                   loading="lazy"
                   width="400"
                   height="400"
                   data-primary>
              
              <!-- Secondary Image Placeholder (filled by JS) -->
              <img class="secondary-image motion-reduce"
                   style="display: none;"
                   alt="{{ card_product.title | escape }} - alternate view"
                   loading="lazy"
                   width="400"
                   height="400"
                   data-secondary>
            </div>
          </div>
        </a>
      {%- endif -%}

      <!-- Minimal Color Variants Container -->
      <div class="color-variants-options" data-color-container></div>

      <!-- Content -->
      <div class="card__content">
        <!-- Tags Container -->
        <div class="product-collection-card-icons" data-tags-container></div>

        <h3 class="card__heading h5">
          <a href="{{ base_url }}{{ variant_param }}" class="full-unstyled-link">
            {{- card_product.title | escape -}}
          </a>
        </h3>

        <!-- Price -->
        <div class="card-information price-details-wrapper">
          {% render 'price', 
            product: card_product,
            use_variant: true,
            forced_variant_id: first_available_id,
            show_compare_at_price: true
          %}
        </div>

        <!-- Discount Container (filled by JS) -->
        <div class="discount-container" data-discount-container>
          <div class="flip-wrapper"></div>
        </div>

        <!-- Badge -->
        <div class="card__badge {{ settings.badge_position }}">
          {%- if card_product.available == false -%}
            <span class="badge color-{{ settings.sold_out_badge_color_scheme }}">{{ 'products.product.sold_out' | t }}</span>
          {%- elsif card_product.compare_at_price > card_product.price -%}
            <span class="badge color-{{ settings.sale_badge_color_scheme }}">{{ 'products.product.on_sale' | t }}</span>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

{%- else -%}
  <!-- Placeholder -->
  <div class="card-wrapper product-card-wrapper">
    <div class="card card--{{ settings.card_style }}">
      <div class="card__inner">
        <div class="card__media">{{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}</div>
      </div>
      <div class="card__content">
        <h3 class="card__heading">{{ 'onboarding.product_title' | t }}</h3>
      </div>
    </div>
  </div>
{%- endif -%}