<script id="RazorpayMagicSSOConfig" type="application/json"> { "email": "{{customer.email}}", "phone": "{{customer.phone}}", "ssoConfig": {{shop.metafields.rzp.sso-config | json}} }</script>
<script>
  (function() {
    function loadRazorpay() {
      if (window.razorpayLoaded) return;
      window.razorpayLoaded = true;
      var script = document.createElement('script');
      script.src = "https://magic-plugins.razorpay.com/shopify-sso/shopify-sso.js";
      script.defer = true;
      // Copy the content from the config script if needed by the plugin
      document.head.appendChild(script);
    }

    var loadTimer = setTimeout(loadRazorpay, 5000);

    function triggerLoad() {
      loadRazorpay();
      clearTimeout(loadTimer);
      ['touchstart', 'mousemove', 'scroll', 'click', 'keydown'].forEach(function(e) {
        window.removeEventListener(e, triggerLoad);
      });
    }

    ['touchstart', 'mousemove', 'scroll', 'click', 'keydown'].forEach(function(e) {
      window.addEventListener(e, triggerLoad, { passive: true });
    });
  })();
</script>