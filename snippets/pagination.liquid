{% comment %}
  Fixed infinite scroll pagination - resolves issues after sort/filter operations
{% endcomment %}

{{ 'component-pagination.css' | asset_url | stylesheet_tag }}

{%- if paginate.parts.size > 0 -%}
  <div class="infinite-scroll-wrapper">
    <!-- Loading indicator -->
    <div id="infinite-scroll-loader" class="infinite-scroll-loader" style="display: none;">
      <div class="loader-content">
        <div class="elegant-dots">
          <div class="dot"></div>
          <div class="dot"></div>
          <div class="dot"></div>
        </div>
        <p class="loading-text">Discovering more exquisite pieces...</p>
      </div>
    </div>

    <!-- End of products indicator -->
    <div id="infinite-scroll-end" class="infinite-scroll-end" style="display: none;">
      <div class="end-content">
        <div class="end-decoration">
          <div class="luxury-line"></div>
          <div class="end-diamond">◆</div>
          <div class="luxury-line"></div>
        </div>
        <p class="end-text">You've explored our complete collection</p>
        <p class="end-subtitle">Every piece tells a story of elegance</p>
      </div>
    </div>

    <!-- Hidden next page URL for JavaScript -->
    <div id="next-page-data" 
         data-next-url="{%- if paginate.next -%}{{ paginate.next.url }}{{ anchor }}{%- endif -%}"
         data-current-page="{{ paginate.current_page }}"
         data-total-pages="{{ paginate.pages }}"
         style="display: none;">
    </div>
  </div>

  <!-- Include your existing CSS styles here -->
  <style>
    .infinite-scroll-wrapper {
      margin-top: 3rem;
      text-align: center;
    }

    .infinite-scroll-loader {
      padding: 2rem 0;
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .infinite-scroll-loader.show {
      opacity: 1;
      transform: translateY(0);
    }

    .infinite-scroll-end {
      padding: 3rem 0;
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .infinite-scroll-end.show {
      opacity: 1;
      transform: translateY(0);
    }

    .loader-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    .elegant-dots {
      display: flex;
      gap: 0.8rem;
      align-items: center;
    }

    .elegant-dots .dot {
      width: 8px;
      height: 8px;
      background: linear-gradient(135deg, #d4af37, #ffd700);
      border-radius: 50%;
      animation: elegantPulse 1.8s ease-in-out infinite;
      box-shadow: 0 2px 8px rgba(212, 175, 55, 0.3);
      display: block !important;
    }

    .elegant-dots .dot:nth-child(1) { animation-delay: 0s; }
    .elegant-dots .dot:nth-child(2) { animation-delay: 0.3s; }
    .elegant-dots .dot:nth-child(3) { animation-delay: 0.6s; }

    @keyframes elegantPulse {
      0%, 60%, 100% {
        transform: scale(1);
        opacity: 0.7;
      }
      30% {
        transform: scale(1.3);
        opacity: 1;
      }
    }

    .loading-text {
      margin: 0;
      color: #8b7355;
      font-size: 0.95rem;
      font-weight: 400;
      letter-spacing: 0.5px;
      font-family: 'Georgia', serif;
    }

    .end-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      max-width: 400px;
      margin: 0 auto;
    }

    .end-decoration {
      display: flex;
      align-items: center;
      gap: 1rem;
      width: 100%;
      max-width: 280px;
    }

    .luxury-line {
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, transparent, #d4af37, transparent);
      display: block !important;
    }

    .end-diamond {
      color: #d4af37;
      font-size: 1.2rem;
      animation: diamondShine 2s ease-in-out infinite;
    }

    @keyframes diamondShine {
      0%, 100% {
        opacity: 0.7;
        transform: scale(1);
      }
      50% {
        opacity: 1;
        transform: scale(1.1);
      }
    }

    .end-text {
      margin: 0;
      color: #6b5b73;
      font-size: 18px;
      font-weight: 500;
      letter-spacing: 0.3px;
      font-family: 'Georgia', serif;
    }

    .end-subtitle {
      margin: 0;
      color: #9b8aa3;
      font-size: 14px;
      font-weight: 400;
      font-style: italic;
      letter-spacing: 0.2px;
      font-family: 'Georgia', serif;
    }

    .product-fade-in {
      opacity: 0;
      transform: translateY(15px);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .product-fade-in.animate {
      opacity: 1;
      transform: translateY(0);
    }

    .product-fade-in:nth-child(1) { transition-delay: 0.05s; }
    .product-fade-in:nth-child(2) { transition-delay: 0.1s; }
    .product-fade-in:nth-child(3) { transition-delay: 0.15s; }
    .product-fade-in:nth-child(4) { transition-delay: 0.2s; }
    .product-fade-in:nth-child(5) { transition-delay: 0.25s; }
    .product-fade-in:nth-child(6) { transition-delay: 0.3s; }
    .product-fade-in:nth-child(7) { transition-delay: 0.35s; }
    .product-fade-in:nth-child(8) { transition-delay: 0.4s; }

    @media (max-width: 768px) {
      .infinite-scroll-wrapper { margin-top: 2rem; }
      .elegant-dots .dot { width: 6px; height: 6px; }
      .loading-text { font-size: 0.85rem; }
      .end-text { font-size: 1rem; }
      .end-subtitle { font-size: 0.8rem; }
      .infinite-scroll-loader { padding: 1.5rem 0; }
      .infinite-scroll-end { padding: 2rem 0; }
    }
  </style>

  <script>
    (function() {
      // Improved global state management
      window.infiniteScrollState = window.infiniteScrollState || {
        cleanup: null,
        loadedProductIds: new Set(),
        isInitialized: false,
        lastInitTime: 0,
        currentUrl: window.location.href,
        currentSearchParams: new URLSearchParams(window.location.search).toString(),
        observer: null,
        scrollHandler: null,
        mutationObserver: null,
        isLoading: false,
        hasNextPage: true
      };

      function debugLog(message, data = {}) {
        console.log(`[InfiniteScroll] ${message}`, data);
      }

      function completeCleanup() {
        const state = window.infiniteScrollState;
        
        if (state.scrollHandler) {
          window.removeEventListener('scroll', state.scrollHandler);
          state.scrollHandler = null;
        }
        
        if (state.observer) {
          state.observer.disconnect();
          state.observer = null;
        }
        
        if (state.mutationObserver) {
          state.mutationObserver.disconnect();
          state.mutationObserver = null;
        }
        
        state.isInitialized = false;
        state.isLoading = false;
        
        debugLog('Complete cleanup performed');
      }

      function hasUrlOrParamsChanged() {
        const currentUrl = window.location.href;
        const currentSearchParams = new URLSearchParams(window.location.search).toString();
        const state = window.infiniteScrollState;
        
        const urlChanged = state.currentUrl !== currentUrl;
        const paramsChanged = state.currentSearchParams !== currentSearchParams;
        
        if (urlChanged || paramsChanged) {
          state.currentUrl = currentUrl;
          state.currentSearchParams = currentSearchParams;
          debugLog('URL/params changed', { urlChanged, paramsChanged });
          return true;
        }
        
        return false;
      }

      function resetUIElements() {
        const loader = document.getElementById('infinite-scroll-loader');
        const endIndicator = document.getElementById('infinite-scroll-end');
        
        if (loader) {
          loader.style.display = 'none';
          loader.classList.remove('show');
        }
        
        if (endIndicator) {
          endIndicator.style.display = 'none';
          endIndicator.classList.remove('show');
        }
        
        debugLog('UI elements reset');
      }

      function waitForElement(selector, timeout = 5000) {
        return new Promise((resolve) => {
          const element = document.querySelector(selector);
          if (element) {
            resolve(element);
            return;
          }

          const observer = new MutationObserver((mutations, obs) => {
            const element = document.querySelector(selector);
            if (element) {
              obs.disconnect();
              resolve(element);
            }
          });

          observer.observe(document.body, {
            childList: true,
            subtree: true
          });

          setTimeout(() => {
            observer.disconnect();
            resolve(null);
          }, timeout);
        });
      }

      async function initInfiniteScroll() {
        debugLog('Starting initialization...');
        
        const currentTime = Date.now();
        const state = window.infiniteScrollState;
        
        // Prevent rapid reinitializations
        if (state.isInitialized && currentTime - state.lastInitTime < 1000) {
          debugLog('Skipping rapid reinitialization');
          return;
        }

        // Complete cleanup of previous instance
        completeCleanup();
        
        // Wait for essential elements
        const productGrid = await waitForElement('#product-grid', 3000);
        const nextPageData = await waitForElement('#next-page-data', 3000);
        const loader = document.getElementById('infinite-scroll-loader');
        const endIndicator = document.getElementById('infinite-scroll-end');
        
        debugLog('Elements found:', {
          productGrid: !!productGrid,
          loader: !!loader,
          endIndicator: !!endIndicator,
          nextPageData: !!nextPageData
        });
        
        if (!productGrid || !loader || !endIndicator || !nextPageData) {
          debugLog('Missing critical elements, aborting');
          return;
        }

        // Reset state for new page/filter
        if (hasUrlOrParamsChanged()) {
          state.loadedProductIds.clear();
          debugLog('Cleared product IDs due to URL change');
        }

        resetUIElements();

        // Get pagination data
        const currentPage = parseInt(nextPageData.dataset.currentPage) || 1;
        const totalPages = parseInt(nextPageData.dataset.totalPages) || 1;
        let nextUrl = nextPageData.dataset.nextUrl || '';
        
        debugLog('Pagination data:', { currentPage, totalPages, nextUrl });

        // Product management functions
        function getProductIdentifier(productElement) {
          return productElement.dataset.productId || 
                 productElement.dataset.id || 
                 productElement.dataset.productHandle ||
                 productElement.getAttribute('data-product-handle') ||
                 productElement.id ||
                 productElement.querySelector('a[href*="/products/"]')?.href.split('/products/')[1]?.split('?')[0] ||
                 Array.from(productElement.classList).find(c => c.includes('product')) ||
                 productElement.innerHTML.slice(0, 50);
        }

        function isProductDuplicate(productElement) {
          const id = getProductIdentifier(productElement);
          const isDuplicate = id && state.loadedProductIds.has(id);
          if (isDuplicate) {
            debugLog('Found duplicate product:', id);
          }
          return isDuplicate;
        }

        function markProductAsLoaded(productElement) {
          const id = getProductIdentifier(productElement);
          if (id) {
            state.loadedProductIds.add(id);
          }
        }

        // Build initial product set from current page
        const productSelectors = [
          '[data-product-id]', 
          '.product-card', 
          '.card-product', 
          '[class*="product"]', 
          '.grid-item',
          '.product',
          '.product-item'
        ];
        
        let existingProducts = [];
        for (const selector of productSelectors) {
          existingProducts = productGrid.querySelectorAll(selector);
          if (existingProducts.length > 0) break;
        }
        
        debugLog('Found existing products:', existingProducts.length);
        
        existingProducts.forEach(product => {
          markProductAsLoaded(product);
        });

        // State variables
        state.isLoading = false;
        state.hasNextPage = nextUrl !== '' && currentPage < totalPages;
        let currentPageNum = currentPage;

        debugLog('Initial state:', { 
          hasNextPage: state.hasNextPage, 
          currentPageNum, 
          totalPages,
          loadedProductsCount: state.loadedProductIds.size 
        });

        // UI functions
        function showLoader() {
          if (loader && state.hasNextPage && !state.isLoading) {
            loader.style.display = 'block';
            requestAnimationFrame(() => {
              loader.classList.add('show');
            });
          }
        }

        function hideLoader() {
          if (loader) {
            loader.classList.remove('show');
            setTimeout(() => {
              if (loader) loader.style.display = 'none';
            }, 400);
          }
        }

        function showEndIndicator() {
          if (endIndicator && !state.hasNextPage) {
            endIndicator.style.display = 'block';
            requestAnimationFrame(() => {
              endIndicator.classList.add('show');
            });
          }
        }

        function animateNewProducts(newProducts) {
          newProducts.forEach((product, index) => {
            product.classList.add('product-fade-in');
            setTimeout(() => {
              product.classList.add('animate');
            }, index * 50); // Slightly longer delay for smoother effect
          });
        }
        
        // Initialize wishlist and other components
        function reinitializeComponents() {
          try {
            // iWish wishlist
            if (typeof iWish !== 'undefined' && typeof iWish.init === 'function') {
              iWish.init();
            }
            
            // Custom events
            document.dispatchEvent(new CustomEvent('iwish:reload'));
            document.dispatchEvent(new CustomEvent('wishlist:init'));
            document.dispatchEvent(new CustomEvent('infiniteScroll:newProducts'));
            
            if (typeof iWishCounter === 'function') {
              iWishCounter();
            }
            
            debugLog('Components reinitialized');
          } catch (error) {
            debugLog('Component init error:', error);
          }
        }

        // Load next page function
        async function loadNextPage() {
          if (state.isLoading || !state.hasNextPage) {
            debugLog('Cannot load next page:', { 
              isLoading: state.isLoading, 
              hasNextPage: state.hasNextPage 
            });
            return false;
          }

          debugLog('Loading next page...', { currentPageNum, nextUrl });
          state.isLoading = true;
          showLoader();

          try {
            const response = await fetch(nextUrl, {
              method: 'GET',
              headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'Cache-Control': 'no-cache'
              }
            });
            
            if (!response.ok) {
              throw new Error(`HTTP ${response.status}: ${response.statusText}`);
            }
            
            const text = await response.text();
            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = text;
            
            // Find new products
            const newProductGrid = tempDiv.querySelector('#product-grid');
            if (!newProductGrid) {
              debugLog('No product grid found in response');
              state.hasNextPage = false;
              return false;
            }
            
            const allNewProducts = Array.from(newProductGrid.children);
            const newNextPageData = tempDiv.querySelector('#next-page-data');
            
            debugLog('Response analysis:', { 
              totalProducts: allNewProducts.length,
              hasNewPageData: !!newNextPageData 
            });
            
            // Filter out duplicates
            const uniqueNewProducts = allNewProducts.filter(product => 
              !isProductDuplicate(product)
            );
            
            debugLog('Filtered products:', { 
              unique: uniqueNewProducts.length,
              total: allNewProducts.length 
            });
            
            if (uniqueNewProducts.length > 0) {
              // Add products to grid
              uniqueNewProducts.forEach(product => {
                markProductAsLoaded(product);
                productGrid.appendChild(product);
              });

              // Reinitialize components
              setTimeout(() => {
                reinitializeComponents();
                animateNewProducts(uniqueNewProducts);
              }, 100);

              // Update pagination state
              currentPageNum++;
              if (newNextPageData) {
                const newNextUrl = newNextPageData.dataset.nextUrl || '';
                const newTotalPages = parseInt(newNextPageData.dataset.totalPages) || totalPages;
                
                nextPageData.dataset.nextUrl = newNextUrl;
                nextPageData.dataset.currentPage = currentPageNum.toString();
                nextUrl = newNextUrl;
                
                state.hasNextPage = newNextUrl !== '' && currentPageNum < newTotalPages;
              } else {
                state.hasNextPage = false;
              }

              debugLog('Updated pagination:', { 
                currentPageNum, 
                hasNextPage: state.hasNextPage,
                nextUrl: nextUrl.slice(0, 50) + '...'
              });

              // Re-observe new products
              setTimeout(() => observeLastProducts(), 200);
              
              return true;
            } else {
              debugLog('No new unique products, ending pagination');
              state.hasNextPage = false;
              return false;
            }

          } catch (error) {
            debugLog('Load error:', error);
            state.hasNextPage = false;
            return false;
          } finally {
            state.isLoading = false;
            hideLoader();
            
            if (!state.hasNextPage) {
              showEndIndicator();
            }
          }
        }

        // Scroll detection
        function shouldLoadMore() {
          const scrollTop = window.scrollY || document.documentElement.scrollTop;
          const windowHeight = window.innerHeight;
          const documentHeight = Math.max(
            document.body.scrollHeight, 
            document.documentElement.scrollHeight
          );
          
          const scrollPercentage = (scrollTop + windowHeight) / documentHeight;
          const shouldLoad = scrollPercentage > 0.8; // Trigger earlier for better UX
          
          if (shouldLoad) {
            debugLog('Scroll trigger activated', { scrollPercentage: scrollPercentage.toFixed(2) });
          }
          
          return shouldLoad;
        }

        // Improved scroll handler with debouncing
        let scrollTimeout;
        function handleScroll() {
          if (scrollTimeout) {
            clearTimeout(scrollTimeout);
          }
          
          scrollTimeout = setTimeout(() => {
            if (shouldLoadMore() && state.hasNextPage && !state.isLoading) {
              loadNextPage();
            }
          }, 150); // Slightly longer debounce for better performance
        }

        // Intersection observer for last products
        function observeLastProducts() {
          if (state.observer) {
            state.observer.disconnect();
          }
          
          const products = Array.from(productGrid.children);
          if (products.length >= 2 && 'IntersectionObserver' in window) {
            state.observer = new IntersectionObserver((entries) => {
              entries.forEach(entry => {
                if (entry.isIntersecting && state.hasNextPage && !state.isLoading) {
                  debugLog('Intersection observer triggered');
                  loadNextPage();
                }
              });
            }, {
              root: null,
              rootMargin: '800px 0px', // Increased margin for earlier loading
              threshold: 0.1
            });

            // Observe last few products
            const observeCount = Math.min(4, products.length);
            const startIndex = Math.max(0, products.length - observeCount);
            
            for (let i = startIndex; i < products.length; i++) {
              if (products[i]) {
                state.observer.observe(products[i]);
              }
            }
            
            debugLog('Observing products:', { 
              count: observeCount, 
              total: products.length,
              startIndex 
            });
          }
        }

        // Set up event listeners
        state.scrollHandler = handleScroll;
        window.addEventListener('scroll', state.scrollHandler, { passive: true });

        // Initialize based on current state
        if (currentPageNum >= totalPages) {
          debugLog('All pages already loaded');
          state.hasNextPage = false;
          showEndIndicator();
        } else if (state.hasNextPage) {
          debugLog('Setting up observers and initial load check');
          
          // Set up intersection observer
          setTimeout(() => {
            observeLastProducts();
            
            // For pages with few products, show a brief loader hint
            if (existingProducts.length < 8) {
              showLoader();
              setTimeout(() => {
                if (!state.isLoading) hideLoader();
              }, 2000);
            }
          }, 500);
        }

        // Mark as initialized
        state.isInitialized = true;
        state.lastInitTime = currentTime;
        state.cleanup = completeCleanup;
        
        debugLog('Initialization complete', {
          hasNextPage: state.hasNextPage,
          currentPage: currentPageNum,
          totalPages: totalPages,
          productsLoaded: state.loadedProductIds.size
        });
      }

      // Enhanced reinitialization function
      window.reinitInfiniteScroll = function(delay = 800) {
        debugLog('Reinitializing infinite scroll', { delay });
        
        completeCleanup();
        
        setTimeout(() => {
          // Additional cleanup and reset
          const state = window.infiniteScrollState;
          state.loadedProductIds.clear();
          state.currentUrl = window.location.href;
          state.currentSearchParams = new URLSearchParams(window.location.search).toString();
          
          resetUIElements();
          
          // Wait a bit more before reinit to ensure DOM is stable
          setTimeout(initInfiniteScroll, 300);
        }, delay);
      };

      // Event listeners for collection changes
      const collectionEvents = [
        'facetsLoaded',
        'collectionFiltered', 
        'collectionSorted',
        'ajaxProductsLoaded',
        'DOMContentLoaded'
      ];

      collectionEvents.forEach(eventName => {
        document.addEventListener(eventName, () => {
          debugLog(`Event received: ${eventName}`);
          setTimeout(() => window.reinitInfiniteScroll(), 600);
        });
      });

      // Enhanced URL change detection
      let lastUrl = window.location.href;
      let lastSearch = window.location.search;
      
      function checkForChanges() {
        const currentUrl = window.location.href;
        const currentSearch = window.location.search;
        
        if (currentUrl !== lastUrl || currentSearch !== lastSearch) {
          debugLog('URL or search params changed');
          lastUrl = currentUrl;
          lastSearch = currentSearch;
          setTimeout(() => window.reinitInfiniteScroll(), 400);
        }
      }

      // Listen for various navigation events
      window.addEventListener('popstate', checkForChanges);
      window.addEventListener('pushstate', checkForChanges);
      window.addEventListener('replacestate', checkForChanges);
      
      // Periodic check as fallback
      setInterval(checkForChanges, 2000);

      // Enhanced DOM change detection
      setTimeout(() => {
        const productGrid = document.getElementById('product-grid');
        if (productGrid) {
          const gridObserver = new MutationObserver((mutations) => {
            let shouldReinit = false;
            
            mutations.forEach((mutation) => {
              if (mutation.type === 'childList' && mutation.target === productGrid) {
                // Check if this was a significant change (filter/sort)
                const addedNodes = Array.from(mutation.addedNodes);
                const removedNodes = Array.from(mutation.removedNodes);
                
                // If many products were replaced at once, it's likely a filter/sort
                if (removedNodes.length > 2 || 
                   (addedNodes.length > 0 && removedNodes.length > 0)) {
                  shouldReinit = true;
                  debugLog('Significant product grid change detected');
                }
              }
            });
            
            if (shouldReinit) {
              setTimeout(() => window.reinitInfiniteScroll(), 700);
            }
          });
          
          window.infiniteScrollState.mutationObserver = gridObserver;
          gridObserver.observe(productGrid, { 
            childList: true, 
            subtree: false 
          });
        }
      }, 1000);

      // Initialize when DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          setTimeout(initInfiniteScroll, 200);
        });
      } else {
        setTimeout(initInfiniteScroll, 200);
      }

    })();
  </script>
{%- endif -%}