{% comment %}
  Renders ultra-fast infinite scroll pagination for products. Must be used within paginate tags.

  Preloads content instantly so users never wait. Fixed duplicate prevention.

  Usage:
  {% paginate results by 2 %}
    {% render 'infinite-scroll-pagination', paginate: paginate, anchor: '#yourID' %}
  {% endpaginate %}

  Accepts:
  - paginate: {Object}
  - anchor: {String} (optional)
{% endcomment %}

{{ 'component-pagination.css' | asset_url | stylesheet_tag }}

{%- if paginate.parts.size > 0 -%}
  <div class="infinite-scroll-wrapper">
    <!-- Loading indicator (elegant dots for luxury) -->
    <div id="infinite-scroll-loader" class="infinite-scroll-loader" style="display: none;">
      <div class="loader-content">
        <div class="elegant-dots">
          <div class="dot"><span style="display: none">.</span></div>
          <div class="dot"><span style="display: none">.</span></div>
          <div class="dot"><span style="display: none">.</span></div>
        </div>
        <p class="loading-text">Discovering more exquisite pieces...</p>
      </div>
    </div>

    <!-- End of products indicator - MOVED INSIDE THE IF CONDITION -->
    <div id="infinite-scroll-end" class="infinite-scroll-end" style="display: none;">
      <div class="end-content">
        <div class="end-decoration">
          <div class="luxury-line"><span style="display: none">.</span></div>
          <div class="end-diamond"><span style="display: none">.</span>◆</div>
          <div class="luxury-line"><span style="display: none">.</span></div>
        </div>
        <p class="end-text">You've explored our complete collection</p>
        <p class="end-subtitle">Every piece tells a story of elegance</p>
      </div>
    </div>

    <!-- Hidden next page URL for JavaScript -->
    <div id="next-page-data" 
         data-next-url="{%- if paginate.next -%}{{ paginate.next.url }}{{ anchor }}{%- endif -%}"
         data-current-page="{{ paginate.current_page }}"
         data-total-pages="{{ paginate.pages }}"
         style="display: none;">
    </div>
  </div>

  <style>
    .infinite-scroll-wrapper {
      margin-top: 3rem;
      text-align: center;
    }

    .infinite-scroll-loader {
      padding: 2rem 0;
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .infinite-scroll-loader.show {
      opacity: 1;
      transform: translateY(0);
    }

    .infinite-scroll-end {
      padding: 3rem 0;
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .infinite-scroll-end.show {
      opacity: 1;
      transform: translateY(0);
    }

    .loader-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    .elegant-dots {
      display: flex;
      gap: 0.8rem;
      align-items: center;
    }

    .elegant-dots .dot {
      width: 8px;
      height: 8px;
      background: linear-gradient(135deg, #d4af37, #ffd700);
      border-radius: 50%;
      animation: elegantPulse 1.8s ease-in-out infinite;
      box-shadow: 0 2px 8px rgba(212, 175, 55, 0.3);
    }

    .elegant-dots .dot:nth-child(1) { animation-delay: 0s; }
    .elegant-dots .dot:nth-child(2) { animation-delay: 0.3s; }
    .elegant-dots .dot:nth-child(3) { animation-delay: 0.6s; }

    @keyframes elegantPulse {
      0%, 60%, 100% {
        transform: scale(1);
        opacity: 0.7;
      }
      30% {
        transform: scale(1.3);
        opacity: 1;
      }
    }

    .loading-text {
      margin: 0;
      color: #8b7355;
      font-size: 0.95rem;
      font-weight: 400;
      letter-spacing: 0.5px;
      font-family: 'Georgia', serif;
    }

    .end-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      max-width: 400px;
      margin: 0 auto;
    }

    .end-decoration {
      display: flex;
      align-items: center;
      gap: 1rem;
      width: 100%;
      max-width: 280px;
    }

    .luxury-line {
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, transparent, #d4af37, transparent);
    }

    .end-diamond {
      color: #d4af37;
      font-size: 1.2rem;
      animation: diamondShine 2s ease-in-out infinite;
    }

    @keyframes diamondShine {
      0%, 100% {
        opacity: 0.7;
        transform: scale(1);
      }
      50% {
        opacity: 1;
        transform: scale(1.1);
      }
    }

    .end-text {
      margin: 0;
      color: #6b5b73;
      font-size: 18px;
      font-weight: 500;
      letter-spacing: 0.3px;
      font-family: 'Georgia', serif;
    }

    .end-subtitle {
      margin: 0;
      color: #9b8aa3;
      font-size: 14px;
      font-weight: 400;
      font-style: italic;
      letter-spacing: 0.2px;
      font-family: 'Georgia', serif;
    }

    /* Product animations */
    .product-fade-in {
      opacity: 0;
      transform: translateY(15px);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .product-fade-in.animate {
      opacity: 1;
      transform: translateY(0);
    }

    /* Staggered animation delays */
    .product-fade-in:nth-child(1) { transition-delay: 0.05s; }
    .product-fade-in:nth-child(2) { transition-delay: 0.1s; }
    .product-fade-in:nth-child(3) { transition-delay: 0.15s; }
    .product-fade-in:nth-child(4) { transition-delay: 0.2s; }
    .product-fade-in:nth-child(5) { transition-delay: 0.25s; }
    .product-fade-in:nth-child(6) { transition-delay: 0.3s; }
    .product-fade-in:nth-child(7) { transition-delay: 0.35s; }
    .product-fade-in:nth-child(8) { transition-delay: 0.4s; }

    @media (max-width: 768px) {
      .infinite-scroll-wrapper { margin-top: 2rem; }
      .elegant-dots .dot { width: 6px; height: 6px; }
      .loading-text { font-size: 0.85rem; }
      .end-text { font-size: 1rem; }
      .end-subtitle { font-size: 0.8rem; }
      .infinite-scroll-loader { padding: 1.5rem 0; }
      .infinite-scroll-end { padding: 2rem 0; }
    }
  </style>

  <script>
    // Global state management with duplicate prevention
    window.infiniteScrollState = window.infiniteScrollState || {
      cleanup: null,
      loadedProductIds: new Set(),
      isInitialized: false,
      lastInitTime: 0,
      currentUrl: window.location.href,
      reinitializationPending: false
    };

    function initInfiniteScroll() {
      const currentTime = Date.now();
      
      // Prevent rapid reinitializations (wait at least 500ms between inits)
      if (window.infiniteScrollState.isInitialized && 
          currentTime - window.infiniteScrollState.lastInitTime < 500) {
        console.log('Skipping initialization - too soon after last init');
        return;
      }

      // Clean up previous instance if exists
      if (window.infiniteScrollState.cleanup) {
        window.infiniteScrollState.cleanup();
      }

      const productGrid = document.getElementById('product-grid');
      const loader = document.getElementById('infinite-scroll-loader');
      const endIndicator = document.getElementById('infinite-scroll-end');
      const nextPageData = document.getElementById('next-page-data');
      
      // Check if elements exist
      if (!productGrid || !loader || !endIndicator || !nextPageData) {
        setTimeout(initInfiniteScroll, 100);
        return;
      }

      // Check if URL changed (indicating sort/filter)
      const currentUrl = window.location.href;
      const urlChanged = window.infiniteScrollState.currentUrl !== currentUrl;
      window.infiniteScrollState.currentUrl = currentUrl;

      // Reset state for new initialization or URL change
      const currentPage = parseInt(nextPageData.dataset.currentPage);
      if (currentPage === 1 || urlChanged) {
        // Fresh start - clear loaded IDs
        window.infiniteScrollState.loadedProductIds.clear();
        console.log('Fresh start - cleared loaded product IDs', urlChanged ? '(URL changed)' : '(Page 1)');
      }

      // Build initial set of loaded product IDs
      function buildInitialProductIds() {
        const existingProducts = productGrid.querySelectorAll('[data-product-id], .product-card, .card-product, [class*="product"]');
        existingProducts.forEach(product => {
          const productId = getProductId(product);
          if (productId) {
            window.infiniteScrollState.loadedProductIds.add(productId);
          }
        });
        console.log('Initial products tracked:', window.infiniteScrollState.loadedProductIds.size);
      }

      // Extract product ID from various possible attributes
      function getProductId(productElement) {
        return productElement.dataset.productId || 
               productElement.dataset.id || 
               productElement.getAttribute('data-product-handle') ||
               productElement.getAttribute('data-handle') ||
               productElement.id ||
               productElement.querySelector('a[href*="/products/"]')?.href.split('/products/')[1]?.split('?')[0] ||
               productElement.outerHTML.slice(0, 100); // Fallback to element signature
      }

      // Check if product is already loaded
      function isProductDuplicate(productElement) {
        const productId = getProductId(productElement);
        if (!productId) return false;
        
        const isDuplicate = window.infiniteScrollState.loadedProductIds.has(productId);
        if (isDuplicate) {
          console.log('Duplicate detected:', productId);
        }
        return isDuplicate;
      }

      // Add product to loaded set
      function markProductAsLoaded(productElement) {
        const productId = getProductId(productElement);
        if (productId) {
          window.infiniteScrollState.loadedProductIds.add(productId);
        }
      }

      // Reset indicators
      loader.style.display = 'none';
      loader.classList.remove('show');
      endIndicator.style.display = 'none';
      endIndicator.classList.remove('show');
      
      let isLoading = false;
      let hasNextPage = nextPageData.dataset.nextUrl !== '';
      let currentPageNum = currentPage;
      const totalPages = parseInt(nextPageData.dataset.totalPages);
      
      let observer = null;
      let loadingPromise = null; // Track loading promise to prevent overlapping

      // Build initial product ID set
      buildInitialProductIds();

      function shouldLoadMore() {
        const scrollTop = window.scrollY;
        const windowHeight = window.innerHeight;
        const documentHeight = document.body.offsetHeight;
        const scrollPercentage = (scrollTop + windowHeight) / documentHeight;

        return scrollPercentage > 0.4; // Less aggressive to prevent excessive loading
      }

      function showLoader() {
        if (loader && isLoading) {
          loader.style.display = 'block';

          loader.offsetHeight;
          loader.classList.add('show');
        }
      }

      function hideLoader() {
        if (loader) {

          if (hasNextPage && currentPageNum < totalPages) {
            loader.style.display = 'block';
            loader.classList.add('show');
          } else {
            loader.classList.remove('show');
            setTimeout(() => {
              if (loader) loader.style.display = 'none';
            }, 400);
          }
        }
      }

      function showEndIndicator() {
        if (endIndicator) {
          endIndicator.style.display = 'block';


          endIndicator.offsetHeight;
          endIndicator.classList.add('show');
        }
      }

      function animateNewProducts(newProducts) {
        newProducts.forEach((product, index) => {
          product.classList.add('product-fade-in');
          setTimeout(() => {
            product.classList.add('animate');
          }, index * 15); // Slightly slower stagger for stability
        });
      }
      
      function Loadwishlist() {
        console.log('Wishlist Load - Enhanced for iWish');
        
        try {
          // Method 1: Initialize iWish system for new products
          if (typeof iWish !== 'undefined' && typeof iWish.init === 'function') {
            iWish.init();
            console.log('iWish.init() called');
          }
          
          // Helper function to update wishlist UI
          function updateWishlistUI(element, productId) {
            if (typeof iWish !== 'undefined' && productId) {
              // Find all elements for this product (in case there are multiple)
              const allProductElements = document.querySelectorAll(`[data-product="${productId}"]`);
              
              allProductElements.forEach(el => {
                if (iWish.isInWishlist(productId)) {
                  el.classList.add('iwish-active', 'active');
                  el.setAttribute('data-wishlist-active', 'true');
                  // Update text or icon if needed
                  const text = el.querySelector('.wishlist-text');
                  if (text) text.textContent = 'Remove from Wishlist';
                } else {
                  el.classList.remove('iwish-active', 'active');
                  el.removeAttribute('data-wishlist-active');
                  // Update text or icon if needed
                  const text = el.querySelector('.wishlist-text');
                  if (text) text.textContent = 'Add to Wishlist';
                }
              });
            }
          }
          
          // Method 5: Dispatch custom events
          document.dispatchEvent(new CustomEvent('iwish:reload'));
          document.dispatchEvent(new CustomEvent('wishlist:init'));
          
          // Method 6: Update wishlist states for all elements
          if (typeof iWish !== 'undefined') {
            const allElements = document.querySelectorAll('.iWishAddColl, .iwishcheck, .iWishAdd');
            allElements.forEach(element => {
              const productId = element.dataset.product;
              if (productId) {
                updateWishlistUI(element, productId);
              }
            });
            
            // Update counter
            if (typeof iWishCounter === 'function') {
              iWishCounter();
            }
          }
          
          // Method 7: jQuery fallback if available
          if (typeof jQuery !== 'undefined') {
            jQuery(document).ready(function($) {
              $('.iWishAddColl, .iwishcheck, .iWishAdd').each(function() {
                // Reinitialize jQuery-based wishlist if needed
                if (typeof $.fn.iWish === 'function') {
                  $(this).iWish();
                }
              });
            });
          }
          
          console.log('Wishlist initialization completed successfully');
          
        } catch (error) {
          console.error('Wishlist initialization error:', error);
        }
        
        // Additional delayed initialization with more robust error handling
        setTimeout(() => {
          try {
            // Re-run initialization after DOM settles
            if (typeof iWish !== 'undefined' && typeof iWish.refresh === 'function') {
              iWish.refresh();
            }
            
            // Update counter again
            if (typeof iWishCounter === 'function') {
              iWishCounter();
            }
            
            // Re-check all wishlist states
            const elements = document.querySelectorAll('.iWishAddColl, .iwishcheck, .iWishAdd');
            elements.forEach(element => {
              const productId = element.dataset.product;
              if (productId && typeof iWish !== 'undefined') {
                if (iWish.isInWishlist(productId)) {
                  element.classList.add('iwish-active', 'active');
                  element.setAttribute('data-wishlist-active', 'true');
                } else {
                  element.classList.remove('iwish-active', 'active');
                  element.removeAttribute('data-wishlist-active');
                }
              }
            });
            
            console.log('Delayed wishlist initialization completed');
            
          } catch (error) {
            console.error('Delayed wishlist init error:', error);
          }
        }, 500);
        
        // Even longer delay for stubborn cases
        setTimeout(() => {
          try {
            if (typeof iWish !== 'undefined' && typeof iWish.init === 'function') {
              iWish.init();
            }
            if (typeof iWishCounter === 'function') {
              iWishCounter();
            }
            
            console.log('Final wishlist initialization completed');
          } catch (error) {
            console.error('Final wishlist init error:', error);
          }
        }, 1000);
      }

      // Enhanced load next page with strict duplicate prevention
      async function loadNextPage() {
        // Prevent overlapping loads
        if (isLoading || !hasNextPage || loadingPromise) {
          console.log('Load blocked:', { isLoading, hasNextPage, loadingPromise: !!loadingPromise });
          return;
        }

        console.log('Starting load for page:', currentPageNum + 1);
        isLoading = true;
        showLoader();

        try {
          const nextUrl = nextPageData.dataset.nextUrl;
          console.log('Fetching:', nextUrl);
          
          loadingPromise = fetch(nextUrl, {
            method: 'GET',
            headers: {
              'X-Requested-With': 'XMLHttpRequest',
              'Cache-Control': 'no-cache'
            }
          });
          
          const response = await loadingPromise;
          const text = await response.text();
          const tempDiv = document.createElement('div');
          tempDiv.innerHTML = text;
          
          const newProductGrid = tempDiv.querySelector('#product-grid');

          const allNewProducts = Array.from(newProductGrid.children);
          const newNextPageData = tempDiv.querySelector('#next-page-data');
          
          // Filter out duplicates
          const uniqueNewProducts = allNewProducts.filter(product => {
            return !isProductDuplicate(product);
          });
          
          console.log(`Found ${allNewProducts.length} products, ${uniqueNewProducts.length} unique`);
          
          if (uniqueNewProducts.length > 0) {
            // Add only unique products
            uniqueNewProducts.forEach(product => {
              markProductAsLoaded(product);
              productGrid.appendChild(product);
            });

            Loadwishlist();
            animateNewProducts(uniqueNewProducts);

            // Update pagination data
            currentPageNum++;
            if (newNextPageData) {
              nextPageData.dataset.nextUrl = newNextPageData.dataset.nextUrl || '';
              nextPageData.dataset.currentPage = currentPageNum.toString();
              hasNextPage = nextPageData.dataset.nextUrl !== '';
            } else {
              hasNextPage = false;
            }


            console.log('Updated to page:', currentPageNum, 'Has next:', hasNextPage);
            observeLastProducts();

          } else {
            console.log('No unique products found - ending pagination');
            hasNextPage = false;
          }

          if (!hasNextPage || currentPageNum >= totalPages) {
            console.log('Showing end indicator');
            showEndIndicator();
          }

        } catch (error) {
          console.error('Error loading next page:', error);
        } finally {
          isLoading = false;
          loadingPromise = null;
          hideLoader();
        }
      }

      // Debounced scroll handler to prevent excessive calls
      let scrollTimeout;
      let lastScrollTime = 0;
      
      function handleScroll() {
        const now = Date.now();
        if (now - lastScrollTime < 100) return; // Throttle to max 10 calls per second
        lastScrollTime = now;

        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(() => {
          if (shouldLoadMore() && hasNextPage && !isLoading && !loadingPromise) {
            loadNextPage();
          }
        }, 50);
      }

      function observeLastProducts() {
        if (observer) {
          observer.disconnect();
        }
        
        const products = Array.from(productGrid.children);
        if (products.length >= 2) {
          // Observe the 2nd last product for better timing
          if ('IntersectionObserver' in window) {
            const observerOptions = {
              root: null,
              rootMargin: '300px',
              threshold: 0
            };

            observer = new IntersectionObserver((entries) => {
              entries.forEach(entry => {
                if (entry.isIntersecting && hasNextPage && !isLoading && !loadingPromise) {
                  console.log('Intersection observed - loading next page');
                  loadNextPage();
                }
              });
            }, observerOptions);

            observer.observe(products[products.length - 2]);
          }
        }
      }

      // Event listeners for cleanup
      const eventListeners = [];
      
      function addTrackedEventListener(element, event, handler, options = {}) {
        element.addEventListener(event, handler, options);
        eventListeners.push({ element, event, handler, options });
      }

      // Add controlled event listeners
      addTrackedEventListener(window, 'scroll', handleScroll, { passive: true });

      // Initial setup based on current state
      if (currentPageNum >= totalPages) {
        showEndIndicator();
      } else {
        if (hasNextPage) {
          loader.style.display = 'block';
          loader.classList.add('show');
        }
        
        // Initial observation setup
        setTimeout(observeLastProducts, 100);
        
        // Controlled initial load if page is very short
        setTimeout(() => {
          if (document.body.offsetHeight <= window.innerHeight * 1.2 && hasNextPage && !isLoading) {
            console.log('Page too short - loading next page');
            loadNextPage();
          }
        }, 200);
      }

      // Update global state
      window.infiniteScrollState.isInitialized = true;
      window.infiniteScrollState.lastInitTime = currentTime;
      window.infiniteScrollState.reinitializationPending = false;

      // Cleanup function
      window.infiniteScrollState.cleanup = function() {
        console.log('Cleaning up infinite scroll');
        
        // Remove all event listeners
        eventListeners.forEach(({ element, event, handler, options }) => {
          element.removeEventListener(event, handler, options);
        });
        eventListeners.length = 0;

        // Disconnect observer
        if (observer) {
          observer.disconnect();
          observer = null;
        }

        // Clear timeouts
        if (scrollTimeout) {
          clearTimeout(scrollTimeout);
        }

        // Cancel any pending loading promise
        if (loadingPromise) {
          loadingPromise = null;
        }

        window.infiniteScrollState.isInitialized = false;

      };
    }

    // Initialize on DOM ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initInfiniteScroll);
    } else {
      initInfiniteScroll();
    }

    // Enhanced function to call after sort/filter with better detection
    window.reinitInfiniteScroll = function() {
      if (window.infiniteScrollState.reinitializationPending) {
        console.log('Reinitialization already pending, skipping');
        return;
      }
      
      window.infiniteScrollState.reinitializationPending = true;
      console.log('Reinitializing infinite scroll after sort/filter');
      
      // Wait for DOM to settle after sort/filter
      setTimeout(() => {
        // Check if we're back to page 1 (which indicates fresh sort/filter)
        const nextPageData = document.getElementById('next-page-data');
        if (nextPageData) {
          const currentPage = parseInt(nextPageData.dataset.currentPage) || 1;
          if (currentPage === 1) {
            // Clear loaded IDs for fresh start
            window.infiniteScrollState.loadedProductIds.clear();
            console.log('Sort/filter detected - cleared loaded product IDs');
          }
        }
        
        initInfiniteScroll();
      }, 300);
    };

    // Enhanced content change detection with better URL monitoring
    if (window.MutationObserver) {
      let mutationTimeout;
      let lastMutationTime = 0;
      let lastUrl = window.location.href;
      
      // URL change detection
      function checkUrlChange() {
        const currentUrl = window.location.href;
        if (currentUrl !== lastUrl) {
          console.log('URL changed from', lastUrl, 'to', currentUrl);
          lastUrl = currentUrl;
          
          // URL changed - likely sort/filter
          setTimeout(() => {
            window.reinitInfiniteScroll();
          }, 100);
        }
      }

      // Monitor URL changes via various methods
      window.addEventListener('popstate', checkUrlChange);
      
      // Poll for URL changes (catches programmatic changes)
      setInterval(checkUrlChange, 500);
      
      const contentObserver = new MutationObserver((mutations) => {
        const now = Date.now();
        if (now - lastMutationTime < 200) return; // Throttle mutations
        lastMutationTime = now;

        // Check URL first
        checkUrlChange();

        // Check if this is a significant change (like sorting/filtering)
        const isSignificantChange = mutations.some(mutation => {
          // Check for major DOM changes
          if (mutation.type === 'childList' && mutation.addedNodes.length > 0) {
            return true;
          }
          
          // Check for attribute changes that might indicate sort/filter
          if (mutation.type === 'attributes' && 
              (mutation.attributeName === 'data-current-page' || 
               mutation.attributeName === 'data-next-url' ||
               mutation.attributeName === 'class')) {
            return true;
          }
          
          return false;
        });

        if (isSignificantChange) {
          clearTimeout(mutationTimeout);
          mutationTimeout = setTimeout(() => {
            const nextPageData = document.getElementById('next-page-data');
            if (nextPageData) {
              const currentPage = parseInt(nextPageData.dataset.currentPage);
              if (currentPage === 1 && !window.infiniteScrollState.reinitializationPending) {
                console.log('Detected page reset via mutation - reinitializing');
                window.reinitInfiniteScroll();
              }
            }
          }, 400); // Longer delay to ensure DOM is stable
        }
      });

      setTimeout(() => {
        const mainContent = document.querySelector('main') || document.querySelector('#product-grid') || document.body;
        contentObserver.observe(mainContent, {
          childList: true,
          subtree: true, // Observe deeper changes
          attributes: true,
          attributeFilter: ['data-current-page', 'data-next-url', 'class', 'data-sort', 'data-filter']
        });
      }, 100);
    }

    // Listen for custom events that might be triggered by sort/filter mechanisms
    document.addEventListener('facetsLoaded', function() {
      console.log('facetsLoaded event detected');
      setTimeout(() => window.reinitInfiniteScroll(), 200);
    });

    document.addEventListener('collectionFiltered', function() {
      console.log('collectionFiltered event detected');
      setTimeout(() => window.reinitInfiniteScroll(), 200);
    });

    // Listen for AJAX complete events (common in Shopify themes)
    if (typeof jQuery !== 'undefined') {
      jQuery(document).ajaxComplete(function(event, xhr, settings) {
        // Check if this might be a sort/filter AJAX call
        if (settings.url && (
          settings.url.includes('collections') || 
          settings.url.includes('sort_by') || 
          settings.url.includes('filter')
        )) {
          console.log('Collection AJAX detected');
          setTimeout(() => window.reinitInfiniteScroll(), 300);
        }
      });
    }
  </script>
{%- endif -%}