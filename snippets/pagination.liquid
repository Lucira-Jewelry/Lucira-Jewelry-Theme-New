{% comment %}
  Renders ultra-fast infinite scroll pagination for products.
  Usage:
  {% paginate collection.products by 24 %}
    {% render 'infinite-scroll-pagination', paginate: paginate %}
  {% endpaginate %}
{% endcomment %}

{{ 'component-pagination.css' | asset_url | stylesheet_tag }}

{%- if paginate.parts.size > 0 -%}
<div class="infinite-scroll-wrapper">
  <!-- Loading indicator -->
  <div id="infinite-scroll-loader" class="infinite-scroll-loader" style="display: none;">
    <div class="loader-content">
      <div class="elegant-dots">
        <div class="dot"></div>
        <div class="dot"></div>
        <div class="dot"></div>
      </div>
      <p class="loading-text">Loading more products...</p>
    </div>
  </div>

  <!-- End indicator -->
  <div id="infinite-scroll-end" class="infinite-scroll-end" style="display: none;">
    <div class="end-content">
      <p class="end-text">You've viewed all products</p>
    </div>
  </div>

  <!-- Hidden data -->
  <div id="next-page-data" 
       data-next-url="{% if paginate.next %}{{ paginate.next.url }}{% endif %}"
       data-current-page="{{ paginate.current_page }}"
       data-total-pages="{{ paginate.pages }}"
       style="display: none;">
  </div>
</div>

<style>
  .infinite-scroll-wrapper {
    margin-top: 3rem;
    text-align: center;
  }
  
  .infinite-scroll-loader {
    padding: 2rem 0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .infinite-scroll-loader.show {
    opacity: 1;
  }
  
  .infinite-scroll-end {
    padding: 2rem 0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .infinite-scroll-end.show {
    opacity: 1;
  }
  
  .loader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  
  .elegant-dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  
  .elegant-dots .dot {
    width: 8px;
    height: 8px;
    background: #000;
    border-radius: 50%;
    animation: dotPulse 1.4s ease-in-out infinite;
  }
  
  .elegant-dots .dot:nth-child(1) { animation-delay: 0s; }
  .elegant-dots .dot:nth-child(2) { animation-delay: 0.2s; }
  .elegant-dots .dot:nth-child(3) { animation-delay: 0.4s; }
  
  @keyframes dotPulse {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.2); opacity: 1; }
  }
  
  .loading-text, .end-text {
    margin: 0;
    color: #666;
    font-size: 0.9rem;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    console.log('Initializing infinite scroll...');
    
    const productGrid = document.getElementById('product-grid');
    const loader = document.getElementById('infinite-scroll-loader');
    const endIndicator = document.getElementById('infinite-scroll-end');
    const nextPageData = document.getElementById('next-page-data');
    
    if (!productGrid || !loader || !endIndicator || !nextPageData) {
      console.error('Required elements not found for infinite scroll');
      return;
    }
    
    let isLoading = false;
    let hasNextPage = nextPageData.dataset.nextUrl && nextPageData.dataset.nextUrl.trim() !== '';
    const currentPage = parseInt(nextPageData.dataset.currentPage) || 1;
    const totalPages = parseInt(nextPageData.dataset.totalPages) || 1;
    
    console.log('Infinite scroll state:', { hasNextPage, currentPage, totalPages });
    
    // Track loaded product IDs to prevent duplicates
    const loadedProductIds = new Set();
    
    // Mark existing products as loaded
    function markExistingProducts() {
      const products = productGrid.querySelectorAll('[data-product-id], [data-product-handle]');
      products.forEach(product => {
        const productId = product.dataset.productId || product.dataset.productHandle;
        if (productId) {
          loadedProductIds.add(productId);
        }
      });
    }
    
    markExistingProducts();
    
    function showLoader() {
      if (hasNextPage) {
        loader.style.display = 'block';
        setTimeout(() => loader.classList.add('show'), 10);
      }
    }
    
    function hideLoader() {
      loader.classList.remove('show');
      setTimeout(() => {
        loader.style.display = 'none';
      }, 300);
    }
    
    function showEndIndicator() {
      if (!hasNextPage) {
        endIndicator.style.display = 'block';
        setTimeout(() => endIndicator.classList.add('show'), 10);
      }
    }
    
    // Check if we should load more based on scroll position
    function shouldLoadMore() {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const windowHeight = window.innerHeight;
      const documentHeight = document.documentElement.scrollHeight;
      const scrollPercent = (scrollTop + windowHeight) / documentHeight;
      
      return scrollPercent > 0.8; // Load when 80% scrolled
    }
    
    // Parse HTML and extract products
    function extractProductsFromHTML(html) {
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');
      
      // Look for product grid in the response
      const newProductGrid = doc.getElementById('product-grid');
      if (newProductGrid) {
        return Array.from(newProductGrid.children);
      }
      
      // Fallback: look for any product elements
      const productElements = doc.querySelectorAll('[data-product-id], [data-product-handle], .product-card, .grid-item');
      return Array.from(productElements);
    }
    
    // Filter out duplicate products
    function filterDuplicates(products) {
      return products.filter(product => {
        const productId = product.dataset?.productId || product.dataset?.productHandle;
        if (!productId) return true; // Include if no ID (can't check for duplicates)
        if (loadedProductIds.has(productId)) {
          console.log('Skipping duplicate product:', productId);
          return false;
        }
        loadedProductIds.add(productId);
        return true;
      });
    }
    
    // Load next page
    async function loadNextPage() {
      if (isLoading || !hasNextPage) return;
      
      isLoading = true;
      showLoader();
      
      try {
        const nextUrl = nextPageData.dataset.nextUrl;
        console.log('Loading next page:', nextUrl);
        
        const response = await fetch(nextUrl);
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        
        const html = await response.text();
        const newProducts = extractProductsFromHTML(html);
        
        console.log('Found products in response:', newProducts.length);
        
        if (newProducts.length > 0) {
          const uniqueProducts = filterDuplicates(newProducts);
          console.log('Unique products after filtering:', uniqueProducts.length);
          
          if (uniqueProducts.length > 0) {
            // Append new products
            uniqueProducts.forEach(product => {
              productGrid.appendChild(product);
            });
            
            // Update next page data
            const newDoc = new DOMParser().parseFromString(html, 'text/html');
            const newNextData = newDoc.getElementById('next-page-data');
            
            if (newNextData && newNextData.dataset.nextUrl) {
              nextPageData.dataset.nextUrl = newNextData.dataset.nextUrl;
              nextPageData.dataset.currentPage = (parseInt(nextPageData.dataset.currentPage) + 1).toString();
              hasNextPage = true;
            } else {
              hasNextPage = false;
              showEndIndicator();
            }
            
            // Reinitialize any product-related JavaScript
            setTimeout(() => {
              if (typeof window.initProducts === 'function') {
                window.initProducts();
              }
            }, 100);
          } else {
            console.log('No unique products found, showing end indicator');
            hasNextPage = false;
            showEndIndicator();
          }
        } else {
          console.log('No products found in response, showing end indicator');
          hasNextPage = false;
          showEndIndicator();
        }
      } catch (error) {
        console.error('Error loading next page:', error);
        hasNextPage = false;
        showEndIndicator();
      } finally {
        isLoading = false;
        hideLoader();
      }
    }
    
    // Scroll event handler
    function handleScroll() {
      if (shouldLoadMore() && hasNextPage && !isLoading) {
        loadNextPage();
      }
    }
    
    // Initialize
    window.addEventListener('scroll', handleScroll, { passive: true });
    
    // Show end indicator if no more pages
    if (!hasNextPage || currentPage >= totalPages) {
      showEndIndicator();
    }
    
    console.log('Infinite scroll initialized successfully');
  });
</script>
{%- endif -%}