{% comment %}
  Renders ultra-fast infinite scroll pagination for products. Must be used within paginate tags.

  Preloads content instantly so users never wait. Fixed duplicate prevention.

  Usage:
  {% paginate results by 2 %}
    {% render 'infinite-scroll-pagination', paginate: paginate, anchor: '#yourID' %}
  {% endpaginate %}

  Accepts:
  - paginate: {Object}
  - anchor: {String} (optional)
{% endcomment %}

{{ 'component-pagination.css' | asset_url | stylesheet_tag }}

{%- if paginate.parts.size > 0 -%}
  <div class="infinite-scroll-wrapper">
    <!-- Loading indicator (elegant dots for luxury) -->
    <div id="infinite-scroll-loader" class="infinite-scroll-loader" style="display: none;">
      <div class="loader-content">
        <div class="elegant-dots">
          <div class="dot"><span style="display: none">.</span></div>
          <div class="dot"><span style="display: none">.</span></div>
          <div class="dot"><span style="display: none">.</span></div>
        </div>
        <p class="loading-text">Discovering more exquisite pieces...</p>
      </div>
    </div>

    <!-- End of products indicator - MOVED INSIDE THE IF CONDITION -->
    <div id="infinite-scroll-end" class="infinite-scroll-end" style="display: none;">
      <div class="end-content">
        <div class="end-decoration">
          <div class="luxury-line"><span style="display: none">.</span></div>
          <div class="end-diamond"><span style="display: none">.</span>◆</div>
          <div class="luxury-line"><span style="display: none">.</span></div>
        </div>
        <p class="end-text">You've explored our complete collection</p>
        <p class="end-subtitle">Every piece tells a story of elegance</p>
      </div>
    </div>

    <!-- Hidden next page URL for JavaScript -->
    <div id="next-page-data" 
         data-next-url="{%- if paginate.next -%}{{ paginate.next.url }}{{ anchor }}{%- endif -%}"
         data-current-page="{{ paginate.current_page }}"
         data-total-pages="{{ paginate.pages }}"
         style="display: none;">
    </div>
  </div>

  <style>
    .infinite-scroll-wrapper{margin-top:3rem;text-align:center}
    .infinite-scroll-loader{padding:2rem 0;opacity:0;transform:translateY(20px);transition:all .4s cubic-bezier(.4,0,.2,1)}
    .infinite-scroll-loader.show{opacity:1;transform:translateY(0)}
    .infinite-scroll-end{padding:3rem 0;opacity:0;transform:translateY(20px);transition:all .5s cubic-bezier(.4,0,.2,1)}
    .infinite-scroll-end.show{opacity:1;transform:translateY(0)}
    .loader-content{display:flex;flex-direction:column;align-items:center;gap:1rem}
    .elegant-dots{display:flex;gap:.8rem;align-items:center}
    .elegant-dots .dot{width:8px;height:8px;background:linear-gradient(135deg,#d4af37,gold);border-radius:50%;animation:elegantPulse 1.8s ease-in-out infinite;box-shadow:0 2px 8px rgba(212,175,55,.3)}
    .elegant-dots .dot:nth-child(1){animation-delay:0s}
    .elegant-dots .dot:nth-child(2){animation-delay:.3s}
    .elegant-dots .dot:nth-child(3){animation-delay:.6s}
    @keyframes elegantPulse{
    0%,100%,60%{transform:scale(1);opacity:.7}
    30%{transform:scale(1.3);opacity:1}
    }
    .loading-text{margin:0;color:#8b7355;font-size:.95rem;font-weight:400;letter-spacing:.5px;font-family:Georgia,serif}
    .end-content{display:flex;flex-direction:column;align-items:center;gap:1.5rem;max-width:400px;margin:0 auto}
    .end-decoration{display:flex;align-items:center;gap:1rem;width:100%;max-width:280px}
    .luxury-line{flex:1;height:1px;background:linear-gradient(to right,transparent,#d4af37,transparent)}
    .end-diamond{color:#d4af37;font-size:1.2rem;animation:diamondShine 2s ease-in-out infinite}
    @keyframes diamondShine{
    0%,100%{opacity:.7;transform:scale(1)}
    50%{opacity:1;transform:scale(1.1)}
    }
    .end-text{margin:0;color:#6b5b73;font-size:18px;font-weight:500;letter-spacing:.3px;font-family:Georgia,serif}
    .end-subtitle{margin:0;color:#9b8aa3;font-size:14px;font-weight:400;font-style:italic;letter-spacing:.2px;font-family:Georgia,serif}
    .product-fade-in{opacity:0;transform:translateY(15px);transition:all .4s cubic-bezier(.4,0,.2,1)}
    .product-fade-in.animate{opacity:1;transform:translateY(0)}
    .product-fade-in:nth-child(1){transition-delay:50ms}
    .product-fade-in:nth-child(2){transition-delay:.1s}
    .product-fade-in:nth-child(3){transition-delay:.15s}
    .product-fade-in:nth-child(4){transition-delay:.2s}
    .product-fade-in:nth-child(5){transition-delay:.25s}
    .product-fade-in:nth-child(6){transition-delay:.3s}
    .product-fade-in:nth-child(7){transition-delay:.35s}
    .product-fade-in:nth-child(8){transition-delay:.4s}
    @media (max-width:768px){
    .infinite-scroll-wrapper{margin-top:2rem}
    .elegant-dots .dot{width:6px;height:6px}
    .loading-text{font-size:.85rem}
    .end-text{font-size:1rem}
    .end-subtitle{font-size:.8rem}
    .infinite-scroll-loader{padding:1.5rem 0}
    .infinite-scroll-end{padding:2rem 0}
    }
  </style>

  <script>
    (function() {
      const DEBUG = true;

      window.infiniteScrollState = window.infiniteScrollState || {
        cleanup: null, loadedProductIds: new Set(), isInitialized: false,
        lastInitTime: 0, currentUrl: window.location.href, observer: null, scrollTimeout: null
      };

      function dbg(...args){ if(DEBUG) console.debug('[infiniteScroll]', ...args); }

      // Robust getProductId — returns null if not determinable (avoid brittle fallbacks)
      function getProductId(productElement){
        if(!productElement || productElement.nodeType !== 1) return null;
        const ds = productElement.dataset || {};
        if(ds.productId) return `id:${ds.productId}`;
        if(ds.id) return `id:${ds.id}`;
        if(ds.productHandle) return `handle:${ds.productHandle}`;
        // try link handle
        const link = productElement.querySelector('a[href*="/products/"]');
        if(link){
          try{
            const href = link.getAttribute('href');
            const handle = href.split('/products/')[1].split('?')[0].replace(/\/$/,'');
            if(handle) return `handle:${handle}`;
          }catch(e){}
        }
        // try variant/product sku elements
        const sku = productElement.querySelector('[data-sku], [data-variant-id], .product-sku, .sku');
        if(sku && sku.textContent.trim()) return `sku:${sku.textContent.trim().slice(0,50)}`;
        return null;
      }

      function isProductDuplicate(productElement){
        const productId = getProductId(productElement);
        if(!productId) return false; // can't safely say it's duplicate — show it
        return window.infiniteScrollState.loadedProductIds.has(productId);
      }

      function markProductAsLoaded(productElement){
        const productId = getProductId(productElement);
        if(productId) window.infiniteScrollState.loadedProductIds.add(productId);
      }

      function animateNewProducts(newProducts){
        newProducts.forEach((product, index) => {
          product.classList.add('product-fade-in');
          setTimeout(()=> product.classList.add('animate'), index * 15);
        });
      }

      function initWishlist() {
        try {
          if (typeof iWish !== 'undefined' && typeof iWish.init === 'function') iWish.init();
          document.dispatchEvent(new CustomEvent('iwish:reload'));
          document.dispatchEvent(new CustomEvent('wishlist:init'));
          if (typeof iWishCounter === 'function') iWishCounter();
        } catch (err) { console.error('Wishlist init error:', err); }
      }

      function initInfiniteScroll(){
        const now = Date.now();
        if(window.infiniteScrollState.isInitialized && now - window.infiniteScrollState.lastInitTime < 500) return;
        if(window.infiniteScrollState.cleanup) window.infiniteScrollState.cleanup();

        const productGrid = document.getElementById('product-grid');
        const loader = document.getElementById('infinite-scroll-loader');
        const endIndicator = document.getElementById('infinite-scroll-end');
        const nextPageData = document.getElementById('next-page-data');

        if(!productGrid || !loader || !endIndicator || !nextPageData){
          dbg('Required DOM nodes not ready, retrying init...');
          setTimeout(initInfiniteScroll, 200);
          return;
        }

        const currentPage = parseInt(nextPageData.dataset.currentPage) || 1;
        const totalPages = parseInt(nextPageData.dataset.totalPages) || 1;
        let isLoading = false;
        let hasNextPage = !!(nextPageData.dataset.nextUrl && nextPageData.dataset.nextUrl.trim());

        if(window.infiniteScrollState.currentUrl !== window.location.href || currentPage === 1) {
          window.infiniteScrollState.loadedProductIds.clear();
        }
        window.infiniteScrollState.currentUrl = window.location.href;

        // mark existing products
        Array.from(productGrid.children).forEach(markProductAsLoaded);

        function showLoader(){ if (hasNextPage) { loader.style.display = 'block'; loader.classList.add('show'); } }
        function hideLoader(){ loader.classList.remove('show'); setTimeout(()=>loader.style.display='none',400); }
        function showEndIndicator(){ if(!hasNextPage){ endIndicator.style.display='block'; endIndicator.classList.add('show'); } }

        async function loadNextPage(){
          if(isLoading || !hasNextPage) return;
          isLoading = true;
          showLoader();

          const fetchUrl = nextPageData.dataset.nextUrl;
          dbg('Fetching next page:', fetchUrl);
          try{
            const response = await fetch(fetchUrl, { method:'GET', headers:{'Cache-Control':'no-cache'} });
            if(!response.ok) throw new Error(`HTTP ${response.status}`);
            const html = await response.text();

            // parse response with DOMParser for reliability
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');

            const newGrid = doc.querySelector('#product-grid');
            const newNextData = doc.querySelector('#next-page-data');

            if(!newGrid){
              dbg('Fetched HTML does not contain #product-grid. Server may return different markup for XHR requests.');
              hasNextPage = false;
              showEndIndicator();
              return;
            }

            // collect product nodes more defensively (direct children or known classes)
            const candidateSelectors = ['[data-product-id]','[data-id]','.product-card','.grid-item','.card','li'];
            let allProducts = [];
            // prefer direct children if they look like product cards
            allProducts = Array.from(newGrid.children).filter(n => n.nodeType===1);
            if(!allProducts.length){
              // fallback to querying known selectors inside newGrid
              const found = newGrid.querySelectorAll(candidateSelectors.join(','));
              allProducts = Array.from(found);
            }

            dbg('newGrid children count:', newGrid.children.length, 'allProducts length:', allProducts.length);

            const uniqueProducts = allProducts.filter(p => !isProductDuplicate(p));
            dbg('uniqueProducts:', uniqueProducts.length);

            if(uniqueProducts.length > 0){
              // append clones so we don't accidentally remove nodes from the fetched doc
              const appended = [];
              uniqueProducts.forEach(p => {
                const clone = p.cloneNode(true);
                productGrid.appendChild(clone);
                markProductAsLoaded(clone);
                appended.push(clone);
              });

              animateNewProducts(appended);
              initWishlist();

              // update pagination dataset
              if(newNextData && newNextData.dataset.nextUrl){
                nextPageData.dataset.nextUrl = newNextData.dataset.nextUrl;
                nextPageData.dataset.currentPage = (parseInt(nextPageData.dataset.currentPage || currentPage) + 1).toString();
                hasNextPage = !!nextPageData.dataset.nextUrl;
              } else {
                // If there's no next-page-data in response, set hasNextPage false
                nextPageData.dataset.nextUrl = '';
                hasNextPage = false;
              }
            } else {
              dbg('No unique items found in fetched page — marking end of results.');
              hasNextPage = false;
            }

            if(!hasNextPage) showEndIndicator();
            reobserveProducts();
          } catch(err){
            console.error('Infinite scroll error:', err);
            hasNextPage = false;
            showEndIndicator();
          } finally {
            isLoading = false;
            hideLoader();
          }
        }

        function shouldLoadMore(){
          const scrollTop = window.scrollY || document.documentElement.scrollTop;
          const windowHeight = window.innerHeight;
          const docHeight = Math.max(document.body.scrollHeight, document.documentElement.scrollHeight);
          return (scrollTop + windowHeight) / docHeight > 0.75;
        }

        function handleScroll(){
          if(window.infiniteScrollState.scrollTimeout) clearTimeout(window.infiniteScrollState.scrollTimeout);
          window.infiniteScrollState.scrollTimeout = setTimeout(()=>{
            if(shouldLoadMore() && hasNextPage && !isLoading) loadNextPage();
          }, 100);
        }

        function reobserveProducts(){
          if(window.infiniteScrollState.observer) { window.infiniteScrollState.observer.disconnect(); window.infiniteScrollState.observer = null; }
          const products = Array.from(productGrid.children).filter(n => n.nodeType===1);
          if(products.length < 1 || !('IntersectionObserver' in window)) return;

          window.infiniteScrollState.observer = new IntersectionObserver(entries => {
            entries.forEach(entry => {
              if(entry.isIntersecting && hasNextPage && !isLoading) loadNextPage();
            });
          }, { root: null, rootMargin: '500px 0px', threshold: 0.1 });

          const observeCount = Math.min(3, products.length);
          for(let i = products.length - observeCount; i < products.length; i++){
            if(products[i]) window.infiniteScrollState.observer.observe(products[i]);
          }
        }

        // initial setup
        window.addEventListener('scroll', handleScroll, { passive: true });
        if(currentPage >= totalPages) showEndIndicator(); else reobserveProducts();

        window.infiniteScrollState.cleanup = function(){
          window.removeEventListener('scroll', handleScroll);
          if(window.infiniteScrollState.observer) { window.infiniteScrollState.observer.disconnect(); window.infiniteScrollState.observer = null; }
          if(window.infiniteScrollState.scrollTimeout) { clearTimeout(window.infiniteScrollState.scrollTimeout); window.infiniteScrollState.scrollTimeout = null; }
          window.infiniteScrollState.isInitialized = false;
        };
        window.infiniteScrollState.isInitialized = true;
        window.infiniteScrollState.lastInitTime = now;
        dbg('Infinite scroll initialized. currentPage:', currentPage, 'totalPages:', totalPages, 'hasNextPage:', hasNextPage);
      }

      // reinit after filters/sorts
      window.reinitInfiniteScroll = function(){
        if(window.infiniteScrollState.cleanup) window.infiniteScrollState.cleanup();
        setTimeout(()=>{
          const nextPageData = document.getElementById('next-page-data');
          if(nextPageData){
            window.infiniteScrollState.loadedProductIds.clear();
            window.infiniteScrollState.currentUrl = window.location.href;
            window.infiniteScrollState.isInitialized = false;
            const loader = document.getElementById('infinite-scroll-loader');
            const endIndicator = document.getElementById('infinite-scroll-end');
            if(loader){ loader.style.display='none'; loader.classList.remove('show'); }
            if(endIndicator){ endIndicator.style.display='none'; endIndicator.classList.remove('show'); }
          }
          setTimeout(initInfiniteScroll, 200);
        }, 500);
      };

      // url change detection
      let lastUrl = window.location.href;
      function checkUrlChange(){ if(window.location.href !== lastUrl){ lastUrl = window.location.href; setTimeout(window.reinitInfiniteScroll, 300); } }
      window.addEventListener('popstate', checkUrlChange);
      setInterval(checkUrlChange, 1000);

      // collection events
      document.addEventListener('facetsLoaded', ()=>setTimeout(window.reinitInfiniteScroll, 400));
      document.addEventListener('collectionFiltered', ()=>setTimeout(window.reinitInfiniteScroll, 400));

      // DOM mutation observer (watch deeper subtree)
      setTimeout(()=>{
        const productGrid = document.getElementById('product-grid');
        if(productGrid){
          const gridObserver = new MutationObserver(mutations=>{
            mutations.forEach(m=>{
              if(m.type === 'childList'){
                const hasProducts = Array.from(productGrid.children).some(c => c.dataset?.productId || c.classList.contains('product-card') || c.classList.contains('grid-item'));
                if(hasProducts && productGrid.children.length > 0) setTimeout(window.reinitInfiniteScroll, 500);
              }
            });
          });
          gridObserver.observe(productGrid, { childList: true, subtree: true });
        }
      }, 1000);

      if(document.readyState === 'loading'){
        document.addEventListener('DOMContentLoaded', ()=>setTimeout(initInfiniteScroll, 100));
      } else {
        setTimeout(initInfiniteScroll, 100);
      }

    })();
  </script>


{%- endif -%}