{% comment %}
  Renders infinite scroll pagination for products. Must be used within paginate tags.
  
  Usage:
  {% paginate collection.products by 12 %}
    {% render 'infinite-scroll-pagination', paginate: paginate, anchor: '' %}
  {% endpaginate %}

  Accepts:
  - paginate: {Object} - Shopify paginate object
  - anchor: {String} - Optional anchor for URL (e.g., '#product-grid')
{% endcomment %}

{{ 'component-pagination.css' | asset_url | stylesheet_tag }}

{%- if paginate.parts.size > 0 -%}
  <div class="infinite-scroll-container" id="infinite-scroll-container">
    
    {%- comment -%} Loading Indicator {%- endcomment -%}
    <div class="infinite-scroll-loading" id="infinite-scroll-loading" style="display: none;">
      <div class="loading-content">
        <div class="loading-dots">
          <span class="loading-dot"></span>
          <span class="loading-dot"></span>
          <span class="loading-dot"></span>
        </div>
        <p class="loading-text">{{ 'general.pagination.loading' | t | default: 'Loading more products...' }}</p>
      </div>
    </div>

    {%- comment -%} End of Results Indicator {%- endcomment -%}
    <div class="infinite-scroll-end" id="infinite-scroll-end" style="display: none;">
      <div class="end-content">
        <div class="end-divider">
          <span class="divider-line"></span>
          <span class="divider-icon">✦</span>
          <span class="divider-line"></span>
        </div>
        <p class="end-text">{{ 'general.pagination.end' | t | default: "You've reached the end" }}</p>
      </div>
    </div>

    {%- comment -%} Hidden Data Container {%- endcomment -%}
    <div id="infinite-scroll-data" 
         data-next-url="{%- if paginate.next -%}{{ paginate.next.url }}{{ anchor }}{%- endif -%}"
         data-current-page="{{ paginate.current_page }}"
         data-total-pages="{{ paginate.pages }}"
         style="display: none;">
    </div>
  </div>

  <style>
    /* Infinite Scroll Container */
    .infinite-scroll-container {
      margin-top: 4rem;
      text-align: center;
    }

    /* Loading State */
    .infinite-scroll-loading {
      padding: 3rem 1rem;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .infinite-scroll-loading.active {
      opacity: 1;
      transform: translateY(0);
    }

    .loading-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }

    .loading-dots {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      justify-content: center;
    }

    .loading-dot {
      width: 10px;
      height: 10px;
      background-color: rgba(var(--color-foreground), 0.3);
      border-radius: 50%;
      animation: loading-pulse 1.4s ease-in-out infinite;
    }

    .loading-dot:nth-child(1) {
      animation-delay: 0s;
    }

    .loading-dot:nth-child(2) {
      animation-delay: 0.2s;
    }

    .loading-dot:nth-child(3) {
      animation-delay: 0.4s;
    }

    @keyframes loading-pulse {
      0%, 100% {
        transform: scale(1);
        opacity: 0.3;
      }
      50% {
        transform: scale(1.2);
        opacity: 1;
      }
    }

    .loading-text {
      margin: 0;
      color: rgba(var(--color-foreground), 0.7);
      font-size: 1.4rem;
      letter-spacing: 0.06rem;
    }

    /* End State */
    .infinite-scroll-end {
      padding: 4rem 1rem;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }

    .infinite-scroll-end.active {
      opacity: 1;
      transform: translateY(0);
    }

    .end-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      max-width: 400px;
      margin: 0 auto;
    }

    .end-divider {
      display: flex;
      align-items: center;
      gap: 1rem;
      width: 100%;
      max-width: 300px;
    }

    .divider-line {
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(var(--color-foreground), 0.2), transparent);
    }

    .divider-icon {
      color: rgba(var(--color-foreground), 0.4);
      font-size: 1.4rem;
    }

    .end-text {
      margin: 0;
      color: rgba(var(--color-foreground), 0.6);
      font-size: 1.4rem;
      letter-spacing: 0.06rem;
    }

    /* Product Animation */
    .product-item-fade {
      opacity: 0;
      transform: translateY(20px);
      animation: product-fade-in 0.5s ease forwards;
    }

    @keyframes product-fade-in {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Mobile Adjustments */
    @media screen and (max-width: 749px) {
      .infinite-scroll-container {
        margin-top: 3rem;
      }

      .loading-text,
      .end-text {
        font-size: 1.3rem;
      }

      .infinite-scroll-loading {
        padding: 2rem 1rem;
      }

      .infinite-scroll-end {
        padding: 3rem 1rem;
      }
    }
  </style>

  <script>
    if (!window.InfiniteScrollPagination) {
      window.InfiniteScrollPagination = class {
        constructor() {
          this.state = {
            isLoading: false,
            hasMorePages: true,
            loadedProductIds: new Set(),
            currentRequest: null,
            initialized: false
          };

          this.elements = {
            productGrid: null,
            loading: null,
            end: null,
            data: null
          };

          this.config = {
            triggerOffset: 400, // pixels from bottom to trigger load
            debounceDelay: 150
          };

          this.init();
        }

        init() {
          if (this.state.initialized) {
            this.cleanup();
          }

          // Wait for DOM to be ready
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', () => this.setup());
          } else {
            this.setup();
          }
        }

        setup() {
          // Get elements
          this.elements.productGrid = document.getElementById('product-grid');
          this.elements.loading = document.getElementById('infinite-scroll-loading');
          this.elements.end = document.getElementById('infinite-scroll-end');
          this.elements.data = document.getElementById('infinite-scroll-data');

          if (!this.elements.productGrid || !this.elements.data) {
            console.warn('Infinite scroll: Required elements not found');
            return;
          }

          // Track existing products
          this.trackExistingProducts();

          // Check if we're on the last page
          const currentPage = parseInt(this.elements.data.dataset.currentPage) || 1;
          const totalPages = parseInt(this.elements.data.dataset.totalPages) || 1;
          
          if (currentPage >= totalPages) {
            this.showEnd();
            return;
          }

          // Set up scroll listener
          this.handleScroll = this.debounce(() => this.checkScroll(), this.config.debounceDelay);
          window.addEventListener('scroll', this.handleScroll, { passive: true });

          this.state.initialized = true;

          // Initial check
          setTimeout(() => this.checkScroll(), 100);
        }

        trackExistingProducts() {
          const products = this.elements.productGrid.querySelectorAll('[data-product-id]');
          products.forEach(product => {
            const id = this.getProductId(product);
            if (id) {
              this.state.loadedProductIds.add(id);
            }
          });
        }

        getProductId(element) {
          // Try multiple methods to get a unique product identifier
          return element.dataset.productId || 
                 element.dataset.productHandle || 
                 element.querySelector('a[href*="/products/"]')?.href.match(/\/products\/([^?]+)/)?.[1] ||
                 element.id;
        }

        checkScroll() {
          if (!this.state.hasMorePages || this.state.isLoading) {
            return;
          }

          const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
          const windowHeight = window.innerHeight;
          const documentHeight = document.documentElement.scrollHeight;

          const distanceFromBottom = documentHeight - (scrollTop + windowHeight);

          if (distanceFromBottom < this.config.triggerOffset) {
            this.loadNextPage();
          }
        }

        async loadNextPage() {
          if (this.state.isLoading || !this.state.hasMorePages) {
            return;
          }

          const nextUrl = this.elements.data.dataset.nextUrl;
          if (!nextUrl) {
            this.state.hasMorePages = false;
            this.showEnd();
            return;
          }

          this.state.isLoading = true;
          this.showLoading();

          try {
            // Cancel any pending request
            if (this.state.currentRequest) {
              this.state.currentRequest.abort();
            }

            const controller = new AbortController();
            this.state.currentRequest = controller;

            const response = await fetch(nextUrl, {
              signal: controller.signal,
              headers: {
                'X-Requested-With': 'XMLHttpRequest'
              }
            });

            if (!response.ok) {
              throw new Error(`HTTP ${response.status}`);
            }

            const html = await response.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');

            // Get new products
            const newProductGrid = doc.getElementById('product-grid');
            const newData = doc.getElementById('infinite-scroll-data');

            if (!newProductGrid) {
              this.state.hasMorePages = false;
              this.showEnd();
              return;
            }

            // Filter out duplicates
            const newProducts = Array.from(newProductGrid.children);
            const uniqueProducts = newProducts.filter(product => {
              const id = this.getProductId(product);
              if (!id || this.state.loadedProductIds.has(id)) {
                return false;
              }
              this.state.loadedProductIds.add(id);
              return true;
            });

            // Append products with animation
            if (uniqueProducts.length > 0) {
              uniqueProducts.forEach((product, index) => {
                product.classList.add('product-item-fade');
                product.style.animationDelay = `${index * 0.05}s`;
                this.elements.productGrid.appendChild(product);
              });

              // Re-initialize any necessary scripts (like quick add, wishlist, etc.)
              this.reinitializeScripts();
            }

            // Update pagination data
            if (newData) {
              this.elements.data.dataset.nextUrl = newData.dataset.nextUrl || '';
              this.elements.data.dataset.currentPage = newData.dataset.currentPage;
            } else {
              this.elements.data.dataset.nextUrl = '';
            }

            // Check if there are more pages
            if (!this.elements.data.dataset.nextUrl) {
              this.state.hasMorePages = false;
              this.showEnd();
            }

          } catch (error) {
            if (error.name !== 'AbortError') {
              console.error('Infinite scroll error:', error);
              this.state.hasMorePages = false;
              this.showEnd();
            }
          } finally {
            this.state.isLoading = false;
            this.state.currentRequest = null;
            this.hideLoading();
          }
        }

        showLoading() {
          if (this.elements.loading) {
            this.elements.loading.style.display = 'block';
            requestAnimationFrame(() => {
              this.elements.loading.classList.add('active');
            });
          }
        }

        hideLoading() {
          if (this.elements.loading) {
            this.elements.loading.classList.remove('active');
            setTimeout(() => {
              this.elements.loading.style.display = 'none';
            }, 300);
          }
        }

        showEnd() {
          if (this.elements.end) {
            this.elements.end.style.display = 'block';
            requestAnimationFrame(() => {
              this.elements.end.classList.add('active');
            });
          }
        }

        hideEnd() {
          if (this.elements.end) {
            this.elements.end.classList.remove('active');
            setTimeout(() => {
              this.elements.end.style.display = 'none';
            }, 300);
          }
        }

        reinitializeScripts() {
          // Trigger custom events for other scripts to reinitialize
          document.dispatchEvent(new CustomEvent('infinite-scroll:products-loaded'));

          // Common reinitializations
          if (typeof Shopify !== 'undefined' && Shopify.ProductForm) {
            // Reinitialize product forms if needed
          }

          // Wishlist apps
          if (typeof iWish !== 'undefined' && iWish.init) {
            iWish.init();
          }

          // Quick view
          if (typeof window.initQuickView === 'function') {
            window.initQuickView();
          }
        }

        reset() {
          this.state.loadedProductIds.clear();
          this.state.hasMorePages = true;
          this.state.isLoading = false;
          this.hideLoading();
          this.hideEnd();
          this.trackExistingProducts();
        }

        cleanup() {
          if (this.handleScroll) {
            window.removeEventListener('scroll', this.handleScroll);
          }
          if (this.state.currentRequest) {
            this.state.currentRequest.abort();
          }
          this.state.initialized = false;
        }

        debounce(func, wait) {
          let timeout;
          return function executedFunction(...args) {
            const later = () => {
              clearTimeout(timeout);
              func(...args);
            };
            clearTimeout(timeout);
            timeout = setTimeout(later, wait);
          };
        }
      };

      // Initialize
      window.infiniteScrollInstance = new window.InfiniteScrollPagination();

      // Listen for collection filter/sort changes
      document.addEventListener('facets-updated', () => {
        setTimeout(() => {
          if (window.infiniteScrollInstance) {
            window.infiniteScrollInstance.cleanup();
            window.infiniteScrollInstance.init();
          }
        }, 300);
      });

      // Listen for custom reinitialization events
      document.addEventListener('infinite-scroll:reinit', () => {
        if (window.infiniteScrollInstance) {
          window.infiniteScrollInstance.cleanup();
          window.infiniteScrollInstance.init();
        }
      });
    }
  </script>
{%- endif -%}