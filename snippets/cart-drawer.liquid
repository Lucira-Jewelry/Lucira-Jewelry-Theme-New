<script>
  document.addEventListener('click', function (e) {
    const viewPriceBreakupEl = e.target.closest('#ViewPriceBreakup');
    if (viewPriceBreakupEl) {
      const drawerFooter = document.querySelector('.drawer__footer');
      const icon = viewPriceBreakupEl.querySelector('i');

      if (drawerFooter) {
        const isVisible = drawerFooter.getAttribute('data-visible') === 'true';

        if (isVisible) {
          // Collapse drawer
          drawerFooter.style.maxHeight = drawerFooter.scrollHeight + 'px';
          requestAnimationFrame(() => {
            drawerFooter.style.maxHeight = '0px';
          });
          drawerFooter.setAttribute('data-visible', 'false');

          // Set icon to angle-up (closed)
          icon.classList.remove('fa-angle-down');
          icon.classList.add('fa-angle-up');
        } else {
          // Expand drawer
          drawerFooter.style.maxHeight = '0px';
          requestAnimationFrame(() => {
            drawerFooter.style.maxHeight = drawerFooter.scrollHeight + 'px';
          });
          drawerFooter.setAttribute('data-visible', 'true');

          // Set icon to angle-down (opened)
          icon.classList.remove('fa-angle-up');
          icon.classList.add('fa-angle-down');
        }
      }
    }
  });
</script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const checkoutBtn = document.getElementById('CartDrawer-Checkout');

    if (!checkoutBtn) return;

    checkoutBtn.addEventListener('click', async function () {
      try {
        const res = await fetch('/cart.js');
        const cart = await res.json();

        const currency = cart.currency || 'INR';
        const grandTotal = cart.original_total_price / 100;
        const totalValue = cart.total_price / 100;
        const discountAmount = (cart.original_total_price - cart.total_price) / 100;
        const totalQuantity = cart.item_count;
        const uniqueProductCount = new Set(cart.items.map((item) => item.product_id)).size;

        const lineItems = cart.items.map((item, index) => ({
          id: item.product_id?.toString() || '',
          sku: item.sku || '',
          variant_id: item.variant_id?.toString() || '',
          product_name: item.product_title,
          product_type: item.product_type || 'Jewelry',
          category: item.product_type || 'General',
          sub_category: item.variant_title || '',
          price: item.original_price / 100,
          offer_price: item.final_price / 100,
          quantity: item.quantity,
          thumbnail_image: item.image || '',
          index_position: index + 1,
        }));

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'beginCheckout',
          cart: {
            currency: currency,
            grand_total: grandTotal,
            total_value: totalValue,
            discount_amount: discountAmount,
            total_quantity: totalQuantity,
            total_product: uniqueProductCount,
            coupon_code: cart.cart_level_discount_applications?.[0]?.code || '',
            offer_detail: cart.cart_level_discount_applications?.[0]?.title || '',
            items: lineItems,
          },
        });
      } catch (error) {
        console.error('Failed to fetch cart or push beginCheckout:', error);
      }
    });
  });
</script>


<script>
document.addEventListener('click', function (e) {
  const btn = e.target.closest('.toggle-children-btn');
  if (!btn) return;

  e.preventDefault();

  const bundleId = btn.dataset.bundleId;
  if (!bundleId) return;

  const childContainer = document.querySelector(
    '.cart-item_components[data-bundle-id="' + bundleId + '"]'
  );

  if (!childContainer) return;

  const isOpen = btn.getAttribute('aria-expanded') === 'true';

  btn.setAttribute('aria-expanded', String(!isOpen));
  childContainer.style.display = isOpen ? 'none' : 'block';
});

</script>

<script>
document.addEventListener('click', async function (e) {
  const btn = e.target.closest('.parent-remove-btn');
  if (!btn) return;

  e.preventDefault();
  e.stopPropagation();

  const bundleId = btn.dataset.bundleId;
  if (!bundleId) return;

  // 🔹 Smooth animation first
  const row = btn.closest('.cart-item');
  if (row) row.classList.add('is-removing');

  try {
    // 1️⃣ Get cart
    const cartRes = await fetch('/cart.js');
    const cart = await cartRes.json();

    // 2️⃣ Build updates (remove whole bundle)
    const updates = {};
    cart.items.forEach(item => {
      if (item.properties?._bundle_id === bundleId) {
        updates[item.key] = 0;
      }
    });

    // 3️⃣ Update cart
    const updateRes = await fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ updates })
    });

    const updatedCart = await updateRes.json();

    // 4️⃣ Refresh cart drawer & bubble HTML
    const sectionRes = await fetch(
      `${window.location.pathname}?sections=cart-drawer,cart-icon-bubble`
    );
    const sections = await sectionRes.json();

    const parser = new DOMParser();
    
    if (sections['cart-drawer']) {
      const drawerHtml = parser.parseFromString(sections['cart-drawer'], 'text/html');
      const newDrawer = drawerHtml.querySelector('cart-drawer');
      const oldDrawer = document.querySelector('cart-drawer');
      if (newDrawer && oldDrawer) {
        oldDrawer.replaceWith(newDrawer);
      }
    }

    if (sections['cart-icon-bubble']) {
      const bubbleHtml = parser.parseFromString(sections['cart-icon-bubble'], 'text/html');
      const newBubbleInner = bubbleHtml.querySelector('#cart-icon-bubble');
      const oldBubble = document.querySelector('#cart-icon-bubble');
      if (newBubbleInner && oldBubble) {
        oldBubble.innerHTML = newBubbleInner.innerHTML;
      }
    }

    // 5️⃣ Update cart bubble
    document.dispatchEvent(
      new CustomEvent('cart:change', {
        bubbles: true,
        detail: { cart: updatedCart }
      })
    );

  } catch (err) {
    console.error('Remove failed', err);
  }
});

</script>




