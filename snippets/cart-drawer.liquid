                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/IGI_Mini_Cart_Icons.png?v=1754052339"
                    class="item-certified"
                    alt="igi-certified"
                    title="igi-certified"
                    width="auto"
                    height="auto"
                  >
                  IGI Certified
                </div>
                <div class="cart-certificate-item-wrapper">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/BIS_Mini_Cart_Icons.png?v=1754052339"
                    class="item-certified"
                    alt="BIS Hallmarked"
                    title="BIS Hallmarked"
                    width="auto"
                    height="auto"
                  >
                  BIS Hallmarked
                </div>
              </div>
              <div class="drawer__cart-items-wrapper">
                <table class="cart-items" role="table">
                  <tbody role="rowgroup">
                    {%- for item in cart.items -%}
                      <tr
                        id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                        class="cart-item"
                        role="row"
                        data-cart-item
                        data-variant-id="{{ item.variant.id }}"
