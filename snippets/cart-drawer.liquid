                                </button>
                              </cart-remove-button>
                            </div>
                          </quantity-popover>
                        </td>
                      </tr>
                    {%- endfor -%}
                  </tbody>
                </table>
              </div>
              {% comment %} {% if cart.total_price > 1500000 %}
                <div class="gold-offers-wrapper" alt="free gold coin">
                  <img
