<script>
  // Price Breakup Toggle
  document.addEventListener('click', function (e) {
    const viewPriceBreakupEl = e.target.closest('#ViewPriceBreakup');
    if (viewPriceBreakupEl) {
      const drawerFooter = document.querySelector('.drawer__footer');

      if (drawerFooter) {
        const isVisible = drawerFooter.getAttribute('data-visible') === 'true';

        if (isVisible) {
          drawerFooter.style.maxHeight = drawerFooter.scrollHeight + 'px';
          requestAnimationFrame(() => {
            drawerFooter.style.maxHeight = '0px';
          });
          drawerFooter.setAttribute('data-visible', 'false');
        } else {
          drawerFooter.style.maxHeight = '0px';
          requestAnimationFrame(() => {
            drawerFooter.style.maxHeight = drawerFooter.scrollHeight + 'px';
          });
          drawerFooter.setAttribute('data-visible', 'true');
        }
      }
    }
  });
</script>

<script>
  // Begin Checkout Analytics
  document.addEventListener('DOMContentLoaded', function () {
    const checkoutBtn = document.getElementById('CartDrawer-Checkout');

    if (!checkoutBtn) return;

    checkoutBtn.addEventListener('click', async function () {
      try {
        const res = await fetch('/cart.js');
        const cart = await res.json();

        const currency = cart.currency || 'INR';
        const grandTotal = cart.original_total_price / 100;
        const totalValue = cart.total_price / 100;
        const discountAmount = (cart.original_total_price - cart.total_price) / 100;
        const totalQuantity = cart.item_count;
        const uniqueProductCount = new Set(cart.items.map((item) => item.product_id)).size;

        const lineItems = cart.items.map((item, index) => ({
          id: item.product_id?.toString() || '',
          sku: item.sku || '',
          variant_id: item.variant_id?.toString() || '',
          product_name: item.product_title,
          product_type: item.product_type || 'Jewelry',
          category: item.product_type || 'General',
          sub_category: item.variant_title || '',
          price: item.original_price / 100,
          offer_price: item.final_price / 100,
          quantity: item.quantity,
          thumbnail_image: item.image || '',
          index_position: index + 1,
        }));

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'beginCheckout',
          cart: {
            currency: currency,
            grand_total: grandTotal,
            total_value: totalValue,
            discount_amount: discountAmount,
            total_quantity: totalQuantity,
            total_product: uniqueProductCount,
            coupon_code: cart.cart_level_discount_applications?.[0]?.code || '',
            offer_detail: cart.cart_level_discount_applications?.[0]?.title || '',
            items: lineItems,
          },
        });
      } catch (error) {
        console.error('Failed to fetch cart or push beginCheckout:', error);
      }
    });
  });
</script> {% endcomment %}








