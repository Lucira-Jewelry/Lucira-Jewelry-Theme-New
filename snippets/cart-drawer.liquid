{{ 'quantity-popover.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'component-card.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'insurance-card.css' | asset_url | stylesheet_tag: preload: true }}

{% comment %} <script src="{{ 'insurance-manager.js' | asset_url }}" defer="defer"></script> {% endcomment %}
<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      {%- if cart == empty -%}
        <div class="drawer__inner-empty">
          <div class="cart-drawer__warnings center{% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}">
            <div class="cart-drawer__empty-content">
              {{- 'empty-cart-drawer-icon.svg' | inline_asset_content -}}
              <p class="cart__empty-text">{{ 'sections.cart.empty' | t }}</p>

              <a href="{{ routes.all_products_collection_url }}" class="button">
                {{ 'general.continue_shopping' | t }}
              </a>

              {%- if shop.customer_accounts_enabled and customer == null -%}
                <p class="cart__login-title h3">{{ 'sections.cart.login.title' | t }}</p>
                <p class="cart__login-paragraph">
                  {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
                </p>
              {%- endif -%}
            </div>
          </div>
          {%- if settings.cart_drawer_collection != blank -%}
            <div class="cart-drawer__collection">
              {% render 'card-collection', card_collection: settings.cart_drawer_collection, columns: 1 %}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="drawer__header">
        <p class="drawer__heading">MY CART</p>
        <div
          class="cart_drawer__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <svg width="32" height="32">
            <use href="#icon-star-circle"></use>
          </svg>
        </div>
      </div>

      <cart-drawer-items
        {% if cart == empty %}
          class=" is-empty"
        {% endif %}
      >
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
            {%- if cart != empty -%}
              <div class="cart-certificate-wrapper">
                <div class="cart-certificate-item-wrapper">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/IGI_Mini_Cart_Icons.png?v=1754052339"
                    class="item-certified"
                    alt="igi-certified"
                    title="igi-certified"
                    width="auto"
                    height="auto"
                  >
                  IGI Certified
                </div>
                <div class="cart-certificate-item-wrapper">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/BIS_Mini_Cart_Icons.png?v=1754052339"
                    class="item-certified"
                    alt="BIS Hallmarked"
                    title="BIS Hallmarked"
                    width="auto"
                    height="auto"
                  >
                  BIS Hallmarked
                </div>
              </div>

              <div class="drawer__cart-items-wrapper">
                <table class="cart-items" role="table">
                  <tbody role="rowgroup">
                    {%- for item in cart.items -%}
                      <tr
                        id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                        class="cart-item"
                        role="row"
                        data-cart-item
                        data-variant-id="{{ item.variant.id }}"
                      >
                        <td class="cart-item__media" role="cell" headers="CartDrawer-ColumnProductImage">
                          {% if item.image %}
                            <a href="{{ item.url }}" class="cart-item__link" tabindex="-1" aria-hidden="true">
                              <img
                                class="cart-item__image"
                                src="{{ item.image | image_url: width: 300 }}"
                                alt="{{ item.image.alt | escape }}"
                                title="{{ item.image.alt | escape }}"
                                loading="lazy"
                                width="150"
                                height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
                              >
                            </a>
                          {% endif %}
                        </td>

                        <td class="cart-item__details" role="cell" headers="CartDrawer-ColumnProduct">
                          <a href="{{ item.url }}" class="cart-item__name h4 break desktop-show">
                            {{- item.product.title | escape | truncate: 42 -}}
                          </a>
                          <a href="{{ item.url }}" class="cart-item__name h4 break mobile-show">
                            {{- item.product.title | escape | truncate: 32 -}}
                          </a>

                          {%- if item.product.has_only_default_variant == false
                            or item.properties.size != 0
                            or item.selling_plan_allocation != null
                          -%}
                            <dl>
                              {%- if item.product.has_only_default_variant == false -%}
                                {%- for option in item.options_with_values -%}
                                  <div class="product-option">
                                    <dt>{{ option.name }}:</dt>
                                    <dd>
                                      {{ option.value -}}
                                      {%- unless forloop.last %}, {% endunless %}
                                    </dd>
                                  </div>
                                {%- endfor -%}
                              {%- endif -%}

                              {%- for property in item.properties -%}
                                {%- assign property_first_char = property.first | slice: 0 -%}
                                {%- if property.last != blank and property_first_char != '_' -%}
                                  {%- unless property.first == 'EngravingText' or property.first == 'EngravingFont' -%}
                                    <div class="product-option">
                                      <dt>{{ property.first }}:</dt>
                                      <dd>
                                        {%- if property.last contains '/uploads/' -%}
                                          <a
                                            href="{{ property.last }}"
                                            class="link"
                                            target="_blank"
                                            aria-describedby="a11y-new-window-message"
                                          >
                                            {{ property.last | split: '/' | last }}
                                          </a>
                                        {%- else -%}
                                          {{ property.last }}
                                        {%- endif -%}
                                      </dd>
                                    </div>
                                  {%- endunless -%}
                                {%- endif -%}
                              {%- endfor -%}
                            </dl>

                            {%- assign v = item.variant -%}
                            {%- assign delivery_days = 2 -%}
                            {%- if v -%}
                              {%- if v.inventory_management != blank -%}
                                {%- if v.inventory_quantity <= 0 -%}
                                  {%- assign delivery_days = 15 -%}
                                {%- endif -%}
                              {%- else -%}
                                {%- if v.available == false -%}
                                  {%- assign delivery_days = 15 -%}
                                {%- endif -%}
                              {%- endif -%}
                            {%- else -%}
                              {%- if item.product.available == false -%}
                                {%- assign delivery_days = 15 -%}
                              {%- endif -%}
                            {%- endif -%}

                            {%- assign total_seconds = delivery_days | times: 86400 -%}
                            {%- assign now = 'now' | date: '%s' -%}
                            {%- assign future_timestamp = now | plus: total_seconds -%}
                            {%- assign delivery_date = future_timestamp | date: '%d %b, %Y' -%}

                            <div class="delivery-date-expected">
                              Dispatch by: <span>{{ delivery_date }}</span>
                            </div>

                            <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                          {%- endif -%}

                        </td>

                        <td class="cart-item__totals right" role="cell" headers="CartDrawer-ColumnTotal">
                          {%- render 'loading-spinner' -%}
                          <div class="cart-item__price-wrapper">
                            {%- if item.original_line_price != item.final_line_price -%}
                              <div class="cart-item__discounted-prices">
                                <span class="visually-hidden">
                                  {{ 'products.product.price.regular_price' | t }}
                                </span>
                                <s class="cart-item__old-price price price--end">
                                  {{ item.original_line_price | money }}
                                </s>
                                <span class="visually-hidden">
                                  {{ 'products.product.price.sale_price' | t }}
                                </span>
                                <span class="price price--end">
                                  {{ item.final_line_price | money }}
                                </span>
                              </div>
                            {%- else -%}
                              <span class="price price--end">
                                {{ item.original_line_price | money }}
                              </span>
                              <span class="original-price-cut-off">
                                {{ item.variant.compare_at_price | times: item.quantity | money }}
                              </span>
                            {%- endif -%}
                          </div>
                        </td>

                        {%- liquid
                          assign has_qty_rules = false
                          if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
                            assign has_qty_rules = true
                          endif

                          assign has_vol_pricing = false
                          if item.variant.quantity_price_breaks.size > 0
                            assign has_vol_pricing = true
                          endif
                        -%}
                        <td
                          class="cart-item__quantity {% if has_qty_rules or has_vol_pricing %} cart-item__quantity--info{% endif %}"
                          role="cell"
                          headers="CartDrawer-ColumnQuantity"
                          style="position:absolute;"
                        >
                          <quantity-popover>
                            <div class="cart-qty cart-item__quantity-wrapper quantity-popover-wrapper">
                              <div class="quantity-popover-container{% if has_qty_rules or has_vol_pricing %} quantity-popover-container--hover{% endif %}">
                                <quantity-input class="quantity cart-quantity qty">
                                  <button class="quantity__button" name="minus" type="button">
                                    <span class="visually-hidden">
                                      {{-
                                        'products.product.quantity.decrease'
                                        | t: product: item.product.title
                                        | escape
                                      -}}
                                    </span>
                                    <span class="svg-wrapper quantity-icon">
                                      {{- 'icon-minus.svg' | inline_asset_content -}}
                                    </span>
                                  </button>
                                  <input
                                    class="quantity__input"
                                    type="number"
                                    data-quantity-variant-id="{{ item.variant.id }}"
                                    name="updates[]"
                                    value="{{ item.quantity }}"
                                    data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                    min="0"
                                    data-min="{{ item.variant.quantity_rule.min }}"
                                    {% if item.variant.quantity_rule.max != null %}
                                      max="{{ item.variant.quantity_rule.max }}"
                                    {% endif %}
                                    step="{{ item.variant.quantity_rule.increment }}"
                                    aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                    id="Drawer-quantity-{{ item.index | plus: 1 }}"
                                    data-index="{{ item.index | plus: 1 }}"
                                  >
                                  <button class="quantity__button" name="plus" type="button">
                                    <span class="visually-hidden">
                                      {{-
                                        'products.product.quantity.increase'
                                        | t: product: item.product.title
                                        | escape
                                      -}}
                                    </span>
                                    <span class="svg-wrapper quantity-icon">
                                      {{- 'icon-plus.svg' | inline_asset_content -}}
                                    </span>
                                  </button>
                                </quantity-input>
                              </div>
                              <cart-remove-button
                                id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                                data-index="{{ item.index | plus: 1 }}"
                              >
                                <button
                                  type="button"
                                  class="button button--tertiary cart-remove-button"
                                  aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                                  data-variant-id="{{ item.variant.id }}"
                                >
                                  <span class="svg-wrapper">{{ 'icon-remove.svg' | inline_asset_content }}</span>
                                </button>
                              </cart-remove-button>
                            </div>
                          </quantity-popover>
                        </td>


                        <td class="td-cart">
                          
                        </td>

                      </tr>
                    {%- endfor -%}
                  </tbody>
                </table>
              </div>


              {% comment %} DO NOT REMOVE {% endcomment %}
              {% if cart.total_price > 1500000 %}
                <div class="gold-offers-wrapper " alt="free gold coin">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Gold-Coin--1gm_1_2_1.png?v=1759495662"
                    width="100"
                    height="100"
                    loading="lazy"
                    alt="free gold coin"
                    title="free gold icon"
                  >
                  <div class="gold-offers-content-wrap" alt="free gold coin">
                    <h4 style="color: white;margin: 0;">Your Cart is Eligible for Gold Coin(s)</h4>
                    <p>Your gold coin(s) are ready. Claim them at checkout!</p>
                  </div>
                </div>
              {% endif %} 
              
            {%- endif -%}

            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>

      {% comment %} {%- assign has_products = false -%}
      {%- assign product_count = 0 -%}
      {%- for item in cart.items -%}
        {%- if item.variant.id != 47709366026458 -%}
          {%- assign has_products = true -%}
          {%- assign product_count = product_count | plus: item.quantity -%}
        {%- endif -%}
      {%- endfor -%}

      <!-- ── APPLY INSURANCE label ── -->
      {% comment %} <div class="apply-insurance" style="display: {% if has_products %}flex{% else %}none{% endif %};">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M20 13C20 18 16.5 20.5 12.34 21.95C12.1222 22.0238 11.8855 22.0202 11.67 21.94C7.5 20.5 4 18 4 13V5.99996C4 5.73474 4.10536 5.48039 4.29289 5.29285C4.48043 5.10532 4.73478 4.99996 5 4.99996C7 4.99996 9.5 3.79996 11.24 2.27996C11.4519 2.09896 11.7214 1.99951 12 1.99951C12.2786 1.99951 12.5481 2.09896 12.76 2.27996C14.51 3.80996 17 4.99996 19 4.99996C19.2652 4.99996 19.5196 5.10532 19.7071 5.29285C19.8946 5.48039 20 5.73474 20 5.99996V13Z" stroke="#666666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M9 12L11 14L15 10" stroke="#666666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        APPLY INSURANCE
      </div> {% endcomment %}

      <!-- Hidden checkbox — insurance-manager.js listens to the 'change' event on this. DO NOT REMOVE. -->
      <input type="checkbox" id="insuranceCheckbox" style="position:absolute;opacity:0;pointer-events:none;width:0;height:0;">

      <!-- ── Insurance card ── -->
      <div class="insurance-box" id="insuranceBox" style="display: {% if has_products %}block{% else %}none{% endif %};">
        <div class="insurance-card">

          <!-- Left: image with shield badge -->
          <div class="insurance-card__image-wrap">
            <img
              src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/296cce7d9884a58ac89bb09b230104f8fb2ef884_1.png?v=1774077656"
              alt="Lucira Jewelry Insurance"
              class="insurance-card__img"
              loading="lazy"
              width="82"
              height="82"
            >
            <span class="insurance-card__shield-badge">
              <svg width="35" height="37" viewBox="0 0 35 37" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 9.23749C5 8.73124 5.41786 8.3222 5.92486 8.25616C9.91586 7.74257 15.7343 4.24647 17.4837 3.14775C17.6382 3.05124 17.8172 3 18 3C18.1828 3 18.3618 3.05124 18.5163 3.14775C20.2657 4.24647 26.0841 7.74074 30.0751 8.25616C30.5821 8.3222 31 8.73124 31 9.23749V17.9502C31 29.8729 18 34 18 34C18 34 5 29.8729 5 17.9502V9.23749Z" fill="#5A413F"/>
                <path d="M6 9.83507C6 9.36148 6.38571 8.97883 6.85371 8.91706C10.5377 8.4366 15.9086 5.16605 17.5234 4.13822C17.666 4.04793 17.8313 4 18 4C18.1687 4 18.334 4.04793 18.4766 4.13822C20.0914 5.16605 25.4623 8.43488 29.1463 8.91706C29.6143 8.97883 30 9.36148 30 9.83507V17.9857C30 29.1392 18 33 18 33C18 33 6 29.1392 6 17.9857V9.83507Z" fill="#FBF7F2"/>
                <path d="M16.0312 25.2999C16.0551 25.3212 16.0854 25.3341 16.1173 25.3367C16.1492 25.3392 16.1811 25.3313 16.2081 25.314C16.2351 25.2968 16.2557 25.2712 16.2668 25.2412C16.278 25.2112 16.279 25.1783 16.2697 25.1477L14.3797 18.6692C14.3627 18.6101 14.3279 18.5578 14.2802 18.5192C14.2324 18.4805 14.174 18.4575 14.1127 18.4532C13.8067 18.4307 13.5012 18.4057 13.1962 18.3782L10.6687 18.1479C10.642 18.1453 10.6151 18.15 10.5908 18.1615C10.5666 18.173 10.5459 18.1908 10.5309 18.2131C10.516 18.2355 10.5074 18.2614 10.506 18.2882C10.5047 18.315 10.5106 18.3417 10.5232 18.3654C11.8905 20.9229 13.8592 23.3604 16.0312 25.2999ZM17.8852 26.6694C17.9002 26.7219 17.9452 26.7609 18 26.7609C18.0265 26.7605 18.0522 26.7513 18.073 26.7347C18.0937 26.7182 18.1084 26.6952 18.1147 26.6694L20.4277 18.7397C20.4346 18.7166 20.4359 18.6923 20.4314 18.6687C20.4269 18.6451 20.4168 18.6229 20.4019 18.604C20.3871 18.5851 20.3679 18.5701 20.346 18.5601C20.3242 18.5502 20.3002 18.5457 20.2762 18.5469C18.7594 18.6118 17.2405 18.6118 15.7237 18.5469C15.6998 18.5457 15.676 18.5502 15.6542 18.5601C15.6324 18.57 15.6133 18.585 15.5984 18.6038C15.5836 18.6226 15.5735 18.6447 15.5689 18.6682C15.5644 18.6917 15.5655 18.7159 15.5722 18.7389L17.8852 26.6694ZM19.7302 25.1477C19.6882 25.2902 19.8577 25.3989 19.9687 25.2999C22.1407 23.3597 24.1095 20.9229 25.4767 18.3654C25.4893 18.3418 25.4952 18.3152 25.4939 18.2884C25.4926 18.2617 25.484 18.2358 25.4692 18.2135C25.4544 18.1912 25.4338 18.1734 25.4096 18.1618C25.3855 18.1503 25.3586 18.1455 25.332 18.1479L22.8045 18.3782C22.4985 18.4057 22.1927 18.4307 21.8872 18.4532C21.826 18.4575 21.7675 18.4805 21.7198 18.5192C21.672 18.5578 21.6373 18.6101 21.6202 18.6692L19.7302 25.1477ZM25.3507 17.0169C25.3769 17.0146 25.402 17.0055 25.4235 16.9905C25.445 16.9754 25.4622 16.955 25.4734 16.9312C25.4845 16.9075 25.4893 16.8812 25.4871 16.855C25.4849 16.8289 25.4759 16.8037 25.461 16.7822L23.0325 13.2609C22.929 13.1109 22.7906 12.9884 22.6293 12.9037C22.4679 12.819 22.2884 12.7748 22.1062 12.7749H20.2387C20.2141 12.7749 20.1898 12.781 20.1681 12.7926C20.1464 12.8042 20.1278 12.8209 20.1141 12.8414C20.1004 12.8618 20.092 12.8854 20.0895 12.9099C20.087 12.9344 20.0906 12.9591 20.1 12.9819L21.7927 17.1242C21.8168 17.1827 21.8588 17.2322 21.9126 17.2655C21.9665 17.2988 22.0296 17.3141 22.0927 17.3094C22.2957 17.2939 22.499 17.2764 22.7025 17.2569L25.3507 17.0169ZM18.8737 12.9594C18.8509 12.9047 18.8123 12.8579 18.763 12.8251C18.7136 12.7922 18.6555 12.7748 18.5962 12.7749H17.4037C17.3444 12.7748 17.2864 12.7922 17.237 12.8251C17.1876 12.8579 17.1491 12.9047 17.1262 12.9594L15.3577 17.2029C15.3486 17.2251 15.3449 17.2492 15.347 17.2731C15.3491 17.297 15.3569 17.3201 15.3697 17.3404C15.3826 17.3607 15.4001 17.3776 15.4209 17.3897C15.4416 17.4018 15.465 17.4087 15.489 17.4099C17.1615 17.4909 18.8385 17.4909 20.5117 17.4099C20.5357 17.4086 20.5589 17.4016 20.5796 17.3894C20.6002 17.3773 20.6177 17.3604 20.6305 17.3401C20.6432 17.3199 20.651 17.2968 20.653 17.2729C20.6551 17.2491 20.6514 17.2251 20.6422 17.2029L18.8737 12.9594ZM15.9 12.9819C15.9093 12.9591 15.9129 12.9344 15.9105 12.9099C15.908 12.8854 15.8995 12.8618 15.8858 12.8414C15.8721 12.8209 15.8536 12.8042 15.8318 12.7926C15.8101 12.781 15.7859 12.7749 15.7612 12.7749H13.8937C13.7115 12.7748 13.532 12.819 13.3707 12.9037C13.2093 12.9884 13.071 13.1109 12.9675 13.2609L10.539 16.7822C10.524 16.8037 10.515 16.8289 10.5129 16.855C10.5107 16.8812 10.5154 16.9075 10.5266 16.9312C10.5377 16.955 10.5549 16.9754 10.5765 16.9905C10.598 17.0055 10.6231 17.0146 10.6492 17.0169L13.2975 17.2569C13.5005 17.2764 13.7037 17.2939 13.9072 17.3094C13.9704 17.3141 14.0334 17.2988 14.0873 17.2655C14.1412 17.2322 14.1832 17.1827 14.2072 17.1242L15.9 12.9819Z" fill="#5A413F"/>
                </svg>
            </span>
          </div>

          <!-- Middle: content -->
          <div class="insurance-card__body">
            <h3 class="insurance-card__title">LUCIRA JEWELRY INSURANCE</h3>
            <p class="insurance-card__desc">
              Protect your jewelry from accidental damage, loss, or theft with a one-time protection plan.
              {% comment %} <a href="/pages/jewelry-insurance" class="insurance-card__learn">Learn More</a> {% endcomment %}
            </p>
            <div class="insurance-card__price-row">
              <s class="insurance-card__original">₹999</s>
              <span class="insurance-card__free">₹1</span>
            </div>
          </div>

          <!-- Right: REMOVE (hidden by default) + ADD / ADDED button stacked -->
          <div class="insurance-btn-wrapper" id="insuranceBtnWrapper">
            <button
              type="button"
              class="insurance-remove-btn"
              id="insuranceRemoveBtn"
              aria-label="Remove jewelry insurance from cart"
            >
              REMOVE
            </button>
            <button
              type="button"
              class="insurance-add-btn"
              id="insuranceAddBtn"
              aria-label="Add jewelry insurance to cart"
            >
              ADD
            </button>
          </div>

        </div>
      </div>

      <!-- Loader (unchanged — insurance-manager.js controls .active class) -->
      <div id="insuranceLoader" class="insurance-loader">
        <span class="loader-spinner"></span>
        <span class="loader-text">Updating insurance…</span>
      </div>

