</cart-drawer>

<script>
  // Price Breakup Toggle
  document.addEventListener('click', function (e) {
    const viewPriceBreakupEl = e.target.closest('#ViewPriceBreakup');
    if (viewPriceBreakupEl) {
      const drawerFooter = document.querySelector('.drawer__footer');
      if (drawerFooter) {
        const isVisible = drawerFooter.getAttribute('data-visible') === 'true';
        if (isVisible) {
          drawerFooter.style.maxHeight = drawerFooter.scrollHeight + 'px';
          requestAnimationFrame(() => { drawerFooter.style.maxHeight = '0px'; });
          drawerFooter.setAttribute('data-visible', 'false');
        } else {
          drawerFooter.style.maxHeight = '0px';
          requestAnimationFrame(() => { drawerFooter.style.maxHeight = drawerFooter.scrollHeight + 'px'; });
          drawerFooter.setAttribute('data-visible', 'true');
        }
      }
    }
  });
</script>

{% comment %} <script>
  (function () {
    const INSURANCE_VARIANT_ID = 47709366026458;
    let _observer = null;
    let _debounceTimer = null;

    // Fetch actual cart and check if insurance variant is present
    async function isInsuranceInCart() {
      try {
        const res = await fetch('/cart.js');
        const cart = await res.json();
        return cart.items.some(function (item) {
          return item.variant_id === INSURANCE_VARIANT_ID;
        });
      } catch (e) {
        return false;
      }
    }

    function syncUI(checkbox, addBtn, wrapper) {
      if (checkbox.checked) {
        addBtn.textContent = 'ADDED ✓';
        addBtn.classList.add('added');
        wrapper.classList.add('is-added');
      } else {
        addBtn.textContent = 'ADD';
        addBtn.classList.remove('added');
        wrapper.classList.remove('is-added');
      }
    }

    async function initInsuranceCard() {
      const addBtn    = document.getElementById('insuranceAddBtn');
      const removeBtn = document.getElementById('insuranceRemoveBtn');
      const wrapper   = document.getElementById('insuranceBtnWrapper');
      const checkbox  = document.getElementById('insuranceCheckbox');
      if (!addBtn || !removeBtn || !wrapper || !checkbox) return;

      // Always sync checkbox state from actual cart — not from DOM
      const inCart = await isInsuranceInCart();
      checkbox.checked = inCart;
      syncUI(checkbox, addBtn, wrapper);

      // Clone nodes to wipe any stale duplicate listeners from previous renders
      const freshAddBtn    = addBtn.cloneNode(true);
      const freshRemoveBtn = removeBtn.cloneNode(true);
      addBtn.parentNode.replaceChild(freshAddBtn, addBtn);
      removeBtn.parentNode.replaceChild(freshRemoveBtn, removeBtn);

      freshAddBtn.addEventListener('click', function () {
        checkbox.click(); // fires 'change' → insurance-manager.js handles cart add/remove
      });

      freshRemoveBtn.addEventListener('click', function () {
        if (checkbox.checked) {
          checkbox.click();
        }
      });

      checkbox.addEventListener('change', function () {
        syncUI(checkbox, freshAddBtn, wrapper);
      });
    }

    // Debounced re-init — called by MutationObserver after every cart re-render
    function debouncedInit() {
      clearTimeout(_debounceTimer);
      _debounceTimer = setTimeout(initInsuranceCard, 300);
    }

    // Watch the entire cart drawer for DOM changes (covers quantity updates,
    // item adds/removes — all of which cause Dawn's cart.js to replace innerHTML)
    function observeCartDrawer() {
      if (_observer) {
        _observer.disconnect();
      }
      const cartDrawer = document.getElementById('CartDrawer');
      if (!cartDrawer) return;

      _observer = new MutationObserver(function (mutations) {
        // Only act on childList / subtree mutations (actual DOM re-renders),
        // not attribute changes (avoids infinite loop from syncUI class toggles)
        const hasStructural = mutations.some(function (m) {
          return m.type === 'childList';
        });
        if (hasStructural) {
          debouncedInit();
        }
      });

      _observer.observe(cartDrawer, { childList: true, subtree: true });
    }

    function boot() {
      initInsuranceCard();
      observeCartDrawer();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }
  })();
</script> {% endcomment %}

<script>
  // Begin Checkout Analytics
  document.addEventListener('DOMContentLoaded', function () {
    const checkoutBtn = document.getElementById('CartDrawer-Checkout');
    if (!checkoutBtn) return;

    checkoutBtn.addEventListener('click', async function () {
      try {
        const res = await fetch('/cart.js');
        const cart = await res.json();

        const currency = cart.currency || 'INR';
        const grandTotal = cart.original_total_price / 100;
        const totalValue = cart.total_price / 100;
        const discountAmount = (cart.original_total_price - cart.total_price) / 100;
        const totalQuantity = cart.item_count;
        const uniqueProductCount = new Set(cart.items.map((item) => item.product_id)).size;

        const lineItems = cart.items.map((item, index) => ({
          id: item.product_id?.toString() || '',
          sku: item.sku || '',
          variant_id: item.variant_id?.toString() || '',
          product_name: item.product_title,
          product_type: item.product_type || 'Jewelry',
          category: item.product_type || 'General',
          sub_category: item.variant_title || '',
          price: item.original_price / 100,
          offer_price: item.final_price / 100,
          quantity: item.quantity,
          thumbnail_image: item.image || '',
          index_position: index + 1,
        }));

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'beginCheckout',
          cart: {
            currency: currency,
            grand_total: grandTotal,
            total_value: totalValue,
            discount_amount: discountAmount,
            total_quantity: totalQuantity,
            total_product: uniqueProductCount,
            coupon_code: cart.cart_level_discount_applications?.[0]?.code || '',
            offer_detail: cart.cart_level_discount_applications?.[0]?.title || '',
            items: lineItems,
          },
        });
      } catch (error) {
        console.error('Failed to fetch cart or push beginCheckout:', error);
      }
    });
  });
</script>
