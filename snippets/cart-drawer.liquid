{% comment %}
  Renders cart drawer

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'component-card.css' | asset_url | stylesheet_tag: preload: true }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer {
  visibility: hidden;
  }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      {%- if cart == empty -%}
        <div class="drawer__inner-empty">
          <div class="cart-drawer__warnings center{% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}">
            <div class="cart-drawer__empty-content">
              {{- 'empty-cart-drawer-icon.svg' | inline_asset_content -}}
              <p class="cart__empty-text">{{ 'sections.cart.empty' | t }}</p>

              <a href="{{ routes.all_products_collection_url }}" class="button">
                {{ 'general.continue_shopping' | t }}
              </a>

              {%- if shop.customer_accounts_enabled and customer == null -%}
                <p class="cart__login-title h3">{{ 'sections.cart.login.title' | t }}</p>
                <p class="cart__login-paragraph">
                  {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
                </p>
              {%- endif -%}
            </div>
          </div>
          {%- if settings.cart_drawer_collection != blank -%}
            <div class="cart-drawer__collection">
              {% render 'card-collection', card_collection: settings.cart_drawer_collection, columns: 1 %}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
      <div class="drawer__header">
        <p class="drawer__heading">MY CART</p>
        <div
          class="cart_drawer__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <svg width="32" height="32">
            <use href="#icon-star-circle"></use>
          </svg>

        </div>
      </div>
      <cart-drawer-items
        {% if cart == empty %}
          class=" is-empty"
        {% endif %}
      >
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
            {%- if cart != empty -%}
              <div class="cart-certificate-wrapper">
                <div class="cart-certificate-item-wrapper">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/IGI_Mini_Cart_Icons.png?v=1754052339"
                    class="item-certified"
                    alt="igi-certified"
                     title="igi-certified"
                    width="auto"
                    height="auto"
                  >
                  IGI Certified
                </div>
                <div class="cart-certificate-item-wrapper">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/BIS_Mini_Cart_Icons.png?v=1754052339"
                    class="item-certified"
                    alt="BIS Hallmarked"
                       title="BIS Hallmarked"
                    width="auto"
                    height="auto"
                  >
                  BIS Hallmarked
                </div>
              </div>
              <div class="drawer__cart-items-wrapper">
                <table class="cart-items" role="table">
                  
                 <tbody role="rowgroup">

{% assign grouped_items = cart.items | group_by: "properties._group_id" %}

{% for group in grouped_items %}

  {% if group.name != blank %}

    {%- assign parent = nil -%}
    {%- for i in group.items -%}
      {% if i.properties._item_role == 'parent' %}
        {% assign parent = i %}
      {% endif %}
    {%- endfor -%}

    {% if parent %}
    <!-- ================= PARENT ================= -->
    <tr class="cart-item parent-item" role="row">
      <td class="cart-item__media">
        <img
          class="cart-item__image"
          src="{{ parent.image | image_url: width: 300 }}"
          alt="{{ parent.image.alt | escape }}"
        >
      </td>

      <td class="cart-item__details">
        <p class="cart-item__name h4">
          {{ parent.product.title }}
        </p>

        {% for option in parent.options_with_values %}
          <div class="product-option">
            {{ option.name }}: {{ option.value }}
          </div>
        {% endfor %}

        <p class="view-breakup" data-group="{{ group.name }}">
          View Breakup <span>▾</span>
        </p>

        <div class="breakup-wrapper" data-breakup="{{ group.name }}" hidden>
          {% for child in group.items %}
            {% if child.properties._item_role == 'child' %}
              <div class="breakup-item">
                <img src="{{ child.image | image_url: width: 80 }}">
                <div>
                  <p>{{ child.product.title }}</p>
                  <small>{{ child.variant.title }}</small>
                </div>
                <span>{{ child.final_line_price | money }}</span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </td>

      <td class="cart-item__totals right">
        <span class="price price--end">
          {{ parent.final_line_price | money }}
        </span>
      </td>

      <td class="cart-item__quantity">
        <quantity-input class="quantity">
          <button class="quantity__button" name="minus" type="button">−</button>
          <input
            class="quantity__input"
            type="number"
            name="updates[]"
            value="{{ parent.quantity }}"
            min="1"
            data-variant-id="{{ parent.variant.id }}"
          >
          <button class="quantity__button" name="plus" type="button">+</button>
        </quantity-input>
      </td>

      <td>
        <cart-remove-button data-index="{{ parent.index | plus: 1 }}">
          <button type="button" class="cart-remove-button">
            ✕
          </button>
        </cart-remove-button>
      </td>
    </tr>
    {% endif %}

  {% else %}

    <!-- ================= NORMAL PRODUCT ================= -->
    {% for item in group.items %}
    <tr class="cart-item" role="row">
      <td class="cart-item__media">
        <img
          class="cart-item__image"
          src="{{ item.image | image_url: width: 300 }}"
        >
      </td>

      <td class="cart-item__details">
        <p class="cart-item__name h4">{{ item.product.title }}</p>
      </td>

      <td class="cart-item__totals right">
        {{ item.final_line_price | money }}
      </td>

      <td class="cart-item__quantity">
        <input type="number" value="{{ item.quantity }}">
      </td>

      <td></td>
    </tr>
    {% endfor %}

  {% endif %}

{% endfor %}
</tbody>

                </table>
              </div>
              {% comment %} {% if cart.total_price > 1500000 %}
                <div class="gold-offers-wrapper" alt="free gold coin">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Gold-Coin--1gm_1_2_1.png?v=1759495662"
                    width="100"
                    height="100"
                    loading="lazy"
                    alt="free gold coin"
                    title="free gold icon"
                  >
                  <div class="gold-offers-content-wrap" alt="free gold coin">
                    <h4>Your Cart is Eligible for Gold Coin(s)</h4>
                    <p>Your gold coin(s) are ready. Claim them at checkout!</p>
                  </div>
                </div>
              {% endif %} {% endcomment %}
            {%- endif -%}
            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>

      <div class="checkout-button" style="display : {% if cart.item_count == 0 %} none {% else %} block {% endif %}">
        <div class="drawer__footer">
          {%- if settings.show_cart_note -%}
            <details id="Details-CartDrawer">
              <summary>
                <span class="summary__title">
                  {{ 'sections.cart.note' | t }}
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
              </summary>
              <cart-note class="cart__note field">
                <label class="visually-hidden" for="CartDrawer-Note">{{ 'sections.cart.note' | t }}</label>
                <textarea
                  id="CartDrawer-Note"
                  class="text-area text-area--resize-vertical field__input"
                  name="note"
                  placeholder="{{ 'sections.cart.note' | t }}"
                >{{ cart.note }}</textarea>
              </cart-note>
            </details>
          {%- endif -%}

          <!-- Start blocks -->
          <!-- Subtotals -->

          <div class="cart-drawer__footer" {{ block.shopify_attributes }}>
            <div>
              {%- if cart.cart_level_discount_applications.size > 0 -%}
                <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                  {%- for discount in cart.cart_level_discount_applications -%}
                    <li class="discounts__discount discounts__discount--end">
                      {{- 'icon-discount.svg' | inline_asset_content -}}
                      {{ discount.title | escape }}
                      (-{{ discount.total_allocated_amount | money }})
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>

            <div class="totals">
              <p class="totals__total">Items ({{ cart.item_count }})</p>
              <p class="totals__total-value" style="color:#1A1A1A;">{{ cart.total_price | money_with_currency }}</p>
            </div>

            <div class="totals">
              <p class="totals__total_delivery">Delivery</p>
              <p class="totals__total-value_delivery"><span style="text-decoration:line-through">₹500</span> Free</p>
            </div>

            <div class="totals" role="status">
              <!-- <h2 class="totals__total">{{ 'sections.cart.estimated_total' | t }}</h2> -->
              <p class="totals__total">GRAND TOTAL</p>
              <p class="totals__total-value" style="font-weight: 600; color:#1A1A1A;">
                {{ cart.total_price | money_with_currency }}
              </p>
            </div>

            <small class="tax-note caption-large rte">
              {%- if cart.duties_included and cart.taxes_included -%}
                {%- if shop.shipping_policy.body == blank -%}
                  {{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_without_policy' | t }}
                {%- else -%}
                  {{
                    'sections.cart.duties_and_taxes_included_shipping_at_checkout_with_policy_html'
                    | t: link: shop.shipping_policy.url
                  }}
                {%- endif -%}
              {%- elsif cart.duties_included == false and cart.taxes_included -%}
                {%- if shop.shipping_policy.body == blank -%}
                  {{ 'sections.cart.taxes_included_shipping_at_checkout_without_policy' | t }}
                {%- else -%}
                  {{
                    'sections.cart.taxes_included_shipping_at_checkout_with_policy_html'
                    | t: link: shop.shipping_policy.url
                  }}
                {%- endif -%}
              {%- elsif cart.duties_included and cart.taxes_included == false -%}
                {%- if shop.shipping_policy.body == blank -%}
                  {{ 'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
                {%- else -%}
                  {{
                    'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_with_policy_html'
                    | t: link: shop.shipping_policy.url
                  }}
                {%- endif -%}
              {%- elsif cart.duties_included == false and cart.taxes_included == false -%}
                {%- if shop.shipping_policy.body == blank -%}
                  {{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
                {%- else -%}
                  {{
                    'sections.cart.taxes_at_checkout_shipping_at_checkout_with_policy_html'
                    | t: link: shop.shipping_policy.url
                  }}
                {%- endif -%}
              {%- endif -%}
            </small>
          </div>

          <!-- CTAs -->
        </div>
        <div>
        {% comment %} {% render 'insurance-cart-item' %} {% endcomment %}
        </div>
        <div class="cart__ctas" {{ block.shopify_attributes }} style="width:100%;">
          <div class="checkout-info" style="display: {% if cart == empty %} none {% else %} flex {% endif %};">
            <p class="grand-total">
              Grand Total: <strong style="font-weight:600;">{{ cart.total_price | money_with_currency }}</strong>
            </p>
            <p class="price-breakup" id="ViewPriceBreakup">View Price Breakup <i class="fa-solid fa-angle-up"></i></p>
          </div>

          {% comment %}
            <div class="cart__ctas" {{ block.shopify_attributes }}>
              <button
                type="submit"
                id="CartDrawer-Checkout"
                class="cart__checkout-button button"
                name="checkout"
                form="CartDrawer-Form"
                {% if cart == empty %}
                  disabled
                {% endif %}
              >
                {{ 'sections.cart.checkout' | t }}
              </button>
            </div>
          {% endcomment %}
          {% render 'gokwik-checkout' %}
        </div>
      </div>
    </div>
  </div>
</cart-drawer>

<script>
  document.addEventListener('click', function (e) {
    const viewPriceBreakupEl = e.target.closest('#ViewPriceBreakup');
    if (viewPriceBreakupEl) {
      const drawerFooter = document.querySelector('.drawer__footer');
      const icon = viewPriceBreakupEl.querySelector('i');

      if (drawerFooter) {
        const isVisible = drawerFooter.getAttribute('data-visible') === 'true';

        if (isVisible) {
          // Collapse drawer
          drawerFooter.style.maxHeight = drawerFooter.scrollHeight + 'px';
          requestAnimationFrame(() => {
            drawerFooter.style.maxHeight = '0px';
          });
          drawerFooter.setAttribute('data-visible', 'false');

          // Set icon to angle-up (closed)
          icon.classList.remove('fa-angle-down');
          icon.classList.add('fa-angle-up');
        } else {
          // Expand drawer
          drawerFooter.style.maxHeight = '0px';
          requestAnimationFrame(() => {
            drawerFooter.style.maxHeight = drawerFooter.scrollHeight + 'px';
          });
          drawerFooter.setAttribute('data-visible', 'true');

          // Set icon to angle-down (opened)
          icon.classList.remove('fa-angle-up');
          icon.classList.add('fa-angle-down');
        }
      }
    }
  });
</script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const checkoutBtn = document.getElementById('CartDrawer-Checkout');

    if (!checkoutBtn) return;

    checkoutBtn.addEventListener('click', async function () {
      try {
        const res = await fetch('/cart.js');
        const cart = await res.json();

        const currency = cart.currency || 'INR';
        const grandTotal = cart.original_total_price / 100;
        const totalValue = cart.total_price / 100;
        const discountAmount = (cart.original_total_price - cart.total_price) / 100;
        const totalQuantity = cart.item_count;
        const uniqueProductCount = new Set(cart.items.map((item) => item.product_id)).size;

        const lineItems = cart.items.map((item, index) => ({
          id: item.product_id?.toString() || '',
          sku: item.sku || '',
          variant_id: item.variant_id?.toString() || '',
          product_name: item.product_title,
          product_type: item.product_type || 'Jewelry',
          category: item.product_type || 'General',
          sub_category: item.variant_title || '',
          price: item.original_price / 100,
          offer_price: item.final_price / 100,
          quantity: item.quantity,
          thumbnail_image: item.image || '',
          index_position: index + 1,
        }));

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'beginCheckout',
          cart: {
            currency: currency,
            grand_total: grandTotal,
            total_value: totalValue,
            discount_amount: discountAmount,
            total_quantity: totalQuantity,
            total_product: uniqueProductCount,
            coupon_code: cart.cart_level_discount_applications?.[0]?.code || '',
            offer_detail: cart.cart_level_discount_applications?.[0]?.title || '',
            items: lineItems,
          },
        });
      } catch (error) {
        console.error('Failed to fetch cart or push beginCheckout:', error);
      }
    });
  });
</script>