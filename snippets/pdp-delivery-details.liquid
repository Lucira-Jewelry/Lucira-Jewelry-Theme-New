{% assign variant = product.selected_or_first_available_variant %}

{% assign is_in_stock = false %}
{% if variant.available and variant.inventory_quantity > 0 %}
  {% assign is_in_stock = true %}
{% elsif variant.available and variant.inventory_management == blank %}
  {% assign is_in_stock = true %}
{% endif %}

{% if is_in_stock %}
  {% assign delivery_days = 2 %}
{% else %}
  {% assign delivery_days = 15 %}
{% endif %}

{% assign total_seconds = delivery_days | times: 86400 %}
{% assign now_ts         = 'now' | date: '%s' %}
{% assign future_ts      = now_ts | plus: total_seconds %}
{% assign delivery_date = future_ts | date: '%B %d, %Y' %}

{% capture variant_stock_json %}
{
  {% for v in product.variants %}
    {% assign v_in_stock = false %}
    {% if v.available and v.inventory_quantity > 0 %}
      {% assign v_in_stock = true %}
    {% elsif v.available and v.inventory_management == blank %}
      {% assign v_in_stock = true %}
    {% endif %}
    {% if v_in_stock %}
      {% assign v_days = 2 %}
    {% else %}
      {% assign v_days = 15 %}
    {% endif %}
    {% assign v_seconds = v_days | times: 86400 %}
    {% assign v_future  = now_ts | plus: v_seconds %}
    "{{ v.id }}": {
      "available": {{ v.available }},
      "inventory": {{ v.inventory_quantity | default: 0 }},
      "days": {{ v_days }},
      "date": "{{ v_future | date: '%B %d, %Y' }}"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
}
{% endcapture %}

<div
  class="lucira-delivery-container"
  id="pdp-delivery-check"
  data-delivery-days="{{ delivery_days }}"
  data-product-sku="{{ variant.sku | escape }}"
  data-product-title="{{ product.title | escape }}"
  data-variant-id="{{ variant.id }}"
  data-inventory-quantity="{{ variant.inventory_quantity | default: 0 }}"
  data-available="{{ variant.available }}"
  data-variant-count="{{ product.variants.size }}"
  data-is-in-stock="{{ is_in_stock }}"
>
  <script>
    window.variantDeliveryData = {{ variant_stock_json }};
  </script>

  <div class="lucira-delivery-input-container">
    <div class="input-wrapper">
      <svg class="pin-beside-pincode" width="18" height="18">
        <use href="#icon-location"></use>
      </svg>
      <input
        type="text"
        id="lucira-delivery-zipcode"
        placeholder="Enter Pincode"
        maxlength="6"
        inputmode="numeric"
        title="enter pincode"
      >
      <button class="submitButton" id="lucira-locate-btn" type="button">
        <svg class="locate-me-icon" width="16" height="16">
          <use xlink:href="#icon-locate"></use>
        </svg>
        <span class="locate-btn-label">Locate Me</span>
      </button>
    </div>
  </div>
  <span class="lucira-pincode-error" id="lucira-pincode-error" style="display:none;color:red;font-size:12px;margin-top:5px;"></span>

  <div class="lucira-delivery-info">
    <span class="lucira-delivery-time">
      <span id="delivery-status-text">
        {% if is_in_stock %}
          Estimated Free Dispatch by
        {% else %}
          Available &amp; Dispatched by
        {% endif %}
      </span>
      <span class="delivry_txt" id="delivery-date-display">{{ delivery_date }}</span>
    </span>
  </div>
</div>

<script>
(function () {
  'use strict';

  function setCookie(name, value, days = 30) {
    var expires = "";
    if (days) {
      var date = new Date();
      date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
      expires = "; expires=" + date.toUTCString();
    }
    document.cookie = name + "=" + value + "; path=/" + expires;
  }

  function getCookie(name) {
    var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
    return match ? match[2] : null;
  }

  function deleteCookie(name) {
    document.cookie = name + "=; Max-Age=0; path=/";
  }

  function showError(msg) {
    var el = document.getElementById('lucira-pincode-error');
    if (!el) return;
    el.textContent = msg;
    el.style.display = msg ? 'block' : 'none';
  }

  function setLocateBtnState(loading) {
    var btn   = document.getElementById('lucira-locate-btn');
    var label = btn && btn.querySelector('.locate-btn-label');
    if (!btn) return;
    btn.disabled = loading;
    if (label) label.textContent = loading ? 'Locating...' : 'Locate Me';
  }

  function toggleButtonState(isSaved = false) {
    var pincodeInput = document.getElementById('lucira-delivery-zipcode');
    var locateBtn    = document.getElementById('lucira-locate-btn');

    if (!pincodeInput || !locateBtn) return;

    var val   = pincodeInput.value.replace(/\s+/g, '').trim();
    var label = locateBtn.querySelector('.locate-btn-label');

    if (isSaved) {
      label.textContent = "Change";
      locateBtn.dataset.mode = "saved";
      pincodeInput.setAttribute("readonly", true);
      return;
    }

    pincodeInput.removeAttribute("readonly");

    if (/^\d{6}$/.test(val)) {
      label.textContent = "Submit";
      locateBtn.dataset.mode = "manual";
    } else {
      label.textContent = "Locate Me";
      locateBtn.dataset.mode = "geo";
    }
  }

  function pushPromoClick(pincode) {
    var container = document.getElementById('pdp-delivery-check');
    var productSku = container ? container.dataset.productSku : '';
    var productTitle = container ? container.dataset.productTitle : '';

    var variantId = window.ShopifyAnalytics && 
                    ShopifyAnalytics.meta && 
                    ShopifyAnalytics.meta.selectedVariantId 
                    ? ShopifyAnalytics.meta.selectedVariantId 
                    : '';

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'promoClick',
      promoClick: {
        promo_id: productSku,
        promo_name: productTitle,
        creative_name: 'pincodeEntered',
        promo_position: pincode,
        location_id: variantId
      }
    });
  }

  function fetchWithRetry(url, retries = 1) {
    return fetch(url)
      .then(r => r.json())
      .catch(err => {
        if (retries > 0) return fetchWithRetry(url, retries - 1);
        throw err;
      });
  }

  function initDeliveryWidget() {
    var locateBtn    = document.getElementById('lucira-locate-btn');
    var pincodeInput = document.getElementById('lucira-delivery-zipcode');

    if (!locateBtn || !pincodeInput) return;

    pincodeInput.addEventListener('input', function () {
      toggleButtonState(false);
    });

    pincodeInput.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') locateBtn.click();
    });

    locateBtn.addEventListener('click', function () {
      showError('');

      var mode = locateBtn.dataset.mode;
      var val  = pincodeInput.value.replace(/\s+/g, '').trim();

      if (mode === "saved") {
        deleteCookie('user_pincode');
        pincodeInput.value = '';
        toggleButtonState(false);
        return;
      }

      if (mode === "manual") {

        if (!/^\d{6}$/.test(val)) {
          showError('Please enter a valid 6-digit pincode.');
          return;
        }

        fetchWithRetry('https://nominatim.openstreetmap.org/search?postalcode=' + val + '&country=India&format=json', 1)
          .then(function(data) {
            if (data && data.length > 0) {

              setCookie('user_pincode', val);
              pushPromoClick(val);

              toggleButtonState(true); // ✅ CHANGE

            } else {
              showError('Pincode not found.');
            }
          })
          .catch(function() {
            showError('Service unavailable.');
          });

        return;
      }

      if (!navigator.geolocation) {
        showError('Geolocation not supported.');
        return;
      }

      setLocateBtnState(true);

      navigator.geolocation.getCurrentPosition(
        function (position) {
          var lat = position.coords.latitude;
          var lon = position.coords.longitude;

          fetchWithRetry('https://nominatim.openstreetmap.org/reverse?lat=' + lat + '&lon=' + lon + '&format=json', 1)
            .then(function(data) {
              var pincode = data && data.address && data.address.postcode;

              if (pincode) pincode = pincode.replace(/\s+/g, '');

              if (pincode && /^\d{6}$/.test(pincode)) {

                pincodeInput.value = pincode;

                setCookie('user_pincode', pincode);
                pushPromoClick(pincode);

                toggleButtonState(true);

              } else {
                showError('Could not detect valid pincode.');
              }
            })
            .catch(function() {
              showError('Location lookup failed.');
            })
            .finally(function() {
              setLocateBtnState(false);
            });
        },
        function () {
          setLocateBtnState(false);
          showError('Permission denied.');
        }
      );
    });

    var saved = getCookie('user_pincode');

    if (saved && /^\d{6}$/.test(saved)) {
      pincodeInput.value = saved;
      toggleButtonState(true);
    } else {
      toggleButtonState(false);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDeliveryWidget);
  } else {
    initDeliveryWidget();
  }

})();
</script>