{% assign delivery_days = product.metafields.custom.shipping | default: 4 %}

<div 
  class="lucira-delivery-container" 
  id="pdp-delivery-check"
  data-delivery-days="{{ delivery_days }}"
  data-product-sku="{{ product.selected_or_first_available_variant.sku }}"
  data-product-title="{{ product.title | escape }}"
>


  <div class="lucira-delivery-input-container">
    <div class="input-wrapper">
      <svg class="pin-beside-pincode" width="18" height="18"> <use href="#icon-location"></use> </svg>
      <input
        type="text"
        id="lucira-delivery-zipcode"
        placeholder="Enter Pincode"
        maxlength="6"
        inputmode="numeric"
        title="enter pincode"
      >
      <button class="submitButton"> <svg class="locate-me-icon" width="16" height="16" class="icon icon-locate"> <use xlink:href="#icon-locate"></use> </svg> Locate Me</button>
    </div>
  </div>

  {% assign total_seconds = delivery_days | times: 86400 %}
  {% assign now = 'now' | date: '%s' %}
  {% assign future_timestamp = now | plus: total_seconds %}
  {% assign delivery_date = future_timestamp | date: '%B %d, %Y' %}

  <div class="lucira-delivery-info">
    <span class="lucira-delivery-time">Estimated Free Dispatch by 
      <span class="delivry_txt">{{ delivery_date }}</span>
    </span>
  </div>
</div>

<script>
(() => {
  const container = document.getElementById("pdp-delivery-check");
  if (!container) return;

  const submitBtn    = container.querySelector(".submitButton");
  const pincodeInput = document.getElementById("lucira-delivery-zipcode");
  const dateSpan     = container.querySelector(".lucira-delivery-time .delivry_txt");

  const META_DAYS = Number(container?.dataset?.deliveryDays || 4);

  const fmtDatePlus = (plusDays) => {
    const d = new Date();
    d.setDate(d.getDate() + Number(plusDays));
    return d.toLocaleDateString("en-US", { day: "numeric", month: "long", year: "numeric" });
  };

  const getSelected = (label) => {
    const radio = document.querySelector(`input[name*="${label}"]:checked`);
    if (radio) return radio.value;
    const sel = document.querySelector(`select[name*="${label}"]`);
    if (sel) return sel.value;
    return null;
  };

  const hasPicker = (label) =>
    !!document.querySelector(`input[name*="${label}"], select[name*="${label}"]`);

  const getBadgeActive = (label) =>
    document.querySelector(
      `input[name*="${label}"]:checked + label .Variant_Stock_Status .stock-active,` +
      `select[name*="${label}"] + label .Variant_Stock_Status .stock-active`
    );

  const ds = () => {
    const avail = String(container.dataset.available || "").toLowerCase();
    const qty   = Number(container.dataset.inventoryQuantity || 0);
    const variantCount = Number(container.dataset.variantCount || 0);
    return { avail, qty, variantCount };
  };

  function isVariantInStock() {
    const colorVal = getSelected("Color");
    const sizeVal  = getSelected("Size");
    const hasColor = hasPicker("Color");
    const hasSize  = hasPicker("Size");
    const { avail, qty, variantCount } = ds();

    if (window.variantStockData) {
      if (colorVal && sizeVal && window.variantStockData[colorVal]) {
        const node = window.variantStockData[colorVal][sizeVal];
        if (node && node.available && Number(node.inventory) > 0) return true;
      }

      if (colorVal && !sizeVal && window.variantStockData[colorVal]) {
        const node = window.variantStockData[colorVal];
        if (node && node.available && Number(node.inventory) > 0) return true;
      }

      if (!colorVal && sizeVal && window.variantStockData[sizeVal]) {
        const node = window.variantStockData[sizeVal];
        if (node && node.available && Number(node.inventory) > 0) return true;
      }
    }

    if (hasColor && !hasSize && getBadgeActive("Color")) return true;
    if (!hasColor && hasSize && getBadgeActive("Size")) return true;
    if (hasColor && hasSize && getBadgeActive("Color") && getBadgeActive("Size")) return true;

    const singleOptionContext =
      (!hasColor && !hasSize) || (hasColor ^ hasSize) || variantCount === 1;

    if (singleOptionContext) {
      if ((avail === "true" || avail === "1") && qty > 0) return true;
      if (avail === "true" && !Number.isFinite(qty)) return true;
    }

    if (qty > 0) return true;

    return false;
  }

  const computeDays = () => (isVariantInStock() ? 2 : META_DAYS);

  function repaint() {
    if (!dateSpan) return;
    dateSpan.textContent = fmtDatePlus(computeDays());
  }

  function setLocateView() {
    submitBtn.innerHTML = `
      <svg width="16" height="16" class="icon icon-locate">
        <use xlink:href="#icon-locate"></use>
      </svg> Locate Me
    `;
    submitBtn.disabled = false;
  }

  function setSubmitView() {
    submitBtn.textContent = "Submit";
    submitBtn.disabled = false;
  }

  // helper to push analytics/dataLayer safely
  function pushPromoEvent(promoData) {
    try {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: "promoClick", promoClick: promoData });
    } catch (e) { /* ignore */ }
  }

  if (pincodeInput) {
    pincodeInput.addEventListener("input", () => {
      const val = pincodeInput.value.replace(/\D/g, "").slice(0, 6);
      pincodeInput.value = val;
      if (val.length === 6) {
        setTimeout(() => {
          setSubmitView();
          submitBtn?.dispatchEvent(new Event("pincode:ready", { bubbles: true }));
        }, 150);
      } else {
        setLocateView();
      }
    });
  }

  if (submitBtn) {
    submitBtn.addEventListener("click", async (e) => {
      e.preventDefault();
      e.stopImmediatePropagation();

      const pin = (pincodeInput?.value || "").trim();
      const isLocate = (submitBtn.textContent || "").toLowerCase().includes("locate");

      if (isLocate || pin.length !== 6) {
        // --- LOCATE FLOW ---
        // Immediately send a locate analytics event (no pincode yet)
        pushPromoEvent({
          promo_id: container.dataset.productSku,
          promo_name: container.dataset.productTitle,
          creative_name: "locateMe",
          location_id: container.dataset.variantId,
          promo_position: "", // unknown until locate resolves
          pincode: "" // may be filled after locate
        });

        // Call locate function if available (may populate the pincode input asynchronously)
        if (typeof window.luciraLocateMe === "function") {
          try {
            // If locate returns a promise we await it
            const result = window.luciraLocateMe();
            if (result && typeof result.then === "function") {
              await result;
            }
          } catch (_) { /* ignore locate errors */ }
        }

        // after locate completes, if a pincode is present, switch to submit and push another event
        const locatedPin = (pincodeInput?.value || "").replace(/\D/g, "");
        if (locatedPin.length === 6) {
          // update button text so user can submit if they want to change
          setSubmitView();

          // send another analytics event now that we have a pincode from locate
          pushPromoEvent({
            promo_id: container.dataset.productSku,
            promo_name: container.dataset.productTitle,
            creative_name: "locateMe:foundPincode",
            location_id: container.dataset.variantId,
            promo_position: locatedPin,
            pincode: locatedPin
          });

          // also immediately update delivery date UI
          const days = isVariantInStock() ? 2 : Number(container.dataset.deliveryDays || META_DAYS);
          const formatted = fmtDatePlus(days);
          if (dateSpan) dateSpan.textContent = formatted;
          setTimeout(() => { if (dateSpan) dateSpan.textContent = formatted; }, 60);
          setTimeout(() => { if (dateSpan) dateSpan.textContent = formatted; }, 250);
        }

        return;
      }

      // --- SUBMIT FLOW (existing behaviour) ---
      try {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "promoClick",
          promoClick: {
            promo_id: container.dataset.productSku,
            promo_name: container.dataset.productTitle,
            creative_name: "pincodeEntered",
            location_id: container.dataset.variantId,
            promo_position: pin,
            pincode: pin
          }
        });
      } catch (_) {}

      const days = isVariantInStock() ? 2 : Number(container.dataset.deliveryDays || META_DAYS);
      const formatted = fmtDatePlus(days);

      if (dateSpan) dateSpan.textContent = formatted;
      setTimeout(() => { if (dateSpan) dateSpan.textContent = formatted; }, 60);
      setTimeout(() => { if (dateSpan) dateSpan.textContent = formatted; }, 250);
    });
  }

  function onVariantChange(e) {
    const v = e?.detail?.variant;
    if (v) {
      container.dataset.variantId = String(v.id || "");
      if (typeof v.inventory_quantity === "number") {
        container.dataset.inventoryQuantity = String(v.inventory_quantity);
      }
      if (typeof v.available !== "undefined") {
        container.dataset.available = String(!!v.available);
      }
    }
    repaint();
  }
  document.addEventListener("variant:change", onVariantChange);
  document.addEventListener("variant:changed", onVariantChange);

  document.addEventListener("change", (evt) => {
    const n = evt.target?.name || "";
    if (n.includes("Color") || n.includes("Size")) repaint();
  });

  if (typeof window.luciraLocateMe === "function") {
    const _orig = window.luciraLocateMe;
    window.luciraLocateMe = async function (...args) {
      try { await _orig.apply(this, args); } catch (_) {}
      setTimeout(() => {
        if ((pincodeInput?.value || "").replace(/\D/g, "").length === 6) setSubmitView();
        repaint();
      }, 50);
    };
  }

  setLocateView();
  repaint();
  setTimeout(repaint, 120);
})();
</script>