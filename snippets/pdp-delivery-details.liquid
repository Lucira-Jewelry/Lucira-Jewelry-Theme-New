{% comment %} ─── 1. VARIANT STOCK LOGIC ─── {% endcomment %}
{% assign variant = product.selected_or_first_available_variant %}

{% assign is_in_stock = false %}
{% if variant.available and variant.inventory_quantity > 0 %}
  {% assign is_in_stock = true %}
{% elsif variant.available and variant.inventory_management == blank %}
  {% assign is_in_stock = true %}
{% endif %}

{% comment %} ─── 2. DAYS CALCULATION ─── {% endcomment %}
{% if is_in_stock %}
  {% assign delivery_days = 2 %}
{% else %}
  {% assign delivery_days = 15 %}
{% endif %}

{% comment %} ─── 3. DATE FORMATTING ─── {% endcomment %}
{% assign total_seconds = delivery_days | times: 86400 %}
{% assign now_ts        = 'now' | date: '%s' %}
{% assign future_ts     = now_ts | plus: total_seconds %}
{% assign delivery_date = future_ts | date: '%B %d, %Y' %}

{% comment %} ─── 4. PRE-COMPUTE ALL VARIANTS FOR JS HANDOFF ─── {% endcomment %}
{% capture variant_stock_json %}
{
  {% for v in product.variants %}
    {% assign v_in_stock = false %}
    {% if v.available and v.inventory_quantity > 0 %}
      {% assign v_in_stock = true %}
    {% elsif v.available and v.inventory_management == blank %}
      {% assign v_in_stock = true %}
    {% endif %}
    {% if v_in_stock %}
      {% assign v_days = 2 %}
    {% else %}
      {% assign v_days = 15 %}
    {% endif %}
    {% assign v_seconds = v_days | times: 86400 %}
    {% assign v_future  = now_ts | plus: v_seconds %}
    "{{ v.id }}": {
      "available": {{ v.available }},
      "inventory": {{ v.inventory_quantity | default: 0 }},
      "days": {{ v_days }},
      "date": "{{ v_future | date: '%B %d, %Y' }}"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
}
{% endcapture %}

{% comment %} ─── 5. RENDER ─── {% endcomment %}
<div
  class="lucira-delivery-container"
  id="pdp-delivery-check"
  data-delivery-days="{{ delivery_days }}"
  data-product-sku="{{ variant.sku | escape }}"
  data-product-title="{{ product.title | escape }}"
  data-variant-id="{{ variant.id }}"
  data-inventory-quantity="{{ variant.inventory_quantity | default: 0 }}"
  data-available="{{ variant.available }}"
  data-variant-count="{{ product.variants.size }}"
  data-is-in-stock="{{ is_in_stock }}"
>
  <script>
    window.variantDeliveryData = {{ variant_stock_json }};
  </script>

  <div class="lucira-delivery-input-container">
    <div class="input-wrapper">
      <svg class="pin-beside-pincode" width="18" height="18">
        <use href="#icon-location"></use>
      </svg>
      <input
        type="text"
        id="lucira-delivery-zipcode"
        placeholder="Enter Pincode"
        maxlength="6"
        inputmode="numeric"
        title="enter pincode"
      >
      <button class="submitButton" id="lucira-locate-btn" data-mode="locate">
        <svg class="locate-me-icon" width="16" height="16">
          <use xlink:href="#icon-locate"></use>
        </svg>
        <span class="locate-btn-label">Locate Me</span>
      </button>
    </div>
    <span class="lucira-pincode-error" id="lucira-pincode-error" style="display:none;color:red;font-size:12px;"></span>
  </div>

  <div class="lucira-delivery-info">
    <span class="lucira-delivery-time">
      {% if is_in_stock %}
        Estimated Free Dispatch by
      {% else %}
        Available &amp; Dispatched by
      {% endif %}
      <span class="delivry_txt">{{ delivery_date }}</span>
    </span>
  </div>

</div>

<script>
(function () {
  'use strict';

  /* ── Helpers ── */
  function showError(msg) {
    var el = document.getElementById('lucira-pincode-error');
    if (!el) return;
    el.textContent = msg;
    el.style.display = msg ? 'block' : 'none';
  }

  function setLocateBtnState(loading) {
    var btn   = document.getElementById('lucira-locate-btn');
    var label = btn && btn.querySelector('.locate-btn-label');
    if (!btn) return;
    btn.disabled = loading;
    if (label) label.textContent = loading ? 'Detecting…' : 'Locate Me';
  }

  /* ── DataLayer push ── */
  function pushPromoClick(pincode) {
    var container    = document.getElementById('pdp-delivery-check');
    var productSku   = container ? container.dataset.productSku   : '';
    var productTitle = container ? container.dataset.productTitle : '';

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'promoClick',
      promoClick: {
        promo_id:       productSku,
        promo_name:     productTitle,
        creative_name:  'pincodeEntered',
        promo_position: pincode,
        location_id:    'pdp'
      }
    });
  }

  /* ── Fetch pincode from coords via Nominatim ── */
  function fetchPincodeFromCoords(lat, lon) {
    var url = 'https://nominatim.openstreetmap.org/reverse?lat=' + lat +
              '&lon=' + lon + '&country=India&format=json';

    fetch(url, { headers: { 'Accept-Language': 'en' } })
      .then(function (res) { return res.json(); })
      .then(function (data) {
        var pincode = data && data.address && data.address.postcode;
        if (pincode) {
          var input = document.getElementById('lucira-delivery-zipcode');
          if (input) input.value = pincode;
          showError('');
          pushPromoClick(pincode);          // ← dataLayer fired here
          handlePincodeCheck(pincode);      // optional: trigger your check logic
        } else {
          showError('Could not detect pincode. Please enter manually.');
        }
      })
      .catch(function () {
        showError('Location lookup failed. Please enter pincode manually.');
      })
      .finally(function () {
        setLocateBtnState(false);
      });
  }

  /* ── Fetch pincode from text query (for manual search) ── */
  function fetchPincodeFromQuery(query) {
    var url = 'https://nominatim.openstreetmap.org/search?postalcode=' +
              encodeURIComponent(query) + '&country=India&format=json';
    return fetch(url).then(function (res) { return res.json(); });
  }

  /* ── Delivery date update helper ── */
  function handlePincodeCheck(pincode) {
    // Plug your serviceability / delivery-date logic here.
    // For now we just fire the dataLayer if called from manual input.
    if (pincode) pushPromoClick(pincode);
  }

  /* ── Locate Me click ── */
  document.addEventListener('DOMContentLoaded', function () {
    var locateBtn = document.getElementById('lucira-locate-btn');

    if (locateBtn) {
      locateBtn.addEventListener('click', function () {
        showError('');

        if (!navigator.geolocation) {
          showError('Geolocation is not supported by your browser.');
          return;
        }

        setLocateBtnState(true);

        navigator.geolocation.getCurrentPosition(
          /* success */
          function (position) {
            fetchPincodeFromCoords(
              position.coords.latitude,
              position.coords.longitude
            );
          },
          /* error */
          function (err) {
            setLocateBtnState(false);
            var messages = {
              1: 'Location permission denied. Please enter pincode manually.',
              2: 'Location unavailable. Please enter pincode manually.',
              3: 'Location request timed out. Please try again.'
            };
            showError(messages[err.code] || 'Unknown location error.');
          },
          { timeout: 10000, maximumAge: 60000 }
        );
      });
    }

    /* ── Manual pincode input (Enter key or blur) ── */
    var pincodeInput = document.getElementById('lucira-delivery-zipcode');
    if (pincodeInput) {
      pincodeInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') {
          var val = pincodeInput.value.trim();
          if (/^\d{6}$/.test(val)) {
            showError('');
            fetchPincodeFromQuery(val).then(function (results) {
              if (results && results.length) {
                pushPromoClick(val);   // ← dataLayer fired for manual entry too
                handlePincodeCheck(val);
              } else {
                showError('Pincode not found. Please check and try again.');
              }
            });
          } else {
            showError('Please enter a valid 6-digit pincode.');
          }
        }
      });
    }
  });
})();
</script>