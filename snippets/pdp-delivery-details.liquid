{% comment %}
  ============================================================
  Lucira Delivery Checker — PDP Snippet
  ============================================================
  NEW: Fetches real Shopify location inventory via Storefront API.
  
  SETUP REQUIRED:
    1. Shopify Admin → Apps & Sales Channels → Develop Apps →
       Create/select app → Storefront API → generate token.
    2. Online Store → Themes → Customize → Theme Settings →
       add setting key "storefront_api_token" and paste the token.
    3. Admin → Settings → Shipping & Delivery → enable
       "In-store pickup" for each location you want shown.
  ============================================================
{% endcomment %}

{% assign variant = product.selected_or_first_available_variant %}

{% comment %} ── Stock detection ── {% endcomment %}
{% assign is_in_stock = false %}
{% if variant.available and variant.inventory_quantity > 0 %}
  {% assign is_in_stock = true %}
{% elsif variant.available and variant.inventory_management == blank %}
  {% assign is_in_stock = true %}
{% endif %}

{% if is_in_stock %}
  {% assign delivery_days = 2 %}
{% else %}
  {% assign delivery_days = 15 %}
{% endif %}

{% assign total_seconds = delivery_days | times: 86400 %}
{% assign now_ts        = 'now' | date: '%s' %}
{% assign future_ts     = now_ts | plus: total_seconds %}
{% assign delivery_date = future_ts | date: '%B %d, %Y' %}

{% comment %} ── Per-variant delivery JSON (all variants, baked in at page load) ── {% endcomment %}
{% capture variant_stock_json %}{
  {% for v in product.variants %}
    {% assign v_in_stock = false %}
    {% if v.available and v.inventory_quantity > 0 %}
      {% assign v_in_stock = true %}
    {% elsif v.available and v.inventory_management == blank %}
      {% assign v_in_stock = true %}
    {% endif %}
    {% if v_in_stock %}{% assign v_days = 2 %}{% else %}{% assign v_days = 15 %}{% endif %}
    {% assign v_seconds = v_days | times: 86400 %}
    {% assign v_future  = now_ts | plus: v_seconds %}
    "{{ v.id }}": {
      "available": {{ v.available }},
      "inventory": {{ v.inventory_quantity | default: 0 }},
      "days": {{ v_days }},
      "date": "{{ v_future | date: '%B %d, %Y' }}",
      "inStock": {{ v_in_stock }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
}{% endcapture %}

<style>
  /* ── Location list ── */
  .lucira-location-list {
    margin-top: 8px;
    font-size: 13px;
  }
  .lucira-location-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 0;
    border-bottom: 1px solid #f0f0f0;
  }
  .lucira-location-item:last-child { border-bottom: none; }

  .lucira-location-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .lucira-location-dot.in-stock  { background: #2e7d32; }
  .lucira-location-dot.out-stock { background: #ccc; }

  .lucira-location-name { flex: 1; color: #333; line-height: 1.3; }
  .lucira-location-city { color: #999; font-size: 11px; }

  .lucira-location-qty {
    font-size: 11px;
    color: #888;
    white-space: nowrap;
  }

  .lucira-location-tag {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 999px;
    font-weight: 500;
    white-space: nowrap;
  }
  .lucira-location-tag.store     { background: #e8f5e9; color: #2e7d32; }
  .lucira-location-tag.warehouse { background: #e3f2fd; color: #1565c0; }
  .lucira-location-tag.out       { background: #f5f5f5; color: #999; }

  .lucira-location-loading { font-size: 12px; color: #999; padding: 8px 0; }

  .lucira-location-header {
    font-size: 12px;
    color: #555;
    margin-top: 10px;
    margin-bottom: 2px;
    font-weight: 600;
  }
  .lucira-location-summary {
    font-size: 12px;
    margin-bottom: 4px;
  }
  .lucira-location-error {
    font-size: 12px;
    color: #999;
    padding: 6px 0;
  }
</style>

<div
  class="lucira-delivery-container"
  id="pdp-delivery-check"
  data-delivery-days="{{ delivery_days }}"
  data-product-sku="{{ variant.sku | escape }}"
  data-product-title="{{ product.title | escape }}"
  data-variant-id="{{ variant.id }}"
  data-variant-gid="gid://shopify/ProductVariant/{{ variant.id }}"
  data-shop-domain="{{ shop.permanent_domain }}"
  data-storefront-token="{{ settings.storefront_api_token }}"
  data-inventory-quantity="{{ variant.inventory_quantity | default: 0 }}"
  data-available="{{ variant.available }}"
  data-variant-count="{{ product.variants.size }}"
  data-is-in-stock="{{ is_in_stock }}"
>
  <script>
    window.variantDeliveryData = {{ variant_stock_json }};
  </script>

  <!-- ── Pincode input ── -->
  <div class="lucira-delivery-input-container">
    <div class="input-wrapper">
      <svg class="pin-beside-pincode" width="18" height="18">
        <use href="#icon-location"></use>
      </svg>
      <input
        type="text"
        id="lucira-delivery-zipcode"
        placeholder="Enter Pincode"
        maxlength="6"
        inputmode="numeric"
        title="enter pincode"
      >
      <button class="submitButton" id="lucira-locate-btn" type="button">
        <svg class="locate-me-icon" width="16" height="16">
          <use xlink:href="#icon-locate"></use>
        </svg>
        <span class="locate-btn-label">Locate Me</span>
      </button>
    </div>
  </div>

  <span
    class="lucira-pincode-error"
    id="lucira-pincode-error"
    style="display:none; color:red; font-size:12px; margin-top:5px;"
  ></span>

  <!-- ── Stock badge ── -->
  <div
    id="lucira-stock-badge"
    style="{% unless is_in_stock %}display:none;{% endunless %}font-size:13px; margin-top:6px; margin-bottom:4px; color:green;"
  >
    ✓ Available at Store
  </div>

  <!-- ── Delivery date ── -->
  <div class="lucira-delivery-info">
    <span class="lucira-delivery-time">
      <span id="delivery-status-text">
        {% if is_in_stock %}Estimated Free Dispatch by{% else %}Available &amp; Dispatched by{% endif %}
      </span>
      <span class="delivry_txt" id="delivery-date-display">{{ delivery_date }}</span>
    </span>
  </div>

  <!-- ── Location availability (revealed after pincode submit) ── -->
  <div id="lucira-location-wrapper" style="display:none;">
    <div class="lucira-location-header">Stock availability at our locations:</div>
    <div id="lucira-location-summary" class="lucira-location-summary"></div>
    <div class="lucira-location-list" id="lucira-location-list"></div>
  </div>
</div>

<script>
  window.customerId = {{ customer.id | json }};
</script>

<script>
(function () {
  'use strict';

  var container        = document.getElementById('pdp-delivery-check');
  var SHOP_DOMAIN      = container.dataset.shopDomain;      // e.g. "yourstore.myshopify.com"
  var STOREFRONT_TOKEN = container.dataset.storefrontToken; // from theme settings
  var currentVariantId = container.dataset.variantId;
  console.log("STOREFRONT_TOKEN-----",STOREFRONT_TOKEN);
  // ─── Cookies ──────────────────────────────────────────────────────────────

  function setCookie(name, value, days) {
    days = days || 30;
    var d = new Date();
    d.setTime(d.getTime() + days * 86400000);
    document.cookie = name + '=' + String(value) + '; path=/; expires=' + d.toUTCString();
  }

  function getCookie(name) {
    var m = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
    return m ? String(m[2]) : null;
  }

  function deleteCookie(name) {
    document.cookie = name + '=; Max-Age=0; path=/';
  }

  // ─── UI helpers ───────────────────────────────────────────────────────────

  function showError(msg) {
    var el = document.getElementById('lucira-pincode-error');
    if (!el) return;
    el.textContent = msg;
    el.style.display = msg ? 'block' : 'none';
  }

  function setLocateBtnState(loading) {
    var btn   = document.getElementById('lucira-locate-btn');
    var label = btn && btn.querySelector('.locate-btn-label');
    if (!btn) return;
    btn.disabled = loading;
    if (label) label.textContent = loading ? 'Locating…' : 'Locate Me';
  }

  function toggleButtonState(isSaved) {
    var input = document.getElementById('lucira-delivery-zipcode');
    var btn   = document.getElementById('lucira-locate-btn');
    if (!input || !btn) return;
    var label = btn.querySelector('.locate-btn-label');

    if (isSaved) {
      label.textContent = 'Change';
      btn.dataset.mode  = 'saved';
      input.setAttribute('readonly', true);
      return;
    }

    input.removeAttribute('readonly');
    var val = input.value.replace(/\s+/g, '').trim();
    if (/^\d{6}$/.test(val)) {
      label.textContent = 'Submit';
      btn.dataset.mode  = 'manual';
    } else {
      label.textContent = 'Locate Me';
      btn.dataset.mode  = 'geo';
    }
  }

  // ─── Analytics ────────────────────────────────────────────────────────────

  function pushPromoClick(pincode) {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'promoClick',
      promoClick: { creative_name: 'pincodeEntered', promo_position: String(pincode) }
    });
  }

  function savePincodeToServer(pincode) {
    try {
      (function attempt(retry) {
        var cid = window.customerId;
        if (!cid || cid === 'null') {
          if (retry < 5) setTimeout(function () { attempt(retry + 1); }, 300);
          return;
        }
        cid = String(cid).replace('gid://shopify/Customer/', '');
        fetch('https://api.lucirajewelry.com/customers/pincode.php', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ customer_id: String(cid), pincode: String(pincode) })
        });
      }(0));
    } catch (e) {}
  }

  // ─── Location rendering ───────────────────────────────────────────────────

  function showLocationLoading() {
    var wrapper = document.getElementById('lucira-location-wrapper');
    var list    = document.getElementById('lucira-location-list');
    var summary = document.getElementById('lucira-location-summary');
    if (!wrapper) return;
    wrapper.style.display = 'block';
    if (summary) summary.textContent = '';
    if (list)    list.innerHTML = '<div class="lucira-location-loading">Checking availability across locations…</div>';
  }

  /**
   * Render location rows.
   *
   * Expected shape per location object:
   *   { name, city?, available (bool), quantityAvailable (int), type? ('store'|'warehouse') }
   */
  function renderLocations(locations, userPincode) {
    var list    = document.getElementById('lucira-location-list');
    var summary = document.getElementById('lucira-location-summary');
    if (!list) return;

    if (!locations || !locations.length) {
      list.innerHTML = '<div class="lucira-location-error">No location data available.</div>';
      return;
    }

    // Sort: in-stock first, then by pincode proximity (first 3 digits)
    var userPre = userPincode ? String(userPincode).slice(0, 3) : '';
    locations.sort(function (a, b) {
      var aS = a.available ? 1 : 0;
      var bS = b.available ? 1 : 0;
      if (bS !== aS) return bS - aS;
      var aC = a.pincode && String(a.pincode).slice(0, 3) === userPre ? 1 : 0;
      var bC = b.pincode && String(b.pincode).slice(0, 3) === userPre ? 1 : 0;
      return bC - aC;
    });

    // Summary line
    var inStockCount = locations.filter(function (l) { return l.available; }).length;
    if (summary) {
      if (inStockCount > 0) {
        summary.textContent = '✓ In stock at ' + inStockCount + ' of ' + locations.length + ' location' + (locations.length !== 1 ? 's' : '');
        summary.style.color = '#2e7d32';
      } else {
        summary.textContent = '✗ Currently out of stock at all locations';
        summary.style.color = '#999';
      }
    }

    list.innerHTML = locations.map(function (loc) {
      var inStock  = !!loc.available;
      var qty      = typeof loc.quantityAvailable === 'number'
                       ? loc.quantityAvailable
                       : (typeof loc.inventory === 'number' ? loc.inventory : null);
      var dotCls   = inStock ? 'in-stock' : 'out-stock';
      var locType  = loc.type || 'store';
      var tagCls   = inStock ? locType : 'out';
      var tagLabel = inStock
        ? (locType === 'warehouse' ? 'Ships from here' : 'Walk-in available')
        : 'Out of stock';

      var cityHtml = loc.city
        ? ' <span class="lucira-location-city">· ' + escapeHtml(loc.city) + '</span>'
        : '';
      var qtyHtml = inStock && qty !== null && qty > 0
        ? '<span class="lucira-location-qty">(' + qty + ' in stock)</span>'
        : '';

      return '<div class="lucira-location-item">'
        + '<div class="lucira-location-dot ' + dotCls + '"></div>'
        + '<span class="lucira-location-name">' + escapeHtml(loc.name) + cityHtml + '</span>'
        + qtyHtml
        + '<span class="lucira-location-tag ' + tagCls + '">' + tagLabel + '</span>'
        + '</div>';
    }).join('');
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // ─── Storefront API — storeAvailability ───────────────────────────────────

  /**
   * Queries Shopify Storefront API for per-location inventory.
   *
   * NOTE: Only locations with "In-store pickup" enabled in Shopify Admin
   * (Settings → Shipping & Delivery) will appear in this response.
   * Enable pickup for each location you want displayed.
   *
   * Returns a normalised array matching the renderLocations() shape.
   */
  function fetchStoreAvailability(variantId) {
    if (!STOREFRONT_TOKEN || !SHOP_DOMAIN) {
      return Promise.reject(new Error('storefront-token-missing'));
    }

    var variantGid = 'gid://shopify/ProductVariant/' + variantId;

    // GraphQL query — storeAvailability returns one node per location
    var query = [
      'query variantAvailability($id: ID!) {',
      '  node(id: $id) {',
      '    ... on ProductVariant {',
      '      storeAvailability(first: 30) {',
      '        nodes {',
      '          available',
      '          quantityAvailable',
      '          location {',
      '            id',
      '            name',
      '            address {',
      '              city',
      '              zip',
      '            }',
      '          }',
      '        }',
      '      }',
      '    }',
      '  }',
      '}'
    ].join('\n');

    return fetch('https://' + SHOP_DOMAIN + '/api/2024-01/graphql.json', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Shopify-Storefront-Access-Token': STOREFRONT_TOKEN
      },
      body: JSON.stringify({ query: query, variables: { id: variantGid } })
    })
    .then(function (r) {
      if (!r.ok) throw new Error('storefront-http-' + r.status);
      return r.json();
    })
    .then(function (json) {
      if (
        !json.data ||
        !json.data.node ||
        !json.data.node.storeAvailability
      ) {
        throw new Error('storefront-unexpected-shape');
      }

      return json.data.node.storeAvailability.nodes.map(function (n) {
        return {
          name:              n.location.name,
          city:              n.location.address && n.location.address.city,
          pincode:           n.location.address && n.location.address.zip,
          available:         n.available,          // bool — true = at least 1 unit
          quantityAvailable: n.quantityAvailable,  // int  — exact count
          type:              'store'               // Storefront API = retail locations
        };
      });
    });
  }

  // ─── Legacy API fallback ──────────────────────────────────────────────────

  /**
   * Calls your existing backend which can use the Shopify Admin API
   * to return inventory for ALL locations (including warehouses not
   * enabled for storefront pickup).
   */
  function fetchLegacyInventory(variantId) {
    return fetch(
      'https://api.lucirajewelry.com/products/inventory.php?variant_id=' + variantId
    )
    .then(function (r) {
      if (!r.ok) throw new Error('legacy-http-' + r.status);
      return r.json();
    })
    .then(function (data) {
      return Array.isArray(data.locations) ? data.locations : [];
    });
  }

  /**
   * Master fetch: tries Storefront API, falls back to legacy API.
   */
  function fetchAndRenderLocations(variantId, pincode) {
    showLocationLoading();

    fetchStoreAvailability(variantId)
      .catch(function (err) {
        // Fallback: Storefront token not set, or API error
        console.warn('[lucira] Storefront API failed (' + err.message + '), falling back to legacy API');
        return fetchLegacyInventory(variantId);
      })
      .then(function (locations) {
        renderLocations(locations, pincode);
      })
      .catch(function () {
        var list = document.getElementById('lucira-location-list');
        if (list) list.innerHTML = '<div class="lucira-location-error">Could not load location availability.</div>';
      });
  }

  // ─── Variant change handling ──────────────────────────────────────────────

  function updateVariantUI(variantId) {
    currentVariantId = String(variantId);
    var data = window.variantDeliveryData && window.variantDeliveryData[currentVariantId];
    if (!data) return;

    var badge     = document.getElementById('lucira-stock-badge');
    var statusTxt = document.getElementById('delivery-status-text');
    var dateTxt   = document.getElementById('delivery-date-display');

    if (badge)     badge.style.display  = data.inStock ? '' : 'none';
    if (statusTxt) statusTxt.textContent = data.inStock
      ? 'Estimated Free Dispatch by'
      : 'Available & Dispatched by';
    if (dateTxt)   dateTxt.textContent = data.date;

    // Keep data attributes in sync (useful for external scripts / MutationObservers)
    container.setAttribute('data-variant-id', currentVariantId);
    container.setAttribute(
      'data-variant-gid',
      'gid://shopify/ProductVariant/' + currentVariantId
    );

    // If pincode already saved, refresh location data for new variant
    var saved = getCookie('user_pincode');
    if (saved && /^\d{6}$/.test(saved)) {
      fetchAndRenderLocations(currentVariantId, saved);
    }
  }

  function listenForVariantChanges() {
    // 1. Custom DOM event fired by most themes
    document.addEventListener('variant:changed', function (e) {
      var v = e.detail && (e.detail.variant || e.detail);
      if (v && v.id) updateVariantUI(v.id);
    });

    // 2. URL ?variant= polling (URL-based themes)
    var lastUrlVariantId = null;
    setInterval(function () {
      var id = new URLSearchParams(window.location.search).get('variant');
      if (id && id !== lastUrlVariantId) {
        lastUrlVariantId = id;
        updateVariantUI(id);
      }
    }, 300);

    // 3. MutationObserver on data-variant-id attribute (attribute-based themes)
    if (window.MutationObserver) {
      new MutationObserver(function (mutations) {
        mutations.forEach(function (m) {
          if (m.attributeName === 'data-variant-id') {
            var id = container.getAttribute('data-variant-id');
            if (id && id !== currentVariantId) updateVariantUI(id);
          }
        });
      }).observe(container, { attributes: true });
    }
  }

  // ─── Pincode flow ─────────────────────────────────────────────────────────

  function onPincodeConfirmed(pincode) {
    setCookie('user_pincode', String(pincode));
    pushPromoClick(pincode);
    savePincodeToServer(pincode);
    toggleButtonState(true);
    fetchAndRenderLocations(currentVariantId, pincode);
  }

  function validatePincodeWithNominatim(val) {
    return fetch(
      'https://nominatim.openstreetmap.org/search?postalcode=' +
      val + '&country=India&format=json'
    )
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (!data || !data.length) throw new Error('not-found');
      return val;
    });
  }

  // ─── Init ─────────────────────────────────────────────────────────────────

  function init() {
    var btn   = document.getElementById('lucira-locate-btn');
    var input = document.getElementById('lucira-delivery-zipcode');
    if (!btn || !input) return;

    input.addEventListener('input', function () { toggleButtonState(false); });
    input.addEventListener('keydown', function (e) { if (e.key === 'Enter') btn.click(); });

    btn.addEventListener('click', function () {
      showError('');
      var mode = btn.dataset.mode;
      var val  = input.value.replace(/\s+/g, '').trim();

      // ── "Change" mode: clear saved pincode ──
      if (mode === 'saved') {
        deleteCookie('user_pincode');
        input.value = '';
        document.getElementById('lucira-location-wrapper').style.display = 'none';
        toggleButtonState(false);
        return;
      }

      // ── Manual 6-digit entry ──
      if (mode === 'manual') {
        if (!/^\d{6}$/.test(val)) {
          showError('Please enter a valid 6-digit pincode');
          return;
        }
        validatePincodeWithNominatim(val)
          .then(function () { onPincodeConfirmed(val); })
          .catch(function () { showError('Pincode not found. Please try again.'); });
        return;
      }

      // ── Geolocation ──
      if (!navigator.geolocation) {
        showError('Geolocation not supported. Please enter pincode manually.');
        return;
      }
      setLocateBtnState(true);

      navigator.geolocation.getCurrentPosition(
        function (pos) {
          fetch(
            'https://nominatim.openstreetmap.org/reverse?lat=' +
            pos.coords.latitude + '&lon=' + pos.coords.longitude + '&format=json'
          )
          .then(function (r) { return r.json(); })
          .then(function (data) {
            var pin = data &&
                      data.address &&
                      data.address.postcode &&
                      data.address.postcode.replace(/\s+/g, '');
            if (pin && /^\d{6}$/.test(pin)) {
              input.value = pin;
              onPincodeConfirmed(pin);
            } else {
              showError('Could not detect a valid Indian pincode. Please enter manually.');
            }
          })
          .catch(function () {
            showError('Location lookup failed. Please enter pincode manually.');
          })
          .finally(function () { setLocateBtnState(false); });
        },
        function () {
          setLocateBtnState(false);
          showError('Location permission denied. Please enter pincode manually.');
        }
      );
    });

    // ── Restore saved pincode from cookie ──
    var saved = getCookie('user_pincode');
    if (saved && /^\d{6}$/.test(saved)) {
      input.value = saved;
      toggleButtonState(true);
      savePincodeToServer(saved);
      fetchAndRenderLocations(currentVariantId, saved);
    } else {
      toggleButtonState(false);
    }

    listenForVariantChanges();
  }

  // Safe DOMContentLoaded (handles both early and late script execution)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

})();
</script>
