{% comment %} ─── 1. VARIANT STOCK LOGIC ─── {% endcomment %}
{% assign variant = product.selected_or_first_available_variant %}

{% assign is_in_stock = false %}
{% if variant.available and variant.inventory_quantity > 0 %}
  {% assign is_in_stock = true %}
{% elsif variant.available and variant.inventory_management == blank %}
  {% comment %} No inventory tracking = always in stock {% endcomment %}
  {% assign is_in_stock = true %}
{% endif %}

{% comment %} ─── 2. DAYS CALCULATION ─── {% endcomment %}
{% if is_in_stock %}
  {% assign delivery_days = 2 %}
{% else %}
  {% assign delivery_days = 15 %}
{% endif %}

{% comment %} ─── 3. DATE FORMATTING ─── {% endcomment %}
{% assign total_seconds  = delivery_days | times: 86400 %}
{% assign now_ts         = 'now' | date: '%s' %}
{% assign future_ts      = now_ts | plus: total_seconds %}
{% assign delivery_date  = future_ts | date: '%B %d, %Y' %}

{% comment %} ─── 4. PRE-COMPUTE ALL VARIANTS FOR JS HANDOFF ─── {% endcomment %}
{% capture variant_stock_json %}
{
  {% for v in product.variants %}
    {% assign v_in_stock = false %}
    {% if v.available and v.inventory_quantity > 0 %}
      {% assign v_in_stock = true %}
    {% elsif v.available and v.inventory_management == blank %}
      {% assign v_in_stock = true %}
    {% endif %}
    {% if v_in_stock %}
      {% assign v_days = 2 %}
    {% else %}
      {% assign v_days = 15 %}
    {% endif %}
    {% assign v_seconds = v_days | times: 86400 %}
    {% assign v_future  = now_ts | plus: v_seconds %}
    "{{ v.id }}": {
      "available": {{ v.available }},
      "inventory": {{ v.inventory_quantity | default: 0 }},
      "days": {{ v_days }},
      "date": "{{ v_future | date: '%B %d, %Y' }}"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
}
{% endcapture %}

{% comment %} ─── 5. RENDER ─── {% endcomment %}
<div
  class="lucira-delivery-container"
  id="pdp-delivery-check"
  data-delivery-days="{{ delivery_days }}"
  data-product-sku="{{ variant.sku | escape }}"
  data-product-title="{{ product.title | escape }}"
  data-variant-id="{{ variant.id }}"
  data-inventory-quantity="{{ variant.inventory_quantity | default: 0 }}"
  data-available="{{ variant.available }}"
  data-variant-count="{{ product.variants.size }}"
  data-is-in-stock="{{ is_in_stock }}"
>

  <script>
    window.variantDeliveryData = {{ variant_stock_json }};
  </script>

  <div class="lucira-delivery-input-container">
    <div class="input-wrapper">
      <svg class="pin-beside-pincode" width="18" height="18">
        <use href="#icon-location"></use>
      </svg>
      <input
        type="text"
        id="lucira-delivery-zipcode"
        placeholder="Enter Pincode"
        maxlength="6"
        inputmode="numeric"
        title="enter pincode"
      >
      <button class="submitButton" data-mode="locate">
        <svg class="locate-me-icon" width="16" height="16">
          <use xlink:href="#icon-locate"></use>
        </svg> Locate Me
      </button>
    </div>
  </div>

  <div class="lucira-delivery-info">
    <span class="lucira-delivery-time">
      {% if is_in_stock %}
        Estimated Free Dispatch by
      {% else %}
        Available &amp; Dispatched by
      {% endif %}
      <span class="delivry_txt">{{ delivery_date }}</span>
    </span>
  </div>

</div>

<script>
  (() => {
    const container = document.getElementById("pdp-delivery-check");
    if (!container) return;

    const submitBtn = container.querySelector(".submitButton");
    const pincodeInput = document.getElementById("lucira-delivery-zipcode");
    const dateSpan = container.querySelector(".lucira-delivery-time .delivry_txt");
    const timeSpan = container.querySelector(".lucira-delivery-time");

    let isProcessingLocate = false;
    let lastEnteredPincode = null;

    // ── Helpers ──────────────────────────────────────────────────────────────

    const fmtDatePlus = (plusDays) => {
      const d = new Date();
      d.setDate(d.getDate() + Number(plusDays));
      return d.toLocaleDateString("en-US", { day: "numeric", month: "long", year: "numeric" });
    };

    const getVariantData = () => {
      const id = container.dataset.variantId;
      return window.variantDeliveryData?.[id] || null;
    };

    const computeDays = () => {
      const data = getVariantData();
      if (data) return data.days;
      // fallback: read data attributes set by product-info.js
      const avail = String(container.dataset.available || "").toLowerCase();
      const qty   = Number(container.dataset.inventoryQuantity || 0);
      return (avail === "true" && qty > 0) ? 2 : 15;
    };

    const updateLabel = (isInStock) => {
      if (!timeSpan) return;
      timeSpan.childNodes.forEach((node) => {
        if (node.nodeType === Node.TEXT_NODE) node.remove();
      });
      const label = isInStock ? "Estimated Free Dispatch by " : "Available & Dispatched by ";
      timeSpan.insertBefore(document.createTextNode(label), timeSpan.firstChild);
    };

    function repaint() {
      if (!dateSpan) return;
      const data = getVariantData();
      const days = computeDays();

      if (data) {
        dateSpan.textContent = data.date;
        updateLabel(data.available && data.inventory > 0);
      } else {
        dateSpan.textContent = fmtDatePlus(days);
        updateLabel(days === 2);
      }

      console.log("Repaint:", { days, date: dateSpan.textContent });
    }

    // ── Button state views ────────────────────────────────────────────────────

    function setLocateView() {
      isProcessingLocate = false;
      lastEnteredPincode = null;
      submitBtn.setAttribute("data-mode", "locate");
      submitBtn.innerHTML = `
        <svg width="16" height="16" class="icon icon-locate">
          <use xlink:href="#icon-locate"></use>
        </svg> Locate Me
      `;
      submitBtn.disabled = false;
      if (pincodeInput) pincodeInput.disabled = false;
    }

    function setSubmitView() {
      submitBtn.setAttribute("data-mode", "submit");
      submitBtn.textContent = "Submit";
      submitBtn.disabled = false;
      if (pincodeInput) pincodeInput.disabled = false;
    }

    function setChangeView() {
      submitBtn.setAttribute("data-mode", "change");
      submitBtn.innerHTML = `Change`;
      submitBtn.disabled = false;
    }

    // ── Locate Me ─────────────────────────────────────────────────────────────

    async function handleLocateMe() {
      if (typeof window.luciraLocateMe !== "function") {
        console.warn("luciraLocateMe function not found");
        // Fallback: just let the user type manually
        pincodeInput?.focus();
        return;
      }

      if (isProcessingLocate) return;
      isProcessingLocate = true;

      submitBtn.disabled = true;
      submitBtn.innerHTML = `
        <svg width="16" height="16" class="icon icon-locate">
          <use xlink:href="#icon-locate"></use>
        </svg> Locating...
      `;

      try {
        await window.luciraLocateMe(); // fills pincodeInput.value

        // Poll for up to 5 seconds until a valid 6-digit pin appears
        let waited = 0;
        const pollInterval = 200;
        const maxWait = 5000;

        const poll = setInterval(() => {
          const newPin = (pincodeInput?.value || "").replace(/\D/g, "").trim();
          waited += pollInterval;

          if (newPin.length === 6) {
            clearInterval(poll);
            isProcessingLocate = false;

            // Dispatch synthetic input event so input listener stays in sync
            pincodeInput.dispatchEvent(new Event("input", { bubbles: true }));

            processDelivery(newPin);

          } else if (waited >= maxWait) {
            clearInterval(poll);
            isProcessingLocate = false;
            setLocateView();
            console.warn("Locate Me: no valid pincode found after timeout");
          }
        }, pollInterval);

      } catch (error) {
        console.error("Location fetch failed:", error);
        isProcessingLocate = false;
        setLocateView();
      }
    }

    // ── Process delivery after pincode submit / locate ────────────────────────

    function processDelivery(pin) {
      lastEnteredPincode = pin;

      try {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "promoClick",
          promoClick: {
            promo_id: container.dataset.productSku,
            promo_name: container.dataset.productTitle,
            creative_name: "Pincode_Entered",
            location_id: pin,
          },
        });
      } catch (_) {}

      const data = getVariantData();
      if (dateSpan) {
        dateSpan.textContent = data ? data.date : fmtDatePlus(computeDays());
      }
      if (data) updateLabel(data.available && data.inventory > 0);

      setChangeView();
    }

    // ── Pincode input events ──────────────────────────────────────────────────

    if (pincodeInput) {
      pincodeInput.addEventListener("input", (e) => {
        const val = e.target.value.replace(/\D/g, "").slice(0, 6);
        pincodeInput.value = val;

        const mode      = submitBtn.getAttribute("data-mode");
        const isEmpty   = val.length === 0;
        const isComplete = val.length === 6;

        if (isEmpty) {
          setLocateView();
          repaint();
          return;
        }

        if (mode === "locate") {
          if (isComplete) setSubmitView();
          return;
        }

        if (mode === "submit") {
          if (!isComplete) { setLocateView(); repaint(); }
          return;
        }

        if (mode === "change") {
          if (isComplete) setSubmitView();
          else { setLocateView(); repaint(); }
          return;
        }
      });

      pincodeInput.addEventListener("click", () => {
        if (submitBtn.getAttribute("data-mode") === "change") {
          setLocateView();
          repaint();
          setTimeout(() => {
            pincodeInput.focus();
            pincodeInput.setSelectionRange(pincodeInput.value.length, pincodeInput.value.length);
          }, 50);
        }
      });

      pincodeInput.addEventListener("focus", () => {
        if (submitBtn.getAttribute("data-mode") === "change") {
          setLocateView();
          repaint();
          setTimeout(() => {
            pincodeInput.setSelectionRange(pincodeInput.value.length, pincodeInput.value.length);
          }, 10);
        }
      });

      pincodeInput.addEventListener("keydown", () => {
        isProcessingLocate = false;
      });
    }

    // ── Button click ──────────────────────────────────────────────────────────

    if (submitBtn) {
      submitBtn.addEventListener("click", async (e) => {
        e.preventDefault();
        e.stopImmediatePropagation();

        const mode = submitBtn.getAttribute("data-mode");
        const pin  = (pincodeInput?.value || "").replace(/\D/g, ""