{% assign delivery_days = product.metafields.custom.shipping | default: 4 %}

<div 
  class="lucira-delivery-container" 
  id="pdp-delivery-check"
  data-delivery-days="{{ delivery_days }}"
  data-product-sku="{{ product.selected_or_first_available_variant.sku }}"
  data-product-title="{{ product.title | escape }}"
>
  <div class="lucira-delivery-header">
    <div class="lucira-delivery-wrapper">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M14 18V6C14 5.46957 13.7893 4.96086 13.4142 4.58579C13.0391 4.21071 12.5304 4 12 4H4C3.46957 4 2.96086 4.21071 2.58579 4.58579C2.21071 4.96086 2 5.46957 2 6V17C2 17.2652 2.10536 17.5196 2.29289 17.7071C2.48043 17.8946 2.73478 18 3 18H5" stroke="#666666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M15 18H9" stroke="#666666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M19 18H21C21.2652 18 21.5196 17.8946 21.7071 17.7071C21.8946 17.5196 22 17.2652 22 17V13.35C21.9996 13.1231 21.922 12.903 21.78 12.726L18.3 8.376C18.2065 8.25888 18.0878 8.16428 17.9528 8.0992C17.8178 8.03412 17.6699 8.00021 17.52 8H14" stroke="#666666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M17 20C18.1046 20 19 19.1046 19 18C19 16.8954 18.1046 16 17 16C15.8954 16 15 16.8954 15 18C15 19.1046 15.8954 20 17 20Z" stroke="#666666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M7 20C8.10457 20 9 19.1046 9 18C9 16.8954 8.10457 16 7 16C5.89543 16 5 16.8954 5 18C5 19.1046 5.89543 20 7 20Z" stroke="#666666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="lucira-delivery-span-1">Delivery Details</span>
    </div>
    <span class="lucira-delivery-span-2 underline-effect" onclick="window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'promoClick',
        promoClick: {
          promo_id: '{{ product.selected_or_first_available_variant.sku }}',
          promo_name: '{{ product.title }}',
          creative_name: 'Locate Me Clicked'
        }
      });
      luciraLocateMe()">Locate me</span>
  </div>


  <div class="lucira-delivery-input-container">
    <span style="display: flex;width: 100%;">
      <img src="{{ 'pdp-delivery-location-pin.svg' | asset_url }}" height="20" width="20" alt="delivery icon">
      <input
        type="text"
        id="lucira-delivery-zipcode"
        placeholder="Enter Pincode"
        maxlength="6"
        inputmode="numeric"
      >
    </span>
    <button class="submitButton" disabled>Submit</button>
  </div>

  {% assign delivery_days = product.metafields.custom.shipping | default: 4 %}
  {% assign total_seconds = delivery_days | times: 86400 %}
  {% assign now = 'now' | date: '%s' %}
  {% assign future_timestamp = now | plus: total_seconds %}
  {% assign delivery_date = future_timestamp | date: '%B %d, %Y' %}

  <div class="lucira-delivery-info">
    <div class="lucira-delivery-icon">
      <div style="display: grid; gap: 5px;">
        <span class="lucira-delivery-time">Estimated Free Dispatch by <span class="delivry_txt">{{ delivery_date }}</span></span>
        {% comment %} <span class="lucira-delivery-text" style="font-size:12px;">(Enter Pincode To Get Your Exact Delivery Date)</span> {% endcomment %}
      </div>
    </div>
  </div>
</div>

<script>
  window.delivery_days_from_metafield = {{ delivery_days }};
  document.addEventListener("DOMContentLoaded", function () {
    const submitBtn = document.querySelector("#pdp-delivery-check .submitButton");
    const pincodeInput = document.querySelector("#lucira-delivery-zipcode");
    const metafieldDays = window.delivery_days_from_metafield || 4;

    // Enable button only when 6 digits entered
    pincodeInput.addEventListener("input", () => {
      const val = pincodeInput.value.trim();
      submitBtn.disabled = !(val.length === 6 && /^\d+$/.test(val));
    });

    submitBtn.addEventListener("click", function () {
      const pincode = pincodeInput?.value?.trim();
      if (!pincode || submitBtn.disabled) return;

      const productData = {
        promo_id: "{{ product.selected_or_first_available_variant.sku }}",
        promo_name: "{{ product.title }}",
        creative_name: "pincodeEntered",
        location_id: "{{ product.selected_or_first_available_variant.id }}",
        promo_position: pincode
      };

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: "promoClick",
        promoClick: productData
      });

      const totalDays = metafieldDays + 2;
      const deliveryDate = new Date();
      deliveryDate.setDate(deliveryDate.getDate() + totalDays);

      const formattedDate = deliveryDate.toLocaleDateString('en-US', {
        day: 'numeric',
        month: 'long',
        year: 'numeric'
      });

      const deliveryTextElement = document.querySelector(".lucira-delivery-time");
      if (deliveryTextElement) {
        deliveryTextElement.innerHTML = `Expected Delivery By <span style="color:#147217;font-weight: bold;">${formattedDate}</span>`;
      }

      const deliveryHint = document.querySelector(".lucira-delivery-text");
      if (deliveryHint) deliveryHint.style.display = "none";
    });
  });
</script>

<script>
document.getElementById("lucira-delivery-zipcode")
  .addEventListener("input", function () {
    this.value = this.value.replace(/\D/g, "").slice(0, 6); 
  });
</script>
