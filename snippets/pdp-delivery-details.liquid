<script>
(function () {
  'use strict';

  /* ── Helpers ── */
  function showError(msg) {
    var el = document.getElementById('lucira-pincode-error');
    if (!el) return;
    el.textContent = msg;
    el.style.display = msg ? 'block' : 'none';
  }

  function setLocateBtnState(loading) {
    var btn   = document.getElementById('lucira-locate-btn');
    var label = btn && btn.querySelector('.locate-btn-label');
    if (!btn) return;
    btn.disabled = loading;
    if (label) label.textContent = loading ? 'Detecting…' : 'Locate Me';
  }

  /* ── DataLayer push ── */
  function pushPromoClick(pincode) {
    var container    = document.getElementById('pdp-delivery-check');
    var productSku   = container ? container.dataset.productSku   : '';
    var productTitle = container ? container.dataset.productTitle : '';

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'promoClick',
      promoClick: {
        promo_id:       productSku,
        promo_name:     productTitle,
        creative_name:  'pincodeEntered',
        promo_position: pincode,
        location_id:    'pdp'
      }
    });
  }

  function handlePincodeCheck(pincode) {
    // Add logic here to update UI with pincode-specific delivery dates if needed
  }

  /* ── Fetch pincode from coords (Reverse Geocoding) ── */
  function fetchPincodeFromCoords(lat, lon) {
    var url = 'https://nominatim.openstreetmap.org/reverse?lat=' + lat + '&lon=' + lon + '&format=json';

    fetch(url, { 
      headers: { 
        'Accept-Language': 'en',
        'User-Agent': 'LuciraEcomStore/1.0' // ✅ Identifying your app prevents blocks
      } 
    })
    .then(function (res) { 
      if (!res.ok) throw new Error('Network response was not ok');
      return res.json(); 
    })
    .then(function (data) {
      var pincode = data && data.address && data.address.postcode;

      // ✅ Clean up spaces (e.g., "400 001" -> "400001")
      if (pincode) pincode = pincode.replace(/\s+/g, '');

      if (pincode && /^\d{6}$/.test(pincode)) {
        var input = document.getElementById('lucira-delivery-zipcode');
        if (input) input.value = pincode;
        showError('');
        pushPromoClick(pincode);
        handlePincodeCheck(pincode);
      } else {
        showError('Pincode not found. Please enter manually.');
      }
    })
    .catch(function (err) {
      console.error('Geo Fetch Error:', err);
      showError('Location lookup failed. Please enter pincode manually.');
    })
    .finally(function () {
      setLocateBtnState(false);
    });
  }

  /* ── Validate manual pincode entry ── */
  function fetchPincodeFromQuery(query) {
    var url = 'https://nominatim.openstreetmap.org/search?postalcode=' +
              encodeURIComponent(query) + '&country=India&format=json';
    return fetch(url, { headers: { 'User-Agent': 'LuciraEcomStore/1.0' } })
      .then(function (res) { return res.json(); });
  }

  /* ── Init ── */
  document.addEventListener('DOMContentLoaded', function () {

    var locateBtn = document.getElementById('lucira-locate-btn');
    if (locateBtn) {
      locateBtn.addEventListener('click', function () {
        showError('');
        if (!navigator.geolocation) {
          showError('Geolocation is not supported by your browser.');
          return;
        }

        setLocateBtnState(true);

        navigator.geolocation.getCurrentPosition(
          function (position) {
            fetchPincodeFromCoords(position.coords.latitude, position.coords.longitude);
          },
          function (err) {
            setLocateBtnState(false);
            var messages = {
              1: 'Permission denied. Please enter manually.',
              2: 'Location unavailable. Please enter manually.',
              3: 'Could not detect location fast enough. Please enter manually.'
            };
            showError(messages[err.code] || 'Unknown location error.');
          },
          { 
            timeout: 15000,           // Increased timeout
            maximumAge: 300000,       // Use cache up to 5 mins
            enableHighAccuracy: false // Faster response using cell towers/WiFi
          }
        );
      });
    }

    var pincodeInput = document.getElementById('lucira-delivery-zipcode');
    if (pincodeInput) {
      pincodeInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') {
          var val = pincodeInput.value.trim();
          if (/^\d{6}$/.test(val)) {
            showError('');
            fetchPincodeFromQuery(val).then(function (results) {
              if (results && results.length) {
                pushPromoClick(val);
                handlePincodeCheck(val);
              } else {
                showError('Pincode not found. Please check and try again.');
              }
            }).catch(function() {
              showError('Network error. Please try again later.');
            });
          } else {
            showError('Please enter a valid 6-digit pincode.');
          }
        }
      });
    }
  });
})();
</script>