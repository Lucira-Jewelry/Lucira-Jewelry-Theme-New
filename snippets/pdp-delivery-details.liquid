<div
  class="lucira-delivery-container"
  id="pdp-delivery-check"
  data-delivery-days="{{ delivery_days }}"
  data-product-sku="{{ variant.sku | escape }}"
  data-product-title="{{ product.title | escape }}"
  data-variant-id="{{ variant.id }}"
  data-inventory-quantity="{{ variant.inventory_quantity | default: 0 }}"
  data-available="{{ variant.available }}"
  data-variant-count="{{ product.variants.size }}"
  data-is-in-stock="{{ is_in_stock }}"
>
  <script>
    window.variantDeliveryData = {{ variant_stock_json }};
  </script>

  <div class="lucira-delivery-input-container">
    <div class="input-wrapper">
      <svg class="pin-beside-pincode" width="18" height="18">
        <use href="#icon-location"></use>
      </svg>
      <input
        type="text"
        id="lucira-delivery-zipcode"
        placeholder="Enter Pincode"
        maxlength="6"
        inputmode="numeric"
        title="enter pincode"
      >
      <button class="submitButton" id="lucira-locate-btn" type="button">
        <svg class="locate-me-icon" width="16" height="16">
          <use xlink:href="#icon-locate"></use>
        </svg>
        <span class="locate-btn-label">Locate Me</span>
      </button>
    </div>
  </div>
  <span
    class="lucira-pincode-error"
    id="lucira-pincode-error"
    style="display:none;color:red;font-size:12px;margin-top:5px;"
  ></span>

  <div
    id="store-availability-wrapper"
    data-available="{{ product.selected_or_first_available_variant.available }}"
  >
    <div class="store-availability-bar">
      <p class="store-text">This Design is <span class="highlight">Available at Store</span></p>

      <button class="store-cta" id="openPincodePopup">Find Nearest Store</button>
    </div>
  </div>

  <style>
    .store-availability-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 0;
      font-size: 14px;
    }

    /* Left text */
    .store-text {
      margin: 0;
      color: #222;
    }

    /* Green highlight */
    .store-text .highlight {
      color: #2e7d32; /* green */
      font-weight: 500;
    }

    /* Right CTA */
    .store-cta {
      background: none;
      border: none;
      color: #7b3f2c; /* brown tone */
      font-size: 14px;
      cursor: pointer;
      text-decoration: underline;
      padding: 0;
    }

    .store-cta:hover {
      opacity: 0.7;
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const btn = document.getElementById('openPincodePopup');

      if (btn) {
        btn.addEventListener('click', function () {
          // Trigger your popup here
          document.body.classList.add('pincode-popup-open');

          // OR:
          // document.getElementById('pincode-popup').style.display = 'block';
        });
      }
    });
  </script>
</div>

