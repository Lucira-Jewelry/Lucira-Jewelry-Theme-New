{% assign delivery_days = product.metafields.custom.shipping | default: 4 %}

<div 
  class="lucira-delivery-container" 
  id="pdp-delivery-check"
  data-delivery-days="{{ delivery_days }}"
  data-product-sku="{{ product.selected_or_first_available_variant.sku }}"
  data-product-title="{{ product.title | escape }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
  data-inventory-quantity="{{ product.selected_or_first_available_variant.inventory_quantity }}"
  data-available="{{ product.selected_or_first_available_variant.available }}"
  data-variant-count="{{ product.variants.size }}"
>

  <div class="lucira-delivery-input-container">
    <div class="input-wrapper">
      <svg class="pin-beside-pincode" width="18" height="18"> <use href="#icon-location"></use> </svg>
      <input
        type="text"
        id="lucira-delivery-zipcode"
        placeholder="Enter Pincode"
        maxlength="6"
        inputmode="numeric"
        title="enter pincode"
      >
      <button class="submitButton" data-mode="locate">
        <svg class="locate-me-icon" width="16" height="16" class="icon icon-locate"> 
          <use xlink:href="#icon-locate"></use> 
        </svg> Locate Me
      </button>
    </div>
  </div>

  {% assign total_seconds = delivery_days | times: 86400 %}
  {% assign now = 'now' | date: '%s' %}
  {% assign future_timestamp = now | plus: total_seconds %}
  {% assign delivery_date = future_timestamp | date: '%B %d, %Y' %}

  <div class="lucira-delivery-info">
    <span class="lucira-delivery-time">Estimated Free Dispatch by 
      <span class="delivry_txt">{{ delivery_date }}</span>
    </span>
  </div>
</div>

<script>
(() => {
  const container = document.getElementById("pdp-delivery-check");
  if (!container) return;

  const submitBtn = container.querySelector(".submitButton");
  const pincodeInput = document.getElementById("lucira-delivery-zipcode");
  const dateSpan = container.querySelector(".lucira-delivery-time .delivry_txt");
  const valentineMsg = container.querySelector(".lucira-valentine-msg");
  const dateWrapper = container.querySelector(".lucira-delivery-time");

  const META_DAYS = Number(container.dataset.deliveryDays || 4);

  let isProcessingLocate = false;
  let lastEnteredPincode = null;

  const fmtDatePlus = (plusDays) => {
    const d = new Date();
    d.setDate(d.getDate() + Number(plusDays));
    return d.toLocaleDateString("en-US", {
      day: "numeric",
      month: "long",
      year: "numeric"
    });
  };

  function isBeforeValentinesCutoff() {
    const now = new Date();
    const cutoff = new Date(now.getFullYear(), 1, 12, 23, 59, 59);
    return now <= cutoff;
  }

  function ds() {
    return {
      avail: String(container.dataset.available || "").toLowerCase(),
      qty: Number(container.dataset.inventoryQuantity || 0),
      variantCount: Number(container.dataset.variantCount || 0)
    };
  }

  function isVariantInStock() {
    const { avail, qty } = ds();
    if ((avail === "true" || avail === "1") && qty > 0) return true;
    return false;
  }

  const computeDays = () => (isVariantInStock() ? 2 : 15);

  function repaint() {
    if (!dateSpan) return;

    const inStock = isVariantInStock();
    const showValentine = inStock && isBeforeValentinesCutoff();
    const days = computeDays();

    if (showValentine) {
      valentineMsg.style.display = "inline";
      dateWrapper.style.display = "none";
    } else {
      valentineMsg.style.display = "none";
      dateWrapper.style.display = "inline";
      const effectiveDays = lastEnteredPincode ? days : META_DAYS;
      dateSpan.textContent = fmtDatePlus(effectiveDays);
    }
  }

  function onVariantChange(e) {
    const v = e?.detail?.variant;
    if (v) {
      container.dataset.variantId = String(v.id || "");
      container.dataset.inventoryQuantity = String(v.inventory_quantity || 0);
      container.dataset.available = String(!!v.available);
    }
    repaint();
  }

  document.addEventListener("variant:change", onVariantChange);
  document.addEventListener("variant:changed", onVariantChange);

  /* --------- INITIAL LOAD FIX --------- */
  setLocateView = () => {}; // keep silent, not needed here

  requestAnimationFrame(() => {
    setTimeout(repaint, 60);
  });

  window.addEventListener("load", repaint);
})();
</script>
