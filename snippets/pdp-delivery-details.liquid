{% assign variant = product.selected_or_first_available_variant %}

{% assign is_in_stock = false %}
{% if variant.available and variant.inventory_quantity > 0 %}
  {% assign is_in_stock = true %}
{% elsif variant.available and variant.inventory_management == blank %}
  {% assign is_in_stock = true %}
{% endif %}

{% if is_in_stock %}
  {% assign delivery_days = 2 %}
{% else %}
  {% assign delivery_days = 15 %}
{% endif %}

{% assign total_seconds = delivery_days | times: 86400 %}
{% assign now_ts         = 'now' | date: '%s' %}
{% assign future_ts      = now_ts | plus: total_seconds %}
{% assign delivery_date = future_ts | date: '%B %d, %Y' %}

{% capture variant_stock_json %}
{
  {% for v in product.variants %}
    {% assign v_in_stock = false %}
    {% if v.available and v.inventory_quantity > 0 %}
      {% assign v_in_stock = true %}
    {% elsif v.available and v.inventory_management == blank %}
      {% assign v_in_stock = true %}
    {% endif %}
    {% if v_in_stock %}
      {% assign v_days = 2 %}
    {% else %}
      {% assign v_days = 15 %}
    {% endif %}
    {% assign v_seconds = v_days | times: 86400 %}
    {% assign v_future  = now_ts | plus: v_seconds %}
    "{{ v.id }}": {
      "available": {{ v.available }},
      "inventory": {{ v.inventory_quantity | default: 0 }},
      "days": {{ v_days }},
      "date": "{{ v_future | date: '%B %d, %Y' }}",
      "inStock": {{ v_in_stock }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
}
{% endcapture %}

<style>
  .lucira-location-list {
    margin-top: 10px;
    font-size: 13px;
  }
  .lucira-location-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 0;
    border-bottom: 1px solid #f0f0f0;
  }
  .lucira-location-item:last-child {
    border-bottom: none;
  }
  .lucira-location-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .lucira-location-dot.in-stock  { background: green; }
  .lucira-location-dot.out-stock { background: #ccc; }
  .lucira-location-name { flex: 1; color: #333; }
  .lucira-location-tag {
    font-size: 11px;
    padding: 2px 7px;
    border-radius: 999px;
    font-weight: 500;
  }
  .lucira-location-tag.store     { background: #e8f5e9; color: #2e7d32; }
  .lucira-location-tag.warehouse { background: #e3f2fd; color: #1565c0; }
  .lucira-location-tag.out       { background: #f5f5f5; color: #999; }
  .lucira-location-loading {
    font-size: 12px;
    color: #999;
    margin-top: 8px;
  }
  .lucira-location-header {
    font-size: 12px;
    color: #555;
    margin-top: 10px;
    margin-bottom: 4px;
    font-weight: 500;
  }
</style>

<div
  class="lucira-delivery-container"
  id="pdp-delivery-check"
  data-delivery-days="{{ delivery_days }}"
  data-product-sku="{{ variant.sku | escape }}"
  data-product-title="{{ product.title | escape }}"
  data-variant-id="{{ variant.id }}"
  data-inventory-quantity="{{ variant.inventory_quantity | default: 0 }}"
  data-available="{{ variant.available }}"
  data-variant-count="{{ product.variants.size }}"
  data-is-in-stock="{{ is_in_stock }}"
>
  <script>
    window.variantDeliveryData = {{ variant_stock_json }};
  </script>

  <div class="lucira-delivery-input-container">
    <div class="input-wrapper">
      <svg class="pin-beside-pincode" width="18" height="18">
        <use href="#icon-location"></use>
      </svg>
      <input
        type="text"
        id="lucira-delivery-zipcode"
        placeholder="Enter Pincode"
        maxlength="6"
        inputmode="numeric"
        title="enter pincode"
      >
      <button class="submitButton" id="lucira-locate-btn" type="button">
        <svg class="locate-me-icon" width="16" height="16">
          <use xlink:href="#icon-locate"></use>
        </svg>
        <span class="locate-btn-label">Locate Me</span>
      </button>
    </div>
  </div>

  <span class="lucira-pincode-error" id="lucira-pincode-error" style="display:none;color:red;font-size:12px;margin-top:5px;"></span>

  <!-- Stock badge -->
  <div id="lucira-stock-badge" style="{% unless is_in_stock %}display:none;{% endunless %}font-size:13px; margin-top:6px; margin-bottom:4px; color:green;">
    ✓ Available at Store
  </div>

  <!-- Delivery info -->
  <div class="lucira-delivery-info">
    <span class="lucira-delivery-time">
      <span id="delivery-status-text">
        {% if is_in_stock %}Estimated Free Dispatch by{% else %}Available &amp; Dispatched by{% endif %}
      </span>
      <span class="delivry_txt" id="delivery-date-display">{{ delivery_date }}</span>
    </span>
  </div>

  <!-- Location availability — shown after pincode submit -->
  <div id="lucira-location-wrapper" style="display:none;">
    <div class="lucira-location-header">Availability near your location:</div>
    <div class="lucira-location-list" id="lucira-location-list"></div>
  </div>

</div>

<script>
  window.customerId = {{ customer.id | json }};
</script>

<script>
(function () {
  'use strict';

  var currentVariantId = '{{ variant.id }}';

  function setCookie(name, value, days) {
    days = days || 30;
    var date = new Date();
    date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
    document.cookie = name + "=" + String(value) + "; path=/; expires=" + date.toUTCString();
  }

  function getCookie(name) {
    var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
    return match ? String(match[2]) : null;
  }

  function deleteCookie(name) {
    document.cookie = name + "=; Max-Age=0; path=/";
  }

  function showError(msg) {
    var el = document.getElementById('lucira-pincode-error');
    if (!el) return;
    el.textContent = msg;
    el.style.display = msg ? 'block' : 'none';
  }

  function setLocateBtnState(loading) {
    var btn   = document.getElementById('lucira-locate-btn');
    var label = btn && btn.querySelector('.locate-btn-label');
    if (!btn) return;
    btn.disabled = loading;
    if (label) label.textContent = loading ? 'Locating...' : 'Locate Me';
  }

  function toggleButtonState(isSaved) {
    var input = document.getElementById('lucira-delivery-zipcode');
    var btn   = document.getElementById('lucira-locate-btn');
    if (!input || !btn) return;

    var val   = input.value.replace(/\s+/g, '').trim();
    var label = btn.querySelector('.locate-btn-label');

    if (isSaved) {
      label.textContent = "Change";
      btn.dataset.mode  = "saved";
      input.setAttribute("readonly", true);
      return;
    }

    input.removeAttribute("readonly");
    if (/^\d{6}$/.test(val)) {
      label.textContent = "Submit";
      btn.dataset.mode  = "manual";
    } else {
      label.textContent = "Locate Me";
      btn.dataset.mode  = "geo";
    }
  }

  function pushPromoClick(pincode) {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'promoClick',
      promoClick: { creative_name: 'pincodeEntered', promo_position: String(pincode) }
    });
  }

  function savePincodeToServer(pincode) {
    try {
      function attemptSend(retry) {
        retry = retry || 0;
        var customerId = window.customerId;
        if (!customerId || customerId === 'null') {
          if (retry < 5) { setTimeout(function () { attemptSend(retry + 1); }, 300); }
          return;
        }
        customerId = String(customerId).replace('gid://shopify/Customer/', '');
        fetch('https://api.lucirajewelry.com/customers/pincode.php', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ customer_id: String(customerId), pincode: String(pincode) })
        });
      }
      attemptSend(0);
    } catch (e) {}
  }

  function fetchWithRetry(url) {
    return fetch(url).then(function (r) { return r.json(); });
  }

  // ─── Location availability ───────────────────────────────────────────────

  function showLocationLoading() {
    var wrapper = document.getElementById('lucira-location-wrapper');
    var list    = document.getElementById('lucira-location-list');
    if (!wrapper || !list) return;
    wrapper.style.display = 'block';
    list.innerHTML = '<div class="lucira-location-loading">Checking store availability…</div>';
  }

  function renderLocations(locations, userPincode) {
    var list = document.getElementById('lucira-location-list');
    if (!list) return;

    if (!locations || !locations.length) {
      list.innerHTML = '<div style="font-size:12px;color:#999;">No location data available.</div>';
      return;
    }

    // Sort: in-stock first, then by proximity (same pincode prefix = closer)
    locations.sort(function (a, b) {
      var aStock = a.available > 0 ? 1 : 0;
      var bStock = b.available > 0 ? 1 : 0;
      if (bStock !== aStock) return bStock - aStock;
      // rough proximity: compare first 3 digits of pincode
      var userPre = userPincode ? userPincode.slice(0, 3) : '';
      var aClose  = a.pincode && a.pincode.slice(0, 3) === userPre ? 1 : 0;
      var bClose  = b.pincode && b.pincode.slice(0, 3) === userPre ? 1 : 0;
      return bClose - aClose;
    });

    list.innerHTML = locations.map(function (loc) {
      var inStock   = loc.available > 0;
      var dotClass  = inStock ? 'in-stock' : 'out-stock';
      var tagClass  = inStock ? loc.type : 'out';
      var tagLabel  = inStock
        ? (loc.type === 'warehouse' ? 'Ships from here' : 'Walk-in available')
        : 'Out of stock';
      var cityLine  = loc.city ? ' <span style="color:#999;font-size:11px;">· ' + loc.city + '</span>' : '';

      return '<div class="lucira-location-item">'
        + '<div class="lucira-location-dot ' + dotClass + '"></div>'
        + '<span class="lucira-location-name">' + loc.name + cityLine + '</span>'
        + '<span class="lucira-location-tag ' + tagClass + '">' + tagLabel + '</span>'
        + '</div>';
    }).join('');
  }

  function fetchLocationAvailability(variantId, pincode) {
    showLocationLoading();
    fetch('https://api.lucirajewelry.com/products/inventory.php?variant_id=' + variantId)
      .then(function (r) { return r.json(); })
      .then(function (data) {
        renderLocations(data.locations, pincode);
      })
      .catch(function () {
        var list = document.getElementById('lucira-location-list');
        if (list) list.innerHTML = '<div style="font-size:12px;color:#999;">Could not load store availability.</div>';
      });
  }

  // ─── Variant change ──────────────────────────────────────────────────────

  function updateVariantUI(variantId) {
    currentVariantId = String(variantId);
    var data = window.variantDeliveryData && window.variantDeliveryData[currentVariantId];
    if (!data) return;

    var badge     = document.getElementById('lucira-stock-badge');
    var statusTxt = document.getElementById('delivery-status-text');
    var dateTxt   = document.getElementById('delivery-date-display');

    if (badge)     badge.style.display = data.inStock ? '' : 'none';
    if (statusTxt) statusTxt.textContent = data.inStock ? 'Estimated Free Dispatch by' : 'Available & Dispatched by';
    if (dateTxt)   dateTxt.textContent = data.date;

    // If a pincode is already saved, refresh location data for new variant
    var saved = String(getCookie('user_pincode') || '');
    if (saved && /^\d{6}$/.test(saved)) {
      fetchLocationAvailability(currentVariantId, saved);
    }
  }

  function listenForVariantChanges() {
    document.addEventListener('variant:changed', function (e) {
      var variant = e.detail && (e.detail.variant || e.detail);
      if (variant && variant.id) updateVariantUI(variant.id);
    });

    var lastVariantId = null;
    setInterval(function () {
      var params    = new URLSearchParams(window.location.search);
      var currentId = params.get('variant');
      if (currentId && currentId !== lastVariantId) {
        lastVariantId = currentId;
        updateVariantUI(currentId);
      }
    }, 300);

    var container = document.getElementById('pdp-delivery-check');
    if (container && window.MutationObserver) {
      new MutationObserver(function (mutations) {
        mutations.forEach(function (m) {
          if (m.attributeName === 'data-variant-id') {
            var id = container.getAttribute('data-variant-id');
            if (id) updateVariantUI(id);
          }
        });
      }).observe(container, { attributes: true });
    }
  }

  // ─── Pincode submit handler ──────────────────────────────────────────────

  function onPincodeConfirmed(pincode) {
    setCookie('user_pincode', String(pincode));
    pushPromoClick(pincode);
    savePincodeToServer(pincode);
    toggleButtonState(true);
    fetchLocationAvailability(currentVariantId, pincode);
  }

  function init() {
    var btn   = document.getElementById('lucira-locate-btn');
    var input = document.getElementById('lucira-delivery-zipcode');
    if (!btn || !input) return;

    input.addEventListener('input', function () { toggleButtonState(false); });
    input.addEventListener('keydown', function (e) { if (e.key === 'Enter') btn.click(); });

    btn.addEventListener('click', function () {
      showError('');
      var mode = btn.dataset.mode;
      var val  = input.value.replace(/\s+/g, '').trim();

      if (mode === "saved") {
        deleteCookie('user_pincode');
        input.value = '';
        document.getElementById('lucira-location-wrapper').style.display = 'none';
        toggleButtonState(false);
        return;
      }

      if (mode === "manual") {
        if (!/^\d{6}$/.test(val)) { showError('Invalid pincode'); return; }
        fetchWithRetry('https://nominatim.openstreetmap.org/search?postalcode=' + val + '&country=India&format=json')
          .then(function (data) {
            if (data && data.length) {
              onPincodeConfirmed(val);
            } else {
              showError('Pincode not found');
            }
          });
        return;
      }

      if (!navigator.geolocation) { showError('Geolocation not supported'); return; }
      setLocateBtnState(true);

      navigator.geolocation.getCurrentPosition(function (pos) {
        fetchWithRetry('https://nominatim.openstreetmap.org/reverse?lat=' + pos.coords.latitude + '&lon=' + pos.coords.longitude + '&format=json')
          .then(function (data) {
            var pin = data && data.address && data.address.postcode && data.address.postcode.replace(/\s+/g, '');
            if (pin && /^\d{6}$/.test(pin)) {
              input.value = pin;
              onPincodeConfirmed(pin);
            } else {
              showError('Invalid location');
            }
          })
          .finally(function () { setLocateBtnState(false); });
      }, function () {
        setLocateBtnState(false);
        showError('Permission denied');
      });
    });

    // Load saved pincode
    var saved = String(getCookie('user_pincode') || '');
    if (saved && /^\d{6}$/.test(saved)) {
      input.value = saved;
      toggleButtonState(true);
      savePincodeToServer(saved);
      fetchLocationAvailability(currentVariantId, saved);
    } else {
      toggleButtonState(false);
    }

    listenForVariantChanges();
  }

  document.addEventListener('DOMContentLoaded', init);
})();
</script>