<div
  class="lucira-delivery-container"
  id="pdp-delivery-check"
  data-delivery-days="{{ delivery_days }}"
  data-product-sku="{{ variant.sku | escape }}"
  data-product-title="{{ product.title | escape }}"
  data-variant-id="{{ variant.id }}"
  data-inventory-quantity="{{ variant.inventory_quantity | default: 0 }}"
  data-available="{{ variant.available }}"
  data-variant-count="{{ product.variants.size }}"
  data-is-in-stock="{{ is_in_stock }}"
>

  <!-- 🔥 VARIANT DATA -->
  <script>
    window.productVariants = {{ product.variants | json }};
    window.initialVariantId = {{ product.selected_or_first_available_variant.id }};
  </script>

  <!-- 🔹 PINCODE INPUT (UNCHANGED) -->
  <div class="lucira-delivery-input-container">
    <div class="input-wrapper">
      <svg class="pin-beside-pincode" width="18" height="18">
        <use href="#icon-location"></use>
      </svg>
      <input
        type="text"
        id="lucira-delivery-zipcode"
        placeholder="Enter Pincode"
        maxlength="6"
        inputmode="numeric"
        title="enter pincode"
      >
      <button class="submitButton" id="lucira-locate-btn" type="button">
        <svg class="locate-me-icon" width="16" height="16">
          <use xlink:href="#icon-locate"></use>
        </svg>
        <span class="locate-btn-label">Locate Me</span>
      </button>
    </div>
  </div>

  <span
    class="lucira-pincode-error"
    id="lucira-pincode-error"
    style="display:none;color:red;font-size:12px;margin-top:5px;"
  ></span>

  <!-- 🔥 STORE BAR (DEFAULT HIDDEN) -->
  <div id="store-availability-wrapper" style="display:none;">
    <div class="store-availability-bar">
      <p class="store-text">
        This Design is <span class="highlight">Available at Store</span>
      </p>

      <button class="store-cta" id="openPincodePopup">
        Find Nearest Store
      </button>
    </div>
  </div>

  <style>
    .store-availability-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 0;
      font-size: 14px;
    }

    .store-text {
      margin: 0;
      color: #222;
    }

    .store-text .highlight {
      color: #2e7d32;
      font-weight: 500;
    }

    .store-cta {
      background: none;
      border: none;
      color: #7b3f2c;
      font-size: 14px;
      cursor: pointer;
      text-decoration: underline;
      padding: 0;
    }

    .store-cta:hover {
      opacity: 0.7;
    }
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", function () {

      const wrapper = document.getElementById("store-availability-wrapper");
      const btn = document.getElementById("openPincodePopup");

      if (!wrapper) return;

      /* CTA */
      if (btn) {
        btn.addEventListener("click", function () {
          document.body.classList.add("pincode-popup-open");
        });
      }

      /* 🔥 STRICT INVENTORY CHECK */
      function isVariantInStock(variant) {
        if (!variant) return false;
        return variant.inventory_quantity > 0;
      }

      /* 🔥 CORE FUNCTION */
      function updateStoreAvailability(variantId) {
        if (!variantId || !window.productVariants) return;

        const variant = window.productVariants.find(v => v.id == variantId);
        if (!variant) return;

        if (isVariantInStock(variant)) {
          wrapper.style.display = "block";
        } else {
          wrapper.style.display = "none";
        }
      }

      /* GET VARIANT FROM URL */
      function getVariantFromUrl() {
        const params = new URLSearchParams(window.location.search);
        return params.get("variant");
      }

      /* INITIAL LOAD */
      const initialVariant = getVariantFromUrl() || window.initialVariantId;
      updateStoreAvailability(initialVariant);

      /* 🔥 LISTEN: VARIANT CHANGE (FORM INPUT) */
      document.querySelectorAll('form[action*="/cart/add"] [name="id"]').forEach(input => {
        input.addEventListener("change", function () {
          updateStoreAvailability(this.value);
        });
      });

      /* 🔥 LISTEN: URL CHANGE */
      let lastUrl = location.href;

      new MutationObserver(() => {
        const currentUrl = location.href;

        if (currentUrl !== lastUrl) {
          lastUrl = currentUrl;
          const variantId = getVariantFromUrl();
          updateStoreAvailability(variantId);
        }
      }).observe(document, { subtree: true, childList: true });

    });
  </script>

</div>