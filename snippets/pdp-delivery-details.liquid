{% assign delivery_days = product.metafields.custom.shipping | default: 4 %}

<div 
  class="lucira-delivery-container" 
  id="pdp-delivery-check"
  data-delivery-days="{{ delivery_days }}"
  data-product-sku="{{ product.selected_or_first_available_variant.sku }}"
  data-product-title="{{ product.title | escape }}"
>


  <div class="lucira-delivery-input-container">
    <div class="input-wrapper">
      <svg class="pin-beside-pincode" width="18" height="18"> <use href="#icon-location"></use> </svg>
      <input
        type="text"
        id="lucira-delivery-zipcode"
        placeholder="Enter Pincode"
        maxlength="6"
        inputmode="numeric"
        title="enter pincode"
      >
      <button class="submitButton"> <svg class="locate-me-icon" width="16" height="16" class="icon icon-locate"> <use xlink:href="#icon-locate"></use> </svg> Locate Me</button>
    </div>
  </div>

  {% assign total_seconds = delivery_days | times: 86400 %}
  {% assign now = 'now' | date: '%s' %}
  {% assign future_timestamp = now | plus: total_seconds %}
  {% assign delivery_date = future_timestamp | date: '%B %d, %Y' %}

  <div class="lucira-delivery-info">
    <span class="lucira-delivery-time">Estimated Free Dispatch by 
      <span class="delivry_txt">{{ delivery_date }}</span>
    </span>
  </div>
</div>

<script>
  window.delivery_days_from_metafield = {{ delivery_days }};
  document.addEventListener("DOMContentLoaded", function () {
    const submitBtn = document.querySelector("#pdp-delivery-check .submitButton");
    const pincodeInput = document.querySelector("#lucira-delivery-zipcode");
    const metafieldDays = window.delivery_days_from_metafield || 4;

    pincodeInput.addEventListener("input", () => {
      const val = pincodeInput.value.trim();
      const isValid = val.length === 6 && /^\d+$/.test(val);
      submitBtn.disabled = !isValid;
      if (isValid) {
        submitBtn.textContent = "Submit";
      } else {
        submitBtn.innerHTML = '<svg width="16" height="16" class="icon icon-locate"> <use xlink:href="#icon-locate"></use> </svg> Locate Me';
      }
    });

    submitBtn.addEventListener("click", function () {
      const pincode = pincodeInput?.value?.trim();
      const buttonText = submitBtn.textContent.trim();
      
      // If button says "Locate Me" or pincode is empty, trigger locate me
      if (buttonText.includes("Locate Me") || !pincode || pincode.length !== 6) {
        luciraLocateMe();
        return;
      }
      
      // If valid pincode and button says Submit, submit
      if (!submitBtn.disabled && buttonText === "Submit") {
        const productData = {
          promo_id: "{{ product.selected_or_first_available_variant.sku }}",
          promo_name: "{{ product.title }}",
          creative_name: "pincodeEntered",
          location_id: "{{ product.selected_or_first_available_variant.id }}",
          promo_position: pincode,
          pincode: pincode
        };

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "promoClick",
          promoClick: productData
        });

        const totalDays = metafieldDays + 2;
        const deliveryDate = new Date();
        deliveryDate.setDate(deliveryDate.getDate() + totalDays);

        const formattedDate = deliveryDate.toLocaleDateString('en-US', {
          day: 'numeric',
          month: 'long',
          year: 'numeric'
        });

        const deliveryTextElement = document.querySelector(".lucira-delivery-time");
        if (deliveryTextElement) {
          deliveryTextElement.innerHTML = `Expected Delivery By <span style="color:#147217;font-weight:bold;">${formattedDate}</span>`;
        }
      }
    });
  });

  document.getElementById("lucira-delivery-zipcode").addEventListener("input", function () {
    this.value = this.value.replace(/\D/g, "").slice(0, 6);
  });
</script>

