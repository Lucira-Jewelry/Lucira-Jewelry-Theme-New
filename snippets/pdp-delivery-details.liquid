<div
  class="lucira-delivery-container"
  id="pdp-delivery-check"
>

  <!-- 🔹 STORE AVAILABILITY BAR -->
  <div id="store-availability-wrapper">
    <div class="store-availability-bar">
      
      <p class="store-text">
        This Design is <span class="highlight">Available at Store</span>
      </p>

      <button class="store-cta" id="openPincodePopup">
        Find Nearest Store
      </button>

    </div>
  </div>

</div>

<!-- 🔥 VARIANT DATA -->
<script>
  window.productVariants = {{ product.variants | json }};
  window.initialVariantId = {{ product.selected_or_first_available_variant.id }};
</script>

<style>
.store-availability-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  font-size: 14px;
}

.store-text {
  margin: 0;
  color: #222;
}

.store-text .highlight {
  color: #2e7d32;
  font-weight: 500;
}

.store-cta {
  background: none;
  border: none;
  color: #7b3f2c;
  font-size: 14px;
  cursor: pointer;
  text-decoration: underline;
  padding: 0;
}

.store-cta:hover {
  opacity: 0.7;
}

/* Optional mobile */
@media (max-width: 600px) {
  .store-availability-bar {
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }

  .store-cta {
    align-self: flex-end;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const wrapper = document.getElementById("store-availability-wrapper");
  const btn = document.getElementById("openPincodePopup");

  if (!wrapper) return;

  /* 🔹 CTA */
  if (btn) {
    btn.addEventListener("click", function () {
      document.body.classList.add("pincode-popup-open");
    });
  }

  /* 🔥 CORE FUNCTION */
  function updateStoreAvailability(variantId) {
    if (!variantId || !window.productVariants) return;

    const variant = window.productVariants.find(v => v.id == variantId);

    if (!variant) return;

    if (variant.available) {
      wrapper.style.display = "block";
    } else {
      wrapper.style.display = "none";
    }
  }

  /* 🔹 GET VARIANT FROM URL */
  function getVariantFromUrl() {
    const params = new URLSearchParams(window.location.search);
    return params.get("variant");
  }

  /* 🔹 INITIAL LOAD */
  updateStoreAvailability(getVariantFromUrl() || window.initialVariantId);

  /* 🔥 LISTEN: VARIANT INPUT CHANGE */
  document.querySelectorAll('form[action*="/cart/add"] [name="id"]').forEach(input => {
    input.addEventListener("change", function () {
      updateStoreAvailability(this.value);
    });
  });

  /* 🔥 LISTEN: URL CHANGE (Dawn & modern themes) */
  let lastUrl = location.href;

  new MutationObserver(() => {
    const currentUrl = location.href;

    if (currentUrl !== lastUrl) {
      lastUrl = currentUrl;
      const variantId = getVariantFromUrl();
      updateStoreAvailability(variantId);
    }
  }).observe(document, { subtree: true, childList: true });

});
</script>