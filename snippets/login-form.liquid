<div id="login-popup" onclick="closeloginPopup('login-popup')">

  <div onclick="event.stopPropagation()">

    <button onclick="closeloginPopup('login-popup')">X</button>

    <form id="otp-login-form">

      <h2>WELCOME TO LUCIRA</h2>

      <div class="otp-number-wrapper">
        <label>Phone Number</label>
        <span>+91</span>
        <input type="tel" id="mobile" maxlength="10">
      </div>

      <button type="button" id="sendOtp">REQUEST OTP</button>

      <div id="otpSection" style="display:none">

        <label>Enter OTP</label>

        <div class="otp-inputs">
          <input maxlength="1">
          <input maxlength="1">
          <input maxlength="1">
          <input maxlength="1">
        </div>

        <button type="button" id="verifyOtp">VERIFY OTP</button>

        <p id="otp-timer">Resend OTP in 02:00</p>

      </div>

    </form>
  </div>
</div>

<div id="signup-popup" onclick="closeloginPopup(event,'signup-popup')">

  <div onclick="event.stopPropagation()">

    <button onclick="closeloginPopup('signup-popup')">X</button>

    {% form 'create_customer' %}
      <input name="customer[first_name]" placeholder="First Name">
      <input name="customer[last_name]" placeholder="Last Name">
      <input name="customer[email]" placeholder="Email">
      <input type="tel" placeholder="Mobile">
      <button>CREATE ACCOUNT</button>
    {% endform %}

  </div>
</div>

<div style="display:none">
  {% form 'customer_login' %}
    <input type="email" id="CustomerEmail" name="customer[email]">
    <input type="password" id="CustomerPassword" name="customer[password]">
    <button>LOGIN</button>
  {% endform %}
</div>

<script>

function openloginPopup(id){
  document.getElementById(id).style.display = 'block';
}
function closeloginPopup(e,id){
  if(typeof id==='undefined') id=e;
  document.getElementById(id).style.display='none';
}

document.getElementById("sendOtp").onclick = async ()=>{

  const mobile = document.getElementById("mobile").value.trim();

  if(!/^[6-9]\d{9}$/.test(mobile)){
    alert("Invalid number");
    return;
  }

  const res = await fetch(
    "https://login-otp-385594025448.asia-south1.run.app",
    {
      method:"POST",
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({mobile})
    }
  );

  const data = await res.json();

  if(data.type==="success"){
    document.querySelector(".otp-number-wrapper").style.display="none";
    document.getElementById("sendOtp").style.display="none";
    document.getElementById("otpSection").style.display="block";
    startTimer();
  }
  else{
    alert("OTP failed");
  }
};

document.getElementById("verifyOtp").onclick = async ()=>{

  const otp = [...document.querySelectorAll(".otp-inputs input")]
              .map(i=>i.value).join("");

  const mobile = document.getElementById("mobile").value.trim();

  if(otp.length!=4){
    alert("Invalid OTP");
    return;
  }

  const res = await fetch(
    "https://login-otp-385594025448.asia-south1.run.app/verify-otp.php",
    {
      method:"POST",
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({otp,mobile})
    }
  );

  const data = await res.json();

  if(data.type==="success"){
    shopifyAutoLogin(data.email,data.password);
  }
  else{
    alert("Wrong OTP");
  }
};

function shopifyAutoLogin(email,password){

  const emailInput = document.getElementById("CustomerEmail");
  const passInput  = document.getElementById("CustomerPassword");

  emailInput.value = email;
  passInput.value  = password;

  const form = emailInput.closest("form");

  // IMPORTANT hidden fields Shopify expects
  const formType = document.createElement("input");
  formType.type="hidden";
  formType.name="form_type";
  formType.value="customer_login";

  const utf8 = document.createElement("input");
  utf8.type="hidden";
  utf8.name="utf8";
  utf8.value="✓";

  form.appendChild(formType);
  form.appendChild(utf8);

  form.submit(); // 🚀 LOGIN
}


const inputs = document.querySelectorAll(".otp-inputs input");

inputs.forEach((el,i)=>{
  el.oninput=()=>{
    el.value = el.value.replace(/\D/g,'');
    if(el.value && inputs[i+1]) inputs[i+1].focus();
  };
  el.onkeydown=(e)=>{
    if(e.key=="Backspace" && !el.value && inputs[i-1])
      inputs[i-1].focus();
  };
});

inputs[0].onpaste=(e)=>{
  e.preventDefault();
  const paste=e.clipboardData.getData("text").replace(/\D/g,'').slice(0,4);
  paste.split("").forEach((n,i)=>{
    if(inputs[i]) inputs[i].value=n;
  });
};

/* TIMER */
let t=120,interval;
function startTimer(){
  t=120;
  clearInterval(interval);
  interval=setInterval(()=>{
    let m=Math.floor(t/60);
    let s=t%60;
    document.getElementById("otp-timer").innerText=
    `Resend OTP in ${m}:${s<10?'0'+s:s}`;
    if(t<=0){
      clearInterval(interval);
      document.getElementById("otp-timer").innerHTML=
      `<a onclick="resendOtp()">Resend OTP</a>`;
    }
    t--;
  },1000);
}

async function resendOtp(){
  const mobile=document.getElementById("mobile").value;
  await fetch(
    "https://login-otp-385594025448.asia-south1.run.app",
    {
      method:"POST",
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({mobile})
    }
  );
  startTimer();
}

</script>


