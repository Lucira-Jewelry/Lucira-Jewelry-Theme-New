<div id="login-popup" class="login-pop-overlay" onclick="closeloginPopup(event,'login-popup')">
  <div class="otp-login-form-wrapper" onclick="event.stopPropagation()">
    <form class="otp-form-wrapper">
      <h2>LOGIN</h2>
      {%- form 'customer_login', novalidate: 'novalidate' -%}
        <input 
          type="email"
          name="customer[email]"
          placeholder="Email"
          required
        >
        <input 
          type="password"
          name="customer[password]"
          placeholder="Password"
          required
        >
        <button class="btn-primary">
          LOGIN
        </button>
        <p class="switch-link">
          New here?
          <a href="javascript:void(0)" onclick="switchToSignup()">SIGN UP</a>
        </p>
      {%- endform -%}
    </form>
  </div>
</div>

<div id="signup-popup" class="login-pop-overlay" onclick="closeloginPopup(event,'signup-popup')">
  <div class="otp-login-form-wrapper" onclick="event.stopPropagation()">
    <form class="otp-form-wrapper">
      <h2>SIGN UP</h2>
      {%- form 'create_customer', novalidate: 'novalidate' -%}
        <input 
          type="text"
          name="customer[first_name]"
          placeholder="First Name"
          required
        >
        <input 
          type="text"
          name="customer[last_name]"
          placeholder="Last Name"
          required
        >
        <input 
          type="email"
          name="customer[email]"
          placeholder="Email"
          required
        >
        <input 
          type="password"
          name="customer[password]"
          placeholder="Password"
          required
        >
        <button class="btn-primary">
          CREATE ACCOUNT
        </button>
        <p class="switch-link">
          Already a member?
          <a href="javascript:void(0)" onclick="switchToLogin()">LOGIN</a>
        </p>
      {%- endform -%}
    </form>
  </div>
</div>



<style>
    .mobile-wrap{
        display:flex;
        align-items:center;
        border:1px solid #ddd;
        border-radius:8px;
        padding:12px;
    }

    .country-code{
        font-weight:600;
        margin-right:8px;
    }

    .mobile-wrap input{
        border:0;
        outline:0;
        width:100%;
    }
</style>

<script>
    function openloginPopup(id){
    document.getElementById(id).style.display="flex";
    }

    function closeloginPopup(e,id){
    document.getElementById(id).style.display="none";
    }

    function switchToSignup(){
    closeloginPopup(null,'login-popup');
    openloginPopup('signup-popup');
    }

    function switchToLogin(){
    closeloginPopup(null,'signup-popup');
    openloginPopup('login-popup');
    }
</script>
