<div id="login-popup" class="login-pop-overlay" onclick="closeloginPopup('login-popup')">
  <div class="otp-login-form-wrapper">
    <button class="close-button" onclick="closeloginPopup('login-popup')">
      {{- 'icon-login-close.svg' | inline_asset_content -}}
    </button>
    <form id="otp-login-form" class="otp-form-wrapper">
      <h2>WELCOME TO LUCIRA</h2>
      <p>Welcome To The Jewelry World Of Lucira! Find Exclusive Designs At Unbelievable Prices.</p>
      <div class="otp-number-wrapper">
        <label>Phone Number</label>
        <div class="mobile-wrap">
          <span class="country-code">+91</span>
          <input
            type="tel"
            name="customer[phone]"
            id="mobile"
            placeholder="Enter Phone Number"
            maxlength="10"
            required
          >
        </div>
      </div>
      <button type="button" id="sendOtp" class="btn-primary">REQUEST OTP</button>

      <div id="otpSection" style="display:none">
        <label>Enter OTP</label>

        <div class="otp-inputs">
          <input maxlength="1" inputmode="numeric">
          <input maxlength="1" inputmode="numeric">
          <input maxlength="1" inputmode="numeric">
          <input maxlength="1" inputmode="numeric">
        </div>

        <button type="button" id="verifyOtp" class="btn-primary">VERIFY OTP</button>

        <p id="otp-timer">Resend OTP in 02:00</p>
      </div>

      <div class="signupSection" style="display:none">
        {%- form 'create_customer', novalidate: 'novalidate' -%}
          <label>First Name</label>
          <input
            type="text"
            name="customer[first_name]"
            placeholder="First Name"
            class="field-input"
            required
          >
          <label>Last Name</label>
          <input
            type="text"
            name="customer[last_name]"
            placeholder="Last Name"
            class="field-input"
            required
          >
          <label>Email Address</label>
          <input
            type="email"
            name="customer[email]"
            placeholder="Email"
            class="field-input"
            required
          >
          <label>Phone Number</label>
          <div class="mobile-wrap">
            <span class="country-code">+91</span>
            <input
              type="tel"
              id="mobile"
              placeholder="Enter Phone Number"
              maxlength="10"
              required
            >
          </div>
          <button class="btn-primary">CREATE ACCOUNT</button>
          <p class="switch-link">
            Already a member?
            <a href="javascript:void(0)" onclick="switchToLogin()">LOGIN</a>
          </p>
        {%- endform -%}
      </div>
    </form>
  </div>
</div>

<script>
  function openloginPopup(id) {
    document.getElementById(id).style.display = 'flex';
  }
  function closeloginPopup(e, id) {
    if (typeof id === 'undefined') id = e;
    document.getElementById(id).style.display = 'none';
  }
  document.querySelectorAll('.otp-login-form-wrapper').forEach((el) => {
    el.addEventListener('click', (e) => e.stopPropagation());
  });
  function switchToSignup() {
    closeloginPopup('login-popup');
    openloginPopup('signup-popup');
  }
  function switchToLogin() {
    closeloginPopup('signup-popup');
    openloginPopup('login-popup');
  }
  const sendBtn = document.getElementById('sendOtp');
  if (sendBtn) {
    sendBtn.addEventListener('click', async () => {

      const mobile = document.getElementById('signupMobile').value.replace(/\s+/g,'').trim();

      const res = await fetch(
        'https://login-otp-385594025448.asia-south1.run.app',
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mobile })
        }
      );

      const data = await res.json();

      if (data.type === 'success') {
        document.querySelector('.otp-number-wrapper').style.display = 'none';
        document.getElementById('sendOtp').style.display = 'none';
        document.getElementById('otpSection').style.display = 'block';
        startTimer();
        alert('OTP Sent');
      } else {
        alert(data.message || 'Failed');
      }
    });
  }
  const verifyBtn = document.getElementById('verifyOtp');
  if (verifyBtn) {
    verifyBtn.addEventListener('click', async () => {
      const otp = [...document.querySelectorAll('.otp-inputs input')]
        .map(i => i.value)
        .join('');
      const mobile = document.getElementById('signupMobile')
        .value.replace(/\s+/g,'').trim();
      if (otp.length !== 4) {
        alert('Enter valid OTP');
        return;
      }
      const res = await fetch(
        'https://login-otp-385594025448.asia-south1.run.app/generate-token.php',
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ otp, mobile })
        }
      );
      const data = await res.json();
      console.log(data);
      if (data.type === 'success' && data.login_url) {
        window.location.href = data.login_url;
        return;
      }
      if (data.type === 'register') {
        document.getElementById('otpSection').style.display = 'none';
        document.querySelector('.signupSection').style.display = 'block';
        document.getElementById('signupMobile').value = mobile;
        document.getElementById('signupMobile').readOnly = true;
        return;
      }
      alert(data.msg || 'Invalid OTP');
    });
  }

  const otpInputs = document.querySelectorAll('.otp-inputs input');
  otpInputs.forEach((input, index) => {

    input.addEventListener('input', e => {
      const value = e.target.value.replace(/\D/g, '');
      e.target.value = value;

      if (value && index < otpInputs.length - 1) {
        otpInputs[index + 1].focus();
      }
    });

    input.addEventListener('keydown', e => {
      if (e.key === 'Backspace' && !e.target.value && index > 0) {
        otpInputs[index - 1].focus();
      }
    });

  });
  otpInputs[0].addEventListener('paste', e => {
    e.preventDefault();
    const paste = e.clipboardData.getData('text').replace(/\D/g, '').slice(0,4);
    paste.split('').forEach((num, i) => {
      if (otpInputs[i]) otpInputs[i].value = num;
    });
    otpInputs[paste.length - 1]?.focus();
  });
  let timer = 120;
  let timerInterval;
  function startTimer() {
    timer = 120;
    clearInterval(timerInterval);

    timerInterval = setInterval(() => {
      let min = Math.floor(timer / 60);
      let sec = timer % 60;

      document.getElementById('otp-timer').innerText =
        `Resend OTP in ${min}:${sec < 10 ? '0' + sec : sec}`;

      if (timer <= 0) {
        clearInterval(timerInterval);
        document.getElementById('otp-timer').innerHTML =
          `<a href="javascript:void(0)" onclick="resendOtp()">Resend OTP</a>`;
      }

      timer--;
    }, 1000);
  }
  async function resendOtp() {
    const mobile = document.getElementById('signupMobile').value.trim();

    await fetch('https://login-otp-385594025448.asia-south1.run.app', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mobile })
    });

    document.getElementById('otp-timer').innerText = "Resend OTP in 02:00";
    startTimer();
  }
  function shopifyAutoLogin(email,password){

    document.getElementById("ShopifyEmail").value = email;
    document.getElementById("ShopifyPassword").value = password;

    document.getElementById("ShopifyEmail")
      .closest("form")
      .submit(); // 🚀 REAL SHOPIFY LOGIN
  }
</script>

<style>
  .otp-login-form-wrapper {background-color: #FFFEFC; padding: 20px; border-radius: 12px; box-shadow: 0 0 10px #0000004d; max-width: 850px; width: 90%; text-align: left; position: relative;}
   .login-pop-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);display:none;justify-content:center;align-items:center;z-index:9999999}
  .otp-login-form-wrapper { width: 900px; display: flex; border-radius: 12px; overflow: hidden; align-items: center;}
  .otp-login-form-wrapper::before{content:"";width:60%;background:url(https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Lucira_model_day_1_32568_copy_2_1_1.jpg?v=1768388597) center/cover no-repeat; height: 460px; border-radius: 8px;}
  .otp-form-wrapper{width: 40%; padding: 0; margin-left: 20px;}
