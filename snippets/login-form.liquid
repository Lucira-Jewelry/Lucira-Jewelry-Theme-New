<div id="login-popup" class="login-pop-overlay" onclick="closeloginPopup('login-popup')">
  <div class="otp-login-form-wrapper">
    <button class="close-button" onclick="closeloginPopup('login-popup')">
      {{- 'icon-login-close.svg' | inline_asset_content -}}
    </button>
    <div id="otp-login-form" class="otp-form-wrapper">
      <h2>WELCOME TO LUCIRA</h2>
      <p>Welcome To The Jewelry World Of Lucira! Find Exclusive Designs At Unbelievable Prices.</p>
      
      <div id="step-mobile">
          <div class="otp-number-wrapper">
            <label>Phone Number</label>
            <div class="mobile-wrap">
              <span class="country-code">+91</span>
              <input type="tel" id="loginMobile" placeholder="Enter Phone Number" maxlength="10">
            </div>
          </div>
          <button type="button" id="sendOtp" class="btn-primary">REQUEST OTP</button>
      </div>

      <div id="step-otp" style="display:none">
        <label>Enter OTP</label>
        <div class="otp-inputs">
          <input maxlength="1" inputmode="numeric"><input maxlength="1" inputmode="numeric"><input maxlength="1" inputmode="numeric"><input maxlength="1" inputmode="numeric">
        </div>
        <button type="button" id="verifyOtp" class="btn-primary">VERIFY OTP</button>
        <p id="otp-timer">Resend OTP in 02:00</p>
      </div>

      <div id="step-register" class="signupSection" style="display:none">
          <label>First Name</label>
          <input type="text" id="regFirstName" class="field-input" placeholder="First Name">
          
          <label>Last Name</label>
          <input type="text" id="regLastName" class="field-input" placeholder="Last Name">
          
          <label>Email Address</label>
          <input type="email" id="regEmail" class="field-input" placeholder="Email">
          
          <label>Phone Number</label>
          <div class="mobile-wrap">
            <span class="country-code">+91</span>
            <input type="tel" id="regMobile" readonly style="background:#f0f0f0;">
          </div>
          
          <button type="button" id="btnCompleteRegister" class="btn-primary">CREATE ACCOUNT</button>
      </div>
      
    </div>
  </div>
</div>

<form id="shopify-auto-login-form" action="/account/login" method="post" style="display:none;">
  <input type="hidden" name="form_type" value="customer_login">
  <input type="hidden" name="utf8" value="✓">
  <input type="email" name="customer[email]" id="ShopifyEmail">
  <input type="password" name="customer[password]" id="ShopifyPassword">
</form>

<script>
  // --- CONFIG ---
  const API_URL = 'https://login-otp-385594025448.asia-south1.run.app'; // Your PHP URL
  
  // --- HELPERS ---
  function openloginPopup(id) { document.getElementById(id).style.display = 'flex'; }
  function closeloginPopup(id) { document.getElementById(id).style.display = 'none'; }
  document.querySelector('.otp-login-form-wrapper').addEventListener('click', e => e.stopPropagation());

  // --- 1. SEND OTP ---
  document.getElementById('sendOtp').addEventListener('click', async () => {
    const mobile = document.getElementById('loginMobile').value.trim();
    if(mobile.length < 10) return alert("Please enter valid number");

    try {
        const res = await fetch(API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mobile: mobile })
        });
        const data = await res.json();
        
        if (data.type === 'success') {
            document.getElementById('step-mobile').style.display = 'none';
            document.getElementById('step-otp').style.display = 'block';
            startTimer();
        } else {
            alert(data.msg || "Error sending OTP");
        }
    } catch(e) { console.error(e); }
  });

  // --- 2. VERIFY OTP ---
  document.getElementById('verifyOtp').addEventListener('click', async () => {
    const otp = [...document.querySelectorAll('.otp-inputs input')].map(i => i.value).join('');
    const mobile = document.getElementById('loginMobile').value.trim();
    
    if(otp.length !== 4) return alert("Enter valid OTP");
    
    document.getElementById('verifyOtp').innerText = "Verifying...";

    try {
        const res = await fetch(API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mobile: mobile, otp: otp, action: 'verify_otp' })
        });
        const data = await res.json();
        document.getElementById('verifyOtp').innerText = "VERIFY OTP";

        if (data.type === 'success') {
            // LOGIN SUCCESS
            shopifyAutoLogin(data.credentials.email, data.credentials.password);
        } 
        else if (data.type === 'register') {
            // USER NEEDS TO REGISTER
            document.getElementById('step-otp').style.display = 'none';
            document.getElementById('step-register').style.display = 'block';
            document.getElementById('regMobile').value = mobile; // Pre-fill mobile
        } 
        else {
            alert(data.msg || "Invalid OTP");
        }
    } catch(e) { console.error(e); }
  });

  // --- 3. COMPLETE REGISTRATION ---
  document.getElementById('btnCompleteRegister').addEventListener('click', async () => {
    const firstName = document.getElementById('regFirstName').value;
    const lastName = document.getElementById('regLastName').value;
    const email = document.getElementById('regEmail').value;
    const mobile = document.getElementById('regMobile').value;

    if(!firstName || !email) return alert("Please fill all fields");

    const btn = document.getElementById('btnCompleteRegister');
    btn.innerText = "Creating Account...";

    try {
        const res = await fetch(API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                action: 'register_customer',
                first_name: firstName,
                last_name: lastName,
                email: email,
                mobile: mobile
            })
        });
        const data = await res.json();

        if (data.type === 'success') {
            shopifyAutoLogin(data.credentials.email, data.credentials.password);
        } else {
            alert(data.msg || "Registration Failed");
            btn.innerText = "CREATE ACCOUNT";
        }
    } catch(e) { console.error(e); }
  });

  // --- UTILS (Timer, Input logic, AutoLogin) ---
  function shopifyAutoLogin(email, password) {
    document.getElementById("ShopifyEmail").value = email;
    document.getElementById("ShopifyPassword").value = password;
    document.getElementById("shopify-auto-login-form").submit();
  }

  // (Include your existing Input handling and Timer logic here...)
  let timer = 120;
  function startTimer() { /* ... your existing timer code ... */ }
  
  // Input auto-focus logic
  const inputs = document.querySelectorAll('.otp-inputs input');
  inputs.forEach((input, i) => {
    input.addEventListener('input', e => {
        if(e.target.value) inputs[i+1]?.focus();
    });
    input.addEventListener('keydown', e => {
        if(e.key === 'Backspace' && !e.target.value) inputs[i-1]?.focus();
    });
  });
</script>

<style>
  .otp-login-form-wrapper {background-color: #FFFEFC; padding: 20px; border-radius: 12px; box-shadow: 0 0 10px #0000004d; max-width: 850px; width: 90%; text-align: left; position: relative;}
   .login-pop-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);display:none;justify-content:center;align-items:center;z-index:9999999}
  .otp-login-form-wrapper { width: 900px; display: flex; border-radius: 12px; overflow: hidden; align-items: center;}
  .otp-login-form-wrapper::before{content:"";width:60%;background:url(https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Lucira_model_day_1_32568_copy_2_1_1.jpg?v=1768388597) center/cover no-repeat; height: 460px; border-radius: 8px;}
  .otp-form-wrapper{width: 40%; padding: 0; margin-left: 20px;}
  .mobile-wrap { display: flex; align-items: center; border: 1px solid #e2e2e2; border-radius: 8px; padding: 10px 16px; background: #ffffff; }
  .country-code { font-weight: 400; font-size: 14px; line-height: 1.6; text-transform: capitalize; margin-right: 10px; padding-right: 12px; border-right: 1px solid #d0d0d0; }
  .mobile-wrap input{border:0;outline:0;width:100%}
  .otp-inputs{display:flex;gap:8px;margin:15px 0}
  .otp-inputs input{width:40px;height:40px;border:1px solid #ddd;border-radius:6px;text-align:center;font-size:16px}
  .otp-login-form-wrapper .btn-primary {width: 100%; background: rgb(183, 119, 102); color: #fff; padding: 16px; border: 0; margin-top: 20px; font-family: Futura Std; font-weight: 400; line-height: 100%; letter-spacing: inherit; text-align: center; text-transform: uppercase; font-size: 13px; border-radius: 8px;}
  #otp-timer{text-align:center;margin-top:10px;font-size:13px}
  .login-image-wrapper img {width: 100%; height: auto;}
  .otp-login-form-wrapper h2 { font-weight: 500; font-size: 18px; line-height: 150%; text-transform: uppercase; text-align: center; margin: 0; margin-bottom: 14px; }
  .otp-login-form-wrapper p {font-weight: 500; font-size: 12px; line-height: 1.7; letter-spacing: 1px; text-align: center; text-transform: capitalize; color: #5B5B5B; margin: 0 0 0px; max-width: 280px; margin-left: auto; margin-right: auto; margin-top: 12px; margin-bottom: 28px;}
  .otp-form-wrapper label { font-family: Futura Std; font-weight: 400; font-size: 12px; line-height: 12px; letter-spacing: normal; margin-bottom: 10px; display: block; color: #666666; }
  .mobile-wrap input { border: 0; outline: 0; width: 100%; font-family: Futura Std; font-weight: 400; font-size: 14px; line-height: 150%; letter-spacing: normal; text-transform: capitalize; }
  .otp-login-form-wrapper button svg {display: block;}
  .otp-login-form-wrapper button.close-button { background: #fff; border-radius: 50%; padding: 4px; position: absolute; right: 20px; top: 20px; border: 0; }
  .otp-login-form-wrapper input.field-input {outline: 0; width: 100%; font-family: Futura Std; font-weight: 400; font-size: 14px; line-height: 150%; letter-spacing: normal; text-transform: capitalize; border: 1px solid #e2e2e2; border-radius: 8px; padding: 10px 16px; background: #ffffff; margin-bottom: 14px;}
  .switch-link a {color: #b77766; font-weight: 500; margin-bottom: 8px;}
  p.switch-link { margin-bottom: 0; }

  @media only screen and (max-width:767px){
      .account-hover-card.active {display: block;}
      .account-wrapper .account-hover-card { position: fixed; top: 98px; left: 50%; right: inherit; transform: translateX(-50%); width: 320px; background: #fff; padding: 20px; border-radius: 14px; box-shadow: 0 10px 30px #00000026; z-index: 99; }
      .otp-form-wrapper { width: 100%; padding: 12px; }
      .otp-login-form-wrapper { width: 95%; background: #fff; display: flex; flex-direction: column; border-radius: 12px; overflow: hidden; }
      .otp-login-form-wrapper::before { content: ""; width: 100%; height: 175px; background: url(https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Lucira_model_day_1_32568_copy_2_1_1.jpg?v=1768388597) center / cover no-repeat; }
      .otp-form-wrapper {margin-left: 0;}
  }
</style>