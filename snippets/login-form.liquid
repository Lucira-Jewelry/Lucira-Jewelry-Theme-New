<div id="login-popup" class="login-pop-overlay" onclick="closeloginPopup('login-popup')">
  <div class="otp-login-form-wrapper">
    <button class="close-button" onclick="closeloginPopup('login-popup')">
      {{- 'icon-login-close.svg' | inline_asset_content -}}
    </button>
    <form id="otp-login-form" class="otp-form-wrapper">
      <h2>WELCOME TO LUCIRA</h2>
      <p>Welcome To The Jewelry World Of Lucira! Find Exclusive Designs At Unbelievable Prices.</p>
      <div class="otp-number-wrapper">
        <label>Phone Number</label>
        <div class="mobile-wrap">
          <span class="country-code">+91</span>
          <input
            type="tel"
            id="loginMobile"
            placeholder="Enter Phone Number"
            maxlength="10"
            required
          >
        </div>
      </div>
      <button type="button" id="sendOtp" class="btn-primary">REQUEST OTP</button>

      <div id="otpSection" style="display:none">
        <label>Enter OTP</label>

        <div class="otp-inputs">
          <input maxlength="1" inputmode="numeric">
          <input maxlength="1" inputmode="numeric">
          <input maxlength="1" inputmode="numeric">
          <input maxlength="1" inputmode="numeric">
        </div>

        <button type="button" id="verifyOtp" class="btn-primary">VERIFY OTP</button>

        <p id="otp-timer">Resend OTP in 02:00</p>
      </div>

      <div class="signupSection" style="display:none">
        <div class="registration-form-inputs">
          <label>First Name</label>
          <input
            type="text"
            id="regFirstName" 
            placeholder="First Name"
            class="field-input"
            required
          >
          <label>Last Name</label>
          <input
            type="text"
            id="regLastName"
            placeholder="Last Name"
            class="field-input"
            required
          >
          <label>Email Address</label>
          <input
            type="email"
            id="regEmail"
            placeholder="Email"
            class="field-input"
            required
          >
          <label>Phone Number</label>
          <div class="mobile-wrap">
            <span class="country-code">+91</span>
            <input
              type="tel"
              id="signupMobile"
              placeholder="Enter Phone Number"
              readonly
            >
          </div>
          
          <button type="button" id="completeRegistration" class="btn-primary">CREATE ACCOUNT</button>
          
          <p class="switch-link">
            Already a member?
            <a href="javascript:void(0)" onclick="switchToLogin()">LOGIN</a>
          </p>
        </div>
      </div>
    </form>
  </div>
</div>

<form id="shopify-auto-login-form" action="/account/login" method="post" style="display:none;">
  <input type="hidden" name="form_type" value="customer_login">
  <input type="hidden" name="utf8" value="✓">
  <input type="email" name="customer[email]" id="ShopifyEmail">
  <input type="password" name="customer[password]" id="ShopifyPassword">
</form>

<script>
  function openloginPopup(id) {
    document.getElementById(id).style.display = 'flex';
  }
  function closeloginPopup(e, id) {
    if (typeof id === 'undefined') id = e;
    document.getElementById(id).style.display = 'none';
  }
  document.querySelectorAll('.otp-login-form-wrapper').forEach((el) => {
    el.addEventListener('click', (e) => e.stopPropagation());
  });
  function switchToSignup() {
    closeloginPopup('login-popup');
    openloginPopup('signup-popup');
  }
  function switchToLogin() {
    closeloginPopup('signup-popup');
    openloginPopup('login-popup');
  }

  const sendBtn = document.getElementById('sendOtp');
  if (sendBtn) {
    sendBtn.addEventListener('click', async () => {
      const mobile = document.getElementById('loginMobile').value.replace(/\s+/g,'').trim();

      const res = await fetch(
        'https://login-otp-385594025448.asia-south1.run.app',
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mobile })
        }
      );

      const data = await res.json();

      if (data.type === 'success') {
        document.querySelector('.otp-number-wrapper').style.display = 'none';
        document.getElementById('sendOtp').style.display = 'none';
        document.getElementById('otpSection').style.display = 'block';
        startTimer();
        alert('OTP Sent');
      } else {
        alert(data.message || 'Failed');
      }
    });
  }

  const verifyBtn = document.getElementById('verifyOtp');
  if (verifyBtn) {
    verifyBtn.addEventListener('click', async () => {
      const otp = [...document.querySelectorAll('.otp-inputs input')]
        .map(i => i.value)
        .join('');
      const mobile = document.getElementById('loginMobile')
        .value.replace(/\s+/g,'').trim();
      
      if (otp.length !== 4) {
        alert('Enter valid OTP');
        return;
      }

      const verifyButton = document.getElementById('verifyOtp');
      const originalText = verifyButton.textContent;
      verifyButton.textContent = 'Verifying...';
      verifyButton.disabled = true;

      try {
        const res = await fetch(
          'https://otp-verification-385594025448.asia-south1.run.app',
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ otp, mobile })
          }
        );

        const data = await res.json();
        console.log('OTP Verification Response:', data);

        if (data.type === 'success' && data.credentials) {
          console.log('Logging in automatically...');
          shopifyAutoLogin(data.credentials.email, data.credentials.password);
          return;
        }

        if (data.type === 'register') {
          document.getElementById('otpSection').style.display = 'none';
          document.querySelector('.signupSection').style.display = 'block';
          document.getElementById('signupMobile').value = mobile;
          document.getElementById('signupMobile').readOnly = true;
          verifyButton.textContent = originalText;
          verifyButton.disabled = false;
          return;
        }

        alert(data.msg || 'Invalid OTP');
        verifyButton.textContent = originalText;
        verifyButton.disabled = false;

      } catch (error) {
        console.error('Error during verification:', error);
        alert('Something went wrong. Please try again.');
        verifyButton.textContent = originalText;
        verifyButton.disabled = false;
      }
    });
  }

  /* --- NEW: HANDLE REGISTRATION SUBMISSION --- */
  const regBtn = document.getElementById('completeRegistration');
  if (regBtn) {
    regBtn.addEventListener('click', async () => {
      
      // 1. Gather Data
      const firstName = document.getElementById('regFirstName').value.trim();
      const lastName = document.getElementById('regLastName').value.trim();
      const email = document.getElementById('regEmail').value.trim();
      const mobile = document.getElementById('signupMobile').value.trim();
      
      // We need the OTP again to pass security check in backend
      const otp = [...document.querySelectorAll('.otp-inputs input')]
        .map(i => i.value)
        .join('');

      // Simple Validation
      if (!firstName || !lastName || !email) {
        alert('Please fill in all fields.');
        return;
      }

      // UI Feedback
      const originalText = regBtn.textContent;
      regBtn.textContent = 'Creating Account...';
      regBtn.disabled = true;

      try {
        // 2. Send to PHP Backend (Same URL as Verification)
        const res = await fetch(
          'https://otp-verification-385594025448.asia-south1.run.app', 
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              mobile: mobile,
              otp: otp,
              email: email,
              first_name: firstName,
              last_name: lastName
            })
          }
        );

        const data = await res.json();
        console.log('Registration Response:', data);

        // 3. Handle Success -> Auto Login
        if (data.type === 'success' && data.credentials) {
           // Optional: Track 'Complete Registration' event here for Analytics
           shopifyAutoLogin(data.credentials.email, data.credentials.password);
        } else {
           alert(data.msg || 'Registration failed. Please try again.');
           regBtn.textContent = originalText;
           regBtn.disabled = false;
        }

      } catch (error) {
        console.error('Registration Error:', error);
        alert('Something went wrong. Please check your connection.');
        regBtn.textContent = originalText;
        regBtn.disabled = false;
      }
    });
  }

  const otpInputs = document.querySelectorAll('.otp-inputs input');
  otpInputs.forEach((input, index) => {
    input.addEventListener('input', e => {
      const value = e.target.value.replace(/\D/g, '');
      e.target.value = value;

      if (value && index < otpInputs.length - 1) {
        otpInputs[index + 1].focus();
      }
    });

    input.addEventListener('keydown', e => {
      if (e.key === 'Backspace' && !e.target.value && index > 0) {
        otpInputs[index - 1].focus();
      }
    });
  });

  otpInputs[0].addEventListener('paste', e => {
    e.preventDefault();
    const paste = e.clipboardData.getData('text').replace(/\D/g, '').slice(0,4);
    paste.split('').forEach((num, i) => {
      if (otpInputs[i]) otpInputs[i].value = num;
    });
    otpInputs[paste.length - 1]?.focus();
  });

  let timer = 120;
  let timerInterval;
  function startTimer() {
    timer = 120;
    clearInterval(timerInterval);

    timerInterval = setInterval(() => {
      let min = Math.floor(timer / 60);
      let sec = timer % 60;

      document.getElementById('otp-timer').innerText =
        `Resend OTP in ${min}:${sec < 10 ? '0' + sec : sec}`;

      if (timer <= 0) {
        clearInterval(timerInterval);
        document.getElementById('otp-timer').innerHTML =
          `<a href="javascript:void(0)" onclick="resendOtp()">Resend OTP</a>`;
      }

      timer--;
    }, 1000);
  }

  async function resendOtp() {
    const mobile = document.getElementById('loginMobile').value.trim();

    await fetch('https://login-otp-385594025448.asia-south1.run.app', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mobile })
    });

    document.getElementById('otp-timer').innerText = "Resend OTP in 02:00";
    startTimer();
  }

  function shopifyAutoLogin(email, password) {
    console.log('Auto-login triggered for:', email);
    document.getElementById("ShopifyEmail").value = email;
    document.getElementById("ShopifyPassword").value = password;
    document.getElementById("shopify-auto-login-form").submit();
  }
</script>

<style>
  .otp-login-form-wrapper {background-color: #FFFEFC; padding: 20px; border-radius: 12px; box-shadow: 0 0 10px #0000004d; max-width: 800px; width: 90%; text-align: left; position: relative;}
   .login-pop-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);display:none;justify-content:center;align-items:center;z-index:9999999}
  .otp-login-form-wrapper { width: 800px; display: flex; border-radius: 12px; overflow: hidden; align-items: center;}
  .otp-login-form-wrapper::before{content:"";width:62%;background:url(https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Lucira_model_day_1_32568_copy_2_1_1.jpg?v=1768388597) center/cover no-repeat; height: 460px; border-radius: 8px;}
  .otp-form-wrapper{width: 38%; padding: 0; margin-left: 20px;}
  .mobile-wrap { display: flex; align-items: center; border: 1px solid #e2e2e2; border-radius: 8px; padding: 10px 16px; background: #ffffff; }
  .country-code { font-weight: 400; font-size: 14px; line-height: 1.6; text-transform: capitalize; margin-right: 10px; padding-right: 12px; border-right: 1px solid #d0d0d0; }
  .mobile-wrap input{border:0;outline:0;width:100%}
  .otp-inputs{display:flex;gap:8px;margin:15px 0}
  .otp-inputs input{width:40px;height:40px;border:1px solid #ddd;border-radius:6px;text-align:center;font-size:16px}
  .otp-login-form-wrapper .btn-primary {width: 100%; background: rgb(183, 119, 102); color: #fff; padding: 16px; border: 0; margin-top: 20px; font-family: Futura Std; font-weight: 400; line-height: 100%; letter-spacing: inherit; text-align: center; text-transform: uppercase; font-size: 13px; border-radius: 8px;}
  #otp-timer{text-align:center;margin-top:10px;font-size:13px}
  .login-image-wrapper img {width: 100%; height: auto;}
  .otp-login-form-wrapper h2 { font-weight: 500; font-size: 18px; line-height: 150%; text-transform: uppercase; text-align: center; margin: 0; margin-bottom: 14px; }
  .otp-login-form-wrapper p {font-weight: 500; font-size: 12px; line-height: 1.7; letter-spacing: 1px; text-align: center; text-transform: capitalize; color: #5B5B5B; margin: 0 0 0px; max-width: 280px; margin-left: auto; margin-right: auto; margin-top: 12px; margin-bottom: 28px;}
  .otp-form-wrapper label { font-family: Futura Std; font-weight: 400; font-size: 12px; line-height: 12px; letter-spacing: normal; margin-bottom: 10px; display: block; color: #666666; }
  .mobile-wrap input { border: 0; outline: 0; width: 100%; font-family: Futura Std; font-weight: 400; font-size: 14px; line-height: 150%; letter-spacing: normal; text-transform: capitalize; }
  .otp-login-form-wrapper button svg {display: block;}
  .otp-login-form-wrapper button.close-button { background: #fff; border-radius: 50%; padding: 4px; position: absolute; right: 20px; top: 20px; border: 0; }
  .otp-login-form-wrapper input.field-input {outline: 0; width: 100%; font-family: Futura Std; font-weight: 400; font-size: 14px; line-height: 150%; letter-spacing: normal; text-transform: capitalize; border: 1px solid #e2e2e2; border-radius: 8px; padding: 10px 16px; background: #ffffff; margin-bottom: 14px;}
  .switch-link a {color: #b77766; font-weight: 500; margin-bottom: 8px;}
  p.switch-link { margin-bottom: 0; }
  .otp-inputs input { width: calc(25% - 0px); height: 50px; border: 1px solid #ddd; border-radius: 6px; text-align: center; font-size: 16px; }

  @media only screen and (max-width:767px){
      .account-hover-card.active {display: block;}
      .account-wrapper .account-hover-card { position: fixed; top: 98px; left: 50%; right: inherit; transform: translateX(-50%); width: 320px; background: #fff; padding: 20px; border-radius: 14px; box-shadow: 0 10px 30px #00000026; z-index: 99; }
      .otp-form-wrapper { width: 100%; padding: 12px; }
      .otp-login-form-wrapper { width: 95%; background: #fff; display: flex; flex-direction: column; border-radius: 12px; overflow: hidden; }
      .otp-login-form-wrapper::before { content: ""; width: 100%; height: 175px; background: url(https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Lucira_model_day_1_32568_copy_2_1_1.jpg?v=1768388597) center / cover no-repeat; }
      .otp-form-wrapper {margin-left: 0;}
  }
</style>