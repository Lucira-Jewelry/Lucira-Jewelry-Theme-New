<div id="login-popup" class="login-pop-overlay" onclick="closeloginPopup('login-popup')">
  <div class="otp-login-form-wrapper">
    <button class="close-button" onclick="closeloginPopup('login-popup')">
      {{- 'icon-login-close.svg' | inline_asset_content -}}
    </button>

    <div id="otp-login-form" class="otp-form-wrapper">

      <h2>WELCOME TO LUCIRA</h2>
      <p>Welcome To The Jewelry World Of Lucira!</p>

      <!-- MOBILE -->
      <div class="otp-number-wrapper">
        <label>Phone Number</label>
        <div class="mobile-wrap">
          <span class="country-code">+91</span>
          <input id="loginMobile" maxlength="10" required>
        </div>
      </div>

      <button type="button" id="sendOtp" class="btn-primary">
        REQUEST OTP
      </button>

      <!-- OTP -->
      <div id="otpSection" style="display:none">
        <label>Enter OTP</label>
        <div class="otp-inputs">
          <input maxlength="1">
          <input maxlength="1">
          <input maxlength="1">
          <input maxlength="1">
        </div>

        <button type="button" id="verifyOtp" class="btn-primary">
          VERIFY OTP
        </button>

        <p id="otp-timer">Resend OTP in 02:00</p>
      </div>

      <!-- REGISTER -->
      <div class="signupSection" style="display:none">

        <label>First Name</label>
        <input id="regFirst" required>

        <label>Last Name</label>
        <input id="regLast" required>

        <label>Email</label>
        <input id="regEmail" type="email" required>

        <label>Phone</label>
        <input id="signupMobile" readonly required>

        <button type="button" id="registerBtn" class="btn-primary">
          CREATE ACCOUNT
        </button>

      </div>

    </div>
  </div>
</div>

<!-- AUTO LOGIN FORM -->
<form id="shopify-auto-login-form" action="/account/login" method="post" style="display:none;">
  <input name="form_type" value="customer_login">
  <input name="utf8" value="✓">
  <input name="customer[email]" id="ShopifyEmail">
  <input name="customer[password]" id="ShopifyPassword">
</form>

<script>
function closeloginPopup(id){
  document.getElementById(id).style.display="none";
}

const API = "https://otp-verification-385594025448.asia-south1.run.app";

/* SEND OTP */
sendOtp.onclick = async () => {
  const mobile = loginMobile.value.trim();

  const res = await fetch(API.replace("otp-verification","login-otp"),{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({mobile})
  });

  const data = await res.json();

  if(data.type==="success"){
    document.querySelector(".otp-number-wrapper").style.display="none";
    sendOtp.style.display="none";
    otpSection.style.display="block";
    startTimer();
  }
};

/* VERIFY OTP */
verifyOtp.onclick = async () => {

  const otp = [...document.querySelectorAll(".otp-inputs input")]
              .map(i=>i.value).join("");

  const mobile = loginMobile.value.trim();

  const res = await fetch(API,{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({otp,mobile})
  });

  const data = await res.json();

  if(data.type==="success"){
    shopifyAutoLogin(data.credentials.email,data.credentials.password);
  }

  if(data.type==="register"){
    otpSection.style.display="none";
    document.querySelector(".signupSection").style.display="block";
    signupMobile.value = mobile;
  }
};

/* REGISTER */
registerBtn.onclick = async () => {

  const payload = {
    first_name: regFirst.value.trim(),
    last_name : regLast.value.trim(),
    email     : regEmail.value.trim(),
    mobile    : signupMobile.value.trim()
  };

  const res = await fetch(API,{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify(payload)
  });

  const data = await res.json();

  if(data.type==="success"){
    shopifyAutoLogin(data.credentials.email,data.credentials.password);
  }else{
    alert(data.msg);
  }
};

/* AUTO LOGIN */
function shopifyAutoLogin(email,password){
  ShopifyEmail.value=email;
  ShopifyPassword.value=password;
  document.getElementById("shopify-auto-login-form").submit();
}

/* TIMER */
let timer=30;
function startTimer(){
  const i=setInterval(()=>{
    let m=Math.floor(timer/60);
    let s=timer%60;
    otp-timer.innerText=`Resend OTP in ${m}:${s<10?'0'+s:s}`;
    timer--;
    if(timer<0) clearInterval(i);
  },1000);
}
</script>



<style>
