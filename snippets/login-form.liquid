<div id="login-popup" class="login-pop-overlay" onclick="closeloginPopup('login-popup')">
  <div class="otp-login-form-wrapper">
    <button class="close-button" onclick="closeloginPopup('login-popup')">{{- 'icon-login-close.svg' | inline_asset_content -}}</button>
    <form id="otp-login-form" class="otp-form-wrapper">
      <h2>WELCOME TO LUCIRA</h2>
      <p>Welcome To The Jewelry World Of Lucira! Find Exclusive Designs At Unbelievable Prices.</p>

      <label>Phone Number</label>
      <div class="mobile-wrap">
        <span class="country-code">+91</span>
        <input 
          type="tel" 
          id="mobile" 
          placeholder="Enter Phone Number" 
          maxlength="10" 
          required
        >
      </div>

      <button type="button" id="sendOtp" class="btn-primary">
        REQUEST OTP
      </button>

      <div id="otpSection" style="display:none">
        <label>Enter OTP</label>

        <div class="otp-inputs">
          <input maxlength="1">
          <input maxlength="1">
          <input maxlength="1">
          <input maxlength="1">
          <input maxlength="1">
          <input maxlength="1">
        </div>

        <button type="button" id="verifyOtp" class="btn-primary">
          VERIFY OTP
        </button>

        <p id="otp-timer">Resend OTP in 02:00</p>
      </div>
    </form>
  </div>
</div>

<div id="signup-popup" class="login-pop-overlay" onclick="closeloginPopup(event,'signup-popup')">
  <div class="otp-login-form-wrapper" onclick="event.stopPropagation()">
    <form class="otp-form-wrapper">
      <h2>WELCOME TO LUCIRA</h2>
      <p>Welcome To The Jewelry World Of Lucira! Find Exclusive Designs At Unbelievable Prices.</p>
      {%- form 'create_customer', novalidate: 'novalidate' -%}
        <label>First Name</label>
        <input 
          type="text"
          name="customer[first_name]"
          placeholder="First Name"
          required
        >
        <label>Last Name</label>
        <input 
          type="text"
          name="customer[last_name]"
          placeholder="Last Name"
          required
        >
        <label>Email Address</label>
        <input 
          type="email"
          name="customer[email]"
          placeholder="Email"
          required
      >
        <label>Phone Number</label>
        <div class="mobile-wrap">
            <span class="country-code">+91</span>
            <input 
            type="tel" 
            id="mobile" 
            placeholder="Enter Phone Number" 
            maxlength="10" 
            required
            >
        </div>
        <button class="btn-primary">
          CREATE ACCOUNT
        </button>
        <p class="switch-link">
          Already a member?
          <a href="javascript:void(0)" onclick="switchToLogin()">LOGIN</a>
        </p>
      {%- endform -%}
    </form>
  </div>
</div>



<style>
    .otp-login-form-wrapper {background-color: #FFFEFC; padding: 20px; border-radius: 12px; box-shadow: 0 0 10px #0000004d; max-width: 800px; width: 90%; text-align: left; position: relative;}
     .login-pop-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);display:none;justify-content:center;align-items:center;z-index:9999999}
    .otp-login-form-wrapper { width: 900px; display: flex; border-radius: 12px; overflow: hidden; align-items: center;}
    .otp-login-form-wrapper::before{content:"";width:60%;background:url(https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Lucira_model_day_1_32568_copy_2_1_1.jpg?v=1768388597) center/cover no-repeat; height: 460px; border-radius: 8px;}
    .otp-form-wrapper{width: 40%; padding: 0; margin-left: 20px;}
    .mobile-wrap { display: flex; align-items: center; border: 1px solid #e2e2e2; border-radius: 8px; padding: 10px 16px; background: #ffffff; }
    .country-code { font-weight: 400; font-size: 14px; line-height: 1.6; text-transform: capitalize; margin-right: 10px; padding-right: 12px; border-right: 1px solid #d0d0d0; }
    .mobile-wrap input{border:0;outline:0;width:100%}
    .otp-inputs{display:flex;gap:8px;margin:15px 0}
    .otp-inputs input{width:40px;height:40px;border:1px solid #ddd;border-radius:6px;text-align:center;font-size:16px}
    .otp-login-form-wrapper .btn-primary {width: 100%; background: rgb(183, 119, 102); color: #fff; padding: 16px; border: 0; margin-top: 10px; font-family: Futura Std; font-weight: 400; line-height: 100%; letter-spacing: inherit; text-align: center; text-transform: uppercase; font-size: 13px; border-radius: 8px;}
    #otp-timer{text-align:center;margin-top:10px;font-size:13px}
    .login-image-wrapper img {width: 100%; height: auto;}
    .otp-login-form-wrapper h2 { font-weight: 500; font-size: 18px; line-height: 150%; text-transform: uppercase; text-align: center; margin: 0; margin-bottom: 10px; }
    .otp-login-form-wrapper p {font-weight: 500; font-size: 12px; line-height: 1.6; letter-spacing: 1px; text-align: center; text-transform: capitalize; color: #5B5B5B; margin: 0 0 28px; max-width: 280px; margin-left: auto; margin-right: auto;}
    .otp-form-wrapper label { font-family: Futura Std; font-weight: 400; font-size: 12px; line-height: 12px; letter-spacing: normal; margin-bottom: 10px; display: block; color: #666666; }
    .mobile-wrap input { border: 0; outline: 0; width: 100%; font-family: Futura Std; font-weight: 400; font-size: 14px; line-height: 150%; letter-spacing: normal; text-transform: capitalize; }
    .otp-login-form-wrapper button svg {display: block;}
    .otp-login-form-wrapper button.close-button { background: #fff; border-radius: 50%; padding: 4px; position: absolute; right: 20px; top: 20px; border: 0; }
    input {outline: 0; width: 100%; font-family: Futura Std; font-weight: 400; font-size: 14px; line-height: 150%; letter-spacing: normal; text-transform: capitalize; border: 1px solid #e2e2e2; border-radius: 8px; padding: 10px 16px; background: #ffffff; margin-bottom: 14px;}
    
    @media only screen and (max-width:767px){
        .account-hover-card.active {display: block;}
        .account-wrapper .account-hover-card { position: fixed; top: 98px; left: 50%; right: inherit; transform: translateX(-50%); width: 320px; background: #fff; padding: 20px; border-radius: 14px; box-shadow: 0 10px 30px #00000026; z-index: 99; }
        .otp-form-wrapper { width: 100%; padding: 12px; }
        .otp-login-form-wrapper { width: 95%; background: #fff; display: flex; flex-direction: column; border-radius: 12px; overflow: hidden; }
        .otp-login-form-wrapper::before { content: ""; width: 100%; height: 175px; background: url(https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Lucira_model_day_1_32568_copy_2_1_1.jpg?v=1768388597) center / cover no-repeat; }
        .otp-form-wrapper {margin-left: 0;}
    }
</style>

<script>
function openloginPopup(id){
  document.getElementById(id).style.display="flex";
}

/* Works for BOTH calls:
   closeloginPopup('login-popup')
   closeloginPopup(event,'login-popup')
*/
function closeloginPopup(e,id){

  // If only one argument passed
  if(typeof id === "undefined"){
    id = e; // first param is id
  }

  document.getElementById(id).style.display="none";
}

/* Stop close when clicking inside popup */
document.querySelectorAll(".otp-login-form-wrapper").forEach(el=>{
  el.addEventListener("click",function(e){
    e.stopPropagation();
  });
});

function switchToSignup(){
  closeloginPopup('login-popup');
  openloginPopup('signup-popup');
}

function switchToLogin(){
  closeloginPopup('signup-popup');
  openloginPopup('login-popup');
}
</script>



