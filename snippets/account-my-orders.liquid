<style>
.return-review{display:flex;flex-direction:column;align-items:center;justify-content:space-between;border-top:1px solid #e5e5e5;padding:0;margin-top:16px;font-size:13px}
.completion-info a{padding:16px;font-size:16px;font-weight:600;color:#555;text-decoration:none;background:#a68380;color:#fff;border-radius:8px}
.return-again{display:flex;border-bottom:1px solid #e6e6e6;padding:8px 0;width:100%}
.review-style{text-decoration:none;color:#555;padding:8px;font-size:14px;font-weight:400;display:block}
.order-style svg,.return-style svg,.review-style svg{margin-right:8px}
.view-details{font-size:14px;color:#666;text-decoration:underline;margin-left:16px;font-weight:500;text-transform:uppercase;padding-right:24px;cursor:pointer}
.line-title{font-size:14px;width:600px}
.line-quantity{font-size:14px;color:#666;margin:12px 0}
.view-details-mob{display:none}
@media(max-width:768px){
.prod-pic{width:80px;height:80px;margin-right:14px}
.view-details-mob{display:flex;font-size:12px!important;justify-content:space-between;align-items:center;margin:0!important;padding:0!important}
.view-details-mob svg{height:9px}
.view-details{display:none}
.line-quantity{margin:0}
.view-details{display:none}
.line-title{font-size:12px;width:auto;max-width:224px;text-overflow:ellipsis;overflow:hidden;white-space:nowrap}
.return-review{margin-top:16px}
}
@media(max-width:380px){
.line-quantity,.return-review{margin:0}
.mobdis-number div,.mobdis-status div{font-size:12px}
}
</style>
