<style>
/* Shipment Timeline Styles */
.shipment-timeline {
  margin: 15px 20px 20px;
  border-radius: 8px;
  background-color: #f9f9f9;
  font-family: sans-serif;
}

.timeline-header {
  text-align: center;
  margin-bottom: 0px;
  font-size: 18px;
  color: #333;
  font-weight: 600;
}

.timeline-track {
  display: flex;
  align-items: center;
  margin: 15px 0;
}

.timeline-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  text-align: center;
  position: relative;
}

.step-indicator {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background-color: #e0e0e0;
  border: 2px solid #ccc;
  margin-bottom: 10px;
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-indicator.active {
  background-color: #f4f0f0;
  border-color: #a68380;
}

.step-indicator.active:after {
  content: "✓";
  color: black;
  font-size: 12px;
  font-weight: bold;
}

.connecting-line {
  flex: 1;
  height: 3px;
  background-color: #e0e0e0;
  position: relative;
  z-index: 1;
}

.connecting-line.active {
  background-color: #a68380;
}
/* 
.step-content {
  padding: 0 5px;
} */

.step-content h4 {
  margin: 0 0 5px;
      color: #555;
  font-size: 14px;
  font-weight: 400;
}

.step-content p {
  margin: 0;
  font-size: 12px;
  color: #666;
  display: none;
}

.step-content:hover p {
  display: block;
  position: absolute;
  background: white;
  border: 1px solid #ddd;
  padding: 5px;
  border-radius: 4px;
  z-index: 10;
  width: 150px;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.completion-info {
  margin-top: 15px;
  text-align: center;
  font-style: italic;
  color: #666;
  font-size: 13px;
}

/* Mobile Responsive Adjustments */
@media (max-width: 768px) {

  .step-indicator{
    width: 16px !important;
    height: 16px !important;
    margin-right: 8px !important;
  }

  .step-content {
    padding: 0;
  }
  
  .timeline-track {
    flex-direction: column;
    align-items: flex-start;
    margin:0;
  }
  
  .timeline-step {
    flex-direction: row;
    margin: 0px !important;
    width: 100%;
    text-align: left;
  }
  
  .step-indicator {
    margin-right: 15px;
    margin-bottom: 0;
  }
  
  .connecting-line {
    width: 4px;
    height: 25px !important;
    margin-left: 12px;
  }

  .step-content h4 {
    font-size: 14px;
    margin: 0 !important;
  }

  .step-content:hover p {
    position: static;
    display: block;
    width: auto;
    border: none;
    padding: 2px 0;
    box-shadow: none;
    transform: none;
    font-size: 11px;
  }

  .timeline-wrapper{
    flex-direction: column;
    height: 404px;
    align-items: baseline;
  }
}

.timeline-track {
  position: relative;
  padding: 20px 0;
}

.timeline-wrapper {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
      width: 100%;
}

.timeline-step {
  display: flex;
  align-items: center;
  margin: 10px 0;
}

.step-indicator {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background-color: #cccccc;
  margin-right: 15px;
  z-index: 2;
}
/* 
.step-indicator.active {
  background-color: #f4f0f0;
} */

.connecting-line {
  flex-grow: 1;
  height: 0;
  border-top: 2px dashed #cccccc;
  margin: 0 5px;
}

.connecting-line.active {
  border-top: 2px dashed #a68380; /* Dashed blue when active */
}

.step-content h4 {
  margin: 0 0 5px 0;
}

.step-content p {
  margin: 0;
  color: #666;
}

.completion-info {
  margin-top: 20px;
  font-style: italic;
}
</style>

{% assign delivery_days = order.metafields.custom.delivery_program | default: 14 %}
<script>
document.addEventListener('DOMContentLoaded', function() {
  const timelineContainers = document.querySelectorAll('[id^="shipment-timeline-"]');
  const deliveryDays = {{ delivery_days | json }};

  // Step labels only
  const deliverySteps = {
    7: ['Order Confirmation', 'Processing', 'Manufacturing', 'Quality Control', 'Certification'],
    14: ['Order Confirmation', 'Processing', 'Manufacturing', 'Quality Control', 'Certification'],
    21: ['Order Confirmation', 'Processing', 'Manufacturing', 'Quality Control', 'Certification']
  };

  const stepDurations = {
    7: [0, 1, 3, 2, 1],
    14: [0, 1, 6, 3, 4],
    21: [0, 1, 10, 7, 3]
  };

  const stepNames = deliverySteps[deliveryDays] || deliverySteps[14];
  const stepDays = stepDurations[deliveryDays] || stepDurations[14];

  timelineContainers.forEach(function(timelineContainer) {
    const orderId = timelineContainer.getAttribute('data-order-id');
    if (!orderId) return;

    initializeTimeline(timelineContainer, orderId);
  });

  function initializeTimeline(container, orderId) {
    const savedData = localStorage.getItem(`shipment_timeline_${orderId}`);
    let timelineData;

    if (savedData) {
      timelineData = JSON.parse(savedData);
    } else {
      timelineData = {
        currentStep: 0,
        startDate: new Date().toISOString(),
        lastUpdated: new Date().toISOString()
      };
      localStorage.setItem(`shipment_timeline_${orderId}`, JSON.stringify(timelineData));
    }

    const now = new Date();
    const startDate = new Date(timelineData.startDate);
    const daysSinceStart = Math.floor((now - startDate) / (1000 * 60 * 60 * 24));

    // Calculate current step
    let accumulatedDays = 0;
    let calculatedStep = 0;

    for (let i = 0; i < stepDays.length; i++) {
      accumulatedDays += stepDays[i];
      if (daysSinceStart >= accumulatedDays) {
        calculatedStep = i;
      } else {
        break;
      }
    }

    if (calculatedStep > timelineData.currentStep) {
      timelineData.currentStep = calculatedStep;
      timelineData.lastUpdated = now.toISOString();
      localStorage.setItem(`shipment_timeline_${orderId}`, JSON.stringify(timelineData));

      const statusElement = document.querySelector('.order-status');
      if (statusElement) {
        statusElement.textContent = stepNames[calculatedStep];
      }
    }

    renderTimeline(container, stepNames, timelineData, calculatedStep);
  }

  function renderTimeline(container, stepNames, timelineData, calculatedStep) {
    container.innerHTML = '';

    const header = document.createElement('div');
    header.className = 'timeline-header';
    header.textContent = 'Order Progress';
    container.appendChild(header);

    const track = document.createElement('div');
    track.className = 'timeline-track';
    container.appendChild(track);

    const timelineWrapper = document.createElement('div');
    timelineWrapper.className = 'timeline-wrapper';
    track.appendChild(timelineWrapper);

    stepNames.forEach((stepName, index) => {
      if (index > 0) {
        const lineSegment = document.createElement('div');
        lineSegment.className = `connecting-line ${index - 1 < timelineData.currentStep ? 'active' : ''}`;
        timelineWrapper.appendChild(lineSegment);
      }

      const stepElement = document.createElement('div');
      stepElement.className = 'timeline-step';

      const stepIndicator = document.createElement('div');
      stepIndicator.className = `step-indicator ${index <= timelineData.currentStep ? 'active' : ''}`;
      stepElement.appendChild(stepIndicator);

      const stepContent = document.createElement('div');
      stepContent.className = 'step-content';

      const stepTitle = document.createElement('h4');
      stepTitle.textContent = stepName;
      stepContent.appendChild(stepTitle);

      stepElement.appendChild(stepContent);
      timelineWrapper.appendChild(stepElement);
    });

    const startDate = new Date(timelineData.startDate);
    const totalDays = stepDays.reduce((sum, day) => sum + day, 0);
    const estimatedCompletion = new Date(startDate);
    estimatedCompletion.setDate(startDate.getDate() + totalDays);

    const completionInfo = document.createElement('div');
    completionInfo.className = 'completion-info';
    
    // Check if all steps are completed
    const allStepsCompleted = timelineData.currentStep >= stepNames.length - 1;
    
    if (allStepsCompleted) {
      // All steps completed - show tracking link
      const trackLink = document.createElement('a');
      trackLink.href = 'https://lucirajewelry.clickpost.in/en';
      trackLink.textContent = 'Track product';
      completionInfo.appendChild(trackLink);
    } else {
      // Not all steps completed - show estimated completion date
      completionInfo.innerHTML = `<p>Estimated completion: ${estimatedCompletion.toLocaleDateString()}</p>`;
    }
    
    container.appendChild(completionInfo);
  }
});

</script>