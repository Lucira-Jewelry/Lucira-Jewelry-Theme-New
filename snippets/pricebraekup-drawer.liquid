<style>
  #lucira-drawer-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 999999 !important;
    display: none;
    align-items: flex-end;
    justify-content: flex-end;
  }
  #lucira-drawer {
   width: 40rem;
    max-width: calc(100vw - 3rem);
    height: 100%;
    background: #fff;
    box-shadow: -12px 0 40px rgba(0,0,0,0.35);
    transform: translateX(100%);
    transition: transform .28s ease;
    display: flex;
    flex-direction: column;
    z-index: 999999 !important;
    position: relative;
  }
  #lucira-drawer.open { transform: translateX(0); }
  
  body.drawer-open {
    overflow: hidden;
  }

  .lucira-drawer__header {
    padding: 18px;
    display:flex;
    align-items:center;
    justify-content: space-between;
    border-bottom: 1px solid #eee;
  }

  .lucira-drawer__body {
    padding: 18px;
    overflow-y: auto;
    flex: 1 1 auto;
  }

  .lucira-variant {
    display:flex;
    gap:12px;
    flex-direction:column;
    align-items:center;
    margin-bottom:14px;
  }
  .lucira-variant img {
    width:100%;
    height: 325px;
    object-position: top;
  }
  .lucira-variant-info .title {
    font-size:15px;
    font-weight:700;
  }
  .lucira-variant-info .sub {
    font-size:12px;
    color:#666;
  }

  .lucira-row {
    display:flex;
    justify-content:space-between;
    padding:10px 0;
    border-bottom:1px dashed #e6e6e6;
  }
  .lucira-row h3 {
    margin:0;
    font-size:14px;
  }
  .lucira-row .value {
    font-size:14px;
  }

  .lucira-drawer__foot {
    padding:14px;
    border-top:1px solid #eee;
    display:flex;
    gap:12px;
  }
#lucira-total-price {
  font-size: 18px!important;
}

  .lucira-btn {
  padding: 20px;
    border: 1px solid #A68380;
    border-radius: 12px;
    cursor: pointer;
    color: #A68380;
    font-size: 16px;
    font-family: "Futura Std", sans-serif !important;
    width: 100%;
    background: none;
  }

  .order_summ{
  font-size:24px;
  }
  .lucira-secondary {
    flex:1;
    border:1px solid #ddd;
    padding:12px 16px;
    background:#fff;
    border-radius:6px;
    cursor:pointer;
  }
  .total_price{
    /* font-weight:600; */
    font-size: 18px !important;;
  }


  @media (max-width:768px) {
      .lucira-variant img {
    object-fit: cover !important;

      }
    #lucira-drawer { width:90%; }
    .order_summ{
    font-size:20px;
    }
    .lucira-row .value {
    font-size:14px;
  }
  .lucira-row {
    padding: 20px 0;
  }
  #lucira-drawer-close{
    transform: none;
    padding: 0;
  }
  }
  
</style>
<script src="{{ 'pricebraekup-drawer.js' | asset_url }}" defer="defer"></script>

<!-- Drawer Markup -->
<div id="lucira-drawer-backdrop" aria-hidden="true">
  <aside id="lucira-drawer">
    
    <div class="lucira-drawer__header">
      <div class="order_summ">Order Summary</div>
      <button id="lucira-drawer-close" style="background:none;border:none;font-size:18px;cursor:pointer">✕</button>
    </div>

    <div class="lucira-drawer__body">

      <!-- Variant section -->
      <div class="lucira-variant">
        <img id="lucira-variant-img" src="" alt="" width="auto" height=" auto" loading="lazy">
        <div class="lucira-variant-info">
          <div class="var_title" id="lucira-variant-title">Product</div>
        </div>
      </div>

      <!-- Metal Weight -->
      <div class="lucira-row">
        <h3>Metal weight (g)</h3>
        <div class="value" id="lucira-metal-value"></div>
      </div>

      <!-- Diamond Weight -->
      <div class="lucira-row">
        <h3>Diamond weight (g)</h3>
        <div class="value" id="lucira-diamond-value"></div>
      </div>

      <!-- Product Price -->
      <div class="lucira-row">
        <h3>Type Of Product :</h3>
        <div class="value" id="lucira-base-price">-</div>
      </div>

      <!-- Charms Price -->
      <div class="lucira-row">
        <h3>Charms type :</h3>
        <div class="value" id="lucira-charms-price">-</div>
      </div>

      <!-- TOTAL PRICE (NEW) -->
      <div class="lucira-row">
        <h3 class="total_price">Total price</h3>
        <div class="value" id="lucira-total-price">-</div>
      </div>

    </div>

    <div class="lucira-drawer__foot">
      <button class="lucira-btn" onclick=sendToCart(); id="lucira-add-to-cart" >ADD TO CART</button>
    </div>

  </aside>
</div>



