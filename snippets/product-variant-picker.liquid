{% assign variant_parts = product.selected_or_first_available_variant.title |
  split: '/' %}
<div class="size-and-customization-section"  id="variant-selects-{{ section.id }}" data-section="{{ section.id }}">
  {%- unless product.has_only_default_variant -%}
    <variant-selects
      id="variant-selects-{{ section.id }}"
      data-section="{{ section.id }}"
      {{ block.shopify_attributes }}
    >
      <div class="size-and-customization-title-wrapper">
        <div class="size_customization_title">
          <h4 class="customization_title">
            SIZE & CUSTOMIZATION
          </h4>
        </div>

        {% assign show_size_guide = false %}

        {% for c in product.collections %}
          {% if c.handle == 'all-rings' %}
            {% assign show_size_guide = true %}
            {% break %}
          {% endif %}
        {% endfor %}

        {% if show_size_guide %}
          <span
            id="size_drawer"
            class="size-guide-button"
            onclick="
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'promoClick',
                promoClick: {
                  promo_id: '{{ product.selected_or_first_available_variant.sku }}',
                  promo_name: '{{ product.title }}',
                  creative_name: 'Size Guide Clicked'
                }
              });
            "
          >
            Size Guide
          </span>
        {% endif %}

      </div>
      <div class="size-and-customization-wrapper" id="product_variant_drawer">
        <div class="customization-wrapper">
            <div class="customization-item">
              {% assign metal = variant_parts[0] | downcase %}
              <div id="customization-metal-color-circle" style="display: inline-block; vertical-align: middle;">
                {% if metal contains 'yellow' %}
                  {{- 'yellow-color.svg' | inline_asset_content -}}
                {% elsif metal contains 'rose' %}
                  {{- 'rose-color.svg' | inline_asset_content -}}
                {% else %}
                  {{- 'silver-color.svg' | inline_asset_content -}}
                {% endif %}
              </div>
    
              {% assign image_url = '' %} 
              
              {% assign bg_color = '' %}
    
              {% if variant_parts contains 'Yellow Gold' %}
                {% assign bg_color = '' %}
                {{- 'yellow-color.svg' | inline_asset_content -}}
              {% elsif variant_parts contains 'Rose Gold' %}
                {% assign bg_color = '' %}
                {{- 'rose-color.svg' | inline_asset_content -}}
              {% elsif variant_parts contains 'White Gold' %}
                {% assign bg_color = '#f8f8f8' %}
                {{- 'silver-color.svg' | inline_asset_content -}}
              {% endif %}
    
              <div class="customization-item-div" id="customization-metal-color">
                {{ variant_parts[0] }}
              </div>
              <!-- <div class="label">14K Metal</div> -->
            </div>
            {% if variant_parts[1] %}
            <div class="customization-item">
              <div class="label">Size :</div>
              <div class="customization-item-div size-customization-item">
                <span id="customization-size">{{ variant_parts[1] }}</span> {% unless product.tags contains 'Bracelets' %}IND{% endunless %}
              </div>
            </div>
            {% endif %}
          </div>
          <span class="customize-button" id="product_variant_drawer"z>CUSTOMIZE</span>
      </div>
    </variant-selects>
  {%- endunless -%}
</div>



{% comment %} <script>
document.addEventListener('DOMContentLoaded', function () {
  window.dataLayer = window.dataLayer || [];

  const drawer = document.getElementById('variant-drawer');
  if (!drawer) return;

  const variants = {{ product.variants | json }};
  let lastFiredVariantId = null;

  const idInput = document.querySelector('form[action*="/cart/add"] input[name="id"]');
  if (!idInput) return;

  const observer = new MutationObserver(function() {
    const variantId = Number(idInput.value);
    const variant = variants.find(v => v.id === variantId);
    
    if (!variant || variant.id === lastFiredVariantId) return;
    
    lastFiredVariantId = variant.id;

    window.dataLayer.push({
      event: "pdp_customize",
      pageType: {
        shopify_product_id: {{ product.id }},
        shopify_variant_id: variant.id,
        shopify_sku: variant.sku
      }
    });
  });

  observer.observe(idInput, { 
    attributes: true, 
    attributeFilter: ['value'] 
  });
});
</script> {% endcomment %}

<script>
document.addEventListener('DOMContentLoaded', function () {
  window.dataLayer = window.dataLayer || [];

  const drawer = document.getElementById('variant-drawer');
  if (!drawer) return;

  const variants = {{ product.variants | json }};
  let lastFiredVariantId = null;

  const idInput = document.querySelector('form[action*="/cart/add"] input[name="id"]');
  if (!idInput) return;

  function pushProductView(variant) {
    window.dataLayer.push({
      event: 'productView',
      products: {
        productId: {{ product.id | json }},
        sku: variant.sku,
        variantId: variant.id,
        vendorCode: {{ product.vendor | json }},
        productName: {{ product.title | json }},
        productType: {{ product.type | json }},
        category: {{ product.metafields.custom.category.value | json }},
        subCategory: {{ product.metafields.custom.sub_category_1.value | json }},
        productUrl: {{ shop.url | append: product.url | json }},
        productUrlw: {{ product.url | json }},
        thumbnailImage: {{ product.featured_image | image_url: width: 800 | prepend: 'https:' | json }},
        image: {{ product.featured_image | image_url: width: 800 | prepend: 'https:' | json }},
        price: variant.price / 100,
        offerPrice: variant.compare_at_price ? variant.compare_at_price / 100 : null,
        productPersona: {{ product.metafields.custom.persona.value | json }}
      }
    });
  }

  const observer = new MutationObserver(function() {
    const variantId = Number(idInput.value);
    const variant = variants.find(v => v.id === variantId);
    
    if (!variant || variant.id === lastFiredVariantId) return;
    
    lastFiredVariantId = variant.id;

    pushProductView(variant);
  });

  observer.observe(idInput, { 
    attributes: true, 
    attributeFilter: ['value'] 
  });
});
</script>