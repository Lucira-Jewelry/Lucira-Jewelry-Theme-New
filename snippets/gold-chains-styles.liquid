{% assign apply_custom_styles = false %}

{% for tag in product.tags %}
  {% if tag == 'Gold Jewelry' %}
    {% assign apply_custom_styles = true %}
  {% endif %}
{% endfor %}

{% if apply_custom_styles %}
  <style>
    section.pdp-price-breakup-tabs .contained-switcher {
      --bubble-position: 0;
      position: relative;
      display: flex;
      align-items: center;
      padding: 4px;
      width: 100%;
      background:white;
      border-radius: 3rem;
      transition: background-color 0.45s ease-out, box-shadow 0.45s ease-out;
    }

    section.pdp-price-breakup-tabs .active > .switch-item {
      color: #1a1a1a;
      text-transform: uppercase;
    }

    section.pdp-price-breakup-tabs .contained-switcher::before {
      content: "";
      position: absolute;
      top: 4px;
      height: calc(100% - 8px);
      width: calc(100% - 8px);
      max-width: calc((100% - 8px) / 2);
      border-radius: 3rem;
      transform: translateX(var(--bubble-position));
      transition: transform 0.45s ease-out;
      z-index: 1;
      background: white;
    }

    section.pdp-price-breakup-tabs .contained-switch {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      padding: 0;
      width: 100%;
      position: relative;
      z-index: 2;
      text-align: center;
      -webkit-tap-highlight-color: transparent !important;
      outline: none !important;
    }
  </style>
{% endif %}