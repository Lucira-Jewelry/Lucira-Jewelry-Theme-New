{% assign show_banner = true %}

{% if section.settings.exclude_from_collections %}
  {% for collection_item in section.settings.excluded_collections %}
    {% if collection_item.handle == collection.handle %}
      {% assign show_banner = false %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if show_banner %}
{{ 'plp-banner.css' | asset_url | stylesheet_tag: preload: true }}

{% assign drawer_content = collection.metafields.custom.plp_banner_content %}
{% assign drawer_image = collection.metafields.custom.plp_drawer_image %}

<section class="curved-slider-section">
  <div class="curve-bg page-width">
    <div class="plp-collection-banner__content">

      {% if section.settings.show_breadcrumbs %}
        <nav class="plp-collection-banner__breadcrumbs"
             itemscope itemtype="https://schema.org/BreadcrumbList">

          <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href="{{ shop.url }}" itemprop="item">
              <span itemprop="name">Home</span>
            </a>
            <meta itemprop="position" content="1" />
          </span>

          <span class="separator">/</span>

          <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href="{{ routes.collections_url }}" itemprop="item">
              <span itemprop="name">Collections</span>
            </a>
            <meta itemprop="position" content="2" />
          </span>

          <span class="separator">/</span>

          <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <span itemprop="name" class="current">
              {{ collection.title | default: 'All Products' }}
            </span>
            <meta itemprop="item" content="{{ shop.url }}{{ collection.url }}" />
            <meta itemprop="position" content="3" />
          </span>
        </nav>
      {% endif %}

      <div class="plp-collection-banner__header">

        <h1 class="plp-collection-banner__title">
          {{ collection.title | default: 'All Products' }}

          {% if drawer_content != blank and drawer_image != blank %}
            <a href="javascript:void(0)"
               class="plp-banner__cta-button open-drawer-btn">
              <img
                src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Info.svg?v=1751958261"
                width="14"
                height="14"
                alt="info"
                loading="lazy">
            </a>
          {% endif %}
        </h1>

        {% if section.settings.show_product_count %}
          <p class="plp-collection-banner__count">
            <small>{{ collection.all_products_count }} designs</small>
          </p>
        {% endif %}
      </div>

      <!-- ✅ SORT (AJAX / NO REFRESH) -->
      <div class="plp-collection-banner__right">
        <label for="SortByBanner" class="visually-hidden">
          {{ 'products.facets.sort_by_label' | t }}
        </label>

        {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
        <select
          id="SortByBanner"
          class="plp-sort-select"
          name="sort_by"
          aria-describedby="a11y-refresh-page-message"
        >
          {% for option in collection.sort_options %}
            <option
              value="{{ option.value }}"
              {% if option.value == sort_by %}selected{% endif %}
            >
              {{ option.name }}
            </option>
          {% endfor %}
        </select>
      </div>

    </div>
  </div>
</section>
{% endif %}

<!-- ================= DRAWER ================= -->

<div id="plp-drawer-wrapper" class="drawer-wrapper hidden">
  <div class="drawer-overlay"></div>

  <div class="collection-drawer">
    <div class="drawer-image-wrapper">
      <img
        src="{{ drawer_image | img_url: 'master' }}"
        alt="Collection banner"
        loading="lazy"
      >
      <button class="drawer-close">✕</button>
    </div>

    <div class="drawer-body">
      <p class="drawer-title">{{ collection.title }}</p>
      <div class="drawer-description">
        {{ drawer_content }}
      </div>
    </div>

    <div class="shopping_button">
      <a href="#" class="continue-button">Continue Shopping</a>
    </div>
  </div>
</div>

<!-- ================= JS ================= -->

<script>
document.addEventListener('DOMContentLoaded', () => {

  /* ---------- Drawer ---------- */
  const wrapper = document.getElementById('plp-drawer-wrapper');

  document.querySelectorAll('.open-drawer-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      wrapper.classList.remove('hidden');
      document.body.classList.add('drawer-open');
    });
  });

  wrapper?.querySelector('.drawer-overlay')?.addEventListener('click', closeDrawer);
  wrapper?.querySelector('.drawer-close')?.addEventListener('click', closeDrawer);
  wrapper?.querySelector('.continue-button')?.addEventListener('click', e => {
    e.preventDefault();
    closeDrawer();
  });

  function closeDrawer() {
    wrapper.classList.add('hidden');
    document.body.classList.remove('drawer-open');
  }

  /* ---------- AJAX SORT (FacetFiltersForm) ---------- */
  const bannerSort = document.getElementById('SortByBanner');
  const facetsForm = document.querySelector('#FacetFiltersForm');

  if (!bannerSort || !facetsForm) return;

  bannerSort.addEventListener('change', () => {
    const facetsSort = facetsForm.querySelector('select[name="sort_by"]');

    if (facetsSort) {
      facetsSort.value = bannerSort.value;
      facetsSort.dispatchEvent(new Event('change', { bubbles: true }));
      return;
    }

    // Fallback
    const input = document.createElement('input');
    input.type = 'hidden';
    input.name = 'sort_by';
    input.value = bannerSort.value;
    facetsForm.appendChild(input);
    facetsForm.dispatchEvent(new Event('submit', { bubbles: true }));
  });
});
</script>

