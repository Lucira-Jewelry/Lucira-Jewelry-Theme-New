          }}
        {%- endif -%}
      </span>
    </h2>
    {%- render 'loading-spinner' -%}
  </div>
  {%- if filter_type == 'drawer' -%}
    <facet-filters-form class="facets facets-pill small-hide">
      <form id="FacetFiltersPillsForm" class="facets__form">
        <div class="active-facets active-facets-desktop">
          {%- for filter in results.filters -%}
            {%- for value in filter.active_values -%}
              <facet-remove>
                <a href="{{ value.url_to_remove }}" class="active-facets__button active-facets__button--light">
                  <span class="active-facets__button-inner button button--tertiary">
                    {{ filter.label | escape }}: {{ value.label | escape }}
                    <span class="svg-wrapper">
                      {{- 'icon-close-small.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'products.facets.clear_filter' | t }}</span>
                  </span>
                </a>
              </facet-remove>
            {%- endfor -%}

            {%- if filter.type == 'price_range' -%}
              {% assign min = filter.min_value.value %}
              {% assign max = filter.max_value.value %}
              {%- if min != null or max != null -%}
                <facet-remove>
                  <a href="{{ filter.url_to_remove }}" class="active-facets__button active-facets__button--light">
                    <span class="active-facets__button-inner button button--tertiary">
                      {{ min | default: 0 | money }} - {{ max | default: filter.range_max | money }}
                      <span class="svg-wrapper">
                        {{- 'icon-close-small.svg' | inline_asset_content -}}
                      </span>
                      <span class="visually-hidden">{{ 'products.facets.clear_filter' | t }}</span>
                    </span>
                  </a>
                </facet-remove>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
          <facet-remove class="active-facets__button-wrapper">
            <a href="{{ results_url }}" class="active-facets__button-remove underlined-link">
              <span>{{ 'products.facets.clear_all' | t }}</span>
            </a>
          </facet-remove>
        </div>
      </form>
    </facet-filters-form>
  {%- endif -%}
</div>

<script>
  // Function to open mobile filters (uses existing Shopify drawer)
  function openMobileFilters() {
    // Store current scroll position
    const scrollY = window.scrollY || window.pageYOffset;

    const filterButton = document.querySelector('.mobile-facets__open');
    if (filterButton) {
      filterButton.click();

      // Restore scroll position after a brief delay
      setTimeout(() => {
        window.scrollTo(0, scrollY);
      }, 0);

      // Also restore after any transitions
      setTimeout(() => {
        window.scrollTo(0, scrollY);
      }, 100);
    }
  }

  // Function to open sort drawer (side panel)
  function openSortDrawer() {
    const sortDrawer = document.getElementById('mobileSortDrawer');
    const overlay = document.querySelector('.mobile-sort-overlay');
    if (sortDrawer) {
      sortDrawer.classList.add('active');
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }

  // Function to close sort drawer
  function closeSortDrawer() {
    const sortDrawer = document.getElementById('mobileSortDrawer');
    const overlay = document.querySelector('.mobile-sort-overlay');
    if (sortDrawer) {
      sortDrawer.classList.remove('active');
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    }
  }

  // Function to select sort option - integrated with FacetFiltersForm
  function selectSortOption(value, name) {
    // Find all sort forms
    const sortForms = [
      document.querySelector('#FacetSortDrawerForm'),
      document.querySelector('#FacetFiltersForm'),
      document.querySelector('#FacetFiltersFormMobile'),
    ].filter((form) => form);

    // Update all sort selects
    sortForms.forEach((form) => {
      const sortSelect = form.querySelector('select[name="sort_by"]');
      if (sortSelect) {
        sortSelect.value = value;

        // Create and dispatch change event
        const event = new Event('change', { bubbles: true });
        sortSelect.dispatchEvent(event);
      }
    });

    // Submit the main form to apply sorting
    const mainForm =
      document.querySelector('#FacetFiltersForm') ||
      document.querySelector('#FacetFiltersFormMobile') ||
      document.querySelector('#FacetSortDrawerForm');

    if (mainForm) {
      // Create a submit event
      const submitEvent = new Event('submit', { bubbles: true, cancelable: true });
      mainForm.dispatchEvent(submitEvent);

      // Also trigger the input event for FacetFiltersForm
      const inputEvent = new Event('input', { bubbles: true });
      mainForm.dispatchEvent(inputEvent);
    }

    closeSortDrawer();
  }

  // Prevent scroll on filter drawer open
  function preventFilterScrollBehavior() {
    let savedScrollPosition = null;
    let isOpening = false;
    let currentScrollPosition = null;

    const filterButton = document.querySelector('.mobile-facets__open');
    if (filterButton) {
      filterButton.addEventListener('click', function (e) {
        savedScrollPosition = window.scrollY || window.pageYOffset;
        isOpening = true;

        // Prevent default scroll behavior on open
        setTimeout(() => {
          if (isOpening && savedScrollPosition !== null) {
            window.scrollTo(0, savedScrollPosition);
          }
        }, 0);

        setTimeout(() => {
          if (isOpening && savedScrollPosition !== null) {
            window.scrollTo(0, savedScrollPosition);
          }
        }, 100);
      });
    }

    // Handle close button clicks - prevent scroll
    const handleCloseButton = function () {
      const closeButtons = document.querySelectorAll(
        '.mobile-facets__close, .mobile-facets__close-button, [data-close-drawer], .drawer__close'
      );

      closeButtons.forEach((btn) => {
        if (!btn.hasAttribute('data-scroll-handled')) {
          btn.setAttribute('data-scroll-handled', 'true');

          btn.addEventListener('click', function (e) {
            // Save current scroll position before closing
            currentScrollPosition = window.scrollY || window.pageYOffset;

            // Prevent scroll after close
            setTimeout(() => {
              if (currentScrollPosition !== null) {
                window.scrollTo(0, currentScrollPosition);
              }
            }, 0);

            setTimeout(() => {
              if (currentScrollPosition !== null) {
                window.scrollTo(0, currentScrollPosition);
              }
            }, 50);

            setTimeout(() => {
              if (currentScrollPosition !== null) {
                window.scrollTo(0, currentScrollPosition);
                currentScrollPosition = null;
              }
            }, 150);
          });
        }
      });
    };

    // Initial call
    handleCloseButton();

    // Watch for dynamically added close buttons
    const observer = new MutationObserver(function () {
      handleCloseButton();
    });

    const bodyObserver = document.querySelector('body');
    if (bodyObserver) {
      observer.observe(bodyObserver, { childList: true, subtree: true });
    }

    // Also prevent scroll on drawer wrapper if it exists
    const drawerWrapper = document.querySelector('.mobile-facets__wrapper');
    if (drawerWrapper) {
      const drawerObserver = new MutationObserver(function (mutations) {
        mutations.forEach(function (mutation) {
          if (mutation.attributeName === 'class') {
            const isNowOpen = drawerWrapper.classList.contains('is-open');

            if (isNowOpen && isOpening && savedScrollPosition !== null) {
              // Only restore scroll when opening
              window.scrollTo(0, savedScrollPosition);
            } else if (!isNowOpen) {
              // Reset flags when closed
              isOpening = false;
              savedScrollPosition = null;
            }
          }
        });
      });

      drawerObserver.observe(drawerWrapper, { attributes: true });
    }
  }

  // Close sort drawer when clicking outside
  document.addEventListener('click', function (event) {
    const sortDrawer = document.getElementById('mobileSortDrawer');
    const overlay = document.querySelector('.mobile-sort-overlay');
    if (
      sortDrawer &&
      sortDrawer.classList.contains('active') &&
      !sortDrawer.contains(event.target) &&
      !event.target.closest('.mobile-sticky-bar__item--sort')
    ) {
      closeSortDrawer();
    }
  });

  // Close sort drawer with escape key
  document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape') {
      closeSortDrawer();
    }
  });

  // Initialize when DOM is loaded
  document.addEventListener('DOMContentLoaded', function () {
    // Initialize scroll prevention
    preventFilterScrollBehavior();

    // Ensure filter count updates
    const updateFilterCount = function () {
      const filterCount = document.querySelector('.mobile-sticky-bar__count');
      if (filterCount) {
        // Count active facets
        const activeFacets = document.querySelectorAll('.active-facets__button').length;

        // Also count price range filters if active
        let priceRangeCount = 0;
        const priceInputs = document.querySelectorAll('input[data-min], input[data-max]');
        priceInputs.forEach((input) => {
          if (input.value && input.value !== '0') {
            priceRangeCount = 1; // Only count once for price range
          }
        });

        const total = activeFacets + priceRangeCount;

        if (total > 0) {
          filterCount.textContent = total;
          filterCount.style.display = 'inline-flex';
        } else {
          filterCount.style.display = 'none';
        }
      }
    };

    // Update filter count on initial load
    updateFilterCount();

    // Update filter count when filters change
    const observer = new MutationObserver(function (mutations) {
      mutations.forEach(function (mutation) {
        if (mutation.type === 'childList' || mutation.type === 'attributes') {
          updateFilterCount();
        }
      });
    });

    // Observe active facets containers
    const activeFacetsContainers = [
      document.querySelector('.active-facets-mobile'),
      document.querySelector('.active-facets-desktop'),
    ].filter((container) => container);

    activeFacetsContainers.forEach((container) => {
      observer.observe(container, {
        childList: true,
        subtree: true,
        attributes: true,
        attributeFilter: ['value', 'data-min', 'data-max'],
      });
    });

    // Also observe price range inputs
    const priceInputs = document.querySelectorAll('input[type="range"], input[data-min], input[data-max]');
    priceInputs.forEach((input) => {
      observer.observe(input, { attributes: true, attributeFilter: ['value'] });
    });
  });
</script>


<script>
  // GTM DataLayer Tracking for Filter and Sort By clicks
(function() {
  'use strict';

  // Helper function to get collection URL
  function getCollectionUrl() {
    // Get current URL path
    const pathname = window.location.pathname;
    
    // Return full collection URL
    return window.location.origin + pathname;
  }

  // Helper function to get collection ID
  function getCollectionId() {
    // Try to get from meta tag
    const metaCollection = document.querySelector('meta[property="og:url"]');
    if (metaCollection) {
      const url = metaCollection.content;
      const match = url.match(/collections\/([^\/\?]+)/);
      if (match) return match[1];
    }
    
    // Try to get from URL
    const pathname = window.location.pathname;
    const match = pathname.match(/collections\/([^\/\?]+)/);
    if (match) return match[1];
    
    // Try to get from Shopify object if available
    if (typeof Shopify !== 'undefined' && Shopify.collection && Shopify.collection.id) {
      return Shopify.collection.id.toString();
    }
    
    // Fallback: try to get from body data attributes
    const body = document.querySelector('body');
    if (body && body.dataset.collectionId) {
      return body.dataset.collectionId;
    }
    
    return 'unknown';
  }

  // Helper function to push to dataLayer
  function pushPromoClick(creativeName, locationId) {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: "promoClick",
      promoClick: {
        creative_name: creativeName,
        location_id: locationId,
        promo_name: getCollectionUrl(),
        promo_id: getCollectionId()
      }
    });
  }

  // Initialize tracking after DOM is ready
  function initializeTracking() {
    
    // ============================================
    // MOBILE STICKY BAR TRACKING
    // ============================================
    
    // Track mobile sticky bar FILTER button click
    const stickyFilterBtn = document.querySelector('.mobile-sticky-bar__item--filter');
    if (stickyFilterBtn) {
      stickyFilterBtn.addEventListener('click', function() {
        pushPromoClick('Filter', 'mobile-plp');
      });
    }

    // Track mobile sticky bar SORT BY button click
    const stickySortBtn = document.querySelector('.mobile-sticky-bar__item--sort');
    if (stickySortBtn) {
      stickySortBtn.addEventListener('click', function() {
        pushPromoClick('Sort By', 'mobile-plp');
      });
    }

    // ============================================
    // DESKTOP FILTER BUTTON TRACKING
    // ============================================
    
    // Track desktop filter button clicks (if you have any filter open buttons on desktop)
    const desktopFilterButtons = document.querySelectorAll('.facets__disclosure summary, .mobile-facets__open');
    desktopFilterButtons.forEach(btn => {
      // Only track non-mobile buttons for desktop
      if (!btn.closest('.mobile-facets__wrapper')) {
        btn.addEventListener('click', function() {
          pushPromoClick('Filter', 'desktop-plp');
        });
      }
    });

    // ============================================
    // MOBILE DRAWER FILTER BUTTON TRACKING
    // ============================================
    
    // Track mobile drawer filter button click
    const mobileFilterOpen = document.querySelector('.mobile-facets__open');
    if (mobileFilterOpen) {
      mobileFilterOpen.addEventListener('click', function() {
        pushPromoClick('Filter', 'mobile-plp');
      });
    }

    // ============================================
    // DESKTOP SORT DROPDOWN CLICK
    // ============================================
    
    // Track desktop sort dropdown click (when user opens it)
    const desktopSortSelect = document.querySelector('#SortBy');
    if (desktopSortSelect) {
      desktopSortSelect.addEventListener('click', function() {
        pushPromoClick('Sort By', 'desktop-plp');
      }, { once: false });
    }

    // Track sort select in drawer form
    const drawerSortSelect = document.querySelector('#FacetSortDrawerForm #SortBy');
    if (drawerSortSelect) {
      drawerSortSelect.addEventListener('click', function() {
        pushPromoClick('Sort By', 'desktop-plp');
      }, { once: false });
    }

    // ============================================
    // MOBILE SORT SELECT CLICK
    // ============================================
    
    // Track mobile sort select click
    const mobileSortSelect = document.querySelector('#SortBy-mobile');
    if (mobileSortSelect) {
      mobileSortSelect.addEventListener('click', function() {
        pushPromoClick('Sort By', 'mobile-plp');
      }, { once: false });
    }
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeTracking);
  } else {
    initializeTracking();
  }

})();
</script>