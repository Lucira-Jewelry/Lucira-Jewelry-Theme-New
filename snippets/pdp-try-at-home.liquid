              </div>
              
                href="https://wa.me/919004435760?text=Hi,%20I'd%20like%20to%20know%20more%20about%20visiting%20Lucira's%20store."
                target="_blank"
                rel="noopener"
                class="visit-store-home-button">
                Book Appointment
              </a>
