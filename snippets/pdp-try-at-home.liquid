      .try-at-home-content .svg-icon svg {width: 24px; height: 19px;}
      .try-at-home-atc-button { text-transform: uppercase; font-family: 'Futura Std', sans-serif; letter-spacing: 1px; border-radius: 8px; border: 1px solid #a68380; color: #a68380; background: #fff; width: 100%; padding: 14px 0; }
