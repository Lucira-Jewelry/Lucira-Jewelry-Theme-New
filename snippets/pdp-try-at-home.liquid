<script>
  (function () {
    var BOOK_APPT_URL =
      "https://wa.me/919004435760?text=Hi,%20I'd%20like%20to%20know%20more%20about%20visiting%20Lucira's%20store.";

    // Holds enriched locations (with lat/lng) from the last inventory event
    var _currentLocations = [];

    // ── Haversine distance in km (rounded to 1 decimal) ──────────────────────
    function haversine(lat1, lon1, lat2, lon2) {
      var R = 6371;
      var dLat = (lat2 - lat1) * Math.PI / 180;
      var dLon = (lon2 - lon1) * Math.PI / 180;
      var a =
        Math.sin(dLat / 2) * Math.sin(dLat / 2) +
        Math.cos(lat1 * Math.PI / 180) *
          Math.cos(lat2 * Math.PI / 180) *
          Math.sin(dLon / 2) *
          Math.sin(dLon / 2);
      return Math.round(2 * R * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a)) * 10) / 10;
    }

    // ── Pincode widget helpers ────────────────────────────────────────────────
    function showPincodeWidget() {
      var w = document.getElementById('lucira-pincode-widget');
      if (w) w.style.display = 'block';
    }

    function hidePincodeWidget() {
      var w = document.getElementById('lucira-pincode-widget');
      if (w) w.style.display = 'none';
      setPincodeStatus('', '');
      var input = document.getElementById('lucira-pincode-input');
      if (input) input.value = '';
    }

    function setPincodeStatus(msg, type) {
      var el = document.getElementById('lucira-pincode-status');
      if (!el) return;
      el.textContent = msg;
      el.className = type || '';
    }

    // ── Pincode submit handler ────────────────────────────────────────────────
    function handlePincodeCheck() {
      var input = document.getElementById('lucira-pincode-input');
      var btn   = document.getElementById('lucira-pincode-submit');
      if (!input) return;

      var pincode = input.value.trim();

      if (!/^\d{6}$/.test(pincode)) {
        setPincodeStatus('Please enter a valid 6-digit pincode.', 'error');
        return;
      }

      // If no store has coords, fall back to unsorted sheet
      var locsWithCoords = _currentLocations.filter(function (l) {
        return l.lat != null && l.lng != null;
      });
      if (!locsWithCoords.length) {
        if (window.luciraOpenStoreSheet) window.luciraOpenStoreSheet();
        return;
      }

      if (btn) btn.disabled = true;
      setPincodeStatus('Finding nearest store…', 'loading');

      // Nominatim free geocoding — no API key required
      // Note: Nominatim usage policy requires max 1 req/s and a valid User-Agent.
      // For production at higher traffic, consider a paid geocoding service.
      fetch(
        'https://nominatim.openstreetmap.org/search' +
          '?postalcode=' + encodeURIComponent(pincode) +
          '&countrycodes=IN' +
          '&format=json' +
          '&limit=1'
      )
        .then(function (res) {
          if (!res.ok) throw new Error('Network error');
          return res.json();
        })
        .then(function (data) {
          if (!data || data.length === 0) {
            setPincodeStatus('Pincode not found. Please try again.', 'error');
            if (btn) btn.disabled = false;
            return;
          }

          var userLat = parseFloat(data[0].lat);
          var userLng = parseFloat(data[0].lon);

          // Attach distance to every location
          var withDistances = _currentLocations.map(function (loc) {
            var dist =
              loc.lat != null && loc.lng != null
                ? haversine(userLat, userLng, loc.lat, loc.lng)
                : null;
            return Object.assign({}, loc, { distance_km: dist });
          });

          // Sort ascending by distance; push nulls to end
          withDistances.sort(function (a, b) {
            if (a.distance_km === null) return 1;
            if (b.distance_km === null) return -1;
            return a.distance_km - b.distance_km;
          });

          setPincodeStatus('', '');
          if (btn) btn.disabled = false;

          if (window.luciraOpenStoreSheet) {
            window.luciraOpenStoreSheet(withDistances);
          }
        })
        .catch(function () {
          setPincodeStatus('Could not fetch location. Please try again.', 'error');
          if (btn) btn.disabled = false;
        });
    }

    // ── Main state handler ────────────────────────────────────────────────────
    function applyInventoryState(inStock, displayNames, locations) {
      _currentLocations = locations || [];

      var title = document.getElementById('lucira-vs-title');
      var desc  = document.getElementById('lucira-vs-desc');
      var cta   = document.getElementById('lucira-vs-cta');
      var card  = document.getElementById('lucira-visit-store-card');
      if (!title || !desc || !cta) return;

      if (inStock) {
        var isSingleStore = displayNames && displayNames.length === 1;

        if (isSingleStore) {
          // ── Single store: name it directly ──
          title.textContent = 'Available In ' + displayNames[0];
          desc.textContent  = 'This design is available for trial at a store near you.';
          hidePincodeWidget();
        } else {
          // ── Multiple stores: show pincode finder ──
          title.textContent = 'Available In Nearby Stores';
          desc.textContent  = 'Enter your pincode to find the nearest store.';
          showPincodeWidget();
        }

        cta.textContent = 'Find All Stores';
        cta.href        = '#';
        cta.removeAttribute('target');
        cta.removeAttribute('rel');
        cta.id = 'open-store-sheet';
        if (card) card.style.borderColor = '';

      } else {
        // ── Out of stock / no nearby stores ──
        title.textContent = 'Visit Our Store';
        desc.textContent  = 'Visit store to explore and try your favourite designs live';
        cta.textContent   = 'Book Appointment';
        cta.href          = BOOK_APPT_URL;
        cta.setAttribute('target', '_blank');
        cta.setAttribute('rel', 'noopener');
        cta.id = 'lucira-vs-cta';
        if (card) card.style.borderColor = '';
        hidePincodeWidget();
      }
    }

    // ── Event listeners ───────────────────────────────────────────────────────
    document.addEventListener('lucira:inventory', function (e) {
      applyInventoryState(e.detail.inStock, e.detail.displayNames, e.detail.locations);
    });

    document.addEventListener('DOMContentLoaded', function () {
      // Wire pincode submit button
      var btn = document.getElementById('lucira-pincode-submit');
      if (btn) btn.addEventListener('click', handlePincodeCheck);

      // Allow Enter key inside input
      var inp = document.getElementById('lucira-pincode-input');
      if (inp) {
        inp.addEventListener('keydown', function (e) {
          if (e.key === 'Enter') handlePincodeCheck();
        });
        // Only allow numeric input
        inp.addEventListener('input', function () {
          this.value = this.value.replace(/\D/g, '');
        });
      }

      // Fallback: event may have fired before this script loaded
      if (window.__storeData) {
        var locs  = window.__storeData.in_stock_locations || [];
        var names = locs.map(function (s) {
          return s.display_name || s.location_name;
        });
        applyInventoryState(locs.length > 0, names, locs);
      }
    });
  })();
</script>