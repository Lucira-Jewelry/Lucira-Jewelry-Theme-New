      .try-at-home-content { width: 100%; border: 1px solid #ffffff; padding: 0; border-radius: 12px; position: relative; box-shadow: 0px 0px 12px 0px #00000014; display: flex; align-items: center; justify-content: flex-start; gap: 10px; }
      .try-at-home-section .svg-icon { position: relative; top: auto; left: auto; transform: none; background: #fff; border-radius: 50%; }
      .try-at-home-section .grid-row .grid-column button {margin: 0;}
