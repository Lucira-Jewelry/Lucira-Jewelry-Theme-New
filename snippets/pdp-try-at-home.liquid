  a.visit-store-home-button { font-weight: 500; line-height: 100%; letter-spacing: 1px; text-transform: uppercase; border: 0; padding: 10px 14px; color: #FFFFFF; border-radius: 8px; cursor: pointer; font-size: 12px; background: rgb(141, 123, 239); min-width: 100%; max-width: 100%; display: flex; align-items: center; justify-content: center; }
