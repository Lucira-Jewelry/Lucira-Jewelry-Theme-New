<section class="try-at-home-section">
    <div class="grid-row">
        <div class="grid-column">
            <div class="try-at-home-content">
                <div class="icon-title-wrap">
                    <div class="svg-icon">
                        {{- 'home-icon.svg' | inline_asset_content -}}
                    </div>
                    <h3 class="try-at-home-title">Product is available for</h3>
                </div>
                <button class="try-at-home-button" onclick="openTryAtHomeOverlay()">Try at Home</button>
            </div>
        </div>
        <div class="grid-column">
            <div class="visit-store-content">
                <div class="icon-title-wrap">
                    <div class="svg-icon">
                        {{- 'store-icon.svg' | inline_asset_content -}}
                    </div>
                    <h3 class="visit-store-home-title">At your Nearest location</h3>
                </div>
                <button class="visit-store-home-button" onclick="openVisitStoreOverlay()">Visit our Store</button>
            </div>
        </div>
    </div>
</section>

<!-- Try at Home Popup -->
<div id="tryAtHomeOverlay" class="form-popup-overlay">
    <div class="popup-form-container">
        <span class="popup-close-btn" onclick="closeTryAtHomeOverlay()">&times;</span>
        
        <div id="tryAtHomeFormSection">
            <h3 class="popup-topic">try at home Appointment</h3>
            <form id="tryAtHomeContactForm" class="popup-form">
                <div class="input-icon-wrapper">
                    {{- 'scheme-user.svg' | inline_asset_content -}}
                    <input type="text" id="try_at_home_name" placeholder="Full Name" required />
                </div>
                <div class="input-icon-wrapper">
                    {{- 'scheme-phone.svg' | inline_asset_content -}}
                    <input
                        type="number"
                        id="try_at_home_phone"
                        placeholder="Phone Number"
                        required
                        oninput="if(this.value.length > 10) this.value = this.value.slice(0, 10);"
                    />
                </div>

                <input type="hidden" id="try_at_home_product_title" value="{{ product.title }}" />

                <p id="try_at_home_phoneError" class="error-message" style="display: none;">Please enter a valid 10-digit phone number</p>
                
                <button type="submit" id="tryAtHomeSubmitBtn" class="popup-submit-btn" disabled>Submit</button>
            </form>
        </div>

        <!-- Success Message Section -->
        <div id="tryAtHomeSuccessMessage" class="popup-success-message" style="display: none;">
            <div class="success-icon">
                <svg width="60" height="60" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="30" cy="30" r="28" fill="#3EC1D3" stroke="#3EC1D3" stroke-width="2"/>
                    <path d="M20 30L26 36L40 22" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <h3>Request Submitted!</h3>
            <p>Our team will contact you shortly to schedule your home visit.</p>
            <div class="progress-bar-container">
                <div class="progress-bar"><span style="display: none;"></span></div>
            </div>
        </div>
    </div>
</div>

<!-- Visit Store Popup -->
<div id="visitStoreOverlay" class="form-popup-overlay">
  <div class="popup-form-container">
    <span class="popup-close-btn" onclick="closeVisitStoreOverlay()">&times;</span>

    <div id="visitStoreFormSection">
      <h3 class="popup-topic">Visit Our Store</h3>
      <form id="visitStoreContactForm" class="popup-form">
        <div class="input-icon-wrapper">
          {{- 'scheme-user.svg' | inline_asset_content -}}
          <input type="text" id="visit_store_name" placeholder="Full Name" required />
        </div>

        <div class="input-icon-wrapper">
          {{- 'scheme-phone.svg' | inline_asset_content -}}
          <input
            type="number"
            id="visit_store_phone"
            placeholder="Phone Number"
            required
            oninput="if(this.value.length > 10) this.value = this.value.slice(0, 10);"
          />
        </div>

        <p id="visit_store_phoneError" class="error-message" style="display: none;">
          Please enter a valid 10-digit phone number
        </p>

        <!-- Store Location Dropdown -->
        {% assign variant_store = product.selected_or_first_available_variant.metafields.custom.in_store_available %}
        <div class="input-icon-wrapper">
          {{- 'scheme-location.svg' | inline_asset_content -}}
          <select id="visit_store_location" required>
            <option value="" disabled {% unless variant_store %}selected{% endunless %}>Select Store Location</option>
            <option value="Chembur - Mumbai" {% if variant_store == "Chembur - Mumbai" %}selected{% endif %}>Chembur - Mumbai</option>
            {% comment %} <option value="JM Road - Pune" {% if variant_store == "JM Road - Pune" %}selected{% endif %}>JM Road - Pune</option> {% endcomment %}
          </select>
        </div>

        <button type="submit" id="visitStoreSubmitBtn" class="popup-submit-btn" disabled>
          Submit
        </button>
      </form>
    </div>

    <div id="visitStoreSuccessMessage" class="popup-success-message" style="display: none;">
      <div class="success-icon">
        <svg width="60" height="60" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="30" cy="30" r="28" fill="#A398DE" stroke="#A398DE" stroke-width="2"/>
          <path d="M20 30L26 36L40 22" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3>Request Submitted!</h3>
      <p>We'll send you store details and directions shortly.</p>
      <div class="progress-bar-container">
        <div class="progress-bar"><span style="display: none;"></span></div>
      </div>
    </div>
  </div>
</div>

<style>
    .try-at-home-section .grid-row { display: grid ; grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .try-at-home-section .grid-row .grid-column {display: flex ; align-items: center; justify-content: center;}
    .try-at-home-section .grid-row .grid-column button { font-family: Futura Std; font-weight: 500; font-size: 12px; line-height: 100%; letter-spacing: 1px; text-transform: uppercase;  border: 0; padding: 14px 20px; width: 100%; margin-top: 12px; color: #FFFFFF; border-radius: 8px; cursor: pointer;}
    .try-at-home-section .grid-column h3 {font-weight: 500; font-size: 12px; line-height: 150%; letter-spacing: 1px; text-align: center; vertical-align: middle; margin: 4px 0;}
    .try-at-home-content { width: 100%; border: 1px solid #3EC1D3; padding: 28px 14px 14px; border-radius: 12px; position: relative;}
    .visit-store-content { width: 100%; border: 1px solid #A398DE; padding: 28px 14px 14px; border-radius: 12px; position: relative;}
    .try-at-home-section .grid-row .grid-column button.try-at-home-button {background: #3EC1D3;}
    .try-at-home-section .grid-row .grid-column button.visit-store-home-button {background: #A398DE;}
    .try-at-home-section .svg-icon svg {display: block;}
    .try-at-home-section .svg-icon { background: #fff; position: absolute; top: -23px; left: 50%; transform: translate(-50%); background: #fff; padding: 12px; border-radius: 50%; }
    .try-at-home-section { margin-top: 35px; }
    div.form-popup-overlay { position: fixed; inset: 0; background: rgba(0, 0, 0, .6); display: none; align-items: center; justify-content: center; z-index: 9999; margin: 0; }
    .form-popup-overlay .popup-form-container {background: #fff; border-radius: 12px; width: 90%; max-width: 420px; padding: 25px; position: fixed; box-shadow: 0 10px 30px rgba(0, 0, 0, .2);}
    .form-popup-overlay .popup-close-btn {position: absolute; top: 18px; right: 20px; font-size: 22px; cursor: pointer; color: #666; line-height: 1; transition: color .3s;}
    .form-popup-overlay .popup-topic {margin: 0;}
    .form-popup-overlay .popup-form-container {background: #fff; border-radius: 12px; width: 90%; max-width: 420px; padding: 0; position: fixed; box-shadow: 0 10px 30px rgba(0, 0, 0, .2); top: 50%; left: 50%; transform: translate(-50%, -50%);}
    .form-popup-overlay .popup-topic { font-weight: 500; font-size: 16px; line-height: 150%; letter-spacing: 1.6px; vertical-align: middle; text-transform: uppercase; margin-bottom: 20px; text-align: center;}
    .input-icon-wrapper input { width: 100%; padding: 16px 20px 16px 50px; border: 1px solid #ddd; border-radius: 8px; font-family: 'Futura Std', sans-serif; font-size: 14px; letter-spacing: .5px; box-sizing: border-box; }
    .input-icon-wrapper svg { position: absolute; top: 50%; transform: translateY(-50%); left: 16px; pointer-events: none; }
    .input-icon-wrapper { position: relative; margin-bottom: 15px; }
    .popup-submit-btn {background: #b77766; color: #fff; padding: 16px; border: none; border-radius: 8px; cursor: pointer; font-family: 'Futura Std', sans-serif; font-weight: 500; font-size: 14px; text-transform: uppercase; letter-spacing: 1.3px; transition: background .3s; margin-top: 0px; width: 100%;}
    .popup-submit-btn:not(:disabled):hover { opacity: 0.9; }
    .error-message { color: #e74c3c; font-size: 12px; margin-top: -10px; margin-bottom: 10px; }
    .popup-success-message { text-align: center; }
    .success-icon { margin: 0 auto 20px; }
    .popup-success-message h3 { font-size: 20px; margin-bottom: 10px; }
    .popup-success-message p { font-size: 14px; color: #666; margin-bottom: 20px; }
    .progress-bar-container { width: 100%; height: 4px; background-color: #f0f0f0; border-radius: 2px; overflow: hidden; }
    .progress-bar { height: 100%; background: linear-gradient(90deg, #3EC1D3 0%, #2a9aa8 100%); width: 0; animation: progressAnimation 3s ease-in-out forwards; }
    #visitStoreOverlay .progress-bar { background: linear-gradient(90deg, #A398DE 0%, #8477c4 100%); }
    .input-icon-wrapper select { width: 100%; padding: 16px 20px 16px 50px; border: 1px solid #ddd; border-radius: 8px; font-family: 'Futura Std', sans-serif; font-size: 14px; letter-spacing: .5px; box-sizing: border-box; color: #747474; }
    .progress-bar-container {margin: 0; position: relative;}
    .popup-success-message { text-align: center; padding: 20px 20px 0; }
    #tryAtHomeFormSection {padding: 30px 20px 30px;}
    #visitStoreFormSection {padding: 30px 20px 30px;}
    @keyframes progressAnimation { to { width: 100%; } }

    @media (max-width: 768px) {
        .try-at-home-section .grid-row { grid-template-columns: 1fr; }
        .try-at-home-content { width: 100%; border: 1px solid #3EC1D3; padding: 14px 14px 14px; border-radius: 12px; position: relative; display: flex ; align-items: center; justify-content: space-between; }
        .try-at-home-section .svg-icon { position: relative; top: auto; left: auto; transform: none; background: #fff; padding: 12px; border-radius: 50%; }
        .try-at-home-section .grid-row .grid-column button {width: max-content;margin: 0;}
        .try-at-home-content {padding: 8px 8px 8px;}
        .visit-store-content { width: 100%; border: 1px solid #A398DE; padding: 8px 8px 8px; border-radius: 12px; position: relative; display: flex ; align-items: center; justify-content: space-between;}
        .visit-store-content { width: 100%; border: 1px solid #A398DE; padding:  8px 8px 8px; border-radius: 12px; position: relative; display: flex ; align-items: center; justify-content: space-between; gap: 10px; }
        .try-at-home-section { margin-top: 20px; }
        .try-at-home-section .grid-row .grid-column button {padding: 10px 12px;font-size: 10px;}
        .icon-title-wrap { display: flex;  align-items: center;}
        .try-at-home-content { padding: 0; }
        .visit-store-content { padding: 0; }
        .try-at-home-section .grid-row {gap: 0;}
        .visit-store-content {border: 0;}
        .try-at-home-content {border: 0;}
        .try-at-home-content .svg-icon svg {width: 24px; height: 19px;}
        .try-at-home-atc-button { text-transform: uppercase; font-family: 'Futura Std', sans-serif; letter-spacing: 1px; border-radius: 8px; border: 1px solid #a68380; color: #a68380; background: #fff; width: 100%; padding: 14px 10px; }
    }
</style>

<script>
    function openTryAtHomeOverlay() {
        document.getElementById('tryAtHomeOverlay').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeTryAtHomeOverlay() {
        document.getElementById('tryAtHomeOverlay').style.display = 'none';
        document.body.style.overflow = 'auto';
        resetTryAtHomeForm();
    }

    function resetTryAtHomeForm() {
        document.getElementById('tryAtHomeFormSection').style.display = 'block';
        document.getElementById('tryAtHomeSuccessMessage').style.display = 'none';
        document.getElementById('tryAtHomeContactForm').reset();
        document.getElementById('tryAtHomeSubmitBtn').disabled = true;
        document.getElementById('tryAtHomeSubmitBtn').textContent = 'Submit';
    }

    function openVisitStoreOverlay() {
        document.getElementById('visitStoreOverlay').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeVisitStoreOverlay() {
        document.getElementById('visitStoreOverlay').style.display = 'none';
        document.body.style.overflow = 'auto';
        resetVisitStoreForm();
    }

    function resetVisitStoreForm() {
        document.getElementById('visitStoreFormSection').style.display = 'block';
        document.getElementById('visitStoreSuccessMessage').style.display = 'none';
        document.getElementById('visitStoreContactForm').reset();
        document.getElementById('visitStoreSubmitBtn').disabled = true;
        document.getElementById('visitStoreSubmitBtn').textContent = 'Submit';
    }

    // Close popups when clicking outside
    window.onclick = function(event) {
        const tryAtHomeOverlay = document.getElementById('tryAtHomeOverlay');
        const visitStoreOverlay = document.getElementById('visitStoreOverlay');
        
        if (event.target === tryAtHomeOverlay) {
            closeTryAtHomeOverlay();
        }
        if (event.target === visitStoreOverlay) {
            closeVisitStoreOverlay();
        }
    }

    // Try at Home Form Validation
    const tryAtHomePhone = document.getElementById('try_at_home_phone');
    const tryAtHomeName = document.getElementById('try_at_home_name');
    const tryAtHomeSubmitBtn = document.getElementById('tryAtHomeSubmitBtn');
    const tryAtHomePhoneError = document.getElementById('try_at_home_phoneError');

    function validateTryAtHomeForm() {
        const phoneValue = tryAtHomePhone.value;
        const nameValue = tryAtHomeName.value.trim();
        const isPhoneValid = phoneValue.length === 10;

        if (phoneValue.length > 0 && !isPhoneValid) {
            tryAtHomePhoneError.style.display = 'block';
        } else {
            tryAtHomePhoneError.style.display = 'none';
        }

        tryAtHomeSubmitBtn.disabled = !(isPhoneValid && nameValue);
    }

    tryAtHomePhone.addEventListener('input', validateTryAtHomeForm);
    tryAtHomeName.addEventListener('input', validateTryAtHomeForm);

    document.getElementById('tryAtHomeContactForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        tryAtHomeSubmitBtn.disabled = true;
        tryAtHomeSubmitBtn.textContent = 'Submitting...';
        
        const formData = {
            name: tryAtHomeName.value.trim(),
            phone: tryAtHomePhone.value,
            type: 'try_at_home'
        };
        
        try {
            const response = await fetch('https://try-at-home-webhook-385594025448.asia-south1.run.app', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            });
            
            if (response.ok) {
                document.getElementById('tryAtHomeFormSection').style.display = 'none';
                document.getElementById('tryAtHomeSuccessMessage').style.display = 'block';
                setTimeout(() => closeTryAtHomeOverlay(), 6000);
            } else {
                throw new Error('Submission failed');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Something went wrong. Please try again.');
            tryAtHomeSubmitBtn.disabled = false;
            tryAtHomeSubmitBtn.textContent = 'Submit';
        }
    });

    // Visit Store Form Validation
    const visitStorePhone = document.getElementById('visit_store_phone');
    const visitStoreName = document.getElementById('visit_store_name');
    const visitStoreSubmitBtn = document.getElementById('visitStoreSubmitBtn');
    const visitStorePhoneError = document.getElementById('visit_store_phoneError');

    function validateVisitStoreForm() {
        const phoneValue = visitStorePhone.value;
        const nameValue = visitStoreName.value.trim();
        const isPhoneValid = phoneValue.length === 10;

        if (phoneValue.length > 0 && !isPhoneValid) {
            visitStorePhoneError.style.display = 'block';
        } else {
            visitStorePhoneError.style.display = 'none';
        }

        visitStoreSubmitBtn.disabled = !(isPhoneValid && nameValue);
    }

    visitStorePhone.addEventListener('input', validateVisitStoreForm);
    visitStoreName.addEventListener('input', validateVisitStoreForm);

    document.getElementById('visitStoreContactForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        visitStoreSubmitBtn.disabled = true;
        visitStoreSubmitBtn.textContent = 'Submitting...';
        
        // Get hidden store name
        const storeNameField = document.getElementById('visit_store_location');
        const storeName = storeNameField ? storeNameField.value : 'Unknown Store';
        
        const formData = {
            name: visitStoreName.value.trim(),
            phone: visitStorePhone.value,
            type: 'visit_store',
            store: storeName
        };
        
        try {
            const response = await fetch('https://try-at-home-webhook-385594025448.asia-south1.run.app', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            });
            
            if (response.ok) {
                document.getElementById('visitStoreFormSection').style.display = 'none';
                document.getElementById('visitStoreSuccessMessage').style.display = 'block';
                setTimeout(() => closeVisitStoreOverlay(), 6000);
            } else {
                throw new Error('Submission failed');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Something went wrong. Please try again.');
            visitStoreSubmitBtn.disabled = false;
            visitStoreSubmitBtn.textContent = 'Submit';
        }
    });
</script>

<script>
(function () {
  function addTrackingListeners() {
    document.querySelectorAll(".try-at-home-button").forEach(btn => {
      if (!btn.dataset.trackingBound) {
        btn.addEventListener("click", function () {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: "promoClick",
            promoClick: {
              promo_id: "Try at Home",
              promo_name: "Try at Home Button",
              creative_name: "Try at Home Section",
              location_id: "TryAtHomeOverlay"
            }
          });
          console.log("✅ GA event fired: Try at Home");
        });
        btn.dataset.trackingBound = true;
      }
    });

    document.querySelectorAll(".visit-store-home-button").forEach(btn => {
      if (!btn.dataset.trackingBound) {
        btn.addEventListener("click", function () {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: "promoClick",
            promoClick: {
              promo_id: "Visit Store",
              promo_name: "Visit Store Button",
              creative_name: "Visit Store Section",
              location_id: "VisitStoreOverlay"
            }
          });
          console.log("✅ GA event fired: Visit Store");
        });
        btn.dataset.trackingBound = true;
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", addTrackingListeners);
  } else {
    addTrackingListeners();
  }

  document.addEventListener("shopify:section:load", addTrackingListeners);
})();
</script>


