<script>
  document.addEventListener("DOMContentLoaded", function() {
    document.querySelectorAll(".trace-badge .trace-icon.new_modal").forEach(function(el) {
      el.addEventListener("click", function() {
        window.dataLayer = window.dataLayer || [];
        dataLayer.push({
          event: "promoClick",
          promoClick: {
            promo_id: 'Trace Clicked',
            promo_name: {{product.title | json}},
            creative_name: 'Trace Batch Clicked',
            location_id: '{{ product.selected_or_first_available_variant.id }}'
            }
        });
        console.log("promoClick event pushed to dataLayer");
      });
    });
  });
</script>
