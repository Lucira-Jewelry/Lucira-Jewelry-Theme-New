        /* BUY WITH SCHEME — outlined, no price */
        #lucira-sticky-bar .lucira-mobile-scheme-btn {
          display: flex !important;
          align-items: center;
          justify-content: center;
          flex: 0 0 auto;
          padding: 0 15px;
          background: transparent;
          border: 1.5px solid #a05a64;
          border-radius: 8px;
          text-decoration: none;
          font-family: inherit;
