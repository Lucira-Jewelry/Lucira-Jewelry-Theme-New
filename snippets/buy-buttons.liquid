{%- comment -%}
  Full product buy-buttons + "Item added to cart" UI
  Replace your current buy-buttons / product-form block with this.
{%- endcomment -%}

<style>
:root { --accent: #a68380; }

/* container */
.small-devicePosition {
  top: 0;
  border: 1px solid rgba(234,226,225,0.71);
  background: white;
  border-radius: 12px;
  z-index: 2;
  display:flex;
  flex-direction: column-reverse;
  min-height:89px;
}

/* ---------- Button layout ---------- */
.product-form__buttons { padding: 0 1rem 1rem; margin: 0; }
.product-form__buttons .button--full-width { padding:0; width:100%; }

/* main button */
.product-form__submit {
  --accent: var(--accent);
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  width: 100%;
  min-height: 56px;
  padding: 14px 18px;
  background: #ffffff;               /* white inner area */
  color: var(--accent);
  border: 2px solid var(--accent);
  border-radius: 12px;
  font-weight: 600;
  letter-spacing: 1px;
  overflow: visible;
  transition: all 250ms ease;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
}

/* main text container (keeps text centered even with icon) */
.product-form__submit .button-content {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  position: relative;
  z-index: 2;
}

/* visible text in the center */
.product-form__submit .button-text {
  display: inline-block;
  transform: translateX(0);
  text-align: center;
  width: 100%;
  color: var(--accent);
  transition: color 200ms ease;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* icon square that overlaps right edge */
.product-form__submit .button-icon {
  position: absolute;
  right: -12px;                 /* overlapping */
  top: 50%;
  transform: translateY(-50%);
  width: 44px;
  height: 44px;
  border-radius: 10px;
  background: var(--accent);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  transition: transform 220ms ease, right 220ms ease, opacity 220ms ease;
}

/* svg inside icon — make it white */
.product-form__submit .button-icon svg * { fill: white !important; stroke: none !important; }
.product-form__submit .button-icon svg { width:20px; height:20px; display:block; }

/* ADDED state */
.product-form__submit.added {
  background: #fff;
  border-color: var(--accent);
}
.product-form__submit.added .button-text {
  color: var(--accent);
  font-weight: 700;
  letter-spacing: 1px;
}

/* subtle pop animation on icon when added */
.product-form__submit.added .button-icon {
  transform: translateY(-50%) scale(1.06);
  right: -10px;
}

/* mobile: keep padding comfortable and avoid overflow issues */
@media (max-width: 480px) {
  .product-form__submit { padding: 12px 14px; min-height:50px; }
  .product-form__submit .button-icon { width:40px;height:40px; right:-10px; }
}

/* price-notification basic */
.price-notification{display:flex;border-radius:8px 8px 0 0;justify-content:space-between;width:100%;background-color:#eae2e1b5;color:#1e1615;text-align:center;padding:12px 12px;border:none;font-size:14px;cursor:pointer;font-weight:500;line-height:20px;letter-spacing:1.25px;text-decoration:none}
@media(max-width:767px){ .small-devicePosition{position:fixed;bottom:0;left:0;width:100%;} .price-notification{display:none} }
</style>

<div
{{ block.shopify_attributes }}
class="small-devicePosition"
>
{%- if product != blank -%}
{%- liquid
 assign gift_card_recipient_feature_active = false
 if block.settings.show_gift_card_recipient and product.gift_card?
   assign gift_card_recipient_feature_active = true
 endif

 assign show_dynamic_checkout = false
 if block.settings.show_dynamic_checkout and gift_card_recipient_feature_active == false
   assign show_dynamic_checkout = true
 endif
-%}

<product-form
 class="product-form"
 data-hide-errors="{{ gift_card_recipient_feature_active }}"
 data-section-id="{{ section.id }}"
 style="margin: 0; padding: 1rem 1rem 1rem;"
>
 {%- form 'product',
   product,
   id: product_form_id,
   class: 'form',
   novalidate: 'novalidate',
   data-type: 'add-to-cart-form',
   onsubmit: 'handleGTMAddToCartSubmit(event)'
 -%}

   <input
     type="hidden"
     name="id"
     value="{{ product.selected_or_first_available_variant.id }}"
     {% if product.selected_or_first_available_variant.available == false or product.selected_or_first_available_variant == null %} disabled {% endif %}
     class="product-variant-id"
   >

   <div class="product-form__buttons">
     {%- liquid
       assign check_against_inventory = true
       if product.selected_or_first_available_variant.inventory_management != 'shopify' or product.selected_or_first_available_variant.inventory_policy == 'continue'
         assign check_against_inventory = false
       endif
       if product.selected_or_first_available_variant.quantity_rule.min > product.selected_or_first_available_variant.inventory_quantity and check_against_inventory
         assign quantity_rule_soldout = true
       endif
     -%}

     <button
       id="ProductSubmitButton-{{ section_id }}"
       type="submit"
       name="add"
       class="product-form__submit button button--full-width {% if show_dynamic_checkout %}button--secondary{% else %}button--primary{% endif %} gtm-add-to-cart"
     >
       <span class="button-content">
         <span class="button-text" data-default-text>
           {%- if product.selected_or_first_available_variant == null -%}
             {{ 'products.product.unavailable' | t }}
           {%- elsif product.selected_or_first_available_variant.available == false or quantity_rule_soldout -%}
             {{ 'products.product.sold_out' | t }}
           {%- else -%}
             {{ 'products.product.add_to_cart' | t }}
           {%- endif -%}
         </span>

         <span class="button-icon" aria-hidden="true">
           <!-- cart svg (kept inline) -->
           <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 22 22" aria-hidden="true" role="img">
             <!-- background rect not required, fills forced to white via CSS; keep shape paths -->
             <path d="M4.86536 19.7085C4.40824 19.7085 4.01775 19.5466 3.69386 19.2229C3.37012 18.899 3.20825 18.5085 3.20825 18.0514V7.6156C3.20825 7.15849 3.37012 6.76799 3.69386 6.4441C4.01775 6.12036 4.40824 5.9585 4.86536 5.9585H6.87492C6.87492 4.81388 7.27627 3.84023 8.07896 3.03754C8.88165 2.23484 9.85531 1.8335 10.9999 1.8335C12.1445 1.8335 13.1182 2.23484 13.9209 3.03754C14.7236 3.84023 15.1249 4.81388 15.1249 5.9585H17.1345C17.5916 5.9585 17.9821 6.12036 18.306 6.4441C18.6297 6.76799 18.7916 7.15849 18.7916 7.6156V18.0514C18.7916 18.5085 18.6297 18.899 18.306 19.2229C17.9821 19.5466 17.5916 19.7085 17.1345 19.7085H4.86536Z"/>
             <path d="M8.24992 5.9585H13.7499C13.7499 5.19461 13.4826 4.5453 12.9478 4.01058C12.4131 3.47586 11.7638 3.2085 10.9999 3.2085C10.236 3.2085 9.58672 3.47586 9.052 4.01058C8.51728 4.5453 8.24992 5.19461 8.24992 5.9585Z"/>
             <path d="M13.7944 10.6455C13.9148 10.6437 14.0201 10.6915 14.106 10.7773C14.1916 10.863 14.2396 10.9679 14.2397 11.0879C14.2397 11.1783 14.2125 11.2605 14.1626 11.332L14.106 11.3994L10.3315 15.1807C10.2343 15.2778 10.1147 15.3301 9.979 15.3301C9.8434 15.33 9.72459 15.2777 9.62744 15.1807L7.88721 13.4414C7.80236 13.3565 7.75815 13.2506 7.75928 13.1309C7.76036 13.0104 7.80811 12.9043 7.89404 12.8184C7.97975 12.7328 8.08553 12.6855 8.20557 12.6855C8.32541 12.6857 8.43051 12.7329 8.51611 12.8184V12.8193L9.979 14.2881L13.4897 10.7773C13.5732 10.6937 13.677 10.6474 13.7944 10.6455Z"/>
           </svg>
         </span>
       </span>

       {%- render 'loading-spinner' -%}
     </button>

     {%- if show_dynamic_checkout -%}
       {{ form | payment_button }}
     {%- endif -%}
   </div>

 {%- endform -%}

 <div class="desktop-show inline-flex">
   {% render 'wishlist-app-links', linkType: 'single-product', product: product  %}
 </div>

 <div class="mobile-show">
  <div class="custom-wp_btn-link">
    <a href="https://wa.me/+919004435760?text=Hi, I want to get more information about this product: {{ product.title | url_encode }}" style="padding: 0 !important; border: 0 !important;" target="_blank">
      <img
        class="chat-with-experts"
        src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Group_1321315733_1.png?v=1755165022"
        height="46"
        width="46"
        alt="Chat with experts"
      >
    </a>
  </div>
 </div>

 <div class="custom-share-icon desktop-show">
   <div>
     <div class="altrcustm cstmshre" onclick="share()" id="">
       <img
         style="width:30px;"
         src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/share.svg?v=1740554864"
         alt="Share"
       >
     </div>
   </div>
 </div>

 <div class="product-form__error-message-wrapper" role="alert" hidden>
   <span class="svg-wrapper">
     {{- 'icon-error.svg' | inline_asset_content -}}
   </span>
   <span class="product-form__error-message"></span>
 </div>
</product-form>

{%- else -%}
<div class="product-form">
 <div class="product-form__buttons form">
   <button
     type="submit"
     name="add"
     class="product-form__submit button button--full-width button--primary"
     disabled
   >
     {{ 'products.product.sold_out' | t }}
   </button>
 </div>
</div>
{%- endif -%}

{%- if show_pickup_availability -%}
 {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}
 <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<div class="price-notification">
  <span class="">When price drop</span>
  <span
    id="openBradNotifymeBtn"
    class="openBradNotifymeBtn brad-delivery-span-2 underline-effect"
    onclick="
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'promoClick',
        promoClick: {
          promo_id: '{{ product.selected_or_first_available_variant.sku }}',
          promo_name: '{{ product.title }}',
          creative_name: 'Notify Me Clicked'
        }
      });
    "
  >Notify me</span>
</div>

</div> <!-- end small-devicePosition -->

<script>
document.addEventListener('DOMContentLoaded', function () {
  const atcForm = document.querySelector('.product-form form');
  const atcButton = document.querySelector('.product-form__submit');

  if (!atcButton) return;

  // Save original HTML to restore exactly after state
  const originalContent = atcButton.innerHTML;

  // Utility to set added state while preserving icon
  function showAddedState() {
    // If the site does a full page refresh on add-to-cart, this won't be visible.
    // For AJAX adds, consider calling this on success callback.
    atcButton.classList.add('added');

    // only update centered text
    const textEl = atcButton.querySelector('.button-text');
    if (textEl) textEl.textContent = 'ITEM ADDED TO CART';

    // restore after 2.5s
    setTimeout(() => {
      // if originalContent contains Liquid rendered HTML references that changed,
      // replace with the original saved content to ensure exact restore.
      atcButton.classList.remove('added');
      atcButton.innerHTML = originalContent;
    }, 2500);
  }

  // If the form element exists, hook submit to show feedback.
  if (atcForm) {
    atcForm.addEventListener('submit', function (e) {
      // If the theme does an ajax add-to-cart, this UI can be triggered on AJAX success.
      // We show it with a slight delay to feel responsive.
      setTimeout(showAddedState, 350);
    });
  } else {
    // If no form (edge case), listen for direct button click
    atcButton.addEventListener('click', function () {
      setTimeout(showAddedState, 350);
    });
  }
});

// share function (keeps your dataLayer push + native share fallback)
function share() {
  const shareData = {
    title: "Lucira",
    url: window.location.href
  };

  const shareEventData = {
    promo_id: "{{ product.selected_or_first_available_variant.sku }}",
    promo_name: "{{ product.title }}",
    creative_name: "share",
  };

  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({ event: "promoClick", promoClick: shareEventData });

  if (navigator.share) {
    navigator.share(shareData).catch((error) => { console.warn("Sharing failed:", error); });
  } else {
    // fallback — open copy link modal or do nothing. For simple fallback, copy URL to clipboard
    if (navigator.clipboard) {
      navigator.clipboard.writeText(shareData.url).then(() => {
        console.log('Link copied to clipboard');
      }).catch(()=> {});
    } else {
      console.log('Native share not supported.');
    }
  }
}
</script>
