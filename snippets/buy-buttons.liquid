      display: flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
      padding: 0 16px;
      background: transparent;
      border: 1.5px solid #A68380;
      border-radius: 12px;
      text-decoration: none;
      font-family: inherit;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #5a4a44;
      white-space: nowrap;
      box-sizing: border-box;
      transition: background 0.2s ease, border-color 0.2s ease;
    }

    .lucira-mobile-scheme-btn:hover {
      background: #f7f0ee;
      border-color: #8c6b62;
      color: #3d2e28;
      text-decoration: none;
    }

    .buy-buttons-wrapper .product-form__buttons .product-form__submit {
      flex: 1 1 auto;
    }
  }

  @media (min-width: 750px) {
    #lucira-sticky-bar { display: none !important; }
  }

  @media (max-width: 749px) {
    #lucira-sticky-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 9999;
      background: #ffffff;
      border-top: 1px solid #e8e0de;
      padding: 10px 16px;
      padding-bottom: calc(10px + env(safe-area-inset-bottom, 0px));
      box-shadow: 0 -4px 20px rgba(0,0,0,0.10);
      transform: translateY(100%);
      transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform;
      pointer-events: none;
      box-sizing: border-box;
    }

    #lucira-sticky-bar.is-visible {
      transform: translateY(0);
      pointer-events: auto;
    }

    #lucira-sticky-bar .product-form__buttons {
      margin: 0 !important;
      display: flex;
      align-items: stretch;
      gap: 8px;
    }

    #lucira-sticky-bar .lucira-sticky-wa-btn {
      display: flex !important;
      align-items: center;
      justify-content: center;
      flex: 0 0 46px;
      width: 46px;
      height: 46px;
      border-radius: 50%;
      background: transparent;
      border: none;
      text-decoration: none;
      align-self: center;
      flex-shrink: 0;
      padding: 0 !important;
    }

    #lucira-sticky-bar .lucira-sticky-wa-btn img {
      width: 46px;
      height: 46px;
      display: block;
    }

    #lucira-sticky-bar .lucira-mobile-scheme-btn {
      display: flex !important;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
      padding: 0 15px;
      background: transparent;
      border: 1.5px solid #a05a64;
      border-radius: 8px;
      text-decoration: none;
      font-family: inherit;
      font-size: 14px;
      font-weight: 500;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #a05a64;
      white-space: nowrap;
      line-height: 1.2;
      text-align: center;
    }

    #lucira-sticky-bar .product-form__submit {
      flex: 1 1 auto;
    }
  }

  /* ── Store side sheet ── */
  .store-sheet {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 99999;
    /* Use visibility instead of display:none so transform can animate */
    visibility: hidden;
    pointer-events: none;
  }

  .store-sheet.active {
    visibility: visible;
    pointer-events: auto;
  }

  .store-sheet-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.45);
    z-index: 9999999;
    opacity: 0;
    transition: opacity 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .store-sheet.active .store-sheet-overlay {
    opacity: 1;
  }

  .store-sheet-content {
    position: absolute;
    right: 0;
    top: 0;
    width: 85%;
    max-width: 500px;
    height: 100%;
    background: #fff;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow-y: scroll;
    z-index: 99999999;
  }

  .store-sheet.active .store-sheet-content {
    transform: translateX(0);
  }

  @media (max-width: 749px) {
    .store-sheet-content {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      top: auto;
      width: 100%;
      max-width: 100%;
      height: 85dvh;
      border-radius: 16px 16px 0 0;
      transform: translateY(100%);
      transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      overflow-y: scroll;
      -webkit-overflow-scrolling: touch;
    }

    .store-sheet.active .store-sheet-content {
      transform: translateY(0);
    }
  }

  .store-sheet-header {
    display: flex;
    justify-content: space-between;
    padding: 16px;
    border-bottom: 1px solid #eee;
  }

  #close-store-sheet {
    background: none;
    border: none;
    font-size: 22px;
    cursor: pointer;
  }

  #store-sheet-body {
    padding: 16px;
  }

