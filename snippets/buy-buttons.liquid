         src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/share.svg?v=1740554864"
       >
       <!-- <span class="txtsh">SHARE</span> -->
     </div>

     <script>
       function share() {
         const shareData = {
           title: "Lucira",
           url: "{{ product.url }}"
         };


         // Push to dataLayer before invoking the native share
         const shareEventData = {
           promo_id: "{{ product.selected_or_first_available_variant.sku }}",  // Shopify Liquid
           promo_name: "{{ product.title }}",
           creative_name: "share",
         };

         window.dataLayer = window.dataLayer || [];
         window.dataLayer.push({
           event: "promoClick",
           promoClick: shareEventData
         });

         console.log("✅ Share dataLayer pushed:", shareEventData);

         // Proceed with native share if supported
         if (navigator.share) {
           navigator.share(shareData).catch((error) => {
             console.warn("Sharing failed:", error);
           });
         } else {
           console.log("Web Share API not supported.");
         }
       }
     </script>

