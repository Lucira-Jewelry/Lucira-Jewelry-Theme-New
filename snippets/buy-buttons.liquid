</style>

<script>
  (function () {
    'use strict';

    if (window.__luciraStickyBarInit) return;
    window.__luciraStickyBarInit = true;

    /* ── scheme_url resolved in Liquid (SSO for logged-in, plain for guests) ── */
    var SCHEME_URL         = {{ scheme_url | json }};
    var SHOW_SCHEME_BTN    = {{ _show_scheme_btn }};
    var PRODUCT_TITLE      = {{ product.title | json }};
    var currentVariantId   = '{{ product.selected_or_first_available_variant.id }}';
    /* ── Build the sticky bar by CLONING the real button row ── */
    function buildBar() {
      var originalButtons = document.querySelector('.buy-buttons-wrapper .product-form__buttons');
      if (!originalButtons) return null;

      var bar = document.createElement('div');
      bar.id = 'lucira-sticky-bar';
      bar.setAttribute('aria-hidden', 'true');

      /* Deep-clone the entire buttons row */
      var cloned = originalButtons.cloneNode(true);

      /* Remove any accidentally cloned scheme buttons (safety net) */
      var existingScheme = cloned.querySelector('.lucira-mobile-scheme-btn');
      if (existingScheme) existingScheme.remove();

      /* Wire ATC clone → original submit */
      var clonedSubmit = cloned.querySelector('[id^="ProductSubmitButton"]');
      if (clonedSubmit) {
        clonedSubmit.id = 'lucira-sticky-atc-btn';
        clonedSubmit.addEventListener('click', function (e) {
          e.preventDefault();
          var origBtn = document.querySelector('.buy-buttons-wrapper #ProductSubmitButton-{{ section_id }}');
          if (origBtn && !origBtn.disabled) origBtn.click();
        });
      }

      var waLink = document.createElement('a');
      waLink.href = 'https://wa.me/+919004435760?text=Hi, I want to get more information about this product: {{ product.title | url_encode }}';
      waLink.target = '_blank';
      waLink.rel = 'noopener noreferrer';
      waLink.className = 'lucira-sticky-wa-btn chat-with-experts-mobile';
      waLink.setAttribute('aria-label', 'Chat on WhatsApp');
      waLink.style.cssText = 'padding:0!important;border:0!important;';

      var waImg = document.createElement('img');
      waImg.src = 'https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Group_1321315733.svg?v=1772780374';
      waImg.width = 46;
      waImg.height = 46;
      waImg.alt = 'whatsapp icon';
      waImg.title = 'whatsapp';
      waImg.className = 'chat-with-experts';
      waLink.appendChild(waImg);

      /* chatWithExperts datalayer is handled by the delegated document listener
         in sticky-chat-experts.liquid (catches .lucira-sticky-wa-btn class) */

      /* ── Build Scheme button using Liquid-resolved SCHEME_URL ── */
      var schemeBtn = document.createElement('a');
      schemeBtn.href = SCHEME_URL;
      schemeBtn.className = 'lucira-mobile-scheme-btn';
      schemeBtn.target = '_blank';
      schemeBtn.rel = 'noopener noreferrer';
      schemeBtn.textContent = ' 9=10 SAVING';

      schemeBtn.addEventListener('click', function () {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'promoClick',
          promoClick: {
            creative_name:  'Scheme Button Mobile Sticky',
            promo_name:     PRODUCT_TITLE,
            promo_position: currentVariantId,
            location_id:    'mobile_sticky_atc'
          }
        });
      });

      /* Order: [WA icon] [SCHEME btn] [ATC btn] */
      if (SHOW_SCHEME_BTN) {
        cloned.insertBefore(schemeBtn, cloned.firstChild); // scheme before ATC
      }
      cloned.insertBefore(waLink, cloned.firstChild);    // WA always shown

      bar.appendChild(cloned);
      document.body.appendChild(bar);
      return bar;
    }

    /* ── Sync disabled state + button text from original → clone ── */
    function syncATC() {
      var origBtn   = document.querySelector('.buy-buttons-wrapper #ProductSubmitButton-{{ section_id }}');
      var stickyBtn = document.getElementById('lucira-sticky-atc-btn');
      if (!origBtn || !stickyBtn) return;

      stickyBtn.disabled = origBtn.disabled;

      var origTxt   = origBtn.querySelector('.add-to-cart-text');
      var stickyTxt = stickyBtn.querySelector('.add-to-cart-text');
      if (origTxt && stickyTxt) {
        stickyTxt.textContent = origTxt.textContent.trim();
      }
    }

    /* ── Show / hide ── */
    function setBarVisible(visible) {
      var bar = document.getElementById('lucira-sticky-bar');
      if (!bar) return;
      bar.classList.toggle('is-visible', visible);
      bar.setAttribute('aria-hidden', String(!visible));
    }

    /* ── IntersectionObserver on the real button row ── */
    function initObserver() {
      var sentinel = document.querySelector('.buy-buttons-wrapper .product-form__buttons');
      if (!sentinel) sentinel = document.querySelector('.buy-buttons-wrapper');
      if (!sentinel) return;

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          // Show sticky bar whenever ATC is NOT visible in viewport (above OR below)
          setBarVisible(!entry.isIntersecting);
        });
      }, { threshold: 0, rootMargin: '0px' });

      observer.observe(sentinel);
    }

    /* ── Variant change → sync ATC state only ── */
    function onVariantChange() {
      requestAnimationFrame(syncATC);

      // Keep currentVariantId fresh for dataLayer reads
      var mainForm     = document.querySelector('.product-form form[action*="/cart/add"]');
      var variantInput = mainForm && mainForm.querySelector('input[name="id"]');
      if (variantInput && variantInput.value) {
        currentVariantId = variantInput.value;
      }
    }

    document.addEventListener('variant:change',  function () { onVariantChange(); });
    document.addEventListener('variant:changed', function () { onVariantChange(); });

    /* MutationObserver fallback on hidden input[name="id"] */
    function watchVariantInput() {
      var mainForm     = document.querySelector('.product-form form[action*="/cart/add"]');
      var variantInput = mainForm && mainForm.querySelector('input[name="id"]');
      if (!variantInput) return;

      new MutationObserver(function () {
        if (variantInput.value) onVariantChange();
      }).observe(variantInput, { attributes: true, attributeFilter: ['value'] });

      variantInput.addEventListener('change', function () {
        if (this.value) onVariantChange();
      });

      mainForm.addEventListener('change', function (e) {
        if (e.target.name === 'id' && e.target.value) onVariantChange();
      });
    }

    /* ── Boot ── */
    document.addEventListener('DOMContentLoaded', function () {
      buildBar();
      syncATC();
      initObserver();
      watchVariantInput();
    });

  })();
</script>
<script>
  (function () {
    const API_URL = 'https://api.lucirajewelry.com/inventory/inventory-check.php';

    /* 🔥 Store Full Details Mapping */
    const STORE_DETAILS = {
      PS1: {
        name: 'Pune Store',
        address: 'JM Road, Pune',
        timings: '10 AM - 8 PM',
        map: 'https://maps.google.com?q=Pune',
      },
      CS1: {
        name: 'Chembur Store',
        address: 'Chembur, Mumbai',
        timings: '10 AM - 8 PM',
        map: 'https://maps.google.com?q=Chembur',
      },
      BO1: {
        name: 'Borivali Store',
        address: 'Borivali, Mumbai',
        timings: '10 AM - 8 PM',
        map: 'https://maps.google.com?q=Borivali',
      },
      'Divinecarat Lifestyles Pvt Ltd': {
        name: 'Head Office',
        address: 'Mumbai HQ',
        timings: '10 AM - 6 PM',
        map: 'https://maps.google.com?q=Mumbai',
      },
    };

    let lastVariantId = null;

    function getVariantId() {
      const input = document.querySelector('form[action="/cart/add"] input[name="id"]');
      return input ? input.value : null;
    }

    function getFutureDate(days = 15) {
      const d = new Date();
      d.setDate(d.getDate() + days);

      return d.toLocaleDateString('en-GB', {
        day: '2-digit',
        month: 'long',
        year: 'numeric',
      });
    }

    function renderStoreData(data) {
      const container = document.getElementById('store-availability-dynamic');
      if (!container) return;

      if (!data) {
        container.innerHTML = `<div class="store-loading">Checking availability...</div>`;
        return;
      }

      if (data.in_stock_locations && data.in_stock_locations.length > 0) {
        window.__storeData = data;

        const store = data.in_stock_locations[0];
        const displayName = STORE_DETAILS[store.location_name]?.name || store.location_name;

        container.innerHTML = `
  <div class="store-available">
    <p class="location-store">
      Available at our ${displayName} & ${data.in_stock_locations.length - 1} other stores
    </p>

    <p class="extra-stores" id="open-store-sheet" style="cursor:pointer; text-decoration: underline;">
      Find All Stores
    </p>
  </div>
`;
      } else {
        container.innerHTML = `
        <div class="made-to-order-box">
          Dispatch by: ${getFutureDate()} | This item is made to order
        </div>
      `;
      }
    }

    function fetchInventory() {
      const variantId = getVariantId();
      if (!variantId) return;

      /* 🚀 Prevent duplicate API calls */
      if (variantId === lastVariantId) return;
      lastVariantId = variantId;

      renderStoreData(null);

      fetch(`${API_URL}?variant_id=${variantId}`)
        .then((res) => res.json())
        .then((data) => {
          renderStoreData(data);
        })
        .catch(() => {
          renderStoreData({ in_stock_locations: [] });
        });
    }

    /* 🔥 SUPER IMPORTANT: MutationObserver (handles ALL themes) */
    function watchVariantChange() {
      const form = document.querySelector('form[action="/cart/add"]');
      if (!form) return;

      const variantInput = form.querySelector('input[name="id"]');
      if (!variantInput) return;

      /* Detect value change */
      new MutationObserver(() => {
        fetchInventory();
      }).observe(variantInput, {
        attributes: true,
        attributeFilter: ['value'],
      });

      /* Backup listeners */
      variantInput.addEventListener('change', fetchInventory);
      form.addEventListener('change', function (e) {
        if (e.target.name === 'id') fetchInventory();
      });
    }

    /* 🔥 SIDE SHEET */

    function openStoreSheet() {
      const sheet = document.getElementById('store-side-sheet');
      const body = document.getElementById('store-sheet-body');

      if (!window.__storeData || !sheet || !body) return;

      body.innerHTML = '';

      window.__storeData.in_stock_locations.forEach((store) => {
        const details = STORE_DETAILS[store.location_name] || {
          name: store.location_name,
          address: 'N/A',
          timings: 'N/A',
          map: '#',
        };

        body.innerHTML += `
  <div class="store-card">
    
    <h4 class="store-title">${details.name}</h4>

    <p class="store-address">
      <span class="icon">                          
        <svg class="icon-location" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      </span>
      ${details.address}
    </p>

    <div class="store-meta">
      <p><span class="icon">📞</span> ${details.phone || ''}</p>
      <p><span class="icon">⏰</span> ${details.timings}</p>
    </div>

    <div class="store-actions">
    
      <a href="https://wa.me/${(details.phone || '').replace(/\\D/g, '')}" target="_blank" class="btn-outline">
      <svg width="25" height="25" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M26.9875 6.95607C25.6885 5.64439 24.1414 4.60436 22.4365 3.89659C20.7315 3.18881 18.9027 2.82746 17.0567 2.83357C9.32166 2.83357 3.01749 9.13774 3.01749 16.8727C3.01749 19.3519 3.66916 21.7602 4.88749 23.8852L2.90416 31.1669L10.3417 29.2119C12.3958 30.3311 14.705 30.9261 17.0567 30.9261C24.7917 30.9261 31.0958 24.6219 31.0958 16.8869C31.0958 13.1327 29.6367 9.60524 26.9875 6.95607ZM17.0567 28.5461C14.96 28.5461 12.9058 27.9794 11.1067 26.9169L10.6817 26.6619L6.26166 27.8236L7.43749 23.5169L7.15416 23.0777C5.98902 21.2177 5.37047 19.0675 5.36916 16.8727C5.36916 10.4411 10.6108 5.19941 17.0425 5.19941C20.1592 5.19941 23.0917 6.41774 25.2875 8.62774C26.375 9.70988 27.2367 10.9972 27.8228 12.415C28.4089 13.8327 28.7076 15.3528 28.7017 16.8869C28.73 23.3186 23.4883 28.5461 17.0567 28.5461ZM23.46 19.8194C23.1058 19.6494 21.3775 18.7994 21.0658 18.6719C20.74 18.5586 20.5133 18.5019 20.2725 18.8419C20.0317 19.1961 19.3658 19.9894 19.1675 20.2161C18.9692 20.4569 18.7567 20.4852 18.4025 20.3011C18.0483 20.1311 16.915 19.7486 15.5833 18.5586C14.535 17.6236 13.8408 16.4761 13.6283 16.1219C13.43 15.7677 13.6 15.5836 13.7842 15.3994C13.94 15.2436 14.1383 14.9886 14.3083 14.7902C14.4783 14.5919 14.5492 14.4361 14.6625 14.2094C14.7758 13.9686 14.7192 13.7702 14.6342 13.6002C14.5492 13.4302 13.8408 11.7019 13.5575 10.9936C13.2742 10.3136 12.9767 10.3986 12.7642 10.3844H12.0842C11.8433 10.3844 11.475 10.4694 11.1492 10.8236C10.8375 11.1777 9.93083 12.0277 9.93083 13.7561C9.93083 15.4844 11.1917 17.1561 11.3617 17.3827C11.5317 17.6236 13.8408 21.1652 17.3542 22.6811C18.19 23.0494 18.8417 23.2619 19.3517 23.4177C20.1875 23.6869 20.9525 23.6444 21.5617 23.5594C22.2417 23.4602 23.6442 22.7094 23.9275 21.8877C24.225 21.0661 24.225 20.3719 24.1258 20.2161C24.0267 20.0602 23.8142 19.9894 23.46 19.8194Z" fill="#b76f79"/>
                            </svg>
        CONNECT WITH US
      </a>

      <a href="${details.map}" target="_blank" class="btn-filled">
        AVAILABLE DESIGNS
      </a>
    </div>

  </div>
`;
      });

      sheet.classList.add('active');
    }

    function closeStoreSheet() {
      document.getElementById('store-side-sheet').classList.remove('active');
    }

    document.addEventListener('click', function (e) {
      if (e.target.id === 'open-store-sheet') {
        openStoreSheet();
      }

      if (e.target.id === 'close-store-sheet' || e.target.classList.contains('store-sheet-overlay')) {
        closeStoreSheet();
      }
    });

    /* 🚀 INIT */
    document.addEventListener('DOMContentLoaded', function () {
      fetchInventory();
      watchVariantChange();
    });
  })();
</script>
