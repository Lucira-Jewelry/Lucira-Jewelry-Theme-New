    let lastVariantId = null;

    function getVariantId() {
      const input = document.querySelector('form[action="/cart/add"] input[name="id"]');
      return input ? input.value : null;
    }

    function getFutureDate(days = 15) {
      const d = new Date();
      d.setDate(d.getDate() + days);
      return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' });
    }

    function renderStoreData(data) {
      const container = document.getElementById('store-availability-dynamic');
      if (!container) return;

      if (!data) {
        container.innerHTML = `<div class="store-loading"></div>`;
        return;
      }
      
      const enrichedLocations = (data.in_stock_locations || []).map(s => ({
        ...s,
        display_name: (STORE_DETAILS[s.location_name] || {}).name || s.location_name,
        lat: (STORE_DETAILS[s.location_name] || {}).lat || null,
        lng: (STORE_DETAILS[s.location_name] || {}).lng || null,
      }));

      if (enrichedLocations.length > 0) {
        window.__storeData = { ...data, in_stock_locations: enrichedLocations };
      } 

      document.dispatchEvent(new CustomEvent('lucira:inventory', {
        detail: {
          inStock: enrichedLocations.length > 0,
          locations: enrichedLocations,
          displayNames: enrichedLocations.map(s => s.display_name),
        }
      }));
    }

    function fetchInventory() {
      const variantId = getVariantId();
      if (!variantId) return;
      if (variantId === lastVariantId) return;
      lastVariantId = variantId;

      renderStoreData(null);

      fetch(`${API_URL}?variant_id=${variantId}`)
        .then(res => res.json())
        .then(data => renderStoreData(data))
        .catch(() => renderStoreData({ in_stock_locations: [] }));
    }

    function watchVariantChange() {
      const form = document.querySelector('form[action="/cart/add"]');
      if (!form) return;

      const variantInput = form.querySelector('input[name="id"]');
      if (!variantInput) return;

      new MutationObserver(() => fetchInventory()).observe(variantInput, {
        attributes: true,
        attributeFilter: ['value'],
      });

      variantInput.addEventListener('change', fetchInventory);
      form.addEventListener('change', e => { if (e.target.name === 'id') fetchInventory(); });
    }

    function openStoreSheet(sortedLocations) {
      const sheet = document.getElementById('store-side-sheet');
      const body  = document.getElementById('store-sheet-body');
      if (!sheet || !body) return;

      const locsToShow =
        sortedLocations ||
        (window.__storeData && window.__storeData.in_stock_locations) ||
        [];

      if (!locsToShow.length) return;

      body.innerHTML = '';

      locsToShow.forEach((store, index) => {
        const details = STORE_DETAILS[store.location_name] || {
          name: store.location_name,
          address: 'N/A',
          timings: 'N/A',
          map: '#',
        };

        const isNearest  = !!(sortedLocations && index === 0);
        const distanceKm = store.distance_km != null ? store.distance_km : null;

        body.innerHTML += `
          <div class="store-card ${isNearest ? 'store-card--nearest' : ''}">

            ${isNearest ? `<div class="nearest-store-badge"><svg width="12" height="12" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg"> <path d="M7.71357 13H4.00357C3.7939 13.0001 3.58956 13.0661 3.41945 13.1886C3.24933 13.3112 3.12204 13.4841 3.05557 13.683L1.05157 19.683C1.00133 19.8333 0.987541 19.9934 1.01133 20.1501C1.03512 20.3068 1.09581 20.4556 1.1884 20.5842C1.28098 20.7128 1.40282 20.8176 1.54385 20.8899C1.68489 20.9622 1.84109 20.9999 1.99957 21H19.9996C20.1579 20.9999 20.314 20.9621 20.455 20.8899C20.5959 20.8177 20.7176 20.713 20.8102 20.5845C20.9028 20.456 20.9635 20.3074 20.9874 20.1508C21.0113 19.9942 20.9976 19.8343 20.9476 19.684L18.9476 13.684C18.8812 13.4848 18.7539 13.3115 18.5835 13.1888C18.4132 13.066 18.2085 12.9999 17.9986 13H14.2866M16.9996 7C16.9996 10.613 13.1306 14.429 11.6066 15.795C11.4322 15.9282 11.2189 16.0003 10.9996 16.0003C10.7802 16.0003 10.5669 15.9282 10.3926 15.795C8.86957 14.429 4.99957 10.613 4.99957 7C4.99957 5.4087 5.63172 3.88258 6.75693 2.75736C7.88215 1.63214 9.40828 1 10.9996 1C12.5909 1 14.117 1.63214 15.2422 2.75736C16.3674 3.88258 16.9996 5.4087 16.9996 7ZM12.9996 7C12.9996 8.10457 12.1041 9 10.9996 9C9.89501 9 8.99957 8.10457 8.99957 7C8.99957 5.89543 9.89501 5 10.9996 5C12.1041 5 12.9996 5.89543 12.9996 7Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/> </svg>Nearest to you</div>` : ''}
            ${distanceKm !== null ? `<p class="store-distance-label">${distanceKm} km from you</p>` : ''}

            <h4 class="store-title">${details.name}</h4>

            <p class="store-address">
              <span class="icon">
                <svg class="icon-location" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </span>
              ${details.address}
            </p>

            <div class="store-meta">
              {% comment %} <p>
                <span class="icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.14 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.05 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                </span>
                ${details.phone || ''}
              </p> {% endcomment %}
              <p>
                <span class="icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.14 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.05 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                </span>
                ${details.phone
                  ? `<a href="tel:${details.phone.replace(/\s+/g, '')}" style="color:inherit;text-decoration:none;">${details.phone}</a>`
                  : ''}
              </p>
              <p>
                <span class="icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                </span>
                ${details.timings}
              </p>
            </div>

            <div class="store-actions">
              <a href="https://wa.me/${(details.phone || '').replace(/\D/g, '')}" target="_blank" class="btn-outline">
                CONNECT WITH US
              </a>
              <a href="${details.map}" target="_blank" class="btn-filled">
                GET DIRECTIONS
              </a>
            </div>

          </div>
        `;
      });

      sheet.classList.add('active');
      // Lock scroll using the standard theme class to prevent jumping
      document.body.classList.add('overflow-hidden');
    }

    // Expose globally so try-at-home-section can call it with sorted locations
    window.luciraOpenStoreSheet = openStoreSheet;

    function closeStoreSheet() {
      const sheet = document.getElementById('store-side-sheet');
      if (sheet) sheet.classList.remove('active');
      // Unlock scroll
      document.body.classList.remove('overflow-hidden');
    }

    document.addEventListener('click', function (e) {
      if (e.target.id === 'open-store-sheet') openStoreSheet();
      if (e.target.id === 'close-store-sheet' || e.target.classList.contains('store-sheet-overlay')) closeStoreSheet();
    });

    document.addEventListener('DOMContentLoaded', function () {
      fetchInventory();
      watchVariantChange();
    });
  })();
</script>