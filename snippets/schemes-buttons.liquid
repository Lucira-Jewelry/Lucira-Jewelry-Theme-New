<script>
(function () {
  // ── Avoid registering multiple listeners if snippet renders twice ──
  if (window.__luciraSchemeInit) return;
  window.__luciraSchemeInit = true;

  // ── Core calculation (mirrors Liquid logic exactly) ───────────────
  // pricePaise : number  — variant.price in paise (Shopify native unit)
  // returns    : { schemePrice, monthly, pay9, productPrice, save } all in rupees
  function calcScheme(pricePaise) {
    var priceRupees = Math.floor(pricePaise / 100);
    var rawMonthly  = Math.floor(priceRupees / 10);
    var remainder   = rawMonthly % 500;
    var monthly     = rawMonthly - remainder;           // FLOOR to lower ₹500 slab
    return {
      productPrice: priceRupees,
      monthly:      monthly,
      pay9:         monthly * 9,
      schemePrice:  priceRupees - monthly,              // effective price on button
      save:         monthly                             // = 10th month saving
    };
  }

  // Format as en-IN  e.g. 62788 → "62,788"
  function formatINR(amount) {
    return amount.toLocaleString('en-IN');
  }

  function rupees(n) {
    return '₹' + formatINR(n);
  }

  // ── Accordion toggle (only outside sticky ATC) ────────────────────
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-scheme-toggle]');
    if (!btn) return;

    // Disable accordion inside sticky ATC — treat as plain no-op there
    if (btn.closest('#md-sticky-atc')) return;

    var wrapper = btn.closest('[data-scheme-wrapper]');
    if (!wrapper) return;

    var panel   = wrapper.querySelector('[data-scheme-panel]');
    if (!panel)  return;

    var isOpen  = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isOpen));
    panel.hidden = isOpen;
  });

  // ── Update every scheme wrapper on the page ───────────────────────
  function updateAllWrappers(variantId) {
    document.querySelectorAll('[data-scheme-wrapper]').forEach(function (wrapper) {
      var prices     = JSON.parse(wrapper.dataset.variantPrices || '{}');
      var pricePaise = prices[variantId];
      if (pricePaise === undefined) return;

      var r = calcScheme(pricePaise);

      // Button header price
      var priceEl = wrapper.querySelector('[data-scheme-price]');
      if (priceEl) priceEl.textContent = rupees(r.schemePrice);

      // Breakdown rows
      var productPriceEl = wrapper.querySelector('[data-scheme-product-price]');
      if (productPriceEl) productPriceEl.textContent = rupees(r.productPrice);

      var monthlyLabelEl = wrapper.querySelector('[data-scheme-monthly-label]');
      if (monthlyLabelEl) monthlyLabelEl.textContent = rupees(r.monthly) + ' x 9 Months';

      var pay9El = wrapper.querySelector('[data-scheme-pay9]');
      if (pay9El) pay9El.textContent = rupees(r.pay9);

      var tenthEl = wrapper.querySelector('[data-scheme-10th]');
      if (tenthEl) tenthEl.textContent = rupees(r.monthly);

      var effectiveEl = wrapper.querySelector('[data-scheme-effective]');
      if (effectiveEl) effectiveEl.textContent = rupees(r.schemePrice);

      var saveEl = wrapper.querySelector('[data-scheme-save]');
      if (saveEl) saveEl.textContent = rupees(r.save);

      // ── Keep enroll href in sync with updated _monthly amount ──
      var link = wrapper.querySelector('[data-scheme-link]');
      if (link) {
        var currentHref = link.getAttribute('href') || '';
        var baseUrl     = currentHref.split('&amount=')[0].split('?amount=')[0];
        var separator   = baseUrl.indexOf('?') !== -1 ? '&' : '?';
        link.href       = baseUrl + separator + 'amount=' + r.monthly;
      }
    });
  }

  // ── Event listeners for variant change ────────────────────────────

  // 1. Shopify native variant:change (most custom themes)
  document.addEventListener('variant:change', function (e) {
    var variant = e.detail && e.detail.variant;
    if (variant && variant.id && variant.price !== undefined) {
      updateAllWrappers(String(variant.id));
    }
  });

  // 2. Dawn / Prestige style
  document.addEventListener('variant:changed', function (e) {
    var variant = e.detail && e.detail.variant;
    if (variant && variant.id && variant.price !== undefined) {
      updateAllWrappers(String(variant.id));
    }
  });

  // 3. Fallback — watch the hidden variant ID input in the main product form
  document.addEventListener('DOMContentLoaded', function () {
    var mainForm = document.querySelector('.product-form form[action*="/cart/add"]');
    if (!mainForm) return;

    var variantInput = mainForm.querySelector('input[name="id"]');
    if (!variantInput) return;

    new MutationObserver(function () {
      if (variantInput.value) updateAllWrappers(variantInput.value);
    }).observe(variantInput, { attributes: true, attributeFilter: ['value'] });

    variantInput.addEventListener('change', function () {
      if (this.value) updateAllWrappers(this.value);
    });

    mainForm.addEventListener('change', function (e) {
      if (e.target.name === 'id' && e.target.value) {
        updateAllWrappers(e.target.value);
      }
    });
  });
})();
</script>

{% endif %}
