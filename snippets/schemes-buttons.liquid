{% comment %}
  ============================================================
  Snippet: scheme-button.liquid
  Save to: snippets/scheme-button.liquid

  Usage in main-product.liquid (below Add to Cart):
    {% render 'scheme-button', product: product %}

  To pass a custom redirect URL:
    {% render 'scheme-button', product: product, scheme_url: '/pages/scheme' %}

  ── ROUNDING FIX EXPLAINED ─────────────────────────────────
  Rule: monthly × 10 must ALWAYS be >= product price
  So we ALWAYS CEIL to the next ₹500 (never round down/nearest)

  Example A — ₹69,788:
    raw_monthly = 69788 / 10 = 6978  (Liquid integer division)
    remainder   = 6978 % 500 = 478
    remainder > 0 → ceil → 6978 - 478 + 500 = 7000
    7000 × 10 = 70,000 >= 69,788 ✓
    scheme_price = 69,788 - 7,000 = 62,788 ✓

  Example B — ₹70,551:
    raw_monthly = 70551 / 10 = 7055  (Liquid integer division)
    remainder   = 7055 % 500 = 55
    remainder > 0 → ceil → 7055 - 55 + 500 = 7500
    7500 × 10 = 75,000 >= 70,551 ✓
    scheme_price = 70,551 - 7,500 = 63,051 ✓

    (Old "nearest" rounding gave 7000 → 70,000 < 70,551 ❌)

  ── DOUBLE-DIVISION FIX ─────────────────────────────────────
  product.price is in PAISE. After dividing by 100 to get rupees,
  multiply × 100 before money_without_currency so the filter
  receives paise and formats correctly. (See Step 4)
  ============================================================
{% endcomment %}

{% comment %} ── Set redirect URL (change to your scheme page) ── {% endcomment %}
{% unless scheme_url %}
  {% assign scheme_url = '/pages/scheme' %}
{% endunless %}

{% comment %} ── Resolve price from selected variant ── {% endcomment %}
{% if variant %}
  {% assign _raw_price = variant.price %}
{% else %}
  {% assign _raw_price = product.selected_or_first_available_variant.price %}
{% endif %}

{% comment %}
  STEP 1 — Convert paise → rupees (integer)
  e.g. 7,055,100 / 100 = 70,551
{% endcomment %}
{% assign _price_rupees = _raw_price | divided_by: 100 %}

{% comment %}
  STEP 2 — CEIL to next ₹500 for monthly installment
  monthly × 10 must always >= product price

  Logic:
    raw_monthly = price / 10   (integer division in Liquid)
    remainder   = raw_monthly % 500
    if remainder == 0 → already exact ₹500 multiple, use as-is
    else              → always round UP: raw - remainder + 500
{% endcomment %}
{% assign _raw_monthly = _price_rupees | divided_by: 10 %}
{% assign _remainder   = _raw_monthly  | modulo: 500 %}

{% if _remainder == 0 %}
  {% assign _monthly = _raw_monthly %}
{% else %}
  {% assign _monthly = _raw_monthly | minus: _remainder | plus: 500 %}
{% endif %}

{% comment %}
  STEP 3 — Effective scheme price (10th month is free — we pay it)
  scheme_price = product_price - monthly_installment
  e.g. 70,551 - 7,500 = 63,051
{% endcomment %}
{% assign _scheme_price = _price_rupees | minus: _monthly %}

{% comment %}
  STEP 4 — Convert back to paise for money_without_currency filter
  63,051 × 100 = 6,305,100 → filter formats as 63,051 ✓
{% endcomment %}
{% assign _scheme_price_paise = _scheme_price | times: 100 %}

{% if _price_rupees > 0 %}
<div class="scheme-btn-wrapper">
  <a
    href="{{ scheme_url }}"
    class="scheme-btn"
  >
    <span class="scheme-btn__text">
      BUY AT
      <strong>&#8377;{{ _scheme_price_paise | money_without_currency | replace: '.00', '' }}</strong>
      WITH SCHEME
    </span>
    <svg width="14" height="14" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2.5"
         aria-hidden="true">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </a>
</div>

<style>
  .scheme-btn-wrapper {
    margin-top: 12px;
    width: 100%;
  }

  .scheme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 13px 24px;
    background: transparent;
    border: 1.5px solid #b8a49a;
    border-radius: 50px;
    cursor: pointer;
    text-decoration: none;
    font-family: inherit;
    font-size: 12px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #5a4a44;
    transition: background 0.2s ease, border-color 0.2s ease;
    box-sizing: border-box;
  }

  .scheme-btn:hover {
    background: #f7f0ee;
    border-color: #8c6b62;
    color: #3d2e28;
    text-decoration: none;
  }

  .scheme-btn__text {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .scheme-btn strong {
    font-weight: 700;
    font-size: 13px;
  }
</style>
{% endif %}
