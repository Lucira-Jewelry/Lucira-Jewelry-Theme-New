{% comment %} ── Resolve price from selected variant ──
{% if variant %}
  {% assign _raw_price = variant.price %}
{% else %}
  {% assign _raw_price = product.selected_or_first_available_variant.price %}
{% endif %}

{% comment %}
  STEP 1 — Convert paise → rupees
{% endcomment %}
{% assign _price_rupees = _raw_price | divided_by: 100 %}

{% comment %}
  STEP 2 — CEIL to next ₹500 (monthly × 10 must always >= product price)
{% endcomment %}
{% assign _raw_monthly = _price_rupees | divided_by: 10 %}
{% assign _remainder   = _raw_monthly  | modulo: 500 %}

{% if _remainder == 0 %}
  {% assign _monthly = _raw_monthly %}
{% else %}
  {% assign _monthly = _raw_monthly | minus: _remainder | plus: 500 %}
{% endif %}

{% comment %}
  STEP 3 — Effective scheme price = product price − free 10th month
{% endcomment %}
{% assign _scheme_price = _price_rupees | minus: _monthly %}

{% comment %}
  STEP 4 — Multiply × 100 before money_without_currency to avoid double-division
{% endcomment %}
{% assign _scheme_price_paise = _scheme_price | times: 100 %}

{% comment %}
  ── Scheme URL builder ────────────────────────────────────────────────
  _monthly is now resolved above (e.g. ₹4,000 = the free 10th month saving).
  Logged-in  → full SSO URL with phone, HMAC signature + &amount=_monthly
  Logged-out → base URL with &amount=_monthly only
{% endcomment %}

{% comment %} ── Step A: Clean & normalise customer phone ── {% endcomment %}
{% assign _raw_phone    = customer.phone | remove: "+" | remove: "-" | remove: " " | remove: "(" | remove: ")" | strip %}
{% if _raw_phone.size == 12 %}
  {% assign _phone_prefix = _raw_phone | slice: 0, 2 %}
  {% if _phone_prefix == "91" %}
    {% assign _clean_phone = _raw_phone | slice: 2, 10 %}
  {% else %}
    {% assign _clean_phone = _raw_phone %}
  {% endif %}
{% else %}
  {% assign _clean_phone = _raw_phone %}
{% endif %}

{% comment %} ── Step B: Build HMAC signature on "phone|timestamp" ── {% endcomment %}
{% assign _ts        = 'now' | date: '%s' %}
{% assign _hmac_data = _clean_phone | append: "|" | append: _ts %}
{% assign _sig       = _hmac_data | hmac_sha256: settings.orn_hmac_secret %}

{% comment %} ── Step C: Compose scheme_url with _monthly as amount ── {% endcomment %}
{% if customer %}
  {% assign scheme_url = 'https://schemes.lucirajewelry.com/api/auth/shopify-sso?p='
    | append: _clean_phone
    | append: '&ts='
    | append: _ts
    | append: '&sig='
    | append: _sig
    | append: '&amount='
    | append: _monthly %}
{% else %}
  {% assign scheme_url = 'https://schemes.lucirajewelry.com/?amount=' | append: _monthly %}
{% endif %}

{% if _price_rupees > 0 %}

{% comment %}
  Pass ALL variant prices as a JSON map so JS can recalculate
  without any extra API calls when the user switches variants.
  Format: { "variant_id": price_in_paise, ... }
{% endcomment %}
{% capture _variant_prices_json %}{
  {% for v in product.variants %}
    "{{ v.id }}": {{ v.price }}{% unless forloop.last %},{% endunless %}
  {% endfor %}
}{% endcapture %}

<div
  class="lucira-scheme-wrapper"
  data-scheme-wrapper
  data-variant-prices='{{ _variant_prices_json }}'
  data-scheme-url="{{ scheme_url }}"
>
  <a
    href="{{ scheme_url }}"
    class="lucira-scheme-btn"
    data-scheme-link
    target="_blank" 
    rel="noopener noreferrer"
  >
    <span class="lucira-scheme-btn__text">
      BUY AT
      <strong
        class="lucira-scheme-btn__price"
        data-scheme-price
      >&#8377;{{ _scheme_price_paise | money_without_currency | replace: '.00', '' }}</strong>
      WITH SCHEME
    </span>
  </a>
</div>

<style>
  /* Wrapper */
  .lucira-scheme-wrapper {
   margin-top: 12px; 
    width: 100%;
  }

  /* Button / link */
  .lucira-scheme-wrapper .lucira-scheme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 12px 24px;
    background: transparent;
    border: 1px solid #A68380;
    border-radius: 12px;
    cursor: pointer;
    text-decoration: none;
    font-family: inherit;
    font-size: 12px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #5a4a44;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    box-sizing: border-box;
  }

  .lucira-scheme-wrapper .lucira-scheme-btn:hover {
    background: #f7f0ee;
    border-color: #8c6b62;
    color: #3d2e28;
    text-decoration: none;
  }

  .lucira-scheme-wrapper .lucira-scheme-btn__text {
    display: flex;
    align-items: center;
    gap: 5px;
    color:#A68380;
    font-size:14px;
    letter-spacing:1px;
  }

  .lucira-scheme-wrapper .lucira-scheme-btn__price {
    font-weight: 600;
    font-size: 14px;
    color:#A68380;
  }

  /* ── Sticky ATC overrides — scoped, won't bleed ── */
  #md-sticky-atc .lucira-scheme-wrapper {
    margin-top: 0;
    width: auto;
    flex-shrink: 0;
  }

  #md-sticky-atc .lucira-scheme-wrapper .lucira-scheme-btn {
    width: auto;
    white-space: nowrap;
    padding: 10px 18px;
    font-size: 11px;
    border-radius: 50px;
  }

@media screen and (max-width:767px){
    .lucira-scheme-wrapper {
    padding: 0 0 10px 0;
    margin-top:0;
  }
  .lucira-scheme-wrapper .lucira-scheme-btn{
  border-radius:8px;
  padding: 11px 24px;
  }
}
</style>

<script>
(function () {
  // ── Avoid registering multiple listeners if snippet renders twice ──
  if (window.__luciraSchemeInit) return;
  window.__luciraSchemeInit = true;

  // ── Core calculation (mirrors Liquid logic exactly) ───────────────
  // pricePaise : number  — variant.price in paise (Shopify native unit)
  // returns    : { schemePrice, monthly } both in rupees
  function calcScheme(pricePaise) {
    var priceRupees = Math.floor(pricePaise / 100);
    var rawMonthly  = Math.floor(priceRupees / 10);
    var remainder   = rawMonthly % 500;
    var monthly     = remainder === 0 ? rawMonthly : rawMonthly - remainder + 500;
    return {
      schemePrice: priceRupees - monthly,
      monthly: monthly
    };
  }

  // Format as en-IN  e.g. 62788 → "62,788"
  function formatINR(amount) {
    return amount.toLocaleString('en-IN');
  }

  // Update every scheme wrapper on the page
  function updateAllWrappers(variantId) {
    document.querySelectorAll('[data-scheme-wrapper]').forEach(function (wrapper) {
      var prices     = JSON.parse(wrapper.dataset.variantPrices || '{}');
      var pricePaise = prices[variantId];
      if (pricePaise === undefined) return;

      var result = calcScheme(pricePaise);

      // Update displayed scheme price on button
      var priceEl = wrapper.querySelector('[data-scheme-price]');
      if (priceEl) {
        priceEl.textContent = '₹' + formatINR(result.schemePrice);
      }

      // ── Keep href in sync with updated _monthly amount ──
      var link = wrapper.querySelector('[data-scheme-link]');
      if (link) {
        // Rebuild the URL: preserve base SSO path, only replace/add &amount=
        var currentHref = link.getAttribute('href') || '';
        var baseUrl     = currentHref.split('&amount=')[0].split('?amount=')[0];
        var separator   = baseUrl.indexOf('?') !== -1 ? '&' : '?';
        link.href       = baseUrl + separator + 'amount=' + result.monthly;
      }
    });
  }

  // ── Event listeners for variant change ────────────────────────────

  // 1. Shopify native variant:change (most custom themes)
  document.addEventListener('variant:change', function (e) {
    var variant = e.detail && e.detail.variant;
    if (variant && variant.id && variant.price !== undefined) {
      updateAllWrappers(String(variant.id));
    }
  });

  // 2. Dawn / Prestige style
  document.addEventListener('variant:changed', function (e) {
    var variant = e.detail && e.detail.variant;
    if (variant && variant.id && variant.price !== undefined) {
      updateAllWrappers(String(variant.id));
    }
  });

  // 3. Fallback — watch the hidden variant ID input in the main product form
  document.addEventListener('DOMContentLoaded', function () {
    var mainForm = document.querySelector('.product-form form[action*="/cart/add"]');
    if (!mainForm) return;

    var variantInput = mainForm.querySelector('input[name="id"]');
    if (!variantInput) return;

    new MutationObserver(function () {
      if (variantInput.value) updateAllWrappers(variantInput.value);
    }).observe(variantInput, { attributes: true, attributeFilter: ['value'] });

    variantInput.addEventListener('change', function () {
      if (this.value) updateAllWrappers(this.value);
    });

    mainForm.addEventListener('change', function (e) {
      if (e.target.name === 'id' && e.target.value) {
        updateAllWrappers(e.target.value);
      }
    });
  });
})();
</script>

{% endif %} {% endcomment %}


{% comment %}
  ============================================================
  Snippet: scheme-button.liquid
  ------------------------------------------------------------
  Place this file in: snippets/scheme-button.liquid

  Render in main-product.liquid (below Add to Cart):
    {% render 'scheme-button', product: product %}

  Or pass a variant price:
    {% render 'scheme-button', product: product, variant: product.selected_or_first_available_variant %}

  ============================================================
  9+1 SCHEME LOGIC (all Liquid, runs server-side)
  ------------------------------------------------------------
  1. product.price is in paise (Shopify minor unit), divide by 100 → rupees
  2. raw_monthly  = price_rupees / 10         (integer division)
  3. remainder    = raw_monthly mod 500
  4. if remainder >= 250  → round UP   to next ₹500
     else                 → round DOWN to prev ₹500
  5. scheme_price = price_rupees - monthly    (10th month is free)
  ============================================================
{% endcomment %}

{% comment %} ── 1. Resolve price source ── {% endcomment %}
{% if variant %}
  {% assign _raw_price = variant.price %}
{% else %}
  {% assign _raw_price = product.selected_or_first_available_variant.price %}
{% endif %}

{% comment %} ── 2. Convert paise → rupees (integer) ── {% endcomment %}
{% assign _price_rupees = _raw_price | divided_by: 100 %}

{% comment %} ── 3. Find nearest ₹500 monthly installment ── {% endcomment %}
{% assign _raw_monthly  = _price_rupees | divided_by: 10 %}
{% assign _remainder    = _raw_monthly  | modulo: 500 %}

{% if _remainder >= 250 %}
  {% assign _monthly = _raw_monthly | minus: _remainder | plus: 500 %}
{% else %}
  {% assign _monthly = _raw_monthly | minus: _remainder %}
{% endif %}

{% comment %} ── 4. Effective scheme price ── {% endcomment %}
{% assign _scheme_price = _price_rupees | minus: _monthly %}

{% comment %} ── 5. Render only if scheme makes sense (price > 0) ── {% endcomment %}
{% if _price_rupees > 0 %}

<div class="scheme-btn-wrapper" data-scheme-wrapper>

  <button
    class="scheme-btn"
    type="button"
    aria-expanded="false"
    aria-controls="scheme-breakdown"
    data-scheme-price="{{ _scheme_price }}"
    data-monthly="{{ _monthly }}"
    data-product-price="{{ _price_rupees }}"
  >
    <span class="scheme-btn__label">
      BUY AT
      <strong class="scheme-btn__price">
        &#8377;{{ _scheme_price | money_without_currency | replace: '.00', '' }}
      </strong>
      WITH SCHEME
    </span>
    <svg class="scheme-btn__chevron" width="14" height="14" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2.5"
         aria-hidden="true">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </button>

  <div class="scheme-breakdown" id="scheme-breakdown" aria-hidden="true" hidden>
    <p class="scheme-breakdown__title">9 + 1 Scheme Breakdown</p>
    <table class="scheme-breakdown__table">
      <tbody>
        <tr>
          <td>Product Price (MRP)</td>
          <td>&#8377;{{ _price_rupees | money_without_currency | replace: '.00', '' }}</td>
        </tr>
        <tr>
          <td>Monthly Installment</td>
          <td>&#8377;{{ _monthly | money_without_currency | replace: '.00', '' }} &times; 9 months</td>
        </tr>
        <tr>
          <td>You Pay (9 months)</td>
          {% assign _total_paid = _monthly | times: 9 %}
          <td>&#8377;{{ _total_paid | money_without_currency | replace: '.00', '' }}</td>
        </tr>
        <tr class="scheme-breakdown__free-row">
          <td>10th Month <span class="scheme-breakdown__badge">FREE</span></td>
          <td class="scheme-breakdown__saving">&minus; &#8377;{{ _monthly | money_without_currency | replace: '.00', '' }}</td>
        </tr>
        <tr class="scheme-breakdown__divider"><td colspan="2"></td></tr>
        <tr class="scheme-breakdown__total">
          <td>Effective Price</td>
          <td>&#8377;{{ _scheme_price | money_without_currency | replace: '.00', '' }}</td>
        </tr>
        <tr class="scheme-breakdown__save-row">
          <td>You Save</td>
          <td class="scheme-breakdown__save-amount">&#8377;{{ _monthly | money_without_currency | replace: '.00', '' }}</td>
        </tr>
      </tbody>
    </table>
  </div>

</div>

<style>
  /* ── Wrapper ── */
  .scheme-btn-wrapper {
    margin-top: 12px;
    width: 100%;
  }

  /* ── Button ── */
  .scheme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 13px 24px;
    background: transparent;
    border: 1.5px solid #b8a49a;
    border-radius: 50px;
    cursor: pointer;
    font-family: inherit;
    font-size: 12px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #5a4a44;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .scheme-btn:hover {
    background: #f7f0ee;
    border-color: #8c6b62;
    color: #3d2e28;
  }

  .scheme-btn__label {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .scheme-btn__price {
    font-weight: 700;
    font-size: 13px;
  }

  .scheme-btn__chevron {
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  .scheme-btn[aria-expanded="true"] .scheme-btn__chevron {
    transform: rotate(180deg);
  }

  /* ── Breakdown panel ── */
  .scheme-breakdown {
    margin-top: 10px;
    padding: 16px 20px;
    border: 1px solid #e4d8d3;
    border-radius: 12px;
    background: #fdfaf9;
    animation: scheme-fadeIn 0.2s ease;
  }

  @keyframes scheme-fadeIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .scheme-breakdown__title {
    margin: 0 0 12px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #3d2e28;
  }

  .scheme-breakdown__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12.5px;
    color: #5a4a44;
  }

  .scheme-breakdown__table td {
    padding: 5px 0;
    vertical-align: middle;
  }

  .scheme-breakdown__table td:last-child {
    text-align: right;
    font-weight: 600;
  }

  .scheme-breakdown__table td:first-child {
    color: #7a6a64;
  }

  .scheme-breakdown__free-row td:first-child {
    color: #9b7d6f;
  }

  .scheme-breakdown__badge {
    display: inline-block;
    margin-left: 6px;
    padding: 1px 7px;
    background: #e8f4e8;
    color: #4a8c4a;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.05em;
    vertical-align: middle;
  }

  .scheme-breakdown__saving {
    color: #c0826d !important;
    font-weight: 700 !important;
  }

  .scheme-breakdown__divider td {
    border-top: 1px solid #e0d4cf;
    padding-top: 10px !important;
  }

  .scheme-breakdown__total td {
    padding-top: 6px;
    font-size: 14px;
    font-weight: 700 !important;
    color: #3d2e28 !important;
  }

  .scheme-breakdown__total td:last-child {
    color: #8c6b62 !important;
    font-size: 15px;
  }

  .scheme-breakdown__save-row td {
    padding-top: 4px;
    font-size: 11.5px;
    color: #a89490 !important;
    font-weight: 400 !important;
  }

  .scheme-breakdown__save-amount {
    color: #4a8c4a !important;
    font-weight: 600 !important;
  }
</style>

<script>
  (function () {
    // Toggle breakdown panel
    document.querySelectorAll('[data-scheme-wrapper]').forEach(function (wrapper) {
      var btn       = wrapper.querySelector('.scheme-btn');
      var breakdown = wrapper.querySelector('.scheme-breakdown');
      if (!btn || !breakdown) return;

      btn.addEventListener('click', function () {
        var isOpen = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!isOpen));
        breakdown.hidden = isOpen;
        breakdown.setAttribute('aria-hidden', String(isOpen));
