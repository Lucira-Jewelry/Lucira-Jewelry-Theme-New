{% comment %} {% if variant %}
  {% assign _raw_price = variant.price %}
{% else %}
  {% assign _raw_price = product.selected_or_first_available_variant.price %}
{% endif %}

{% comment %}
  STEP 1 — Convert paise → rupees
{% endcomment %}
{% assign _price_rupees = _raw_price | divided_by: 100 %}

{% comment %}
  STEP 2 — FLOOR to previous ₹500 (monthly × 10 may be <= product price)
{% endcomment %}
{% assign _raw_monthly = _price_rupees | divided_by: 10 %}
{% assign _remainder   = _raw_monthly  | modulo: 500 %}
{% assign _monthly     = _raw_monthly  | minus: _remainder %}

{% comment %}
  STEP 3 — Effective scheme price = product price − free 10th month
{% endcomment %}
{% assign _scheme_price = _price_rupees | minus: _monthly %}

{% comment %}
  STEP 4 — Multiply × 100 before money_without_currency to avoid double-division
{% endcomment %}
{% assign _scheme_price_paise = _scheme_price | times: 100 %}

{% comment %}
  ── Scheme URL builder ────────────────────────────────────────────────
  _monthly is now resolved above (e.g. ₹3,500 = the free 10th month saving).
  Logged-in  → full SSO URL with phone, HMAC signature + &amount=_monthly
  Logged-out → base URL with &amount=_monthly only
{% endcomment %}

{% comment %} ── Step A: Clean & normalise customer phone ── {% endcomment %}
{% assign _raw_phone    = customer.phone | remove: "+" | remove: "-" | remove: " " | remove: "(" | remove: ")" | strip %}
{% if _raw_phone.size == 12 %}
  {% assign _phone_prefix = _raw_phone | slice: 0, 2 %}
  {% if _phone_prefix == "91" %}
    {% assign _clean_phone = _raw_phone | slice: 2, 10 %}
  {% else %}
    {% assign _clean_phone = _raw_phone %}
  {% endif %}
{% else %}
  {% assign _clean_phone = _raw_phone %}
{% endif %}

{% comment %} ── Step B: Build HMAC signature on "phone|timestamp" ── {% endcomment %}
{% assign _ts        = 'now' | date: '%s' %}
{% assign _hmac_data = _clean_phone | append: "|" | append: _ts %}
{% assign _sig       = _hmac_data | hmac_sha256: settings.orn_hmac_secret %}

{% comment %} ── Step C: Compose scheme_url with _monthly as amount ── {% endcomment %}
{% if customer %}
  {% assign scheme_url = 'https://schemes.lucirajewelry.com/api/auth/shopify-sso?p='
    | append: _clean_phone
    | append: '&ts='
    | append: _ts
    | append: '&sig='
    | append: _sig
    | append: '&amount='
    | append: _monthly %}
{% else %}
  {% assign scheme_url = 'https://schemes.lucirajewelry.com/?amount=' | append: _monthly %}
{% endif %}

{% if _price_rupees > 0 %}

{% comment %}
  Pass ALL variant prices as a JSON map so JS can recalculate
  without any extra API calls when the user switches variants.
  Format: { "variant_id": price_in_paise, ... }
{% endcomment %}
{% capture _variant_prices_json %}{
  {% for v in product.variants %}
    "{{ v.id }}": {{ v.price }}{% unless forloop.last %},{% endunless %}
  {% endfor %}
}{% endcapture %}

<div
  class="lucira-scheme-wrapper"
  data-scheme-wrapper
  data-variant-prices='{{ _variant_prices_json }}'
  data-scheme-url="{{ scheme_url }}"
>
  <a
