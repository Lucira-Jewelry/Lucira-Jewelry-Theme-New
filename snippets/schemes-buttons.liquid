{% comment %}
  ============================================================
  Snippet: scheme-button.liquid
  Save to: snippets/scheme-button.liquid

  Usage in main-product.liquid (below Add to Cart):
    {% render 'scheme-button', product: product %}

  To pass a custom redirect URL:
    {% render 'scheme-button', product: product, scheme_url: '/pages/scheme' %}

  ── BUG FIX: Double division by 100 ────────────────────────
  product.price = paise  (₹69,788 stored as 6,978,800)
  After divided_by: 100  → _scheme_price is in RUPEES (62788)
  money_without_currency → divides by 100 again → ₹627.88 ❌

  FIX: multiply _scheme_price × 100 back to paise BEFORE
       passing to money_without_currency filter          ✓
  ============================================================
{% endcomment %}

{% comment %} ── Set redirect URL (change to your scheme page) ── {% endcomment %}
{% unless scheme_url %}
  {% assign scheme_url = '/pages/scheme' %}
{% endunless %}

{% comment %} ── Resolve price from selected variant ── {% endcomment %}
{% if variant %}
  {% assign _raw_price = variant.price %}
{% else %}
  {% assign _raw_price = product.selected_or_first_available_variant.price %}
{% endif %}

{% comment %}
  STEP 1 — Convert paise → rupees
  e.g. 6,978,800 / 100 = 69,788
{% endcomment %}
{% assign _price_rupees = _raw_price | divided_by: 100 %}

{% comment %}
  STEP 2 — Find nearest ₹500 monthly installment (9+1 scheme)
  raw_monthly = 69788 / 10 = 6978
  remainder   = 6978 % 500 = 478
  478 >= 250  → round UP → 6978 - 478 + 500 = 7000 ✓
{% endcomment %}
{% assign _raw_monthly = _price_rupees | divided_by: 10 %}
{% assign _remainder   = _raw_monthly  | modulo: 500 %}

{% if _remainder >= 250 %}
  {% assign _monthly = _raw_monthly | minus: _remainder | plus: 500 %}
{% else %}
  {% assign _monthly = _raw_monthly | minus: _remainder %}
{% endif %}

{% comment %}
  STEP 3 — Effective scheme price (user saves the 10th month)
  69788 - 7000 = 62788
{% endcomment %}
{% assign _scheme_price = _price_rupees | minus: _monthly %}

{% comment %}
  STEP 4 — Convert back to paise for money_without_currency filter
  62788 × 100 = 6,278,800 paise → filter formats as 62,788 ✓
{% endcomment %}
{% assign _scheme_price_paise = _scheme_price | times: 100 %}

{% if _price_rupees > 0 %}
<div class="scheme-btn-wrapper">
  <a
    href="{{ scheme_url }}"
    class="scheme-btn"
  >
    <span class="scheme-btn__text">
      BUY AT
      <strong>&#8377;{{ _scheme_price_paise | money_without_currency | replace: '.00', '' }}</strong>
      WITH SCHEME
    </span>
    <svg width="14" height="14" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2.5"
         aria-hidden="true">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </a>
</div>

<style>
  .scheme-btn-wrapper {
    margin-top: 12px;
    width: 100%;
  }

  .scheme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 13px 24px;
    background: transparent;
    border: 1.5px solid #b8a49a;
    border-radius: 50px;
    cursor: pointer;
    text-decoration: none;
    font-family: inherit;
    font-size: 12px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #5a4a44;
    transition: background 0.2s ease, border-color 0.2s ease;
    box-sizing: border-box;
  }

  .scheme-btn:hover {
    background: #f7f0ee;
    border-color: #8c6b62;
    color: #3d2e28;
    text-decoration: none;
  }

  .scheme-btn__text {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .scheme-btn strong {
    font-weight: 700;
    font-size: 13px;
  }
</style>
{% endif %}
