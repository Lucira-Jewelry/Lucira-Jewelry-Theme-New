<style>
  /* Wrapper */
  .lucira-scheme-wrapper {
   margin-top: 12px; 
    width: 100%;
  }

  /* Button / link */
  .lucira-scheme-wrapper .lucira-scheme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 12px 24px;
    background: transparent;
    border: 1px solid #A68380;
