{% comment %}
  ============================================================
  Snippet: scheme-button.liquid
  Save to: snippets/scheme-button.liquid

  Usage in main-product.liquid (below Add to Cart):
    {% render 'scheme-button', product: product %}

  With custom redirect:
    {% render 'scheme-button', product: product, scheme_url: '/pages/scheme' %}
  ============================================================
{% endcomment %}

{% comment %} ── Redirect URL ── {% endcomment %}
{% unless scheme_url %}
  {% assign scheme_url = 'https://schemes.lucirajewelry.com/' %}
{% endunless %}

{% comment %} ── Resolve price from selected variant ── {% endcomment %}
{% if variant %}
  {% assign _raw_price = variant.price %}
{% else %}
  {% assign _raw_price = product.selected_or_first_available_variant.price %}
{% endif %}

{% comment %}
  STEP 1 — Convert paise → rupees
{% endcomment %}
{% assign _price_rupees = _raw_price | divided_by: 100 %}

{% comment %}
  STEP 2 — CEIL to next ₹500 (monthly × 10 must always >= product price)
{% endcomment %}
{% assign _raw_monthly = _price_rupees | divided_by: 10 %}
{% assign _remainder   = _raw_monthly  | modulo: 500 %}

{% if _remainder == 0 %}
  {% assign _monthly = _raw_monthly %}
{% else %}
  {% assign _monthly = _raw_monthly | minus: _remainder | plus: 500 %}
{% endif %}

{% comment %}
  STEP 3 — Effective scheme price = product price − free 10th month
{% endcomment %}
{% assign _scheme_price = _price_rupees | minus: _monthly %}

{% comment %}
  STEP 4 — Multiply × 100 before money_without_currency to avoid double-division
{% endcomment %}
{% assign _scheme_price_paise = _scheme_price | times: 100 %}

{% if _price_rupees > 0 %}

{% comment %}
  Pass ALL variant prices as a JSON map so JS can recalculate
  without any extra API calls when the user switches variants.
  Format: { "variant_id": price_in_paise, ... }
{% endcomment %}
{% capture _variant_prices_json %}{
  {% for v in product.variants %}
    "{{ v.id }}": {{ v.price }}{% unless forloop.last %},{% endunless %}
  {% endfor %}
}{% endcapture %}

<div
  class="lucira-scheme-wrapper"
  data-scheme-wrapper
  data-variant-prices='{{ _variant_prices_json }}'
  data-scheme-url="{{ scheme_url }}"
>
  <a
    href="{{ scheme_url }}"
    class="lucira-scheme-btn"
    data-scheme-link
  >
    <span class="lucira-scheme-btn__text">
      BUY AT
      <strong
        class="lucira-scheme-btn__price"
        data-scheme-price
      >&#8377;{{ _scheme_price_paise | money_without_currency | replace: '.00', '' }}</strong>
      WITH SCHEME
    </span>
    {% comment %} <svg width="14" height="14" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2.5"
         aria-hidden="true">
      <polyline points="9 18 15 12 9 6"/>
    </svg> {% endcomment %}
  </a>
</div>

{% comment %} ── Scoped CSS — all rules prefixed with .lucira-scheme-wrapper ── {% endcomment %}
<style>
  /* Wrapper */
  .lucira-scheme-wrapper {
   margin-top: 12px; 
    width: 100%;
  }

  /* Button / link */
  .lucira-scheme-wrapper .lucira-scheme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 12px 24px;
    background: transparent;
    border: 1.5px solid #A68380;
    border-radius: 12px;
    cursor: pointer;
    text-decoration: none;
    font-family: inherit;
    font-size: 12px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #5a4a44;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    box-sizing: border-box;
  }

  .lucira-scheme-wrapper .lucira-scheme-btn:hover {
    background: #f7f0ee;
    border-color: #8c6b62;
    color: #3d2e28;
    text-decoration: none;
  }

  .lucira-scheme-wrapper .lucira-scheme-btn__text {
    display: flex;
    align-items: center;
    gap: 5px;
    color:#A68380;
  }

  .lucira-scheme-wrapper .lucira-scheme-btn__price {
    font-weight: 600;
    font-size: 12px;
    color:#A68380;
  }

  /* ── Sticky ATC overrides — scoped, won't bleed ── */
  #md-sticky-atc .lucira-scheme-wrapper {
    margin-top: 0;
    width: auto;
    flex-shrink: 0;
  }

  #md-sticky-atc .lucira-scheme-wrapper .lucira-scheme-btn {
    width: auto;
    white-space: nowrap;
    padding: 10px 18px;
    font-size: 11px;
    border-radius: 50px;
  }

@media screen and (max-width:767px){
    .lucira-scheme-wrapper {
    padding: 12px 1.5rem;
    margin-top:0;
  }
}
</style>

<script>
(function () {
  // ── Avoid registering multiple listeners if snippet renders twice ──
  if (window.__luciraSchemeInit) return;
  window.__luciraSchemeInit = true;

  // ── Core calculation (mirrors Liquid logic exactly) ───────────────
  // pricePaise : number  — variant.price in paise (Shopify native unit)
  // returns    : number  — scheme price in RUPEES
  function calcSchemePrice(pricePaise) {
    var priceRupees = Math.floor(pricePaise / 100);
    var rawMonthly  = Math.floor(priceRupees / 10);
    var remainder   = rawMonthly % 500;
    var monthly     = remainder === 0 ? rawMonthly : rawMonthly - remainder + 500;
    return priceRupees - monthly;
  }

  // Format as en-IN  e.g. 62788 → "62,788"
  function formatINR(amount) {
    return amount.toLocaleString('en-IN');
  }

  // Update every scheme wrapper on the page
  function updateAllWrappers(variantId) {
    document.querySelectorAll('[data-scheme-wrapper]').forEach(function (wrapper) {
      var prices     = JSON.parse(wrapper.dataset.variantPrices || '{}');
      var pricePaise = prices[variantId];
      if (pricePaise === undefined) return;

      var schemePrice = calcSchemePrice(pricePaise);

      // Update displayed price
      var priceEl = wrapper.querySelector('[data-scheme-price]');
      if (priceEl) {
        priceEl.textContent = '₹' + formatINR(schemePrice);
      }

      // Keep href in sync (optional — appends price as query param for landing page)
      // var link = wrapper.querySelector('[data-scheme-link]');
      // if (link) {
      //   var base = wrapper.dataset.schemeUrl || link.href.split('?')[0];
      //   link.href = base + '?scheme_price=' + schemePrice + '&variant=' + variantId;
      // }
    });
  }

  // ── Event listeners for variant change ────────────────────────────
  // Covers: Dawn, Debut, custom themes, Prestige, Symmetry etc.

  // 1. Shopify native variant:change (most custom themes)
  document.addEventListener('variant:change', function (e) {
    var variant = e.detail && e.detail.variant;
    if (variant && variant.id && variant.price !== undefined) {
      updateAllWrappers(String(variant.id));
    }
  });

  // 2. Dawn / Prestige style
  document.addEventListener('variant:changed', function (e) {
    var variant = e.detail && e.detail.variant;
    if (variant && variant.id && variant.price !== undefined) {
      updateAllWrappers(String(variant.id));
    }
  });

  // 3. Fallback — watch the hidden variant ID input in the main product form
  //    Fires when any JS (including theme's native variant picker) changes the value.
  document.addEventListener('DOMContentLoaded', function () {
    var mainForm = document.querySelector('.product-form form[action*="/cart/add"]');
    if (!mainForm) return;

    var variantInput = mainForm.querySelector('input[name="id"]');
    if (!variantInput) return;

    // Use MutationObserver to catch programmatic value changes
    new MutationObserver(function () {
      if (variantInput.value) updateAllWrappers(variantInput.value);
    }).observe(variantInput, { attributes: true, attributeFilter: ['value'] });

    // Also catch direct change events (select[name="id"] fallback)
    variantInput.addEventListener('change', function () {
      if (this.value) updateAllWrappers(this.value);
    });

    mainForm.addEventListener('change', function (e) {
      if (e.target.name === 'id' && e.target.value) {
        updateAllWrappers(e.target.value);
      }
    });
  });
})();
</script>

{% endif %}
{% comment %} End scheme-button.liquid {% endcomment %}
