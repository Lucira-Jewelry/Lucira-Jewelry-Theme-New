    }

    /* Specific styles for second button container to override default button styles */
    #second-tryon-button-1 #tryonButton,
    #virtual-try-on-content #tryonButton {
        position: static !important;
        width: auto !important;
        height: auto !important;
        min-width: auto !important;
        min-height: auto !important;
        max-width: none !important;
        max-height: none !important;
        margin: 0 !important;
        padding: 10px 20px !important;
        display: inline-block !important;
        z-index: 1 !important;
    }

    /* Hide any default content */
    #tryonButton > *:not(.tryon-button-wrapper):not(.tryon-text-only) {
        display: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
    }

    /* Force hide any pseudo elements */
    #tryonButton::before,
    #tryonButton::after {
        display: none !important;
        content: none !important;
    }

    /* Mobile specific styles with higher specificity */
    @media (max-width: 768px) {
        .tryon-absolute-wrapper {
            top: 10px !important;
            left: 10px !important;
        }

        button#tryonButton,
        button[id="tryonButton"],
        #tryonButton {
            position: relative !important;
            width: 30px !important;
            height: 30px !important;
            left: 0 !important;
            top: 0 !important;
            margin: 0 !important;
            z-index: 9999 !important;
            display: block !important;
            visibility: visible !important;
            opacity: 1 !important;
            pointer-events: auto !important;
        }

        .tryon-button-wrapper {
            width: 30px !important;
            height: 30px !important;
            display: block !important;
            visibility: visible !important;
            opacity: 1 !important;
            z-index: 9999 !important;
