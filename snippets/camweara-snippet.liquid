<style>
    .tryon-button-wrapper {
        position: relative;
        width: 54px;
        height: 54px;
    }

    .tryon-button-container {
        position: absolute;
        left: 0;
        top: 0;
        width: 54px;
        height: 54px;
        overflow: visible;
    }

    .tryon-sliding-panel {
        position: absolute;
        left: 0;
        top: 0;
        height: 54px;
        background: #F4F0F0;
        border-radius: 27px;
        display: flex;
        align-items: center;
        padding-left: 64px;
        padding-right: 20px;
        border: 0.75px solid #000;
        width: 200px;
        clip-path: circle(27px at 27px 27px);
        transition: clip-path 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        z-index: 1;
        cursor: pointer;
    }

    .tryon-sliding-panel.expanded {
        clip-path: circle(150% at 27px 27px);
    }

    .tryon-icon-circle {
        position: absolute;
        left: 0;
        top: 0;
        width: 54px;
        height: 54px;
        cursor: pointer;
        z-index: 3;
    }

    .tryon-icon-circle svg {
        width: 100%;
        height: 100%;
        display: block;
    }

    .tryon-text-content {
        opacity: 0;
        transition: opacity 0.3s ease;
        white-space: nowrap;
    }

    .tryon-sliding-panel.expanded .tryon-text-content {
        opacity: 1;
        transition-delay: 0.25s;
    }

    .tryon-text-content span {
        font-size: 16px;
        font-weight: 500;
        color: #000;
        letter-spacing: 0.3px;
        font-family: 'Futura Std', 'Futura', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    /* For the second tryon button */
    #second-tryon-button .tryon-button-wrapper {
        position: static;
        margin: 0 auto;
    }
    
    #second-tryon-button .tryon-button-container {
        position: relative;
        margin: 0 auto;
    }
</style>

<script src="{{ 'camweara-api.js' | asset_url }}" async></script>

<script>
  function initTryOnButton() {
    if (typeof loadTryOnButton !== "function") {
      setTimeout(initTryOnButton, 100);
      return;
    }

    // Create animated button structure
    function createAnimatedButton() {
      const buttonWrapper = document.createElement('div');
      buttonWrapper.className = 'tryon-button-wrapper';
      
      const buttonContainer = document.createElement('div');
      buttonContainer.className = 'tryon-button-container';
      
      const slidingPanel = document.createElement('div');
      slidingPanel.className = 'tryon-sliding-panel';
      slidingPanel.id = 'animatedTryOnPanel';
      
      const textContent = document.createElement('div');
      textContent.className = 'tryon-text-content';
      textContent.innerHTML = '<span>Try Them On</span>';
      
      const iconCircle = document.createElement('div');
      iconCircle.className = 'tryon-icon-circle';
      iconCircle.innerHTML = `
        <svg width="54" height="54" viewBox="0 0 54 54" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="0.375" y="0.375" width="53.2501" height="53.25" rx="26.625" fill="white" fill-opacity="0.2"/>
            <rect x="0.375" y="0.375" width="53.2501" height="53.25" rx="26.625" stroke="black" stroke-width="0.75"/>
            <path d="M16.125 22.5982L19.3256 19.4557M16.125 22.5982L26.7547 36M16.125 22.5982L22.1758 25.0244M19.3256 19.4557L22.9 18H31.0767L35.2117 19.4557M19.3256 19.4557L23.3906 20.9114M35.2117 19.4557L37.875 22.5982M35.2117 19.4557L30.8898 20.9114M37.875 22.5982L26.7547 36M37.875 22.5982L31.9644 25.0244M26.7547 36L31.9644 25.0244M26.7547 36L22.1758 25.0244M31.9644 25.0244L30.8898 20.9114M31.9644 25.0244H22.1758M30.8898 20.9114H23.3906M23.3906 20.9114L22.1758 25.0244" stroke="black" stroke-width="1.24143"/>
            <rect x="12" y="33" width="0.75" height="9" fill="black"/>
            <rect x="12" y="42" width="0.75" height="9" transform="rotate(-90 12 42)" fill="black"/>
            <rect width="0.75" height="9" transform="matrix(1 0 0 -1 11.9999 21)" fill="black"/>
            <rect width="0.75" height="9" transform="matrix(0 1 1 0 12 12)" fill="black"/>
            <rect x="42.0001" y="21" width="0.75" height="9" transform="rotate(180 42.0001 21)" fill="black"/>
            <rect x="42" y="12" width="0.75" height="9" transform="rotate(90 42 12)" fill="black"/>
            <rect width="0.75" height="9" transform="matrix(-1 0 0 1 42 33)" fill="black"/>
            <rect width="0.75" height="9" transform="matrix(0 -1 -1 0 42 42)" fill="black"/>
        </svg>
      `;
      
      slidingPanel.appendChild(textContent);
      buttonContainer.appendChild(slidingPanel);
      buttonContainer.appendChild(iconCircle);
      buttonWrapper.appendChild(buttonContainer);
      
      return { wrapper: buttonWrapper, panel: slidingPanel };
    }

    // Function to start animation
    function startButtonAnimation(panel) {
      if (!panel) return;
      
      function animateButton() {
        panel.classList.add('expanded');
        
        setTimeout(() => {
          panel.classList.remove('expanded');
        }, 2000);
      }
      
      // Start animation after delay
      setTimeout(() => {
        animateButton();
        
        // Repeat animation
        setInterval(() => {
          animateButton();
        }, 4000);
      }, 1000);
      
      // Add click handler
      panel.addEventListener('click', function(e) {
        e.stopPropagation();
        // This will be handled by the loadTryOnButton callback
        console.log('Try on button clicked');
      });
    }

    loadTryOnButton({
      psku: "{{ sku_tryon_pdp }}",
      page: "product",
      regionId: "2",
      company: "luciraonline",
      prependButton: {
        class: "product__media-list contains-media grid grid--peek list-unstyled"
      },
      MBprependButton: {
        class: "product__media-list contains-media grid grid--peek list-unstyled"
      },
      styles: {
        tryonbutton: {
          display: "none" // Hide default button since we're using custom
        },
        MBtryonbutton: {
          display: "none" // Hide default mobile button
        }
      },
      prodRecommendation: "true",
      buynowCallback: "onTryOnBuynowclick",
      tryonButtonData: {
        text: "Try Them On",
        faIcon: "fa fa-camera"
      },
      buynow: {
        enable: "{{ is_product_available }}"
      },
      // Custom button injection
      customButton: true,
      onButtonLoad: function() {
        // Find where the button should be placed
        const buttonTarget = document.querySelector('.product__media-list.contains-media');
        if (buttonTarget) {
          const { wrapper, panel } = createAnimatedButton();
          
          // Insert at the beginning of the media list
          buttonTarget.insertBefore(wrapper, buttonTarget.firstChild);
          
          // Start animation
          startButtonAnimation(panel);
        }
      }
    });

    // Code for the second try on button which is below the add to cart
    getSkusListWithTryOn({companyName: 'luciraonline', regionId:'2'})
      .then((skusList) => {
        console.log("all skus", skusList);
        if (skusList.includes(productSKUTryOn)){
          const secondButtonContainer = document.getElementById("second-tryon-button");
          const tryOnContent = document.getElementById("virtual-try-on-content");
          
          if (secondButtonContainer && tryOnContent) {
            secondButtonContainer.style.display = "block";
            tryOnContent.style.display = "flex";
            
            // Create animated button for second position
            const { wrapper, panel } = createAnimatedButton();
            secondButtonContainer.innerHTML = '';
            secondButtonContainer.appendChild(wrapper);
            
            // Start animation
            startButtonAnimation(panel);
            
            // Add click handler for second button
            panel.addEventListener('click', function() {
              // Trigger the try-on functionality
              console.log('Second try-on button clicked');
              // You might want to trigger the same functionality as the first button
            });
          }
        }
      });
  }

  document.addEventListener("DOMContentLoaded", initTryOnButton);
</script>