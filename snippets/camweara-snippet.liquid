            <path d="M16.125 22.5982L19.3256 19.4557M16.125 22.5982L26.7547 36M16.125 22.5982L22.1758 25.0244M19.3256 19.4557L22.9 18H31.0767L35.2117 19.4557M19.3256 19.4557L23.3906 20.9114M35.2117 19.4557L37.875 22.5982M35.2117 19.4557L30.8898 20.9114M37.875 22.5982L26.7547 36M37.875 22.5982L31.9644 25.0244M26.7547 36L31.9644 25.0244M26.7547 36L22.1758 25.0244M31.9644 25.0244L30.8898 20.9114M31.9644 25.0244H22.1758M30.8898 20.9114H23.3906M23.3906 20.9114L22.1758 25.0244" stroke="black" stroke-width="1.24143"/>
            <rect x="12" y="33" width="0.75" height="9" fill="black"/>
            <rect x="12" y="42" width="0.75" height="9" transform="rotate(-90 12 42)" fill="black"/>
            <rect width="0.75" height="9" transform="matrix(1 0 0 -1 11.9999 21)" fill="black"/>
            <rect width="0.75" height="9" transform="matrix(0 1 1 0 12 12)" fill="black"/>
            <rect x="42.0001" y="21" width="0.75" height="9" transform="rotate(180 42.0001 21)" fill="black"/>
            <rect x="42" y="12" width="0.75" height="9" transform="rotate(90 42 12)" fill="black"/>
            <rect width="0.75" height="9" transform="matrix(-1 0 0 1 42 33)" fill="black"/>
            <rect width="0.75" height="9" transform="matrix(0 -1 -1 0 42 42)" fill="black"/>
        </svg>
      `;
      
      slidingPanel.appendChild(textContent);
      buttonContainer.appendChild(slidingPanel);
      buttonContainer.appendChild(iconCircle);
      buttonWrapper.appendChild(buttonContainer);
      
      // Clear existing content and add animated button
      tryonButton.innerHTML = '';
      tryonButton.appendChild(buttonWrapper);
      
      // Mark as transformed
      tryonButton.classList.add('tryon-button-transformed');
      
      // If it's a mobile button, add the mobile class
      if (isMobileButton) {
        tryonButton.classList.add('MBtryonbutton');
        // Also add inline styles for mobile
        tryonButton.style.width = '40px';
        tryonButton.style.height = '40px';
        tryonButton.style.minWidth = '40px';
        tryonButton.style.minHeight = '40px';
        tryonButton.style.left = '10px';
        tryonButton.style.margin = '8px';
      }
      
      // Restore the original onclick handler to the new elements
      if (originalOnClick) {
        slidingPanel.onclick = originalOnClick;
        iconCircle.onclick = originalOnClick;
      } else {
        // If no onclick, find and preserve any event listeners
        const originalButton = tryonButton.cloneNode(true);
        const clickEvent = originalButton.onclick;
        if (clickEvent) {
          slidingPanel.onclick = clickEvent;
          iconCircle.onclick = clickEvent;
        }
      }
      
      // Start animation
      startButtonAnimation(slidingPanel);
    }

    // Function to start animation
    function startButtonAnimation(panel) {
      if (!panel) return;
      
      function animateButton() {
        panel.classList.add('expanded');
        
        setTimeout(() => {
          panel.classList.remove('expanded');
        }, 2000);
      }
      
      // Start animation after delay
      setTimeout(() => {
        animateButton();
        
        // Repeat animation
        setInterval(() => {
          animateButton();
        }, 4000);
      }, 1000);
    }

    // Transform the tryonButton after it's loaded
    setTimeout(transformTryOnButton, 500);
    
    // Also check for mobile button after a delay
    setTimeout(() => {
      const tryonButton = document.getElementById('tryonButton');
      if (tryonButton && !tryonButton.classList.contains('tryon-button-transformed')) {
        transformTryOnButton();
      }
    }, 1000);

    // Handle window resize
    window.addEventListener('resize', function() {
      const tryonButton = document.getElementById('tryonButton');
      if (tryonButton && tryonButton.classList.contains('tryon-button-transformed')) {
        if (window.innerWidth <= 768) {
          tryonButton.classList.add('MBtryonbutton');
          tryonButton.style.width = '40px';
          tryonButton.style.height = '40px';
          tryonButton.style.minWidth = '40px';
          tryonButton.style.minHeight = '40px';
          tryonButton.style.left = '10px';
          tryonButton.style.margin = '8px';
          
          // Also update the inner elements
          const wrapper = tryonButton.querySelector('.tryon-button-wrapper');
          const panel = tryonButton.querySelector('.tryon-sliding-panel');
          const icon = tryonButton.querySelector('.tryon-icon-circle');
          
          if (wrapper) {
            wrapper.style.width = '40px';
            wrapper.style.height = '40px';
          }
          if (panel) {
            panel.style.width = '40px';
            panel.style.height = '40px';
            panel.style.paddingLeft = '40px';
            panel.style.clipPath = 'circle(50% at 20px 20px)';
          }
          if (icon) {
            icon.style.width = '40px';
            icon.style.height = '40px';
          }
        } else {
          tryonButton.classList.remove('MBtryonbutton');
          tryonButton.style.width = '45px';
          tryonButton.style.height = '45px';
          tryonButton.style.minWidth = '45px';
          tryonButton.style.minHeight = '45px';
          tryonButton.style.left = '0';
          tryonButton.style.margin = '10px';
          
          // Also update the inner elements
          const wrapper = tryonButton.querySelector('.tryon-button-wrapper');
          const panel = tryonButton.querySelector('.tryon-sliding-panel');
          const icon = tryonButton.querySelector('.tryon-icon-circle');
          
          if (wrapper) {
            wrapper.style.width = '45px';
            wrapper.style.height = '45px';
          }
          if (panel) {
            panel.style.width = '45px';
            panel.style.height = '45px';
            panel.style.paddingLeft = '45px';
            panel.style.clipPath = 'circle(50% at 22.5px 22.5px)';
          }
          if (icon) {
            icon.style.width = '45px';
            icon.style.height = '45px';
          }
        }
      }
    });

    // Code for the second try on button which is below the add to cart
    getSkusListWithTryOn({companyName: 'luciraonline', regionId:'2'})
      .then((skusList) => {
        console.log("all skus", skusList);
        if (skusList.includes(productSKUTryOn)){
          document.getElementById("second-tryon-button").style.display = "block";
          document.getElementById("virtual-try-on-content").style.display = "flex";

          // Also transform the second button if it exists with id="tryonButton" in that section
          setTimeout(() => {
            const secondTryonButton = document.querySelector('#second-tryon-button #tryonButton, #virtual-try-on-content #tryonButton');
            if (secondTryonButton) {
              // Clone the transformation for second button
              transformTryOnButton();
            }
          }, 500);
        }
      });
  }

  document.addEventListener("DOMContentLoaded", initTryOnButton);
</script>