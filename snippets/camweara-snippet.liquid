          borderRadius: "5px",
          margin: "10px 10px",
          left: "0%",
          position: "absolute",
          zIndex: "22",
          width: "150px"
        },
        MBtryonbutton: {
          width: "148px",
          margin: "10px 0%",
          left: "10px"
        }
      },
      prodRecommendation: "true",
      buynowCallback: "onTryOnBuynowclick",
      tryonButtonData: {
        text: "Try Them On",
        faIcon: "fa fa-camera"
      },
