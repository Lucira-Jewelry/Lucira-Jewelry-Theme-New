<script>
  function initTryOnButton() {
    if (typeof loadTryOnButton !== "function") {
      setTimeout(initTryOnButton, 100);
      return;
    }

    loadTryOnButton({
      psku: "{{ sku_tryon_pdp }}",
      page: "product",
      regionId: "2",
      company: "luciraonline",
      prependButton: {
        class: "product__media-list contains-media grid grid--peek list-unstyled"
      },
      MBprependButton: {
        class: "product__media-list contains-media grid grid--peek list-unstyled"
      },
      styles: {
        tryonbutton: {
          backgroundColor: "transparent",
          color: "transparent",
          border: "none",
          borderRadius: "15px",
          margin: "0",
          left: "0",
          top: "0",
          position: "relative",
          zIndex: "9999",
          width: "30px",
          height: "30px",
          padding: "0",
          fontSize: "0",
          lineHeight: "0",
          visibility: "visible",
          opacity: "1",
          display: "block"
        },
        MBtryonbutton: {
          width: "30px",
          height: "30px",
          margin: "0",
          left: "0",
          top: "0",
          padding: "0",
          backgroundColor: "transparent",
          border: "none",
          position: "relative",
          color: "transparent",
          fontSize: "0",
          lineHeight: "0",
          zIndex: "9999",
          visibility: "visible",
          opacity: "1",
          display: "block"
        }
      },
      prodRecommendation: "true",
      buynowCallback: "onTryOnBuynowclick",
      tryonButtonData: {
        text: "",
        faIcon: ""
      },
      buynow: {
        enable: "{{ is_product_available }}"
      }
    });

    // Track which buttons have been transformed
    const transformedButtons = new WeakSet();

    // Function to wrap button in absolute positioned container
    function wrapButtonInAbsoluteContainer(buttonElement) {
      // Don't wrap if already wrapped or if it's the second button
      if (buttonElement.closest('.tryon-absolute-wrapper') || 
          buttonElement.closest('#second-tryon-button-1') || 
          buttonElement.closest('#virtual-try-on-content')) {
        return;
      }

      console.log('📦 Wrapping button in absolute container');

      // Create wrapper
      const wrapper = document.createElement('div');
      wrapper.className = 'tryon-absolute-wrapper';
      wrapper.style.cssText = 'position:absolute !important;top:10px !important;left:10px !important;width:30px !important;height:30px !important;z-index:9999 !important;pointer-events:none !important;';

      // Insert wrapper before button
      buttonElement.parentNode.insertBefore(wrapper, buttonElement);
      
      // Move button into wrapper
      wrapper.appendChild(buttonElement);

      console.log('✅ Button wrapped successfully');
    }

    // Function to completely clean and transform button (FIRST BUTTON - WITH ANIMATION)
    function transformTryOnButton(buttonElement) {
      if (!buttonElement) return false;

      // Check if already transformed
      if (transformedButtons.has(buttonElement) || 
          buttonElement.querySelector('.tryon-button-wrapper') || 
          buttonElement.querySelector('.tryon-text-only')) {
        return true;
      }

      // CRITICAL: Check if this is the second button - if so, skip animation transform
      const isSecondButton = buttonElement.closest('#second-tryon-button-1') || 
                            buttonElement.closest('#virtual-try-on-content');
      
      if (isSecondButton) {
        console.log('⏭️ Skipping animation transform for second button');
        return false;
      }

      console.log('🔄 Transforming Try On button');

      // Store click handler
      const originalOnClick = buttonElement.onclick;
      
      // Nuclear option: Remove ALL content including text nodes
      buttonElement.textContent = '';
      buttonElement.innerHTML = '';
      
      // Apply critical inline styles - RELATIVE positioning since we're in absolute wrapper
      buttonElement.style.cssText = `
        position: relative !important;
        width: 30px !important;
        height: 30px !important;
        left: 0 !important;
        top: 0 !important;
        z-index: 9999 !important;
        display: block !important;
        visibility: visible !important;
        opacity: 1 !important;
        margin: 0 !important;
        padding: 0 !important;
        background: transparent !important;
        border: none !important;
        pointer-events: auto !important;
        transform: translateZ(0) !important;
      `;
      
      // Create structure
      const buttonWrapper = document.createElement('div');
      buttonWrapper.className = 'tryon-button-wrapper';
      buttonWrapper.style.cssText = 'position:relative !important;width:30px !important;height:30px !important;display:block !important;visibility:visible !important;opacity:1 !important;z-index:9999 !important;pointer-events:auto !important;';
      
      const buttonContainer = document.createElement('div');
      buttonContainer.className = 'tryon-button-container';
      buttonContainer.style.cssText = 'position:absolute !important;left:0 !important;top:0 !important;width:30px !important;height:30px !important;display:block !important;z-index:9999 !important;overflow:visible !important;';
      
      const slidingPanel = document.createElement('div');
      slidingPanel.className = 'tryon-sliding-panel';
      slidingPanel.id = 'animatedTryOnPanel';
      slidingPanel.style.cssText = 'z-index:9999 !important;visibility:visible !important;opacity:1 !important;pointer-events:auto !important;';
      
      const textContent = document.createElement('div');
      textContent.className = 'tryon-text-content';
      textContent.innerHTML = '<span>Try Them On</span>';
      
      const iconCircle = document.createElement('div');
      iconCircle.className = 'tryon-icon-circle';
      iconCircle.style.cssText = 'position:absolute !important;left:0 !important;top:0 !important;width:30px !important;height:30px !important;display:block !important;visibility:visible !important;opacity:1 !important;z-index:10000 !important;pointer-events:auto !important;';
      
      // Inline SVG
      iconCircle.innerHTML = `
        <svg width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:block !important;width:100% !important;height:100% !important;visibility:visible !important;">
            <rect x="0.25" y="0.25" width="29.5" height="29.5" rx="14.75" fill="white" stroke="black" stroke-width="0.5"/>
            <path d="M8.95833 12.5547L10.7365 10.8087M8.95833 12.5547L14.8637 20M8.95833 12.5547L12.32 13.9025M10.7365 10.8087L12.7222 10H17.2648L19.5621 10.8087M10.7365 10.8087L12.9948 11.6175M19.5621 10.8087L21.0417 12.5547M19.5621 10.8087L17.1610 11.6175M21.0417 12.5547L14.8637 20M21.0417 12.5547L17.758 13.9025M14.8637 20L17.758 13.9025M14.8637 20L12.32 13.9025M17.758 13.9025L17.1610 11.6175M17.758 13.9025H12.32M17.1610 11.6175H12.9948M12.9948 11.6175L12.32 13.9025" stroke="black" stroke-width="0.689681"/>
            <rect x="6.66667" y="18.3333" width="0.416667" height="5" fill="black"/>
            <rect x="6.66667" y="23.3333" width="0.416667" height="5" transform="rotate(-90 6.66667 23.3333)" fill="black"/>
            <rect width="0.416667" height="5" transform="matrix(1 0 0 -1 6.66661 11.6667)" fill="black"/>
            <rect width="0.416667" height="5" transform="matrix(0 1 1 0 6.66667 6.66667)" fill="black"/>
            <rect x="23.3334" y="11.6667" width="0.416667" height="5" transform="rotate(180 23.3334 11.6667)" fill="black"/>
            <rect x="23.3333" y="6.66667" width="0.416667" height="5" transform="rotate(90 23.3333 6.66667)" fill="black"/>
            <rect width="0.416667" height="5" transform="matrix(-1 0 0 1 23.3333 18.3333)" fill="black"/>
            <rect width="0.416667" height="5" transform="matrix(0 -1 -1 0 23.3333 23.3333)" fill="black"/>
        </svg>
      `;
      
      // Assemble
      slidingPanel.appendChild(textContent);
      buttonContainer.appendChild(slidingPanel);
      buttonContainer.appendChild(iconCircle);
      buttonWrapper.appendChild(buttonContainer);
      buttonElement.appendChild(buttonWrapper);
      
      // Force visibility again after DOM manipulation
      buttonElement.style.visibility = 'visible';
      buttonElement.style.opacity = '1';
      buttonElement.style.display = 'block';
      buttonElement.style.zIndex = '9999';
      
      // Restore click functionality
      const clickHandler = function(e) {
        e.preventDefault();
        e.stopPropagation();
        console.log('👆 Try On button clicked');
        if (originalOnClick) {
          originalOnClick.call(buttonElement, e);
        }
      };
      
      slidingPanel.addEventListener('click', clickHandler);
      slidingPanel.addEventListener('touchstart', clickHandler, { passive: false });
      iconCircle.addEventListener('click', clickHandler);
      iconCircle.addEventListener('touchstart', clickHandler, { passive: false });
      buttonElement.addEventListener('click', clickHandler);
      buttonElement.addEventListener('touchstart', clickHandler, { passive: false });
      
      // Mark as transformed
      transformedButtons.add(buttonElement);
      
      // Wrap in absolute container AFTER transformation
      wrapButtonInAbsoluteContainer(buttonElement);
      
      // Setup hover-based animation
      setTimeout(() => {
        setupHoverAnimation(slidingPanel, buttonWrapper);
      }, 500);
      
      return true;
    }

    // Function for second button - TEXT ONLY, NO ANIMATION
    function transformSecondButton(buttonElement) {
      if (!buttonElement) return false;
      
      // Check if already transformed
      if (transformedButtons.has(buttonElement) || 
          buttonElement.querySelector('.tryon-text-only') || 
          buttonElement.querySelector('.tryon-button-wrapper')) {
        return true;
      }

      console.log('🔄 Transforming second Try On button (text only)');

      // Store click handler
      const originalOnClick = buttonElement.onclick;
      
      // Clear button content
      buttonElement.textContent = '';
      buttonElement.innerHTML = '';
      buttonElement.style.cssText = '';
      
      // Create simple text wrapper
      const textWrapper = document.createElement('div');
      textWrapper.className = 'tryon-text-only';
      textWrapper.innerHTML = '<span>Try Them On</span>';
      textWrapper.style.cssText = 'font-size:15px;font-weight:500;color:#000;letter-spacing:1px;font-family:"Futura Std",Arial,sans-serif;white-space:nowrap;display:inline-block;';
      
      buttonElement.appendChild(textWrapper);
      
      // Force visibility
      buttonElement.style.visibility = 'visible';
      buttonElement.style.opacity = '1';
      buttonElement.style.display = 'inline-block';
      buttonElement.style.background = 'transparent';
      buttonElement.style.border = 'none';
      buttonElement.style.padding = '10px 20px';
      buttonElement.style.cursor = 'pointer';
      buttonElement.style.position = 'static';
      
      // Restore click functionality
      const clickHandler = function(e) {
        e.preventDefault();
        e.stopPropagation();
        console.log('👆 Second Try On button clicked');
        if (originalOnClick) {
          originalOnClick.call(buttonElement, e);
        }
      };
      
      buttonElement.addEventListener('click', clickHandler);
      buttonElement.addEventListener('touchstart', clickHandler, { passive: false });
      
      // Mark as transformed
      transformedButtons.add(buttonElement);
      
      return true;
    }

    // Animation function - plays once on load, then on hover
    function setupHoverAnimation(panel, wrapper) {
      if (!panel || !wrapper) return;
      
      let hasPlayedInitial = false;
      
      function animateButton() {
        panel.classList.add('expanded');
        setTimeout(() => {
          panel.classList.remove('expanded');
        }, 2000);
      }
      
      // Play once on initial load
      setTimeout(() => {
        animateButton();
        hasPlayedInitial = true;
      }, 500);
      
      // Setup hover listeners
      const hoverHandler = () => {
        if (hasPlayedInitial && !panel.classList.contains('expanded')) {
          animateButton();
        }
      };
      
      wrapper.addEventListener('mouseenter', hoverHandler);
      panel.addEventListener('mouseenter', hoverHandler);
      
      // For touch devices
      wrapper.addEventListener('touchstart', (e) => {
        if (hasPlayedInitial && !panel.classList.contains('expanded')) {
          animateButton();
        }
      }, { passive: true });
    }

    // Aggressive transformation strategy for mobile (first button ONLY)
    function findAndTransformButton() {
      // Try multiple selectors but EXCLUDE second button containers
      const selectors = [
        '.product__media-list #tryonButton:not(#second-tryon-button-1 #tryonButton):not(#virtual-try-on-content #tryonButton)',
        'button#tryonButton:not(#second-tryon-button-1 #tryonButton):not(#virtual-try-on-content #tryonButton)',
        '#MB_tryonButton:not(#second-tryon-button-1 #MB_tryonButton):not(#virtual-try-on-content #MB_tryonButton)',
        'button[id*="tryonButton"]:not(#second-tryon-button-1 button):not(#virtual-try-on-content button)'
      ];
      
      for (const selector of selectors) {
        const buttons = document.querySelectorAll(selector);
        buttons.forEach(button => {
          // Double check it's not in second button container
          const isSecondButton = button.closest('#second-tryon-button-1') || 
                                button.closest('#virtual-try-on-content');
          
          if (!isSecondButton && 
              !transformedButtons.has(button) && 
              !button.querySelector('.tryon-button-wrapper') && 
              !button.querySelector('.tryon-text-only')) {
            console.log('✅ Found first button with selector:', selector);
            
            const success = transformTryOnButton(button);
            if (success) {
              console.log('✅ First button transformed successfully');
              return true;
            }
          }
        });
      }
      return false;
    }

    // Multiple transformation attempts
    let attempts = 0;
    const maxAttempts = 25;
    
    function attemptTransform() {
      attempts++;
      console.log(`🔍 Attempt ${attempts}/${maxAttempts} to transform first button`);
      
      const success = findAndTransformButton();
      
      if (!success && attempts < maxAttempts) {
        const delay = window.innerWidth <= 768 ? 500 : 300;
        setTimeout(attemptTransform, delay);
      } else if (success) {
        console.log('🎉 First button transformation complete!');
      } else {
        console.warn('⚠️ Could not transform first button after all attempts');
      }
    }

    // Start after initial delay
    const initialDelay = window.innerWidth <= 768 ? 1000 : 500;
    setTimeout(attemptTransform, initialDelay);

    // Additional checks on various events
    window.addEventListener('load', () => {
      const delay = window.innerWidth <= 768 ? 500 : 300;
      setTimeout(findAndTransformButton, delay);
    });

    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) {
        setTimeout(findAndTransformButton, 200);
      }
    });

    // SECOND BUTTON HANDLING - TEXT ONLY, NO ANIMATION
    function setupSecondButton() {
      getSkusListWithTryOn({companyName: 'luciraonline', regionId:'2'})
        .then((skusList) => {
          console.log("all skus", skusList);
          if (skusList.includes(productSKUTryOn)){
            // First make containers visible
            const secondButtonContainer = document.getElementById("second-tryon-button-1");
            const virtualTryOnContent = document.getElementById("virtual-try-on-content");
            
            if (secondButtonContainer) secondButtonContainer.style.display = "block";
            if (virtualTryOnContent) virtualTryOnContent.style.display = "flex";

            // Wait a bit for the button to be rendered, then transform
            setTimeout(() => {
              const secondButtons = document.querySelectorAll('#second-tryon-button-1 #tryonButton, #virtual-try-on-content #tryonButton');
              
              secondButtons.forEach(button => {
                if (!transformedButtons.has(button) && 
                    !button.querySelector('.tryon-text-only') && 
                    !button.querySelector('.tryon-button-wrapper')) {
                  console.log('✅ Found second button, transforming to text-only');
                  transformSecondButton(button);
                }
              });
            }, 200);
          }
        })
        .catch(err => console.error('Error loading SKUs:', err));
    }

    // Initialize second button
    setTimeout(setupSecondButton, 1500);

  }

  // Initialize on various events
  if (document.readyState === 'loading') {
    document.addEventListener("DOMContentLoaded", initTryOnButton);
  } else {
    setTimeout(initTryOnButton, 100);
  }

  window.addEventListener('load', () => {
    const delay = window.innerWidth <= 768 ? 500 : 300;
    setTimeout(initTryOnButton, delay);
  });

  // Fallback for mobile browsers
  setTimeout(initTryOnButton, 1000);
  if (window.innerWidth <= 768) {
    setTimeout(initTryOnButton, 2000);
  }
</script>
