      const iconCircle = document.createElement('div');
      iconCircle.className = 'tryon-icon-circle';
      iconCircle.style.cssText = 'position:absolute;left:0;top:0;width:45px;height:45px;display:block;visibility:visible;opacity:1;z-index:3;';
      
      // Inline SVG to ensure it loads - UPDATED viewBox and dimensions to 45x45
      iconCircle.innerHTML = `
        <svg width="45" height="45" viewBox="0 0 45 45" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:block;width:100%;height:100%;visibility:visible;">
            <rect x="0.3125" y="0.3125" width="44.375" height="44.375" rx="22.1875" fill="white" fill-opacity="0.2"/>
            <rect x="0.3125" y="0.3125" width="44.375" height="44.375" rx="22.1875" stroke="black" stroke-width="0.625"/>
            <path d="M13.4375 18.832L16.1047 16.2131M13.4375 18.832L22.2956 30M13.4375 18.832L18.48 20.8537M16.1047 16.2131L19.0833 15H25.8972L29.3431 16.2131M16.1047 16.2131L19.4922 17.4262M29.3431 16.2131L31.5625 18.832M29.3431 16.2131L25.7415 17.4262M31.5625 18.832L22.2956 30M31.5625 18.832L26.637 20.8537M22.2956 30L26.637 20.8537M22.2956 30L18.48 20.8537M26.637 20.8537L25.7415 17.4262M26.637 20.8537H18.48M25.7415 17.4262H19.4922M19.4922 17.4262L18.48 20.8537" stroke="black" stroke-width="1.03452"/>
            <rect x="10" y="27.5" width="0.625" height="7.5" fill="black"/>
            <rect x="10" y="35" width="0.625" height="7.5" transform="rotate(-90 10 35)" fill="black"/>
            <rect width="0.625" height="7.5" transform="matrix(1 0 0 -1 9.99992 17.5)" fill="black"/>
            <rect width="0.625" height="7.5" transform="matrix(0 1 1 0 10 10)" fill="black"/>
            <rect x="35.0001" y="17.5" width="0.625" height="7.5" transform="rotate(180 35.0001 17.5)" fill="black"/>
            <rect x="35" y="10" width="0.625" height="7.5" transform="rotate(90 35 10)" fill="black"/>
            <rect width="0.625" height="7.5" transform="matrix(-1 0 0 1 35 27.5)" fill="black"/>
            <rect width="0.625" height="7.5" transform="matrix(0 -1 -1 0 35 35)" fill="black"/>
        </svg>
      `;
      
      // Assemble
      slidingPanel.appendChild(textContent);
      buttonContainer.appendChild(slidingPanel);
      buttonContainer.appendChild(iconCircle);
      buttonWrapper.appendChild(buttonContainer);
      buttonElement.appendChild(buttonWrapper);
      
      // Force visibility
      buttonElement.style.visibility = 'visible';
      buttonElement.style.opacity = '1';
      buttonElement.style.display = 'block';
      
      // Restore click functionality
      const clickHandler = function(e) {
        e.preventDefault();
        e.stopPropagation();
        console.log('👆 Try On button clicked');
        if (originalOnClick) {
          originalOnClick.call(buttonElement, e);
        }
      };
      
      slidingPanel.addEventListener('click', clickHandler);
      slidingPanel.addEventListener('touchstart', clickHandler);
      iconCircle.addEventListener('click', clickHandler);
      iconCircle.addEventListener('touchstart', clickHandler);
      buttonElement.addEventListener('click', clickHandler);
      buttonElement.addEventListener('touchstart', clickHandler);
      
      // Start animation
      setTimeout(() => {
        startButtonAnimation(slidingPanel);
      }, 500);
      
      return true;
    }

    // Function for second button - TEXT ONLY, NO ANIMATION
    function transformSecondButton(buttonElement) {
      if (!buttonElement) return false;
      
      // Check if already transformed
      if (buttonElement.querySelector('.tryon-text-only')) {
        return true;
      }

      console.log('🔄 Transforming second Try On button (text only)');

      // Store click handler
      const originalOnClick = buttonElement.onclick;
      
      // Clear button content
      buttonElement.textContent = '';
      buttonElement.innerHTML = '';
      buttonElement.style.cssText = '';
      
      // Create simple text wrapper
      const textWrapper = document.createElement('div');
      textWrapper.className = 'tryon-text-only';
      textWrapper.innerHTML = '<span>Try Them On</span>';
      textWrapper.style.cssText = 'font-size:15px;font-weight:500;color:#000;letter-spacing:1px;font-family:"Futura Std";white-space:nowrap;display:inline-block;';
      
      buttonElement.appendChild(textWrapper);
      
      // Force visibility
      buttonElement.style.visibility = 'visible';
      buttonElement.style.opacity = '1';
      buttonElement.style.display = 'inline-block';
      buttonElement.style.background = 'transparent';
      buttonElement.style.border = 'none';
      buttonElement.style.padding = '0';
      buttonElement.style.cursor = 'pointer';
      
      // Restore click functionality
      const clickHandler = function(e) {
        e.preventDefault();
        e.stopPropagation();
        console.log('👆 Second Try On button clicked');
        if (originalOnClick) {
          originalOnClick.call(buttonElement, e);
        }
      };
      
      buttonElement.addEventListener('click', clickHandler);
      buttonElement.addEventListener('touchstart', clickHandler);
      
      return true;
    }

    // Animation function (for first button only)
    function startButtonAnimation(panel) {
      if (!panel) return;
      
      function animateButton() {
        panel.classList.add('expanded');
        setTimeout(() => {
          panel.classList.remove('expanded');
        }, 2000);
      }
      
      setTimeout(() => {
        animateButton();
        setInterval(animateButton, 4000);
      }, 1000);
    }

    // Aggressive transformation strategy for mobile (first button)
    function findAndTransformButton() {
      // Try multiple selectors
      const selectors = [
        '#tryonButton',
        'button#tryonButton',
        '[id="tryonButton"]',
        'button[id*="tryon"]',
        '.product__media-list button[id*="tryon"]'
      ];
      
      for (const selector of selectors) {
        const button = document.querySelector(selector);
        if (button && !button.querySelector('.tryon-button-wrapper') && !button.querySelector('.tryon-text-only')) {
          console.log('✅ Found button with selector:', selector);
          const success = transformTryOnButton(button);
          if (success) {
            console.log('✅ Button transformed successfully');
            return true;
          }
        }
      }
      return false;
    }

    // Multiple transformation attempts with longer delays for mobile
    let attempts = 0;
    const maxAttempts = 20;
    
    function attemptTransform() {
      attempts++;
      console.log(`🔍 Attempt ${attempts}/${maxAttempts} to transform button`);
      
      const success = findAndTransformButton();
      
      if (!success && attempts < maxAttempts) {
        setTimeout(attemptTransform, 300);
      } else if (success) {
        console.log('🎉 Button transformation complete!');
      } else {
        console.warn('⚠️ Could not transform button after all attempts');
      }
    }

    // Start after initial delay
    setTimeout(attemptTransform, 500);

    // Additional checks on various events
    window.addEventListener('load', () => {
      setTimeout(findAndTransformButton, 300);
    });

    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) {
        setTimeout(findAndTransformButton, 200);
      }
    });

    // Intersection Observer for when button becomes visible
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const button = entry.target;
            if (!button.querySelector('.tryon-button-wrapper')) {
              transformTryOnButton(button);
            }
          }
        });
      });

      // Observe after delay
      setTimeout(() => {
        const button = document.getElementById('tryonButton');
        if (button) {
          observer.observe(button);
        }
      }, 1000);
    }

    // SECOND BUTTON HANDLING - TEXT ONLY, NO ANIMATION
    getSkusListWithTryOn({companyName: 'luciraonline', regionId:'2'})
      .then((skusList) => {
        console.log("all skus", skusList);
        if (skusList.includes(productSKUTryOn)){
          document.getElementById("second-tryon-button-1").style.display = "block";
          document.getElementById("virtual-try-on-content").style.display = "flex";

          // Transform the second button with text-only style
          setTimeout(() => {
            const secondTryonButton = document.querySelector('#second-tryon-button-1 #tryonButton, #virtual-try-on-content #tryonButton');
            if (secondTryonButton) {
              console.log('✅ Found second button, transforming to text-only');
              transformSecondButton(secondTryonButton);
            }
          }, 800);
        }
      })
      .catch(err => console.error('Error loading SKUs:', err));

  }

  // Initialize on various events
  if (document.readyState === 'loading') {
    document.addEventListener("DOMContentLoaded", initTryOnButton);
  } else {
    setTimeout(initTryOnButton, 100);
  }

  window.addEventListener('load', () => {
    setTimeout(initTryOnButton, 300);
  });

  // Fallback for mobile browsers
  setTimeout(initTryOnButton, 1000);
</script>
