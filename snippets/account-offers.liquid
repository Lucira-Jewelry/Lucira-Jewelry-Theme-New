<style>
    .swiper {
      width: 100%;
      height: 100%;
    }

    .swiper-slide {
      text-align: center;
      font-size: 18px;
      background: #fff;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .swiper-slide img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

  .swiper-button-prev:after, .swiper-rtl .swiper-button-next:after, .swiper-button-next:after, .swiper-rtl .swiper-button-prev:after{
    content:unset;
  }

  .swiper-button-prev{
        transform: rotateY(180deg);
  }
  
  .featured-offers-section {
  width: 100%;
  /* max-width: 1200px; */
  padding: 32px 80px;
  background:#F4F0F0
}

.featured-offers-section .container-ao {
  /* padding: 0 20px; */
}

  .tabs-switch{
    max-width: 1080px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.featured-offers-section .featured-offers-heading {
  font-size: 24px;
  font-weight: 600;
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.featured-offers-section .featured-offers-subheading {
  font-size: 16px;
  margin-bottom: 30px;
  color: #666666;
  text-align: center;
}

.featured-offers-section .featured-offers-slider {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: auto;
  gap: 20px;
  padding: 10px 0;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none; /* Firefox */
}

.featured-offers-section .featured-offers-slider::-webkit-scrollbar {
  display: none; /* Chrome, Safari, Edge */
}

.featured-offers-section .featured-offer-card {
  flex: 0 0 auto;
  width: calc(33.333% - 14px);
  min-width: 250px;
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.featured-offers-section .featured-offer-image-container-ao {
  position: relative;
  padding-top: 100%; /* 1:1 Aspect Ratio */
  background: #f5f5f5;
}

.featured-offers-section .featured-offer-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.featured-offers-section .placeholder-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
}

.featured-offers-section .placeholder-svg {
  width: 60%;
  height: 60%;
  opacity: 0.3;
}

.featured-offers-section .featured-offer-content {
  padding: 16px;
  text-align: left;
}

.featured-offers-section .featured-offer-discount {
  font-size: 16px !important;
  font-weight: 400;
  color: #D32F2F;
  margin-bottom: 12px;
}

.featured-offers-section .featured-offer-name {
  font-size: 14px !important;
  color: #1A1A1A;
  font-weight: 500;
  margin-bottom: 24px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.featured-offers-section .featured-offer-button {
  width:100%;
  text-align:center;
  display: inline-block;
  background-color: #A68380;
  color: white;
  padding: 8px 24px;
  border-radius: 50px;
  text-transform: uppercase;
  font-size: 16px;
  letter-spacing: 0.5px;
  text-decoration: none;
  transition: background-color 0.3s;
}

.featured-offers-section .featured-offer-button:hover {
  background-color: #a07a67;
}
  
  .faq-btn{
    margin: 0 200px;
    display: flex;
    justify-content: center;
    background: #F2F2F2;
    margin-bottom: 40px;
    border-radius: 44px;
  }

  .tab {
  margin-bottom: 32px;
  overflow: hidden;
  padding: 4px;
  border-radius: 44px;
  width: fit-content;
  /* border: 1px solid #ccc; */
  background-color: #f1f1f1;
}

/* Style the buttons inside the tab */
.tab button {
  background-color: inherit;
  float: left;
  border: none;
  border-radius: 44px;
  outline: none;
  cursor: pointer;
  /* margin-right: 16px; */
  padding: 14px 52px;
  transition: 0.3s;
  font-size: 17px;
}

/* Change background color of buttons on hover */
/* .tab button:hover {
  background-color: #ddd;
} */

/* Create an active/current tablink class */
.tab button.active {
  background-color: #fff;
}

/* Style the tab content */
.tabcontent {
  display: none;
  padding: 6px 12px;
  /* border: 1px solid #ccc; */
  width: 100%;
  border-top: none;
}

.tabcontent {
  animation: fadeEffect 1s; /* Fading effect takes 1 second */
}

  .tabcontent.active{
    display:block;
  }

/* Go from zero to full opacity */
@keyframes fadeEffect {
  from {opacity: 0;}
  to {opacity: 1;}
}

  @media screen and (max-width: 768px) {
   .featured-offers-section .featured-offer-card {
      width: calc(50% - 10px);
    }

    .faq-question{
    font-size:12px;
    }

    .tab-content{
      padding: 20px 0;
    }

   .tab {
      margin-left: 16px;
      margin-bottom: 16px;
      overflow: scroll;
      width: max-content;
    }

    .featured-offers-section{
      padding: 16px 20px;
    }

    .tabs-switch{
      align-items: baseline;
    }

  .tab button {
    padding: 8px 52px;
    font-size:12px;
  }
}

@media screen and (max-width: 480px) {
 .featured-offers-section .featured-offer-card {
    width: 100%;
  }
}
</style>
<div class="featured-offers-section" style="margin-top: {{ section.settings.padding_top }}px; margin-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="container-ao">
    {% if section.settings.heading != blank %}
      <h2 class="featured-offers-heading text-center">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.subheading != blank %}
      <p class="featured-offers-subheading text-center">{{ section.settings.subheading }}</p>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="featured-offers-slider">
        {% for block in section.blocks %}
          {% if block.type == 'offer_card' %}
            <div class="featured-offer-card" {{ block.shopify_attributes }}>
              <div class="featured-offer-image-container-ao">
                {% if block.settings.image != blank %}
                  <img 
                    src="{{ block.settings.image | img_url: '600x' }}" 
                    alt="{{ block.settings.offer_name | escape }}"
                    loading="lazy"
                    class="featured-offer-image"
                  >
                {% else %}
                  {% if block.settings.collection != blank %}
                    {% if block.settings.collection.image != blank %}
                      <img 
                        src="{{ block.settings.collection.image | img_url: '600x' }}" 
                        alt="{{ block.settings.collection.title | escape }}"
                        loading="lazy"
                        class="featured-offer-image"
                      >
                    {% else %}
                      <div class="placeholder-image">
                        {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {% endif %}
                  {% else %}
                    <div class="placeholder-image">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {% endif %}
                {% endif %}
              </div>
              
              <div class="featured-offer-content">
                {% if block.settings.discount_text != blank %}
                  <p class="featured-offer-discount">{{ block.settings.discount_text }}</p>
                {% endif %}
                
                {% if block.settings.offer_name != blank %}
                  <p class="featured-offer-name">{{ block.settings.offer_name }}</p>
                {% endif %}
                
                {% if block.settings.collection != blank %}
                  <a href="{{ block.settings.collection.url }}" class="btn featured-offer-button">
                    {{ block.settings.button_text | default: 'ADD TO BAG' }}
                  </a>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

