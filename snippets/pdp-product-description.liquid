{% assign variant = product.selected_or_first_available_variant %}

<div class="pdp-details-main">
  <div class="pdp-details-accordion">

    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-1" />
      <label for="pdp-details-accordion-item-1" class="pdp-details-accordion-item-title" onclick="pushPromo('Product Information')">
        Product Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <p id="Sku-{{ section.id }}" class="product__sku">{{ variant.sku }}</p>
        <div class="product__description rte quick-add-hidden">
          {{ product.description }}
        </div>
      </div>
    </div>

    <!-- Metal Information -->
    <div class="pdp-details-accordion-item" id="metal-section">
      <input type="checkbox" id="pdp-details-accordion-item-2" />
      <label for="pdp-details-accordion-item-2" class="pdp-details-accordion-item-title" onclick="pushPromo('Metal Information')">
        Metal Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table id="metal-info-table">
          <thead>
            <tr>
              <th>METAL</th>
              <th>WEIGHT</th>
              <th>DIMENSIONS</th>
            </tr>
          </thead>
          <tbody>
            <tr id="metal-info-row">
              <td id="metal-type"></td>
              <td id="metal-weight"></td>
              <td id="metal-dimensions"></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Diamond Information -->
    <div class="pdp-details-accordion-item" id="diamond-section">
      <input type="checkbox" id="pdp-details-accordion-item-3" />
      <label for="pdp-details-accordion-item-3" class="pdp-details-accordion-item-title" onclick="pushPromo('Diamond Information')">
        Diamond Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table>
          <thead>
            <tr>
              <th>TYPE</th>
              <th>PCS / SHAPE</th>
              <th>SETTING / WT</th>
            </tr>
          </thead>
          <tbody id="diamond-table-body"></tbody>
        </table>
      </div>
    </div>

    <!-- Gemstone Information -->
    <div class="pdp-details-accordion-item" id="gemstone-section">
      <input type="checkbox" id="pdp-details-accordion-item-4"/>
      <label for="pdp-details-accordion-item-4" class="pdp-details-accordion-item-title" onclick="pushPromo('Gemstone Information')">
        Gemstone Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table>
          <thead>
            <tr>
              <th>TYPE</th>
              <th>SHAPE / PCS</th>
              <th>SETTING / WT</th>
            </tr>
          </thead>
          <tbody id="gemstone-table-body"></tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<script>
window.variantMetafields = {};

{% for v in product.variants %}

  {% assign diamonds_array = "" %}
  {% for i in (1..4) %}
    {% assign key_type = "diamond_" | append: i | append: "_type_" %}
    {% if v.metafields.custom[key_type] != blank %}
      {% assign key_shape = "diamond_" | append: i | append: "_shape" %}
      {% assign key_numbers = "diamond_" | append: i | append: "_numbers" %}
      {% assign key_setting = "diamond_" | append: i | append: "_setting" %}
      {% assign key_weight = "diamond_" | append: i | append: "_weight" %}
      {% assign key_clarity = "diamond_" | append: i | append: "_clarity" %}
      {% assign key_color = "diamond_" | append: i | append: "_color" %}

      {% capture diamond_item %}
        {
          "type": {{ v.metafields.custom[key_type] | json }},
          "shape": {{ v.metafields.custom[key_shape] | json }},
          "numbers": {{ v.metafields.custom[key_numbers] | json }},
          "setting": {{ v.metafields.custom[key_setting] | json }},
          "weight": {{ v.metafields.custom[key_weight] | json }},
          "clarity": {{ v.metafields.custom[key_clarity] | json }},
          "color": {{ v.metafields.custom[key_color] | json }}
        }
      {% endcapture %}

      {% if forloop.first %}
        {% assign diamonds_array = diamond_item %}
      {% else %}
        {% assign diamonds_array = diamonds_array | append: "," | append: diamond_item %}
      {% endif %}
    {% endif %}
  {% endfor %}

  {% assign gemstones_array = "" %}
  {% for i in (1..4) %}
    {% assign key_type = "gemstone_" | append: i | append: "_type_" %}
    {% if v.metafields.custom[key_type] != blank %}
      {% assign key_shape = "gemstone_" | append: i | append: "_shape" %}
      {% assign key_numbers = "gemstone_" | append: i | append: "_numbers" %}
      {% assign key_setting = "gemstone_" | append: i | append: "_setting" %}
      {% assign key_weight = "gemstone_" | append: i | append: "_weight" %}
      {% assign key_clarity = "gemstone_" | append: i | append: "_clarity" %}
      {% assign key_color = "gemstone_" | append: i | append: "_color" %}

      {% capture gemstone_item %}
        {
          "type": {{ v.metafields.custom[key_type] | json }},
          "shape": {{ v.metafields.custom[key_shape] | json }},
          "numbers": {{ v.metafields.custom[key_numbers] | json }},
          "setting": {{ v.metafields.custom[key_setting] | json }},
          "weight": {{ v.metafields.custom[key_weight] | json }},
          "clarity": {{ v.metafields.custom[key_clarity] | json }},
          "color": {{ v.metafields.custom[key_color] | json }}
        }
      {% endcapture %}

      {% if forloop.first %}
        {% assign gemstones_array = gemstone_item %}
      {% else %}
        {% assign gemstones_array = gemstones_array | append: "," | append: gemstone_item %}
      {% endif %}
    {% endif %}
  {% endfor %}

  window.variantMetafields["{{ v.id }}"] = {
    sku: {{ v.sku | json }},
    metal_purity: {{ v.metafields.custom.metal_purity | json }},
    metal_color: {{ v.metafields.custom.metal_color | json }},
    metal_weight: {{ v.metafields.custom.metal_weight | json }},
    gross_weight: {{ v.metafields.custom.gross_weight | json }},
    top_width: {{ v.metafields.custom.top_width | json }},
    top_height: {{ v.metafields.custom.top_height | json }},
    diamonds: [{{ diamonds_array }}],
    gemstones: [{{ gemstones_array }}]
  };

{% endfor %}
</script>

<script>
(function(){
  function escapeHtml(str) {
    if (!str) return '';
    return String(str)
      .replace(/&/g,'&amp;')
      .replace(/</g,'&lt;')
      .replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;')
      .replace(/'/g,'&#39;');
  }

  function hasValue(val) {
    return val && val !== null && val !== undefined && val !== '' && String(val).trim() !== '';
  }

  function clearAccordion() {
    // Clear content
    const skuEl = document.getElementById('Sku-{{ section.id }}');
    const metalTypeEl = document.getElementById('metal-type');
    const metalWeightEl = document.getElementById('metal-weight');
    const metalDimensionsEl = document.getElementById('metal-dimensions');
    const diamondBodyEl = document.getElementById('diamond-table-body');
    const gemstoneBodyEl = document.getElementById('gemstone-table-body');

    if (skuEl) skuEl.textContent = '';
    if (metalTypeEl) metalTypeEl.textContent = '';
    if (metalWeightEl) metalWeightEl.innerHTML = '';
    if (metalDimensionsEl) metalDimensionsEl.innerHTML = '';
    if (diamondBodyEl) diamondBodyEl.innerHTML = '';
    if (gemstoneBodyEl) gemstoneBodyEl.innerHTML = '';

    // Hide all sections initially
    const metalSection = document.getElementById('metal-section');
    const diamondSection = document.getElementById('diamond-section');
    const gemstoneSection = document.getElementById('gemstone-section');

    if (metalSection) metalSection.style.display = 'none';
    if (diamondSection) diamondSection.style.display = 'none';
    if (gemstoneSection) gemstoneSection.style.display = 'none';
  }

  function updateAccordionForVariant(variantId) {
    var data = window.variantMetafields[variantId];
    if(!data) return clearAccordion();

    // SKU
    const skuEl = document.getElementById('Sku-{{ section.id }}');
    if (skuEl) skuEl.textContent = data.sku || '';

    // Metal Section
    const metalSection = document.getElementById('metal-section');
    const metalTypeEl = document.getElementById('metal-type');
    const metalWeightEl = document.getElementById('metal-weight');
    const metalDimensionsEl = document.getElementById('metal-dimensions');

    const hasMetal = hasValue(data.metal_purity) || hasValue(data.metal_color) || 
                     hasValue(data.metal_weight) || hasValue(data.gross_weight) || 
                     hasValue(data.top_width) || hasValue(data.top_height);

    if (hasMetal && metalSection) {
      metalSection.style.display = 'block';
      
      if (metalTypeEl) {
        metalTypeEl.textContent = [data.metal_purity, data.metal_color].filter(hasValue).join(' - ');
      }
      
      if (metalWeightEl) {
        metalWeightEl.innerHTML = 
          (hasValue(data.metal_weight) ? 'Net Wt: '+escapeHtml(data.metal_weight)+'g<br>' : '') +
          (hasValue(data.gross_weight) ? 'Gross Wt: '+escapeHtml(data.gross_weight)+'g' : '');
      }
      
      if (metalDimensionsEl) {
        metalDimensionsEl.innerHTML =
          (hasValue(data.top_width) ? 'Width: '+escapeHtml(data.top_width)+'mm<br>' : '') +
          (hasValue(data.top_height) ? 'Height: '+escapeHtml(data.top_height)+'mm' : '');
      }
    } else if (metalSection) {
      metalSection.style.display = 'none';
    }

    // Diamond Section
    const diamondSection = document.getElementById('diamond-section');
    const diamondBody = document.getElementById('diamond-table-body');
    const validDiamonds = (data.diamonds || []).filter(d => hasValue(d.type));

    if (validDiamonds.length > 0 && diamondSection && diamondBody) {
      diamondSection.style.display = 'block';
      diamondBody.innerHTML = validDiamonds.map(d => {
        const clarityColor = [d.clarity, d.color].filter(hasValue).join('-');
        const typeCell = escapeHtml(d.type) + (clarityColor ? ' / ' + escapeHtml(clarityColor) : '');
        const pcsShape = [d.numbers, d.shape].filter(hasValue).join(' - ');
        const settingWeight = [d.setting, hasValue(d.weight) ? d.weight + 'ct' : ''].filter(hasValue).join(': ');
        
        return `
          <tr>
            <td>${typeCell}</td>
            <td>${escapeHtml(pcsShape)}</td>
            <td>${escapeHtml(settingWeight)}</td>
          </tr>
        `;
      }).join('');
    } else if (diamondSection) {
      diamondSection.style.display = 'none';
      if (diamondBody) diamondBody.innerHTML = '';
    }

    // Gemstone Section
    const gemstoneSection = document.getElementById('gemstone-section');
    const gemstoneBody = document.getElementById('gemstone-table-body');
    const validGemstones = (data.gemstones || []).filter(g => hasValue(g.type));

    if (validGemstones.length > 0 && gemstoneSection && gemstoneBody) {
      gemstoneSection.style.display = 'block';
      gemstoneBody.innerHTML = validGemstones.map(g => {
        const colorType = [g.color, g.type].filter(hasValue).join(' - ');
        const numbersShape = [g.numbers, g.shape].filter(hasValue).join(' - ');
        const settingWeight = [g.setting, hasValue(g.weight) ? g.weight + 'ct' : ''].filter(hasValue).join(': ');
        
        return `
          <tr>
            <td>${escapeHtml(colorType)}</td>
            <td>${escapeHtml(numbersShape)}</td>
            <td>${escapeHtml(settingWeight)}</td>
          </tr>
        `;
      }).join('');
    } else if (gemstoneSection) {
      gemstoneSection.style.display = 'none';
      if (gemstoneBody) gemstoneBody.innerHTML = '';
    }
  }

  window.pushPromo = function(promoName){
    var currentVariantId = document.querySelector('select[name="id"], input[name="id"]')?.value || '{{ variant.id }}';
    var sku = window.variantMetafields[currentVariantId]?.sku || '';
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'promoClick',
      promoClick: { promo_id: sku, promo_name: '{{ product.title }}', creative_name: promoName }
    });
  };

  document.addEventListener('DOMContentLoaded', function(){
    var sel = document.querySelector('select[name="id"], input[name="id"]');
    var initialVariantId = sel?.value || '{{ variant.id }}';
    
    // Initialize with clear state first
    clearAccordion();
    updateAccordionForVariant(initialVariantId);

    // Variant change listener
    document.addEventListener('variant:change', e => {
      var vid = e?.detail?.variant?.id;
      if(vid) updateAccordionForVariant(vid);
    });

    // Select / Swatch fallback
    sel?.addEventListener('change', function(){ updateAccordionForVariant(this.value); });
    document.body.addEventListener('click', function(e){
      var vid = e.target?.dataset?.variantId || e.target?.getAttribute('data-variant-id');
      if(vid) updateAccordionForVariant(vid);
    });
  });
})();
</script>