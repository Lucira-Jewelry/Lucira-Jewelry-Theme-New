{% assign variant = product.selected_or_first_available_variant %}

<div class="pdp-details-main">
  <div class="pdp-details-accordion">

    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-1" />
      <label for="pdp-details-accordion-item-1" class="pdp-details-accordion-item-title" onclick="pushPromo('Product Information')">
        Product Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <p id="Sku-{{ section.id }}" class="product__sku">{{ variant.sku }}</p>
        <div class="product__description rte quick-add-hidden">
          {{ product.description }}
        </div>
      </div>
    </div>

    <!-- Metal Information -->
    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-2" />
      <label for="pdp-details-accordion-item-2" class="pdp-details-accordion-item-title" onclick="pushPromo('Metal Information')">
        Metal Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table id="metal-info-table">
          <thead>
            <tr>
              <th>METAL</th>
              <th>WEIGHT</th>
              <th>DIMENSIONS</th>
            </tr>
          </thead>
          <tbody>
            <tr id="metal-info-row">
              <td id="metal-type"></td>
              <td id="metal-weight"></td>
              <td id="metal-dimensions"></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Diamond Information -->
    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-3" />
      <label for="pdp-details-accordion-item-3" class="pdp-details-accordion-item-title" onclick="pushPromo('Diamond Information')">
        Diamond Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table>
          <thead>
            <tr>
              <th>TYPE</th>
              <th>PCS / SHAPE</th>
              <th>SETTING / WT</th>
            </tr>
          </thead>
          <tbody id="diamond-table-body"></tbody>
        </table>
      </div>
    </div>

    <!-- Gemstone Information -->
    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-4"/>
      <label for="pdp-details-accordion-item-4" class="pdp-details-accordion-item-title" onclick="pushPromo('Gemstone Information')">
        Gemstone Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table>
          <thead>
            <tr>
              <th>TYPE</th>
              <th>SHAPE / PCS</th>
              <th>SETTING / WT</th>
            </tr>
          </thead>
          <tbody id="gemstone-table-body"></tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<script>
window.variantMetafields = {};

{% for v in product.variants %}

  {% assign diamonds_array = "" %}
  {% for i in (1..4) %}
    {% assign key_type = "diamond_" | append: i | append: "_type_" %}
    {% if v.metafields.custom[key_type] != blank %}
      {% assign key_shape = "diamond_" | append: i | append: "_shape" %}
      {% assign key_numbers = "diamond_" | append: i | append: "_numbers" %}
      {% assign key_setting = "diamond_" | append: i | append: "_setting" %}
      {% assign key_weight = "diamond_" | append: i | append: "_weight" %}
      {% assign key_clarity = "diamond_" | append: i | append: "_clarity" %}
      {% assign key_color = "diamond_" | append: i | append: "_color" %}

      {% capture diamond_item %}
        {
          "type": {{ v.metafields.custom[key_type] | json }},
          "shape": {{ v.metafields.custom[key_shape] | json }},
          "numbers": {{ v.metafields.custom[key_numbers] | json }},
          "setting": {{ v.metafields.custom[key_setting] | json }},
          "weight": {{ v.metafields.custom[key_weight] | json }},
          "clarity": {{ v.metafields.custom[key_clarity] | json }},
          "color": {{ v.metafields.custom[key_color] | json }}
        }
      {% endcapture %}

      {% if forloop.first %}
        {% assign diamonds_array = diamond_item %}
      {% else %}
        {% assign diamonds_array = diamonds_array | append: "," | append: diamond_item %}
      {% endif %}
    {% endif %}
  {% endfor %}

  {% assign gemstones_array = "" %}
  {% for i in (1..4) %}
    {% assign key_type = "gemstone_" | append: i | append: "_type_" %}
    {% if v.metafields.custom[key_type] != blank %}
      {% assign key_shape = "gemstone_" | append: i | append: "_shape" %}
      {% assign key_numbers = "gemstone_" | append: i | append: "_numbers" %}
      {% assign key_setting = "gemstone_" | append: i | append: "_setting" %}
      {% assign key_weight = "gemstone_" | append: i | append: "_weight" %}
      {% assign key_clarity = "gemstone_" | append: i | append: "_clarity" %}
      {% assign key_color = "gemstone_" | append: i | append: "_color" %}

      {% capture gemstone_item %}
        {
          "type": {{ v.metafields.custom[key_type] | json }},
          "shape": {{ v.metafields.custom[key_shape] | json }},
          "numbers": {{ v.metafields.custom[key_numbers] | json }},
          "setting": {{ v.metafields.custom[key_setting] | json }},
          "weight": {{ v.metafields.custom[key_weight] | json }},
          "clarity": {{ v.metafields.custom[key_clarity] | json }},
          "color": {{ v.metafields.custom[key_color] | json }}
        }
      {% endcapture %}

      {% if forloop.first %}
        {% assign gemstones_array = gemstone_item %}
      {% else %}
        {% assign gemstones_array = gemstones_array | append: "," | append: gemstone_item %}
      {% endif %}
    {% endif %}
  {% endfor %}

  window.variantMetafields["{{ v.id }}"] = {
    sku: {{ v.sku | json }},
    metal_purity: {{ v.metafields.custom.metal_purity | json }},
    metal_color: {{ v.metafields.custom.metal_color | json }},
    metal_weight: {{ v.metafields.custom.metal_weight | json }},
    gross_weight: {{ v.metafields.custom.gross_weight | json }},
    top_width: {{ v.metafields.custom.top_width | json }},
    top_height: {{ v.metafields.custom.top_height | json }},
    diamonds: [{{ diamonds_array }}],
    gemstones: [{{ gemstones_array }}]
  };

{% endfor %}
</script>

<!-- =========================
     JS: update on variant change
     ========================= -->
<script>
(function(){
  // small HTML escape helper
  function escapeHtml(str) {
    if (str === null || str === undefined) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function clearTables() {
    var d = document.getElementById('diamond-table-body');
    var g = document.getElementById('gemstone-table-body');
    if (d) d.innerHTML = '';
    if (g) g.innerHTML = '';
  }

  function updateAccordionForVariant(variantId) {
    if (!variantId) return;
    var data = window.variantMetafields && window.variantMetafields[variantId];
    if (!data) {
      // no metafields for this variant -> clear
      document.getElementById('metal-type').textContent = '';
      document.getElementById('metal-weight').textContent = '';
      document.getElementById('metal-dimensions').textContent = '';
      clearTables();
      // clear SKU
      var skuEl = document.getElementById('Sku-{{ section.id }}');
      if (skuEl) skuEl.textContent = '';
      return;
    }

    // SKU
    var skuEl = document.getElementById('Sku-{{ section.id }}');
    if (skuEl) {
      skuEl.textContent = (data.sku || '');
    }

    // Metal
    var metalType = '';
    if (data.metal_purity) metalType += data.metal_purity;
    if (data.metal_color) metalType += (metalType ? ' - ' : '') + data.metal_color;
    document.getElementById('metal-type').textContent = metalType;

    var metalWeight = '';
    if (data.metal_weight) metalWeight += 'Net Wt: ' + data.metal_weight + 'g<br>';
    if (data.gross_weight) metalWeight += 'Gross Wt: ' + data.gross_weight + 'g';
    document.getElementById('metal-weight').innerHTML = metalWeight;

    var metalDimensions = '';
    if (data.top_width) metalDimensions += 'Width: ' + data.top_width + 'mm<br>';
    if (data.top_height) metalDimensions += 'Height: ' + data.top_height + 'mm';
    document.getElementById('metal-dimensions').innerHTML = metalDimensions;

    // Diamonds
    var diamondBody = document.getElementById('diamond-table-body');
    if (diamondBody) {
      var html = '';
      for (var i = 1; i <= 4; i++) {
        var d = (data.diamonds && data.diamonds[String(i)]) || {};
        if (d && d.type) {
          var clarity = d.clarity || '';
          var color = d.color || '';
          var numbers = d.numbers || '';
          var shape = d.shape || '';
          var setting = d.setting || '';
          var weight = d.weight || '';
          var typeCell = escapeHtml(d.type) + ((clarity || color) ? ('/ ' + escapeHtml(clarity) + '-' + escapeHtml(color)) : '');
          html += '<tr>';
          html += '<td>' + typeCell + '</td>';
          html += '<td>' + escapeHtml(numbers) + ' - ' + escapeHtml(shape) + '</td>';
          html += '<td>' + escapeHtml(setting) + ': ' + escapeHtml(weight) + 'ct</td>';
          html += '</tr>';
        }
      }
      diamondBody.innerHTML = html;
    }

    // Gemstones
    var gemBody = document.getElementById('gemstone-table-body');
    if (gemBody) {
      var html = '';
      for (var i = 1; i <= 4; i++) {
        var g = (data.gemstones && data.gemstones[String(i)]) || {};
        if (g && g.type) {
          html += '<tr>';
          html += '<td>' + escapeHtml(g.color || '') + ' - ' + escapeHtml(g.type) + '</td>';
          html += '<td>' + escapeHtml(g.numbers || '') + ' - ' + escapeHtml(g.shape || '') + '</td>';
          html += '<td>' + escapeHtml(g.setting || '') + ': ' + escapeHtml(g.weight || '') + 'ct</td>';
          html += '</tr>';
        }
      }
      gemBody.innerHTML = html;
    }
  }

  // Push promo helper (for your labels)
  window.pushPromo = function(promoName) {
    var currentVariantId = null;
    // First try to read the currently selected variant id from common selectors
    var sel = document.querySelector('select[name="id"], input[name="id"]');
    if (sel) currentVariantId = sel.value || sel.getAttribute('value');
    // fallback to data stored on window (if your theme sets current variant elsewhere)
    if (!currentVariantId && window.currentVariant && window.currentVariant.id) currentVariantId = window.currentVariant.id;
    // fallback to server-warmed variant
    if (!currentVariantId) currentVariantId = '{{ variant.id }}';

    var sku = (window.variantMetafields && window.variantMetafields[currentVariantId] && window.variantMetafields[currentVariantId].sku) || '';
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'promoClick',
      promoClick: {
        promo_id: sku,
        promo_name: '{{ product.title }}',
        creative_name: promoName
      }
    });
  };

  // Listen for variant changes
  document.addEventListener('DOMContentLoaded', function() {
    // initial render: use selected id if present, otherwise server-side variant id
    var initialVariantId = '{{ variant.id }}';
    var sel = document.querySelector('select[name="id"], input[name="id"]');
    if (sel && sel.value) initialVariantId = sel.value;

    updateAccordionForVariant(initialVariantId);

    // Theme event (Dawn etc.)
    document.addEventListener('variant:change', function(e) {
      var vid = e && e.detail && e.detail.variant && e.detail.variant.id;
      if (vid) updateAccordionForVariant(vid);
    });

    // select fallback
    var selector = document.querySelector('select[name="id"], input[name="id"]');
    if (selector) {
      selector.addEventListener('change', function() {
        updateAccordionForVariant(this.value);
      });
    }

    // swatch / clickable elements sometimes use data-variant-id
    document.body.addEventListener('click', function(e) {
      var el = e.target;
      if (!el) return;
      var vid = el.getAttribute && (el.getAttribute('data-variant-id') || el.dataset && el.dataset.variantId);
      if (vid) {
        updateAccordionForVariant(vid);
      }
    });
  });
})();
</script>