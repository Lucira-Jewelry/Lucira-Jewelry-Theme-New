{%- assign variant = product.selected_or_first_available_variant -%}
<variant-selects id="VariantSelect-{{ unique }}" data-product-json-id="product-json-{{ unique }}">
  <div class="pdp-tabs-container">
    <div class="product-Information-wrapper">Product Details</div>
    <div class="pdp-tab-content active" id="product-details">
      <div class="pdp-product-sku">
        <span id="sku-content">SKU: {{ variant.sku }}</span>
        <button class="sku-copy-btn" id="sku-copy-button" title="Copy SKU">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 1.33301H7.33333C6.97971 1.33301 6.64057 1.47348 6.39052 1.72353C6.14048 1.97358 6 2.31272 6 2.66634V9.99967C6 10.3533 6.14048 10.6924 6.39052 10.9425C6.64057 11.1925 6.97971 11.333 7.33333 11.333H12.6667C13.0203 11.333 13.3594 11.1925 13.6095 10.9425C13.8595 10.6924 14 10.3533 14 9.99967V5.33301" stroke="#666666" stroke-linecap="round" stroke-linejoin="round"/><path d="M11.1373 1.80368C10.9882 1.65403 10.8109 1.53538 10.6157 1.4546C10.4205 1.37382 10.2113 1.33249 10 1.33301V4.66635C10 4.84316 10.0702 5.01273 10.1953 5.13775C10.3203 5.26277 10.4899 5.33301 10.6667 5.33301H14C14.0005 5.12175 13.9592 4.91248 13.8784 4.71727C13.7976 4.52207 13.679 4.34479 13.5293 4.19568L11.1373 1.80368Z" stroke="#666666" stroke-linecap="round" stroke-linejoin="round"/><path d="M3.33333 4.66699C2.97971 4.66699 2.64057 4.80747 2.39052 5.05752C2.14048 5.30756 2 5.6467 2 6.00033V13.3337C2 13.6873 2.14048 14.0264 2.39052 14.2765C2.64057 14.5265 2.97971 14.667 3.33333 14.667H8.66667C8.90071 14.667 9.13063 14.6054 9.33331 14.4884C9.536 14.3713 9.70431 14.203 9.82133 14.0003" stroke="#666666" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <svg
            class="check-icon"
            style="display: none;"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <mask id="mask0_10852_4816" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24"><rect width="24" height="24" fill="#D9D9D9"/></mask><g mask="url(#mask0_10852_4816)"><path d="M9.55001 15.5155L18.1885 6.87702C18.3372 6.72819 18.5112 6.65219 18.7105 6.64902C18.9098 6.64585 19.0871 6.72185 19.2423 6.87702C19.3974 7.03219 19.475 7.21035 19.475 7.41152C19.475 7.61285 19.3974 7.7911 19.2423 7.94627L10.1828 17.0213C10.0019 17.2019 9.79101 17.2923 9.55001 17.2923C9.30901 17.2923 9.09809 17.2019 8.91726 17.0213L4.74226 12.8463C4.59359 12.6974 4.52026 12.5208 4.52226 12.3163C4.52409 12.1119 4.60259 11.9322 4.75776 11.777C4.91292 11.6219 5.09109 11.5443 5.29226 11.5443C5.49359 11.5443 5.67184 11.6219 5.82701 11.777L9.55001 15.5155Z" fill="#666666"/></g>
          </svg>
        </button>
      </div>
      {% if product.description != blank %}
        <div class="pdp-product-description rte">
          <div class="read-more-wrapper">
            <div id="readMoreContent" class="read-more-content collapsed">{{ product.description }}</div>
            <button id="readMoreBtn" class="read-more-btn">Read More</button>
          </div>
        </div>
      {% endif %}
      <div class="grid-information">
        {%- assign components_data = variant.metafields.ornaverse.components.value -%}
        {%- assign json_components = components_data.components -%}

        {%- assign metal_weight = variant.metafields.ornaverse.metal_weight
          | default: variant.metafields.custom.metal_weight
        -%}
        {%- assign gross_weight = variant.metafields.ornaverse.gross_weight
          | default: variant.metafields.custom.gross_weight
        -%}
        {%- if variant.metafields.custom.metal_purity != blank
          or variant.metafields.custom.metal_color != blank
          or metal_weight != blank
        -%}
          <div class="pdp-info-section" id="metal-information" data-section="metal">
            <div class="pdp-section-title">
              {{- 'icon-metal.svg' | inline_asset_content -}}
              Metal
            </div>
            <div class="pdp-info-grid">
              <div class="pdp-info-item">
                {%- if variant.metafields.custom.metal_purity != blank
                  or variant.metafields.custom.metal_color != blank
                -%}
                  <span class="pdp-info-title" id="metal-label" data-field="metal_purity, metal_color">
                    {{ variant.metafields.custom.metal_purity }}
                    {{ variant.metafields.custom.metal_color }}
                  </span>
                {% endif %}
                {% if metal_weight != blank -%}
                  <span class="pdp-info-title" id="metal-net-weight" data-field="net_weight">
                    Net Wt: {{ metal_weight }} g
                  </span>
                {%- endif %}
              </div>
            </div>
          </div>
        {%- endif -%}
        {%- if variant.metafields.custom.top_height != blank
          or variant.metafields.custom.top_width != blank
          or gross_weight != blank
        -%}
          <div class="pdp-info-section" id="dimension-information" data-section="dimension">
            <div class="pdp-section-title">
              {{- 'icon-dimension.svg' | inline_asset_content -}}
              Dimension
            </div>
            <div class="pdp-info-grid">
              <div class="pdp-info-item">
                {% if variant.metafields.custom.top_height != blank -%}
                  <span class="pdp-info-title" id="dimension-height" data-field="top_height">
                    Height: {{ variant.metafields.custom.top_height }}mm
                  </span>
                {%- endif %}
                {% if variant.metafields.custom.top_width != blank %}
                  <span class="pdp-info-title" id="dimension-width" data-field="top_width">
                    Width: {{ variant.metafields.custom.top_width }}mm
                  </span>
                {% endif %}
                {% if gross_weight != blank -%}
                  <span class="pdp-info-title" id="dimension-gross-weight" data-field="gross_weight">
                    Gross Wt: {{ gross_weight | round: 2 }} g
                  </span>
                {%- endif %}
              </div>
            </div>
          </div>
        {%- endif -%}
        {%- assign has_diamonds = false -%}
        {%- assign json_diamonds = '' -%}
        {%- for comp in json_components -%}
          {%- if comp.item_group_name == 'Diamond' -%}
            {%- assign has_diamonds = true -%}
            {%- assign json_diamonds = json_diamonds | append: comp.weight | append: ' ' -%}
          {%- endif -%}
        {%- endfor -%}

        {%- assign custom_diamonds_exist = false -%}
        {%- for i in (1..4) -%}
          {%- assign clarity_key = 'diamond_' | append: i | append: '_clarity' -%}
          {%- if variant.metafields.custom[clarity_key] != blank -%}
            {%- assign custom_diamonds_exist = true -%}
            {%- assign has_diamonds = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if has_diamonds -%}
          <div class="pdp-info-section" id="diamond-information" data-section="diamond">
            <div class="pdp-section-title">
              {{- 'icon-diamond.svg' | inline_asset_content -}}
              Diamond
            </div>
            <div class="pdp-info-grid" id="diamond-grid">
              {%- assign diamonds_displayed = false -%}

              {%- for comp in json_components -%}
                {%- if comp.item_group_name == 'Diamond' -%}
                  {%- assign diamonds_displayed = true -%}
                  <div class="pdp-info-item" data-source="json">
                    {%- if comp.quality_code != 'NA' or comp.stone_color_code != 'NA' -%}
                      <span class="pdp-info-title">
                        {%- if comp.quality_code != 'NA' -%}{{ comp.quality_code }}{%- endif -%}
                        {%- if comp.quality_code != 'NA' and comp.stone_color_code != 'NA' -%}, {% endif -%}
                        {%- if comp.stone_color_code != 'NA' -%}{{ comp.stone_color_code }}{%- endif -%}
                      </span>
                    {%- endif -%}
                    {%- if comp.shape_code != 'NA' -%}
                      <span class="pdp-info-title">{{ comp.shape_code }}</span>
                    {%- endif -%}
                    {%- if comp.pieces != 0 -%}
                      <span class="pdp-info-title">{{ comp.pieces }}pcs</span>
                    {%- endif -%}
                    {%- if comp.weight > 0 -%}
                      <span class="pdp-info-title">{{ comp.weight }}ct</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}

              {%- unless diamonds_displayed -%}
                {%- for i in (1..4) -%}
                  {%- assign clarity_key = 'diamond_' | append: i | append: '_clarity' -%}
                  {%- assign color_key = 'diamond_' | append: i | append: '_color' -%}
                  {%- assign shape_key = 'diamond_' | append: i | append: '_shape' -%}
                  {%- assign numbers_key = 'diamond_' | append: i | append: '_numbers' -%}
                  {%- assign weight_key = 'diamond_' | append: i | append: '_weight' -%}

                  {%- if variant.metafields.custom[clarity_key] != blank
                    or variant.metafields.custom[color_key] != blank
                    or variant.metafields.custom[shape_key] != blank
                    or variant.metafields.custom[numbers_key] != blank
                    or variant.metafields.custom[weight_key] != blank
                  -%}
                    <div class="pdp-info-item" data-diamond="{{ i }}" data-source="custom">
                      {% if variant.metafields.custom[clarity_key] != blank
                        or variant.metafields.custom[color_key] != blank
                      -%}
                        <span class="pdp-info-title" id="diamond-clarity-color-{{ i }}">
                          {{ variant.metafields.custom[clarity_key] -}}
                          {%- if variant.metafields.custom[clarity_key] != blank
                            and variant.metafields.custom[color_key] != blank
                          -%}
                            ,
                          {% endif -%}
                          {{- variant.metafields.custom[color_key] }}
                        </span>
                      {% endif %}
                      {% if variant.metafields.custom[shape_key] != blank -%}
                        <span class="pdp-info-title" id="diamond-shape-{{ i }}">
                          {{ variant.metafields.custom[shape_key] }}
                        </span>
                      {% endif %}
                      {% if variant.metafields.custom[numbers_key] != blank -%}
                        <span class="pdp-info-title" id="diamond-pcs-{{ i }}">
                          {{- variant.metafields.custom[numbers_key] }}pcs
                        </span>
                      {%- endif %}
                      {% if variant.metafields.custom[weight_key] != blank -%}
                        <span class="pdp-info-title" id="diamond-weight-{{ i }}">
                          {{- variant.metafields.custom[weight_key] }}ct
                        </span>
                      {%- endif %}
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              {%- endunless -%}
            </div>
          </div>
        {%- endif -%}
        {%- assign has_gemstones = false -%}
        {%- for comp in json_components -%}
          {%- assign group_lower = comp.item_group_name | downcase -%}
          {%- if group_lower contains 'gold'
            or group_lower contains 'metal'
            or group_lower contains 'silver'
            or group_lower contains 'platinum'
            or group_lower contains 'diamond'
          -%}
            {%- continue -%}
          {%- endif -%}
          {%- assign has_gemstones = true -%}
          {%- break -%}
        {%- endfor -%}
        {%- unless has_gemstones -%}
          {%- for i in (1..4) -%}
            {%- assign color_key = 'gemstone_' | append: i | append: '_color' -%}
            {%- assign shape_key = 'gemstone_' | append: i | append: '_shape' -%}
            {%- assign weight_key = 'gemstone_' | append: i | append: '_weight' -%}

            {%- if variant.metafields.custom[color_key] != blank
              or variant.metafields.custom[shape_key] != blank
              or variant.metafields.custom[weight_key] != blank
            -%}
              {%- assign has_gemstones = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endunless -%}

        {%- if has_gemstones -%}
          <div class="pdp-info-section" id="gemstone-information" data-section="gemstone">
            <div class="pdp-section-title">
              {{- 'icon-gemstone.svg' | inline_asset_content -}}
              Gemstone
            </div>
            <div class="pdp-info-grid" id="gemstone-grid">
              {%- for comp in json_components -%}
                {%- assign group_lower = comp.item_group_name | downcase -%}
                {%- unless group_lower contains 'gold'
                  or group_lower contains 'metal'
                  or group_lower contains 'silver'
                  or group_lower contains 'platinum'
                  or group_lower contains 'diamond'
                -%}
                  <div class="pdp-info-item" data-source="json">
                    {%- if comp.item_group_name != 'Gemstone' -%}
                      <span class="pdp-info-title">{{ comp.item_group_name }}</span>
                    {%- endif -%}
                    {%- if comp.stone_color_code != 'NA' -%}
                      <span class="pdp-info-title">{{ comp.stone_color_code }}</span>
                    {%- endif -%}
                    {%- if comp.shape_code != 'NA' -%}
                      <span class="pdp-info-title">{{ comp.shape_code }}</span>
                    {%- endif -%}
                    {%- if comp.pieces != 0 -%}
                      <span class="pdp-info-title">{{ comp.pieces }}pcs</span>
                    {%- endif -%}
                    {%- if comp.weight > 0 -%}
                      <span class="pdp-info-title">{{ comp.weight }}ct</span>
                    {%- endif -%}
                  </div>
                {%- endunless -%}
              {%- endfor -%}
              {%- for i in (1..4) -%}
                {%- assign color_key = 'gemstone_' | append: i | append: '_color' -%}
                {%- assign shape_key = 'gemstone_' | append: i | append: '_shape' -%}
                {%- assign numbers_key = 'gemstone_' | append: i | append: '_numbers' -%}
                {%- assign weight_key = 'gemstone_' | append: i | append: '_weight' -%}

                {%- if variant.metafields.custom[color_key] != blank
                  or variant.metafields.custom[shape_key] != blank
                  or variant.metafields.custom[numbers_key] != blank
                  or variant.metafields.custom[weight_key] != blank
                -%}
                  <div class="pdp-info-item" data-gemstone="{{ i }}" data-source="custom">
                    {%- if variant.metafields.custom[color_key] != blank -%}
                      <span class="pdp-info-title" id="gemstone-color-{{ i }}">
                        {{ variant.metafields.custom[color_key] }}
                      </span>
                    {%- endif -%}
                    {%- if variant.metafields.custom[shape_key] != blank -%}
                      <span class="pdp-info-title" id="gemstone-shape-{{ i }}">
                        {{ variant.metafields.custom[shape_key] }}
                      </span>
                    {%- endif -%}
                    {%- if variant.metafields.custom[numbers_key] != blank -%}
                      <span class="pdp-info-title" id="gemstone-numbers-{{ i }}">
                        {{- variant.metafields.custom[numbers_key] }}pcs
                      </span>
                    {%- endif -%}
                    {%- if variant.metafields.custom[weight_key] != blank -%}
                      <span class="pdp-info-title" id="gemstone-weight-{{ i }}">
                        {{- variant.metafields.custom[weight_key] }}ct
                      </span>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</variant-selects>

<style>
  .pdp-tabs-container .pdp-info-section {width: calc(50% - 5px);}
</style>

{%- assign components_data = variant.metafields.ornaverse.components.value -%}
{%- assign json_components = components_data.components -%}
{%- assign g1 = variant.metafields.custom.gemstone_1_color -%}
{%- assign g2 = variant.metafields.custom.gemstone_2_color -%}
{%- assign g3 = variant.metafields.custom.gemstone_3_color -%}
{%- assign d1 = variant.metafields.custom.diamond_1_color -%}
{%- assign d2 = variant.metafields.custom.diamond_2_color -%}
{%- assign d3 = variant.metafields.custom.diamond_3_color -%}
{%- assign has_gem = 'false' -%}
{%- assign has_diam = 'false' -%}
{%- if g1 != blank or g2 != blank or g3 != blank -%}
  {%- assign has_gem = 'true' -%}
{%- endif -%}
{%- if d1 != blank or d2 != blank or d3 != blank -%}
  {%- assign has_diam = 'true' -%}
{%- endif -%}
{%- if json_components != blank -%}
  {%- for comp in json_components -%}
    {%- assign group_lower = comp.item_group_name | downcase -%}
    {%- if group_lower contains 'diamond' -%}
      {%- assign has_diam = 'true' -%}
    {%- elsif group_lower contains 'gold'
      or group_lower contains 'metal'
      or group_lower contains 'silver'
      or group_lower contains 'platinum'
    -%}
    {%- else -%}
      {%- assign has_gem = 'true' -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- assign gem_count = 0 -%}
{%- if g1 != blank -%}{%- assign gem_count = gem_count | plus: 1 -%}{%- endif -%}
{%- if g2 != blank -%}{%- assign gem_count = gem_count | plus: 1 -%}{%- endif -%}
{%- if g3 != blank -%}{%- assign gem_count = gem_count | plus: 1 -%}{%- endif -%}

{%- assign diam_count = 0 -%}
{%- if d1 != blank -%}{%- assign diam_count = diam_count | plus: 1 -%}{%- endif -%}
{%- if d2 != blank -%}{%- assign diam_count = diam_count | plus: 1 -%}{%- endif -%}
{%- if d3 != blank -%}{%- assign diam_count = diam_count | plus: 1 -%}{%- endif -%}

{%- if gem_count <= 2 and diam_count <= 2 and gem_count > 0 and diam_count > 0 -%}
  <style>
    .pdp-tabs-container #gemstone-information .pdp-info-item,
    .pdp-tabs-container #diamond-information .pdp-info-item {
      width: calc(50% - 10px) !important;
    }
  </style>
{%- endif -%}

{%- if has_gem == 'false' and diam_count >= 2 -%}
  <style>
    .pdp-tabs-container #diamond-information .pdp-info-item {
      width: calc(25% - 15px);
    }
  </style>
{%- endif -%}

{%- if g3 != blank -%}
  <style>
    .pdp-tabs-container #diamond-information { width: 100%; display:block; }
    .pdp-tabs-container #gemstone-information { width: 100%; display:block; }
    .pdp-tabs-container #gemstone-information .pdp-info-item {width: calc(25% - 15px);}
  </style>
{%- elsif d3 != blank -%}
  <style>
    .pdp-tabs-container #diamond-information { width: 100%; display:block; }
    .pdp-tabs-container #gemstone-information { width: 100%; display:block; }
    .pdp-tabs-container #diamond-information .pdp-info-item {width: calc(25% - 15px);}
  </style>
{%- elsif has_gem == 'false' and has_diam == 'true' -%}
  <style>
    .pdp-tabs-container #diamond-information { width: 100%; }
    .pdp-tabs-container #gemstone-information { display: none; }
  </style>

{%- elsif has_gem == 'true' and has_diam == 'false' -%}
  <style>
    .pdp-tabs-container #gemstone-information { width: 100%; }
    .pdp-tabs-container #diamond-information { display: none; }
  </style>
{%- elsif has_gem == 'true' and has_diam == 'true' -%}
  <style>
    .pdp-tabs-container .pdp-info-section { width: calc(50% - 5px); display: block; }
    .pdp-tabs-container #diamond-information { display: block; }
    .pdp-tabs-container #gemstone-information { display: block; }
  </style>
{%- else -%}
  <style>
    .pdp-tabs-container .pdp-info-section { width: calc(50% - 5px); }
  </style>
{%- endif -%}

{% assign config = variant.metafields['DI-GoldPrice'].variant_config.value %}
{% assign metal_rates = shop.metafields['DI-GoldPrice'].metal_prices.value %}
{% assign stone_pricing_db = shop.metafields['DI-GoldPrice'].stone_pricing.value %}

{% assign metal_color = 'Yellow' %}
{% assign variant_title_down = variant.title | downcase %}
{% if variant_title_down contains 'rose' %}
  {% assign metal_color = 'Rose' %}
{% elsif variant_title_down contains 'platinum' %}
  {% assign metal_color = 'Platinum' %}
{% elsif variant_title_down contains 'white' %}
  {% assign metal_color = 'White' %}
{% endif %}

{% assign metal_rate_key = '' %}
{% assign metal_type = config.metal_type | downcase %}

{% if metal_type == 'platinum' %}
  {% assign metal_rate_key = 'platinum_price' %}
  {% assign final_metal_rate = metal_rates[metal_rate_key] | times: 100 %}
{% else %}
  {% assign purity_key = config.purity | downcase | prepend: 'gold_price_' %}
  {% assign final_metal_rate = metal_rates[purity_key] | times: 100 %}
{% endif %}

{% assign metal_cost = final_metal_rate | times: config.metal_weight %}

{% assign gold_rate = final_metal_rate %}
{% assign display_rate_per_g = final_metal_rate | divided_by: 100.0 %}

{% assign diamond_final = 0.0 %}
{% assign diamond_original = 0.0 %}
{% assign diamond_pcs = 0 %}
{% assign diamond_groups = '' %}

{% assign gemstone_final = 0.0 %}
{% assign gemstone_original = 0.0 %}
{% assign gemstone_pcs = 0 %}
{% assign gemstone_title = '' %}

{% for stone_item in config.advanced_stone_config %}
  {% assign slab_rate = 0 %}
  {% assign slab_discount = 0 %}
  {% assign current_title = '' %}

  {% assign pricing_ref = stone_pricing_db | where: 'id', stone_item.pricing_id | first %}

  {% if pricing_ref %}
    {% assign current_title = pricing_ref.title %}
    {% assign avg_weight = stone_item.stone_weight | times: 1.0 | divided_by: stone_item.stone_quantity %}

    {% for slab in pricing_ref.slabs %}
      {% if avg_weight >= slab.from_weight and avg_weight <= slab.to_weight %}
        {% assign slab_rate = slab.price | times: 100 %}
        {% assign slab_discount = slab.discount | default: 0 %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {% assign item_base_cost = slab_rate | times: stone_item.stone_weight %}

  {% assign applied_discount = 0 %}
  {% if stone_item.stone_type == 'diamond' %}
    {% assign applied_discount = config.diamond_discount | default: slab_discount %}
  {% else %}
    {% assign applied_discount = slab_discount %}
  {% endif %}

  {% assign discount_amount = item_base_cost | times: applied_discount | divided_by: 100.0 %}
  {% assign item_final_cost = item_base_cost | minus: discount_amount %}

  {% if stone_item.stone_type == 'diamond' %}

  {% assign diamond_final = diamond_final | plus: item_final_cost %}
  {% assign diamond_original = diamond_original | plus: item_base_cost %}
  {% assign diamond_pcs = diamond_pcs | plus: stone_item.stone_quantity %}

  {% else %}
    {% assign gemstone_final = gemstone_final | plus: item_final_cost %}
    {% assign gemstone_original = gemstone_original | plus: item_base_cost %}
    {% assign gemstone_pcs = gemstone_pcs | plus: stone_item.stone_quantity %}
    {% if gemstone_title == '' %}{% assign gemstone_title = current_title %}{% endif %}
  {% endif %}
{% endfor %}

{% assign grp_diamond_titles = '' %}
{% for stone_item in config.advanced_stone_config %}
  {% if stone_item.stone_type == 'diamond' %}
    {% assign grp_pr = stone_pricing_db | where: 'id', stone_item.pricing_id | first %}
    {% if grp_pr %}
      {% assign grp_t = grp_pr.title %}
      {% assign grp_title_list = grp_diamond_titles | split: '||' %}
      {% assign grp_already = false %}
      {% for grp_existing in grp_title_list %}
        {% if grp_existing == grp_t %}{% assign grp_already = true %}{% break %}{% endif %}
      {% endfor %}
      {% unless grp_already %}
        {% if grp_diamond_titles == '' %}
          {% assign grp_diamond_titles = grp_t %}
        {% else %}
          {% assign grp_diamond_titles = grp_diamond_titles | append: '||' | append: grp_t %}
        {% endif %}
      {% endunless %}
    {% endif %}
  {% endif %}
{% endfor %}

{% assign grp_title_arr = grp_diamond_titles | split: '||' %}
{% capture diamond_rows %}
  {% for grp_title in grp_title_arr %}
    {% assign grp_qty   = 0 %}
    {% assign grp_base  = 0.0 %}
    {% assign grp_final = 0.0 %}

    {% for stone_item in config.advanced_stone_config %}
      {% if stone_item.stone_type == 'diamond' %}
        {% assign grp_pr = stone_pricing_db | where: 'id', stone_item.pricing_id | first %}
        {% if grp_pr and grp_pr.title == grp_title %}
          {% assign grp_avg_wt    = stone_item.stone_weight | times: 1.0 | divided_by: stone_item.stone_quantity %}
          {% assign grp_slab_rate = 0 %}
          {% assign grp_slab_disc = 0 %}
          {% for slab in grp_pr.slabs %}
            {% if grp_avg_wt >= slab.from_weight and grp_avg_wt <= slab.to_weight %}
              {% assign grp_slab_rate = slab.price | times: 100 %}
              {% assign grp_slab_disc = slab.discount | default: 0 %}
              {% break %}
            {% endif %}
          {% endfor %}
          {% assign grp_item_base  = grp_slab_rate | times: stone_item.stone_weight %}
          {% assign grp_app_disc   = config.diamond_discount | default: grp_slab_disc %}
          {% assign grp_disc_amt   = grp_item_base | times: grp_app_disc | divided_by: 100.0 %}
          {% assign grp_item_final = grp_item_base | minus: grp_disc_amt %}
          {% assign grp_qty   = grp_qty   | plus: stone_item.stone_quantity %}
          {% assign grp_base  = grp_base  | plus: grp_item_base %}
          {% assign grp_final = grp_final | plus: grp_item_final %}
        {% endif %}
      {% endif %}
    {% endfor %}

     <div class="price-breakdown-box-item">
      <span>
        {{ grp_title }} ({{ grp_qty }} Pcs.)
        {% assign grp_saving = grp_base | minus: grp_final %}
