                  {% elsif avg_wt <= 0.999 %}
                    {% assign mined_rate = 89373 %}
                  {% elsif avg_wt <= 1.499 %}
                    {% assign mined_rate = 126906 %}
                  {% elsif avg_wt <= 1.999 %}
                    {% assign mined_rate = 179840 %}
                  {% elsif avg_wt <= 2.999 %}
                    {% assign mined_rate = 301515 %}
                  {% else %}
