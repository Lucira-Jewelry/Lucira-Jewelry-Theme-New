        {% endif %}
        <span class="price-breakdown-box-value">{{ grp_final | money }}</span>
      </div>
    </div>
  {% endfor %}
{% endcapture %}

{% assign mc_rate_original = config.making_charges | default: 0 | times: 100 %}
