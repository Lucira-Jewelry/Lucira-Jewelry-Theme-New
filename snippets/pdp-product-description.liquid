{% assign variant = product.selected_or_first_available_variant %}
<div class="pdp-details-main">
  <div class="pdp-details-accordion">

    <!-- Product Information -->
    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-1" />
      <label for="pdp-details-accordion-item-1" class="pdp-details-accordion-item-title" onclick="pushPromo('Product Information')">
        Product Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <div>
          <p class="product__sku{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if variant.sku.size == 0 %} visibility-hidden{% endif %}" id="Sku-{{ section.id }}" role="status" {{ block.shopify_attributes }}>
            {% if variant.sku %}
              <span class="visually-hidden-">{{ 'products.product.sku' | t }}:</span>
              {{- variant.sku -}}
            {% endif %}
          </p>
          <div class="product__description rte quick-add-hidden" {{ block.shopify_attributes }}>
            {{ product.description }}
          </div>
        </div>
      </div>
    </div>

    <!-- Metal Information -->
    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-2" />
      <label for="pdp-details-accordion-item-2" class="pdp-details-accordion-item-title" onclick="pushPromo('Metal Information')">
        Metal Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table id="metal-info-table">
          <thead>
            <tr>
              <th>METAL</th>
              <th>WEIGHT</th>
              <th>DIMENSIONS</th>
            </tr>
          </thead>
          <tbody>
            <tr id="metal-info-row">
              <td id="metal-type">
                {% if variant.metafields.custom.metal_purity %}{{ variant.metafields.custom.metal_purity }} - {% endif %}
                {% if variant.metafields.custom.metal_color %}{{ variant.metafields.custom.metal_color }}{% endif %}
              </td>
              <td id="metal-weight">
                {% if variant.metafields.custom.metal_weight %}Net Wt: {{ variant.metafields.custom.metal_weight }}g<br>{% endif %}
                {% if variant.metafields.custom.gross_weight %}Gross Wt: {{ variant.metafields.custom.gross_weight }}g{% endif %}
              </td>
              <td id="metal-dimensions">
                {% if variant.metafields.custom.top_width %}Width: {{ variant.metafields.custom.top_width }}mm<br>{% endif %}
                {% if variant.metafields.custom.top_height %}Height: {{ variant.metafields.custom.top_height }}mm{% endif %}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Diamond Information (rendered server-side for initial variant) -->
    {% assign diamond_count = 4 %}
    {% assign show_diamonds = false %}
    {% for i in (1..diamond_count) %}
      {% assign type_key = 'diamond_' | append: i | append: '_type_' %}
      {% assign type_value = variant.metafields.custom[type_key] | metafield_text %}
      {% if type_value != blank %}
        {% assign show_diamonds = true %}
      {% endif %}
    {% endfor %}

    {% if show_diamonds %}
      <div class="pdp-details-accordion-item">
        <input type="checkbox" id="pdp-details-accordion-item-3" />
        <label for="pdp-details-accordion-item-3" class="pdp-details-accordion-item-title" onclick="pushPromo('Diamond Information')">
          Diamond Information
          <i class="fa-solid fa-angle-down"></i>
        </label>
        <div class="pdp-details-accordion-item-content">
          <table>
            <thead>
              <tr>
                <th>TYPE</th>
                <th>PCS / SHAPE</th>
                <th>SETTING / WT</th>
              </tr>
            </thead>
            <tbody id="diamond-table-body">
              {% for i in (1..diamond_count) %}
                {% assign type_key = 'diamond_' | append: i | append: '_type_' %}
                {% assign shape_key = 'diamond_' | append: i | append: '_shape' %}
                {% assign numbers_key = 'diamond_' | append: i | append: '_numbers' %}
                {% assign setting_key = 'diamond_' | append: i | append: '_setting' %}
                {% assign weight_key = 'diamond_' | append: i | append: '_weight' %}
                {% assign clarity_key = 'diamond_' | append: i | append: '_clarity' %}
                {% assign color_key = 'diamond_' | append: i | append: '_color' %}
                {% assign type_value = variant.metafields.custom[type_key] | metafield_text %}
                {% if type_value != blank %}
                  <tr>
                    <td>{{ type_value }}/ {{ variant.metafields.custom[clarity_key] | metafield_text }} - {{ variant.metafields.custom[color_key] | metafield_text }}</td>
                    <td>{{ variant.metafields.custom[numbers_key] | metafield_text }} - {{ variant.metafields.custom[shape_key] | metafield_text }}</td>
                    <td>{{ variant.metafields.custom[setting_key] | metafield_text }}: {{ variant.metafields.custom[weight_key] | metafield_text }}ct</td>
                  </tr>
                {% endif %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% endif %}

    <!-- Gemstone Information (rendered server-side for initial variant) -->
    {% assign gemstone_count = 4 %}
    {% assign show_gemstones = false %}
    {% for i in (1..gemstone_count) %}
      {% assign type_key = 'gemstone_' | append: i | append: '_type_' %}
      {% assign type_value = variant.metafields.custom[type_key] | metafield_text %}
      {% if type_value != blank %}
        {% assign show_gemstones = true %}
      {% endif %}
    {% endfor %}

    {% if show_gemstones %}
      <div class="pdp-details-accordion-item">
        <input type="checkbox" id="pdp-details-accordion-item-4"/>
        <label for="pdp-details-accordion-item-4" class="pdp-details-accordion-item-title" onclick="pushPromo('Gemstone Information')">
          Gemstone Information
          <i class="fa-solid fa-angle-down"></i>
        </label>
        <div class="pdp-details-accordion-item-content">
          <table>
            <thead>
              <tr>
                <th>TYPE</th>
                <th>SHAPE / PCS</th>
                <th>SETTING / WT</th>
              </tr>
            </thead>
            <tbody id="gemstone-table-body">
              {% for i in (1..gemstone_count) %}
                {% assign type_key = 'gemstone_' | append: i | append: '_type_' %}
                {% assign shape_key = 'gemstone_' | append: i | append: '_shape' %}
                {% assign numbers_key = 'gemstone_' | append: i | append: '_numbers' %}
                {% assign setting_key = 'gemstone_' | append: i | append: '_setting' %}
                {% assign weight_key = 'gemstone_' | append: i | append: '_weight' %}
                {% assign clarity_key = 'gemstone_' | append: i | append: '_clarity' %}
                {% assign color_key = 'gemstone_' | append: i | append: '_color' %}
                {% assign type_value = variant.metafields.custom[type_key] | metafield_text %}
                {% if type_value != blank %}
                  <tr>
                    <td>{{ variant.metafields.custom[color_key] | metafield_text }} - {{ type_value }}</td>
                    <td>{{ variant.metafields.custom[numbers_key] | metafield_text }} - {{ variant.metafields.custom[shape_key] | metafield_text }}</td>
                    <td>{{ variant.metafields.custom[setting_key] | metafield_text }}: {{ variant.metafields.custom[weight_key] | metafield_text }}ct</td>
                  </tr>
                {% endif %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% endif %}

  </div>
</div>

<!-- =========================
     Variant metafields -> JS
     (safe Liquid - builds window.variantMetafields)
     ========================= -->
<script>
window.variantMetafields = window.variantMetafields || {};
{% for v in product.variants %}
  window.variantMetafields["{{ v.id }}"] = {
    sku: {{ v.sku | json }},
    metal_purity: {{ v.metafields.custom.metal_purity | json }},
    metal_color: {{ v.metafields.custom.metal_color | json }},
    metal_weight: {{ v.metafields.custom.metal_weight | json }},
    gross_weight: {{ v.metafields.custom.gross_weight | json }},
    top_width: {{ v.metafields.custom.top_width | json }},
    top_height: {{ v.metafields.custom.top_height | json }},
    diamonds: {
      {% for i in (1..4) %}
        {% assign t = 'diamond_' | append: i | append: '_type_' %}
        {% assign s = 'diamond_' | append: i | append: '_shape' %}
        {% assign n = 'diamond_' | append: i | append: '_numbers' %}
        {% assign se = 'diamond_' | append: i | append: '_setting' %}
        {% assign w = 'diamond_' | append: i | append: '_weight' %}
        {% assign c = 'diamond_' | append: i | append: '_clarity' %}
        {% assign co = 'diamond_' | append: i | append: '_color' %}
        "{{ i }}": {
          type: {{ v.metafields.custom[t] | json }},
          shape: {{ v.metafields.custom[s] | json }},
          numbers: {{ v.metafields.custom[n] | json }},
          setting: {{ v.metafields.custom[se] | json }},
          weight: {{ v.metafields.custom[w] | json }},
          clarity: {{ v.metafields.custom[c] | json }},
          color: {{ v.metafields.custom[co] | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    },
    gemstones: {
      {% for i in (1..4) %}
        {% assign t = 'gemstone_' | append: i | append: '_type_' %}
        {% assign s = 'gemstone_' | append: i | append: '_shape' %}
        {% assign n = 'gemstone_' | append: i | append: '_numbers' %}
        {% assign se = 'gemstone_' | append: i | append: '_setting' %}
        {% assign w = 'gemstone_' | append: i | append: '_weight' %}
        {% assign c = 'gemstone_' | append: i | append: '_clarity' %}
        {% assign co = 'gemstone_' | append: i | append: '_color' %}
        "{{ i }}": {
          type: {{ v.metafields.custom[t] | json }},
          shape: {{ v.metafields.custom[s] | json }},
          numbers: {{ v.metafields.custom[n] | json }},
          setting: {{ v.metafields.custom[se] | json }},
          weight: {{ v.metafields.custom[w] | json }},
          clarity: {{ v.metafields.custom[c] | json }},
          color: {{ v.metafields.custom[co] | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    }
  };
{% endfor %}
</script>


<script>
(function(){
  // Helper to escape HTML
  function escapeHtml(str) {
    if (str === null || str === undefined) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  // Clear diamond & gemstone tables
  function clearTables() {
    const d = document.getElementById('diamond-table-body');
    const g = document.getElementById('gemstone-table-body');
    if(d) d.innerHTML = '';
    if(g) g.innerHTML = '';
  }

  // Update accordion for a variant object (only current variant)
  function updateAccordionForVariantData(data) {
    if (!data) {
      // Clear all fields
      document.getElementById('metal-type').textContent = '';
      document.getElementById('metal-weight').textContent = '';
      document.getElementById('metal-dimensions').textContent = '';
      clearTables();
      const skuEl = document.getElementById('Sku-{{ section.id }}');
      if(skuEl) skuEl.textContent = '';
      return;
    }

    // SKU
    const skuEl = document.getElementById('Sku-{{ section.id }}');
    if(skuEl) skuEl.textContent = data.sku || '';

    // Metal
    let metalType = '';
    if(data.metal_purity) metalType += data.metal_purity;
    if(data.metal_color) metalType += (metalType ? ' - ' : '') + data.metal_color;
    document.getElementById('metal-type').textContent = metalType;

    let metalWeight = '';
    if(data.metal_weight) metalWeight += 'Net Wt: ' + data.metal_weight + 'g<br>';
    if(data.gross_weight) metalWeight += 'Gross Wt: ' + data.gross_weight + 'g';
    document.getElementById('metal-weight').innerHTML = metalWeight;

    let metalDimensions = '';
    if(data.top_width) metalDimensions += 'Width: ' + data.top_width + 'mm<br>';
    if(data.top_height) metalDimensions += 'Height: ' + data.top_height + 'mm';
    document.getElementById('metal-dimensions').innerHTML = metalDimensions;

    // Diamonds
    const diamondBody = document.getElementById('diamond-table-body');
    if(diamondBody) {
      let html = '';
      (data.diamonds || []).forEach(d => {
        if(d && d.type) {
          const typeCell = escapeHtml(d.type) + ((d.clarity || d.color) ? ('/ ' + escapeHtml(d.clarity) + '-' + escapeHtml(d.color)) : '');
          html += '<tr>';
          html += '<td>' + typeCell + '</td>';
          html += '<td>' + escapeHtml(d.numbers || '') + ' - ' + escapeHtml(d.shape || '') + '</td>';
          html += '<td>' + escapeHtml(d.setting || '') + ': ' + escapeHtml(d.weight || '') + 'ct</td>';
          html += '</tr>';
        }
      });
      diamondBody.innerHTML = html;
    }

    // Gemstones
    const gemBody = document.getElementById('gemstone-table-body');
    if(gemBody) {
      let html = '';
      (data.gemstones || []).forEach(g => {
        if(g && g.type) {
          html += '<tr>';
          html += '<td>' + escapeHtml(g.color || '') + ' - ' + escapeHtml(g.type) + '</td>';
          html += '<td>' + escapeHtml(g.numbers || '') + ' - ' + escapeHtml(g.shape || '') + '</td>';
          html += '<td>' + escapeHtml(g.setting || '') + ': ' + escapeHtml(g.weight || '') + 'ct</td>';
          html += '</tr>';
        }
      });
      gemBody.innerHTML = html;
    }
  }

  // Fetch metafields for a variant dynamically via data attributes
  function getVariantData(variantId) {
    // Look for a container with data for this variant
    const el = document.querySelector('[data-variant-id="'+variantId+'"]');
    if(!el) return null;
    return {
      sku: el.dataset.sku,
      metal_purity: el.dataset.metalPurity,
      metal_color: el.dataset.metalColor,
      metal_weight: el.dataset.metalWeight,
      gross_weight: el.dataset.grossWeight,
      top_width: el.dataset.topWidth,
      top_height: el.dataset.topHeight,
      diamonds: JSON.parse(el.dataset.diamonds || '[]'),
      gemstones: JSON.parse(el.dataset.gemstones || '[]')
    };
  }

  // Push promo click event
  window.pushPromo = function(promoName) {
    const sel = document.querySelector('select[name="id"], input[name="id"]');
    const variantId = sel ? sel.value : '{{ variant.id }}';
    const el = document.querySelector('[data-variant-id="'+variantId+'"]');
    const sku = el ? el.dataset.sku : '';
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'promoClick',
      promoClick: {
        promo_id: sku,
        promo_name: '{{ product.title }}',
        creative_name: promoName
      }
    });
  };

  // Listen for variant changes
  document.addEventListener('DOMContentLoaded', function() {
    const sel = document.querySelector('select[name="id"], input[name="id"]');
    const initialVariantId = sel ? sel.value : '{{ variant.id }}';
    updateAccordionForVariantData(getVariantData(initialVariantId));

    // Variant change via event
    document.addEventListener('variant:change', function(e) {
      const vid = e?.detail?.variant?.id;
      if(vid) updateAccordionForVariantData(getVariantData(vid));
    });

    // Variant change via select
    if(sel) {
      sel.addEventListener('change', function() {
        updateAccordionForVariantData(getVariantData(this.value));
      });
    }

    // Variant change via clickable elements with data-variant-id
    document.body.addEventListener('click', function(e) {
      const vid = e.target?.dataset?.variantId;
      if(vid) updateAccordionForVariantData(getVariantData(vid));
    });
  });
})();
</script>