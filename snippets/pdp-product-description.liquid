{% assign variant = product.selected_or_first_available_variant %}

<div class="pdp-details-main">
  <div class="pdp-details-accordion">

    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-1" />
      <label for="pdp-details-accordion-item-1" class="pdp-details-accordion-item-title" onclick="pushPromo('Product Information')">
        Product Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <p id="Sku-{{ section.id }}" class="product__sku">{{ variant.sku }}</p>
        <div class="product__description rte quick-add-hidden">
          {{ product.description }}
        </div>
      </div>
    </div>

    <!-- Metal Information -->
    <div class="pdp-details-accordion-item" id="metal-section">
      <input type="checkbox" id="pdp-details-accordion-item-2" />
      <label for="pdp-details-accordion-item-2" class="pdp-details-accordion-item-title" onclick="pushPromo('Metal Information')">
        Metal Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table id="metal-info-table">
          <thead>
            <tr>
              <th>METAL</th>
              <th>WEIGHT</th>
              <th>DIMENSIONS</th>
            </tr>
          </thead>
          <tbody>
            <tr id="metal-info-row">
              <td id="metal-type"></td>
              <td id="metal-weight"></td>
              <td id="metal-dimensions"></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Diamond Information -->
    <div class="pdp-details-accordion-item" id="diamond-section">
      <input type="checkbox" id="pdp-details-accordion-item-3" />
      <label for="pdp-details-accordion-item-3" class="pdp-details-accordion-item-title" onclick="pushPromo('Diamond Information')">
        Diamond Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table>
          <thead>
            <tr>
              <th>TYPE</th>
              <th>PCS / SHAPE</th>
              <th>SETTING / WT</th>
            </tr>
          </thead>
          <tbody id="diamond-table-body"></tbody>
        </table>
      </div>
    </div>

    <!-- Gemstone Information -->
    <div class="pdp-details-accordion-item" id="gemstone-section">
      <input type="checkbox" id="pdp-details-accordion-item-4"/>
      <label for="pdp-details-accordion-item-4" class="pdp-details-accordion-item-title" onclick="pushPromo('Gemstone Information')">
        Gemstone Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table>
          <thead>
            <tr>
              <th>TYPE</th>
              <th>SHAPE / PCS</th>
              <th>SETTING / WT</th>
            </tr>
          </thead>
          <tbody id="gemstone-table-body"></tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<script>
window.variantMetafields = {};

{% for v in product.variants %}
  {% comment %} Build diamonds array {% endcomment %}
  {% assign diamonds_array = "" %}
  {% assign has_diamonds = false %}
  {% for i in (1..4) %}
    {% assign key_type = "diamond_" | append: i | append: "_type_" %}
    {% if v.metafields.custom[key_type] != blank %}
      {% assign has_diamonds = true %}
      {% assign key_shape = "diamond_" | append: i | append: "_shape" %}
      {% assign key_numbers = "diamond_" | append: i | append: "_numbers" %}
      {% assign key_setting = "diamond_" | append: i | append: "_setting" %}
      {% assign key_weight = "diamond_" | append: i | append: "_weight" %}
      {% assign key_clarity = "diamond_" | append: i | append: "_clarity" %}
      {% assign key_color = "diamond_" | append: i | append: "_color" %}

      {% capture diamond_item %}
        {
          "type": {{ v.metafields.custom[key_type] | json }},
          "shape": {{ v.metafields.custom[key_shape] | default: '' | json }},
          "numbers": {{ v.metafields.custom[key_numbers] | default: '' | json }},
          "setting": {{ v.metafields.custom[key_setting] | default: '' | json }},
          "weight": {{ v.metafields.custom[key_weight] | default: '' | json }},
          "clarity": {{ v.metafields.custom[key_clarity] | default: '' | json }},
          "color": {{ v.metafields.custom[key_color] | default: '' | json }}
        }
      {% endcapture %}

      {% if diamonds_array == "" %}
        {% assign diamonds_array = diamond_item %}
      {% else %}
        {% assign diamonds_array = diamonds_array | append: "," | append: diamond_item %}
      {% endif %}
    {% endif %}
  {% endfor %}

  {% comment %} Build gemstones array {% endcomment %}
  {% assign gemstones_array = "" %}
  {% assign has_gemstones = false %}
  {% for i in (1..4) %}
    {% assign key_type = "gemstone_" | append: i | append: "_type_" %}
    {% if v.metafields.custom[key_type] != blank %}
      {% assign has_gemstones = true %}
      {% assign key_shape = "gemstone_" | append: i | append: "_shape" %}
      {% assign key_numbers = "gemstone_" | append: i | append: "_numbers" %}
      {% assign key_setting = "gemstone_" | append: i | append: "_setting" %}
      {% assign key_weight = "gemstone_" | append: i | append: "_weight" %}
      {% assign key_clarity = "gemstone_" | append: i | append: "_clarity" %}
      {% assign key_color = "gemstone_" | append: i | append: "_color" %}

      {% capture gemstone_item %}
        {
          "type": {{ v.metafields.custom[key_type] | json }},
          "shape": {{ v.metafields.custom[key_shape] | default: '' | json }},
          "numbers": {{ v.metafields.custom[key_numbers] | default: '' | json }},
          "setting": {{ v.metafields.custom[key_setting] | default: '' | json }},
          "weight": {{ v.metafields.custom[key_weight] | default: '' | json }},
          "clarity": {{ v.metafields.custom[key_clarity] | default: '' | json }},
          "color": {{ v.metafields.custom[key_color] | default: '' | json }}
        }
      {% endcapture %}

      {% if gemstones_array == "" %}
        {% assign gemstones_array = gemstone_item %}
      {% else %}
        {% assign gemstones_array = gemstones_array | append: "," | append: gemstone_item %}
      {% endif %}
    {% endif %}
  {% endfor %}

  window.variantMetafields["{{ v.id }}"] = {
    sku: {{ v.sku | default: '' | json }},
    metal_purity: {{ v.metafields.custom.metal_purity | default: '' | json }},
    metal_color: {{ v.metafields.custom.metal_color | default: '' | json }},
    metal_weight: {{ v.metafields.custom.metal_weight | default: '' | json }},
    gross_weight: {{ v.metafields.custom.gross_weight | default: '' | json }},
    top_width: {{ v.metafields.custom.top_width | default: '' | json }},
    top_height: {{ v.metafields.custom.top_height | default: '' | json }},
    diamonds: {% if has_diamonds %}[{{ diamonds_array }}]{% else %}[]{% endif %},
    gemstones: {% if has_gemstones %}[{{ gemstones_array }}]{% else %}[]{% endif %},
    has_metal_info: {% if v.metafields.custom.metal_purity != blank or v.metafields.custom.metal_color != blank or v.metafields.custom.metal_weight != blank or v.metafields.custom.gross_weight != blank or v.metafields.custom.top_width != blank or v.metafields.custom.top_height != blank %}true{% else %}false{% endif %},
    has_diamonds: {{ has_diamonds | json }},
    has_gemstones: {{ has_gemstones | json }}
  };
{% endfor %}
</script>

<script>
(function(){
  function escapeHtml(str) {
    if (!str) return '';
    return String(str)
      .replace(/&/g,'&amp;')
      .replace(/</g,'&lt;')
      .replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;')
      .replace(/'/g,'&#39;');
  }

  function clearAccordion() {
    const skuElement = document.getElementById('Sku-{{ section.id }}');
    const metalTypeElement = document.getElementById('metal-type');
    const metalWeightElement = document.getElementById('metal-weight');
    const metalDimensionsElement = document.getElementById('metal-dimensions');
    const diamondBodyElement = document.getElementById('diamond-table-body');
    const gemstoneBodyElement = document.getElementById('gemstone-table-body');

    if (skuElement) skuElement.textContent = '';
    if (metalTypeElement) metalTypeElement.textContent = '';
    if (metalWeightElement) metalWeightElement.innerHTML = '';
    if (metalDimensionsElement) metalDimensionsElement.innerHTML = '';
    if (diamondBodyElement) diamondBodyElement.innerHTML = '';
    if (gemstoneBodyElement) gemstoneBodyElement.innerHTML = '';

    // Hide all sections
    const metalSection = document.getElementById('metal-section');
    const diamondSection = document.getElementById('diamond-section');
    const gemstoneSection = document.getElementById('gemstone-section');
    
    if (metalSection) metalSection.style.display = 'none';
    if (diamondSection) diamondSection.style.display = 'none';
    if (gemstoneSection) gemstoneSection.style.display = 'none';
  }

  function updateAccordionForVariant(variantId) {
    console.log('Updating accordion for variant:', variantId);
    const data = window.variantMetafields[variantId];
    
    if (!data) {
      console.log('No data found for variant:', variantId);
      return clearAccordion();
    }

    console.log('Variant data:', data);

    // SKU
    const skuElement = document.getElementById('Sku-{{ section.id }}');
    if (skuElement) {
      skuElement.textContent = data.sku || '';
    }

    // Metal Section
    const metalSection = document.getElementById('metal-section');
    if (metalSection && data.has_metal_info) {
      metalSection.style.display = 'block';
      
      const metalTypeElement = document.getElementById('metal-type');
      const metalWeightElement = document.getElementById('metal-weight');
      const metalDimensionsElement = document.getElementById('metal-dimensions');
      
      if (metalTypeElement) {
        const metalParts = [data.metal_purity, data.metal_color].filter(part => part && part.trim() !== '');
        metalTypeElement.textContent = metalParts.join(' - ');
      }
      
      if (metalWeightElement) {
        let weightHtml = '';
        if (data.metal_weight && data.metal_weight.trim() !== '') {
          weightHtml += 'Net Wt: ' + escapeHtml(data.metal_weight) + 'g<br>';
        }
        if (data.gross_weight && data.gross_weight.trim() !== '') {
          weightHtml += 'Gross Wt: ' + escapeHtml(data.gross_weight) + 'g';
        }
        metalWeightElement.innerHTML = weightHtml;
      }
      
      if (metalDimensionsElement) {
        let dimensionsHtml = '';
        if (data.top_width && data.top_width.trim() !== '') {
          dimensionsHtml += 'Width: ' + escapeHtml(data.top_width) + 'mm<br>';
        }
        if (data.top_height && data.top_height.trim() !== '') {
          dimensionsHtml += 'Height: ' + escapeHtml(data.top_height) + 'mm';
        }
        metalDimensionsElement.innerHTML = dimensionsHtml;
      }
    } else if (metalSection) {
      metalSection.style.display = 'none';
    }

    // Diamonds Section
    const diamondSection = document.getElementById('diamond-section');
    const diamondBody = document.getElementById('diamond-table-body');
    
    if (diamondSection && diamondBody && data.has_diamonds && data.diamonds.length > 0) {
      const diamondRows = data.diamonds
        .filter(d => d.type && d.type.trim() !== '')
        .map(d => {
          let typeCell = escapeHtml(d.type);
          if ((d.clarity && d.clarity.trim() !== '') || (d.color && d.color.trim() !== '')) {
            const clarityColor = [d.clarity, d.color].filter(item => item && item.trim() !== '').join('-');
            if (clarityColor) {
              typeCell += ' / ' + escapeHtml(clarityColor);
            }
          }
          
          const pcsShape = [d.numbers, d.shape].filter(item => item && item.trim() !== '').join(' - ');
          const settingWeight = [d.setting, d.weight ? d.weight + 'ct' : ''].filter(item => item && item.trim() !== '').join(': ');
          
          return `
            <tr>
              <td>${typeCell}</td>
              <td>${escapeHtml(pcsShape)}</td>
              <td>${escapeHtml(settingWeight)}</td>
            </tr>
          `;
        }).join('');
      
      if (diamondRows) {
        diamondBody.innerHTML = diamondRows;
        diamondSection.style.display = 'block';
      } else {
        diamondBody.innerHTML = '';
        diamondSection.style.display = 'none';
      }
    } else if (diamondSection) {
      if (diamondBody) diamondBody.innerHTML = '';
      diamondSection.style.display = 'none';
    }

    // Gemstones Section
    const gemstoneSection = document.getElementById('gemstone-section');
    const gemstoneBody = document.getElementById('gemstone-table-body');
    
    if (gemstoneSection && gemstoneBody && data.has_gemstones && data.gemstones.length > 0) {
      const gemstoneRows = data.gemstones
        .filter(g => g.type && g.type.trim() !== '')
        .map(g => {
          const colorType = [g.color, g.type].filter(item => item && item.trim() !== '').join(' - ');
          const numbersShape = [g.numbers, g.shape].filter(item => item && item.trim() !== '').join(' - ');
          const settingWeight = [g.setting, g.weight ? g.weight + 'ct' : ''].filter(item => item && item.trim() !== '').join(': ');
          
          return `
            <tr>
              <td>${escapeHtml(colorType)}</td>
              <td>${escapeHtml(numbersShape)}</td>
              <td>${escapeHtml(settingWeight)}</td>
            </tr>
          `;
        }).join('');
      
      if (gemstoneRows) {
        gemstoneBody.innerHTML = gemstoneRows;
        gemstoneSection.style.display = 'block';
      } else {
        gemstoneBody.innerHTML = '';
        gemstoneSection.style.display = 'none';
      }
    } else if (gemstoneSection) {
      if (gemstoneBody) gemstoneBody.innerHTML = '';
      gemstoneSection.style.display = 'none';
    }
  }

  window.pushPromo = function(promoName) {
    const currentVariantElement = document.querySelector('select[name="id"], input[name="id"]');
    const currentVariantId = currentVariantElement?.value || '{{ variant.id }}';
    const sku = window.variantMetafields[currentVariantId]?.sku || '';
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'promoClick',
      promoClick: { 
        promo_id: sku, 
        promo_name: '{{ product.title }}', 
        creative_name: promoName 
      }
    });
  };

  document.addEventListener('DOMContentLoaded', function() {
    const sel = document.querySelector('select[name="id"], input[name="id"]');
    const initialVariantId = sel?.value || '{{ variant.id }}';
    
    console.log('Available variant metafields:', window.variantMetafields);
    console.log('Initial variant ID:', initialVariantId);
    
    updateAccordionForVariant(initialVariantId);

    // Variant change listener
    document.addEventListener('variant:change', function(e) {
      const vid = e?.detail?.variant?.id;
      if (vid) {
        console.log('Variant changed to:', vid);
        updateAccordionForVariant(vid);
      }
    });

    // Select / Swatch fallback
    if (sel) {
      sel.addEventListener('change', function() { 
        console.log('Select changed to:', this.value);
        updateAccordionForVariant(this.value); 
      });
    }
    
    document.body.addEventListener('click', function(e) {
      const vid = e.target?.dataset?.variantId || e.target?.getAttribute('data-variant-id');
      if (vid) {
        console.log('Variant clicked:', vid);
        updateAccordionForVariant(vid);
      }
    });
  });
})();
</script>