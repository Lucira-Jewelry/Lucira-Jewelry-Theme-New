<div class="pdp-details-main">
  <div class="pdp-details-accordion">

    <!-- Product Information -->
    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-1" />
      <label for="pdp-details-accordion-item-1" class="pdp-details-accordion-item-title" onclick="pushPromo('Product Information')">
        Product Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <div>
          <p class="product__sku{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if variant.sku.size == 0 %} visibility-hidden{% endif %}" id="Sku-{{ section.id }}" role="status" {{ block.shopify_attributes }}>
            {% if variant.sku %}
              <span class="visually-hidden-">{{ 'products.product.sku' | t }}:</span>
              {{- variant.sku -}}
            {% endif %}
          </p>
          <div class="product__description rte quick-add-hidden" {{ block.shopify_attributes }}>
            {{ product.description }}
          </div>
        </div>
      </div>
    </div>

    <!-- Metal Information -->
    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-2" />
      <label for="pdp-details-accordion-item-2" class="pdp-details-accordion-item-title" onclick="pushPromo('Metal Information')">
        Metal Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table id="metal-info-table">
          <thead>
            <tr>
              <th>METAL</th>
              <th>WEIGHT</th>
              <th>DIMENSIONS</th>
            </tr>
          </thead>
          <tbody>
            <tr id="metal-info-row">
              <td id="metal-type">
                {% if variant.metafields.custom.metal_purity %}{{ variant.metafields.custom.metal_purity }} - {% endif %}
                {% if variant.metafields.custom.metal_color %}{{ variant.metafields.custom.metal_color }}{% endif %}
              </td>
              <td id="metal-weight">
                {% if variant.metafields.custom.metal_weight %}Net Wt: {{ variant.metafields.custom.metal_weight }}g<br>{% endif %}
                {% if variant.metafields.custom.gross_weight %}Gross Wt: {{ variant.metafields.custom.gross_weight }}g{% endif %}
              </td>
              <td id="metal-dimensions">
                {% if variant.metafields.custom.top_width %}Width: {{ variant.metafields.custom.top_width }}mm<br>{% endif %}
                {% if variant.metafields.custom.top_height %}Height: {{ variant.metafields.custom.top_height }}mm{% endif %}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Diamond Information (rendered server-side for initial variant) -->
    {% assign diamond_count = 4 %}
    {% assign show_diamonds = false %}
    {% for i in (1..diamond_count) %}
      {% assign type_key = 'diamond_' | append: i | append: '_type_' %}
      {% assign type_value = variant.metafields.custom[type_key] | metafield_text %}
      {% if type_value != blank %}
        {% assign show_diamonds = true %}
      {% endif %}
    {% endfor %}

    {% if show_diamonds %}
      <div class="pdp-details-accordion-item">
        <input type="checkbox" id="pdp-details-accordion-item-3" />
        <label for="pdp-details-accordion-item-3" class="pdp-details-accordion-item-title" onclick="pushPromo('Diamond Information')">
          Diamond Information
          <i class="fa-solid fa-angle-down"></i>
        </label>
        <div class="pdp-details-accordion-item-content">
          <table>
            <thead>
              <tr>
                <th>TYPE</th>
                <th>PCS / SHAPE</th>
                <th>SETTING / WT</th>
              </tr>
            </thead>
            <tbody id="diamond-table-body">
              {% for i in (1..diamond_count) %}
                {% assign type_key = 'diamond_' | append: i | append: '_type_' %}
                {% assign shape_key = 'diamond_' | append: i | append: '_shape' %}
                {% assign numbers_key = 'diamond_' | append: i | append: '_numbers' %}
                {% assign setting_key = 'diamond_' | append: i | append: '_setting' %}
                {% assign weight_key = 'diamond_' | append: i | append: '_weight' %}
                {% assign clarity_key = 'diamond_' | append: i | append: '_clarity' %}
                {% assign color_key = 'diamond_' | append: i | append: '_color' %}
                {% assign type_value = variant.metafields.custom[type_key] | metafield_text %}
                {% if type_value != blank %}
                  <tr>
                    <td>{{ type_value }}/ {{ variant.metafields.custom[clarity_key] | metafield_text }} - {{ variant.metafields.custom[color_key] | metafield_text }}</td>
                    <td>{{ variant.metafields.custom[numbers_key] | metafield_text }} - {{ variant.metafields.custom[shape_key] | metafield_text }}</td>
                    <td>{{ variant.metafields.custom[setting_key] | metafield_text }}: {{ variant.metafields.custom[weight_key] | metafield_text }}ct</td>
                  </tr>
                {% endif %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% endif %}

    <!-- Gemstone Information (rendered server-side for initial variant) -->
    {% assign gemstone_count = 4 %}
    {% assign show_gemstones = false %}
    {% for i in (1..gemstone_count) %}
      {% assign type_key = 'gemstone_' | append: i | append: '_type_' %}
      {% assign type_value = variant.metafields.custom[type_key] | metafield_text %}
      {% if type_value != blank %}
        {% assign show_gemstones = true %}
      {% endif %}
    {% endfor %}

    {% if show_gemstones %}
      <div class="pdp-details-accordion-item">
        <input type="checkbox" id="pdp-details-accordion-item-4"/>
        <label for="pdp-details-accordion-item-4" class="pdp-details-accordion-item-title" onclick="pushPromo('Gemstone Information')">
          Gemstone Information
          <i class="fa-solid fa-angle-down"></i>
        </label>
        <div class="pdp-details-accordion-item-content">
          <table>
            <thead>
              <tr>
                <th>TYPE</th>
                <th>SHAPE / PCS</th>
                <th>SETTING / WT</th>
              </tr>
            </thead>
            <tbody id="gemstone-table-body">
              {% for i in (1..gemstone_count) %}
                {% assign type_key = 'gemstone_' | append: i | append: '_type_' %}
                {% assign shape_key = 'gemstone_' | append: i | append: '_shape' %}
                {% assign numbers_key = 'gemstone_' | append: i | append: '_numbers' %}
                {% assign setting_key = 'gemstone_' | append: i | append: '_setting' %}
                {% assign weight_key = 'gemstone_' | append: i | append: '_weight' %}
                {% assign clarity_key = 'gemstone_' | append: i | append: '_clarity' %}
                {% assign color_key = 'gemstone_' | append: i | append: '_color' %}
                {% assign type_value = variant.metafields.custom[type_key] | metafield_text %}
                {% if type_value != blank %}
                  <tr>
                    <td>{{ variant.metafields.custom[color_key] | metafield_text }} - {{ type_value }}</td>
                    <td>{{ variant.metafields.custom[numbers_key] | metafield_text }} - {{ variant.metafields.custom[shape_key] | metafield_text }}</td>
                    <td>{{ variant.metafields.custom[setting_key] | metafield_text }}: {{ variant.metafields.custom[weight_key] | metafield_text }}ct</td>
                  </tr>
                {% endif %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% endif %}

  </div>
</div>

<script>
  const variantSelector = document.querySelector("[name='id']");
  const allVariantInformation = JSON.parse(document.getElementById("variant-metafields-information").textContent);

  // Update SKU inside accordion
  function updateAccordionContent(variantData) {
    const skuSelectors = [
      '.product__sku span:not(.visually-hidden-)',
      '.product__sku span:last-child',
      '.product__sku'
    ];

    let skuElement = null;
    for (const selector of skuSelectors) {
      skuElement = document.querySelector(selector);
      if (skuElement) break;
    }

    if (skuElement && variantData.sku) {
      skuElement.textContent = variantData.sku;
    }

    updateMetalInfoTable(variantData);
    updateDiamondTable(variantData);
    updateGemstoneTable(variantData);
  }

  // Update Metal Information Table
  function updateMetalInfoTable(variantData) {
    const metalTypeCell = document.getElementById('metal-type');
    if (metalTypeCell) {
      let metalTypeText = '';
      if (variantData['metal_purity']) {
        metalTypeText += variantData['metal_purity'] + ' - ';
      }
      if (variantData['metal_color']) {
        metalTypeText += variantData['metal_color'];
      }
      metalTypeCell.innerText = metalTypeText;
    }

    const metalWeightCell = document.getElementById('metal-weight');
    if (metalWeightCell) {
      let metalWeightText = '';
      if (variantData['metal_weight']) {
        metalWeightText += 'Net Wt: ' + variantData['metal_weight'] + 'g';
      }
      if (variantData['gross_weight']) {
        if (metalWeightText) metalWeightText += '<br>';
        metalWeightText += 'Gross Wt: ' + variantData['gross_weight'] + 'g';
      }
      metalWeightCell.innerHTML = metalWeightText;
    }

    const metalDimensionsCell = document.getElementById('metal-dimensions');
    if (metalDimensionsCell) {
      let dimensionsText = '';
      if (variantData['top_width']) {
        dimensionsText += 'Width: ' + variantData['top_width'] + 'mm';
      }
      if (variantData['top_height']) {
        if (dimensionsText) dimensionsText += '<br>';
        dimensionsText += 'Height: ' + variantData['top_height'] + 'mm';
      }
      metalDimensionsCell.innerHTML = dimensionsText;
    }
  }

  // Update Diamond Table
  function updateDiamondTable(variantData) {
    const diamondTableBody = document.getElementById('diamond-table-body');
    if (!diamondTableBody) return;

    diamondTableBody.innerHTML = '';

    for (let i = 1; i <= 4; i++) {
      const typeKey = `diamond_${i}_type_`;
      const shapeKey = `diamond_${i}_shape`;
      const numbersKey = `diamond_${i}_numbers`;
      const settingKey = `diamond_${i}_setting`;
      const weightKey = `diamond_${i}_weight`;
      const clarityKey = `diamond_${i}_clarity`;
      const colorKey = `diamond_${i}_color`;

      if (variantData[typeKey]) {
        const row = document.createElement('tr');

        const typeCell = document.createElement('td');
        let typeText = variantData[typeKey] || '';
        if (variantData[clarityKey]) typeText += '/ ' + variantData[clarityKey];
        if (variantData[colorKey]) typeText += '- ' + variantData[colorKey];
        typeCell.innerText = typeText;

        const shapeCell = document.createElement('td');
        let shapeText = '';
        if (variantData[numbersKey]) shapeText += variantData[numbersKey];
        if (variantData[shapeKey]) {
          if (shapeText) shapeText += ' - ';
          shapeText += variantData[shapeKey];
        }
        shapeCell.innerText = shapeText;

        const settingCell = document.createElement('td');
        let settingText = '';
        if (variantData[settingKey]) settingText += variantData[settingKey];
        if (variantData[weightKey]) {
          if (settingText) settingText += ': ';
          settingText += variantData[weightKey] + 'ct';
        }
        settingCell.innerText = settingText;

        row.appendChild(typeCell);
        row.appendChild(shapeCell);
        row.appendChild(settingCell);
        diamondTableBody.appendChild(row);
      }
    }
  }

  // Update Gemstone Table
  function updateGemstoneTable(variantData) {
    const gemstoneTableBody = document.getElementById('gemstone-table-body');
    if (!gemstoneTableBody) return;

    gemstoneTableBody.innerHTML = '';

    for (let i = 1; i <= 4; i++) {
      const typeKey = `gemstone_${i}_type_`;
      const shapeKey = `gemstone_${i}_shape`;
      const numbersKey = `gemstone_${i}_numbers`;
      const settingKey = `gemstone_${i}_setting`;
      const weightKey = `gemstone_${i}_weight`;
      const colorKey = `gemstone_${i}_color`;

      if (variantData[typeKey]) {
        const row = document.createElement('tr');

        const typeCell = document.createElement('td');
        let typeText = '';
        if (variantData[colorKey]) typeText += variantData[colorKey] + ' - ';
        typeText += variantData[typeKey];
        typeCell.innerText = typeText;

        const shapeCell = document.createElement('td');
        let shapeText = '';
        if (variantData[numbersKey]) shapeText += variantData[numbersKey];
        if (variantData[shapeKey]) {
          if (shapeText) shapeText += ' - ';
          shapeText += variantData[shapeKey];
        }
        shapeCell.innerText = shapeText;

        const settingCell = document.createElement('td');
        let settingText = '';
        if (variantData[settingKey]) settingText += variantData[settingKey];
        if (variantData[weightKey]) {
          if (settingText) settingText += ': ';
          settingText += variantData[weightKey] + 'ct';
        }
        settingCell.innerText = settingText;

        row.appendChild(typeCell);
        row.appendChild(shapeCell);
        row.appendChild(settingCell);
        gemstoneTableBody.appendChild(row);
      }
    }
  }

  // Event listener for variant change
  if (variantSelector) {
    variantSelector.addEventListener('change', (event) => {
      const selectedVariantId = event.target.value;
      const variantData = allVariantInformation[selectedVariantId];
      if (variantData) {
        updateAccordionContent(variantData);
      }
    });
  }
</script>
