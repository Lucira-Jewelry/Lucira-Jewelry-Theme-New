<div class="pdp-details-main">
  <div class="pdp-details-accordion">

    {% comment %}
      Ensure we always have the current variant reference
    {% endcomment %}
    {% assign variant = product.selected_or_first_available_variant %}

    <!-- Debug (remove later) -->
    <!-- <pre>{{ variant.metafields.custom | json }}</pre> -->

    <!-- Product Information -->
    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-1" />
      <label for="pdp-details-accordion-item-1" class="pdp-details-accordion-item-title" onclick="pushPromo('Product Information')">
        Product Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <div>
          <p class="product__sku{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if variant.sku.size == 0 %} visibility-hidden{% endif %}" id="Sku-{{ section.id }}" role="status" {{ block.shopify_attributes }}>
            {% if variant.sku %}
              <span class="visually-hidden-">{{ 'products.product.sku' | t }}:</span>
              {{- variant.sku -}}
            {% endif %}
          </p>
          <div class="product__description rte quick-add-hidden" {{ block.shopify_attributes }}>
            {{ product.description }}
          </div>
        </div>
      </div>
    </div>

    <!-- Metal Information -->
    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-2" />
      <label for="pdp-details-accordion-item-2" class="pdp-details-accordion-item-title" onclick="pushPromo('Metal Information')">
        Metal Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table id="metal-info-table">
          <thead>
            <tr>
              <th>METAL</th>
              <th>WEIGHT</th>
              <th>DIMENSIONS</th>
            </tr>
          </thead>
          <tbody>
            <tr id="metal-info-row">
              <td id="metal-type">
                {% if variant.metafields.custom.metal_purity %}{{ variant.metafields.custom.metal_purity }} - {% endif %}
                {% if variant.metafields.custom.metal_color %}{{ variant.metafields.custom.metal_color }}{% endif %}
              </td>
              <td id="metal-weight">
                {% if variant.metafields.custom.metal_weight %}Net Wt: {{ variant.metafields.custom.metal_weight }}g<br>{% endif %}
                {% if variant.metafields.custom.gross_weight %}Gross Wt: {{ variant.metafields.custom.gross_weight }}g{% endif %}
              </td>
              <td id="metal-dimensions">
                {% if variant.metafields.custom.top_width %}Width: {{ variant.metafields.custom.top_width }}mm<br>{% endif %}
                {% if variant.metafields.custom.top_height %}Height: {{ variant.metafields.custom.top_height }}mm{% endif %}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Diamond Information -->
    {% assign diamond_count = 4 %}
    {% assign show_diamonds = false %}
    {% for i in (1..diamond_count) %}
      {% assign type_key_underscore = 'diamond_' | append: i | append: '_type' %}
      {% assign type_key_plain = 'diamond' | append: i | append: '_type' %}
      {% assign type_value = variant.metafields.custom[type_key_underscore] | default: variant.metafields.custom[type_key_plain] %}
      {% if type_value != blank %}
        {% assign show_diamonds = true %}
      {% endif %}
    {% endfor %}

    {% if show_diamonds %}
      <div class="pdp-details-accordion-item">
        <input type="checkbox" id="pdp-details-accordion-item-3" />
        <label for="pdp-details-accordion-item-3" class="pdp-details-accordion-item-title" onclick="pushPromo('Diamond Information')">
          Diamond Information
          <i class="fa-solid fa-angle-down"></i>
        </label>
        <div class="pdp-details-accordion-item-content">
          <table>
            <thead>
              <tr>
                <th>TYPE</th>
                <th>PCS / SHAPE</th>
                <th>SETTING / WT</th>
              </tr>
            </thead>
            <tbody id="diamond-table-body">
              {% for i in (1..diamond_count) %}
                {% assign type_key_underscore = 'diamond_' | append: i | append: '_type' %}
                {% assign type_key_plain = 'diamond' | append: i | append: '_type' %}
                {% assign type_value = variant.metafields.custom[type_key_underscore] | default: variant.metafields.custom[type_key_plain] %}

                {% assign shape_key_underscore = 'diamond_' | append: i | append: '_shape' %}
                {% assign shape_key_plain = 'diamond' | append: i | append: '_shape' %}
                {% assign shape_value = variant.metafields.custom[shape_key_underscore] | default: variant.metafields.custom[shape_key_plain] %}

                {% assign numbers_key_underscore = 'diamond_' | append: i | append: '_numbers' %}
                {% assign numbers_key_plain = 'diamond' | append: i | append: '_numbers' %}
                {% assign numbers_value = variant.metafields.custom[numbers_key_underscore] | default: variant.metafields.custom[numbers_key_plain] %}

                {% assign setting_key_underscore = 'diamond_' | append: i | append: '_setting' %}
                {% assign setting_key_plain = 'diamond' | append: i | append: '_setting' %}
                {% assign setting_value = variant.metafields.custom[setting_key_underscore] | default: variant.metafields.custom[setting_key_plain] %}

                {% assign weight_key_underscore = 'diamond_' | append: i | append: '_weight' %}
                {% assign weight_key_plain = 'diamond' | append: i | append: '_weight' %}
                {% assign weight_value = variant.metafields.custom[weight_key_underscore] | default: variant.metafields.custom[weight_key_plain] %}

                {% assign clarity_key_underscore = 'diamond_' | append: i | append: '_clarity' %}
                {% assign clarity_key_plain = 'diamond' | append: i | append: '_clarity' %}
                {% assign clarity_value = variant.metafields.custom[clarity_key_underscore] | default: variant.metafields.custom[clarity_key_plain] %}

                {% assign color_key_underscore = 'diamond_' | append: i | append: '_color' %}
                {% assign color_key_plain = 'diamond' | append: i | append: '_color' %}
                {% assign color_value = variant.metafields.custom[color_key_underscore] | default: variant.metafields.custom[color_key_plain] %}

                {% if type_value != blank %}
                  <tr>
                    <td>{{ type_value }} / {{ clarity_value }} - {{ color_value }}</td>
                    <td>{{ numbers_value }} - {{ shape_value }}</td>
                    <td>{{ setting_value }}: {{ weight_value }}ct</td>
                  </tr>
                {% endif %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% endif %}

    <!-- Gemstone Information -->
    {% assign gemstone_count = 4 %}
    {% assign show_gemstones = false %}
    {% for i in (1..gemstone_count) %}
      {% assign type_key = 'gemstone_' | append: i | append: '_type' %}
      {% assign type_value = variant.metafields.custom[type_key] %}
      {% if type_value != blank %}
        {% assign show_gemstones = true %}
      {% endif %}
    {% endfor %}

    {% if show_gemstones %}
      <div class="pdp-details-accordion-item">
        <input type="checkbox" id="pdp-details-accordion-item-4"/>
        <label for="pdp-details-accordion-item-4" class="pdp-details-accordion-item-title" onclick="pushPromo('Gemstone Information')">
          Gemstone Information
          <i class="fa-solid fa-angle-down"></i>
        </label>
        <div class="pdp-details-accordion-item-content">
          <table>
            <thead>
              <tr>
                <th>TYPE</th>
                <th>SHAPE / PCS</th>
                <th>SETTING / WT</th>
              </tr>
            </thead>
            <tbody id="gemstone-table-body">
              {% for i in (1..gemstone_count) %}
                {% assign type_key = 'gemstone_' | append: i | append: '_type' %}
                {% assign shape_key = 'gemstone_' | append: i | append: '_shape' %}
                {% assign numbers_key = 'gemstone_' | append: i | append: '_numbers' %}
                {% assign setting_key = 'gemstone_' | append: i | append: '_setting' %}
                {% assign weight_key = 'gemstone_' | append: i | append: '_weight' %}
                {% assign clarity_key = 'gemstone_' | append: i | append: '_clarity' %}
                {% assign color_key = 'gemstone_' | append: i | append: '_color' %}
                {% assign type_value = variant.metafields.custom[type_key] %}
                {% if type_value != blank %}
                  <tr>
                    <td>{{ variant.metafields.custom[color_key] }} - {{ type_value }}</td>
                    <td>{{ variant.metafields.custom[numbers_key] }} - {{ variant.metafields.custom[shape_key] }}</td>
                    <td>{{ variant.metafields.custom[setting_key] }}: {{ variant.metafields.custom[weight_key] }}ct</td>
                  </tr>
                {% endif %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% endif %}

  </div>
</div>