{% assign variant = product.selected_or_first_available_variant %}

<div class="pdp-details-main">
  <div class="pdp-details-accordion">

    <!-- Product Information -->
    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-1" />
      <label for="pdp-details-accordion-item-1" class="pdp-details-accordion-item-title" onclick="pushPromo('Product Information')">
        Product Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <div>
          <p class="product__sku{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if variant.sku.size == 0 %} visibility-hidden{% endif %}" id="Sku-{{ section.id }}" role="status" {{ block.shopify_attributes }}>
            {% if variant.sku %}
              <span class="visually-hidden-">{{ 'products.product.sku' | t }}:</span>
              {{- variant.sku -}}
            {% endif %}
          </p>
          <div class="product__description rte quick-add-hidden" {{ block.shopify_attributes }}>
            {{ product.description }}
          </div>
        </div>
      </div>
    </div>

    <!-- Metal Information -->
    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-2" />
      <label for="pdp-details-accordion-item-2" class="pdp-details-accordion-item-title" onclick="pushPromo('Metal Information')">
        Metal Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table id="metal-info-table">
          <thead>
            <tr>
              <th>METAL</th>
              <th>WEIGHT</th>
              <th>DIMENSIONS</th>
            </tr>
          </thead>
          <tbody>
            <tr id="metal-info-row">
              <td id="metal-type"></td>
              <td id="metal-weight"></td>
              <td id="metal-dimensions"></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Diamond Information -->
    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-3" />
      <label for="pdp-details-accordion-item-3" class="pdp-details-accordion-item-title" onclick="pushPromo('Diamond Information')">
        Diamond Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table>
          <thead>
            <tr>
              <th>TYPE</th>
              <th>PCS / SHAPE</th>
              <th>SETTING / WT</th>
            </tr>
          </thead>
          <tbody id="diamond-table-body"></tbody>
        </table>
      </div>
    </div>

    <!-- Gemstone Information -->
    <div class="pdp-details-accordion-item">
      <input type="checkbox" id="pdp-details-accordion-item-4" />
      <label for="pdp-details-accordion-item-4" class="pdp-details-accordion-item-title" onclick="pushPromo('Gemstone Information')">
        Gemstone Information
        <i class="fa-solid fa-angle-down"></i>
      </label>
      <div class="pdp-details-accordion-item-content">
        <table>
          <thead>
            <tr>
              <th>TYPE</th>
              <th>SHAPE / PCS</th>
              <th>SETTING / WT</th>
            </tr>
          </thead>
          <tbody id="gemstone-table-body"></tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<!-- Variant Data for JS -->
{% assign diamonds_json = "" | split: "" %}
{% assign gemstones_json = "" | split: "" %}

{% for i in (1..4) %}
  {% assign t = 'diamond_' | append: i | append: '_type_' %}
  {% assign type_value = variant.metafields.custom[t] | metafield_text %}
  {% if type_value != blank %}
    {% assign diamonds_json = diamonds_json | push: 
      '{"type":"{{ type_value }}","shape":"{{ variant.metafields.custom["diamond_" | append: i | append: "_shape"] | metafield_text }}","numbers":"{{ variant.metafields.custom["diamond_" | append: i | append: "_numbers"] | metafield_text }}","setting":"{{ variant.metafields.custom["diamond_" | append: i | append: "_setting"] | metafield_text }}","weight":"{{ variant.metafields.custom["diamond_" | append: i | append: "_weight"] | metafield_text }}","clarity":"{{ variant.metafields.custom["diamond_" | append: i | append: "_clarity"] | metafield_text }}","color":"{{ variant.metafields.custom["diamond_" | append: i | append: "_color"] | metafield_text }}"}'
    %}
  {% endif %}
{% endfor %}

{% for i in (1..4) %}
  {% assign t = 'gemstone_' | append: i | append: '_type_' %}
  {% assign type_value = variant.metafields.custom[t] | metafield_text %}
  {% if type_value != blank %}
    {% assign gemstones_json = gemstones_json | push: 
      '{"type":"{{ type_value }}","shape":"{{ variant.metafields.custom["gemstone_" | append: i | append: "_shape"] | metafield_text }}","numbers":"{{ variant.metafields.custom["gemstone_" | append: i | append: "_numbers"] | metafield_text }}","setting":"{{ variant.metafields.custom["gemstone_" | append: i | append: "_setting"] | metafield_text }}","weight":"{{ variant.metafields.custom["gemstone_" | append: i | append: "_weight"] | metafield_text }}","clarity":"{{ variant.metafields.custom["gemstone_" | append: i | append: "_clarity"] | metafield_text }}","color":"{{ variant.metafields.custom["gemstone_" | append: i | append: "_color"] | metafield_text }}"}'
    %}
  {% endif %}
{% endfor %}

<div id="current-variant-data"
     data-variant-id="{{ variant.id }}"
     data-sku="{{ variant.sku }}"
     data-metal-purity="{{ variant.metafields.custom.metal_purity }}"
     data-metal-color="{{ variant.metafields.custom.metal_color }}"
     data-metal-weight="{{ variant.metafields.custom.metal_weight }}"
     data-gross-weight="{{ variant.metafields.custom.gross_weight }}"
     data-top-width="{{ variant.metafields.custom.top_width }}"
     data-top-height="{{ variant.metafields.custom.top_height }}"
     data-diamonds='[{{ diamonds_json | join: "," }}]'
     data-gemstones='[{{ gemstones_json | join: "," }}]'>
</div>

<!-- =========================
     Accordion JS
========================= -->
<script>
(function(){
  function escapeHtml(str){ if(!str) return ''; return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }
  function clearTables(){ document.getElementById('diamond-table-body').innerHTML=''; document.getElementById('gemstone-table-body').innerHTML=''; }

  function updateAccordionForVariantData(data){
    if(!data){ document.getElementById('metal-type').textContent=''; document.getElementById('metal-weight').textContent=''; document.getElementById('metal-dimensions').textContent=''; clearTables(); document.getElementById('Sku-{{ section.id }}').textContent=''; return; }

    // SKU
    document.getElementById('Sku-{{ section.id }}').textContent = data.sku || '';

    // Metal
    document.getElementById('metal-type').textContent = (data.metal_purity||'') + ((data.metal_purity && data.metal_color)?' - ':'') + (data.metal_color||'');
    document.getElementById('metal-weight').innerHTML = (data.metal_weight?'Net Wt: '+data.metal_weight+'g<br>':'') + (data.gross_weight?'Gross Wt: '+data.gross_weight+'g':'');
    document.getElementById('metal-dimensions').innerHTML = (data.top_width?'Width: '+data.top_width+'mm<br>':'') + (data.top_height?'Height: '+data.top_height+'mm':'');

    // Diamonds
    let html='';
    (data.diamonds||[]).forEach(d=>{
      if(d.type){
        html+='<tr><td>'+escapeHtml(d.type)+((d.clarity||d.color)?'/ '+escapeHtml(d.clarity)+'-'+escapeHtml(d.color):'')+'</td>';
        html+='<td>'+escapeHtml(d.numbers)+' - '+escapeHtml(d.shape)+'</td>';
        html+='<td>'+escapeHtml(d.setting)+': '+escapeHtml(d.weight)+'ct</td></tr>';
      }
    });
    document.getElementById('diamond-table-body').innerHTML = html;

    // Gemstones
    html='';
    (data.gemstones||[]).forEach(g=>{
      if(g.type){
        html+='<tr><td>'+escapeHtml(g.color)+' - '+escapeHtml(g.type)+'</td>';
        html+='<td>'+escapeHtml(g.numbers)+' - '+escapeHtml(g.shape)+'</td>';
        html+='<td>'+escapeHtml(g.setting)+': '+escapeHtml(g.weight)+'ct</td></tr>';
      }
    });
    document.getElementById('gemstone-table-body').innerHTML = html;
  }

  function getVariantData(variantId){
    const el=document.querySelector('[data-variant-id="'+variantId+'"]'); 
    if(!el) return null;
    return {
      sku: el.dataset.sku,
      metal_purity: el.dataset.metalPurity,
      metal_color: el.dataset.metalColor,
      metal_weight: el.dataset.metalWeight,
      gross_weight: el.dataset.grossWeight,
      top_width: el.dataset.topWidth,
      top_height: el.dataset.topHeight,
      diamonds: JSON.parse(el.dataset.diamonds||'[]'),
      gemstones: JSON.parse(el.dataset.gemstones||'[]')
    };
  }

  window.pushPromo = function(promoName){
    const sel=document.querySelector('select[name="id"], input[name="id"]');
    const variantId = sel ? sel.value : '{{ variant.id }}';
    const el = document.querySelector('[data-variant-id="'+variantId+'"]');
    const sku = el ? el.dataset.sku : '';
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event:'promoClick',
      promoClick:{ promo_id:sku, promo_name:'{{ product.title }}', creative_name:promoName }
    });
  };

  document.addEventListener('DOMContentLoaded',function(){
    const sel=document.querySelector('select[name="id"], input[name="id"]');
    updateAccordionForVariantData(getVariantData(sel?sel.value:'{{ variant.id }}'));
    if(sel) sel.addEventListener('change',function(){ updateAccordionForVariantData(getVariantData(this.value)); });
    document.body.addEventListener('click',function(e){ const vid=e.target?.dataset?.variantId; if(vid) updateAccordionForVariantData(getVariantData(vid)); });
  });
})();
</script>