{% comment %} exit intent for similar items shown {% endcomment %}

{% if product.metafields.custom.matching_product != blank %}
  <script>
    (function () {
      'use strict';

      const STORAGE_KEY = 'exit_intent_{{ product.id }}';
      const PDP_COUNT_KEY = 'pdp_view_count';
      const ATC_KEY = 'atc_clicked_{{ product.id }}';

      const CONFIG = Object.freeze({
        // Rapid scroll up
        RAPID_SCROLL_PX: 120,
        RAPID_SCROLL_MS: 300,
        SCROLL_ARM_DEPTH_PX: 300,

        // Visibility
        VISIBILITY_RETURN_MS: 8000,

        // Desktop mouse
        MOUSE_EXIT_MAX_Y: 50,

        // ── NEW conditions ──────────────────────────
        MIN_PDP_VIEWS: 2, // Must have viewed ≥ 2 PDPs this session
        MIN_TIME_ON_PDP_MS: 20000, // Must spend ≥ 20s on this PDP
      });

      const state = {
        drawn: false,
        armed: false,
        hiddenAt: null,
        historyPushed: false,
        scrollSamples: [],
        lastScrollY: window.scrollY,
        lastMouseY: null,
        mouseVelY: 0,
        pendingMouseY: null,

        // NEW
        atcClicked: false,
        pageEnterTime: Date.now(),
      };

      // ─── PDP View Counter ────────────────────────────────────────────────────────
      // Increment on every PDP load — stored in sessionStorage so it persists
      // across page navigations within the same browser session

      function incrementPDPCount() {
        try {
          const current = parseInt(sessionStorage.getItem(PDP_COUNT_KEY) || '0', 10);
          sessionStorage.setItem(PDP_COUNT_KEY, String(current + 1));
        } catch (e) {}
      }

      function getPDPCount() {
        try {
          return parseInt(sessionStorage.getItem(PDP_COUNT_KEY) || '0', 10);
        } catch (e) {
          return 0;
        }
      }

      // ─── ATC Detection ───────────────────────────────────────────────────────────
      // Watches ANY add-to-cart button click on the page — covers default Shopify
      // ATC buttons, quick-add, sticky bars, etc.

      function initATCWatcher() {
        // Covers all common Shopify ATC button patterns
        const ATC_SELECTORS = [
          '[name="add"]',
          '.product-form__submit',
          '[data-testid="Sticky-Add-To-Cart"]',
          '.sticky-atc-btn',
          '.product-form button[type="submit"]',
        ].join(', ');

        document.addEventListener(
          'click',
          function (e) {
            if (e.target.closest(ATC_SELECTORS)) {
              state.atcClicked = true;
              try {
                sessionStorage.setItem(ATC_KEY, '1');
              } catch (e) {}
            }
          },
          { passive: true }
        );

        // Also restore from sessionStorage if they clicked ATC then scrolled
        try {
          if (sessionStorage.getItem(ATC_KEY)) state.atcClicked = true;
        } catch (e) {}
      }

      // ─── Core Helpers ────────────────────────────────────────────────────────────

      function alreadyShown() {
        try {
          return !!sessionStorage.getItem(STORAGE_KEY);
        } catch (e) {
          return false;
        }
      }

      function markShown() {
        state.drawn = true;
        try {
          sessionStorage.setItem(STORAGE_KEY, '1');
        } catch (e) {}
      }

      {% comment %} function openDrawer() {
        const btn = document.querySelector('.view-similar-btn[data-product-id="{{ product.id }}"]');
        if (btn) btn.click();
      } {% endcomment %}

      function openDrawer() {
        const btn = document.querySelector('.view-similar-btn[data-product-id="{{ product.id }}"]');
        if (!btn) return;

        // Watch for the drawer title to appear after AJAX injection
        const observer = new MutationObserver(function (mutations, obs) {
          const titleEl = document.getElementById('similar-items-title');
          if (!titleEl) return;

          // Title element found — swap text and stop observing
          titleEl.textContent = 'Still deciding? Explore More';
          obs.disconnect();
        });

        observer.observe(document.body, {
          childList: true,
          subtree: true,
        });

        // Safety: auto-disconnect after 3s if drawer never opens
        setTimeout(function () {
          observer.disconnect();
        }, 3000);

        btn.click();
      }

      // ── All 4 conditions must pass ───────────────────────────────────────────────
      function canFire() {
        if (state.drawn) return false; // Already fired this load
        if (alreadyShown()) return false; // ✅ Not shown in session
        if (state.atcClicked) return false; // ✅ No ATC clicked
        if (getPDPCount() < CONFIG.MIN_PDP_VIEWS) return false; // ✅ ≥ 2 PDPs viewed
        if (Date.now() - state.pageEnterTime < CONFIG.MIN_TIME_ON_PDP_MS) return false; // ✅ ≥ 20s on page
        return true;
      }

      function fire(source) {
        if (!canFire()) return;
        markShown();
        openDrawer();
      }

      function isMobile() {
        return 'ontouchstart' in window || navigator.maxTouchPoints > 0 || window.innerWidth <= 768;
      }

      // ════════════════════════════════════════════════════════════════════════════
      // TRIGGER 1 — HISTORY API (Back Button Hijack)
      // ════════════════════════════════════════════════════════════════════════════

      function initHistoryHijack() {
        history.pushState({ _exitIntent: true }, '');
        state.historyPushed = true;

        window.addEventListener('popstate', function onPop() {
          if (!canFire()) {
            window.removeEventListener('popstate', onPop);
            return;
          }
          fire('history-back');
          history.pushState({ _exitIntent: true }, '');
        });
      }

      // ════════════════════════════════════════════════════════════════════════════
      // TRIGGER 2 — RAPID SCROLL UP
      // ════════════════════════════════════════════════════════════════════════════

      function initRapidScrollUp() {
        window.addEventListener(
          'scroll',
          function () {
            const currentY = window.scrollY;
            const now = Date.now();

            if (currentY > CONFIG.SCROLL_ARM_DEPTH_PX) state.armed = true;
            if (!state.armed) {
              state.lastScrollY = currentY;
              return;
            }

            const scrollingUp = currentY < state.lastScrollY;

            if (scrollingUp) {
              state.scrollSamples.push({ y: currentY, t: now });
              state.scrollSamples = state.scrollSamples.filter(function (s) {
                return now - s.t <= CONFIG.RAPID_SCROLL_MS;
              });

              if (state.scrollSamples.length >= 2) {
                const oldest = state.scrollSamples[0];
                const newest = state.scrollSamples[state.scrollSamples.length - 1];
                const deltaPx = oldest.y - newest.y;
                const deltaMs = newest.t - oldest.t;

                if (deltaPx >= CONFIG.RAPID_SCROLL_PX && deltaMs <= CONFIG.RAPID_SCROLL_MS) {
                  fire('rapid-scroll-up');
                }
              }
            } else {
              state.scrollSamples = [];
            }

            state.lastScrollY = currentY;
          },
          { passive: true }
        );
      }

      // ════════════════════════════════════════════════════════════════════════════
      // TRIGGER 3 — TAB SWITCH / VISIBILITY CHANGE
      // ════════════════════════════════════════════════════════════════════════════

      function initVisibilityChange() {
        document.addEventListener('visibilitychange', function () {
          if (document.visibilityState === 'hidden') {
            if (canFire()) state.hiddenAt = Date.now();
          } else if (document.visibilityState === 'visible') {
            if (state.hiddenAt !== null) {
              const away = Date.now() - state.hiddenAt;
              if (away <= CONFIG.VISIBILITY_RETURN_MS && canFire()) {
                setTimeout(function () {
                  fire('visibility-return');
                }, 200);
              }
              state.hiddenAt = null;
            }
          }
        });
      }

      // ════════════════════════════════════════════════════════════════════════════
      // DESKTOP — Mouse Leave
      // ════════════════════════════════════════════════════════════════════════════

      function initDesktopMouseLeave() {
        document.addEventListener(
          'mousemove',
          function (e) {
            state.pendingMouseY = e.clientY;
          },
          { passive: true }
        );

        setInterval(function () {
          if (state.pendingMouseY !== null) {
            if (state.lastMouseY !== null) {
              state.mouseVelY = state.pendingMouseY - state.lastMouseY;
            }
            state.lastMouseY = state.pendingMouseY;
            state.pendingMouseY = null;
          }
        }, 100);

        document.addEventListener('mouseleave', function (e) {
          if (e.clientY > CONFIG.MOUSE_EXIT_MAX_Y) return;
          if (state.mouseVelY >= 0) return;
          fire('desktop-mouseleave');
        });
      }

      // ════════════════════════════════════════════════════════════════════════════
      // INIT
      // ════════════════════════════════════════════════════════════════════════════

      function init() {
        const btn = document.querySelector('.view-similar-btn[data-product-id="{{ product.id }}"]');
        if (!btn) return;

        // ✅ Count this PDP view
        incrementPDPCount();

        // ✅ Start watching ATC clicks
        initATCWatcher();

        // Already shown — no need to attach exit listeners
        if (alreadyShown()) return;

        if (isMobile()) {
          initHistoryHijack();
          initRapidScrollUp();
          initVisibilityChange();
        } else {
          initDesktopMouseLeave();
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
{% endif %}


