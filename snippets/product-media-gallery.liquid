<script>
  (function () {
    function initAudioPlayers() {
      const audioPlayers = document.querySelectorAll('.product-audio-player');
      audioPlayers.forEach((wrapper) => {
        const button = wrapper.querySelector('.audio-play-button');
        const audio = wrapper.querySelector('audio');
        if (!button || !audio) return;
        const newBtn = button.cloneNode(true);
        button.replaceWith(newBtn);
        const playIcon = newBtn.querySelector('.icon-play');
        const pauseIcon = newBtn.querySelector('.icon-pause');
        playIcon.style.display = 'block';
        pauseIcon.style.display = 'none';
        newBtn.addEventListener('click', () => {
          if (audio.paused) {
            audio.play();
            playIcon.style.display = 'none';
            pauseIcon.style.display = 'block';
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              event: 'promoClick',
              promoClick: {
                promo_id: '{{ product.selected_or_first_available_variant.sku }}',
                creative_name: 'Audio Click Start',
                promo_name: '{{ product.title }}',
              },
            });
          } else {
            audio.pause();
            playIcon.style.display = 'block';
            pauseIcon.style.display = 'none';
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              event: 'promoClick',
              promoClick: {
                promo_id: '{{ product.selected_or_first_available_variant.sku }}',
                creative_name: 'Audio Click End',
                promo_name: '{{ product.title }}',
              },
            });
          }
        });
        audio.addEventListener('ended', () => {
          playIcon.style.display = 'block';
          pauseIcon.style.display = 'none';
        });
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAudioPlayers);
    } else {
      initAudioPlayers();
    }
    document.addEventListener('variant:change', initAudioPlayers);
  })();
</script>

<script>
  (function () {
    const wrapper = document.getElementById('MediaGalleryWrapper-{{ section.id }}');
    if (wrapper) {
      const firstImg = wrapper.querySelector('.product__media-item img');
      if (firstImg && firstImg.complete) {
        wrapper.classList.add('loaded');
      } else if (firstImg) {
        firstImg.addEventListener(
          'load',
          function () {
            wrapper.classList.add('loaded');
          },
          { once: true }
        );
      } else {
        setTimeout(() => wrapper.classList.add('loaded'), 100);
      }
    }
  })();

  document.addEventListener('DOMContentLoaded', function () {
    if (typeof PhotoSwipeLightbox === 'undefined') {
      console.error('PhotoSwipeLightbox not loaded');
      return;
    }

    const lightbox = new PhotoSwipeLightbox({
      gallery: '#Slider-Gallery-{{ section.id }}',
      children: 'a.pswp-gallery-item',
      pswpModule: PhotoSwipe,
      
      bgOpacity: 0.9,
      showHideAnimationType: 'fade',
      
      initialZoomLevel: 'fit',
      secondaryZoomLevel: 1.5,
      maxZoomLevel: 3,
      
      pinchToClose: true,
      closeOnVerticalDrag: true,
      
      paddingFn: (viewportSize) => {
        return {
          top: 30,
          bottom: 30,
          left: 30,
          right: 30
        }
      }
    });
    lightbox.on('uiRegister', function() {
      lightbox.pswp.ui.registerElement({
        name: 'fullscreen-button',
        order: 8,
        isButton: true,
        html: `
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 3H5C3.89543 3 3 3.89543 3 5V8M16 3H19C20.1046 3 21 3.89543 21 5V8M8 21H5C3.89543 21 3 20.1046 3 19V16M16 21H19C20.1046 21 21 20.1046 21 19V16" 
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        `,
        onClick: (event, el) => {
          if (!document.fullscreenElement) {
            lightbox.pswp.element.requestFullscreen();
          } else {
            document.exitFullscreen();
          }
        }
      });
      lightbox.pswp.ui.registerElement({
        name: 'share-button',
        order: 9,
        isButton: true,
        html: `
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8.59 13.51L15.42 17.49M15.41 6.51L8.59 10.49M21 5C21 6.65685 19.6569 8 18 8C16.3431 8 15 6.65685 15 5C15 3.34315 16.3431 2 18 2C19.6569 2 21 3.34315 21 5ZM9 12C9 13.6569 7.65685 15 6 15C4.34315 15 3 13.6569 3 12C3 10.3431 4.34315 9 6 9C7.65685 9 9 10.3431 9 12ZM21 19C21 20.6569 19.6569 22 18 22C16.3431 22 15 20.6569 15 19C15 17.3431 16.3431 16 18 16C19.6569 16 21 17.3431 21 19Z" 
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        `,
        onClick: (event, el, pswp) => {
          const currentSlide = pswp.currSlide;
          const shareData = {
            title: '{{ product.title | escape }}',
            text: 'Check out this product image',
            url: window.location.href
          };
          
          if (navigator.share) {
            navigator.share(shareData).catch(err => console.log('Error sharing:', err));
          } else {
            navigator.clipboard.writeText(window.location.href).then(() => {
              alert('Link copied to clipboard!');
            });
          }
        }
      });
    });
    lightbox.init();
    console.log('PhotoSwipe initialized successfully');
  });
</script>


