{% comment %}
  Renders a product media gallery with optimized loading and skeleton screens
{% endcomment %}


{%- liquid
  if section.settings.hide_variants and variant_images.size == product.media.size
    assign single_media_visible = true
  endif

  if limit == 1
    assign single_media_visible = true
  endif

  assign media_count = product.media.size
  if section.settings.hide_variants and media_count > 1 and variant_images.size > 0
    assign media_count = media_count | minus: variant_images.size | plus: 1
  endif

  if media_count == 1 or single_media_visible
    assign single_media_visible_mobile = true
  endif

  if media_count == 0 or single_media_visible_mobile or section.settings.mobile_thumbnails == 'show' or section.settings.mobile_thumbnails == 'columns' and media_count < 3
    assign hide_mobile_slider = true
  endif

  if section.settings.media_size == 'large'
    assign media_width = 0.65
  elsif section.settings.media_size == 'medium'
    assign media_width = 0.55
  elsif section.settings.media_size == 'small'
    assign media_width = 0.45
  endif
-%}

<div class="media-gallery-tabs-section product__column-sticky">
  <div class="media-gallery-wrapper" id="MediaGalleryWrapper-{{ section.id }}">
    {% comment %} {%- if product.metafields.custom.products_audio -%}
      <div class="product-audio-player mobile-show">
        <button class="audio-play-button" id="audioPlayButton-{{ section.id }}" aria-label="Play product audio">
          <!-- Play Icon -->
          <svg class="icon-play" width="16" height="16" viewBox="0 0 20 20" fill="none">
            <path d="M5.75 4.33203C5.75 4.13441 5.96844 4.01461 6.13477 4.12109L14.9521 9.79004C15.1052 9.88845 15.1052 10.1116 14.9521 10.21L6.13477 15.8789C5.96844 15.9854 5.75 15.8656 5.75 15.668V4.33203Z"
                  fill="#1A1A1A" stroke="#1A1A1A" stroke-width="1.5"/>
          </svg>

          <svg
            style="display:none"
            class="icon-pause"
            width="16"
            height="16"
            viewBox="0 0 20 20"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path d="M12.499 4.08301H14.166C14.2119 4.08301 14.2488 4.12014 14.249 4.16602V15.833C14.249 15.879 14.212 15.916 14.166 15.916H12.499C12.4532 15.9158 12.416 15.8789 12.416 15.833V4.16602C12.4162 4.12025 12.4533 4.08318 12.499 4.08301Z" fill="#1A1A1A" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M5.83301 4.08301H7.5C7.54591 4.08301 7.58283 4.12014 7.58301 4.16602V15.833C7.58301 15.879 7.54602 15.916 7.5 15.916H5.83301C5.78713 15.9158 5.75 15.8789 5.75 15.833V4.16602C5.75018 4.12025 5.78724 4.08318 5.83301 4.08301Z" fill="#1A1A1A" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>

          <!-- Pause Icon -->

          <p class="text-audio-player">Listen Story</p>
        </button>

        <audio id="productAudio-{{ section.id }}" preload="none">
          <source src="{{ product.metafields.custom.products_audio | file_url }}" type="audio/mpeg">
        </audio>
      </div>
    {%- endif -%} {% endcomment %}

    {%- if product.metafields.reviews.rating.value != blank -%}
      <a href="#nector-reviews" class="mobile-rating-wrapper mobile-show" style="text-decoration: none;">
        <div class="rating-wrapper-custom mobile-rating">
          {% liquid
            assign rating_decimal = 0
            assign decimal = product.metafields.reviews.rating.value.rating | modulo: 1
            if decimal >= 0.3 and decimal <= 0.7
              assign rating_decimal = 0.5
            elsif decimal > 0.7
              assign rating_decimal = 1
            endif
          %}
          
      

          <span class="pdp-rating">
            <svg class="rating-summary-custom" width="16" height="16">
              <use href ="#plp-rating-1"></use>
            </svg>
          </span>

          <p class="rating-summary-custom">
            <span class="rating-value">{{ product.metafields.reviews.rating.value.rating | round: 1 }}</span>
            <span class="rating-divider">|</span>
            <span class="rating-count">{{ product.metafields.reviews.rating_count }}</span>
          </p>
        </div>
      </a>
    {%- endif -%}

    

    <media-gallery
      id="MediaGallery-{{ section.id }}"
      role="region"
      {% if section.settings.enable_sticky_info %}
        class="product__column-sticky"
      {% endif %}
      aria-label="{{ 'products.product.media.gallery_viewer' | t }}"
      data-desktop-layout="{{ section.settings.gallery_layout }}"
    >
      <div id="GalleryStatus-{{ section.id }}" class="visually-hidden" role="status"></div>
      <slider-component id="GalleryViewer-{{ section.id }}" class="slider-mobile-gutter">
        <a class="skip-to-content-link button visually-hidden quick-add-hidden" href="#ProductInfo-{{ section.id }}">
          {{ 'accessibility.skip_to_product_info' | t }}
        </a>
        <ul
          id="Slider-Gallery-{{ section.id }}"
          class="product__media-list contains-media grid grid--peek list-unstyled slider slider--mobile"
          role="list"
        >
          {%- if product.selected_or_first_available_variant.featured_media != null -%}
            {%- assign featured_media = product.selected_or_first_available_variant.featured_media -%}
            <li
              id="Slide-{{ section.id }}-{{ featured_media.id }}"
              class="product__media-item grid__item slider__slide is-active{% if single_media_visible %} product__media-item--single{% endif %}{% if featured_media.media_type != 'image' %} product__media-item--full{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
              data-media-id="{{ section.id }}-{{ featured_media.id }}"
              data-color="{{ featured_media.alt | downcase }}"
            >
              {%- assign media_position = 1 -%}
              {% if featured_media.media_type == 'image' %}
                <a
                  href="{{ featured_media | image_url: width: 2000 }}"
                  data-pswp-width="{{ featured_media.width }}"
                  data-pswp-height="{{ featured_media.height }}"
                  class="pswp-gallery-item"
                >
                  {% render 'product-thumbnail',
                    media: featured_media,
                    media_count: media_count,
                    position: media_position,
                    desktop_layout: section.settings.gallery_layout,
                    mobile_layout: section.settings.mobile_thumbnails,
                    loop: section.settings.enable_video_looping,
                    modal_id: section.id,
                    xr_button: true,
                    media_width: media_width,
                    media_fit: section.settings.media_fit,
                    constrain_to_viewport: section.settings.constrain_to_viewport,
                    lazy_load: false,
                    fetchpriority: 'high'
                  %}
                </a>
              {% else %}
                {% render 'product-thumbnail',
                  media: featured_media,
                  media_count: media_count,
                  position: media_position,
                  desktop_layout: section.settings.gallery_layout,
                  mobile_layout: section.settings.mobile_thumbnails,
                  loop: section.settings.enable_video_looping,
                  modal_id: section.id,
                  xr_button: true,
                  media_width: media_width,
                  media_fit: section.settings.media_fit,
                  constrain_to_viewport: section.settings.constrain_to_viewport,
                  lazy_load: false
                %}
              {% endif %}
            </li>
          {%- endif -%}
          {%- for media in product.media -%}
            {% if media_position >= limit
              or media_position >= 1
              and section.settings.hide_variants
              and variant_images contains media.src
            %}
              {% continue %}
            {% endif %}

            {%- unless media.id == product.selected_or_first_available_variant.featured_media.id -%}
              <li
                id="Slide-{{ section.id }}-{{ media.id }}"
                class="product__media-item grid__item slider__slide{% if single_media_visible %} product__media-item--single{% endif %}{% if product.selected_or_first_available_variant.featured_media == nil and forloop.index == 1 %} is-active{% endif %}{% if media.media_type != 'image' %} product__media-item--full{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
                data-media-id="{{ section.id }}-{{ media.id }}"
                data-color="{{ media.alt | downcase }}"
              >
                {%- liquid
                  assign media_position = media_position | default: 0 | plus: 1
                  assign lazy_load = false
                  if media_position > 1
                    assign lazy_load = true
                  endif
                -%}
                {% if media.media_type == 'image' %}
                  <a
                    href="{{ media | image_url: width: 2000 }}"
                    data-pswp-width="{{ media.width }}"
                    data-pswp-height="{{ media.height }}"
                    class="pswp-gallery-item"
                  >
                    {% render 'product-thumbnail',
                      media: media,
                      media_count: media_count,
                      position: media_position,
                      desktop_layout: section.settings.gallery_layout,
                      mobile_layout: section.settings.mobile_thumbnails,
                      loop: section.settings.enable_video_looping,
                      modal_id: section.id,
                      xr_button: true,
                      media_width: media_width,
                      media_fit: section.settings.media_fit,
                      constrain_to_viewport: section.settings.constrain_to_viewport,
                      lazy_load: lazy_load
                    %}
                  </a>
                {% else %}
                  {% render 'product-thumbnail',
                    media: media,
                    media_count: media_count,
                    position: media_position,
                    desktop_layout: section.settings.gallery_layout,
                    mobile_layout: section.settings.mobile_thumbnails,
                    loop: section.settings.enable_video_looping,
                    modal_id: section.id,
                    xr_button: true,
                    media_width: media_width,
                    media_fit: section.settings.media_fit,
                    constrain_to_viewport: section.settings.constrain_to_viewport,
                    lazy_load: lazy_load
                  %}
                {% endif %}
              </li>
            {%- endunless -%}
          {%- endfor -%}
        </ul>
        <div class="slider-buttons quick-add-hidden{% if hide_mobile_slider %} small-hide{% endif %}">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
          </button>

          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
          </button>
        </div>
        <div class="custom-share-icon mobile-show">
          <div>
            <div class="product-share product_share" onclick="share()" id="product_share">
              {{ 'icon-share-product.svg' | inline_asset_content }}
            </div>
          </div>
        </div>
      </slider-component>
    </media-gallery>
  </div>
  <div class="hulk-wishlist-icon-wrap mobile-show">
    <div class="iwish-app-block-product">
      <a
        class="iWishAdd st-1"
        href="#"
        data-variant="{{ product.variants.first.id }}"
        data-product="{{ product.id }}"
        data-pTitle="{{ product.title | escape }}"
      ></a>
    </div>
    
  </div>


{% if product.metafields.custom.matching_product != blank %}
  {% assign has_matching_products = false %}
  {% for matching_product in product.metafields.custom.matching_product.value limit: 1 %}
    {% assign has_matching_products = true %}
  {% endfor %}
  
  {% if has_matching_products %}
    <button 
      type="button"
      class="view-similar-btn"
      data-product-id="{{ product.id }}"
      data-product-handle="{{ product.handle }}"
      aria-label="View similar items for {{ product.title }}"
    >

      <span class="view-similar-btn__text">View Similar</span>
      <span class="view-similar-btn__icon">
        
       <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <mask id="mask0_13509_13149" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24">
        <rect width="24" height="24" fill="#D9D9D9"/>
        </mask>
        <g mask="url(#mask0_13509_13149)">
        <path d="M7.50084 19.5V4.5H16.5008V19.5H7.50084ZM3.80859 17.5V6.5H5.30859V17.5H3.80859ZM18.6931 17.5V6.5H20.1931V17.5H18.6931ZM9.00084 18H15.0008V6H9.00084V18Z" fill="#333333"/>
        </g>
        </svg>
      </span>

    </button>
  {% endif %}
{% endif %}

  <div class="inside_the_packages desktop-show" id="inside_the_packages">
    <div class="inside-the-Package">
      <div class="inside-the-Package-title">WHAT'S IN THE PACKAGE</div>
      <div class="inside-the-Package-main">
        <div class="inside-the-Package-items" alt="package">
          <img
            src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Box.webp?v=1744615950"
            height="400"
            loading="lazy"
            width="400"
            alt="box packaging"
            title="box packaging"
          >
        </div>
        <div class="inside-the-Package-items" alt="package">
          <img
            src="https://www.lucirajewelry.com/cdn/shop/files/Selvet.jpg?v=1754973457"
            height="400"
            loading="lazy"
            width="400"
            alt="selvet"
            title="selvet"
          >
        </div>
        <div class="inside-the-Package-items" alt="package">
          <img
            src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/Thank-You-Card.jpg?v=1754973455"
            height="400"
            loading="lazy"
            width="400"
            alt="thankyou card"
            title="thanku card"
          >
        </div>
      </div>
    </div>
  </div>

  {% if product.metafields.custom.matching_product != blank %}
<script>
(function () {
  'use strict';

  // ─── Config ──────────────────────────────────────────────────────────────────
  const CONFIG = Object.freeze({
    STORAGE_KEY:              'exit_intent_{{ product.id }}',
    MIN_TIME_ON_PAGE_MS:      4000,    // Must spend 4s on page before trigger can fire
    MIN_SCROLL_DEPTH_PERCENT: 25,      // Must scroll 25% before trigger is armed

    // Desktop
    MOUSE_EXIT_MAX_Y:         50,      // px from top — cursor must exit above this line

    // Mobile scroll-based
    SCROLL_ARM_DEPTH:         0.30,    // Must reach 30% depth to arm
    SCROLL_UP_RATIO:          0.30,    // Must scroll back up 30% of viewport height
    SCROLL_RETURN_TO_TOP:     0.20,    // Must be back in top 20% of page

    // Mobile edge-swipe (back gesture)
    IOS_EDGE_MAX_X:           50,      // px from LEFT edge for iOS back swipe start
    ANDROID_EDGE_MIN_X_RATIO: 0.85,   // % from RIGHT edge for Android back swipe start
    SWIPE_MIN_DELTA_X:        80,      // Min horizontal travel (px) to count as back swipe
    SWIPE_MAX_DELTA_Y:        80,      // Max vertical drift allowed (keeps it a horizontal swipe)
    SWIPE_MIN_VELOCITY:       0.4,     // px/ms — must be fast enough to be intentional

    // Mobile visibility (tab hide / home button)
    VISIBILITY_RETURN_WINDOW: 3000,    // ms — if user returns within this, open drawer
  });

  // ─── State (fully isolated — no globals) ────────────────────────────────────
  const state = {
    triggered:          false,
    armed:              false,
    pageEnterTime:      Date.now(),

    // Mouse tracking (desktop)
    lastMouseY:         null,
    mouseVelocityY:     0,
    pendingMouseY:      null,
    mouseTrackTimer:    null,

    // Mobile scroll
    maxScrollY:         0,
    lastScrollY:        window.scrollY,
    scrollUpStartY:     null,
    scrollDebounce:     null,

    // Touch / swipe
    touchStartX:        null,
    touchStartY:        null,
    touchStartTime:     null,
    touchEdgeType:      null, // 'ios-left' | 'android-right' | null

    // Visibility
    hiddenAt:           null,
  };

  // ─── Helpers ─────────────────────────────────────────────────────────────────

  function hasTriggeredThisSession() {
    try { return !!sessionStorage.getItem(CONFIG.STORAGE_KEY); } catch (e) { return false; }
  }

  function markTriggered() {
    state.triggered = true;
    try { sessionStorage.setItem(CONFIG.STORAGE_KEY, '1'); } catch (e) {}
  }

  function openSimilarDrawer() {
    // Scoped querySelector — only touches .view-similar-btn, nothing else
    const btn = document.querySelector('.view-similar-btn[data-product-id="{{ product.id }}"]');
    if (btn) btn.click();
  }

  function timeOnPage() {
    return Date.now() - state.pageEnterTime;
  }

  function getScrollPercent() {
    const docH = document.documentElement.scrollHeight - window.innerHeight;
    return docH > 0 ? window.scrollY / docH : 0;
  }

  function canTrigger() {
    if (state.triggered)               return false;
    if (hasTriggeredThisSession())     return false;
    if (timeOnPage() < CONFIG.MIN_TIME_ON_PAGE_MS) return false;
    if (!state.armed)                  return false;
    return true;
  }

  function doTrigger(source) {
    if (!canTrigger()) return;
    markTriggered();
    openSimilarDrawer();
  }

  function isMobileDevice() {
    return (
      /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent) ||
      ('ontouchstart' in window) ||
      (window.innerWidth <= 768)
    );
  }

  function isIOS() {
    return /iPhone|iPad|iPod/i.test(navigator.userAgent) ||
           (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
  }

  // ─── ARM: scroll engagement gate (shared desktop + mobile) ──────────────────

  function checkArm() {
    if (state.armed) return;
    if (getScrollPercent() * 100 >= CONFIG.MIN_SCROLL_DEPTH_PERCENT) {
      state.armed = true;
    }
  }

  // ════════════════════════════════════════════════════════════════════════════
  // DESKTOP
  // ════════════════════════════════════════════════════════════════════════════

  function initDesktop() {
    // Sample mouse Y every 100ms for velocity without hogging scroll thread
    document.addEventListener('mousemove', function(e) {
      state.pendingMouseY = e.clientY;
    }, { passive: true });

    state.mouseTrackTimer = setInterval(function() {
      if (state.pendingMouseY !== null) {
        if (state.lastMouseY !== null) {
          state.mouseVelocityY = state.pendingMouseY - state.lastMouseY;
        }
        state.lastMouseY = state.pendingMouseY;
        state.pendingMouseY = null;
      }
    }, 100);

    document.addEventListener('mouseleave', function(e) {
      if (e.clientY > CONFIG.MOUSE_EXIT_MAX_Y) return; // Not exiting from top
      if (state.mouseVelocityY >= 0) return;           // Not moving upward
      doTrigger('desktop-mouseleave');
    });
  }

  // ════════════════════════════════════════════════════════════════════════════
  // MOBILE — SCROLL BEHAVIOR MODEL
  // Scroll deep → scroll back up significantly → near top = exit intent
  // ════════════════════════════════════════════════════════════════════════════

  function initMobileScroll() {
    window.addEventListener('scroll', function() {
      const currentY   = window.scrollY;
      const scrollPct  = getScrollPercent();
      const scrollingUp = currentY < state.lastScrollY;

      // Track deepest point
      if (currentY > state.maxScrollY) state.maxScrollY = currentY;

      // Arm on depth
      if (scrollPct >= CONFIG.SCROLL_ARM_DEPTH) state.armed = true;

      // Track upward scroll pivot
      if (scrollingUp && state.scrollUpStartY === null) {
        state.scrollUpStartY = currentY;
      }
      if (!scrollingUp) {
        state.scrollUpStartY = null; // reset if they go back down
      }

      state.lastScrollY = currentY;

      clearTimeout(state.scrollDebounce);
      state.scrollDebounce = setTimeout(function() {
        if (!canTrigger()) return;
        if (state.scrollUpStartY === null) return;

        const scrolledUpPx   = state.maxScrollY - currentY;
        const upRatio        = scrolledUpPx / window.innerHeight;
        const currentDepth   = getScrollPercent();

        if (upRatio >= CONFIG.SCROLL_UP_RATIO && currentDepth < CONFIG.SCROLL_RETURN_TO_TOP) {
          doTrigger('mobile-scroll-up');
        }
      }, 150);
    }, { passive: true });
  }

  // ════════════════════════════════════════════════════════════════════════════
  // MOBILE — EDGE SWIPE BACK GESTURE
  //
  // iOS Safari:   Swipe RIGHT from LEFT edge   → back navigation
  // Android:      Swipe LEFT from RIGHT edge   → back navigation (gesture nav)
  //
  // We intercept the INTENT (touchstart near edge + directional swipe)
  // BEFORE the browser processes it — giving time to open the drawer.
  // ════════════════════════════════════════════════════════════════════════════

  function initEdgeSwipe() {
    const screenW = window.innerWidth;
    const androidEdgeMinX = screenW * CONFIG.ANDROID_EDGE_MIN_X_RATIO;

    document.addEventListener('touchstart', function(e) {
      const touch = e.touches[0];
      state.touchStartX    = touch.clientX;
      state.touchStartY    = touch.clientY;
      state.touchStartTime = Date.now();
      state.touchEdgeType  = null;

      // Detect edge origin
      if (isIOS() && touch.clientX <= CONFIG.IOS_EDGE_MAX_X) {
        state.touchEdgeType = 'ios-left';
      } else if (!isIOS() && touch.clientX >= androidEdgeMinX) {
        state.touchEdgeType = 'android-right';
      }
    }, { passive: true });

    document.addEventListener('touchend', function(e) {
      if (!state.touchEdgeType) return;          // Not an edge touch
      if (!canTrigger()) return;

      const touch     = e.changedTouches[0];
      const deltaX    = touch.clientX - state.touchStartX;
      const deltaY    = Math.abs(touch.clientY - state.touchStartY);
      const elapsed   = Date.now() - state.touchStartTime;
      const velocityX = Math.abs(deltaX) / (elapsed || 1);

      const isRightSwipe = deltaX > 0;   // iOS back = swipe right
      const isLeftSwipe  = deltaX < 0;   // Android back = swipe left

      const horizontalEnough = Math.abs(deltaX) >= CONFIG.SWIPE_MIN_DELTA_X;
      const verticalOk       = deltaY <= CONFIG.SWIPE_MAX_DELTA_Y;
      const fastEnough       = velocityX >= CONFIG.SWIPE_MIN_VELOCITY;

      let isBackSwipe = false;

      if (state.touchEdgeType === 'ios-left' && isRightSwipe) {
        isBackSwipe = horizontalEnough && verticalOk && fastEnough;
      } else if (state.touchEdgeType === 'android-right' && isLeftSwipe) {
        isBackSwipe = horizontalEnough && verticalOk && fastEnough;
      }

      if (isBackSwipe) {
        doTrigger('mobile-edge-swipe');
      }

      // Reset
      state.touchEdgeType  = null;
      state.touchStartX    = null;
      state.touchStartY    = null;
      state.touchStartTime = null;
    }, { passive: true });

    // Cancel if touch is cancelled (interrupted)
    document.addEventListener('touchcancel', function() {
      state.touchEdgeType  = null;
      state.touchStartX    = null;
      state.touchStartY    = null;
    }, { passive: true });
  }

  // ════════════════════════════════════════════════════════════════════════════
  // MOBILE — PAGE VISIBILITY
  // Catches: home button press, tab switch, lock screen, browser chrome pull
  // ════════════════════════════════════════════════════════════════════════════

  function initVisibility() {
    document.addEventListener('visibilitychange', function() {
      if (document.visibilityState === 'hidden') {
        if (!hasTriggeredThisSession() && !state.triggered) {
          // Mark session now — second hide = real exit, no drawer
          markTriggered();
          state.hiddenAt = Date.now();
        } else {
          state.hiddenAt = null;
        }
      } else if (document.visibilityState === 'visible') {
        // User came back quickly = they used the back gesture or switched tab briefly
        if (state.hiddenAt && (Date.now() - state.hiddenAt) < CONFIG.VISIBILITY_RETURN_WINDOW) {
          // Small delay so page has rendered before we open drawer
          setTimeout(openSimilarDrawer, 100);
        }
        state.hiddenAt = null;
      }
    });
  }

  // ════════════════════════════════════════════════════════════════════════════
  // INIT
  // ════════════════════════════════════════════════════════════════════════════

  function init() {
    // Bail if drawer button doesn't exist in DOM
    const btn = document.querySelector('.view-similar-btn[data-product-id="{{ product.id }}"]');
    if (!btn) return;

    // Bail if already shown this session
    if (hasTriggeredThisSession()) return;

    // Shared scroll arm listener
    window.addEventListener('scroll', checkArm, { passive: true });

    if (isMobileDevice()) {
      initMobileScroll();
      initEdgeSwipe();
      initVisibility();
    } else {
      initDesktop();
    }
  }

  // Safe init
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

})(); // End IIFE — zero global leakage
</script>
{% endif %}

