{% comment %}
  Renders a megamenu for the header.

  Usage:
  {% render 'header-mega-menu' %}
{% endcomment %}
<nav class="header__inline-menu desktop-menu">
  <div class="small-logo">
    <a href="{{ routes.root_url }}">
      <svg class="icon icon-lucira-logo" width="30" height="40">
        <use xlink:href="#icon-lucira-logo"></use>
      </svg>
    </a>
  </div>
  <ul class="list-menu list-menu--inline" role="list">
    {%- for link in section.settings.menu.links -%}
      {%- assign current_parent_index = forloop.index -%}
                      {% assign badge_key = 'menu_badge_' | append: current_parent_index %}
                {% assign badge_type = settings[badge_key] %}

      <li>
        {%- if link.links != blank -%}
          <!-- Mega menu for links with children -->
          <header-menu>
            <details id="Details-HeaderMenu-{{ forloop.index }}" class="mega-menu">
              <summary
                id="HeaderMenu-{{ link.handle }}"
                class="header__menu-item list-menu__item link focus-inset"
              >
                <a href="{{ link.url }}">
                  <span
                    {%- if link.child_active %}
                      class="header__active-menu-item"
                    {% endif %}
                  >
                    {{- link.title | escape -}}
                    {% assign menu_index = forloop.index %}
                    {% assign badge_setting_key = 'show_new_label_menu_' | append: menu_index %}

                    {% if badge_type != 'none' %}
                      <span class="menu-badge menu-badge-{{ badge_type }} mobile-menu-badge">
                        {% if badge_type == 'fire' %}
                          🔥
                        {% else %}
                          New
                        {% endif %}
                      </span>
                    {% endif %}
                  </span>
                </a>
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </summary>

              <div
                id="MegaMenu-Content-{{ forloop.index }}"
                class="mega-menu__content color-{{ section.settings.menu_color_scheme }} gradient motion-reduce global-settings-popup"
                tabindex="-1"
              >
                <ul
                  class="mega-menu__list page-width{% if link.levels == 1 %} mega-menu__list--condensed{% endif %}"
                  role="list"
                >
                  {%- for childlink in link.links -%}
                    <li>
                      <a
                        id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                        href="{{ childlink.url }}"
                        class="mega-menu__link mega-menu__link--level-2 link{% if childlink.current %} mega-menu__link--active{% endif %}"
                        {% if childlink.current %}
                          aria-current="page"
                        {% endif %}
                      >
                        {{ childlink.title | escape }}
                      </a>

                      {%- if childlink.links != blank -%}
                        <ul class="list-unstyled" role="list">
                          {%- for grandchildlink in childlink.links -%}
                            <li>
                              {%- assign grandchild_collection = grandchildlink.object -%}

                              {%- if grandchild_collection != blank -%}
                                {%- if grandchild_collection.metafields.custom.menu_image_svg_sprite != blank -%}
                                  <div class="mega-menu__image">
                                    <svg class="icon menu-image-icon">
                                      {{ grandchild_collection.metafields.custom.menu_image_svg_sprite }}
                                    </svg>
                                  </div>
                                {%- elsif grandchild_collection.metafields.custom.mega_menu_image != blank -%}
                                  <div class="mega-menu__image">
                                    <img
                                      src="{{ grandchild_collection.metafields.custom.mega_menu_image | image_url: width: 160 }}"
                                      alt="{{ grandchild_collection.title | escape }}"
                                      width="24"
                                      height="24"
                                      loading="lazy"
                                    >
                                  </div>
                                {%- endif -%}
                              {%- endif -%}

                              <a
                                id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                href="{{ grandchildlink.url }}"
                                class="mega-menu__link link{% if grandchildlink.current %} mega-menu__link--active{% endif %}"
                                {% if grandchildlink.current %}
                                  aria-current="page"
                                {% endif %}
                              >
                                {{ grandchildlink.title | escape }}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}

                  {%- comment -%} Add menu images if defined {%- endcomment -%}
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'menu_image'
                      and block.settings.parent_index == current_parent_index
                      and block.settings.image != blank
                    -%}
                      {%- assign collection_title = '' -%}
                      {%- if block.settings.link contains '/collections/' -%}
                        {%- assign collection_handle = block.settings.link | remove: '/collections/' | remove: '/' -%}
                        {%- assign collection_obj = collections[collection_handle] -%}
                        {%- if collection_obj != null -%}
                          {%- assign collection_title = collection_obj.title -%}
                        {%- endif -%}
                      {%- endif -%}
                      {%- if collection_title == '' -%}
                        {%- assign collection_title = link.title -%}
                      {%- endif -%}
                      <li class="product-menu-image">
                        <a href="{{ block.settings.link | default: '#' }}">
                          <img
                            src="{{ block.settings.image | image_url: width: block.settings.image_width, height: block.settings.image_height }}"
                            alt="{{ collection_title | escape }}"
                            loading="lazy"
                            width="{{ block.settings.image_width | default: 420 }}"
                            height="{{ block.settings.image_height | default: 420 }}"
                            style="object-fit: {{ block.settings.image_fit | default: 'cover' }};"
                            title="header"
                          >
                          <span class="menu-image-caption">{{ collection_title }}</span>
                        </a>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              </div>
            </details>
          </header-menu>

        {%- else -%}
          {%- assign has_menu_image = false -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'menu_image'
              and block.settings.parent_index == current_parent_index
              and block.settings.image != blank
            -%}
              {%- assign has_menu_image = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if has_menu_image -%}
            <!-- Mega menu for link without children but with image -->
            <header-menu>
              <details id="Details-HeaderMenu-{{ forloop.index }}" class="mega-menu">
                <summary
                  id="HeaderMenu-{{ link.handle }}"
                  class="header__menu-item list-menu__item link focus-inset"
                >
                  <a href="{{ link.url }}">
                    <span>{{- link.title | escape -}}</span>
                    {% assign menu_index = forloop.index %}
                    {% assign badge_setting_key = 'show_new_label_menu_' | append: menu_index %}

                    {% if badge_type != 'none' %}
                      <span class="menu-badge menu-badge-{{ badge_type }} mobile-menu-badge">
                        {% if badge_type == 'fire' %}
                          🔥
                        {% else %}
                          New
                        {% endif %}
                      </span>
                    {% endif %}
                  </a>
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </summary>
                <div
                  id="MegaMenu-Content-{{ forloop.index }}"
                  class="mega-menu__content color-{{ section.settings.menu_color_scheme }} gradient motion-reduce global-settings-popup"
                  tabindex="-1"
                >
                  <ul class="mega-menu__list page-width" role="list">
                    {%- for block in section.blocks -%}
                      {%- if block.type == 'menu_image'
                        and block.settings.parent_index == current_parent_index
                        and block.settings.image != blank
                      -%}
                        {%- assign collection_title = '' -%}
                        {%- if block.settings.link contains '/collections/' -%}
                          {%- assign collection_handle = block.settings.link | remove: '/collections/' | remove: '/' -%}
                          {%- assign collection_obj = collections[collection_handle] -%}
                          {%- if collection_obj != null -%}
                            {%- assign collection_title = collection_obj.title -%}
                          {%- endif -%}
                        {%- endif -%}
                        {%- if collection_title == '' -%}
                          {%- assign collection_title = link.title -%}
                        {%- endif -%}
                        <li class="product-menu-image">
                          <a href="{{ block.settings.link | default: '#' }}">
                            <img
                              src="{{ block.settings.image | image_url: width: block.settings.image_width, height: block.settings.image_height }}"
                              alt="{{ collection_title | escape }}"
                              loading="lazy"
                              width="{{ block.settings.image_width | default: 420 }}"
                              height="{{ block.settings.image_height | default: 420 }}"
                              style="object-fit: {{ block.settings.image_fit | default: 'cover' }};"
                              title="header"
                            >
                            <span class="menu-image-caption">{{ collection_title }}</span>
                            {% if collection_obj != null %}
                              {% if collection_obj.handle == 'hexa' %}
                                <span class="menu-image-subtitle">An Ode to Transformation</span>
                              {% elsif collection_obj.handle == 'sports-collection' %}
                                <span class="menu-image-subtitle">For life in constant motion</span>
                              {% elsif collection_obj.handle == 'cotton-candy' %}
                                <span class="menu-image-subtitle">Savour Your Sweet Memories</span>
                              {% endif %}
                            {% endif %}
                          </a>
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>
                </div>
              </details>
            </header-menu>
          {%- else -%}
            <!-- Regular link if no children and no image -->
            <a
              id="HeaderMenu-{{ link.handle }}"
              href="{{ link.url }}"
              class="header__menu-item list-menu__item link link--text focus-inset"
              {% if link.current %}
                aria-current="page"
              {% endif %}
            >
              <span
                {%- if link.current %}
                  class="header__active-menu-item"
                {% endif %}
              >
                {{- link.title | escape -}}
                {% assign menu_index = forloop.index %}
                {% assign badge_setting_key = 'show_new_label_menu_' | append: menu_index %}

                {% if badge_type != 'none' %}
                  <span class="menu-badge menu-badge-{{ badge_type }} mobile-menu-badge">
                    {% if badge_type == 'fire' %}
                      🔥
                    {% else %}
                      New
                    {% endif %}
                  </span>
                {% endif %}
              </span>
            </a>
          {%- endif -%}
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</nav>
