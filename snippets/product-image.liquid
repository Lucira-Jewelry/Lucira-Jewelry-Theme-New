{% comment %}
  Renders a performance-optimized product image.

  Accepts:
  - image: {Object} Image object (required)
  - class: {String} Extra classes (optional)
  - lazy_load: {Boolean} Whether to lazy load the image. Default: true (optional)
  - priority: {String} fetchpriority attribute. Default: 'auto' (optional)
  - sizes: {String} sizes attribute (optional)
  - widths: {String} comma-separated widths (optional)
  - alt: {String} Alt text (optional)

  Usage:
  {% render 'product-image',
    image: media.preview_image,
    lazy_load: false,
    priority: 'high'
  %}
{% endcomment %}

{%- liquid
  assign loading = 'lazy'
  if lazy_load == false
    assign loading = 'eager'
  endif

  assign fetch_priority = priority | default: 'auto'
  
  assign image_widths = widths | default: '165, 300, 375, 450, 550, 750, 950, 1024, 1200, 1400, 1600, 1800, 2000'
  assign image_sizes = sizes | default: '(min-width: 1200px) 50vw, (min-width: 750px) 50vw, 100vw'
  assign image_alt = alt | default: image.alt | escape
-%}

{{ image
  | image_url: width: 2000
  | image_tag:
    class: class,
    loading: loading,
    fetchpriority: fetch_priority,
    decoding: 'async',
    sizes: image_sizes,
    widths: image_widths,
    alt: image_alt
}}
