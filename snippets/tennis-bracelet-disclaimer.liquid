{% if product.tags contains 'Tennis Bracelets' %}
<section class="tennis-bracelet-disclaimer">
  <div class="container">
    <p class="disclaimer-text">
      Bracelet size changes may alter diamond count and price*
    </p>
  </div>
</section>
{% endif %}

{% assign product_weight = product.metafields.custom.weight.value | default: 0 %}
{% assign product_type = product.type | downcase %}

{{ product_weight }}  }g
{{product_type}} - type

<style>
.tennis-bracelet-disclaimer .disclaimer-text {
  font-size: 12px;
  color: #555;
  margin: 10px 0;
  font-style: italic;
}
</style>
