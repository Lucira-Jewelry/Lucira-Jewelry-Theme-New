  <div class="container">
    <p class="disclaimer-text">
      Bracelet size changes may alter diamond count and price.
    </p>
  </div>
</section>
{% endif %}



<style>
.tennis-bracelet-disclaimer .disclaimer-text {
  font-size: 14px;
  color: #555;
  margin: 10px 0;
  font-style: italic;
}
</style>
