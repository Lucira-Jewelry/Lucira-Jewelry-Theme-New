<div class="fab-container">
  <div class="fab-actions" id="fabActions">

    <a href="#" class="fab-btn" id="fabChat" title="Live Chat">
      <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/chat_1.png?v=1772104883" width="20" height="20" loading="lazy">
      <span class="fab-badge" id="fabChatBadge"></span>
    </a>

    <a href="tel:+918976773659" target="_blank" class="fab-btn" id="fabPhone" title="Call">
      <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/phone-call_1.png?v=1772105479" width="20" height="20" loading="lazy">
    </a>

    {% assign wa_text = 'Hi, I want to get more information about Lucira' %}

    {% if template.name == 'index' %}
      {% assign wa_text = "Hi! Can you tell me more about Lucira Jewelry's collection and designs?" %}
    {% elsif template.name == 'collection' %}
      {% assign wa_text = 'Hi, I want to get more information about this collection: ' | append: collection.title %}
    {% elsif template.name == 'product' %}
      {% assign wa_text = 'Hi, I want to get more information about this product: ' | append: product.title %}
    {% elsif template.name == 'blog' %}
      {% assign wa_text = 'Hi, Can you Tell me more about Lucira Blogs' %}
    {% elsif template.name == 'article' %}
      {% assign wa_text = 'Hi, can you tell me more about this blog: ' | append: article.title %}
    {% elsif template.name == 'page' %}
      {% if page.handle contains 'gold-rate' %}
        {% assign city = page.handle | remove: 'gold-rate-' | replace: '-', ' ' %}
        {% assign wa_text = 'Tell me more about ' | append: city | append: ' gold rate' %}
      {% elsif page.handle contains 'platinum-rate' %}
        {% assign city = page.handle | remove: 'platinum-rate-' | replace: '-', ' ' %}
        {% assign wa_text = 'Tell me more about ' | append: city | append: ' platinum rate' %}
      {% endif %}
    {% endif %}

    <a
      href="https://wa.me/919004435760?text={{ wa_text | url_encode }}"
      class="fab-btn"
      id="fabWhatsapp"
      title="WhatsApp"
      target="_blank"
    >
      <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/whatsapp_3_1.png?v=1772105856" width="20" height="20" loading="lazy">
    </a>

  </div>

  <div class="fab-main" id="fabMain">
    <img src="https://cdn.shopify.com/s/files/1/0739/8516/3482/files/plus-sign.png?v=1772106817" width="28" height="28" loading="lazy">
    <span class="fab-badge" id="fabMainBadge"></span>
  </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function () {

  // ── SalesIQ Badge Sync ──────────────────────────────────────────────
  const fabMainBadge  = document.getElementById('fabMainBadge');      // + button
  const fabChatBadge  = document.getElementById('fabChatBadge');   // WhatsApp button

  function syncBadge(count) {
    const show = count && parseInt(count) > 0;
    [fabMainBadge, fabChatBadge].forEach(function (el) {
      if (!el) return;
      el.textContent   = show ? count : '';
      el.style.display = show ? 'flex' : 'none';
    });
  }

  function watchZsiqIndicator() {
    const zsiqEl = document.getElementById('zsiq-indicator');
    if (!zsiqEl) {
      setTimeout(watchZsiqIndicator, 800);
      return;
    }

    syncBadge(zsiqEl.textContent.trim());

    const observer = new MutationObserver(function () {
      syncBadge(zsiqEl.textContent.trim());
    });
    observer.observe(zsiqEl, { childList: true, characterData: true, subtree: true });
  }

  watchZsiqIndicator();

  // ── WhatsApp dataLayer ──────────────────────────────────────────────
  const fabWhatsapp = document.getElementById('fabWhatsapp');
  if (fabWhatsapp) {
    fabWhatsapp.addEventListener('click', function () {
      const chatData = {
        promo_id:      '{{ product.selected_or_first_available_variant.sku | default: "N/A" }}',
        promo_name:    '{{ product.title | default: "General Inquiry" }}',
        creative_name: 'fabWhatsapp',
        location_id:   '{{ request.path }}'
      };
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'promoClick', promoClick: chatData });
      console.log('✅ FAB WhatsApp dataLayer pushed:', chatData);
    });
  }

});
</script>