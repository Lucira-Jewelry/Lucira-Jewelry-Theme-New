                </svg>
              </div>
              <h3 class="empty-address-title">No Address Yet</h3>
              <p class="empty-address-text">Please Add Your Address For Better Experience</p>
            </div>
          {%- else -%}
            {%- for address in customer.addresses -%}
              <div class="address-card {% if address == customer.default_address %}default{% endif %}">
                <!-- existing address card code remains the same -->
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endpaginate -%}
    </div>

