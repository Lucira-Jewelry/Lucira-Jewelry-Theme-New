<script>
  function openAddressModal() {
    document.getElementById('addAddressModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeAddressModal() {
    document.getElementById('addAddressModal').classList.remove('active');
    document.body.style.overflow = 'auto';
  }

  function openEditModal(id, firstName, lastName, phone, address1, address2, city, province, zip, country) {
    document.getElementById('EditAddressId').value = id;
    document.getElementById('EditAddressFirstName').value = firstName || '';
    document.getElementById('EditAddressLastName').value = lastName || '';
    document.getElementById('EditAddressPhone').value = phone || '';
    document.getElementById('EditAddressAddress1').value = address1 || '';
    document.getElementById('EditAddressAddress2').value = address2 || '';
    document.getElementById('EditAddressCity').value = city || '';
    document.getElementById('EditAddressProvince').value = province || '';
    document.getElementById('EditAddressZip').value = zip || '';
    document.getElementById('EditAddressCountry').value = country || 'India';
    
    document.getElementById('editAddressModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeEditModal() {
    document.getElementById('editAddressModal').classList.remove('active');
    document.body.style.overflow = 'auto';
  }

  function deleteAddress(url) {
    if (!confirm('Are you sure you want to delete this address?')) return;

    const form = document.createElement('form');
    form.method = 'POST';

    // 👇 Add return_to as a query param on the action URL
    form.action = url + '?return_to={{ routes.account_url | url_encode }}';
    // If you want a specific tab: '?return_to={{ '/account?tab=addresses' | url_encode }}'

    const methodInput = document.createElement('input');
    methodInput.type = 'hidden';
    methodInput.name = '_method';
    methodInput.value = 'delete';
    form.appendChild(methodInput);

    document.body.appendChild(form);
    form.submit();
  }

  document.getElementById('addAddressModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeAddressModal();
    }
  });

  document.getElementById('editAddressModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeEditModal();
    }
  });

  document.getElementById('editAddressForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    const editPin = document.getElementById('EditAddressZip').value.trim();
    if (!/^\d{6}$/.test(editPin)) {
      alert('Please enter a valid 6-digit pincode.');
      return;
    }

    const addressId = document.getElementById('EditAddressId').value;

    const formData = new FormData();
    formData.append('_method', 'put');
    formData.append('address[first_name]', document.getElementById('EditAddressFirstName').value);
    formData.append('address[last_name]', document.getElementById('EditAddressLastName').value);
    formData.append('address[phone]', document.getElementById('EditAddressPhone').value);
    formData.append('address[address1]', document.getElementById('EditAddressAddress1').value);
    formData.append('address[address2]', document.getElementById('EditAddressAddress2').value);
    formData.append('address[city]', document.getElementById('EditAddressCity').value);
    formData.append('address[province]', document.getElementById('EditAddressProvince').value);
    formData.append('address[country]', 'India');
    formData.append('address[zip]', editPin);

    try {
      const res = await fetch(`/account/addresses/${addressId}`, {
        method: 'POST',
        body: formData
      });

      if (res.ok) {
        alert('✅ Address updated successfully');
        window.location.reload(); // refresh to show updated address
      } else {
        alert('❌ Failed to update address');
        console.error(await res.text());
      }
    } catch (err) {
      console.error(err);
      alert('⚠️ Network error');
    }
  });

  window.addEventListener('load', () => {
    typeof CustomerAddresses !== 'undefined' && new CustomerAddresses();
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const countrySelect = document.getElementById('AddressCountryNew');
    if (countrySelect && !countrySelect.value) {
      countrySelect.value = 'India';
    }
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const editBtn = document.getElementById("edit-btn");
    const cancelBtn = document.getElementById("cancel-btn");
    const saveBtn = document.getElementById("save-button");

    /* 🔹 ADDED dob & doa here */
    const inputs = document.querySelectorAll(
      "#first_name, #last_name, #email, #dob, #doa"
    );

    const phoneInput = document.getElementById("phone");
    const emailError = document.querySelector(".email-error");
    const originalValues = {};

    phoneInput.setAttribute("disabled", "true");

    inputs.forEach(input => {
      originalValues[input.id] = input.value;
    });

    editBtn.addEventListener("click", () => {
      inputs.forEach((input) => input.removeAttribute("disabled"));
      saveBtn.removeAttribute("disabled");
      cancelBtn.style.display = "inline-flex";
      editBtn.style.display = "none";
    });

    cancelBtn.addEventListener("click", () => {
      inputs.forEach(input => {
        input.value = originalValues[input.id];
        input.setAttribute("disabled", "true");
      });
      saveBtn.setAttribute("disabled", "true");
      cancelBtn.style.display = "none";
      editBtn.style.display = "inline-flex";
      emailError.style.display = "none";
    });

    document.getElementById("customer-info-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      emailError.style.display = "none";

      const email = document.getElementById("email").value;
      if (!validateEmail(email)) {
        emailError.textContent = "Please enter a valid email address";
        emailError.style.display = "block";
        return;
      }

      const data = {
        id: document.getElementById("customer_id").value,
        first_name: document.getElementById("first_name").value,
        last_name: document.getElementById("last_name").value,
        email: email,
        phone: document.getElementById("phone").value,

        note: `dob:${document.getElementById("dob").value || ''};doa:${document.getElementById("doa").value || ''}`
      };

      try {
        const res = await fetch("https://personal-information-api-385594025448.asia-south1.run.app/", {
          method: "PUT",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify(data)
        });

        const result = await res.json();

        if (res.ok) {
          alert("✅ Customer information updated successfully.");
          inputs.forEach(input => {
            originalValues[input.id] = input.value;
            input.setAttribute("disabled", "true");
          });
          saveBtn.setAttribute("disabled", "true");
          cancelBtn.style.display = "none";
          editBtn.style.display = "inline-block";
        } else {
          if (result.errors && result.errors.email) {
            emailError.textContent = result.errors.email.join(', ');
            emailError.style.display = "block";
          } else {
            alert("❌ Error updating customer: " + (result.message || "Unknown error"));
          }
          console.error("Update error:", result);
        }
      } catch (err) {
        alert("⚠️ Network error. Please try again.");
        console.error("Network error:", err);
      }
    });

    function validateEmail(email) {
      const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return re.test(email);
    }
  });
</script>


<script>
  document.addEventListener('DOMContentLoaded', function () {
    const addAddressForm = document.querySelector('#addAddressModal form');
    const addPinInput = document.getElementById('AddressZipNew');

    if (addAddressForm && addPinInput) {
      addPinInput.addEventListener('input', function (e) {
        let v = e.target.value.replace(/\D/g, '');
        if (v.length > 6) v = v.slice(0, 6);
        e.target.value = v;
      });

      addAddressForm.addEventListener('submit', function (e) {
        const first = document.getElementById('AddressFirstNameNew').value.trim();
        const last = document.getElementById('AddressLastNameNew').value.trim();
        const address = document.getElementById('AddressAddress1New').value.trim();
        const phone = document.getElementById('AddressPhoneNew').value.trim();
        const pin = addPinInput.value.trim();

        if (!first || !last || !address) {
          e.preventDefault();
          alert('* Indicated Fields are Required.');
          return;
        }

        if (phone && !/^[6-9]\d{9}$/.test(phone)) {
          e.preventDefault();
          alert('Please enter a valid 10-digit mobile number.');
          return;
        }

        if (!/^\d{6}$/.test(pin)) {
          e.preventDefault();
          alert('Please enter a valid 6-digit pincode.');
        }
      });
    }

    // Same input mask for Edit
    const editPinInput = document.getElementById('EditAddressZip');
    if (editPinInput) {
      editPinInput.addEventListener('input', function (e) {
        let v = e.target.value.replace(/\D/g, '');
        if (v.length > 6) v = v.slice(0, 6);
        e.target.value = v;
      });
    }
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const addPinInput = document.getElementById('AddressZipNew');
    const addCityInput = document.getElementById('AddressCityNew');
    const addStateSelect = document.getElementById('AddressProvinceNew');

    const editPinInput = document.getElementById('EditAddressZip');
    const editCityDisplayInput = document.getElementById('EditAddressAddress2');
    const editStateSelect = document.getElementById('EditAddressProvince');

    ['AddressPhoneNew', 'EditAddressPhone'].forEach(id => {
      const input = document.getElementById(id);
      if (!input) return;

      input.addEventListener('input', function () {
        let value = this.value;

        // remove non-digits
        value = value.replace(/\D/g, '');

        // limit to 10 digits
        if (value.length > 10) {
          value = value.slice(0, 10);
        }

        this.value = value;
      });
    });

    async function fetchLocationFromPincode(pin) {
      if (!/^\d{6}$/.test(pin)) return null;
      try {
        const res = await fetch('https://api.postalpincode.in/pincode/' + pin);
        const data = await res.json();

        if (Array.isArray(data) &&
            data[0].Status === 'Success' &&
            data[0].PostOffice &&
            data[0].PostOffice.length) {

          const po = data[0].PostOffice[0];
          return {
            city: po.District || '',
            state: po.State || ''
          };
        }
      } catch (err) {
        console.error('Pincode lookup failed:', err);
      }
      return null;
    }

    function setupPincodeAutoFill(pinInput, cityInput, stateSelect) {
      if (!pinInput) return;
      pinInput.addEventListener('blur', async function (e) {
        const pin = e.target.value.trim();
        if (!/^\d{6}$/.test(pin)) return;

        const loc = await fetchLocationFromPincode(pin);
        if (!loc) return;

        // Fill city
        if (cityInput && !cityInput.value) {
          cityInput.value = loc.city;
        }
        if (stateSelect && loc.state) {
          const stateOption = Array.from(stateSelect.options).find(function (opt) {
            return opt.value.toLowerCase() === loc.state.toLowerCase();
          });
          if (stateOption) {
            stateSelect.value = stateOption.value;
          }
        }
      });
    }
    setupPincodeAutoFill(addPinInput, addCityInput, addStateSelect);
    setupPincodeAutoFill(editPinInput, editCityDisplayInput, editStateSelect);
  });
</script>
