<div class="acc-personal-tabs-wrapper">
  <input type="radio" name="personal-tab" id="tab-info" hidden checked>
  <input type="radio" name="personal-tab" id="tab-addresses" hidden>

  <div class="acc-personal-tab-buttons">
    <label for="tab-info">Personal Information</label>
    <label for="tab-addresses">Manage Addresses</label>
  </div>

  <form class="acc-personal-tab-content acc-tab-info" id="customer-info-form">
    <input type="hidden" id="customer_id" value="{{ customer.id }}">
  
    <div class="personal-info-heading-wrapper">
      <h2>PERSONAL INFORMATION</h2>
      <button type="button" class="acc-edit-btn" id="edit-btn">EDIT</button>
      <button type="button" class="acc-cancel-btn" id="cancel-btn" style="display: none;">Cancel</button>
    </div>
  
    <div class="acc-form-row">
      <div class="acc-form-group">
        <label>First Name</label>
        <input type="text" id="first_name" value="{{ customer.first_name }}" disabled>
      </div>
      <div class="acc-form-group">
        <label>Last Name</label>
        <input type="text" id="last_name" value="{{ customer.last_name }}" disabled>
      </div>
    </div>
    
    <div class="acc-form-group">
      <label>Mobile Number</label>
      <input type="text" id="phone" value="{{ customer.phone | default: '' }}" disabled>
    </div>
    
    <div class="acc-form-group email-group">
      <label>Email</label>
      <input type="email" id="email" value="{{ customer.email }}" disabled>
      <div class="email-error" style="color: red; display: none;"></div>
    </div>
  
    <button class="save-button" id="save-button" type="submit" disabled>SAVE</button>
  </form>

  <div class="acc-personal-tab-content acc-tab-addresses">
    <input type="hidden" id="customer_id" value="{{ customer.id }}">
  
    <div class="acc-address-header">
      <h2 class="acc-address-title">ADDRESS</h2>
      <button type="button" class="acc-header-edit-btn">EDIT</button>
    </div>
  
    <div class="acc-address-list">
      {% if customer.addresses.size > 0 %}
        {% for address in customer.addresses %}
          <form class="acc-address-card acc-address-form" data-address-id="{{ address.id }}">
            <div class="acc-address-card-content">
              <div class="acc-address-view">
                <p class="acc-address-name">
                  <strong>{{ address.first_name }} {{ address.last_name }}</strong>
                  {% if address.phone %}&nbsp;&nbsp;{{ address.phone }}{% endif %}
                </p>
                <p class="acc-address-text">
                  {{ address.address1 }}{% if address.address2 %}, {{ address.address2 }}{% endif %},
                  {{ address.city }}, {{ address.province }}, {{ address.country }} - <strong>{{ address.zip }}</strong>
                </p>
              </div>
  
              <div class="acc-address-edit" style="display: none;">
                <div class="acc-form-group">
                  <label>First Name</label>
                  <input type="text" name="first_name" value="{{ address.first_name }}" disabled>
                </div>
                <div class="acc-form-group">
                  <label>Last Name</label>
                  <input type="text" name="last_name" value="{{ address.last_name }}" disabled>
                </div>
                <div class="acc-form-group">
                  <label>Phone</label>
                  <input type="text" name="phone" value="{{ address.phone }}" disabled>
                </div>
                <div class="acc-form-group">
                  <label>Address 1</label>
                  <input type="text" name="address1" value="{{ address.address1 }}" disabled>
                </div>
                <div class="acc-form-group">
                  <label>Address 2</label>
                  <input type="text" name="address2" value="{{ address.address2 }}" disabled>
                </div>
                <div class="acc-form-group">
                  <label>City</label>
                  <input type="text" name="city" value="{{ address.city }}" disabled>
                </div>
                <div class="acc-form-group">
                  <label>Province</label>
                  <input type="text" name="province" value="{{ address.province }}" disabled>
                </div>
                <div class="acc-form-group">
                  <label>Country</label>
                  <input type="text" name="country" value="{{ address.country }}" disabled>
                </div>
                <div class="acc-form-group">
                  <label>ZIP</label>
                  <input type="text" name="zip" value="{{ address.zip }}" disabled>
                </div>
  
                <button type="submit" class="save-button" disabled>SAVE</button>
              </div>
            </div>
          </form>
        {% endfor %}
      {% else %}
        <div class="acc-no-address">
          <p>No address provided</p>
        </div>
      {% endif %}
    </div>
  </div>

</div>

<style>
  .acc-personal-tab-buttons {
    display: flex;
    justify-content: space-between;
    background: #f2f2f2;
    padding: 5px;
    border-radius: 24px;
    gap: 1rem;
  }
  .acc-personal-tab-buttons label {
    flex: 1;
    cursor: pointer;
    padding: 0.5rem 1rem;
    text-align: center;
    border-radius: 24px;
    font-size: 14px;
    background: transparent;
  }
  #tab-info:checked ~ .acc-personal-tab-buttons label[for="tab-info"],
  #tab-addresses:checked ~ .acc-personal-tab-buttons label[for="tab-addresses"] {
    background: white;
    box-shadow: 0px 3px 12px 0px #0000001F;
  }
  .acc-personal-tab-content {
    display: none;
    flex-direction: column;
    gap: 1rem;
    padding-top: 2rem;
  }
  #tab-info:checked ~ .acc-tab-info,
  #tab-addresses:checked ~ .acc-tab-addresses {
    display: flex;
  }
  .acc-form-row {
    display: flex;
    gap: 2rem;
  }
  .acc-form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .acc-form-group input {
    padding: 1rem;
    border: 1px solid #ccc;
    border-radius: 8px;
    width: 100%;
  }
  .acc-form-group input:disabled {
    background-color: #f5f5f5;
    color: #666;
    cursor: not-allowed;
  }
  .save-button {
    font-family: 'Futura', sans-serif;
    font-weight: 500;
    font-size: 16px;
    text-transform: uppercase;
    padding: 1.7rem 3rem;
    border-radius: 3rem;
    border: 0;
    width: 100%;
    max-width: 360px;
    margin: 20px auto 0;
    cursor: pointer;
  }
  .save-button:enabled {
    background: #a68380;
    color: white;
  }
  .save-button:disabled { background: #F4F0F0; color: #D5C5C3; cursor: not-allowed; font-family: 'Futura Std', sans-serif; letter-spacing: 1px; }
  .acc-content h2 {margin: 5px 0; text-align: left; margin-bottom: 24px; font-weight: 500; font-size: 20px; line-height: 150%; letter-spacing: 1px; vertical-align: middle; text-transform: uppercase; color: #000;}
  button#edit-btn { background: transparent; border: 0; font-family: 'Futura', sans-serif; font-weight: 500; font-size: 16px; line-height: 150%; vertical-align: middle; text-transform: capitalize; text-decoration: underline; text-decoration-style: solid; text-decoration-thickness: 0%; text-decoration-skip-ink: auto; color: #666666; }
  .personal-info-heading-wrapper {display: flex ; align-items: center; justify-content: space-between; margin-top: 12px; margin-bottom: 12px;}
  :is(.account,.order) p { margin: 8px 0 8px; font-size: 14px; text-transform: capitalize;}
  .acc-address-card-content { background: #F4F0F0; padding: 20px 30px; border: 1px solid #CCCCCC; border-radius: 8px; margin-top: 10px; }
  p.acc-address-name { font-weight: 600; }
  button#cancel-btn { background: transparent; border: 0; font-family: 'Futura', sans-serif; font-weight: 500; font-size: 16px; line-height: 150%; vertical-align: middle; text-transform: capitalize; text-decoration: underline; text-decoration-style: solid; text-decoration-thickness: 0%; text-decoration-skip-ink: auto; color: #666666; }
  label.acc-tab { border-bottom: 1px solid #E6E6E6; border-left: 8px solid #ffffff; }
  .acc-tab {padding: 26px 40px;}
  span.tab-option span { margin-top: 0; font-family: 'Futura'; font-weight: 500; font-size: 14px; line-height: 150%; vertical-align: middle; text-transform: uppercase; }
  .acc-info {gap: 2rem; padding: 2rem 5rem;}
  .acc-info b { font-family: 'Futura'; font-weight: 600; font-size: 16px; line-height: 150%; vertical-align: middle; text-transform: uppercase; letter-spacing: 1px; }
  .acc-address-header {display: flex ; align-items: center; justify-content: space-between;}
  button.acc-header-edit-btn { background: transparent; border: 0; font-family: 'Futura', sans-serif; font-weight: 500; font-size: 16px; line-height: 150%; vertical-align: middle; text-transform: capitalize; text-decoration: underline; text-decoration-style: solid; text-decoration-thickness: 0%; text-decoration-skip-ink: auto; color: #666666; }
  .acc-account .tab-logo {position: relative; top: -4px;}
  @media only screen and (min-width:0px) and (max-width:767px){
    .acc-personal-tab-buttons label {font-size: 13px !important;}
    .acc-content h2 {font-size: 16px;}
    .acc-content { padding: 3rem 2rem 3rem 2rem; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const editBtn = document.getElementById("edit-btn");
    const cancelBtn = document.getElementById("cancel-btn");
    const saveBtn = document.getElementById("save-button");
    const inputs = document.querySelectorAll("#first_name, #last_name, #email, #phone");
    const emailError = document.querySelector(".email-error");
    const originalValues = {};
  
    // Store original values
    inputs.forEach(input => {
      originalValues[input.id] = input.value;
    });
  
    editBtn.addEventListener("click", () => {
      inputs.forEach((input) => input.removeAttribute("disabled"));
      saveBtn.removeAttribute("disabled");
      cancelBtn.style.display = "inline-block";
      editBtn.style.display = "none";
    });
  
    cancelBtn.addEventListener("click", () => {
      // Reset to original values
      inputs.forEach(input => {
        input.value = originalValues[input.id];
        input.setAttribute("disabled", "true");
      });
      saveBtn.setAttribute("disabled", "true");
      cancelBtn.style.display = "none";
      editBtn.style.display = "inline-block";
      emailError.style.display = "none";
    });
  
    document.getElementById("customer-info-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      emailError.style.display = "none";
  
      // Validate email format
      const email = document.getElementById("email").value;
      if (!validateEmail(email)) {
        emailError.textContent = "Please enter a valid email address";
        emailError.style.display = "block";
        return;
      }
  
      const data = {
        id: document.getElementById("customer_id").value,
        first_name: document.getElementById("first_name").value,
        last_name: document.getElementById("last_name").value,
        email: email,
        phone: document.getElementById("phone").value
      };
  
      try {
        const res = await fetch("https://user-edit-385594025448.asia-south1.run.app/", {
          method: "PUT",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify(data)
        });
  
        const result = await res.json();
  
        if (res.ok) {
          alert("✅ Customer information updated successfully.");
          // Update original values with new ones
          inputs.forEach(input => {
            originalValues[input.id] = input.value;
            input.setAttribute("disabled", "true");
          });
          saveBtn.setAttribute("disabled", "true");
          cancelBtn.style.display = "none";
          editBtn.style.display = "inline-block";
        } else {
          // Handle Shopify-specific email errors
          if (result.errors && result.errors.email) {
            emailError.textContent = result.errors.email.join(', ');
            emailError.style.display = "block";
          } else {
            alert("❌ Error updating customer: " + (result.message || "Unknown error"));
          }
          console.error("Update error:", result);
        }
      } catch (err) {
        alert("⚠️ Network error. Please try again.");
        console.error("Network error:", err);
      }
    });
  
    function validateEmail(email) {
      const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return re.test(email);
    }
  });
</script>

<script>
  document.querySelectorAll(".acc-address-form").forEach((form) => {
    const viewSection = form.querySelector(".acc-address-view");
    const editSection = form.querySelector(".acc-address-edit");
    const saveBtn = form.querySelector(".save-button");
    const inputs = editSection.querySelectorAll("input");

    // Global header elements (shared)
    const headerTitle = document.querySelector(".acc-address-title");
    const headerButton = document.querySelector(".acc-header-edit-btn");

    let isEditing = false;

    const enterEditMode = () => {
      viewSection.style.display = "none";
      editSection.style.display = "block";
      inputs.forEach((input) => input.removeAttribute("disabled"));
      saveBtn.removeAttribute("disabled");

      // Update header
      headerTitle.textContent = "EDIT ADDRESS";
      headerButton.textContent = "CANCEL";
      isEditing = true;
    };

    const cancelEditMode = () => {
      viewSection.style.display = "block";
      editSection.style.display = "none";
      inputs.forEach((input) => input.setAttribute("disabled", true));
      saveBtn.setAttribute("disabled", true);

      // Reset header
      headerTitle.textContent = "ADDRESS";
      headerButton.textContent = "EDIT";
      isEditing = false;
    };

    // Toggle edit/cancel via header button
    headerButton.addEventListener("click", () => {
      if (isEditing) {
        cancelEditMode();
      } else {
        enterEditMode();
      }
    });

    // Save updated address
    saveBtn.addEventListener("click", async (e) => {
      e.preventDefault();

      const customerId = document.getElementById("customer_id").value;
      const addressId = form.dataset.addressId;

      const data = {
        customer_id: customerId,
        address_id: addressId,
        first_name: editSection.querySelector('[name="first_name"]').value,
        last_name: editSection.querySelector('[name="last_name"]').value,
        phone: editSection.querySelector('[name="phone"]').value,
        address1: editSection.querySelector('[name="address1"]').value,
        address2: editSection.querySelector('[name="address2"]').value,
        city: editSection.querySelector('[name="city"]').value,
        province: editSection.querySelector('[name="province"]').value,
        country: editSection.querySelector('[name="country"]').value,
        zip: editSection.querySelector('[name="zip"]').value
      };

      try {
        const response = await fetch("https://user-address-edit-385594025448.asia-south1.run.app", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data)
        });

        const result = await response.json();

        if (response.ok) {
          alert("✅ Address updated successfully.");

          // Update view
          const nameElement = viewSection.querySelector(".acc-address-name strong");
          const phoneElement = viewSection.querySelector(".acc-address-name");
          const addressTextElement = viewSection.querySelector(".acc-address-text");

          nameElement.textContent = `${data.first_name} ${data.last_name}`;
          if (data.phone) {
            phoneElement.innerHTML = `<strong>${data.first_name} ${data.last_name}</strong>&nbsp;&nbsp;${data.phone}`;
          } else {
            phoneElement.innerHTML = `<strong>${data.first_name} ${data.last_name}</strong>`;
          }

          addressTextElement.innerHTML = `
            ${data.address1}${data.address2 ? `, ${data.address2}` : ''},
            ${data.city}, ${data.province}, ${data.country} - <strong>${data.zip}</strong>
          `;

          cancelEditMode(); // Exit edit mode
        } else {
          alert("❌ Failed to update address.");
          console.error(result);
        }
      } catch (err) {
        alert("⚠️ Network error.");
        console.error(err);
      }
    });
  });
</script>