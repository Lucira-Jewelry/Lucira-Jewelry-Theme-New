{{ 'customer.css' | asset_url | stylesheet_tag: preload: true }}
<script src="{{ 'customer.js' | asset_url }}" defer></script>

<div class="customer-personal-tabs-wrapper">
    <input type="radio" name="personal-tab" id="tab-info" hidden checked>
    <input type="radio" name="personal-tab" id="tab-addresses" hidden>

    <div class="customer-personal-tab-buttons">
      <label for="tab-info">Personal Information</label>
      <label for="tab-addresses">Manage Addresses</label>
    </div>

    <form class="customer-personal-tab-content customer-tab-info" id="customer-info-form">
      <input type="hidden" id="customer_id" value="{{ customer.id }}">
    
      <div class="personal-info-heading-wrapper">
        <h2>PERSONAL INFORMATION</h2>
        <button type="button" class="customer-edit-btn" id="edit-btn">Edit</button>
        <button type="button" class="customer-cancel-btn" id="cancel-btn" style="display: none;">Cancel</button>
      </div>
    
      <div class="customer-form-row">
        <div class="customer-form-group">
          <label>First Name</label>
          <input type="text" id="first_name" value="{{ customer.first_name }}" disabled>
        </div>
        <div class="customer-form-group">
          <label>Last Name</label>
          <input type="text" id="last_name" value="{{ customer.last_name }}" disabled>
        </div>
      </div>
      
      <div class="customer-form-group">
        <label>Mobile Number</label>
        <input type="text" id="phone" value="{{ customer.phone | default: '' }}" disabled>
      </div>
      
      <div class="customer-form-group email-group">
        <label>Email</label>
        <input type="email" id="email" value="{{ customer.email }}" disabled>
        <div class="email-error" style="color: red; display: none;"></div>
      </div>
    
      <button class="save-button" id="save-button" type="submit" disabled>SAVE</button>
    </form>

    <div class="customer-addresses-wrapper">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0; margin-top: 20px;">
        <h2 style="margin: 0; font-size: 20px;">ADDRESSES</h2>
        <button class="add-address-btn" onclick="openAddressModal()">+ Add New Address</button>
      </div>

      {%- paginate customer.addresses by 10 -%}
        <div class="addresses-list">
          {%- for address in customer.addresses -%}
            <div class="address-card {% if address == customer.default_address %}default{% endif %}">
              <div class="address-card-header">
                <div>
                  <div class="address-card-name">{{ address.first_name }} {{ address.last_name }}</div>
                  {% if address.phone != blank %}
                    <div class="address-card-phone">{{ address.phone }}</div>
                  {% endif %}
                </div>
                {% if address == customer.default_address %}
                  <span class="default-badge">Default</span>
                {% endif %}
              </div>

              <div class="address-card-content">
                {% if address.company != blank %}
                  <div>{{ address.company }}</div>
                {% endif %}
                {% if address.address1 != blank %}
                  <div>{{ address.address1 }}</div>
                {% endif %}
                {% if address.address2 != blank %}
                  <div>{{ address.address2 }}</div>
                {% endif %}
                <div>
                  {% if address.city %}{{ address.city }}{% if address.province or address.zip %}, {% endif %}{% endif %}
                  {% if address.province %}{{ address.province }}{% if address.zip %}, {% endif %}{% endif %}
                  {% if address.zip %}{{ address.zip }}{% endif %}
                </div>
                <div>{{ address.country }}</div>
              </div>

              <div class="address-card-actions">
                <button class="btn-edit" onclick='openEditModal({{ address.id | json }}, {{ address.first_name | json }}, {{ address.last_name | json }}, {{ address.phone | json }}, {{ address.address1 | json }}, {{ address.address2 | json }}, {{ address.city | json }}, {{ address.province | json }}, {{ address.zip | json }}, {{ address.country | json }})'>Edit</button>
                <button class="btn-delete" onclick="deleteAddress('https://www.lucirajewelry.com/account')">Delete</button>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endpaginate -%}
    </div>

    <!-- Add Address Modal -->
    <div class="address-modal-overlay" id="addAddressModal">
      <div class="address-modal">
        <div class="address-modal-header">
          <h2>Add New Address</h2>
          <button class="address-modal-close" onclick="closeAddressModal()"><span>{{- 'icon-close-x.svg' | inline_asset_content -}}</span></button>
        </div>

        {%- form 'customer_address', customer.new_address, return_to: routes.account_url -%}
          <div class="address-form-row">
            <div class="address-form-group">
              <label for="AddressFirstNameNew">First Name</label>
              <input
                type="text"
                id="AddressFirstNameNew"
                name="address[first_name]"
                placeholder="First name"
                autocomplete="given-name"
              >
            </div>
            <div class="address-form-group">
              <label for="AddressLastNameNew">Last Name</label>
              <input
                type="text"
                id="AddressLastNameNew"
                name="address[last_name]"
                placeholder="Last name"
                autocomplete="family-name"
              >
            </div>
          </div>

          <div class="address-form-group">
            <label for="AddressPhoneNew">Mobile No.</label>
            <input
              type="tel"
              id="AddressPhoneNew"
              name="address[phone]"
              placeholder="Enter your Number"
              autocomplete="tel"
            >
          </div>

          <div class="address-form-row">
            <div class="address-form-group">
              <label for="AddressZipNew">Pincode</label>
              <input
                type="text"
                id="AddressZipNew"
                name="address[zip]"
                placeholder="Enter Your Pincode"
                autocapitalize="characters"
                autocomplete="postal-code"
              >
            </div>
            <div class="address-form-group">
              <label for="AddressCityNew">City</label>
              <input
                type="text"
                id="AddressCityNew"
                name="address[city]"
                placeholder="Enter your Locality"
                autocomplete="address-level2"
              >
            </div>
          </div>

          <div class="address-form-group">
            <label for="AddressAddress1New">Address</label>
            <input
              type="text"
              id="AddressAddress1New"
              name="address[address1]"
              placeholder="Enter Your Address"
              autocomplete="address-line1"
            >
          </div>

          <div class="address-form-row">
            <div class="address-form-group">
              <label for="AddressAddress2New">Street/Locality</label>
              <input
                type="text"
                id="AddressAddress2New"
                name="address[address2]"
                placeholder="Enter Your Street"
                autocomplete="address-line2"
              >
            </div>
            <div class="address-form-group">
              <label for="AddressProvinceNew">State</label>
              <select
                id="AddressProvinceNew"
                name="address[province]"
                autocomplete="address-level1"
              >
                <option value="">-- Select State --</option>
                <option value="Andhra Pradesh">Andhra Pradesh</option>
                <option value="Arunachal Pradesh">Arunachal Pradesh</option>
                <option value="Assam">Assam</option>
                <option value="Bihar">Bihar</option>
                <option value="Chhattisgarh">Chhattisgarh</option>
                <option value="Goa">Goa</option>
                <option value="Gujarat">Gujarat</option>
                <option value="Haryana">Haryana</option>
                <option value="Himachal Pradesh">Himachal Pradesh</option>
                <option value="Jharkhand">Jharkhand</option>
                <option value="Karnataka">Karnataka</option>
                <option value="Kerala">Kerala</option>
                <option value="Madhya Pradesh">Madhya Pradesh</option>
                <option value="Maharashtra">Maharashtra</option>
                <option value="Manipur">Manipur</option>
                <option value="Meghalaya">Meghalaya</option>
                <option value="Mizoram">Mizoram</option>
                <option value="Nagaland">Nagaland</option>
                <option value="Odisha">Odisha</option>
                <option value="Punjab">Punjab</option>
                <option value="Rajasthan">Rajasthan</option>
                <option value="Sikkim">Sikkim</option>
                <option value="Tamil Nadu">Tamil Nadu</option>
                <option value="Telangana">Telangana</option>
                <option value="Tripura">Tripura</option>
                <option value="Uttar Pradesh">Uttar Pradesh</option>
                <option value="Uttarakhand">Uttarakhand</option>
                <option value="West Bengal">West Bengal</option>
              </select>
            </div>
          </div>

          <input type="hidden" name="address[country]" value="India">

          <div class="save-as-section">
            <label>Save As</label>
            <div class="save-as-options">
              <label>
                <input type="radio" name="address_type" value="Home" checked> Home
              </label>
              <label>
                <input type="radio" name="address_type" value="Work"> Work
              </label>
            </div>
          </div>

          <div style="margin: 15px 0;">
            {{ form.set_as_default_checkbox }}
            <label for="address_default_address_new" style="display: inline; margin-left: 8px; font-size: 14px; cursor: pointer;">
              Set as default address
            </label>
          </div>

          <div class="address-modal-actions">
            <button type="submit" class="btn-save">SAVE</button>
            <button type="button" class="btn-cancel" onclick="closeAddressModal()">CANCEL</button>
          </div>
        {%- endform -%}
      </div>
    </div>

    <!-- Edit Address Modal -->
    <div class="address-modal-overlay" id="editAddressModal">
      <div class="address-modal">
        <div class="address-modal-header">
          <h2>Edit Address</h2>
          <button class="address-modal-close" onclick="closeEditModal()"><span>{{- 'icon-close-x.svg' | inline_asset_content -}}</span></button>
        </div>

        <form id="editAddressForm">
          <input type="hidden" id="EditAddressId">
          
          <div class="address-form-row">
            <div class="address-form-group">
              <label for="EditAddressFirstName">First Name</label>
              <input
                type="text"
                id="EditAddressFirstName"
                placeholder="First name"
              >
            </div>
            <div class="address-form-group">
              <label for="EditAddressLastName">Last Name</label>
              <input
                type="text"
                id="EditAddressLastName"
                placeholder="Last name"
              >
            </div>
          </div>

          <div class="address-form-group">
            <label for="EditAddressPhone">Mobile No.</label>
            <input
              type="tel"
              id="EditAddressPhone"
              placeholder="Enter your Number"
            >
          </div>

          <div class="address-form-row">
            <div class="address-form-group">
              <label for="EditAddressZip">Pincode</label>
              <input
                type="text"
                id="EditAddressZip"
                placeholder="Enter Your Pincode"
              >
            </div>
            <div class="address-form-group">
              <label for="EditAddressCity">Street/Locality</label>
              <input
                type="text"
                id="EditAddressCity"
                placeholder="Enter your Locality"
              >
            </div>
          </div>

          <div class="address-form-group">
            <label for="EditAddressAddress1">Address</label>
            <input
              type="text"
              id="EditAddressAddress1"
              placeholder="Enter Your Address"
            >
          </div>

          <div class="address-form-row">
            <div class="address-form-group">
              <label for="EditAddressAddress2">City/ District/ Town</label>
              <input
                type="text"
                id="EditAddressAddress2"
                placeholder="Enter Your City"
              >
            </div>
            <div class="address-form-group">
              <label for="EditAddressProvince">State</label>
              <select id="EditAddressProvince">
                <option value="">-- Select State --</option>
                <option value="Andhra Pradesh">Andhra Pradesh</option>
                <option value="Arunachal Pradesh">Arunachal Pradesh</option>
                <option value="Assam">Assam</option>
                <option value="Bihar">Bihar</option>
                <option value="Chhattisgarh">Chhattisgarh</option>
                <option value="Goa">Goa</option>
                <option value="Gujarat">Gujarat</option>
                <option value="Haryana">Haryana</option>
                <option value="Himachal Pradesh">Himachal Pradesh</option>
                <option value="Jharkhand">Jharkhand</option>
                <option value="Karnataka">Karnataka</option>
                <option value="Kerala">Kerala</option>
                <option value="Madhya Pradesh">Madhya Pradesh</option>
                <option value="Maharashtra">Maharashtra</option>
                <option value="Manipur">Manipur</option>
                <option value="Meghalaya">Meghalaya</option>
                <option value="Mizoram">Mizoram</option>
                <option value="Nagaland">Nagaland</option>
                <option value="Odisha">Odisha</option>
                <option value="Punjab">Punjab</option>
                <option value="Rajasthan">Rajasthan</option>
                <option value="Sikkim">Sikkim</option>
                <option value="Tamil Nadu">Tamil Nadu</option>
                <option value="Telangana">Telangana</option>
                <option value="Tripura">Tripura</option>
                <option value="Uttar Pradesh">Uttar Pradesh</option>
                <option value="Uttarakhand">Uttarakhand</option>
                <option value="West Bengal">West Bengal</option>
              </select>
            </div>
          </div>

          <input type="hidden" id="EditAddressCountry" value="India">

          <div class="address-modal-actions">
            <button type="submit" class="btn-save">UPDATE</button>
            <button type="button" class="btn-cancel" onclick="closeEditModal()">CANCEL</button>
          </div>
        </form>
      </div>
    </div>

    <script>
      window.addEventListener('load', () => {
        typeof CustomerAddresses !== 'undefined' && new CustomerAddresses();
      });
    </script>
</div>

<script>
  function openAddressModal() {
    document.getElementById('addAddressModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeAddressModal() {
    document.getElementById('addAddressModal').classList.remove('active');
    document.body.style.overflow = 'auto';
  }

  function openEditModal(id, firstName, lastName, phone, address1, address2, city, province, zip, country) {
    document.getElementById('EditAddressId').value = id;
    document.getElementById('EditAddressFirstName').value = firstName || '';
    document.getElementById('EditAddressLastName').value = lastName || '';
    document.getElementById('EditAddressPhone').value = phone || '';
    document.getElementById('EditAddressAddress1').value = address1 || '';
    document.getElementById('EditAddressAddress2').value = address2 || '';
    document.getElementById('EditAddressCity').value = city || '';
    document.getElementById('EditAddressProvince').value = province || '';
    document.getElementById('EditAddressZip').value = zip || '';
    document.getElementById('EditAddressCountry').value = country || 'India';
    
    document.getElementById('editAddressModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeEditModal() {
    document.getElementById('editAddressModal').classList.remove('active');
    document.body.style.overflow = 'auto';
  }

  function deleteAddress(url) {
    if (!confirm('Are you sure you want to delete this address?')) return;

    const form = document.createElement('form');
    form.method = 'POST';

    // 👇 Add return_to as a query param on the action URL
    form.action = url + '?return_to={{ routes.account_url | url_encode }}';
    // If you want a specific tab: '?return_to={{ '/account?tab=addresses' | url_encode }}'

    const methodInput = document.createElement('input');
    methodInput.type = 'hidden';
    methodInput.name = '_method';
    methodInput.value = 'delete';
    form.appendChild(methodInput);

    document.body.appendChild(form);
    form.submit();
  }

  document.getElementById('addAddressModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeAddressModal();
    }
  });

  document.getElementById('editAddressModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeEditModal();
    }
  });

  // Handle Edit Address Form Submission
  document.getElementById('editAddressForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    const customerId = document.getElementById('customer_id').value;
    const addressId = document.getElementById('EditAddressId').value;

    const data = {
      customer_id: customerId,
      address_id: addressId,
      first_name: document.getElementById('EditAddressFirstName').value,
      last_name: document.getElementById('EditAddressLastName').value,
      phone: document.getElementById('EditAddressPhone').value,
      address1: document.getElementById('EditAddressAddress1').value,
      address2: document.getElementById('EditAddressAddress2').value,
      city: document.getElementById('EditAddressCity').value,
      province: document.getElementById('EditAddressProvince').value,
      country: document.getElementById('EditAddressCountry').value,
      zip: document.getElementById('EditAddressZip').value
    };

    try {
      const response = await fetch("https://user-address-edit-385594025448.asia-south1.run.app", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
      });

      const result = await response.json();

      if (response.ok) {
        alert("✅ Address updated successfully.");
        closeEditModal();
        location.reload(); // Reload to show updated address
      } else {
        alert("❌ Failed to update address: " + (result.message || "Unknown error"));
        console.error(result);
      }
    } catch (err) {
      alert("⚠️ Network error. Please try again.");
      console.error(err);
    }
  });

  window.addEventListener('load', () => {
    typeof CustomerAddresses !== 'undefined' && new CustomerAddresses();
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const countrySelect = document.getElementById('AddressCountryNew');
    if (countrySelect && !countrySelect.value) {
      countrySelect.value = 'India';
    }
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const editBtn = document.getElementById("edit-btn");
    const cancelBtn = document.getElementById("cancel-btn");
    const saveBtn = document.getElementById("save-button");
    const inputs = document.querySelectorAll("#first_name, #last_name, #email, #phone");
    const emailError = document.querySelector(".email-error");
    const originalValues = {};
  
    // Store original values
    inputs.forEach(input => {
      originalValues[input.id] = input.value;
    });
  
    editBtn.addEventListener("click", () => {
      inputs.forEach((input) => input.removeAttribute("disabled"));
      saveBtn.removeAttribute("disabled");
      cancelBtn.style.display = "inline-flex";
      editBtn.style.display = "none";
    });
  
    cancelBtn.addEventListener("click", () => {
      // Reset to original values
      inputs.forEach(input => {
        input.value = originalValues[input.id];
        input.setAttribute("disabled", "true");
      });
      saveBtn.setAttribute("disabled", "true");
      cancelBtn.style.display = "none";
      editBtn.style.display = "inline-flex";
      emailError.style.display = "none";
    });
  
    document.getElementById("customer-info-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      emailError.style.display = "none";
  
      // Validate email format
      const email = document.getElementById("email").value;
      if (!validateEmail(email)) {
        emailError.textContent = "Please enter a valid email address";
        emailError.style.display = "block";
        return;
      }
  
      const data = {
        id: document.getElementById("customer_id").value,
        first_name: document.getElementById("first_name").value,
        last_name: document.getElementById("last_name").value,
        email: email,
        phone: document.getElementById("phone").value
      };
  
      try {
        const res = await fetch("https://user-edit-385594025448.asia-south1.run.app/", {
          method: "PUT",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify(data)
        });
  
        const result = await res.json();
  
        if (res.ok) {
          alert("✅ Customer information updated successfully.");
          // Update original values with new ones
          inputs.forEach(input => {
            originalValues[input.id] = input.value;
            input.setAttribute("disabled", "true");
          });
          saveBtn.setAttribute("disabled", "true");
          cancelBtn.style.display = "none";
          editBtn.style.display = "inline-block";
        } else {
          // Handle Shopify-specific email errors
          if (result.errors && result.errors.email) {
            emailError.textContent = result.errors.email.join(', ');
            emailError.style.display = "block";
          } else {
            alert("❌ Error updating customer: " + (result.message || "Unknown error"));
          }
          console.error("Update error:", result);
        }
      } catch (err) {
        alert("⚠️ Network error. Please try again.");
        console.error("Network error:", err);
      }
    });
  
    function validateEmail(email) {
      const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return re.test(email);
    }
  });
</script>