{{ 'customer.css' | asset_url | stylesheet_tag: preload: true }}
<script src="{{ 'customer.js' | asset_url }}" defer></script>

<div class="customer-personal-tabs-wrapper">
    <input type="radio" name="personal-tab" id="tab-info" hidden checked>
    <input type="radio" name="personal-tab" id="tab-addresses" hidden>

    <div class="customer-personal-tab-buttons">
      <label for="tab-info">Personal Information</label>
      <label for="tab-addresses">Manage Addresses</label>
    </div>

    <form class="customer-personal-tab-content customer-tab-info" id="customer-info-form">
      <input type="hidden" id="customer_id" value="{{ customer.id }}">
    
      <div class="personal-info-heading-wrapper">
        <h2>PERSONAL INFORMATION</h2>
        <button type="button" class="customer-edit-btn" id="edit-btn">Edit</button>
        <button type="button" class="customer-cancel-btn" id="cancel-btn" style="display: none;">Cancel</button>
      </div>
    
      <div class="customer-form-row">
        <div class="customer-form-group">
          <label>First Name</label>
          <input type="text" id="first_name" value="{{ customer.first_name }}" disabled>
        </div>
        <div class="customer-form-group">
          <label>Last Name</label>
          <input type="text" id="last_name" value="{{ customer.last_name }}" disabled>
        </div>
      </div>
      
      <div class="customer-form-group">
        <label>Mobile Number</label>
        <input type="text" id="phone" value="{{ customer.phone | default: '' }}" disabled>
      </div>
      
      <div class="customer-form-group email-group">
        <label>Email</label>
        <input type="email" id="email" value="{{ customer.email }}" disabled>
        <div class="email-error" style="color: red; display: none;"></div>
      </div>

      <div class="customer-form-row">
        <div class="customer-form-group">
          <label>Date of Birth</label>
          <input
            type="date"
            id="dob"
            value="{{ customer.metafields.custom.date_of_birth.value | default: '' }}"
            disabled
          >
        </div>

        <div class="customer-form-group">
          <label>Date of Anniversary</label>
          <input
            type="date"
            id="doa"
            value="{{ customer.metafields.custom.date_of_anniversary.value | default: '' }}"
            disabled
          >
        </div>
      </div>
    
      <button class="save-button" id="save-button" type="submit" disabled>SAVE</button>
    </form>

    <div class="customer-addresses-wrapper">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0; margin-top: 20px;">
        <h2 style="margin: 0; font-size: 20px;">ADDRESSES</h2>
        <button class="add-address-btn" onclick="openAddressModal()">+ Add New Address</button>
      </div>

      {%- paginate customer.addresses by 10 -%}
