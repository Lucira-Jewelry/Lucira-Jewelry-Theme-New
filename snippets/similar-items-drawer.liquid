{% layout none %}

{% comment %}
  This template is ONLY loaded via AJAX when the button is clicked.
  Product is accessed via the URL: /products/{handle}?view=similar-items
{% endcomment %}

{% if product.metafields.custom.matching_product != blank %}
  {% assign matching_products = product.metafields.custom.matching_product.value %}
  
  {% comment %} Early exit if no products {% endcomment %}
  {% assign product_count = matching_products.size %}
  
  {% if product_count > 0 %}
    <div class="similar-items-drawer__header">
      <h2 class="similar-items-drawer__title" id="similar-items-title">View Similar</h2>
      <button 
        type="button" 
        class="similar-items-drawer__close" 
        aria-label="Close similar items drawer"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
    
    <div class="similar-items-drawer__content">
      <div class="similar-items-grid">
        {% for similar_product in matching_products limit: 10 %}
          <div class="similar-items-grid__item">
            {% comment %} {% render 'card-product', 
              card_product: similar_product,
              show_vendor: false,
              show_rating: true,
              show_secondary_image: false,
              media_aspect_ratio: 'portrait',
              lazy_load: true
            %} {% endcomment %}
              <!-- In your similar items drawer/modal -->
          {%- for product in similar_products -%}
            {%- render 'card-product-similar',
              card_product: product,
              show_secondary_image: true,
              show_rating: true
            -%}
          {%- endfor -%}
          </div>
        {% endfor %}
      </div>
    </div>
  {% else %}
    <div class="similar-items-drawer__empty">
      <p>No similar items found.</p>
    </div>
  {% endif %}
{% else %}
  <div class="similar-items-drawer__empty">
    <p>No similar items available.</p>
  </div>
{% endif %}