
<style>

    .view-details {
    display: inline-flex;
    } 

  .charm-drawer {
    position: fixed;
    inset: 0;
    z-index: 4;
    pointer-events: none;
  }

  .charm-drawer.is-open {
    pointer-events: auto;
  }

  .charm-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, .55);
    backdrop-filter: blur(3px);
    opacity: 0;
    transition: opacity .35s ease;
  }

  .charm-drawer.is-open .charm-drawer__overlay {
    opacity: 1;
  }

 .charm-drawer__panel {
  position: absolute;
  top: 0;
  right: 0;
  height: 100%;
  width: min( 25vw);
  background: #fff;
  transform: translateX(100%);
  transition: transform .35s cubic-bezier(.28, .68, .4, 1);
  display: flex;
  flex-direction: column;
  box-shadow: -32px 0 60px rgba(0, 0, 0, .22);
}

.charm-drawer.is-open .charm-drawer__panel {
  transform: translateX(0);
}


  .charm-drawer__close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 36px;
    height: 36px;
   background: #fff;
   border:none;
    cursor: pointer;
    font-size: 28px;
  }

  #charm-details-drawer {
    background: transparent;
    transition: background .28s ease;
  }

  #charm-details-drawer.is-open {
    background: #1a1a1a66;
  }
.charm-drawer__body {
    overflow: auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
    height: 100%;
  }
.charm-drawer__content{
padding: 20px 10px;
    padding-bottom: 60px;
}
  .charm-drawer__image-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .charm-drawer__image-wrap img {
    width: 50%;
    height: auto;
    display: block;
  }

  .charm-drawer__content h3 {
    font-size: 32px;
    /* font-weight:650; */
    margin: 40px 0 24px;
  }

  .charm-drawer__content p {
    color: #444;
    font-size: 16px;
    line-height: 1.55;
    margin: 24px 0 14px;
  }
  @media (max-width: 768px){

    .charms-grid {
      max-width: 200vw;
      display: flex !important;
      gap: 12px;
      padding: 12px;
      overflow-x: auto;
    }

    .charm-thumb-wrap {
      height: unset;
    }
    .charm-drawer__panel {
    top: 70px;
        width: 90%;
        height: 93%;

}

  }
  @media screen and (min-width:900px) and (max-width:1600px){
.charm-drawer__image-wrap{
    width:300px;
    height:auto;
}
.charm-drawer__content h3 {
    font-size: 24px;
}
}
  .charm-drawer__specs {
    margin-top: 30px;
    border-top: 1px solid #f0f0f0;
    padding-top: 20px;
  }
  .spec-item {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    font-size: 15px;
    color: #1a1a1a;
  }
  .spec-label {
    color: #666;
  }
  .spec-value {
    font-weight: 500;
  }
</style>


<div id="charm-details-drawer" class="charm-drawer" aria-hidden="true">
  <div class="charm-drawer__overlay" data-close-drawer></div>

  <div class="charm-drawer__panel">
    <button class="charm-drawer__close" type="button" data-close-drawer>✕</button>

    <div class="charm-drawer__body">
      <div class="charm-drawer__image-wrap">
        <img id="drawer-charm-image" src="" alt="" width="auto" height="auto" loading="lazy">
      </div>

      <div class="charm-drawer__content">
       
        
        <div id="drawer-product-desc-wrap" style="display:none;">
          <div id="drawer-product-desc" style="font-size: 14px; color: #666; line-height: 1.6; margin-top: 10px;"></div>
        </div>

        <div class="charm-drawer__specs" id="drawer-specs-wrap" style="display:none;">
          <div class="spec-item"><span class="spec-label">Gold Purity :</span><span class="spec-value" id="spec-gold-purity">-</span></div>
          <div class="spec-item"><span class="spec-label">Gold Weight (Net) :</span><span class="spec-value" id="spec-gold-weight">-</span></div>
          <div class="spec-item"><span class="spec-label">Diamond Weight :</span><span class="spec-value" id="spec-diamond-weight">-</span></div>
          <div class="spec-item"><span class="spec-label">Diamond Quantity :</span><span class="spec-value" id="spec-diamond-qty">-</span></div>
          <div class="spec-item"><span class="spec-label">Pendant Weight (Gross) :</span><span class="spec-value" id="spec-gross-weight">-</span></div>
        </div>

        <button class="drawer-cta" data-close-drawer>CONTINUE SHOPPING</button>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const d = document.getElementById('charm-details-drawer');
    if (!d) return;

    const overlay = d.querySelector('.charm-drawer__overlay');
    const panel = d.querySelector('.charm-drawer__panel');
    const img = d.querySelector('#drawer-charm-image');
    const title = d.querySelector('#drawer-charm-title');
    const desc = d.querySelector('#drawer-charm-desc');
    let lastFocus;

    const getMeta = (id) => {
      const el = document.getElementById('variant-meta-' + id);
      if (!el) return null;
      try {
        return JSON.parse(el.textContent);
      } catch {
        return null;
      }
    };

    const open = (m) => {
      console.log('Charm Drawer: Opening with metadata:', m);
      if (!m) return;
      if (img) {
        img.src = m.image || '';
        img.alt = m.heading || '';
      }
      if (title) title.textContent = m.heading || '';
      if (desc) desc.textContent = m.description || '';

      // Product Description
      const prodDescWrap = document.getElementById('drawer-product-desc-wrap');
      const prodDesc = document.getElementById('drawer-product-desc');
      if (prodDesc && m.product_description) {
        prodDesc.innerHTML = m.product_description;
        prodDescWrap.style.display = 'block';
      } else if (prodDescWrap) {
        prodDescWrap.style.display = 'none';
      }

      // Specifications calculation
      const specsWrap = document.getElementById('drawer-specs-wrap');
      if (specsWrap) {
        // Handle different JSON structures: either { components: [...] } or just [...]
        let comps = null;
        if (m.components) {
          if (Array.isArray(m.components)) {
             comps = m.components;
          } else if (m.components.components && Array.isArray(m.components.components)) {
             comps = m.components.components;
          }
        }

        if (comps && comps.length > 0) {
          console.log('Charm Drawer: Calculating specs from', comps.length, 'components');
          specsWrap.style.display = 'block';
          
          // Gold Purity (Variant Name)
          document.getElementById('spec-gold-purity').textContent = m.heading || '-';
          
          let goldWeight = 0;
          let diamondWeight = 0;
          let diamondQty = 0;
          let grossWeight = 0;
          let goldFound = false;
          
          comps.forEach((c) => {
            const w = parseFloat(c.weight) || 0;
            const p = parseInt(c.pieces) || 0;
            
            grossWeight += w;
            
            if (p === 0) {
              // 1st item with 0 pieces is Gold
              if (!goldFound) {
                goldWeight = w;
                goldFound = true;
              }
            } else if (p > 0) {
              // Items with pieces > 0 are Diamonds/Stones
              diamondWeight += w;
              diamondQty += p;
            }
          });
          
          document.getElementById('spec-gold-weight').textContent = goldWeight.toFixed(2) + ' gm';
          document.getElementById('spec-diamond-weight').textContent = diamondWeight.toFixed(3) + ' gm';
          document.getElementById('spec-diamond-qty').textContent = diamondQty + ' units';
          document.getElementById('spec-gross-weight').textContent = grossWeight.toFixed(2) + ' gm';
        } else {
          console.warn('Charm Drawer: No components array found in', m.components);
          specsWrap.style.display = 'none';
        }
      }

      lastFocus = document.activeElement;
      document.body.style.overflow = 'hidden';
      d.classList.add('is-open');
      d.setAttribute('aria-hidden', 'false');
      setTimeout(() => panel?.focus(), 0);
    };

    const close = () => {
      d.classList.remove('is-open');
      d.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      lastFocus?.focus?.();
    };

    document.addEventListener(
      'click',
      (e) => {
        const btn = e.target.closest('.view-details');
        if (!btn) return;
        e.preventDefault();
        open(getMeta(btn.dataset.variantId) || {});
      },
      { passive: false }
    );

    d.addEventListener('click', (e) => {
      if (e.target.closest('[data-close-drawer]')) close();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  })();
</script>