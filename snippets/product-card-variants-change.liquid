<script>
    (function () {
      "use strict";
    
      // Enhanced auto-selection function to detect color from image and select correct variant
      function autoSelectVariantFromImage() {
        document
          .querySelectorAll('[id^="product-image-"]')
          .forEach((productImage) => {
            const productId = productImage.id.replace("product-image-", "");
            const currentSrc = productImage.getAttribute("src");
            const currentAlt = productImage.getAttribute("alt") || "";
    
            if (currentSrc && productId) {
              const swatches = document.querySelectorAll(
                '.color-option[data-product-id="' + productId + '"]'
              );
    
              // First, clear all active states
              swatches.forEach((swatch) => swatch.classList.remove("active"));
    
              // Try to detect color from image alt text or filename
              let detectedColor = detectColorFromImage(currentSrc, currentAlt);
    
              // If we detected a color, find the matching swatch
              if (detectedColor) {
                const matchingSwatch = Array.from(swatches).find((swatch) => {
                  const swatchColor = swatch.getAttribute("data-color");
                  return (
                    swatchColor &&
                    swatchColor.toLowerCase() === detectedColor.toLowerCase()
                  );
                });
    
                if (matchingSwatch) {
                  matchingSwatch.classList.add("active");
                  {% comment %} console.log(
                    "Auto-selected variant:",
                    detectedColor,
                    "for product:",
                    productId
                  ); {% endcomment %}
                  return;
                }
              }
    
              // Fallback: try exact image matching (existing logic)
              let foundMatch = false;
              swatches.forEach((btn) => {
                if (foundMatch) return;
    
                const swatchSrc = btn.getAttribute("data-image-src");
                if (swatchSrc && currentSrc.includes(swatchSrc.split("?")[0])) {
                  btn.classList.add("active");
                  foundMatch = true;
                  console.log(
                    "Auto-selected variant by image match for product:",
                    productId
                  );
                }
              });
    
              // Final fallback: select first available swatch if none matched
              if (!foundMatch && swatches.length > 0) {
                swatches[0].classList.add("active");
                console.log(
                  "Auto-selected first variant as fallback for product:",
                  productId
                );
              }
            }
          });
      }
    
      // Function to detect color from image source or alt text
      function detectColorFromImage(imageSrc, imageAlt) {
        const colorKeywords = {
          "yellow gold": ["yellow", "gold", "yg"],
          "rose gold": ["rose", "pink", "rg"],
          "white gold": ["white", "wg"],
          platinum: ["platinum", "pt", "plat"],
        };
    
        // Combine image source and alt text for analysis
        const searchText = (imageSrc + " " + imageAlt).toLowerCase();
    
        // Check for color keywords in order of specificity
        for (const [color, keywords] of Object.entries(colorKeywords)) {
          for (const keyword of keywords) {
            if (searchText.includes(keyword)) {
              // Return the properly formatted color name
              return color
                .split(" ")
                .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
                .join(" ");
            }
          }
        }
    
        // Try to detect from filename patterns
        const filename = imageSrc.split("/").pop().toLowerCase();
    
        // Common filename patterns
        if (
          filename.includes("yellow") ||
          filename.includes("_yg_") ||
          filename.includes("-yg-")
        ) {
          return "Yellow Gold";
        }
        if (
          filename.includes("rose") ||
          filename.includes("pink") ||
          filename.includes("_rg_") ||
          filename.includes("-rg-")
        ) {
          return "Rose Gold";
        }
        if (
          filename.includes("white") ||
          filename.includes("_wg_") ||
          filename.includes("-wg-")
        ) {
          return "White Gold";
        }
        if (
          filename.includes("platinum") ||
          filename.includes("_pt_") ||
          filename.includes("-pt-")
        ) {
          return "Platinum";
        }
    
        return null;
      }
    
      function initializeProductImageSwitch() {
        // Handle color variant clicks
        const colorOptions = document.querySelectorAll(
          ".color-option:not([data-initialized])"
        );
    
        colorOptions.forEach(function (button) {
          // Mark as initialized to prevent duplicate listeners
          button.setAttribute("data-initialized", "true");
    
          button.addEventListener("click", function (e) {
            e.preventDefault();
            e.stopPropagation();
    
            const productId = this.getAttribute("data-product-id");
            const variantId = this.getAttribute("data-variant-id");
            const imageSrc = this.getAttribute("data-image-src");
            const imageAlt = this.getAttribute("data-image-alt") || "";
    
            console.log("Color option clicked:", {
              productId: productId,
              variantId: variantId,
              imageSrc: imageSrc,
              imageAlt: imageAlt,
            });
    
            if (!productId) {
              console.warn("Missing product ID");
              return;
            }
    
            // Remove active class from all color options for this product
            const productContainer =
              this.closest(".color-variants-options") ||
              this.closest('[data-product-id="' + productId + '"]') ||
              this.parentElement;
    
            if (productContainer) {
              const allColorOptions = productContainer.querySelectorAll(
                '.color-option[data-product-id="' + productId + '"]'
              );
              allColorOptions.forEach(function (btn) {
                btn.classList.remove("active");
              });
            }
    
            // Add active class to clicked button
            this.classList.add("active");
    
            // Get product media data
            const mediaData = getProductMediaData(productId);
            let primaryImage = null;
            let secondaryImage = null;
    
            if (imageAlt && mediaData && mediaData.media) {
              // Find images for this variant by alt text (exclude videos)
              const variantImages = mediaData.media.filter(function (media) {
                // Skip if it's a video or doesn't match our alt text
                if (media.media_type === 'video') return false;
                return (
                  media.media_type === "image" &&
                  media.alt &&
                  media.alt.toLowerCase().includes(imageAlt.toLowerCase())
                );
              });
    
              console.log("Found variant images:", variantImages);
    
              if (variantImages.length > 0) {
                primaryImage = variantImages[0]; // First image as primary
                
                // Only use the second image if it exists and is not a video
                if (variantImages.length > 1) {
                  secondaryImage = variantImages[1];
                }
              }
            }
    
            // Fallback to provided image src if no variant images found
            if (!primaryImage && imageSrc) {
              primaryImage = {
                src: imageSrc,
                alt: imageAlt,
              };
            }
    
            // Update the primary product image
            const productImage = document.getElementById(
              "product-image-" + productId
            );
            if (productImage && primaryImage) {
              console.log("Updating primary image:", primaryImage.src);
    
              // Add loading state
              productImage.style.opacity = "0.7";
              productImage.style.transition = "opacity 0.3s ease";
    
              // Create a new image to preload
              const newImage = new Image();
              newImage.onload = function () {
                // Update the src and alt
                productImage.src = primaryImage.src;
                productImage.alt = primaryImage.alt || "";
                productImage.setAttribute("data-current-variant", imageAlt);
    
                // Update srcset if needed
                if (primaryImage.src.includes("width=")) {
                  const baseUrl = primaryImage.src.split("?")[0];
                  const newSrcset = [
                    baseUrl + "?width=165 165w",
                    baseUrl + "?width=360 360w",
                    baseUrl + "?width=533 533w",
                    baseUrl + "?width=720 720w",
                    baseUrl + "?width=940 940w",
                    baseUrl + "?width=1066 1066w",
                  ].join(", ");
                  productImage.srcset = newSrcset;
                }
    
                // Restore opacity
                productImage.style.opacity = "1";
    
                console.log("Primary image updated successfully");
              };
    
              newImage.onerror = function () {
                console.error("Failed to load primary image:", primaryImage.src);
                productImage.style.opacity = "1";
              };
    
              newImage.src = primaryImage.src;
            }
    
            // Update the secondary image (for hover effect)
            const secondaryImageEl = document.getElementById(
              "product-image-secondary-" + productId
            );
            if (secondaryImageEl) {
              if (secondaryImage) {
                console.log("Updating secondary image:", secondaryImage.src);
    
                const newSecondaryImage = new Image();
                newSecondaryImage.onload = function () {
                  secondaryImageEl.src = secondaryImage.src;
                  secondaryImageEl.alt = secondaryImage.alt || "";
    
                  // Update srcset
                  if (secondaryImage.src.includes("width=")) {
                    const baseUrl = secondaryImage.src.split("?")[0];
                    const newSrcset = [
                      baseUrl + "?width=165 165w",
                      baseUrl + "?width=360 360w",
                      baseUrl + "?width=533 533w",
                      baseUrl + "?width=720 720w",
                      baseUrl + "?width=940 940w",
                      baseUrl + "?width=1066 1066w",
                    ].join(", ");
                    secondaryImageEl.srcset = newSrcset;
                  }
    
                  console.log("Secondary image updated successfully");
                };
    
                newSecondaryImage.onerror = function () {
                  console.error(
                    "Failed to load secondary image:",
                    secondaryImage.src
                  );
                };
    
                newSecondaryImage.src = secondaryImage.src;
              } else {
                // Hide secondary image if no second image for this variant
                secondaryImageEl.style.opacity = "0";
              }
            }
    
            // Update any hidden form inputs
            const variantInput =
              document.querySelector(
                'input[name="id"][data-product-id="' + productId + '"]'
              ) || document.querySelector('input[name="id"]');
            if (variantInput && variantId) {
              variantInput.value = variantId;
              console.log("Updated variant input:", variantId);
            }
    
            // Trigger custom event
            try {
              const event = new CustomEvent("variant:changed", {
                detail: {
                  productId: productId,
                  variantId: variantId,
                  primaryImage: primaryImage,
                  secondaryImage: secondaryImage,
                },
              });
              document.dispatchEvent(event);
            } catch (error) {
              console.warn("CustomEvent not supported");
            }
          });
        });
    
        {% comment %} console.log(
          "Product image switch initialized for",
          colorOptions.length,
          "new color options"
        ); {% endcomment %}
    
        // Run the enhanced auto-selection after initializing event listeners
        autoSelectVariantFromImage();
      }
    
      function initializeVideoIcons() {
        document
          .querySelectorAll(".product-video-icon-wrapper:not([data-initialized])")
          .forEach((icon) => {
            // Mark as initialized to prevent duplicate listeners
            icon.setAttribute("data-initialized", "true");
    
            icon.addEventListener("click", function (e) {
              e.preventDefault();
              e.stopPropagation();
    
              const productHandle = this.getAttribute("data-product-handle");
              const videoId = this.getAttribute("data-video-id");
    
              console.log("Video icon clicked:", {
                productHandle: productHandle,
                videoId: videoId,
              });
    
              // Find the product modal if it exists
              const modal = document.querySelector(
                `#ProductModal-${productHandle}`
              );
    
              if (modal) {
                // Find the video media item and click it to open
                const videoButton = modal.querySelector(
                  `[data-media-id="${videoId}"]`
                );
                if (videoButton) {
                  videoButton.click();
                }
              } else {
                // If modal doesn't exist, navigate to product page
                window.location.href = `/products/${productHandle}?view=video`;
              }
            });
          });
    
        {% comment %} console.log(
          "Video icons initialized for",
          document.querySelectorAll(".product-video-icon-wrapper[data-initialized]")
            .length,
          "icons"
        ); {% endcomment %}
      }
    
      // Function to get product media data from the hidden script tag
      function getProductMediaData(productId) {
        const mediaScript = document.querySelector(
          '.product-media-data[data-product-id="' + productId + '"]'
        );
        if (!mediaScript) {
          console.warn("No media data script found for product:", productId);
          return null;
        }
    
        try {
          // First sanitize the JSON string
          let jsonString = mediaScript.textContent
            .replace(/[\u0000-\u001F\u007F-\u009F]/g, "") // Remove control characters
            .trim();
    
          // Handle common Shopify JSON issues
          jsonString = jsonString
            .replace(/([{,]\s*)([a-zA-Z0-9_]+)(\s*:)/g, '$1"$2"$3') // Ensure property names are quoted
            .replace(/'/g, '"'); // Replace single quotes with double quotes
    
          return JSON.parse(jsonString);
        } catch (e) {
          console.error(
            "Failed to parse product media data for product:",
            productId,
            "Error:",
            e
          );
          console.error("Problematic JSON content:", mediaScript.textContent);
          return null;
        }
      }
    
      // Main initialization function
      function initializeAll() {
        {% comment %} console.log("Initializing all product functionality..."); {% endcomment %}
        initializeProductImageSwitch();
        initializeVideoIcons();
      }
    
      // Initialize when DOM is ready
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initializeAll);
      } else {
        initializeAll();
      }
    
      // Also initialize on page load as fallback
      window.addEventListener("load", function () {
        setTimeout(initializeAll, 100);
      });
    
      // MutationObserver to watch for new product cards added to DOM
      const observer = new MutationObserver(function (mutations) {
        let shouldReinitialize = false;
    
        mutations.forEach(function (mutation) {
          // Check if new nodes were added
          mutation.addedNodes.forEach(function (node) {
            if (node.nodeType === 1) {
              // Element node
              // Check if the added node contains product cards or is a product card itself
              if (
                node.matches &&
                (node.matches(".product-card-wrapper") ||
                  node.matches(".card-wrapper") ||
                  node.matches(".color-option") ||
                  node.matches(".product-video-icon-wrapper") ||
                  node.querySelector(".color-option") ||
                  node.querySelector(".product-video-icon-wrapper") ||
                  node.querySelector(".product-card-wrapper") ||
                  node.querySelector(".card-wrapper"))
              ) {
                shouldReinitialize = true;
              }
            }
          });
        });
    
        if (shouldReinitialize) {
          console.log("New product content detected, reinitializing...");
          // Small delay to ensure DOM is fully updated
          setTimeout(initializeAll, 50);
        }
      });
    
      // Start observing the document for changes
      observer.observe(document.body, {
        childList: true,
        subtree: true,
      });
    
      // Listen for common AJAX events that might indicate new content
      document.addEventListener("ajaxComplete", function () {
        console.log("AJAX complete detected, reinitializing...");
        setTimeout(initializeAll, 100);
      });
    
      // Listen for Shopify section reloads
      document.addEventListener("shopify:section:load", function () {
        console.log("Shopify section loaded, reinitializing...");
        setTimeout(initializeAll, 100);
      });
    
      // Listen for jQuery AJAX events if jQuery is available
      if (typeof jQuery !== "undefined") {
        jQuery(document).ajaxComplete(function () {
          console.log("jQuery AJAX complete detected, reinitializing...");
          setTimeout(initializeAll, 100);
        });
      }
    
      // Custom event for manual triggering if needed
      document.addEventListener("product-cards:refresh", function () {
        console.log("Manual refresh triggered, reinitializing...");
        initializeAll();
      });
    
      // Listen for filter/sort events (common event names)
      document.addEventListener("collection:updated", function () {
        console.log("Collection updated, reinitializing...");
        setTimeout(initializeAll, 100);
      });
    
      document.addEventListener("products:loaded", function () {
        console.log("Products loaded, reinitializing...");
        setTimeout(initializeAll, 100);
      });
    
      // Expose global function for manual triggering
      window.reinitializeProductCards = initializeAll;
    
      console.log("Product card functionality script loaded and initialized");
    })();
</script>