{% doc %}
  @prompt
    video slider on left side as in image design and subtitle, heading and paragraph in right in mobile column
    
    exact as image
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-slider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-video-slider-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.gap }}px;
    align-items: center;
  }

  .ai-video-slider-left-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-video-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.video_border_radius }}px;
  }

  .ai-video-slider-slides-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-video-slider-slide-{{ ai_gen_id }} {
    min-width: 100%;
    position: relative;
  }

  .ai-video-slider-slide-{{ ai_gen_id }} video {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.video_border_radius }}px;
  }

  .ai-video-slider-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.video_border_radius }}px;
  }

  .ai-video-slider-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-video-slider-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 20px;
  }

  .ai-video-slider-nav-{{ ai_gen_id }} {
    background-color: {{ block.settings.nav_button_color }};
    color: {{ block.settings.nav_button_icon_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-video-slider-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_color }};
  }

  .ai-video-slider-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-video-slider-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .ai-video-slider-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-video-slider-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-video-slider-right-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-video-slider-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-video-slider-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  .ai-video-slider-paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.paragraph_size }}px;
    color: {{ block.settings.paragraph_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-video-slider-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-video-slider-right-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_content_padding }}px;
    }

    .ai-video-slider-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-video-slider-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-video-slider-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.paragraph_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<section class="page-width">
<video-slider-{{ ai_gen_id }} class="ai-video-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-slider-container-{{ ai_gen_id }}">
    <div class="ai-video-slider-left-{{ ai_gen_id }}">
      <div class="ai-video-slider-wrapper-{{ ai_gen_id }}">
        <div class="ai-video-slider-slides-{{ ai_gen_id }}">
          {% if block.settings.video_1 != blank %}
            <div class="ai-video-slider-slide-{{ ai_gen_id }}">
              {{
                block.settings.video_1
                | video_tag:
                  autoplay: block.settings.autoplay,
                  loop: block.settings.loop,
                  muted: block.settings.muted,
                  controls: block.settings.controls
              }}
            </div>
          {% else %}
            <div class="ai-video-slider-slide-{{ ai_gen_id }}">
              <div class="ai-video-slider-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            </div>
          {% endif %}

          {% if block.settings.video_2 != blank %}
            <div class="ai-video-slider-slide-{{ ai_gen_id }}">
              {{
                block.settings.video_2
                | video_tag:
                  autoplay: block.settings.autoplay,
                  loop: block.settings.loop,
                  muted: block.settings.muted,
                  controls: block.settings.controls
              }}
            </div>
          {% endif %}

          {% if block.settings.video_3 != blank %}
            <div class="ai-video-slider-slide-{{ ai_gen_id }}">
              {{
                block.settings.video_3
                | video_tag:
                  autoplay: block.settings.autoplay,
                  loop: block.settings.loop,
                  muted: block.settings.muted,
                  controls: block.settings.controls
              }}
            </div>
          {% endif %}
        </div>
      </div>

      {% assign total_videos = 0 %}
      {% if block.settings.video_1 != blank %}
        {% assign total_videos = total_videos | plus: 1 %}
      {% endif %}
      {% if block.settings.video_2 != blank %}
        {% assign total_videos = total_videos | plus: 1 %}
      {% endif %}
      {% if block.settings.video_3 != blank %}
        {% assign total_videos = total_videos | plus: 1 %}
      {% endif %}

      {% if total_videos > 1 %}
        <div class="ai-video-slider-controls-{{ ai_gen_id }}">
          <button class="ai-video-slider-nav-{{ ai_gen_id }} ai-video-slider-prev-{{ ai_gen_id }}" aria-label="Previous video">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>

          <div class="ai-video-slider-dots-{{ ai_gen_id }}">
            {% for i in (1..total_videos) %}
              <button
                class="ai-video-slider-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
                data-index="{{ forloop.index0 }}"
                aria-label="Go to video {{ forloop.index }}"
              ></button>
            {% endfor %}
          </div>

          <button class="ai-video-slider-nav-{{ ai_gen_id }} ai-video-slider-next-{{ ai_gen_id }}" aria-label="Next video">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      {% endif %}
    </div>

    <div class="ai-video-slider-right-{{ ai_gen_id }}">
      {% if block.settings.subtitle != blank %}
        <div class="ai-video-slider-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-video-slider-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.paragraph != blank %}
        <div class="ai-video-slider-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</div>
      {% endif %}
    </div>
  </div>
</video-slider-{{ ai_gen_id }}>
</section>

<script>
  (function() {
    class VideoSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.totalSlides = 0;
      }

      connectedCallback() {
        this.slidesContainer = this.querySelector('.ai-video-slider-slides-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-video-slider-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-video-slider-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-video-slider-next-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-video-slider-dot-{{ ai_gen_id }}');
        this.totalSlides = this.slides.length;

        if (this.totalSlides <= 1) return;

        this.prevButton.addEventListener('click', () => this.goToPrevious());
        this.nextButton.addEventListener('click', () => this.goToNext());

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.updateSlider();
      }

      goToNext() {
        this.currentIndex = (this.currentIndex + 1) % this.totalSlides;
        this.updateSlider();
      }

      goToPrevious() {
        this.currentIndex = (this.currentIndex - 1 + this.totalSlides) % this.totalSlides;
        this.updateSlider();
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateSlider();
      }

      updateSlider() {
        const offset = -this.currentIndex * 100;
        this.slidesContainer.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });

        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex === this.totalSlides - 1;
      }
    }

    customElements.define('video-slider-{{ ai_gen_id }}', VideoSlider{{ ai_gen_id }});
  })();
</script>

