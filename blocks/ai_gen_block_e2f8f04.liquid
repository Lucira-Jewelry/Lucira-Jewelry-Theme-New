{% doc %}
  @prompt
    video slider on left side as in image design and subtitle, heading and paragraph in right in mobile column
    - Auto-advance to next video on video end
    - Top/bottom padding settings
    - Show products from a specific collection below the slider
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-slider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  /* ── Grid Layout ── */
  .ai-video-slider-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.gap }}px;
    align-items: center;
  }

  /* ── Left: Video ── */
  .ai-video-slider-left-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-video-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.video_border_radius }}px;
  }

  .ai-video-slider-slides-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-video-slider-slide-{{ ai_gen_id }} {
    min-width: 100%;
    position: relative;
  }

  .ai-video-slider-slide-{{ ai_gen_id }} video {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.video_border_radius }}px;
  }

  .ai-video-slider-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.video_border_radius }}px;
  }

  .ai-video-slider-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  /* ── Slider controls ── */
  .ai-video-slider-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 20px;
  }

  .ai-video-slider-nav-{{ ai_gen_id }} {
    background-color: {{ block.settings.nav_button_color }};
    color: {{ block.settings.nav_button_icon_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-video-slider-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_color }};
  }

  .ai-video-slider-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-video-slider-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .ai-video-slider-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-video-slider-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  /* ── Right: Content ── */
  .ai-video-slider-right-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-video-slider-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-video-slider-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  .ai-video-slider-paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.paragraph_size }}px;
    color: {{ block.settings.paragraph_color }};
    line-height: 1.6;
    margin: 0;
  }

  /* ── Products Section ── */
  .ai-video-slider-products-section-{{ ai_gen_id }} {
    margin-top: {{ block.settings.products_section_top_gap }}px;
  }

  .ai-video-slider-products-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.products_heading_size }}px;
    color: {{ block.settings.products_heading_color }};
    margin: 0 0 {{ block.settings.products_heading_bottom_gap }}px 0;
    text-align: {{ block.settings.products_heading_align }};
    line-height: 1.2;
  }

  .ai-video-slider-products-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.products_gap }}px;
  }

  .ai-video-slider-product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
    color: inherit;
  }

  .ai-video-slider-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }

  .ai-video-slider-product-img-wrap-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.product_image_ratio }};
    overflow: hidden;
    background: #f4f4f4;
  }

  .ai-video-slider-product-img-wrap-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .ai-video-slider-product-card-{{ ai_gen_id }}:hover .ai-video-slider-product-img-wrap-{{ ai_gen_id }} img {
    transform: scale(1.05);
  }

  .ai-video-slider-product-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 10px;
    left: 10px;
    background: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: 11px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-video-slider-product-info-{{ ai_gen_id }} {
    padding: {{ block.settings.card_content_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .ai-video-slider-product-vendor-{{ ai_gen_id }} {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: {{ block.settings.product_vendor_color }};
  }

  .ai-video-slider-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0;
    line-height: 1.3;
    font-weight: 600;
  }

  .ai-video-slider-product-price-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .ai-video-slider-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
    font-weight: 600;
  }

  .ai-video-slider-product-compare-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size | minus: 2 }}px;
    color: #999;
    text-decoration: line-through;
  }

  .ai-video-slider-product-btn-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin-top: auto;
    padding: 10px 16px;
    background: {{ block.settings.product_btn_color }};
    color: {{ block.settings.product_btn_text_color }};
    border: none;
    border-radius: {{ block.settings.product_btn_radius }}px;
    font-size: 13px;
    font-weight: 600;
    text-align: center;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.3s ease, opacity 0.3s ease;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .ai-video-slider-product-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.product_btn_hover_color }};
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .ai-video-slider-{{ ai_gen_id }} {
      padding-top: {{ block.settings.mobile_padding_top }}px;
      padding-bottom: {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-video-slider-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-video-slider-right-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_content_padding }}px;
    }

    .ai-video-slider-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-video-slider-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-video-slider-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.paragraph_size | times: 0.9 }}px;
    }

    .ai-video-slider-products-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.mobile_products_per_row }}, 1fr);
      gap: {{ block.settings.products_gap | divided_by: 1.5 | round }}px;
    }

    .ai-video-slider-products-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.products_heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<section class="page-width">
  <video-slider-{{ ai_gen_id }} class="ai-video-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>

    {%- comment -%} ─── VIDEO + CONTENT ROW ─── {%- endcomment -%}
    <div class="ai-video-slider-container-{{ ai_gen_id }}">

      {%- comment -%} LEFT – Video Slider {%- endcomment -%}
      <div class="ai-video-slider-left-{{ ai_gen_id }}">
        <div class="ai-video-slider-wrapper-{{ ai_gen_id }}">
          <div class="ai-video-slider-slides-{{ ai_gen_id }}">

            {% if block.settings.video_1 != blank %}
              <div class="ai-video-slider-slide-{{ ai_gen_id }}">
                {{
                  block.settings.video_1
                  | video_tag:
                    autoplay: block.settings.autoplay,
                    loop: false,
                    muted: block.settings.muted,
                    controls: block.settings.controls
                }}
              </div>
            {% else %}
              <div class="ai-video-slider-slide-{{ ai_gen_id }}">
                <div class="ai-video-slider-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              </div>
            {% endif %}

            {% if block.settings.video_2 != blank %}
              <div class="ai-video-slider-slide-{{ ai_gen_id }}">
                {{
                  block.settings.video_2
                  | video_tag:
                    autoplay: false,
                    loop: false,
                    muted: block.settings.muted,
                    controls: block.settings.controls
                }}
              </div>
            {% endif %}

            {% if block.settings.video_3 != blank %}
              <div class="ai-video-slider-slide-{{ ai_gen_id }}">
                {{
                  block.settings.video_3
                  | video_tag:
                    autoplay: false,
                    loop: false,
                    muted: block.settings.muted,
                    controls: block.settings.controls
                }}
              </div>
            {% endif %}

          </div>
        </div>

        {%- comment -%} Nav controls (dots + prev/next) {%- endcomment -%}
        {% assign total_videos = 0 %}
        {% if block.settings.video_1 != blank %}{% assign total_videos = total_videos | plus: 1 %}{% endif %}
        {% if block.settings.video_2 != blank %}{% assign total_videos = total_videos | plus: 1 %}{% endif %}
        {% if block.settings.video_3 != blank %}{% assign total_videos = total_videos | plus: 1 %}{% endif %}

        {% comment %} {% if total_videos > 1 %}
          <div class="ai-video-slider-controls-{{ ai_gen_id }}">
            <button class="ai-video-slider-nav-{{ ai_gen_id }} ai-video-slider-prev-{{ ai_gen_id }}" aria-label="Previous video">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>

            <div class="ai-video-slider-dots-{{ ai_gen_id }}">
              {% for i in (1..total_videos) %}
                <button
                  class="ai-video-slider-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
                  data-index="{{ forloop.index0 }}"
                  aria-label="Go to video {{ forloop.index }}"
                ></button>
              {% endfor %}
            </div>

            <button class="ai-video-slider-nav-{{ ai_gen_id }} ai-video-slider-next-{{ ai_gen_id }}" aria-label="Next video">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
        {% endif %} {% endcomment %}
      </div>

      {%- comment -%} RIGHT – Text Content {%- endcomment -%}
      <div class="ai-video-slider-right-{{ ai_gen_id }}">
        {% if block.settings.subtitle != blank %}
          <div class="ai-video-slider-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}

        {% if block.settings.heading != blank %}
          <h2 class="ai-video-slider-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.paragraph != blank %}
          <div class="ai-video-slider-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</div>
        {% endif %}
      </div>

    </div>

    {%- comment -%} ─── PRODUCTS FROM COLLECTION ─── {%- endcomment -%}
    {% if block.settings.collection != blank and block.settings.show_collection_products %}
      {% assign product_collection = collections[block.settings.collection] %}
      {% if product_collection != blank %}
        <div class="ai-video-slider-products-section-{{ ai_gen_id }}">

          {% if block.settings.products_heading != blank %}
            <h3 class="ai-video-slider-products-title-{{ ai_gen_id }}">
              {{ block.settings.products_heading }}
            </h3>
          {% endif %}

          <div class="ai-video-slider-products-grid-{{ ai_gen_id }}">
            {% assign product_limit = block.settings.products_to_show %}
            {% for product in product_collection.products limit: product_limit %}
              <a
                href="{{ product.url }}"
                class="ai-video-slider-product-card-{{ ai_gen_id }}"
                aria-label="{{ product.title }}"
              >
                {%- comment -%} Image {%- endcomment -%}
                <div class="ai-video-slider-product-img-wrap-{{ ai_gen_id }}">
                  {% if product.featured_image != blank %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      loading="lazy"
                      width="600"
                      height="{{ 600 | divided_by: product.featured_image.aspect_ratio | round }}"
                    >
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}

                  {%- comment -%} Sale badge {%- endcomment -%}
                  {% if product.compare_at_price > product.price and block.settings.show_sale_badge %}
                    <span class="ai-video-slider-product-badge-{{ ai_gen_id }}">
                      {{ 'products.product.on_sale' | t | default: 'Sale' }}
                    </span>
                  {% endif %}
                </div>

                {%- comment -%} Info {%- endcomment -%}
                <div class="ai-video-slider-product-info-{{ ai_gen_id }}">
                  {% if block.settings.show_vendor and product.vendor != blank %}
                    <div class="ai-video-slider-product-vendor-{{ ai_gen_id }}">{{ product.vendor }}</div>
                  {% endif %}

                  <h4 class="ai-video-slider-product-title-{{ ai_gen_id }}">{{ product.title }}</h4>

                  <div class="ai-video-slider-product-price-row-{{ ai_gen_id }}">
                    <span class="ai-video-slider-product-price-{{ ai_gen_id }}">
                      {{ product.price | money }}
                    </span>
                    {% if product.compare_at_price > product.price %}
                      <span class="ai-video-slider-product-compare-{{ ai_gen_id }}">
                        {{ product.compare_at_price | money }}
                      </span>
                    {% endif %}
                  </div>

                  {% if block.settings.show_add_to_cart %}
                    {% if product.available %}
                      <button
                        class="ai-video-slider-product-btn-{{ ai_gen_id }}"
                        data-product-id="{{ product.variants.first.id }}"
                        onclick="
                          event.preventDefault();
                          fetch('/cart/add.js', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ id: {{ product.variants.first.id }}, quantity: 1 })
                          }).then(() => { window.location.href = '/cart'; });
                        "
                      >
                        {{ block.settings.add_to_cart_text | default: 'Add to Cart' }}
                      </button>
                    {% else %}
                      <span class="ai-video-slider-product-btn-{{ ai_gen_id }}" style="opacity:0.55;cursor:not-allowed;">
                        {{ 'products.product.sold_out' | t | default: 'Sold Out' }}
                      </span>
                    {% endif %}
                  {% endif %}
                </div>
              </a>
            {% endfor %}
          </div>

        </div>
      {% endif %}
    {% endif %}

  </video-slider-{{ ai_gen_id }}>
</section>

<script>
  (function () {
    class VideoSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.totalSlides = 0;
      }

      connectedCallback() {
        this.slidesContainer = this.querySelector('.ai-video-slider-slides-{{ ai_gen_id }}');
        this.slides          = this.querySelectorAll('.ai-video-slider-slide-{{ ai_gen_id }}');
        this.prevButton      = this.querySelector('.ai-video-slider-prev-{{ ai_gen_id }}');
        this.nextButton      = this.querySelector('.ai-video-slider-next-{{ ai_gen_id }}');
        this.dots            = this.querySelectorAll('.ai-video-slider-dot-{{ ai_gen_id }}');
        this.totalSlides     = this.slides.length;

        if (this.totalSlides <= 1) return;

        // ── Navigation buttons ──
        if (this.prevButton) this.prevButton.addEventListener('click', () => this.goToPrevious());
        if (this.nextButton) this.nextButton.addEventListener('click', () => this.goToNext());

        // ── Dots ──
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        // ── Auto-advance on video end ──
        this.slides.forEach((slide, index) => {
          const video = slide.querySelector('video');
          if (video) {
            video.addEventListener('ended', () => {
              if (index !== this.currentIndex) return;
              if (this.currentIndex < this.totalSlides - 1) {
                this.goToNext();
                // Play the newly visible video
                const nextVideo = this.slides[this.currentIndex].querySelector('video');
                if (nextVideo) {
                  nextVideo.currentTime = 0;
                  nextVideo.play().catch(() => {});
                }
              }
            });
          }
        });

        this.updateSlider();
      }

      goToNext() {
        this.currentIndex = (this.currentIndex + 1) % this.totalSlides;
        this.updateSlider();
      }

      goToPrevious() {
        this.currentIndex = (this.currentIndex - 1 + this.totalSlides) % this.totalSlides;
        this.updateSlider();
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateSlider();
      }

      updateSlider() {
        const offset = -this.currentIndex * 100;
        this.slidesContainer.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === this.currentIndex);
        });

        if (this.prevButton) this.prevButton.disabled = this.currentIndex === 0;
        if (this.nextButton) this.nextButton.disabled = this.currentIndex === this.totalSlides - 1;

        // Pause all videos then play current
        this.slides.forEach((slide, i) => {
          const v = slide.querySelector('video');
          if (!v) return;
          if (i === this.currentIndex) {
            v.currentTime = 0;
            v.play().catch(() => {});
          } else {
            v.pause();
          }
        });
      }
    }

    customElements.define('video-slider-{{ ai_gen_id }}', VideoSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Video Slider + Products",
  "tag": null,
  "settings": [

    { "type": "header", "content": "Videos" },
    { "type": "video",    "id": "video_1", "label": "Video 1" },
    { "type": "video",    "id": "video_2", "label": "Video 2" },
    { "type": "video",    "id": "video_3", "label": "Video 3" },
    { "type": "checkbox", "id": "autoplay",  "label": "Autoplay first video", "default": true },
    { "type": "checkbox", "id": "muted",     "label": "Mute videos",          "default": true },
    { "type": "checkbox", "id": "controls",  "label": "Show video controls",  "default": false },
    {
      "type": "range",
      "id": "video_border_radius",
      "min": 0, "max": 40, "step": 2, "unit": "px",
      "label": "Video border radius",
      "default": 12
    },

    { "type": "header", "content": "Content" },
    { "type": "inline_richtext", "id": "subtitle",  "label": "Subtitle",  "default": "Discover" },
    { "type": "inline_richtext", "id": "heading",   "label": "Heading",   "default": "Timeless elegance" },
    {
      "type": "richtext", "id": "paragraph", "label": "Paragraph",
      "default": "<p>Experience the beauty of handcrafted jewelry designed to celebrate life's precious moments.</p>"
    },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range", "id": "padding_top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Padding top (desktop)", "default": 60
    },
    {
      "type": "range", "id": "padding_bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Padding bottom (desktop)", "default": 60
    },
    {
      "type": "range", "id": "mobile_padding_top",
      "min": 0, "max": 80, "step": 4, "unit": "px",
      "label": "Padding top (mobile)", "default": 32
    },
    {
      "type": "range", "id": "mobile_padding_bottom",
      "min": 0, "max": 80, "step": 4, "unit": "px",
      "label": "Padding bottom (mobile)", "default": 32
    },

    { "type": "header", "content": "Layout" },
    {
      "type": "range", "id": "desktop_width_percent",
      "min": 50, "max": 100, "step": 5, "unit": "%",
      "label": "Desktop width", "default": 100
    },
    {
      "type": "range", "id": "gap",
      "min": 20, "max": 100, "step": 10, "unit": "px",
      "label": "Gap between video and content", "default": 40
    },
    {
      "type": "range", "id": "mobile_gap",
      "min": 10, "max": 60, "step": 5, "unit": "px",
      "label": "Mobile gap", "default": 30
    },
    {
      "type": "range", "id": "content_padding",
      "min": 0, "max": 60, "step": 5, "unit": "px",
      "label": "Content padding", "default": 20
    },
    {
